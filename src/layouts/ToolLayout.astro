---
// Reusable wrapper for tool pages. Handles breadcrumb, H1, intro, the FAQ
// section, and the SEO structured data (SoftwareApplication + FAQPage) so each
// tool page only needs to provide its tool UI and a bit of content.
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/site.js';
import { categories, tools } from '../data/tools.js';

const {
  title,
  description,
  intro,
  category, // { id, name }
  faqs = [],
  appCategory = 'UtilitiesApplication',
  hideDisclaimer = false,
  ogImage, // optional per-tool social card; forwarded to BaseLayout
} = Astro.props;

const liveTools = tools.filter((t) => t.enabled && t.status === 'live');
const categoryCounts = Object.fromEntries(
  categories.map((c) => [c.id, liveTools.filter((t) => t.category === c.id).length])
);
const otherCategories = categories.filter((c) => c.id !== category.id && categoryCounts[c.id] > 0);

// Category-level disclaimers — shown automatically on every tool in these categories.
const disclaimers = {
  islamic: 'For general guidance only. These tools use standard, widely accepted calculations and values, but rulings differ between scholars and schools of thought. Calculated Hijri dates, prayer/Sehri/Iftar times and Qibla direction are based on astronomical calculation and may differ from local moon-sighting or measurement. For Zakat, Khums, inheritance and other religious or financial obligations, please verify with a qualified scholar before acting.',
  health: 'For general information only — this is not medical advice. Results are estimates and must not replace professional diagnosis, advice or treatment. Consult a qualified healthcare professional for any personal health decision.',
  finance: 'For general information only — this is not financial, tax, investment or legal advice. Results are estimates; confirm figures with a qualified professional before making any financial decision.',
  construction: 'Results are estimates for planning only. Always verify quantities, measurements and structural loads against local building codes and a qualified professional before purchasing materials or building.',
  engineering: 'Results are estimates for educational and preliminary purposes only. Verify with full engineering calculations and a qualified professional before relying on them for any real design or safety-critical use.',
  physics: 'This tool is provided for educational purposes to support learning in physics. It is not a substitute for professional engineering or safety-critical calculations.',
  chemistry: 'This tool is provided for educational purposes to support learning in chemistry. It is not a substitute for professional laboratory, safety, or dosage calculations.',
  biology: 'This tool is provided for educational purposes to support learning in biology. It is not a substitute for professional laboratory, clinical, or diagnostic use.',
  automotive: 'Results are estimates for general guidance only. Always follow your vehicle manufacturer’s specifications and consult a qualified mechanic for safety-critical decisions.',
};
const disclaimer = hideDisclaimer ? null : disclaimers[category.id];

const pageUrl = new URL(Astro.url.pathname, site.url).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: `${title} — ${site.name}`,
      applicationCategory: appCategory,
      operatingSystem: 'Any (web browser)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description,
      author: { '@id': `${site.url}/#organization` },
    },
    ...(faqs.length
      ? [{
          '@type': 'FAQPage',
          mainEntity: faqs.map((f) => ({
            '@type': 'Question',
            name: f.q,
            acceptedAnswer: { '@type': 'Answer', text: f.a },
          })),
        }]
      : []),
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
        { '@type': 'ListItem', position: 2, name: 'Tools', item: `${site.url}/tools/` },
        { '@type': 'ListItem', position: 3, name: category.name, item: `${site.url}/tools/${category.id}` },
        { '@type': 'ListItem', position: 4, name: title, item: pageUrl },
      ],
    },
    // WebPage + Speakable: tells voice assistants and AI answer engines which
    // parts of the page are safe to read aloud (the title and the FAQ answers).
    {
      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      url: pageUrl,
      name: `${title} — ${site.name}`,
      isPartOf: { '@id': `${site.url}/#organization` },
      speakable: {
        '@type': 'SpeakableSpecification',
        cssSelector: ['h1', '.faq-a'],
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} ogImage={ogImage}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <nav class="mb-4 text-sm text-slate-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-1">›</span>
      <a href={`/tools/${category.id}`} class="hover:text-indigo-600">{category.name}</a>
      <span class="mx-1">›</span>
      <span class="text-slate-700">{title}</span>
    </nav>

    <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{title}</h1>
    {intro && <p class="mt-2 text-slate-600">{intro}</p>}

    <p class="mt-3 text-xs text-slate-400">Reviewed by the <a href="/about/" class="text-indigo-500 hover:text-indigo-600">ToolNestr Team</a> &mdash; {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</p>

    {disclaimer && (
      <div class="mt-4 flex gap-2.5 rounded-xl border border-amber-300 bg-amber-50 p-3 text-sm text-amber-800 dark:border-amber-500/40 dark:bg-amber-950/30 dark:text-amber-200" role="note">
        <svg class="mt-0.5 h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
        <span><strong>Disclaimer:</strong> {disclaimer}</span>
      </div>
    )}

    <!-- Tool UI + page-specific content goes here -->
    <slot />

    {faqs.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-slate-900">Frequently asked questions</h2>
        <div class="mt-3 space-y-4">
          {faqs.map((f) => (
            <div class="rounded-xl border border-slate-200 bg-white p-4">
              <h3 class="font-semibold text-slate-900">{f.q}</h3>
              <p class="faq-a mt-1 text-sm text-slate-600">{f.a}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="mt-8 border-t border-slate-200 pt-8">
      <h2 class="text-xl font-bold text-slate-900">All tool categories</h2>
      <div class="mt-4 space-y-1.5">
        <!-- current category shown first, expanded -->
        <details class="group rounded-xl border border-indigo-200 bg-indigo-50" open>
          <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-indigo-700">
            <span>{category.emoji} {category.name} <span class="font-normal text-indigo-500">({categoryCounts[category.id]} tools)</span></span>
            <svg class="h-4 w-4 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="grid gap-2 border-t border-indigo-200 px-4 pb-3 pt-3 sm:grid-cols-2 lg:grid-cols-3">
            {liveTools.filter((t) => t.category === category.id && t.slug !== Astro.url.pathname.split('/').pop()).map((t) => (
              <a href={`/tools/${t.slug}`} class="flex items-center gap-2 rounded-lg bg-white px-3 py-2 text-sm text-slate-700 transition hover:bg-indigo-100 hover:text-indigo-700">{t.emoji} {t.title}</a>
            ))}
          </div>
        </details>
        <!-- other categories, collapsed -->
        {otherCategories.map((c) => (
          <details class="group rounded-xl border border-slate-200 bg-white">
            <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-slate-800">
              <span>{c.emoji} {c.name} <span class="font-normal text-slate-400">({categoryCounts[c.id]} tools)</span></span>
              <svg class="h-4 w-4 text-slate-400 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="grid gap-2 border-t border-slate-200 px-4 pb-3 pt-3 sm:grid-cols-2 lg:grid-cols-3">
              {liveTools.filter((t) => t.category === c.id).map((t) => (
                <a href={`/tools/${t.slug}`} class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-indigo-700">{t.emoji} {t.title}</a>
              ))}
            </div>
          </details>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
