---
// Reusable wrapper for tool pages. Handles breadcrumb, H1, intro, the FAQ
// section, and the SEO structured data (SoftwareApplication + FAQPage) so each
// tool page only needs to provide its tool UI and a bit of content.
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/site.js';
import { categories, tools } from '../data/tools.js';

const {
  title,
  description,
  intro,
  category, // { id, name }
  faqs = [],
  appCategory = 'UtilitiesApplication',
} = Astro.props;

const liveTools = tools.filter((t) => t.enabled && t.status === 'live');
const categoryCounts = Object.fromEntries(
  categories.map((c) => [c.id, liveTools.filter((t) => t.category === c.id).length])
);
const otherCategories = categories.filter((c) => c.id !== category.id && categoryCounts[c.id] > 0);

const pageUrl = new URL(Astro.url.pathname, site.url).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: `${title} — ${site.name}`,
      applicationCategory: appCategory,
      operatingSystem: 'Any (web browser)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description,
      author: { '@type': 'Organization', name: site.name, url: site.url },
    },
    ...(faqs.length
      ? [{
          '@type': 'FAQPage',
          mainEntity: faqs.map((f) => ({
            '@type': 'Question',
            name: f.q,
            acceptedAnswer: { '@type': 'Answer', text: f.a },
          })),
        }]
      : []),
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
        { '@type': 'ListItem', position: 2, name: 'Tools', item: `${site.url}/tools/` },
        { '@type': 'ListItem', position: 3, name: category.name, item: `${site.url}/tools/${category.id}` },
        { '@type': 'ListItem', position: 4, name: title, item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <nav class="mb-4 text-sm text-slate-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-1">›</span>
      <a href={`/tools/${category.id}`} class="hover:text-indigo-600">{category.name}</a>
      <span class="mx-1">›</span>
      <span class="text-slate-700">{title}</span>
    </nav>

    <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{title}</h1>
    {intro && <p class="mt-2 text-slate-600">{intro}</p>}

    <p class="mt-3 text-xs text-slate-400">Reviewed by the <a href="/about/" class="text-indigo-500 hover:text-indigo-600">ToolNestr Team</a> &mdash; {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</p>

    <!-- Tool UI + page-specific content goes here -->
    <slot />

    {faqs.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-slate-900">Frequently asked questions</h2>
        <div class="mt-3 space-y-4">
          {faqs.map((f) => (
            <div class="rounded-xl border border-slate-200 bg-white p-4">
              <h3 class="font-semibold text-slate-900">{f.q}</h3>
              <p class="mt-1 text-sm text-slate-600">{f.a}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="mt-8 border-t border-slate-200 pt-8">
      <h2 class="text-xl font-bold text-slate-900">All tool categories</h2>
      <div class="mt-4 space-y-1.5">
        <!-- current category shown first, expanded -->
        <details class="group rounded-xl border border-indigo-200 bg-indigo-50" open>
          <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-indigo-800">
            <span>{category.emoji} {category.name} <span class="font-normal text-indigo-500">({categoryCounts[category.id]} tools)</span></span>
            <svg class="h-4 w-4 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="grid gap-2 border-t border-indigo-200 px-4 pb-3 pt-3 sm:grid-cols-2 lg:grid-cols-3">
            {liveTools.filter((t) => t.category === category.id && t.slug !== Astro.url.pathname.split('/').pop()).map((t) => (
              <a href={`/tools/${t.slug}`} class="flex items-center gap-2 rounded-lg bg-white px-3 py-2 text-sm text-slate-700 transition hover:bg-indigo-100 hover:text-indigo-700">{t.emoji} {t.title}</a>
            ))}
          </div>
        </details>
        <!-- other categories, collapsed -->
        {otherCategories.map((c) => (
          <details class="group rounded-xl border border-slate-200 bg-white">
            <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-slate-800">
              <span>{c.emoji} {c.name} <span class="font-normal text-slate-400">({categoryCounts[c.id]} tools)</span></span>
              <svg class="h-4 w-4 text-slate-400 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="grid gap-2 border-t border-slate-200 px-4 pb-3 pt-3 sm:grid-cols-2 lg:grid-cols-3">
              {liveTools.filter((t) => t.category === c.id).map((t) => (
                <a href={`/tools/${t.slug}`} class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-indigo-700">{t.emoji} {t.title}</a>
              ))}
            </div>
          </details>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
