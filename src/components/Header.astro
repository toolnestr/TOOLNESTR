---
import { site } from '../data/site.js';
import { categories } from '../data/tools.js';
---

<header class="sticky top-0 z-30 border-b border-slate-200 bg-white/90 backdrop-blur dark:border-slate-700 dark:bg-slate-900/90">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 font-bold text-slate-900 dark:text-white">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 text-white shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 32 32" fill="none">
          <path d="M10 11h12M10 16h12M10 21h7" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
          <circle cx="22" cy="21" r="2" fill="currentColor" />
        </svg>
      </span>
      <span class="text-lg tracking-tight">{site.name}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-3 text-sm font-medium text-slate-600 dark:text-slate-300 lg:flex lg:whitespace-nowrap">
      <a href="/tools/seo-analyzer" class="rounded-lg bg-gradient-to-r from-indigo-500 to-violet-600 px-4 py-1.5 text-white shadow-sm transition hover:from-indigo-600 hover:to-violet-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="-mt-0.5 inline h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        SEO Analyzer
      </a>
      <a href="/tools/ip-tracker" class="rounded-lg bg-gradient-to-r from-emerald-500 to-teal-600 px-4 py-1.5 text-white shadow-sm transition hover:from-emerald-600 hover:to-teal-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="-mt-0.5 inline h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" /></svg>
        IP Tracker
      </a>
      {categories.slice(0, 4).map((c) => (
        <a href={`/tools/${c.id}/`} class="whitespace-nowrap transition hover:text-indigo-600 dark:hover:text-indigo-400">{c.name}</a>
      ))}
      {categories.length > 4 && (
        <div class="relative dropdown-group">
          <button id="more-btn" aria-expanded="false" class="flex items-center gap-1 whitespace-nowrap transition hover:text-indigo-600 dark:hover:text-indigo-400">
            More <svg class="h-3 w-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div id="more-dropdown" class="absolute right-0 top-full z-40 mt-2 hidden max-h-[70vh] w-56 overflow-y-auto rounded-xl border border-slate-200 bg-white p-2 shadow-lg dark:border-slate-700 dark:bg-slate-800">
            {categories.slice(4).map((c) => (
              <a href={`/tools/${c.id}/`} class="flex items-center gap-2 rounded-lg px-3 py-2 transition hover:bg-slate-100 dark:hover:bg-slate-700"><span class="w-5 text-center">{c.emoji}</span> {c.name}</a>
            ))}
          </div>
        </div>
      )}
      <a href="/about" class="whitespace-nowrap transition hover:text-indigo-600 dark:hover:text-indigo-400">About</a>
      <span class="h-5 w-px bg-slate-200 dark:bg-slate-700" aria-hidden="true"></span>
      <button id="theme-toggle" aria-label="Toggle dark mode" class="rounded-lg p-2 text-slate-500 transition hover:bg-slate-100 hover:text-indigo-600 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-indigo-400">
        <svg class="theme-sun hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
        <svg class="theme-moon hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
      </button>
    </nav>

    <!-- Mobile controls -->
    <div class="flex items-center gap-1 lg:hidden">
      <button id="theme-toggle-m" aria-label="Toggle dark mode" class="rounded-lg p-2 text-slate-500 transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
        <svg class="theme-sun hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
        <svg class="theme-moon hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
      </button>
      <button id="menu-btn" aria-label="Open menu" aria-expanded="false" class="rounded-lg p-2 text-slate-600 transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
        <svg id="menu-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
        <svg id="menu-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <nav id="mobile-menu" class="hidden max-h-[75vh] overflow-y-auto border-t border-slate-200 bg-white px-4 py-3 dark:border-slate-700 dark:bg-slate-900 lg:hidden">
    {categories.map((c) => (
      <a href={`/tools/${c.id}/`} class="mobile-link flex items-center gap-2.5 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"><span class="w-5 text-center">{c.emoji}</span> {c.name}</a>
    ))}
    <a href="/about" class="mobile-link mt-1 flex items-center gap-2.5 border-t border-slate-100 px-3 pt-3 pb-2.5 text-sm font-medium text-slate-700 transition hover:text-indigo-600 dark:border-slate-800 dark:text-slate-200">About</a>
  </nav>
</header>

<script>
  // ── Dark-mode toggle ──
  function syncThemeIcons() {
    var dark = document.documentElement.classList.contains('dark');
    document.querySelectorAll('.theme-sun').forEach(function (e) { e.classList.toggle('hidden', !dark); });
    document.querySelectorAll('.theme-moon').forEach(function (e) { e.classList.toggle('hidden', dark); });
  }
  function toggleTheme() {
    var dark = document.documentElement.classList.toggle('dark');
    try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
    syncThemeIcons();
  }
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-m')?.addEventListener('click', toggleTheme);
  syncThemeIcons();

  // ── Mobile menu ──
  var menuBtn = document.getElementById('menu-btn');
  var menu = document.getElementById('mobile-menu');
  var iOpen = document.getElementById('menu-open');
  var iClose = document.getElementById('menu-close');
  function closeMenu() {
    menu.classList.add('hidden');
    iOpen.classList.remove('hidden');
    iClose.classList.add('hidden');
    menuBtn.setAttribute('aria-expanded', 'false');
  }
  menuBtn?.addEventListener('click', function () {
    var open = menu.classList.toggle('hidden');
    iOpen.classList.toggle('hidden', !open);
    iClose.classList.toggle('hidden', open);
    menuBtn.setAttribute('aria-expanded', String(!open));
  });
  document.querySelectorAll('.mobile-link').forEach(function (l) { l.addEventListener('click', closeMenu); });

  // ── More dropdown ──
  var moreBtn = document.getElementById('more-btn');
  var moreDropdown = document.getElementById('more-dropdown');
  if (moreBtn && moreDropdown) {
    var moreChevron = moreBtn.querySelector('svg');
    function syncMore() {
      var open = !moreDropdown.classList.contains('hidden');
      moreBtn.setAttribute('aria-expanded', String(open));
      if (moreChevron) moreChevron.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
    }
    moreBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      moreDropdown.classList.toggle('hidden');
      syncMore();
    });
    document.addEventListener('click', function () { moreDropdown.classList.add('hidden'); syncMore(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') { moreDropdown.classList.add('hidden'); syncMore(); } });
    moreDropdown.addEventListener('click', function (e) { e.stopPropagation(); });
  }
</script>
