---
import { site } from '../data/site.js';
import { categories, liveTools } from '../data/tools.js';
---

<header class="sticky top-0 z-30 border-b border-slate-200 bg-white/90 backdrop-blur dark:border-slate-700 dark:bg-slate-900/90">
  <div class="relative z-30 mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
    <!-- Logo -->
    <a href="/" class="group flex shrink-0 items-center gap-2.5 font-bold text-slate-900 dark:text-white">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-slate-900 text-white shadow-sm transition-transform duration-300 group-hover:scale-105 dark:bg-white dark:text-slate-900">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 32 32" fill="none">
          <path d="M10 11h12M10 16h12M10 21h7" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
          <circle cx="22" cy="21" r="2" fill="currentColor" />
        </svg>
      </span>
      <span class="text-lg tracking-tight transition-colors group-hover:text-slate-600 dark:group-hover:text-slate-300">{site.name}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-2.5 text-sm font-medium text-slate-600 dark:text-slate-300 xl:flex xl:whitespace-nowrap">
      <a href="/tools/dropspot" class="press inline-flex items-center gap-1.5 rounded-lg bg-slate-900 px-3 py-1.5 text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-slate-800 hover:shadow-md dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" /></svg>
        Dropspot
      </a>
      <a href="/tools/seo-analyzer" class="press inline-flex items-center gap-1.5 rounded-lg bg-slate-900 px-3 py-1.5 text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-slate-800 hover:shadow-md dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        SEO Analyzer
      </a>
      <a href="/tools/ip-tracker" class="press inline-flex items-center gap-1.5 rounded-lg bg-slate-900 px-3 py-1.5 text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-slate-800 hover:shadow-md dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" /></svg>
        IP Tracker
      </a>
      {categories.slice(0, 4).map((c) => (
        <a href={`/tools/${c.id}/`} class="nav-underline whitespace-nowrap transition hover:text-slate-900 dark:hover:text-white">{c.name}</a>
      ))}
      {categories.length > 4 && (
        <div class="relative dropdown-group">
          <button id="more-btn" aria-expanded="false" class="inline-flex items-center gap-1 whitespace-nowrap rounded-lg border border-slate-200 bg-slate-50 px-2.5 py-1.5 font-medium text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:bg-slate-100 hover:text-slate-900 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700 dark:hover:text-white">
            More <span class="rounded bg-slate-200 px-1 text-[11px] font-semibold text-slate-500 dark:bg-slate-700 dark:text-slate-300">{categories.length - 4}</span>
            <svg class="h-3 w-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div id="more-dropdown" class="absolute right-0 top-full z-40 mt-2 hidden max-h-[70vh] w-56 overflow-y-auto rounded-xl border border-slate-200 bg-white p-2 shadow-lg dark:border-slate-700 dark:bg-slate-800">
            {categories.slice(4).map((c) => (
              <a href={`/tools/${c.id}/`} class="flex items-center gap-2 rounded-lg px-3 py-2 transition hover:bg-slate-100 dark:hover:bg-slate-700"><span class="w-5 text-center">{c.emoji}</span> {c.name}</a>
            ))}
          </div>
        </div>
      )}
      <a href="/about" class="nav-underline whitespace-nowrap transition hover:text-slate-900 dark:hover:text-white">About</a>
      <span class="h-5 w-px bg-slate-200 dark:bg-slate-700" aria-hidden="true"></span>
      <button
        id="search-trigger"
        type="button"
        aria-haspopup="dialog"
        title="Search tools (Ctrl+K)"
        aria-label="Search tools"
        class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-600 shadow-sm transition hover:border-slate-300 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:text-white"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      </button>
      <button id="theme-toggle" aria-label="Toggle dark mode" class="rounded-lg p-2 text-slate-500 transition hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white">
        <svg class="theme-sun hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
        <svg class="theme-moon hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
      </button>
    </nav>

    <!-- Mobile controls -->
    <div class="flex items-center gap-1 xl:hidden">
      <button id="search-trigger-m" aria-label="Search tools" aria-haspopup="dialog" class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-600 shadow-sm transition active:scale-95 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      </button>
      <button id="theme-toggle-m" aria-label="Toggle dark mode" class="rounded-lg p-2 text-slate-500 transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
        <svg class="theme-sun hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
        <svg class="theme-moon hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
      </button>
      <button id="menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" class="press relative h-10 w-10 rounded-lg p-2 text-slate-700 transition hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
        <span class="ham-line ham-top absolute left-1/2 top-[13px] block h-0.5 w-5 -translate-x-1/2 rounded-full bg-current"></span>
        <span class="ham-line ham-mid absolute left-1/2 top-[19px] block h-0.5 w-5 -translate-x-1/2 rounded-full bg-current"></span>
        <span class="ham-line ham-bottom absolute left-1/2 top-[25px] block h-0.5 w-5 -translate-x-1/2 rounded-full bg-current"></span>
      </button>
    </div>
  </div>

  <!-- Scrim behind the mobile menu -->
  <div id="menu-scrim" class="xl:hidden" aria-hidden="true"></div>

  <!-- Mobile slide-in menu -->
  <nav id="mobile-menu" class="absolute inset-x-0 top-full z-40 max-h-[80vh] overflow-y-auto rounded-b-2xl border-t border-slate-200 bg-white/95 px-3 py-3 shadow-xl shadow-slate-900/10 backdrop-blur-lg dark:border-slate-700 dark:bg-slate-900/95 dark:shadow-black/40 xl:hidden">
    <p class="px-3 pb-1.5 pt-1 text-[11px] font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">Browse categories</p>
    {categories.map((c, i) => (
      <a href={`/tools/${c.id}/`} style={`animation-delay:${40 + i * 28}ms`} class="mobile-link flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-slate-700 transition active:scale-[0.98] hover:bg-slate-100 hover:text-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-white">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-base dark:bg-slate-800">{c.emoji}</span>
        <span class="flex-1">{c.name}</span>
        <svg class="h-4 w-4 text-slate-300 dark:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
      </a>
    ))}
    <a href="/about" style={`animation-delay:${40 + categories.length * 28}ms`} class="mobile-link mt-1.5 flex items-center gap-3 border-t border-slate-100 px-3 pt-3.5 pb-2 text-sm font-semibold text-slate-700 transition hover:text-slate-900 dark:border-slate-800 dark:text-slate-200">About ToolNestr</a>
  </nav>

  <!-- Site-wide tool search (command-palette style) -->
  <div id="search-overlay" class="fixed inset-0 z-50 hidden items-start justify-center bg-slate-900/50 px-4 pt-[10vh] backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Search tools">
    <div id="search-panel" class="w-full max-w-xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl shadow-slate-900/10 dark:border-slate-700 dark:bg-slate-800 dark:shadow-black/40">
      <div class="flex items-center gap-3 border-b border-slate-200 px-4 py-3 dark:border-slate-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search any tool… (e.g. subnet, tip calculator, BMI)"
          autocomplete="off"
          spellcheck="false"
          class="w-full border-0 bg-transparent text-base text-slate-900 outline-none placeholder:text-slate-400 dark:text-white"
        />
        <button id="search-close" aria-label="Close search" class="shrink-0 rounded-lg p-1 text-slate-400 transition hover:bg-slate-100 hover:text-slate-600 dark:hover:bg-slate-700 dark:hover:text-slate-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2"></div>
      <div id="search-empty" class="hidden px-4 py-10 text-center text-sm text-slate-400">No tools match your search.</div>
      <div id="search-hint" class="px-4 py-10 text-center text-sm text-slate-400">Start typing to search {liveTools.length}+ tools…</div>
      <div class="hidden items-center gap-4 border-t border-slate-100 px-4 py-2 text-[11px] text-slate-400 dark:border-slate-700 sm:flex">
        <span><kbd class="rounded border border-slate-300 px-1 dark:border-slate-600">&uarr;</kbd> <kbd class="rounded border border-slate-300 px-1 dark:border-slate-600">&darr;</kbd> navigate</span>
        <span><kbd class="rounded border border-slate-300 px-1 dark:border-slate-600">Enter</kbd> open</span>
        <span><kbd class="rounded border border-slate-300 px-1 dark:border-slate-600">Esc</kbd> close</span>
      </div>
    </div>
  </div>
</header>

<style>
  #search-overlay {
    opacity: 0;
    transition: opacity 0.16s ease;
  }
  #search-overlay.search-open {
    opacity: 1;
  }
  #search-panel {
    transform: scale(0.97) translateY(-6px);
    transition: transform 0.16s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #search-overlay.search-open #search-panel {
    transform: scale(1) translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    #search-overlay,
    #search-panel {
      transition: none;
    }
  }
</style>

<script define:vars={{ categoryMap: Object.fromEntries(categories.map((c) => [c.id, { name: c.name, emoji: c.emoji }])) }}>
  window.__TOOLNESTR_CATEGORIES__ = categoryMap;
</script>

<script>
  // ── Dark-mode toggle ──
  function syncThemeIcons() {
    var dark = document.documentElement.classList.contains('dark');
    document.querySelectorAll('.theme-sun').forEach(function (e) { e.classList.toggle('hidden', !dark); });
    document.querySelectorAll('.theme-moon').forEach(function (e) { e.classList.toggle('hidden', dark); });
  }
  function toggleTheme() {
    var dark = document.documentElement.classList.toggle('dark');
    try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
    syncThemeIcons();
  }
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-m')?.addEventListener('click', toggleTheme);
  syncThemeIcons();

  // ── Mobile menu (slide-in panel + scrim) ──
  var menuBtn = document.getElementById('menu-btn');
  var menu = document.getElementById('mobile-menu');
  var scrim = document.getElementById('menu-scrim');
  function setMenu(open) {
    if (!menu) return;
    menu.classList.toggle('open', open);
    if (scrim) scrim.classList.toggle('show', open);
    menuBtn.setAttribute('aria-expanded', String(open));
    menuBtn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.style.overflow = open ? 'hidden' : '';
  }
  function closeMenu() { setMenu(false); }
  menuBtn?.addEventListener('click', function () {
    setMenu(!menu.classList.contains('open'));
  });
  scrim?.addEventListener('click', closeMenu);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });
  document.querySelectorAll('.mobile-link').forEach(function (l) { l.addEventListener('click', closeMenu); });

  // ── More dropdown ──
  var moreBtn = document.getElementById('more-btn');
  var moreDropdown = document.getElementById('more-dropdown');
  if (moreBtn && moreDropdown) {
    var moreChevron = moreBtn.querySelector('svg');
    function syncMore() {
      var open = !moreDropdown.classList.contains('hidden');
      moreBtn.setAttribute('aria-expanded', String(open));
      if (moreChevron) moreChevron.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
    }
    moreBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      moreDropdown.classList.toggle('hidden');
      syncMore();
    });
    document.addEventListener('click', function () { moreDropdown.classList.add('hidden'); syncMore(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') { moreDropdown.classList.add('hidden'); syncMore(); } });
    moreDropdown.addEventListener('click', function (e) { e.stopPropagation(); });
  }

  // ── Site-wide tool search ──
  (function () {
    var overlay = document.getElementById('search-overlay');
    var panel = document.getElementById('search-panel');
    var input = document.getElementById('search-input');
    var resultsEl = document.getElementById('search-results');
    var emptyEl = document.getElementById('search-empty');
    var hintEl = document.getElementById('search-hint');
    var closeBtn = document.getElementById('search-close');
    var triggers = [document.getElementById('search-trigger'), document.getElementById('search-trigger-m')];
    if (!overlay || !input) return;

    var CATS = window.__TOOLNESTR_CATEGORIES__ || {};
    var data = null; // lazily loaded tool index
    var loading = null;
    var matches = [];
    var selected = -1;

    function loadData() {
      if (data) return Promise.resolve(data);
      if (loading) return loading;
      loading = fetch('/search-index.json')
        .then(function (r) { return r.json(); })
        .then(function (json) { data = json; return data; })
        .catch(function () { data = []; return data; });
      return loading;
    }

    function esc(s) {
      var d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function highlight(text, q) {
      if (!q) return esc(text);
      var idx = text.toLowerCase().indexOf(q.toLowerCase());
      if (idx === -1) return esc(text);
      return esc(text.slice(0, idx)) + '<mark class="rounded bg-slate-200 text-slate-900 dark:bg-slate-600 dark:text-white">' + esc(text.slice(idx, idx + q.length)) + '</mark>' + esc(text.slice(idx + q.length));
    }

    function score(tool, q, words) {
      var title = tool.t.toLowerCase();
      if (title === q) return 0;
      if (title.indexOf(q) === 0) return 1;
      if (title.indexOf(q) !== -1) return 2;
      // every word appears in the title (in any order/position) -- e.g.
      // "ip tracker" should rank "IP Address Tracker" above a description-only hit
      if (words.every(function (w) { return title.indexOf(w) !== -1; })) return 3;
      if ((tool.d || '').toLowerCase().indexOf(q) !== -1) return 4;
      return 5;
    }

    function render(query) {
      var q = query.trim().toLowerCase();
      if (!q) {
        resultsEl.innerHTML = '';
        emptyEl.classList.add('hidden');
        hintEl.classList.remove('hidden');
        matches = [];
        selected = -1;
        return;
      }
      hintEl.classList.add('hidden');

      var words = q.split(/\s+/).filter(Boolean);
      matches = (data || []).filter(function (t) {
        var haystack = (t.t + ' ' + (t.d || '') + ' ' + t.s.replace(/-/g, ' ')).toLowerCase();
        // every word in the query must appear somewhere (AND match), so
        // "ip tracker" finds "IP Address Tracker" even though the words
        // aren't contiguous in the title.
        return words.every(function (w) { return haystack.indexOf(w) !== -1; });
      }).sort(function (a, b) { return score(a, q, words) - score(b, q, words); }).slice(0, 8);

      if (matches.length === 0) {
        resultsEl.innerHTML = '';
        emptyEl.classList.remove('hidden');
        selected = -1;
        return;
      }
      emptyEl.classList.add('hidden');
      selected = 0;

      resultsEl.innerHTML = matches.map(function (t, i) {
        var cat = CATS[t.c] || { name: t.c, emoji: '🔧' };
        return '<a href="/tools/' + t.s + '/" data-idx="' + i + '" class="search-result flex items-center gap-3 rounded-xl px-3 py-2.5 transition ' +
          (i === selected ? 'bg-slate-100 dark:bg-slate-700/60' : 'hover:bg-slate-50 dark:hover:bg-slate-700/50') + '">' +
          '<span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-base dark:bg-slate-700">' + esc(t.e || cat.emoji) + '</span>' +
          '<span class="min-w-0 flex-1">' +
            '<span class="block truncate text-sm font-medium text-slate-900 dark:text-white">' + highlight(t.t, q) + '</span>' +
            '<span class="block truncate text-xs text-slate-400">' + esc(cat.name) + '</span>' +
          '</span>' +
        '</a>';
      }).join('');
    }

    function updateSelectionStyles() {
      resultsEl.querySelectorAll('.search-result').forEach(function (el, i) {
        el.classList.toggle('bg-slate-100', i === selected);
        el.classList.toggle('dark:bg-slate-700/60', i === selected);
      });
      var activeEl = resultsEl.querySelector('[data-idx="' + selected + '"]');
      if (activeEl) activeEl.scrollIntoView({ block: 'nearest' });
    }

    function openSearch() {
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      document.body.style.overflow = 'hidden';
      loadData().then(function () { render(input.value); });
      setTimeout(function () { input.focus(); }, 10);
      // Force a reflow before adding the "open" class so the transition
      // actually plays instead of the panel snapping straight to its end state.
      overlay.offsetHeight;
      requestAnimationFrame(function () { overlay.classList.add('search-open'); });
    }

    function closeSearch() {
      overlay.classList.remove('search-open');
      setTimeout(function () {
        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
      }, 160);
      document.body.style.overflow = '';
    }

    triggers.forEach(function (btn) {
      if (btn) btn.addEventListener('click', openSearch);
    });
    closeBtn?.addEventListener('click', closeSearch);
    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closeSearch();
    });
    panel?.addEventListener('click', function (e) { e.stopPropagation(); });

    input.addEventListener('input', function () { render(input.value); });

    input.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (matches.length) { selected = (selected + 1) % matches.length; updateSelectionStyles(); }
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (matches.length) { selected = (selected - 1 + matches.length) % matches.length; updateSelectionStyles(); }
      } else if (e.key === 'Enter') {
        e.preventDefault();
        var target = matches[selected] || matches[0];
        if (target) window.location.href = '/tools/' + target.s + '/';
      }
    });

    document.addEventListener('keydown', function (e) {
      var isOpen = !overlay.classList.contains('hidden');
      if (e.key === 'Escape' && isOpen) { closeSearch(); return; }
      var isTypingElsewhere = /^(INPUT|TEXTAREA|SELECT)$/.test((document.activeElement && document.activeElement.tagName) || '') && document.activeElement !== input;
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k' && !isOpen) {
        e.preventDefault();
        openSearch();
      } else if (e.key === '/' && !isOpen && !isTypingElsewhere) {
        e.preventDefault();
        openSearch();
      }
    });
  })();
</script>
