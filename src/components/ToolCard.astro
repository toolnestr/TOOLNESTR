---
// One card in the homepage grid. Live tools link out; "soon" tools show a badge.
const { tool } = Astro.props;
const isLive = tool.enabled && tool.status === 'live';
const href = isLive ? `/tools/${tool.slug}` : undefined;
const Tag = isLive ? 'a' : 'div';
---

<Tag
  href={href}
  data-name={tool.title.toLowerCase()}
  class:list={[
    'tool-card group relative flex flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition duration-200',
    isLive
      ? 'cursor-pointer hover:-translate-y-1 hover:border-indigo-300 hover:shadow-lg hover:shadow-indigo-100/60 dark:hover:shadow-black/30'
      : 'opacity-70',
  ]}
>
  <div class="mb-3 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-xl">
    {tool.emoji}
  </div>
  <h3 class="font-semibold text-slate-900">{tool.title}</h3>
  <p class="mt-1 text-sm leading-relaxed text-slate-500">{tool.short}</p>

  {isLive
    ? <span class="mt-3 text-sm font-medium text-indigo-600">Try it free →</span>
    : <span class="absolute right-4 top-4 rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">Soon</span>
  }
</Tag>
