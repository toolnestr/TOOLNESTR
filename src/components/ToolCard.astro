---
// One card in a category grid. Compact horizontal layout: emoji tile on the left,
// title + one-line description, and a chevron that slides in on hover.
// `accent` picks the hover/arrow color so cards match their category's theme.
const { tool, accent = 'indigo' } = Astro.props;
const isLive = tool.enabled && tool.status === 'live';
const isFlagship = isLive && tool.flagship === true;
const href = isLive ? `/tools/${tool.slug}/` : undefined;
const Tag = isLive ? 'a' : 'div';

// Full class strings (no interpolation) so Tailwind's JIT scanner keeps them.
const accents = {
  indigo: {
    hover: 'hover:border-indigo-300 hover:shadow-indigo-200/50 dark:hover:border-indigo-500/40 dark:hover:shadow-black/30',
    arrow: 'group-hover:text-indigo-500 dark:group-hover:text-indigo-400',
    tile: 'from-indigo-50 to-violet-50 text-indigo-600 dark:from-indigo-500/20 dark:to-violet-500/20 dark:text-indigo-300',
  },
  amber: {
    hover: 'hover:border-amber-300 hover:shadow-amber-200/50 dark:hover:border-amber-500/40 dark:hover:shadow-amber-900/20',
    arrow: 'group-hover:text-amber-500 dark:group-hover:text-amber-400',
    tile: 'from-amber-50 to-orange-50 text-amber-600 dark:from-amber-500/15 dark:to-orange-500/15 dark:text-amber-300',
  },
  rose: {
    hover: 'hover:border-rose-300 hover:shadow-rose-200/50 dark:hover:border-rose-500/40 dark:hover:shadow-rose-900/20',
    arrow: 'group-hover:text-rose-500 dark:group-hover:text-rose-400',
    tile: 'from-rose-50 to-pink-50 text-rose-600 dark:from-rose-500/15 dark:to-pink-500/15 dark:text-rose-300',
  },
  fuchsia: {
    hover: 'hover:border-fuchsia-300 hover:shadow-fuchsia-200/50 dark:hover:border-fuchsia-500/40 dark:hover:shadow-fuchsia-900/20',
    arrow: 'group-hover:text-fuchsia-600 dark:group-hover:text-fuchsia-400',
    tile: 'from-fuchsia-50 to-purple-50 text-fuchsia-700 dark:from-fuchsia-500/15 dark:to-purple-500/15 dark:text-fuchsia-300',
  },
};
const a = accents[accent] ?? accents.indigo;
---

<Tag
  href={href}
  data-name={tool.title.toLowerCase()}
  class:list={[
    'tool-card card-enter group relative flex items-center gap-3.5 rounded-xl border p-3.5 shadow-sm transition-all duration-300',
    !isLive && 'cursor-default border-slate-200 bg-white opacity-60 dark:border-slate-700 dark:bg-slate-800/80 dark:opacity-50',
    isLive && !isFlagship && ['cursor-pointer border-slate-200 bg-white hover:-translate-y-0.5 hover:shadow-lg dark:border-slate-700 dark:bg-slate-800/80', a.hover],
    isFlagship && 'cursor-pointer border-indigo-300 bg-gradient-to-br from-indigo-50 to-violet-50 ring-1 ring-indigo-200 hover:-translate-y-0.5 hover:border-indigo-400 hover:shadow-lg hover:shadow-indigo-200/60 dark:border-indigo-500/60 dark:from-indigo-950/50 dark:to-violet-950/50 dark:ring-indigo-500/30',
  ]}
>
  <div class:list={[
    'flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br text-xl transition-transform duration-300 group-hover:scale-105',
    isFlagship ? 'from-indigo-100 to-violet-100 text-indigo-600 dark:from-indigo-500/30 dark:to-violet-500/30' : a.tile,
  ]}>
    {tool.emoji}
  </div>

  <div class="min-w-0 flex-1">
    <h3 class:list={[
      'truncate text-[15px] font-semibold leading-snug',
      isFlagship ? 'text-indigo-900 dark:text-indigo-100' : 'text-slate-900 dark:text-white',
    ]}>{tool.title}</h3>
    <p class="mt-0.5 line-clamp-2 text-xs leading-relaxed text-slate-500 dark:text-slate-400">{tool.short}</p>
  </div>

  {isLive
    ? (
      <svg class:list={['h-4 w-4 shrink-0 self-center text-slate-300 transition-all duration-300 group-hover:translate-x-0.5 dark:text-slate-600', a.arrow]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    )
    : <span class="badge-rose shrink-0 self-center rounded-full px-2 py-0.5 text-xs font-medium">Soon</span>
  }

  {isFlagship && (
    <span class="absolute -top-2 right-3 inline-flex items-center gap-1 rounded-full bg-indigo-600 px-2 py-0.5 text-[10px] font-semibold text-white shadow dark:bg-indigo-500">
      ★ Flagship
    </span>
  )}
</Tag>
