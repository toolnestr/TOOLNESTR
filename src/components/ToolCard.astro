---
// One card in the homepage grid. Live tools link out; "soon" tools show a badge.
const { tool } = Astro.props;
const isLive = tool.enabled && tool.status === 'live';
const isFlagship = isLive && tool.flagship === true;
const href = isLive ? `/tools/${tool.slug}` : undefined;
const Tag = isLive ? 'a' : 'div';
---

<Tag
  href={href}
  data-name={tool.title.toLowerCase()}
  class:list={[
    'tool-card card-enter group relative flex flex-col rounded-2xl border p-5 shadow-sm transition-all duration-300',
    !isLive && 'cursor-default opacity-60 border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-800/80 dark:opacity-50',
    isLive && !isFlagship && 'cursor-pointer border-slate-200 bg-white hover:-translate-y-1.5 hover:border-indigo-300 hover:shadow-xl hover:shadow-indigo-200/50 dark:border-slate-700 dark:bg-slate-800/80 dark:hover:border-indigo-500/40 dark:hover:shadow-black/30',
    isFlagship && 'btn-shine cursor-pointer border-indigo-300 bg-gradient-to-br from-indigo-50 to-violet-50 ring-1 ring-indigo-200 hover:-translate-y-1.5 hover:border-indigo-400 hover:shadow-xl hover:shadow-indigo-200/70 dark:border-indigo-500/60 dark:from-indigo-950/60 dark:to-violet-950/60 dark:ring-indigo-500/30 dark:hover:border-indigo-400/70 dark:hover:shadow-indigo-900/40',
  ]}
>
  {isFlagship && (
    <span class="absolute right-3 top-3 inline-flex items-center gap-1 rounded-full bg-indigo-600 px-2.5 py-0.5 text-xs font-semibold text-white shadow dark:bg-indigo-500">
      ★ Flagship
    </span>
  )}

  <div class:list={[
    'mb-3 inline-flex h-11 w-11 items-center justify-center rounded-xl text-xl transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-3',
    isFlagship
      ? 'bg-gradient-to-br from-indigo-100 to-violet-100 dark:from-indigo-500/30 dark:to-violet-500/30'
      : 'bg-gradient-to-br from-indigo-50 to-violet-50 dark:from-indigo-500/20 dark:to-violet-500/20',
  ]}>
    {tool.emoji}
  </div>

  <h3 class:list={[
    'font-semibold',
    isFlagship ? 'text-indigo-900 dark:text-indigo-100' : 'text-slate-900 dark:text-white',
  ]}>{tool.title}</h3>
  <p class="mt-1 text-sm leading-relaxed text-slate-500 dark:text-slate-400">{tool.short}</p>

  {isLive
    ? <span class:list={['mt-3 text-sm font-medium', isFlagship ? 'text-indigo-600 dark:text-indigo-400' : 'text-rose-600 dark:text-rose-400']}>Try it free →</span>
    : <span class="badge-rose absolute right-4 top-4 rounded-full px-2 py-0.5 text-xs font-medium">Soon</span>
  }
</Tag>
