---
// One card in the homepage grid. Live tools link out; "soon" tools show a badge.
const { tool } = Astro.props;
const isLive = tool.enabled && tool.status === 'live';
const href = isLive ? `/tools/${tool.slug}` : undefined;
const Tag = isLive ? 'a' : 'div';
---

<Tag
  href={href}
  data-name={tool.title.toLowerCase()}
  class:list={[
    'tool-card group relative flex flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-all duration-250',
    isLive
      ? 'cursor-pointer hover:-translate-y-1.5 hover:border-indigo-300 hover:shadow-lg hover:shadow-indigo-100/60 dark:border-slate-700 dark:bg-slate-800/80 dark:hover:border-indigo-500/40 dark:hover:shadow-black/30'
      : 'opacity-60 dark:opacity-50',
  ]}
>
  <div class="mb-3 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-50 to-violet-50 text-xl dark:from-indigo-500/20 dark:to-violet-500/20">
    {tool.emoji}
  </div>
  <h3 class="font-semibold text-slate-900 dark:text-white">{tool.title}</h3>
  <p class="mt-1 text-sm leading-relaxed text-slate-500 dark:text-slate-400">{tool.short}</p>

  {isLive
    ? <span class="mt-3 text-sm font-medium text-rose-600 dark:text-rose-400">Try it free →</span>
    : <span class="badge-rose absolute right-4 top-4 rounded-full px-2 py-0.5 text-xs font-medium">Soon</span>
  }
</Tag>
