---
import { site } from '../data/site.js';
const year = new Date().getFullYear();
---

<footer class="max-md:sticky max-md:bottom-0 max-md:z-10 border-t border-slate-200 bg-white md:static">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <a href="/" class="text-base font-bold text-slate-800">{site.name}</a>
      <nav class="flex flex-wrap gap-5 text-sm font-medium text-slate-600">
        <a href="/about" class="transition hover:text-indigo-600">About</a>
        <a href="/privacy" class="transition hover:text-indigo-600">Privacy</a>
        <a href="/contact" class="transition hover:text-indigo-600">Contact</a>
      </nav>
    </div>
    <p class="mt-5 text-xs text-slate-500">
      © {year} {site.name}. {site.tagline}. All tools run in your browser — your data never leaves your device.
    </p>
  </div>
</footer>
