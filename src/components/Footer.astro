---
import { site } from '../data/site.js';
import { categories, totalInCategory } from '../data/tools.js';
const year = new Date().getFullYear();

// Show the categories that actually have live tools, most-populated first.
const popularCategories = [...categories]
  .map((c) => ({ ...c, count: totalInCategory(c.id) }))
  .filter((c) => c.count > 0)
  .sort((a, b) => b.count - a.count)
  .slice(0, 8);
---

<footer class="border-t border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 font-bold text-slate-900 dark:text-white">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 text-white shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 32 32" fill="none">
              <path d="M10 11h12M10 16h12M10 21h7" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" />
              <circle cx="22" cy="21" r="2" fill="currentColor" />
            </svg>
          </span>
          <span class="text-lg tracking-tight">{site.name}</span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-500 dark:text-slate-400">
          {site.tagline}. Every tool runs in your browser — fast, private and free, with no sign-up.
        </p>
      </div>

      <!-- Popular categories -->
      <div class="lg:col-span-2">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">Popular categories</h2>
        <ul class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2.5 text-sm">
          {popularCategories.map((c) => (
            <li>
              <a href={`/tools/${c.id}/`} class="inline-flex items-center gap-2 text-slate-600 transition hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400">
                <span class="w-4 text-center text-xs">{c.emoji}</span>
                <span>{c.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company links -->
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">ToolNestr</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li><a href="/about" class="text-slate-600 transition hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400">About</a></li>
          <li><a href="/privacy" class="text-slate-600 transition hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400">Privacy</a></li>
          <li><a href="/contact" class="text-slate-600 transition hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start gap-3 border-t border-slate-100 pt-6 dark:border-slate-800 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-slate-500 dark:text-slate-400">
        &copy; {year} {site.name}. All tools run in your browser — your data never leaves your device.
      </p>
      <p class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 dark:text-slate-400">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        No sign-up · No tracking · 100% free
      </p>
    </div>
  </div>
</footer>
