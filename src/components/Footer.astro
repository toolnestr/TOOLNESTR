---
import { site } from '../data/site.js';
import { categories } from '../data/tools.js';
const year = new Date().getFullYear();
---

<!-- Desktop footer -->
<footer class="hidden border-t border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900 md:block">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <a href="/" class="text-base font-bold text-slate-800 dark:text-white">{site.name}</a>
      <nav class="flex flex-wrap gap-5 text-sm font-medium text-slate-600 dark:text-slate-400">
        <a href="/about" class="transition hover:text-indigo-600">About</a>
        <a href="/privacy" class="transition hover:text-indigo-600">Privacy</a>
        <a href="/contact" class="transition hover:text-indigo-600">Contact</a>
      </nav>
    </div>
    <p class="mt-5 text-xs text-slate-500">
      &copy; {year} {site.name}. {site.tagline}. All tools run in your browser &mdash; your data never leaves your device.
    </p>
  </div>
</footer>

<!-- Mobile sticky toolbar -->
<div class="fixed bottom-0 left-0 right-0 z-50 border-t border-slate-200 bg-white/95 backdrop-blur dark:border-slate-700 dark:bg-slate-900/95 md:hidden">
  <div class="flex items-center justify-around py-2 text-xs font-medium text-slate-600 dark:text-slate-400">
    <button id="m-search" class="flex flex-col items-center gap-0.5 px-3 py-1 transition active:text-indigo-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
      <span>Search</span>
    </button>
    <button id="m-categories" class="flex flex-col items-center gap-0.5 px-3 py-1 transition active:text-indigo-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" /></svg>
      <span>Categories</span>
    </button>
    <button id="m-theme" class="flex flex-col items-center gap-0.5 px-3 py-1 transition active:text-indigo-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
      <span id="m-theme-label">Dark</span>
    </button>
    <button id="m-top" class="flex flex-col items-center gap-0.5 px-3 py-1 transition active:text-indigo-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" /></svg>
      <span>Top</span>
    </button>
  </div>
</div>

<!-- Categories drawer overlay -->
<div id="m-cat-overlay" class="fixed inset-0 z-40 hidden bg-black/40 md:hidden" style="top:0"></div>

<!-- Categories drawer -->
<div id="m-cat-drawer" class="fixed bottom-0 left-0 right-0 z-50 hidden max-h-[60vh] overflow-y-auto rounded-t-2xl border-t border-slate-200 bg-white pb-8 shadow-2xl dark:border-slate-700 dark:bg-slate-900 md:hidden" style="transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
  <div class="sticky top-0 border-b border-slate-100 bg-white px-5 py-3 font-semibold text-slate-900 dark:border-slate-700 dark:bg-slate-900 dark:text-white">
    Categories
  </div>
  <div class="grid grid-cols-2 gap-1 px-3 pt-3">
    {categories.map((c) => (
      <a href={`/#${c.id}`} class="m-cat-link block rounded-lg px-3 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-indigo-50 hover:text-indigo-600 dark:text-slate-300 dark:hover:bg-indigo-500/10 dark:hover:text-indigo-400">
        {c.emoji} {c.name}
      </a>
    ))}
  </div>
</div>

<script>
  // ── Mobile toolbar: Search ──
  document.getElementById('m-search')?.addEventListener('click', function () {
    var input = document.getElementById('tool-search');
    if (input) {
      input.focus();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // ── Mobile toolbar: Categories drawer ──
  var catBtn = document.getElementById('m-categories');
  var drawer = document.getElementById('m-cat-drawer');
  var overlay = document.getElementById('m-cat-overlay');
  function openDrawer() {
    overlay.classList.remove('hidden');
    drawer.classList.remove('hidden');
    requestAnimationFrame(function () { drawer.style.transform = 'translateY(0)'; });
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    drawer.style.transform = 'translateY(100%)';
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
    setTimeout(function () { drawer.classList.add('hidden'); }, 300);
  }
  catBtn?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);
  document.querySelectorAll('.m-cat-link').forEach(function (l) { l.addEventListener('click', closeDrawer); });

  // ── Mobile toolbar: Theme toggle ──
  document.getElementById('m-theme')?.addEventListener('click', function () {
    var dark = document.documentElement.classList.toggle('dark');
    try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
    document.getElementById('m-theme-label').textContent = dark ? 'Light' : 'Dark';
  });

  // ── Mobile toolbar: Scroll to top ──
  document.getElementById('m-top')?.addEventListener('click', function () {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Sync theme label on load
  (function () {
    var label = document.getElementById('m-theme-label');
    if (label) {
      label.textContent = document.documentElement.classList.contains('dark') ? 'Light' : 'Dark';
    }
  })();
</script>
