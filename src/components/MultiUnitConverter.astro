---
// Reusable multi-unit converter hub (from/to dropdowns via a base-unit factor map).
import ToolLayout from '../layouts/ToolLayout.astro';

const {
  title,                 // e.g. "Length Converter"
  emoji = '🔄',
  quantity,              // "length", "weight", ...
  units,                 // [{ name, sym, toBase }]  toBase = how many base units in 1 of this unit
  baseName,              // name of the base unit (for prose)
  defaultFrom = 0, defaultTo = 1,
  intro, blurb,          // unique prose
  related = [],
  faqs = [],
} = Astro.props;

const category = { id: 'converters', name: 'Converters', emoji: '🔄' };
const description = `Free online ${title.toLowerCase()} — convert between ${units.slice(0, 6).map((u) => u.name).join(', ')} and more, instantly and accurately.`;
const unitsJson = JSON.stringify(units.map((u) => u.toBase));
const fullFaqs = faqs.length ? faqs : [
  { q: `How does this ${title.toLowerCase()} work?`, a: `Choose the unit you have and the unit you want, type a value, and the tool converts it via a common base unit (the ${baseName}). It supports ${units.length} ${quantity} units.` },
  { q: `Is the ${title.toLowerCase()} accurate?`, a: `Yes. Every unit is defined by its exact ratio to the ${baseName}, so conversions are precise; displayed results are rounded for readability.` },
  { q: `Can I convert in both directions?`, a: `Yes. Swap the “from” and “to” units, or press the swap button, to convert either way between any two ${quantity} units.` },
  { q: `Which ${quantity} units are supported?`, a: `It includes ${units.map((u) => u.name).join(', ')}.` },
];

// HowTo schema (AEO/GEO) for the converter's from/to workflow.
const howTo = {
  name: `How to use the ${title.toLowerCase()}`,
  steps: [
    { name: 'Pick your units', text: `Choose the ${quantity} unit you have in the "From" dropdown and the unit you want in the "To" dropdown.` },
    { name: 'Enter a value', text: 'Type the amount to convert; the result updates instantly via the common base unit.' },
    { name: 'Swap if needed', text: 'Press the swap button to reverse the conversion between the two units.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={fullFaqs} howTo={howTo}>
  <div id="muc" data-units={unitsJson} class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-3 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
      <label class="block"><span class="text-sm font-medium text-slate-700">From</span>
        <select id="from" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          {units.map((u, i) => <option value={i} selected={i === defaultFrom}>{u.name} ({u.sym})</option>)}
        </select></label>
      <button id="swap" aria-label="Swap units" class="mb-1 hidden h-11 w-11 items-center justify-center rounded-xl border border-slate-300 text-slate-600 transition hover:bg-slate-50 sm:flex">⇄</button>
      <label class="block"><span class="text-sm font-medium text-slate-700">To</span>
        <select id="to" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          {units.map((u, i) => <option value={i} selected={i === defaultTo}>{u.name} ({u.sym})</option>)}
        </select></label>
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Value</span>
      <input id="val" type="number" step="any" placeholder="Enter a value" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-4 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div id="out-label" class="text-sm opacity-80">Result</div>
      <div id="out" class="mt-1 text-3xl font-bold tabular-nums">—</div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="150" viewBox="0 0 800 150" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="mu-title mu-desc">
      <title id="mu-title">{title} via a base unit</title>
      <desc id="mu-desc">Any unit converts to any other through a shared base unit, the {baseName}.</desc>
      <rect x="60" y="55" width="200" height="40" rx="6" fill="#eef2ff" stroke="#a5b4fc" /><text x="160" y="80" text-anchor="middle" font-size="14" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">From unit</text>
      <rect x="320" y="55" width="160" height="40" rx="6" fill="#6366f1" /><text x="400" y="80" text-anchor="middle" font-size="13" fill="#fff" font-family="system-ui,sans-serif">Base: {baseName}</text>
      <rect x="540" y="55" width="200" height="40" rx="6" fill="#f8fafc" stroke="#cbd5e1" /><text x="640" y="80" text-anchor="middle" font-size="14" fill="#1e293b" font-family="system-ui,sans-serif" font-weight="bold">To unit</text>
      <path d="M262 75 L318 75" stroke="#94a3b8" stroke-width="2" marker-end="url(#mua)" /><path d="M482 75 L538 75" stroke="#94a3b8" stroke-width="2" marker-end="url(#mua)" /><defs><marker id="mua" markerWidth="10" markerHeight="10" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#94a3b8" /></marker></defs>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">{title}: every unit converts through the {baseName}.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this {title.toLowerCase()}</h2>
    <p class="mt-2 text-slate-600">{blurb} This {title.toLowerCase()} lets you move between {units.length} different {quantity} units in either direction. Pick the unit you are starting from, the unit you want, and enter a value — the result appears instantly as you type, with the calculation running entirely in your browser.</p>
    <p class="mt-3 text-slate-600">Internally, every unit is defined by its exact ratio to a single base unit, the {baseName}. To convert, the tool first changes your value into the base unit, then into the target unit. This base-unit method keeps results consistent and precise no matter which pair of units you choose, and makes it easy to add uncommon units alongside the everyday ones.</p>
    <p class="mt-3 text-slate-600">Use the swap control to reverse the direction at any time, which is handy when you are checking a figure both ways. Because the converter is mobile-first and works offline once loaded, it is a quick reference for {quantity} whether you are studying, working, travelling or shopping across measurement systems.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Supported {quantity} units</h2>
    <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
      {units.map((u) => (<div class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700"><span class="font-semibold text-slate-900">{u.sym}</span> — {u.name}</div>))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related converters</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      {related.map((r) => (<a href={`/tools/${r.slug}/`} class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{r.label}</a>))}
    </div>
  </section>

  <script is:inline>
    (function () {
      const root = document.getElementById('muc');
      const toBase = JSON.parse(root.dataset.units);
      const from = document.getElementById('from'), to = document.getElementById('to'), val = document.getElementById('val'), out = document.getElementById('out');
      function update() {
        const v = parseFloat(val.value);
        if (!isFinite(v)) { out.textContent = '—'; return; }
        const base = v * toBase[+from.value];
        const res = base / toBase[+to.value];
        out.textContent = (Math.round(res * 1e8) / 1e8).toLocaleString(undefined, { maximumFractionDigits: 8 });
      }
      document.getElementById('swap').addEventListener('click', () => { const a = from.value; from.value = to.value; to.value = a; update(); });
      [from, to, val].forEach((e) => e.addEventListener('input', update));
    })();
  </script>
</ToolLayout>
