---
// Universal, searchable currency selector for all money tools.
// - Auto-detects the visitor's currency from their IP (Cloudflare /cdn-cgi/trace → country → currency)
// - Searchable, height-bounded dropdown listing every currency (Intl.supportedValuesOf)
// - Remembers a manual choice across the whole site (localStorage 'tn_currency')
// - Exposes window.tnFmtMoney(n) and fires a 'tn:currency' event so tools re-render on change
---
<label class="mb-4 block">
  <span class="text-sm font-medium text-slate-700">Currency</span>
  <div id="cur-wrap" class="relative mt-1">
    <button id="cur-btn" type="button" aria-haspopup="listbox" aria-expanded="false"
      class="flex w-full items-center justify-between rounded-xl border border-slate-300 p-3 text-left outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
      <span id="cur-label" class="truncate">USD — US Dollar</span>
      <svg class="ml-2 h-4 w-4 flex-shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
    </button>
    <div id="cur-panel" class="absolute left-0 right-0 z-40 mt-1 hidden overflow-hidden rounded-xl border border-slate-200 bg-white shadow-xl dark:border-slate-700 dark:bg-slate-800">
      <div class="border-b border-slate-100 p-2 dark:border-slate-700">
        <input id="cur-search" type="text" autocomplete="off" placeholder="Search currency or code…"
          class="w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div id="cur-list" class="max-h-60 overflow-y-auto p-1" role="listbox"></div>
      <div id="cur-empty" class="hidden p-3 text-center text-sm text-slate-500">No matching currency</div>
    </div>
  </div>
</label>
<script is:inline>
(function () {
  if (window.__tnCurInit) return; window.__tnCurInit = true;
  var wrap = document.getElementById('cur-wrap');
  if (!wrap) return;
  var btn = document.getElementById('cur-btn'), panel = document.getElementById('cur-panel'),
      search = document.getElementById('cur-search'), list = document.getElementById('cur-list'),
      labelEl = document.getElementById('cur-label'), empty = document.getElementById('cur-empty');

  var POPULAR = ['USD','EUR','GBP','PKR','INR','BDT','IDR','MYR','SAR','AED','QAR','KWD','BHD','OMR','EGP','TRY','NGN','ZAR','CAD','AUD'];
  var FALLBACK = POPULAR.concat(['JOD','LBP','IQD','IRR','SYP','YER','TND','DZD','MAD','LYD','SDG','SOS','KES','TZS','UGX','GHS','XOF','XAF','LKR','NPR','AFN','AZN','KZT','UZS','BND','MVR','MUR','JPY','CNY','HKD','SGD','THB','PHP','VND','KRW','CHF','SEK','NOK','DKK','PLN','CZK','HUF','RON','RUB','UAH','BRL','MXN','ARS','CLP','COP','NZD']);
  var C2CUR = {
    US:'USD',GB:'GBP',
    AT:'EUR',BE:'EUR',CY:'EUR',EE:'EUR',FI:'EUR',FR:'EUR',DE:'EUR',GR:'EUR',IE:'EUR',IT:'EUR',LV:'EUR',LT:'EUR',LU:'EUR',MT:'EUR',NL:'EUR',PT:'EUR',SK:'EUR',SI:'EUR',ES:'EUR',HR:'EUR',
    PK:'PKR',IN:'INR',BD:'BDT',LK:'LKR',NP:'NPR',BT:'BTN',
    ID:'IDR',MY:'MYR',SG:'SGD',TH:'THB',PH:'PHP',VN:'VND',KR:'KRW',JP:'JPY',CN:'CNY',HK:'HKD',MO:'MOP',TW:'TWD',MM:'MMK',KH:'KHR',LA:'LAK',BN:'BND',MV:'MVR',MN:'MNT',
    SA:'SAR',AE:'AED',QA:'QAR',KW:'KWD',BH:'BHD',OM:'OMR',JO:'JOD',LB:'LBP',IL:'ILS',IQ:'IQD',IR:'IRR',SY:'SYP',YE:'YER',TR:'TRY',
    AZ:'AZN',KZ:'KZT',UZ:'UZS',TM:'TMT',KG:'KGS',TJ:'TJS',AF:'AFN',GE:'GEL',AM:'AMD',
    EG:'EGP',MA:'MAD',DZ:'DZD',TN:'TND',LY:'LYD',SD:'SDG',SO:'SOS',
    NG:'NGN',GH:'GHS',KE:'KES',TZ:'TZS',UG:'UGX',ET:'ETB',ZA:'ZAR',ZM:'ZMW',ZW:'ZWL',RW:'RWF',
    SN:'XOF',CI:'XOF',ML:'XOF',BF:'XOF',NE:'XOF',BJ:'XOF',TG:'XOF',GW:'XOF',
    CM:'XAF',GA:'XAF',CG:'XAF',TD:'XAF',CF:'XAF',GQ:'XAF',
    AO:'AOA',MZ:'MZN',MG:'MGA',MU:'MUR',MW:'MWK',BW:'BWP',NA:'NAD',SZ:'SZL',LS:'LSL',SC:'SCR',GM:'GMD',SL:'SLL',LR:'LRD',MR:'MRU',DJ:'DJF',ER:'ERN',CV:'CVE',
    CA:'CAD',AU:'AUD',NZ:'NZD',MX:'MXN',BR:'BRL',AR:'ARS',CL:'CLP',CO:'COP',PE:'PEN',UY:'UYU',PY:'PYG',BO:'BOB',VE:'VES',EC:'USD',
    CR:'CRC',GT:'GTQ',HN:'HNL',NI:'NIO',PA:'PAB',DO:'DOP',JM:'JMD',TT:'TTD',CU:'CUP',BS:'BSD',BB:'BBD',BZ:'BZD',
    RU:'RUB',UA:'UAH',BY:'BYN',PL:'PLN',CZ:'CZK',HU:'HUF',RO:'RON',BG:'BGN',RS:'RSD',BA:'BAM',MK:'MKD',AL:'ALL',MD:'MDL',IS:'ISK',NO:'NOK',SE:'SEK',DK:'DKK',CH:'CHF',LI:'CHF',
    FJ:'FJD',PG:'PGK'
  };

  function stored() { try { return localStorage.getItem('tn_currency') || ''; } catch (e) { return ''; } }
  function save(c) { try { localStorage.setItem('tn_currency', c); } catch (e) {} }
  var CUR = stored() || 'USD';
  window.tnCurrency = function () { return CUR; };
  window.tnFmtMoney = function (n) {
    try { return new Intl.NumberFormat(undefined, { style: 'currency', currency: CUR, maximumFractionDigits: 2 }).format(n); }
    catch (e) { return CUR + ' ' + Number(n).toLocaleString(undefined, { maximumFractionDigits: 2 }); }
  };
  function fire() { try { document.dispatchEvent(new CustomEvent('tn:currency', { detail: CUR })); } catch (e) {} }

  var codes; try { codes = Intl.supportedValuesOf('currency'); } catch (e) {}
  if (!codes || !codes.length) codes = FALLBACK.slice();
  var dn; try { dn = new Intl.DisplayNames(undefined, { type: 'currency' }); } catch (e) {}
  function label(code) { var nm; try { nm = dn ? dn.of(code) : ''; } catch (e) { nm = ''; } return nm && nm !== code ? code + ' — ' + nm : code; }

  var seen = {}, pop = [];
  POPULAR.forEach(function (c) { if (!seen[c]) { seen[c] = 1; pop.push(c); } });
  var rest = codes.slice().sort().filter(function (c) { return !seen[c]; });
  var ordered = pop.concat(rest);

  ordered.forEach(function (c, i) {
    var b = document.createElement('button');
    b.type = 'button'; b.dataset.code = c; b.dataset.s = (c + ' ' + label(c)).toLowerCase();
    b.className = 'block w-full truncate rounded-lg px-3 py-2 text-left text-sm text-slate-700 hover:bg-indigo-50 dark:text-slate-200 dark:hover:bg-slate-700';
    b.textContent = label(c);
    b.addEventListener('click', function () { choose(c); });
    list.appendChild(b);
    if (i === pop.length - 1 && rest.length) {
      var hr = document.createElement('div'); hr.id = 'cur-div'; hr.className = 'my-1 border-t border-slate-100 dark:border-slate-700'; list.appendChild(hr);
    }
  });

  function setLabel() { labelEl.textContent = label(CUR); }
  function choose(c) { CUR = c; save(c); setLabel(); close(); fire(); }
  function open() { panel.classList.remove('hidden'); btn.setAttribute('aria-expanded', 'true'); search.value = ''; filter(''); setTimeout(function () { search.focus(); }, 0); }
  function close() { panel.classList.add('hidden'); btn.setAttribute('aria-expanded', 'false'); }
  function filter(q) {
    q = q.trim().toLowerCase(); var shown = 0;
    list.querySelectorAll('button').forEach(function (b) { var m = !q || b.dataset.s.indexOf(q) >= 0; b.style.display = m ? '' : 'none'; if (m) shown++; });
    var hr = document.getElementById('cur-div'); if (hr) hr.style.display = q ? 'none' : '';
    empty.classList.toggle('hidden', shown > 0);
  }

  btn.addEventListener('click', function (e) { e.stopPropagation(); panel.classList.contains('hidden') ? open() : close(); });
  search.addEventListener('input', function () { filter(search.value); });
  search.addEventListener('keydown', function (e) { if (e.key === 'Escape') { close(); btn.focus(); } });
  document.addEventListener('click', function (e) { if (!wrap.contains(e.target)) close(); });
  setLabel();

  if (!stored()) {
    fetch('/cdn-cgi/trace').then(function (r) { return r.text(); }).then(function (t) {
      var m = t.match(/loc=([A-Z]{2})/); var cc = m && C2CUR[m[1]];
      if (cc) { CUR = cc; setLabel(); fire(); }
    }).catch(function () {
      try { var p = (navigator.language || '').split('-')[1]; var cc = p && C2CUR[p.toUpperCase()]; if (cc) { CUR = cc; setLabel(); fire(); } } catch (e) {}
    });
  }
})();
</script>
