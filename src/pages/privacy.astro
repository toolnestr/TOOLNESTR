---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.js';
const updated = 'June 21, 2026';

const privacyJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Privacy Policy',
  description: `Privacy Policy for ${site.name}. Learn what data we do and don't collect, how analytics and advertising cookies work, and how to contact us.`,
  mainEntity: {
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
  },
};
---

<BaseLayout
  title="Privacy Policy"
  description={`Privacy Policy for ${site.name}. Learn what data we do and don't collect, how analytics and advertising cookies work, and how to contact us.`}
  jsonLd={privacyJsonLd}
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Privacy Policy</h1>
    <p class="mt-2 text-sm text-slate-400">Last updated: {updated}</p>

    <div class="mt-6 space-y-4 text-slate-600">
      <p>
        This Privacy Policy explains how {site.name} (“we”, “us”) handles information when you use
        our website and tools at {site.url.replace('https://', '')}. We’ve tried to keep it short
        and clear.
      </p>

      <h2 class="pt-4 text-xl font-bold text-slate-900">The short version</h2>
      <p>
        Most of our tools run entirely in your browser. The text, files and data you put into a
        tool are processed on your own device and are <strong>not uploaded to or stored on our
        servers</strong>. We don’t require accounts and we don’t ask for personal information to
        use the tools.
      </p>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Information we collect</h2>
      <ul class="list-disc space-y-1 pl-5">
        <li>
          <strong>Tool content:</strong> Content you enter into a tool (text, files, images) is
          handled locally in your browser and is not sent to us.
        </li>
        <li>
          <strong>Analytics data:</strong> We use privacy-friendly analytics to understand which
          tools are popular and how the site performs. This is aggregated and does not identify
          you personally.
        </li>
        <li>
          <strong>Technical data:</strong> Like most websites, our hosting provider may
          automatically process basic technical information (such as browser type and approximate
          region) to deliver and secure the site.
        </li>
      </ul>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Cookies and advertising</h2>
      <p>
        We may display advertisements to keep the site free. Third-party vendors, including Google,
        use cookies to serve ads based on a user’s prior visits to this and other websites.
      </p>
      <ul class="list-disc space-y-1 pl-5">
        <li>
          Google’s use of advertising cookies enables it and its partners to serve ads to you
          based on your visit to this site and/or other sites on the Internet.
        </li>
        <li>
          You may opt out of personalized advertising by visiting
          <a href="https://www.google.com/settings/ads" rel="nofollow noopener" target="_blank" class="text-indigo-600 hover:underline">Google Ads Settings</a>.
        </li>
        <li>
          You can also opt out of some third-party vendors’ use of cookies for personalized
          advertising at
          <a href="https://www.aboutads.info/choices/" rel="nofollow noopener" target="_blank" class="text-indigo-600 hover:underline">aboutads.info</a>.
        </li>
        <li>
          Learn more about how Google uses data in advertising at
          <a href="https://policies.google.com/technologies/ads" rel="nofollow noopener" target="_blank" class="text-indigo-600 hover:underline">policies.google.com/technologies/ads</a>.
        </li>
      </ul>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Third-party links</h2>
      <p>
        Our site may link to other websites. We aren’t responsible for the privacy practices of
        those sites, so we encourage you to review their policies.
      </p>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Children’s privacy</h2>
      <p>
        Our tools are intended for a general audience and are not directed at children under 13.
        We do not knowingly collect personal information from children.
      </p>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Changes to this policy</h2>
      <p>
        We may update this policy from time to time. When we do, we’ll revise the “Last updated”
        date above.
      </p>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Contact us</h2>
      <p>
        Questions about this policy? Email us at
        <a href={`mailto:${site.email}`} class="font-medium text-indigo-600 hover:underline">{site.email}</a>
        or use our <a href="/contact" class="font-medium text-indigo-600 hover:underline">contact page</a>.
      </p>
    </div>
  </div>
</BaseLayout>
