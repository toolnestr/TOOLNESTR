---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.js';
import { tools } from '../data/tools.js';
const toolCount = tools.length;
---

<BaseLayout
  title="About"
  description={`Learn about ${site.name} — a collection of free, fast and private online tools that run entirely in your browser.`}
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">About {site.name}</h1>

    <div class="mt-6 space-y-4 text-slate-600">
      <p>
        {site.name} is a growing collection of free online tools built around one simple idea:
        small, focused utilities that do one job well — and do it instantly, without sign-ups,
        downloads or hassle.
      </p>
      <p>
        From word counters and calculators to PDF tools, image helpers and developer utilities,
        every tool is designed to be fast, clean and genuinely useful on any device.
      </p>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Privacy comes first</h2>
      <p>
        Most of our tools run <strong>entirely in your browser</strong>. That means when you merge
        a PDF, generate a password or convert an image, your files and text never get uploaded to a
        server — they stay on your device. It’s faster, and it keeps your data private.
      </p>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Always free</h2>
      <p>
        Every tool here is free to use. We keep the lights on with unobtrusive advertising, which
        lets us keep building and improving tools for everyone.
      </p>

      <h2 class="pt-4 text-xl font-bold text-slate-900">Always growing</h2>
      <p>
        We currently offer {toolCount}+ tools and we’re adding more all the time. Have an idea for a
        tool you wish existed? We’d love to hear it — drop us a line on our
        <a href="/contact" class="font-medium text-indigo-600 hover:underline">contact page</a>.
      </p>

      <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5">
        <p class="text-sm text-slate-600">
          Ready to explore? <a href="/" class="font-medium text-indigo-600 hover:underline">Browse all tools →</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
