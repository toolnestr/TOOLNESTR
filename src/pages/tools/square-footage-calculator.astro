---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Square Footage Calculator';
const description = 'Calculate the square footage of rectangles, circles, and triangles from your measurements. Get instant, accurate area calculations for any project.';
const intro = 'Calculate the area of any space in square feet — rectangles, circles, and triangles.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'What is the difference between square footage and square feet?', a: 'They mean the same thing. Square footage is the area measured in square feet. Both terms are used interchangeably in real estate and construction.' },
  { q: 'How do I measure an irregularly shaped room?', a: 'Break it into rectangles, triangles, and circles. Calculate each separately using this tool and add the results together.' },
  { q: 'Is the garage included in square footage?', a: 'In most US real estate listings, garages are not counted in the living area square footage (GLA). They are listed separately.' },
  { q: 'What about stairs and hallways?', a: 'Stairs are counted once per floor. Measure the length and width of the stairwell opening or the tread area. Hallways are measured as rectangles.' },
];
const howTo = {
  name: 'How to calculate square footage',
  steps: [
    { name: 'Measure dimensions', text: 'Use a tape measure to find the length, width, radius, or base and height of the space.' },
    { name: 'Select shape', text: 'Choose rectangle, circle, or triangle and enter your measurements in the input fields.' },
    { name: 'Read the result', text: 'The tool shows square footage and acres instantly. Use the total to plan materials or compare spaces.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex gap-2">
      {['Rectangle', 'Circle', 'Triangle'].map((s) => (
        <button data-shape={s.toLowerCase()} class="shape-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{s}</button>
      ))}
    </div>
    <div id="rect-inputs" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="rect-length" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="rect-width" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="circle-inputs" class="hidden grid gap-4 sm:grid-cols-1">
      <label class="block"><span class="text-sm font-medium text-slate-700">Radius (ft)</span>
        <input id="circle-radius" type="number" step="any" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="triangle-inputs" class="hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Base (ft)</span>
        <input id="tri-base" type="number" step="any" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="tri-height" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total square footage</div>
        <div id="r-area" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Shape</div><div id="r-shape" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Acres</div><div id="r-acres" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sqft-title sqft-desc">
      <title id="sqft-title">Rectangle area diagram</title>
      <desc id="sqft-desc">A rectangle labelled with Length L and Width W, showing the area formula L x W</desc>
      <rect x="150" y="80" width="400" height="180" fill="#e0e7ff" stroke="#6366f1" stroke-width="3" rx="4" />
      <text x="350" y="180" text-anchor="middle" font-size="20" fill="#4338ca" font-family="system-ui,sans-serif" font-weight="bold">Area = L &times; W</text>
      <line x1="150" y1="55" x2="550" y2="55" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <polygon points="150,55 162,50 162,60" fill="#94a3b8" />
      <polygon points="550,55 538,50 538,60" fill="#94a3b8" />
      <text x="350" y="46" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Length (L)</text>
      <line x1="125" y1="80" x2="125" y2="260" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <polygon points="125,80 117,92 133,92" fill="#94a3b8" />
      <polygon points="125,260 117,248 133,248" fill="#94a3b8" />
      <text x="112" y="175" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif" transform="rotate(-90 112 175)">Width (W)</text>
      <rect x="620" y="80" width="150" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="635" y="105" font-size="12" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Formulas</text>
      <text x="635" y="124" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Rectangle: L &times; W</text>
      <text x="635" y="142" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Circle: &pi;r&sup2;</text>
      <text x="635" y="160" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Triangle: &frac12; &times; b &times; h</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The square footage formula for a rectangle — the most common shape in real estate and construction</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the square footage calculator works</h2>
    <p class="mt-2 text-slate-600">
      The calculator computes the area of three common shapes — rectangle, circle, and triangle — based on the dimensions you enter. For rectangles, it multiplies length by width. For circles, it uses pi times the radius squared. For triangles, it multiplies base by height and divides by two. The result is displayed in square feet and also converted to acres for larger areas.
    </p>
    <p class="mt-3 text-slate-600">
      To use the tool, select the shape that matches the space you are measuring. Enter the required dimensions in feet. The area updates automatically as you type. If you need to measure a room with multiple sections, calculate each section separately and add the totals together.
    </p>
    <p class="mt-3 text-slate-600">
      Square footage is the standard unit for real estate listings in the United States and Canada. It determines property value, renovation costs, material quantities, and even furniture fit. Knowing the exact area of each room helps you make informed decisions about flooring, paint, heating and cooling capacity, and spatial planning.
    </p>
    <p class="mt-3 text-xs text-slate-400">Living area (gross living area, or GLA) measurement conventions follow ANSI Z765-2021, the American National Standard for Determining Gross Living Area, used by appraisers and real estate professionals nationwide.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure dimensions</h3>
        <p class="mt-1 text-sm text-slate-600">Use a tape measure to find the length, width, radius, or base and height of the space.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select shape</h3>
        <p class="mt-1 text-sm text-slate-600">Choose rectangle, circle, or triangle and enter your measurements in the input fields.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The tool shows square footage and acres instantly. Use the total to plan materials or compare spaces.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      Each geometric shape has a specific formula for calculating area. Understanding these formulas helps you verify measurements and adapt to unusual spaces:
    </p>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Rectangle area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Area = L &times; W</span>. A room that is 15 feet long and 12 feet wide has an area of 15 &times; 12 = <strong>180 sq ft</strong>. This is the most common calculation in real estate and covers most rooms, hallways, and lots.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Circle area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Area = &pi;r&sup2;</span>. A circular patio with a radius of 6 feet has an area of &pi; &times; 6&sup2; = &pi; &times; 36 ≈ <strong>113.1 sq ft</strong>. Use this for round tables, circular rooms, or garden features.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Triangle area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Area = &frac12; &times; b &times; h</span>. A triangular garden bed with a base of 8 feet and a height of 5 feet has an area of 0.5 &times; 8 &times; 5 = <strong>20 sq ft</strong>. Triangles are common in angled lots and A-frame structures.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A living room measures 18&prime; &times; 14&prime; with a rectangular bay window area of 6&prime; &times; 3&prime; attached.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Main room:</span> <span class="text-slate-600">18 &times; 14 = 252 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Bay area:</span> <span class="text-slate-600">6 &times; 3 = 18 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Total:</span> <span class="text-slate-600">252 + 18 = <strong>270 sq ft</strong></span></div>
        <div><span class="font-medium text-slate-700">In acres:</span> <span class="text-slate-600">270 &divide; 43,560 ≈ <strong>0.0062 acres</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the square footage calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Home buyer or seller</h3>
        <p class="mt-1 text-sm text-slate-600">Compare the square footage of homes you are considering. Verify listed dimensions against your own measurements. Accurate square footage directly affects property valuation and listing price.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🪚</span>
        <h3 class="mt-2 font-semibold text-slate-900">Renovation planning</h3>
        <p class="mt-1 text-sm text-slate-600">Estimate flooring, paint, and tile quantities for each room. Knowing the exact square footage helps you buy the right amount of materials without costly waste or shortages.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">👷</span>
        <h3 class="mt-2 font-semibold text-slate-900">Contractor bidding</h3>
        <p class="mt-1 text-sm text-slate-600">Provide accurate area measurements in client proposals. Square footage drives pricing for flooring installation, painting, drywall, and many other trades.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌳</span>
        <h3 class="mt-2 font-semibold text-slate-600">Landscaping</h3>
        <p class="mt-1 text-sm text-slate-600">Measure lawn areas for sod, garden beds for mulch, and patios for pavers. The circle and triangle modes handle curved beds and angled corners that rectangles miss.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for measuring square footage</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Measure from wall to wall</h3>
        <p class="mt-1 text-sm text-slate-600">Always measure between the interior wall surfaces, not including baseboards or trim. For exterior measurements, measure from the outside of the walls. Real estate listings typically use interior dimensions for living area and exterior dimensions for the total building footprint.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Break complex rooms into sections</h3>
        <p class="mt-1 text-sm text-slate-600">An L-shaped room is simply two rectangles added together. A room with a bay window is a rectangle plus a smaller rectangle or triangle. A circular turret is a circle. By combining shapes, you can measure any floor plan accurately with just a tape measure and this calculator.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Account for obstructions</h3>
        <p class="mt-1 text-sm text-slate-600">Permanent fixtures like built-in cabinets, fireplaces, and columns reduce usable square footage. Measure around them or subtract their area from the room total. For renovation material estimates, measure the full floor area since materials must go around these features.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Round to the nearest half foot</h3>
        <p class="mt-1 text-sm text-slate-600">Perfect precision is rarely necessary for most projects. Measuring to the nearest half foot (6 inches) gives sufficient accuracy for flooring, paint, and tile estimates. For critical cuts, measure to the nearest inch and double-check before cutting.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Appraisers use this exact rectangle-plus-circle-plus-triangle decomposition when calculating gross living area for a listing. Consider an L-shaped ranch home: a main block measuring 22 ft by 16 ft (352 sq ft) plus an attached wing measuring 10 ft by 8 ft (80 sq ft) totals 432 sq ft, or about 0.0099 acres — a figure that would need to be added to every other room in the house to reach the total GLA reported on a listing sheet.
    </p>
    <p class="mt-3 text-slate-600">
      Circular features come up more often than people expect — round patios, gazebos, and turret-style rooms all use the pi-r-squared formula. An 8 ft radius circular patio works out to π × 8² ≈ 201.1 sq ft, or roughly 0.0046 acres, which is enough space for a standard patio table, four chairs, and a small grill with room to walk around.
    </p>
    <p class="mt-3 text-slate-600">
      Triangle mode is most useful for angled lots and gable-end walls. A triangular side yard with a 45 ft base and a 30 ft height (measured perpendicular to the base) covers 0.5 × 45 × 30 = 675 sq ft, about 0.0155 acres — a common shape where a rectangular lot meets a curved street or property line at an angle.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Square footage on a listing always matches what you'd measure yourself." <strong class="text-slate-900">Not necessarily.</strong> Different appraisers and county assessors sometimes use different conventions — some include finished basements or garages, others exclude them entirely per ANSI Z765 guidelines. Always verify by measuring the living area yourself if square footage is critical to your decision.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A bigger radius circle takes proportionally more material than a bigger rectangle." <strong class="text-slate-900">Circles scale differently.</strong> Because circle area depends on the radius squared, doubling a circular patio's radius quadruples its area (not doubles it) — a detail that catches people off guard when budgeting pavers or concrete for a larger round feature.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/perimeter-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Perimeter Calculator</a>
      <a href="/tools/cubic-yardage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Cubic Yardage Calculator</a>
      <a href="/tools/concrete-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let currentShape = 'rectangle';

    function update() {
      let area = 0, shape = '—';
      if (currentShape === 'rectangle') {
        const L = parseFloat(el('rect-length').value);
        const W = parseFloat(el('rect-width').value);
        if (L > 0 && W > 0) { area = L * W; shape = 'Rectangle'; }
      } else if (currentShape === 'circle') {
        const r = parseFloat(el('circle-radius').value);
        if (r > 0) { area = Math.PI * r * r; shape = 'Circle'; }
      } else if (currentShape === 'triangle') {
        const b = parseFloat(el('tri-base').value);
        const h = parseFloat(el('tri-height').value);
        if (b > 0 && h > 0) { area = 0.5 * b * h; shape = 'Triangle'; }
      }
      if (area > 0) {
        el('r-area').textContent = area.toFixed(1).toLocaleString() + ' sq ft';
        el('r-shape').textContent = shape;
        el('r-acres').textContent = (area / 43560).toFixed(4) + ' acres';
        el('results').classList.remove('hidden');
      } else {
        el('results').classList.add('hidden');
      }
    }

    document.querySelectorAll('.shape-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.shape-btn').forEach((b) => {
          b.className = 'shape-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50';
        });
        btn.className = 'shape-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
        currentShape = btn.dataset.shape;
        ['rect', 'circle', 'triangle'].forEach((s) => {
          // currentShape is 'rectangle' but the input-div prefix is 'rect', so
          // compare by prefix — a plain !== left rectangle's fields permanently hidden.
          el(s + '-inputs').classList.toggle('hidden', !currentShape.startsWith(s));
        });
        update();
      });
    });
    ['rect-length', 'rect-width', 'circle-radius', 'tri-base', 'tri-height'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
    document.querySelector('.shape-btn').click();
  </script>
</ToolLayout>
