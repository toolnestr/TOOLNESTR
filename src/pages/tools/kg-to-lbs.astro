---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Kg to Lbs"
  emoji="⚖️"
  fromUnit="kilograms" toUnit="pounds"
  fromTitle="Kilograms" toTitle="Pounds"
  fromSym="kg" toSym="lb"
  quantity="weight"
  kind="factor" factor={2.2046226218}
  reverseSlug="lbs-to-kg" reverseLabel="Lbs to Kg Converter"
  hasReverse={true}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="It is the everyday conversion for body weight, luggage limits and gym plates between metric and imperial countries."
/>
