---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Mitosis Stage Identifier';
const description = 'Mitosis stage identifier with a live 3D chromosome diagram and charts. Answer a short dichotomous key to identify prophase, metaphase, anaphase, or telophase from observed cell features, with worked examples.';
const intro = "Answer a short series of yes/no questions about what you observe in a dividing cell — nuclear envelope status, chromosome alignment, and chromatid separation — to identify exactly which stage of mitosis it's in. Two 3D diagrams compare the classic metaphase alignment to anaphase separation, and charts show how much of the cell cycle each stage typically occupies.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What are the stages of mitosis, in order?', a: 'Prophase, (prometaphase), metaphase, anaphase, and telophase — often remembered with the mnemonic "PMAT" — followed by cytokinesis, the physical division of the cytoplasm into two daughter cells.' },
  { q: 'How can you tell metaphase and anaphase apart under a microscope?', a: "Metaphase shows chromosomes lined up in a single file along the cell's equator (the metaphase plate), all still joined as sister chromatid pairs. Anaphase shows those sister chromatids clearly separated and moving toward opposite poles of the cell." },
  { q: 'What is the difference between mitosis and the rest of the cell cycle?', a: 'Mitosis (division of the nucleus) is just one relatively brief part of the full cell cycle — most of a cell\'s time is actually spent in interphase (G1, S, and G2 phases), preparing for and growing between divisions.' },
  { q: 'Why does the nuclear envelope disappear during mitosis?', a: "The nuclear envelope breaks down at the end of prophase (sometimes called prometaphase) so that the mitotic spindle's microtubules, based in the cytoplasm, can directly access and attach to the chromosomes." },
  { q: 'What happens right after telophase?', a: "Cytokinesis follows telophase, physically dividing the cytoplasm into two separate daughter cells — in animal cells via a pinching cleavage furrow, and in plant cells via a newly formed cell plate." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Mitosis Stage Identifier',
  description: 'Answer a short dichotomous key based on observed cell features to identify the mitosis stage.',
  steps: [
    { name: 'Answer each question', text: 'Is the nuclear envelope intact? Are chromosomes aligned at the equator? Are chromatids separating? Are new nuclear envelopes forming?' },
    { name: 'Read the identified stage', text: 'The matching mitosis stage, with its key identifying features, displays automatically.' },
  ],
};

const formulas = [
  { expr: 'Nuclear envelope intact? → Interphase', note: 'if yes, the cell has not yet entered mitosis' },
  { expr: 'Chromosomes aligned at the equator? → Metaphase', note: 'the defining feature of metaphase' },
  { expr: 'Sister chromatids separating toward opposite poles? → Anaphase', note: 'the defining feature of anaphase' },
  { expr: 'New nuclear envelopes reforming? → Telophase', note: 'otherwise, condensed chromosomes with no alignment/separation/reforming → Prophase' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — identifying metaphase', tone: 'slate',
    given: 'A cell shows: nuclear envelope absent, chromosomes condensed and visible, all lined up in a single row at the cell\'s center.',
    rows: [
      { label: 'Q1 (envelope intact?):', value: 'No → continue' },
      { label: 'Q2 (aligned at equator?):', value: 'Yes → stop here' },
      { label: 'Identification:', value: 'Metaphase', full: true },
    ],
    note: 'The single-file alignment at the cell equator is metaphase\'s single most distinctive and easily recognized feature under a microscope.',
  },
  {
    title: 'Worked example 2 — identifying anaphase', tone: 'amber',
    given: 'A cell shows: nuclear envelope absent, chromosomes not aligned at the center, sister chromatids clearly separated and moving toward opposite ends of the cell.',
    rows: [
      { label: 'Q1 (envelope intact?):', value: 'No → continue' },
      { label: 'Q2 (aligned at equator?):', value: 'No → continue' },
      { label: 'Q3 (chromatids separating?):', value: 'Yes → stop here' },
      { label: 'Identification:', value: 'Anaphase', full: true },
    ],
    note: 'Anaphase is often the shortest and most dramatic stage to catch under a microscope, since the visible chromatid separation happens relatively quickly.',
  },
];

const comparison = {
  heading: 'Key identifying feature of each stage',
  note: 'One standout feature is usually enough to identify each stage confidently.',
  headers: [{ label: 'Stage' }, { label: 'Key identifying feature' }],
  rows: [
    ['Prophase', 'Chromosomes condensing and becoming visible; nuclear envelope starting to break down'],
    ['Metaphase ★', 'Chromosomes aligned in a single row at the cell\'s equator'],
    ['Anaphase', 'Sister chromatids visibly separated, moving toward opposite poles'],
    ['Telophase', 'Two new nuclear envelopes reforming around separated chromosome groups'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Metaphase\'s neat single-file alignment is often the easiest stage for beginning students to recognize confidently.',
};

const realWorld = [
  { emoji: '🔬', title: 'Histology and pathology slide analysis', body: 'Pathologists count the fraction of cells in mitosis (the mitotic index) in a tissue sample to help assess how rapidly a tumor is growing — accurately identifying mitotic stages is a core diagnostic skill.' },
  { emoji: '🎓', title: 'Biology education and lab practicals', body: "Identifying mitosis stages from prepared slides (often onion root tip or whitefish blastula slides) is one of the most common hands-on microscopy exercises in introductory biology courses." },
  { emoji: '💊', title: 'Cancer drug development', body: 'Many chemotherapy drugs specifically target cells in a particular mitotic stage (like the mitotic spindle during metaphase/anaphase) — understanding and identifying these stages is fundamental to how such drugs are designed and tested.' },
  { emoji: '🧬', title: 'Developmental biology research', body: "Tracking which mitotic stage embryonic cells are in helps researchers understand the timing and coordination of cell division during early development." },
];

const misconceptions = [
  { claim: '"Cells spend most of their time actively dividing."', truth: "Most cells spend the vast majority of their life cycle in interphase (roughly 90-95% of the total cell cycle), with mitosis itself — all four stages combined — typically making up only a small fraction of the total time." },
  { claim: '"Prometaphase isn\'t a real, separate stage."', truth: 'Many textbooks do include prometaphase as its own stage between prophase and metaphase (marked by complete nuclear envelope breakdown and the start of spindle attachment) — this tool simplifies to the classic four-stage PMAT framework, but the five-stage version is equally valid and commonly taught.' },
  { claim: '"Chromosomes are only present during mitosis."', truth: "Chromosomal DNA is always present in the cell — during interphase it's simply uncondensed, dispersed chromatin that isn't visible as discrete chromosome structures under a standard light microscope, not physically absent." },
  { claim: '"Anaphase and telophase are hard to tell apart."', truth: "They have a clear distinguishing feature: anaphase shows chromatids actively moving apart with no nuclear envelope present at all, while telophase shows chromatids that have already reached the poles, with new nuclear envelopes visibly reforming around each group." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 10, "Cell Reproduction" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/10-2-the-cell-cycle" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Mitosis and the mitotic spindle chapter.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — The cell cycle chapter.' },
];
const sourcesNote = 'A simplified four-stage (PMAT) dichotomous key. Some textbooks additionally distinguish prometaphase as its own stage between prophase and metaphase.';

const howToUse = [
  { title: 'Answer each yes/no question', body: "About nuclear envelope status, chromosome alignment, and chromatid separation." },
  { title: 'Read the identified stage', body: 'The matching stage and its key features display automatically as you answer.' },
  { title: 'Compare to the diagrams', body: 'Check your identification against the metaphase and anaphase reference diagrams.' },
];

const related = [
  { href: '/tools/cell-doubling-time-calculator', emoji: '⏱️', title: 'Cell Doubling Time Calculator', desc: 'Population doubling time and PDL for cell culture.' },
  { href: '/tools/surface-area-volume-ratio-calculator', emoji: '📦', title: 'Surface Area-to-Volume Ratio Calculator', desc: 'SA:V = 6/s — why cells stay small.' },
  { href: '/tools/osmosis-tonicity-calculator', emoji: '🔬', title: 'Osmosis/Tonicity Predictor', desc: 'Predict water movement and cell behavior.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="each stage of mitosis has one visually unmistakable signature — chromosomes lining up, chromatids pulling apart, envelopes reforming — so a short, ordered sequence of yes/no questions is all it takes to identify exactly which stage a cell is frozen in."
  howIntro="Mitosis unfolds as a tightly choreographed sequence, and each stage leaves an unmistakable visual signature behind: prophase condenses chromosomes and starts dismantling the nuclear envelope, metaphase lines every chromosome up along the cell's exact center, anaphase pulls sister chromatids cleanly apart toward opposite poles, and telophase rebuilds two fresh nuclear envelopes around the newly separated chromosome sets. Because these signatures rarely overlap, working through a short, ordered checklist of yes/no observations — starting with whether a nuclear envelope is even present — narrows down the correct stage in just a few questions, exactly the same logic used in biological identification keys for classifying species."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where mitosis stage identification actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="space-y-4">
      <div>
        <p class="text-sm font-medium text-slate-700">1. Is the nuclear envelope intact and visible?</p>
        <div class="mt-1 flex gap-2">
          <button data-q="envelope" data-val="yes" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">Yes</button>
          <button data-q="envelope" data-val="no" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">No</button>
        </div>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-700">2. Are chromosomes aligned in a single row at the cell's equator?</p>
        <div class="mt-1 flex gap-2">
          <button data-q="aligned" data-val="yes" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">Yes</button>
          <button data-q="aligned" data-val="no" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">No</button>
        </div>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-700">3. Are sister chromatids visibly separated, moving toward opposite poles?</p>
        <div class="mt-1 flex gap-2">
          <button data-q="separating" data-val="yes" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">Yes</button>
          <button data-q="separating" data-val="no" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">No</button>
        </div>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-700">4. Are two new nuclear envelopes reforming?</p>
        <div class="mt-1 flex gap-2">
          <button data-q="reforming" data-val="yes" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">Yes</button>
          <button data-q="reforming" data-val="no" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">No</button>
        </div>
      </div>
    </div>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Identified stage</div>
      <div id="r-stage" class="mt-1 text-2xl font-bold">Answer the questions above</div>
      <div id="r-detail" class="mt-1 text-sm opacity-90"></div>
    </div>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Metaphase vs. anaphase</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-metaphase" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Metaphase</h3>
          <p class="mt-1 text-sm text-slate-600">Chromosomes aligned in a single row at the cell's equator.</p>
        </div>
        <div>
          <div id="diag-anaphase" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Anaphase</h3>
          <p class="mt-1 text-sm text-slate-600">Sister chromatids separated, moving toward opposite poles.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">The cell cycle in proportion</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Approximate time spent in each phase</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-cycle"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Mitosis stages only (excluding interphase)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mitosis"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const answers = { envelope: null, aligned: null, separating: null, reforming: null };

      const stageInfo = {
        interphase: { name: 'Interphase (not yet in mitosis)', detail: 'Nuclear envelope intact, chromatin uncondensed — the cell is growing and preparing for division.' },
        prophase: { name: 'Prophase', detail: 'Chromosomes condensing, nuclear envelope breaking down — no alignment or separation yet.' },
        metaphase: { name: 'Metaphase', detail: 'Chromosomes aligned in a single row at the cell equator.' },
        anaphase: { name: 'Anaphase', detail: 'Sister chromatids separated, actively moving toward opposite poles.' },
        telophase: { name: 'Telophase', detail: 'Two new nuclear envelopes reforming around separated chromosome groups.' },
      };

      function identify() {
        if (answers.envelope === null) return null;
        if (answers.envelope === 'yes') return 'interphase';
        if (answers.aligned === null) return null;
        if (answers.aligned === 'yes') return 'metaphase';
        if (answers.separating === null) return null;
        if (answers.separating === 'yes') return 'anaphase';
        if (answers.reforming === null) return null;
        if (answers.reforming === 'yes') return 'telophase';
        return 'prophase';
      }
      function updateResult() {
        const stage = identify();
        if (!stage) { el('r-stage').textContent = 'Answer the questions above'; el('r-detail').textContent = ''; return; }
        el('r-stage').textContent = stageInfo[stage].name;
        el('r-detail').textContent = stageInfo[stage].detail;
      }
      document.querySelectorAll('.q-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const q = btn.getAttribute('data-q'), val = btn.getAttribute('data-val');
          answers[q] = val;
          document.querySelectorAll('.q-btn[data-q="' + q + '"]').forEach((b) => {
            b.className = b === btn ? 'q-btn rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white' : 'q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium';
          });
          updateResult();
        });
      });

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        new Chart(el('chart-cycle'), {
          type: 'pie',
          data: { labels: ['Interphase', 'Prophase', 'Metaphase', 'Anaphase', 'Telophase'], datasets: [{ data: [90, 3, 3, 1, 3], backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444', '#10b981'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        new Chart(el('chart-mitosis'), {
          type: 'bar',
          data: { labels: ['Prophase', 'Metaphase', 'Anaphase', 'Telophase'], datasets: [{ label: 'Relative duration', data: [3, 3, 1, 3], backgroundColor: ['#6366f1', '#f59e0b', '#ef4444', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Relative duration' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function chromosomeScene(container, aligned) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const n = 6;
        for (let i = 0; i < n; i++) {
          const group = new THREE.Group();
          const c1 = new THREE.Mesh(new THREE.SphereGeometry(0.18, 12, 10), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          const c2 = new THREE.Mesh(new THREE.SphereGeometry(0.18, 12, 10), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          if (aligned) {
            c1.position.set(0, 0.2, 0); c2.position.set(0, -0.2, 0);
            group.position.set((i - n / 2) * 0.5, 0, 0);
          } else {
            const side = i < n / 2 ? -1 : 1;
            c1.position.set(0, 0, 0); c2.position.set(0, 0, 0);
            group.position.set(side * (1.5 + Math.random()), (i % (n / 2) - 1) * 0.5, 0);
          }
          group.add(c1); group.add(c2);
          s.scene.add(group);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagMeta = null, diagAna = null;
      function initDiagMeta() { const c = el('diag-metaphase'); if (!c) throw new Error('no container'); diagMeta = chromosomeScene(c, true); }
      function initDiagAna() { const c = el('diag-anaphase'); if (!c) throw new Error('no container'); diagAna = chromosomeScene(c, false); }

      function boot() {
        try { initCharts(); updateResult(); } catch (e) { console.error('[mitosis-stage] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagMeta(); } catch (e) { console.error('[mitosis-stage] metaphase diagram failed', e); }
          try { initDiagAna(); } catch (e) { console.error('[mitosis-stage] anaphase diagram failed', e); }
        }
        mountResize([diagMeta, diagAna]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
