---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Day of Year Calculator';
const description = 'Free online day of year calculator. Find the day number (1-365/366), week number, days remaining and more for any date.';
const intro = 'Select any date to see its day of the year, remaining days, week number, quarter and other calendar statistics.';
const category = { id: 'time-date', name: 'Time & Date' };
const faqs = [
  { q: 'What is the day of year?', a: 'The day of year (ordinal date) is a number from 1 to 365 (or 366 in leap years) representing the sequential day count starting from January 1 as day 1.' },
  { q: 'How is day of year calculated?', a: 'It is simply the count of days from January 1 to the selected date, inclusive. For example, February 1 is day 32 (31 days of January + 1 day of February).' },
  { q: 'What is a leap year?', a: 'A leap year occurs every 4 years (except century years not divisible by 400). It has 366 days because February has 29 days instead of 28.' },
  { q: 'How do I know if a year is a leap year?', a: 'A year is a leap year if it is divisible by 4 but not by 100, unless it is also divisible by 400. 2024 and 2000 are leap years; 1900 is not.' },
  { q: 'What is week number?', a: 'Week number follows the ISO 8601 standard where the week containing the first Thursday of the year is week 1. Week 1 can start in late December of the previous year.' },
  { q: 'What is the ordinal suffix?', a: 'The ordinal suffix is the "st", "nd", "rd", or "th" appended to a number. For day of year: 1st, 2nd, 3rd, 4th, 11th, 12th, 13th, 21st, etc.' },
  { q: 'Why is day of year useful in programming?', a: 'Day of year is used in date arithmetic, file naming conventions, scientific data processing, and any application that needs to track day-by-day progress without month boundaries.' },
  { q: 'Is day 60 always March 1?', a: 'In non-leap years, day 60 is March 1. In leap years, day 60 is February 29 (since February has 29 days, so March 1 becomes day 61).' },
  { q: 'What is the maximum day of year?', a: 'The maximum is 365 in a common year and 366 in a leap year. December 31 is always the last day of the year.' },
  { q: 'What is an ordinal date?', a: 'An ordinal date is a date format that combines the year and the day of year, e.g., 2025-150 for May 30, 2025 (the 150th day of the year). It is commonly used in logistics and programming.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700" for="doy-date">Select a date</label>
      <input id="doy-date" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </div>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Day of Year</div><div id="doy-daynum" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-emerald-600 p-4 text-center text-white"><div class="text-xs opacity-80">Days Remaining</div><div id="doy-remaining" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-violet-600 p-4 text-center text-white"><div class="text-xs opacity-80">Week Number</div><div id="doy-week" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-amber-600 p-4 text-center text-white"><div class="text-xs opacity-80">Quarter</div><div id="doy-quarter" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Month</div><div id="doy-month" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Days in Month</div><div id="doy-daysinmonth" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Leap Year?</div><div id="doy-leap" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Day of Week</div><div id="doy-dow" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Progress through the year</h2>
    <div class="mt-3">
      <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Year progress</span><span id="doy-pct-label" class="text-slate-400">0.0%</span></div>
      <div class="mt-1 h-4 w-full rounded-full bg-slate-100"><div id="doy-bar" class="h-4 rounded-full bg-indigo-500 transition-all" style="width:0%"></div></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📋</span>
      <h3 class="mt-2 font-semibold text-slate-900">Project Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Track project milestones by day of year. Know exactly which day your deliverable falls on and how many days remain until the deadline.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍎</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Plan lesson schedules and semester calendars using day numbers. Easily determine the school day count for curriculum planning.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📅</span>
      <h3 class="mt-2 font-semibold text-slate-900">Event Planner</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate days until an event and track the ordinal date for invitations, countdowns, and coordination with vendors.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💻</span>
      <h3 class="mt-2 font-semibold text-slate-900">Developer</h3>
      <p class="mt-1 text-sm text-slate-600">Use day of year for date serialization, logging with ordinal dates, and implementing custom date-based features.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Day of year milestones</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead><tr class="border-b border-slate-200 text-slate-500"><th class="pb-2 pr-4 font-medium">Description</th><th class="pb-2 pr-4 font-medium">Day</th><th class="pb-2 font-medium">Date</th></tr></thead>
        <tbody class="text-slate-700">
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">First day of year</td><td class="py-2 pr-4 font-mono">1</td><td class="py-2">Jan 1</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">100th day</td><td class="py-2 pr-4 font-mono">100</td><td class="py-2">Apr 10 (common) / Apr 9 (leap)</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">200th day</td><td class="py-2 pr-4 font-mono">200</td><td class="py-2">Jul 19 (common) / Jul 18 (leap)</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">300th day</td><td class="py-2 pr-4 font-mono">300</td><td class="py-2">Oct 27 (common) / Oct 26 (leap)</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">Last day (common)</td><td class="py-2 pr-4 font-mono">365</td><td class="py-2">Dec 31</td></tr>
          <tr><td class="py-2 pr-4">Last day (leap)</td><td class="py-2 pr-4 font-mono">366</td><td class="py-2">Dec 31</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How day-of-year calculation works</h2>
    <p class="mt-2 text-slate-600">The day-of-year (ordinal date) is calculated by summing the total days in all preceding months and adding the current day of the month. For non-leap years, January has 31 days, February has 28, March has 31, and so on. In leap years, February has 29 days, shifting all subsequent dates by one day.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Date:</span> <span class="text-slate-600">March 15, 2026 (non-leap)</span></div>
        <div><span class="font-medium text-slate-700">January:</span> <span class="text-slate-600">31 days</span></div>
        <div><span class="font-medium text-slate-700">February:</span> <span class="text-slate-600">28 days</span></div>
        <div><span class="font-medium text-slate-700">Day of year:</span> <span class="text-slate-600">31 + 28 + 15 = day 74</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the day of year calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select a date</h3>
        <p class="mt-1 text-sm text-slate-600">Click the date picker and choose any date from any year.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">View statistics</h3>
        <p class="mt-1 text-sm text-slate-600">See day number, week number, quarter, days remaining, and more.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Track progress</h3>
        <p class="mt-1 text-sm text-slate-600">Use the progress bar to visualize how far through the year you are.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Day of year tips</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Leap years shift dates</h3>
        <p class="mt-1 text-sm text-slate-600">In leap years, all dates after February 28 shift by one day. Day 100 is April 9 instead of April 10. Always check if the year is a leap year when comparing ordinal dates.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Week number vs day of year</h3>
        <p class="mt-1 text-sm text-slate-600">Week number (ISO 8601) does not align perfectly with day of year. Week 1 can start in December of the previous year, and week numbers reset each year.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Ordinal suffix rules</h3>
        <p class="mt-1 text-sm text-slate-600">The suffix is "st" for numbers ending in 1 (except 11), "nd" for 2 (except 12), "rd" for 3 (except 13), and "th" for everything else. For example: 1st, 2nd, 3rd, 4th, 11th, 12th, 13th, 21st.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is day of year?</h2>
    <p class="mt-2 text-slate-600">The day of year (also called ordinal date) is a sequential number assigned to each day of the year. January 1 is always day 1, and December 31 is day 365 (or 366 in a leap year). This system ignores month boundaries, making it useful for date arithmetic, scientific data, and programming.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">Leap years</h2>
    <p class="mt-2 text-slate-600">Leap years add an extra day (February 29) to keep the calendar year synchronized with the astronomical year. The Earth takes approximately 365.242 days to orbit the Sun, so we add a leap day every 4 years, except on century years not divisible by 400. This means 2000 was a leap year, but 1900 was not.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">Ordinal dates</h2>
    <p class="mt-2 text-slate-600">An ordinal date combines the year and day of year into a compact format like 2025-150 or 2025150. This format is popular in logistics, inventory systems, and data science because it provides a monotonic date representation that is easy to sort and compare.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">Uses in programming</h2>
    <p class="mt-2 text-slate-600">Day of year is used extensively in software development for date comparison, calculating date differences, implementing recurring schedules, and sorting data chronologically. Languages typically provide built-in functions (like JavaScript's getDay() for week day or custom logic for day of year) making it straightforward to implement.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use day of year calculations</h2>
    <p class="mt-2 text-slate-600">Day of year calculations are useful across many professional and personal scenarios. Project managers track milestones by day number to measure progress independent of month boundaries. Knowing that a deliverable falls on day 200 provides a clearer picture of annual progress than saying it is in late July. Event planners use the day number to calculate precise intervals between dates, such as the number of days until a conference or the elapsed time since a project kickoff. In education, teachers and administrators track school days using ordinal dates to plan curriculum pacing and ensure required instructional hours are met. Software developers use day of year extensively for date serialization, log file naming, and implementing recurring schedules. The ordinal date format YYYY-DDD is compact and sortable, making it ideal for data storage and comparison. Scientists and researchers working with time-series data often use day of year as the temporal axis, simplifying analysis of seasonal patterns and annual cycles without dealing with varying month lengths. In logistics and supply chain management, ordinal dates appear on shipping labels, inventory tracking systems, and production schedules. Farmers and agricultural planners track growing degree days and planting schedules using day of year for precise timing. The common thread is that day of year provides a monotonic, month-independent count that simplifies date arithmetic and comparison across different years.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Limitations and considerations</h2>
    <p class="mt-2 text-slate-600">Day of year calculations have several important limitations to keep in mind. The most significant is the leap year effect. A date like March 1 corresponds to day 60 in a common year but day 61 in a leap year because February has 29 days instead of 28. This shift affects all dates after February 28 and must be accounted for when comparing ordinal dates across different years. Simple day number comparisons between a leap year and a common year will be off by one day for all dates after February 28. The ISO week number shown alongside the day of year follows a different system. Week 1 is defined as the week containing the first Thursday of the year, which can start in late December of the previous year. This means the week number and day of year do not align neatly, and week 53 may occur in some years. Day of year calculations also depend on accurate date input. Timezone differences can shift the date boundary, particularly for users near the International Date Line. The tool uses the local date selected by the user, but if the date is interpreted differently due to timezone settings, the day of year value may differ from what another observer would calculate. For global teams working across timezones, it is important to agree on a reference timezone when sharing ordinal dates to avoid off-by-one discrepancies.</p>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);

    function getOrdinal(n) {
      const s = ['th', 'st', 'nd', 'rd'];
      const v = n % 100;
      return n + (s[(v - 20) % 10] || s[v] || s[0]);
    }

    function isLeapYear(y) {
      return (y % 4 === 0 && y % 100 !== 0) || y % 400 === 0;
    }

    function updateDayOfYear() {
      const val = $('doy-date').value;
      if (!val) return;
      const d = new Date(val + 'T12:00:00');
      const y = d.getFullYear();
      const month = d.getMonth();
      const day = d.getDate();

      const start = new Date(y, 0, 0);
      const diff = d - start;
      const oneDay = 86400000;
      const dayOfYear = Math.floor(diff / oneDay);

      const daysInYear = isLeapYear(y) ? 366 : 365;
      const remaining = daysInYear - dayOfYear;

      const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
      const dowNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

      const daysInMonth = new Date(y, month + 1, 0).getDate();
      const quarter = Math.floor(month / 3) + 1;

      $('doy-daynum').textContent = getOrdinal(dayOfYear);
      $('doy-remaining').textContent = remaining;
      $('doy-week').textContent = getISOWeek(y, month, day);
      $('doy-quarter').textContent = 'Q' + quarter;
      $('doy-month').textContent = monthNames[month];
      $('doy-daysinmonth').textContent = daysInMonth;
      $('doy-leap').textContent = isLeapYear(y) ? 'Yes' : 'No';
      $('doy-dow').textContent = dowNames[d.getDay()];

      const pct = ((dayOfYear / daysInYear) * 100);
      $('doy-bar').style.width = Math.min(pct, 100) + '%';
      $('doy-pct-label').textContent = pct.toFixed(1) + '%';
    }

    function getISOWeek(y, m, d) {
      const date = new Date(y, m, d);
      const dayNum = (date.getDay() + 6) % 7;
      date.setDate(date.getDate() - dayNum + 3);
      const firstThursday = date.valueOf();
      date.setMonth(0, 1);
      if (date.getDay() !== 4) {
        date.setMonth(0, 1 + ((4 - date.getDay()) + 7) % 7);
      }
      return 1 + Math.ceil((firstThursday - date) / 604800000);
    }

    $('doy-date').addEventListener('change', updateDayOfYear);
    $('doy-date').valueAsDate = new Date();
    updateDayOfYear();
  </script>
</ToolLayout>
