---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Pleated Skirt Calculator';
const description = 'Calculate the fabric width needed at the waist for a knife-pleated or box-pleated skirt.';
const intro = 'Calculate the flat fabric width needed at the waist for a pleated skirt.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is pleat depth?', a: 'Pleat depth is how far the fabric folds back on itself to form one pleat, measured from the fold to where it lies flat again. A deeper pleat uses more fabric and creates a more pronounced fold.' },
  { q: 'Why does each pleat use twice its depth in fabric?', a: 'A knife or box pleat folds the fabric back on itself, so the folded-under portion doubles back — for the pleat to have a visible depth of, say, 1.5 inches, the fabric underneath needs 1.5 inches folded under plus another 1.5 inches for the fold itself, totaling twice the depth per pleat.' },
  { q: 'How many pleats should I use?', a: 'This depends on your waist measurement and desired pleat width — common finished pleat widths range from about 1 to 2 inches; divide your waist measurement by your target pleat width for an approximate starting pleat count, then adjust to a number that divides evenly.' },
  { q: 'Does a box pleat use the same formula as a knife pleat?', a: 'A box pleat is essentially two knife pleats folding toward each other, so it uses roughly the same twice-the-depth fabric per pleat, though some box pleat styles use a slightly different underlay calculation — check your specific pattern\'s instructions for style variations.' },
];
const howTo = {
  name: 'How to calculate pleated skirt fabric',
  steps: [
    { name: 'Enter waist measurement', text: 'Enter your finished waist measurement (with seam allowance).' },
    { name: 'Enter pleat count and depth', text: 'Enter how many pleats you want and how deep each pleat should be.' },
    { name: 'Read total fabric width needed', text: 'The total flat fabric width required at the waist appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Waist measurement (in)</span>
        <input id="waist" type="number" step="any" placeholder="e.g. 28" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of pleats</span>
        <input id="numPleats" type="number" step="1" placeholder="e.g. 14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pleat depth (in)</span>
        <input id="depth" type="number" step="any" placeholder="e.g. 1.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total fabric width needed</div>
        <div id="r-width" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="psc-title psc-desc">
      <title id="psc-title">Fabric strip with knife pleats folded in</title>
      <desc id="psc-desc">A flat fabric strip shown with several folded pleats, illustrating how folding consumes extra fabric width</desc>
      <rect x="100" y="60" width="600" height="60" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      {[180, 280, 380, 480, 580].map((x) => (
        <path d={`M${x} 60 L${x - 30} 90 L${x} 120`} fill="none" stroke="#c026d3" stroke-width="2" />
      ))}
      <text x="400" y="150" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Flat width needed = waist + (pleats × 2 × depth)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Each pleat fold consumes twice its depth in extra fabric</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How pleated skirt fabric is calculated</h2>
    <p class="mt-2 text-slate-600">
      A pleat is created by folding fabric back on itself, so each pleat consumes twice its finished depth in fabric — once for the fold itself and once for the fabric it folds under. This calculator multiplies your number of pleats by twice the pleat depth, then adds that to your flat waist measurement to find the total flat fabric width needed before any pleats are folded in.
    </p>
    <p class="mt-3 text-slate-600">
      Once folded, all those pleats compress back down to the original waist measurement, since the extra fabric is hidden in the folds rather than adding to the finished waist size — this is why a pleated skirt can look dramatically fuller than its waistband while still fitting the same waist as a flat, unpleated skirt.
    </p>
    <p class="mt-3 text-xs text-slate-400">This is the standard fabric-consumption formula for knife and box pleats used across dressmaking and skirt-drafting references.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 28-inch waist, 14 knife pleats, each 1.5 inches deep.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Extra per pleat:</span> <span class="text-slate-600">2 × 1.5 = 3 in</span></div>
        <div><span class="font-medium text-slate-700">Total pleat fabric:</span> <span class="text-slate-600">14 × 3 = 42 in</span></div>
        <div><span class="font-medium text-slate-700">Total flat width:</span> <span class="text-slate-600">28 + 42 = <strong>70 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      School uniform skirts are one of the most common pleated-skirt projects, since standard uniform pleating patterns are well documented and reproducible — knowing the total flat width in advance is essential because uniform fabric is often bought in a fixed quantity per skirt, and running short mid-cut means an exact-match reorder that may not be available later in the same dye lot.
    </p>
    <p class="mt-3 text-slate-600">
      Kilts and formal pleated skirts often use significantly deeper pleats (2-3 inches) for a more dramatic silhouette, which multiplies fabric needs substantially compared to a subtle school-uniform-style pleat — this is a case where the pleat-depth input matters far more to the total than the pleat count does.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"More pleats always means a fuller-looking skirt regardless of depth." <strong class="text-slate-900">Depth matters just as much.</strong> Twenty shallow, quarter-inch-deep pleats use far less fabric and create far less visual fullness than ten pleats that are two inches deep, even though the shallow version has more individual pleats.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Pleated skirts need less fabric than gathered skirts." <strong class="text-slate-900">Not necessarily.</strong> Deep pleats can consume as much or more fabric than a moderately gathered skirt of the same waist — the fullness ratio, not the construction method name, determines actual fabric use.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/circle-skirt-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Circle Skirt Calculator</a>
      <a href="/tools/gathering-ratio-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Gathering Ratio Calculator</a>
      <a href="/tools/pleat-allowance-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Pleat Allowance Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const waist = parseFloat(el('waist').value);
      const numPleats = parseFloat(el('numPleats').value);
      const depth = parseFloat(el('depth').value);
      if (!waist || !numPleats || !depth || waist <= 0 || numPleats <= 0 || depth <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const totalWidth = waist + numPleats * 2 * depth;
      el('r-width').textContent = totalWidth.toFixed(1) + ' in';
      el('results').classList.remove('hidden');
    }

    ['waist', 'numPleats', 'depth'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
