---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Thread Consumption Calculator';
const description = 'Estimate total thread length needed for a seam based on seam length and stitch type.';
const intro = 'Estimate total thread length needed for a seam from seam length and stitch type.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why does thread consumption need more length than the seam itself?', a: 'Stitching doesn\'t lay thread in a straight line along the seam — it loops, interlocks, and sometimes wraps around the fabric edge (as in overlocking), so every stitch type uses a multiple of the actual seam length in total thread, not a 1-to-1 length.' },
  { q: 'Why does an overlock/serger stitch use so much more thread than a straight stitch?', a: 'Overlock stitches use multiple threads (commonly 3, 4, or 5) that wrap around the fabric edge to encase and finish it, rather than one or two threads running straight through the fabric, which multiplies the total thread length used per inch of seam.' },
  { q: 'Do these multipliers change with stitch length settings?', a: 'Yes — a shorter stitch length packs more stitches into the same seam length, using more thread, while a longer stitch length uses less; the multipliers here represent a typical medium stitch length setting.' },
  { q: 'How do I convert this to thread spools?', a: 'Check your thread spool\'s labeled yardage (commonly 100-1,000+ yards per spool depending on the brand and thread weight), then divide your total consumption estimate by that number to see how many spools a production run would need.' },
];
const howTo = {
  name: 'How to calculate thread consumption',
  steps: [
    { name: 'Enter total seam length', text: 'Enter the total length of seams to be sewn, in inches.' },
    { name: 'Choose stitch type', text: 'Select the stitch type being used, since each uses a different thread multiplier.' },
    { name: 'Read total thread needed', text: 'The estimated total thread length appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Total seam length (in)</span>
        <input id="seamLen" type="number" step="any" placeholder="e.g. 200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <div>
        <span class="text-sm font-medium text-slate-700">Stitch type</span>
        <select id="stitch" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100">
          <option value="3">Straight lockstitch (301)</option>
          <option value="4.5" selected>Zigzag stitch</option>
          <option value="7">3-thread overlock/serger</option>
          <option value="11">5-thread safety stitch</option>
        </select>
      </div>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total thread needed</div>
        <div id="r-thread" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tcc-title tcc-desc">
      <title id="tcc-title">Straight seam next to a looped, interlocking stitch line</title>
      <desc id="tcc-desc">A short straight line representing a seam, compared to a much longer looping line representing the actual thread path used to stitch it</desc>
      <line x1="100" y1="60" x2="400" y2="60" stroke="#94a3b8" stroke-width="3" />
      <text x="250" y="45" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Seam length</text>
      <path d="M100 130 Q120 110 140 130 Q160 150 180 130 Q200 110 220 130 Q240 150 260 130 Q280 110 300 130 Q320 150 340 130 Q360 110 380 130 Q400 150 420 130" fill="none" stroke="#e11d48" stroke-width="2.5" />
      <text x="260" y="165" text-anchor="middle" font-size="12" fill="#e11d48" font-family="system-ui,sans-serif">Actual thread path (longer)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Stitching loops and interlocks, so thread length always exceeds seam length</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How thread consumption is estimated</h2>
    <p class="mt-2 text-slate-600">
      Every stitch type uses thread less efficiently than a straight line following the seam, since stitching involves loops, interlocking passes, and — for overlock stitches — thread wrapping fully around the fabric edge. This calculator multiplies your total seam length by a factor representing how many times longer the actual thread path is compared to the seam itself: roughly 3 times for a basic straight lockstitch, higher for zigzag, and considerably higher for multi-thread overlock and safety stitches.
    </p>
    <p class="mt-3 text-slate-600">
      These multipliers combine all threads involved in a stitch type — a straight lockstitch uses two threads (needle and bobbin) that together add up to about 3 times the seam length, while a 3-thread overlock's three separate threads combine to roughly 7 times the seam length, since each thread individually travels further due to the looping stitch formation.
    </p>
    <p class="mt-3 text-xs text-slate-400">Multipliers reflect commonly published typical thread-consumption ratios for medium stitch-length settings across garment industry references; exact consumption varies with stitch length, tension, and fabric.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A garment has 200 inches of total seams, sewn with a 3-thread overlock.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Seam length:</span> <span class="text-slate-600">200 in</span></div>
        <div><span class="font-medium text-slate-700">Multiplier:</span> <span class="text-slate-600">7×</span></div>
        <div><span class="font-medium text-slate-700">Thread needed:</span> <span class="text-slate-600">200 × 7 = 1,400 in</span></div>
        <div><span class="font-medium text-slate-700">In yards:</span> <span class="text-slate-600">1,400 ÷ 36 ≈ <strong>38.9 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Small production runs and made-to-order sewing businesses use thread consumption estimates to budget material cost per garment accurately, since thread is a genuine line-item cost that's easy to underestimate when focused mainly on fabric — running out of a specific thread color mid-batch also risks a visible shade mismatch if a new cone comes from a different dye lot.
    </p>
    <p class="mt-3 text-slate-600">
      Home sewists rarely calculate this precisely, but it explains a common frustrating experience: a single spool of all-purpose thread seeming to run out much faster on a project finished entirely with an overlock/serger than on one sewn with a straight stitch alone, even for a similar amount of visible seam.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Thread consumption is roughly equal to seam length." <strong class="text-slate-900">It's several times more.</strong> Even the most thread-efficient common stitch type uses about three times the seam length in total thread, and overlock stitches can use ten times or more.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All overlock stitches use the same amount of thread." <strong class="text-slate-900">Not quite.</strong> A 3-thread overlock uses noticeably less thread than a 4- or 5-thread safety stitch, since each additional thread path in the stitch formation adds its own separate consumption on top of the others.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/stitch-length-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Stitch Length Calculator</a>
      <a href="/tools/needle-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Needle Size Calculator</a>
      <a href="/tools/denier-tex-dtex-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Denier/Tex/Dtex Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const seamLen = parseFloat(el('seamLen').value);
      const multiplier = parseFloat(el('stitch').value);
      if (!seamLen || seamLen <= 0) { el('results').classList.add('hidden'); return; }
      const totalIn = seamLen * multiplier;
      const yards = totalIn / 36;
      el('r-thread').textContent = yards.toFixed(1) + ' yd (' + totalIn.toFixed(0) + ' in)';
      el('results').classList.remove('hidden');
    }

    el('seamLen').addEventListener('input', update);
    el('stitch').addEventListener('change', update);
  </script>
</ToolLayout>
