---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Sock Size Calculator';
const description = 'Find your sock size and alpha size (S/M/L) from your US shoe size.';
const intro = 'Convert a US shoe size into the matching sock size and alpha size.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why is sock size a different number than shoe size?', a: 'Sock sizing traditionally measures the foot length differently than shoe last sizing does, and the hosiery industry settled on its own numbering convention decades ago — as a rough rule, sock size runs about 2 sizes larger in number than the equivalent US shoe size.' },
  { q: 'Do socks really need to be sized precisely?', a: 'Less than shoes, since knit fabric stretches significantly, but a sock that is too small will bunch and feel tight around the toes, while one that is too large will sag and bunch inside the shoe, so getting into the right range still matters for comfort.' },
  { q: 'What does a sock size range like "9-11" mean?', a: 'It means that one sock size is designed to comfortably stretch across shoe sizes in that band — a "9-11" sock is meant to fit feet corresponding to roughly shoe sizes 6 through 9, not literally shoe sizes 9 through 11.' },
  { q: 'Do men\'s and women\'s socks use the same size numbers?', a: 'The sock size number itself is usually gender-neutral (based on foot length), but the shoe-size-to-sock-size mapping differs slightly because men\'s and women\'s shoe sizing scales are offset from each other for the same foot length.' },
];
const howTo = {
  name: 'How to find your sock size',
  steps: [
    { name: 'Choose gender scale', text: 'Select Men\'s or Women\'s, since shoe sizing scales differ between them.' },
    { name: 'Enter your shoe size', text: 'Type your usual US shoe size into the calculator.' },
    { name: 'Read your sock size', text: 'The matching sock size number and alpha size (S/M/L) appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {["Men's", "Women's"].map((d) => (
        <button data-gender={d} class="gender-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">US shoe size</span>
      <input id="shoe" type="number" step="0.5" placeholder="e.g. 9" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">Sock size</div><div id="r-sock" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Alpha size</div><div id="r-alpha" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="skc-title skc-desc">
      <title id="skc-title">Shoe-to-sock size relationship diagram</title>
      <desc id="skc-desc">Two parallel scales showing shoe size aligned against the larger sock size number for the same foot</desc>
      <line x1="100" y1="70" x2="700" y2="70" stroke="#94a3b8" stroke-width="2" />
      <text x="90" y="75" text-anchor="end" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Shoe</text>
      <circle cx="300" cy="70" r="6" fill="#94a3b8" />
      <text x="300" y="55" text-anchor="middle" font-size="13" fill="#1e293b" font-family="system-ui,sans-serif">9</text>
      <line x1="100" y1="140" x2="700" y2="140" stroke="#c026d3" stroke-width="2" />
      <text x="90" y="145" text-anchor="end" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Sock</text>
      <circle cx="420" cy="140" r="6" fill="#c026d3" />
      <text x="420" y="160" text-anchor="middle" font-size="13" fill="#1e293b" font-family="system-ui,sans-serif">11</text>
      <line x1="300" y1="70" x2="420" y2="140" stroke="#f0abfc" stroke-width="1.5" stroke-dasharray="4 3" />
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Sock size numbers typically run about 2 higher than the equivalent US shoe size</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How sock sizing works</h2>
    <p class="mt-2 text-slate-600">
      Sock sizing uses its own numbering convention separate from shoe sizing, rooted in how hosiery manufacturers historically measured foot length. As a general rule adopted across most US sock brands, sock size runs about 2 numbers higher than the equivalent US shoe size — a size 9 shoe typically pairs with a size 11 sock, though because knit fabric stretches, one sock size usually covers a range of two or three shoe sizes comfortably.
    </p>
    <p class="mt-3 text-slate-600">
      Alpha sizing (S/M/L) groups sock sizes into broader bands for casual and athletic socks, similar to how alpha sizing works for gloves — precision matters less because the stretch in knit fabric absorbs small differences in foot size.
    </p>
    <p class="mt-3 text-xs text-slate-400">The shoe-size-plus-2 rule reflects the general convention used across the US hosiery industry; exact ranges vary by manufacturer and sock style.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">Someone wears a men's US shoe size 9 and wants dress socks.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Shoe size:</span> <span class="text-slate-600">US 9</span></div>
        <div><span class="font-medium text-slate-700">Sock size:</span> <span class="text-slate-600">9 + 2 = <strong>11</strong></span></div>
        <div><span class="font-medium text-slate-700">Alpha size:</span> <span class="text-slate-600"><strong>L</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Buying socks as a gift or in bulk multi-packs is the main place sock sizing actually matters, since single pairs bought in person are usually tried against the packaging's printed shoe-size range directly. Multi-packs sized "9-11" or "10-13" force a choice between two overlapping ranges, and knowing the plus-2 conversion helps pick the pack that actually centers on the recipient's foot rather than sitting at its edge.
    </p>
    <p class="mt-3 text-slate-600">
      Compression and athletic socks are more size-sensitive than casual crew socks, since a compression sock relies on a specific fit to apply graduated pressure correctly — sizing too large defeats the compression effect, making an accurate shoe-to-sock conversion more important than for everyday socks.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Sock size 11 means it fits a size 11 shoe." <strong class="text-slate-900">Usually the opposite.</strong> A sock labeled size 11 is generally sized for roughly a size 9 shoe, not an 11 — the sock-size scale runs consistently higher than the shoe-size scale for the same foot.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"One sock size fits any foot reasonably well thanks to stretch." <strong class="text-slate-900">Only within a limited range.</strong> Stretch fabric absorbs a size or two of difference, but a foot far outside a sock's intended range will either bunch at the toe or overstretch and sag.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/shoe-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Shoe Size Converter</a>
      <a href="/tools/shoelace-length-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Shoelace Length Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let gender = "Men's";

    function alphaFor(sockSize) {
      if (sockSize <= 10) return 'S';
      if (sockSize <= 12) return 'M';
      if (sockSize <= 14) return 'L';
      return 'XL';
    }

    function update() {
      const v = parseFloat(el('shoe').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const offset = gender === "Men's" ? 2 : 3; // women's US shoe scale runs ~1 size higher than men's for the same foot
      const sockSize = Math.round(v + offset);
      el('r-sock').textContent = sockSize;
      el('r-alpha').textContent = alphaFor(sockSize);
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.gender-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.gender-btn').forEach((b) => {
          b.className = 'gender-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'gender-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        gender = btn.dataset.gender;
        update();
      });
    });

    el('shoe').addEventListener('input', update);
    document.querySelector('.gender-btn').click();
  </script>
</ToolLayout>
