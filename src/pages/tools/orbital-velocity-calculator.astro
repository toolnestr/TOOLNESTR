---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Orbital Velocity Calculator';
const description = 'Orbital velocity calculator with a live 3D orbit diagram and charts. Solve v = √(GM/r) for the speed of a circular orbit, with presets for LEO, GEO, the Moon, and Mars, plus worked examples.';
const intro = 'Solve v = √(GM/r) for the circular orbital velocity around a body, or rearrange to find the central mass or orbital radius. Two 3D diagrams show concentric orbits at different radii and compare fast, tight orbits to slow, wide ones, with charts showing how orbital velocity falls off with radius and comparing real orbits across the solar system.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is orbital velocity?', a: 'Orbital velocity is the speed an object needs to maintain a stable circular orbit around a central body at a given radius, where gravity exactly supplies the centripetal force needed to keep the orbit circular: v = √(GM/r), with G the gravitational constant and M the central body\'s mass.' },
  { q: 'How is orbital velocity different from escape velocity?', a: 'Orbital velocity (v = √(GM/r)) keeps an object in a stable circular orbit, while escape velocity (v_esc = √(2GM/r)) is the speed needed to leave the body\'s gravity entirely. Escape velocity is always exactly √2 (about 1.414) times the circular orbital velocity at the same radius.' },
  { q: 'Why is the International Space Station\'s orbital velocity so high?', a: 'At an altitude of about 400 km, the ISS needs roughly 7.67 km/s to maintain a stable low Earth orbit — gravity is still nearly as strong there as at the surface, so a very high speed is needed to "fall around" the Earth rather than straight down.' },
  { q: 'Why does the Moon orbit slower than satellites near Earth?', a: 'Orbital velocity falls off as 1/√r — since the Moon orbits at about 3.84×10⁸ m, roughly 57 times farther than a low-Earth-orbit satellite, its required orbital velocity is much lower (about 1.02 km/s) despite orbiting the same planet.' },
  { q: 'Does orbital velocity depend on the mass of the orbiting object?', a: 'No — just like escape velocity, the mass of the orbiting satellite cancels out of the equations of motion entirely. Orbital velocity depends only on the mass of the central body M and the orbital radius r, not on how heavy the satellite itself is.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Orbital Velocity Calculator',
  description: 'Calculate the circular orbital velocity from a central mass and orbital radius, using v = √(GM/r).',
  steps: [
    { name: 'Pick a preset or enter custom values', text: 'Choose LEO (400 km altitude), GEO, the Moon\'s orbit, or Mars around the Sun — or enter your own mass and radius.' },
    { name: 'Choose what to solve for', text: 'Solve for velocity, central mass, or orbital radius from the other two.' },
    { name: 'Read the result', text: 'Orbital velocity solves instantly, and the 3D orbit diagrams and charts update.' },
  ],
};

const formulas = [
  { expr: 'v = √(GM / r)', note: 'circular orbital velocity from central mass and radius' },
  { expr: 'G = 6.674 × 10⁻¹¹ N·m²/kg²', note: 'universal gravitational constant' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — low Earth orbit (LEO)', tone: 'slate',
    given: 'A satellite orbits Earth at 400 km altitude: M = 5.972×10²⁴ kg, r = 6,771,000 m (Earth radius 6.371×10⁶ m + 4×10⁵ m altitude).',
    rows: [
      { label: 'Formula:', value: 'v = √(GM/r)' },
      { label: 'Substitute:', value: 'v = √(6.674×10⁻¹¹ × 5.972×10²⁴ / 6,771,000)' },
      { label: 'Result:', value: 'v ≈ 7672.3 m/s ≈ 7.67 km/s', full: true },
    ],
    note: 'This roughly 7.67 km/s speed is why LEO satellites, including the ISS, orbit the Earth in only about 90 minutes.',
  },
  {
    title: 'Worked example 2 — geostationary orbit (GEO)', tone: 'amber',
    given: 'A geostationary satellite orbits at r = 4.216×10⁷ m, with Earth\'s mass M = 5.972×10²⁴ kg.',
    rows: [
      { label: 'Formula:', value: 'v = √(GM/r)' },
      { label: 'Substitute:', value: 'v = √(6.674×10⁻¹¹ × 5.972×10²⁴ / 4.216×10⁷)' },
      { label: 'Result:', value: 'v ≈ 3074.7 m/s ≈ 3.07 km/s', full: true },
    ],
    note: 'GEO satellites orbit much slower than LEO satellites because they are far higher up — but their orbital period still matches Earth\'s 24-hour rotation, keeping them fixed above one point on the ground.',
  },
];

const comparison = {
  heading: 'Orbital velocity across the solar system',
  note: 'Radius dominates: even though the Sun is vastly more massive than Earth, Mars orbits it slower than a satellite orbits close to Earth, because Mars is so much farther from its central body.',
  headers: [{ label: 'Orbit' }, { label: 'Central mass', sub: 'kg' }, { label: 'Radius', sub: 'm' }, { label: 'v_orbit', sub: 'km/s' }],
  rows: [
    ['Moon around Earth', '5.972 × 10²⁴', '3.844 × 10⁸', '1.018'],
    ['GEO satellite ★', '5.972 × 10²⁴', '4.216 × 10⁷', '3.075'],
    ['LEO satellite (400 km)', '5.972 × 10²⁴', '6.771 × 10⁶', '7.672'],
    ['Mars around Sun', '1.989 × 10³⁰', '2.279 × 10¹¹', '24.135'],
    ['Earth around Sun', '1.989 × 10³⁰', '1.496 × 10¹¹', '29.788'],
  ],
  highlightIndex: 1,
  footnote: '★ GEO reference. Orbital velocity ∝ √(M/r) — Earth around the Sun is faster than Mars around the Sun purely because Earth orbits closer, despite both circling the same central mass.',
};

const realWorld = [
  { emoji: '🛰️', title: 'Satellite mission design', body: 'Engineers use v = √(GM/r) to determine exactly how fast to launch a satellite into a target orbit, whether a fast low-Earth orbit for imaging or a slower geostationary orbit for communications that stays fixed above one location.' },
  { emoji: '🚀', title: 'Rendezvous and docking', body: 'Spacecraft docking with the International Space Station must match both the ISS\'s orbital radius and its orbital velocity almost exactly — any mismatch in speed means drifting away or a dangerously fast collision.' },
  { emoji: '🌕', title: 'The Moon\'s stable orbit', body: "The Moon's roughly 1.02 km/s orbital velocity around Earth has stayed remarkably stable for billions of years, a natural demonstration of the same physics used to design every artificial satellite orbit today." },
  { emoji: '🔭', title: 'Exoplanet detection', body: "Astronomers infer a planet's orbital velocity around its star from the periodic Doppler wobble it induces, then use v = √(GM/r) in reverse to estimate the star's mass or the planet's orbital radius." },
];

const misconceptions = [
  { claim: '"A more massive central body always means a faster orbit at any given distance."', truth: 'Mass increases orbital velocity, but distance matters just as much: v = √(GM/r) falls off with the square root of radius. A satellite very close to a small planet can orbit faster than one very far from a much larger star.' },
  { claim: '"Objects in orbit are not affected by gravity — that\'s why they float."', truth: 'Orbiting objects are very much affected by gravity — it is the entire force providing the centripetal acceleration that curves their path into a circle. "Floating" (weightlessness) happens because both the spacecraft and everything inside it are in continuous free-fall together, not because gravity has vanished.' },
  { claim: '"A heavier satellite needs a higher orbital velocity."', truth: 'Just like escape velocity, the orbiting object\'s own mass cancels out of the physics entirely — a heavier or lighter satellite at the same radius around the same central body needs exactly the same orbital velocity.' },
  { claim: '"Higher orbits mean faster speeds, since they cover more ground."', truth: 'The opposite is true for orbital velocity — v = √(GM/r) actually decreases as radius increases. Higher orbits are slower (though they can still take a longer total time to complete one revolution, or a shorter one, depending on the combination of speed and circumference).' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §13.4 "Satellite Orbits and Energy" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/13-4-satellite-orbits-and-energy" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 13, Gravitation (Satellites: Orbits and Energy).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 13, Universal Gravitation (Kepler\'s Laws).' },
];
const sourcesNote = 'v = √(GM/r) with G ≈ 6.674×10⁻¹¹ N·m²/kg² (CODATA), for a stable circular orbit. Preset masses and radii are standard textbook/NASA reference values. Results are rounded for display.';

const howToUse = [
  { title: 'Pick a preset orbit', body: 'Choose LEO, GEO, the Moon, or Mars around the Sun to auto-fill mass and radius.' },
  { title: 'Choose the unknown', body: 'Solve for orbital velocity, central mass, or orbital radius from the other two.' },
  { title: 'Compare on the chart', body: 'See how orbital velocity falls off with radius, and how it compares across real orbits.' },
];

const related = [
  { href: '/tools/escape-velocity-calculator', emoji: '🛸', title: 'Escape Velocity Calculator', desc: 'v_esc = √(2GM/r) — leave a body\'s gravity for good.' },
  { href: '/tools/gravitational-force-calculator', emoji: '🌍', title: 'Gravitational Force Calculator', desc: "Newton's law of gravitation between masses." },
  { href: '/tools/weight-on-other-planets-calculator', emoji: '🪐', title: 'Weight on Other Planets Calculator', desc: 'W = mg — compare your weight across the solar system.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="Orbital velocity is the exact speed at which gravity's pull on an orbiting object supplies precisely the centripetal force needed to keep it moving in a stable circle, rather than falling in or flying away."
  howIntro="Setting gravitational force equal to the centripetal force requirement, GMm/r² = mv²/r, and canceling the orbiting mass m gives v = √(GM/r). Rearranged, M = v²r/G solves for the central mass, and r = GM/v² solves for the orbital radius. Because v falls off as 1/√r, an orbit four times farther out needs only half the speed to stay in a stable circle."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where orbital velocity actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Pick a preset orbit, or enter a custom mass and radius.</p>
    <div class="mb-4 flex flex-wrap gap-2">
      <button type="button" class="orbit-preset rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white" data-m="5.972e24" data-r="6771000">LEO (400 km alt.)</button>
      <button type="button" class="orbit-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-m="5.972e24" data-r="4.216e7">GEO</button>
      <button type="button" class="orbit-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-m="5.972e24" data-r="3.844e8">Moon's orbit</button>
      <button type="button" class="orbit-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-m="1.989e30" data-r="2.279e11">Mars around Sun</button>
    </div>

    <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-v" type="button" data-solve="v" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Velocity (v)</button>
      <button id="mode-m" type="button" data-solve="m" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Central mass (M)</button>
      <button id="mode-r" type="button" data-solve="r" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Radius (r)</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <label id="field-v" class="block"><span class="text-sm font-medium text-slate-700">Velocity (v)</span>
        <input id="v" type="text" inputmode="decimal" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-m" class="block"><span class="text-sm font-medium text-slate-700">Central mass (M)</span>
        <input id="mass" type="text" inputmode="decimal" placeholder="kg" value="5.972e24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-r" class="block"><span class="text-sm font-medium text-slate-700">Orbital radius (r)</span>
        <input id="radius" type="text" inputmode="decimal" placeholder="m" value="6771000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div id="box-v" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Velocity</div><div id="r-v" class="mt-1 text-2xl font-bold">—</div></div>
      <div id="box-m" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Central mass</div><div id="r-m" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-r" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Radius</div><div id="r-r" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="ov-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Orbits at different radii</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-orbits" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Concentric orbits around a central body</h3>
          <p class="mt-1 text-sm text-slate-600">A central sphere with three concentric orbital paths at different radii, each carrying its own satellite — the wider orbits sit farther from the central body.</p>
        </div>
        <div>
          <div id="diag-speeds" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Tight, fast orbit vs wide, slow orbit</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-amber-500">tight inner orbit</span> has a long velocity arrow (fast), while the <span class="font-semibold text-slate-500">wide outer orbit</span> has a short velocity arrow (slow) — both tangent to their respective paths.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Orbital velocity graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">v vs radius r (fixed M = Earth) — an inverse square-root curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-r"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Orbital velocity comparison — Moon, GEO, LEO, Mars around Sun</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-compare"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const Gc = 6.674e-11;
      const EARTH_M = 5.972e24, LEO_R = 6771000;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      function vorbit(M, r) { return Math.sqrt((Gc * M) / r); }

      // ---- calculator ----
      let solveFor = 'v';
      const modeBtns = { v: 'mode-v', m: 'mode-m', r: 'mode-r' };
      const fieldEls = { v: 'field-v', m: 'field-m', r: 'field-r' };
      const boxEls = { v: 'box-v', m: 'box-m', r: 'box-r' };

      function switchSolve(s) {
        solveFor = s;
        Object.keys(modeBtns).forEach((k) => {
          el(modeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(fieldEls).forEach((k) => { el(fieldEls[k]).style.opacity = k === s ? '0.45' : '1'; });
        Object.keys(boxEls).forEach((k) => {
          el(boxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        update();
      }

      function update() {
        el('ov-err').textContent = '';
        ['r-v', 'r-m', 'r-r'].forEach((id) => (el(id).textContent = '—'));
        const v = parseFloat(el('v').value);
        const M = parseFloat(el('mass').value);
        const r = parseFloat(el('radius').value);
        let V, Mm, R;
        if (solveFor === 'v') {
          if (isNaN(M) || isNaN(r)) return;
          if (r <= 0 || M <= 0) { el('ov-err').textContent = 'Mass and radius must both be positive.'; return; }
          V = vorbit(M, r); Mm = M; R = r;
        } else if (solveFor === 'm') {
          if (isNaN(v) || isNaN(r)) return;
          if (r <= 0 || v <= 0) { el('ov-err').textContent = 'Velocity and radius must both be positive.'; return; }
          Mm = (v * v * r) / Gc; V = v; R = r;
        } else {
          if (isNaN(v) || isNaN(M)) return;
          if (v <= 0 || M <= 0) { el('ov-err').textContent = 'Velocity and mass must both be positive.'; return; }
          R = (Gc * M) / (v * v); V = v; Mm = M;
        }
        el('r-v').textContent = fmt(V) + ' m/s';
        el('r-m').textContent = fmt(Mm) + ' kg';
        el('r-r').textContent = fmt(R) + ' m';
      }
      el('mode-v').addEventListener('click', () => switchSolve('v'));
      el('mode-m').addEventListener('click', () => switchSolve('m'));
      el('mode-r').addEventListener('click', () => switchSolve('r'));
      ['v', 'mass', 'radius'].forEach((id) => el(id).addEventListener('input', update));

      document.querySelectorAll('.orbit-preset').forEach((b) => b.addEventListener('click', () => {
        document.querySelectorAll('.orbit-preset').forEach((x) => (x.className = 'orbit-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600'));
        b.className = 'orbit-preset rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white';
        el('mass').value = b.getAttribute('data-m');
        el('radius').value = b.getAttribute('data-r');
        switchSolve('v');
      }));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const L1 = [], D1 = [];
        for (let mult = 1; mult <= 10.001; mult += 0.3) { L1.push(mult.toFixed(1)); D1.push(+(vorbit(EARTH_M, LEO_R * mult) / 1000).toFixed(3)); }
        charts.r = new Chart(el('chart-r'), {
          type: 'line',
          data: { labels: L1, datasets: [{ label: 'v', data: D1, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Radius (× LEO radius)' } }, y: { title: { display: true, text: 'Orbital velocity (km/s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        const bodies = [
          { name: 'Moon', v: 1.018 },
          { name: 'GEO', v: 3.075 },
          { name: 'LEO', v: 7.672 },
          { name: 'Mars/Sun', v: 24.135 },
        ];
        charts.compare = new Chart(el('chart-compare'), {
          type: 'bar',
          data: { labels: bodies.map((b) => b.name), datasets: [{ label: 'v (km/s)', data: bodies.map((b) => b.v), backgroundColor: ['#94a3b8', '#38bdf8', '#6366f1', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Orbital velocity (km/s, log scale)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: concentric orbits ----
      let diagOrbits = null;
      function initDiagOrbits() {
        const c = el('diag-orbits'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), OPTS);
        const planet = new THREE.Mesh(new THREE.SphereGeometry(1, 28, 24), new THREE.MeshStandardMaterial({ color: 0x2563eb, roughness: 0.6 }));
        s.scene.add(planet);

        const radii = [2.4, 3.6, 4.8];
        const colors = [0xf59e0b, 0x10b981, 0x94a3b8];
        radii.forEach((rad, i) => {
          const curve = new THREE.EllipseCurve(0, 0, rad, rad, 0, Math.PI * 2, false, 0);
          const pts = curve.getPoints(64).map((p) => new THREE.Vector3(p.x, 0, p.y));
          const geo = new THREE.BufferGeometry().setFromPoints(pts);
          const ring = new THREE.Line(geo, new THREE.LineBasicMaterial({ color: colors[i] }));
          s.scene.add(ring);
          const sat = new THREE.Mesh(new THREE.SphereGeometry(0.22, 16, 14), new THREE.MeshStandardMaterial({ color: colors[i] }));
          sat.position.set(rad, 0, 0);
          s.scene.add(sat);
        });

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagOrbits = { resize: s.resize };
      }

      // ---- Diagram 2: fast tight orbit vs slow wide orbit with velocity arrows ----
      let diagSpeeds = null;
      function initDiagSpeeds() {
        const c = el('diag-speeds'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), OPTS);
        const planet = new THREE.Mesh(new THREE.SphereGeometry(1, 28, 24), new THREE.MeshStandardMaterial({ color: 0x2563eb, roughness: 0.6 }));
        s.scene.add(planet);

        function addOrbitWithArrow(rad, arrowLen, color) {
          const curve = new THREE.EllipseCurve(0, 0, rad, rad, 0, Math.PI * 2, false, 0);
          const pts = curve.getPoints(64).map((p) => new THREE.Vector3(p.x, 0, p.y));
          const geo = new THREE.BufferGeometry().setFromPoints(pts);
          s.scene.add(new THREE.Line(geo, new THREE.LineBasicMaterial({ color })));
          const sat = new THREE.Mesh(new THREE.SphereGeometry(0.22, 16, 14), new THREE.MeshStandardMaterial({ color }));
          sat.position.set(rad, 0, 0);
          s.scene.add(sat);
          // tangent direction at (rad, 0) moving counterclockwise is (0, 0, -1)*rad direction -> tangent = (0,0,-1)
          const tip = new THREE.Vector3(rad, 0, -arrowLen);
          s.scene.add(arrow(sat.position, tip, color));
        }
        addOrbitWithArrow(2.2, 2.2, 0xf59e0b); // tight, fast
        addOrbitWithArrow(5.0, 0.8, 0x94a3b8); // wide, slow

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagSpeeds = { resize: s.resize };
      }

      function boot() {
        try { switchSolve('v'); update(); } catch (e) { console.error('[orbital-velocity] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[orbital-velocity] charts failed', e); }
        if (window.THREE) {
          try { initDiagOrbits(); } catch (e) { console.error('[orbital-velocity] orbits diagram failed', e); }
          try { initDiagSpeeds(); } catch (e) { console.error('[orbital-velocity] speeds diagram failed', e); }
        }
        mountResize([diagOrbits, diagSpeeds]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
