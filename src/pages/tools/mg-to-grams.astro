---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Mg to Grams"
  emoji="⚖️"
  fromUnit="milligrams" toUnit="grams"
  fromTitle="Milligrams" toTitle="Grams"
  fromSym="mg" toSym="g"
  quantity="weight"
  kind="factor" factor={0.001}
  reverseSlug="grams-to-ounces" reverseLabel="Grams to Ounces Converter"
  hasReverse={false}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Common in medicine and nutrition, where dosages and micro-ingredients are given in milligrams but totalled in grams."
/>
