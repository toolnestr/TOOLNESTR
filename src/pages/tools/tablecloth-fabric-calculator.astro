---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Tablecloth Fabric Calculator';
const description = 'Calculate fabric yardage needed for a rectangular or round tablecloth, including drop length and hem.';
const intro = 'Calculate fabric yardage for a rectangular or round tablecloth from table size and drop length.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is "drop length"?', a: 'Drop length is how far the tablecloth hangs down past the table edge on each side — a common casual drop is 6-8 inches, a formal floor-length drop can be 24-30 inches depending on table height.' },
  { q: 'Why do round tablecloths need a square of fabric?', a: 'A round tablecloth is normally cut from a square piece of fabric with a side length equal to the finished diameter, then trimmed into a circle — you can\'t avoid buying the full square\'s worth of fabric even though the corners are cut away and discarded.' },
  { q: 'What if my finished width is wider than the fabric bolt?', a: 'For a rectangular cloth wider than one fabric width, the calculator adds a second panel seamed down the middle (or two side panels), which uses roughly double the length for the width portion — the tool accounts for this automatically.' },
  { q: 'Should I add extra for hemming?', a: 'Yes, a small hem allowance (commonly 1-2 inches) is included as a separate input so the finished, hemmed tablecloth matches your intended drop exactly rather than losing an inch or two to the hem fold.' },
];
const howTo = {
  name: 'How to calculate tablecloth fabric',
  steps: [
    { name: 'Choose shape and enter table size', text: 'Select rectangular or round, and enter your table\'s dimensions.' },
    { name: 'Enter drop and hem allowance', text: 'Enter how far you want the cloth to hang down, plus a small hem allowance.' },
    { name: 'Read fabric needed', text: 'Total fabric yardage, accounting for seaming if needed, appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Rectangular', 'Round'].map((d) => (
        <button data-shape={d} class="shape-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <div id="rect-fields" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Table length (in)</span>
        <input id="tLen" type="number" step="any" placeholder="e.g. 72" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Table width (in)</span>
        <input id="tWid" type="number" step="any" placeholder="e.g. 36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="round-fields" class="mt-4 hidden">
      <label class="block"><span class="text-sm font-medium text-slate-700">Table diameter (in)</span>
        <input id="tDia" type="number" step="any" placeholder="e.g. 48" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Drop length (in)</span>
        <input id="drop" type="number" step="any" value="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Hem allowance (in)</span>
        <input id="hem" type="number" step="any" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fabric width (in)</span>
        <input id="fabWid" type="number" step="any" value="54" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Fabric needed</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="mt-1 text-sm opacity-90"></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tfc-title tfc-desc">
      <title id="tfc-title">Table with tablecloth drop shown on the side</title>
      <desc id="tfc-desc">A rectangular table shown from the side with fabric draping down past the table edge, labeled as the drop</desc>
      <rect x="250" y="70" width="300" height="20" fill="#94a3b8" />
      <path d="M250 90 L235 160 L250 160 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      <path d="M550 90 L565 160 L550 160 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      <rect x="250" y="90" width="300" height="8" fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      <line x1="565" y1="90" x2="600" y2="90" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="4 3" />
      <line x1="600" y1="90" x2="600" y2="160" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="4 3" />
      <text x="630" y="130" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Drop</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Drop length is how far the tablecloth hangs past the table edge</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How tablecloth fabric is calculated</h2>
    <p class="mt-2 text-slate-600">
      For a rectangular tablecloth, the finished length and width are each the table's own dimension plus twice the drop (since the cloth hangs down on both opposite sides) plus a small hem allowance. If the finished width exceeds your fabric's usable width, a second fabric panel needs to be seamed in, roughly doubling the length of fabric required to cover that width.
    </p>
    <p class="mt-3 text-slate-600">
      For a round tablecloth, the finished diameter is the table's diameter plus twice the drop plus hem allowance, and — because round shapes are cut from a square of fabric with the corners trimmed away — the fabric length needed equals that same finished diameter, not a smaller circular calculation.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows standard home-decor sewing practice for drop-and-hem tablecloth construction.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 72 × 36 inch table, 8-inch drop, 1-inch hem, cut from 54-inch-wide fabric.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Finished length:</span> <span class="text-slate-600">72 + 16 + 2 = 90 in</span></div>
        <div><span class="font-medium text-slate-700">Finished width:</span> <span class="text-slate-600">36 + 16 + 2 = 54 in</span></div>
        <div><span class="font-medium text-slate-700">Fits one width:</span> <span class="text-slate-600">54 ≤ 54 in fabric</span></div>
        <div><span class="font-medium text-slate-700">Fabric needed:</span> <span class="text-slate-600">90 in ÷ 36 = <strong>2.5 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Formal dining tables and banquet tables often exceed standard fabric widths, especially for a floor-length drop on a wide table, so knowing in advance that a seamed center panel is needed avoids an unpleasant surprise partway through cutting a single length of expensive formal fabric.
    </p>
    <p class="mt-3 text-slate-600">
      Round tables catch first-time sewists off guard the most, since it's intuitive to assume a round shape needs less fabric than a square of the same width — in practice it needs exactly as much fabric as the enclosing square, with the corner fabric simply cut away and wasted rather than saved.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A round tablecloth uses less fabric than a square one of the same size." <strong class="text-slate-900">It doesn't.</strong> Both are cut from the same size square of fabric — the round shape just discards the corner fabric rather than using it.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Drop length only affects the sides, not fabric needed for the top." <strong class="text-slate-900">It affects the whole finished size.</strong> Drop is added to both the length and width dimensions since the cloth must hang on every side, so it increases the total fabric footprint on all edges, not just two.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pillow-box-cushion-fabric-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Pillow/Box Cushion Fabric Calculator</a>
      <a href="/tools/curtain-panel-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Curtain Panel Calculator</a>
      <a href="/tools/fabric-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Cost Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let shape = 'Rectangular';

    function update() {
      const drop = parseFloat(el('drop').value) || 0;
      const hem = parseFloat(el('hem').value) || 0;
      const fabWid = parseFloat(el('fabWid').value);
      if (!fabWid || fabWid <= 0) { el('results').classList.add('hidden'); return; }

      if (shape === 'Rectangular') {
        const tLen = parseFloat(el('tLen').value);
        const tWid = parseFloat(el('tWid').value);
        if (!tLen || !tWid || tLen <= 0 || tWid <= 0) { el('results').classList.add('hidden'); return; }
        const finLen = tLen + 2 * drop + 2 * hem;
        const finWid = tWid + 2 * drop + 2 * hem;
        const panels = Math.ceil(finWid / fabWid);
        const totalIn = finLen * panels;
        el('r-yards').textContent = (totalIn / 36).toFixed(2) + ' yd';
        el('r-note').textContent = panels > 1 ? panels + ' panels seamed for width' : 'Fits one fabric width';
      } else {
        const tDia = parseFloat(el('tDia').value);
        if (!tDia || tDia <= 0) { el('results').classList.add('hidden'); return; }
        const finDia = tDia + 2 * drop + 2 * hem;
        const panels = Math.ceil(finDia / fabWid);
        const totalIn = finDia * panels;
        el('r-yards').textContent = (totalIn / 36).toFixed(2) + ' yd';
        el('r-note').textContent = 'Cut from a ' + finDia.toFixed(0) + ' in square, corners trimmed to round';
      }
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.shape-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.shape-btn').forEach((b) => {
          b.className = 'shape-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'shape-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        shape = btn.dataset.shape;
        el('rect-fields').classList.toggle('hidden', shape !== 'Rectangular');
        el('round-fields').classList.toggle('hidden', shape !== 'Round');
        update();
      });
    });

    ['tLen', 'tWid', 'tDia', 'drop', 'hem', 'fabWid'].forEach((id) => el(id).addEventListener('input', update));
    document.querySelector('.shape-btn').click();
  </script>
</ToolLayout>
