---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Impulse Calculator';
const description = 'Impulse calculator with a live 3D strike animation and charts. Solve J = FΔt = Δp = mΔv for force, time, or momentum change, with worked examples and a force-vs-time area view.';
const intro = 'Solve the impulse–momentum theorem J = FΔt = Δp from any two of force, time and impulse, or from mass and the change in velocity. A live 3D puck shows a strike in action, and charts show impulse as the area under a force–time graph.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is impulse?', a: 'Impulse (J) is the change in momentum produced by a force acting over a time interval: J = FΔt for a constant force, and J = Δp = m(v_f − v_i) by the impulse–momentum theorem. Units are newton-seconds (N·s), the same as kg·m/s.' },
  { q: 'How is impulse different from momentum?', a: 'Momentum (p = mv) describes the motion an object has right now. Impulse is the change delivered to that momentum by a force over time — it is the "action" that alters momentum, not a property an object carries by itself.' },
  { q: 'What if the force is not constant?', a: 'Then J = FΔt only works with the average force. In general, impulse is the area under a force-vs-time graph: J = ∫F dt. This calculator assumes a constant (or average) force, which is exactly the area of a rectangle F × Δt.' },
  { q: 'Why do airbags and padded gloves reduce force?', a: 'The impulse needed to stop a given object at a given speed (Δp) is fixed. Since J = FΔt, stretching out Δt over a longer time reduces the average force F needed to deliver the same impulse — that is the entire principle behind airbags, crash mats and boxing gloves.' },
  { q: 'Can impulse be negative?', a: 'Yes. Impulse is a vector in the direction of the force. If a force decelerates an object, the impulse is opposite to the direction of motion, and Δp = m(v_f − v_i) comes out negative if v_f < v_i along your chosen positive axis.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Impulse Calculator',
  description: 'Calculate impulse from force and time, or from a change in momentum.',
  steps: [
    { name: 'Pick a mode', text: 'Choose "Force & time" (J = FΔt) or "Momentum change" (J = mΔv).' },
    { name: 'Enter the values', text: 'Type any two of the three quantities in the chosen mode.' },
    { name: 'Read the result', text: 'The impulse solves instantly, and the 3D strike and charts update.' },
  ],
};

const formulas = [
  { expr: 'J = F · Δt', note: 'impulse from a constant (or average) force acting over a time interval' },
  { expr: 'J = Δp = m(v<sub>f</sub> − v<sub>i</sub>)', note: 'impulse–momentum theorem — impulse equals the resulting change in momentum' },
  { expr: 'J = area under F–t graph', note: 'for a varying force, impulse is the area under the curve, not just F×Δt' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — hockey puck slap shot', tone: 'slate',
    given: 'A stick applies an average force of 400 N to a 0.17 kg puck for 0.015 s. Find the impulse and the resulting change in velocity (puck starts at rest).',
    rows: [
      { label: 'Impulse:', value: 'J = F · Δt = 400 × 0.015 = 6.0 N·s' },
      { label: 'Change in velocity:', value: 'Δv = J / m = 6.0 ÷ 0.17 ≈ 35.3 m/s' },
      { label: 'Check:', value: 'Δp = mΔv = 0.17 × 35.3 ≈ 6.0 kg·m/s — matches J', full: true },
    ],
  },
  {
    title: 'Worked example 2 — catching a ball softly', tone: 'amber',
    given: 'A 0.15 kg ball arrives at 18 m/s and is brought to rest. Compare a rigid catch (Δt = 0.01 s) with a soft "giving" catch (Δt = 0.15 s).',
    rows: [
      { label: 'Required impulse (fixed):', value: 'J = Δp = 0.15 × 18 = 2.7 N·s (both cases)' },
      { label: 'Rigid catch force:', value: 'F = J / Δt = 2.7 ÷ 0.01 = 270 N' },
      { label: 'Soft catch force:', value: 'F = J / Δt = 2.7 ÷ 0.15 = 18 N', full: true },
    ],
    note: 'Same impulse, but a 15× longer catch time cuts the average force by 15× — why "giving" with a catch doesn\'t sting.',
  },
];

const comparison = {
  heading: 'Typical impulses in sports and safety',
  note: 'Approximate values — impulse is what changes an object\'s momentum in a collision or strike.',
  headers: [{ label: 'Event' }, { label: 'Force', sub: 'N (approx.)' }, { label: 'Time', sub: 's' }, { label: 'Impulse', sub: 'N·s' }],
  rows: [
    ['Tennis serve', '~600', '0.005', '~3'],
    ['Football kick', '~1,500', '0.008', '~12'],
    ['Boxing punch (gloved)', '~2,500', '0.015', '~38'],
    ['Car airbag deployment', '~5,000', '0.15', '~750'],
    ['Car crash without airbag', '~50,000', '0.02', '~1,000'],
  ],
  highlightIndex: 3,
  footnote: 'Impulse J = FΔt is the area of the force–time rectangle; real strikes have varying force, so these are average-force estimates.',
};

const realWorld = [
  { emoji: '🎈', title: 'Airbags and crumple zones', body: 'A crash must remove a fixed amount of momentum (a fixed impulse). Airbags and crumple zones extend the stopping time Δt, which — since F = J/Δt — sharply cuts the peak force on the occupant.' },
  { emoji: '🥊', title: 'Padding and follow-through', body: 'Boxing gloves, catcher\'s mitts and crash mats all work the same way: spreading a fixed impulse over more time lowers the force. Follow-through in golf, tennis and batting does the opposite on purpose — it extends contact time to deliver more impulse (more Δp) to the ball.' },
  { emoji: '🖐️', title: 'Catching a ball', body: '"Giving" with your hands as you catch increases Δt for the same required impulse, reducing the sting compared to catching rigidly.' },
];

const misconceptions = [
  { claim: '"Impulse and force are the same thing."', truth: 'Force is measured in newtons; impulse is force accumulated over time, measured in newton-seconds. A small force applied for a long time can deliver the same impulse as a huge force applied briefly.' },
  { claim: '"J = FΔt works for any force."', truth: 'It only gives the exact impulse for a constant force, or F as the average force. For a force that changes with time, impulse is the area under the F–t curve, which may not equal (peak F) × Δt.' },
  { claim: '"Longer contact time always means a bigger hit."', truth: 'It depends on what you\'re trying to do. To reduce force for the same impulse (airbags, catching), you want a longer Δt. To increase impulse itself (a golf swing), you want a longer Δt at a sustained force — the goal, not the time alone, determines what "better" means.' },
  { claim: '"Impulse only matters in collisions."', truth: 'Impulse describes any momentum change from a force over time — throwing a ball, a rocket burn, or a sustained push all involve impulse, not just crashes.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §9.2 "Impulse and Collisions" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/9-2-impulse-and-collisions" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 9, Center of Mass and Linear Momentum.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 9, Linear Momentum and Collisions.' },
];
const sourcesNote = 'Results are rounded for display. Impulse and momentum share units: 1 N·s = 1 kg·m/s.';

const howToUse = [
  { title: 'Pick the mode', body: '"Force & time" for J = FΔt; "Momentum change" for J = mΔv.' },
  { title: 'Enter two values', body: 'Fill any two of the three fields; the third solves live.' },
  { title: 'Watch the strike', body: 'Use the sliders to see how force and duration shape the impulse and the resulting velocity change.' },
];

const related = [
  { href: '/tools/momentum-calculator', emoji: '🎯', title: 'Momentum & Impulse Calculator', desc: 'p = mv plus a combined impulse mode.' },
  { href: '/tools/force-calculator', emoji: '💥', title: 'Force Calculator', desc: 'F = ma — solve for any variable.' },
  { href: '/tools/uniform-circular-motion-calculator', emoji: '🔄', title: 'Uniform Circular Motion Calculator', desc: 'Centripetal accel/force, period, ω from r and v.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="impulse is what a force actually does to motion over time — it's the push, sustained, and it equals exactly the change in momentum it causes."
  howIntro="Rearranging the impulse–momentum theorem gives F = J/Δt: for a fixed impulse (a fixed momentum change), a longer contact time means a smaller average force. That single rearrangement explains airbags, padded gloves and why 'giving' with a catch doesn't hurt."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where impulse actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-ft" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Force &amp; time (J = FΔt)</button>
      <button id="mode-mv" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Momentum change (J = mΔv)</button>
    </div>
    <div id="ft-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Impulse (J)</span>
        <input id="J" type="number" step="any" placeholder="N·s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="F" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time (Δt)</span>
        <input id="dt" type="number" step="any" placeholder="s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="mv-fields" class="hidden gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Impulse (J)</span>
        <input id="J2" type="number" step="any" placeholder="N·s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mm" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Δv (v<sub>f</sub> − v<sub>i</sub>)</span>
        <input id="dv" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Impulse</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Force</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Time</div><div id="r-3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="imp-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-area" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Impulse is the area under F–t</h3>
          <p class="mt-1 text-sm text-slate-600">The stacked bars trace out a force-vs-time rectangle. Their combined volume is exactly J = FΔt — impulse is literally the area (here, volume) swept out while the force acts.</p>
        </div>
        <div>
          <div id="diag-strike" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. A struck object gains velocity</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-red-500">red arrow</span> shows the force hitting the puck; the <span class="font-semibold text-emerald-500">green arrow</span> shows the velocity change (Δv) it produces — the impulse–momentum theorem, drawn as two vectors.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Impulse graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Force vs time — impulse is the shaded area (F × Δt)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ft"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Impulse vs Δt at your current force — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-jt"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      // ---- calculator ----
      let mode = 'ft';
      function switchMode(m) {
        mode = m;
        el('mode-ft').className = m === 'ft' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-mv').className = m === 'mv' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('ft-fields').className = m === 'ft' ? 'grid gap-4 sm:grid-cols-3' : 'hidden';
        el('mv-fields').className = m === 'mv' ? 'grid gap-4 sm:grid-cols-3' : 'hidden gap-4 sm:grid-cols-3';
        el('lab-1').textContent = 'Impulse';
        el('lab-2').textContent = m === 'ft' ? 'Force' : 'Mass';
        el('lab-3').textContent = m === 'ft' ? 'Time' : 'Δv';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        el('imp-err').textContent = '';
      }
      function update() {
        el('imp-err').textContent = '';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        if (mode === 'ft') {
          const J = parseFloat(el('J').value), F = parseFloat(el('F').value), dt = parseFloat(el('dt').value);
          const filled = [!isNaN(J), !isNaN(F), !isNaN(dt)];
          if (filled.filter(Boolean).length < 2) return;
          let rJ = NaN, rF = NaN, rdt = NaN;
          if (filled[1] && filled[2]) { rJ = F * dt; rF = F; rdt = dt; }
          else if (filled[0] && filled[2]) { if (dt === 0) { el('imp-err').textContent = 'Time cannot be zero.'; return; } rF = J / dt; rJ = J; rdt = dt; }
          else if (filled[0] && filled[1]) { if (F === 0) { el('imp-err').textContent = 'Force cannot be zero when solving for time.'; return; } rdt = J / F; rJ = J; rF = F; }
          if (!isNaN(rJ)) el('r-1').textContent = fmt(rJ) + ' N·s';
          if (!isNaN(rF)) el('r-2').textContent = fmt(rF) + ' N';
          if (!isNaN(rdt)) el('r-3').textContent = fmt(rdt) + ' s';
        } else {
          const J = parseFloat(el('J2').value), m = parseFloat(el('mm').value), dv = parseFloat(el('dv').value);
          const filled = [!isNaN(J), !isNaN(m), !isNaN(dv)];
          if (filled.filter(Boolean).length < 2) return;
          let rJ = NaN, rm = NaN, rdv = NaN;
          if (filled[1] && filled[2]) { rJ = m * dv; rm = m; rdv = dv; }
          else if (filled[0] && filled[2]) { if (dv === 0) { el('imp-err').textContent = 'Δv cannot be zero when solving for mass.'; return; } rm = J / dv; rJ = J; rdv = dv; }
          else if (filled[0] && filled[1]) { if (m === 0) { el('imp-err').textContent = 'Mass cannot be zero.'; return; } rdv = J / m; rJ = J; rm = m; }
          if (!isNaN(rJ)) el('r-1').textContent = fmt(rJ) + ' N·s';
          if (!isNaN(rm)) el('r-2').textContent = fmt(rm) + ' kg';
          if (!isNaN(rdv)) el('r-3').textContent = fmt(rdv) + ' m/s';
        }
      }
      el('mode-ft').addEventListener('click', () => { switchMode('ft'); update(); });
      el('mode-mv').addEventListener('click', () => { switchMode('mv'); update(); });
      ['J', 'F', 'dt', 'J2', 'mm', 'dv'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts shared state ----
      const charts = {};
      function bState() {
        const F = 400, t = 0.015, m = 0.17;
        const J = F * t, dv = m > 0 ? J / m : 0;
        return { F, t, m, J, dv };
      }

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.ft = new Chart(el('chart-ft'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'F', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.18)', fill: true, stepped: true, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Force (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.jt = new Chart(el('chart-jt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'J', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Δt (s)' } }, y: { title: { display: true, text: 'Impulse J (N·s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        // F-t rectangle: 0 up to t=0, jump to F, hold to Δt, drop to 0, hold to 1.2*Δt
        const pad = Math.max(s.t * 0.3, 0.005);
        const L1 = [0, 0, s.t, s.t, s.t + pad].map((v) => v.toFixed(4));
        const D1 = [0, s.F, s.F, 0, 0];
        charts.ft.data.labels = L1; charts.ft.data.datasets[0].data = D1; charts.ft.update();

        const L2 = [], D2 = [];
        const maxT = Math.max(0.3, s.t * 2);
        for (let tt = 0; tt <= maxT + 1e-9; tt += maxT / 20) { L2.push(tt.toFixed(3)); D2.push(+(s.F * tt).toFixed(3)); }
        charts.jt.data.labels = L2; charts.jt.data.datasets[0].data = D2; charts.jt.update();
      }

      // ================= THREE.js STANDALONE DIAGRAMS =================
      let diagArea = null, diagStrike = null;

      // ---- Diagram 1: force-vs-time "area under curve" as stacked bars (auto-rotating) ----
      function initDiagArea() {
        const c = el('diag-area'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0.6, 0), OPTS);
        s.scene.add(new THREE.GridHelper(8, 8, 0xe2e8f0, 0xeef2f7));
        const n = 6;
        const barMat = new THREE.MeshStandardMaterial({ color: 0xef4444, roughness: 0.4 });
        for (let i = 0; i < n; i++) {
          const bar = new THREE.Mesh(new THREE.BoxGeometry(0.5, 1.4, 0.5), barMat);
          bar.position.set(-2.5 + i * 1, 0.7, 0);
          s.scene.add(bar);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0035); s.renderer.render(s.scene, s.camera); }
        frame();
        diagArea = { resize: s.resize };
      }

      // ---- Diagram 2: struck puck — force arrow + velocity-change arrow (auto-rotating) ----
      function initDiagStrike() {
        const c = el('diag-strike'); if (!c) throw new Error('no container');
        const s = makeScene(c, 11, new THREE.Vector3(0, 0.4, 0), OPTS);
        s.scene.add(new THREE.GridHelper(16, 16, 0xe2e8f0, 0xeef2f7));
        const disc = new THREE.Mesh(new THREE.CylinderGeometry(0.7, 0.7, 0.35, 32), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
        disc.position.set(0, 0.2, 0);
        s.scene.add(disc);
        s.scene.add(arrow(new THREE.Vector3(-3.2, 0.2, 0), new THREE.Vector3(-0.9, 0.2, 0), 0xef4444));
        s.scene.add(arrow(new THREE.Vector3(0.9, 0.9, 0), new THREE.Vector3(3.4, 0.9, 0), 0x10b981));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagStrike = { resize: s.resize };
      }

      function boot() {
        try { switchMode('ft'); update(); } catch (e) { console.error('[impulse] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[impulse] charts failed', e); }
        if (window.THREE) {
          try { initDiagArea(); } catch (e) { console.error('[impulse] diagram 1 failed', e); }
          try { initDiagStrike(); } catch (e) { console.error('[impulse] diagram 2 failed', e); }
        }
        mountResize([diagArea, diagStrike]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
