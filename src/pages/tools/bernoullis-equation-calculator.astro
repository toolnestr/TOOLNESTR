---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Bernoulli's Equation Calculator";
const description = "Bernoulli's equation calculator with a live 3D Venturi-tube diagram and charts. Find pressure at a second point in a flowing fluid from velocity and elevation changes, with worked examples.";
const intro = "Solve Bernoulli's equation P₁ + ½ρv₁² + ρgh₁ = P₂ + ½ρv₂² + ρgh₂ for the pressure at a second point in a flow, accounting for both speed changes and elevation changes. Two 3D diagrams show a Venturi tube constriction and an airfoil generating lift, with charts showing how pressure responds to velocity and height.";
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: "What is Bernoulli's equation?", a: "Bernoulli's equation, P₁ + ½ρv₁² + ρgh₁ = P₂ + ½ρv₂² + ρgh₂, expresses conservation of energy for an ideal, incompressible, non-viscous fluid in steady flow — it relates pressure, kinetic energy (from speed), and potential energy (from height) at any two points along a streamline." },
  { q: 'Why does pressure drop where fluid speeds up?', a: "In a horizontal flow (h₁ = h₂), Bernoulli's equation reduces to P₁ + ½ρv₁² = P₂ + ½ρv₂². Since the sum must stay constant, a faster speed at point 2 means a lower pressure at point 2 — this is the Venturi effect, used in carburetors, atomizers, and airflow measurement." },
  { q: 'How does elevation affect pressure in Bernoulli\'s equation?', a: 'The ρgh term acts exactly like hydrostatic pressure — fluid flowing to a higher elevation loses pressure (or speed) to "pay for" the increase in gravitational potential energy, just as it would if it were standing still.' },
  { q: "What assumptions does Bernoulli's equation make?", a: 'It assumes the fluid is incompressible (constant density), inviscid (no internal friction/viscosity), and the flow is steady along a single streamline. Real fluids like air and water deviate from this ideal, especially at high speeds or with turbulence, but the equation is an excellent approximation in many engineering situations.' },
  { q: 'How does Bernoulli\'s principle explain lift on an airplane wing?', a: "An airfoil is shaped so air travels faster over the curved top surface than along the flatter bottom. By Bernoulli's principle, that faster-moving air over the top has lower pressure than the slower air below, creating a net upward force — lift (though modern aerodynamics shows this is only part of the full explanation, which also involves Newton's third law and airflow deflection)." },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: "How to use the Bernoulli's Equation Calculator",
  description: 'Find the pressure at a second point in a flowing fluid from the pressure, speed, and elevation at a first point.',
  steps: [
    { name: 'Enter conditions at point 1', text: 'Provide fluid density ρ, pressure P₁, velocity v₁, and elevation h₁.' },
    { name: 'Enter conditions at point 2', text: 'Provide velocity v₂ and elevation h₂ (from continuity or a given pipe geometry).' },
    { name: 'Read the result', text: 'Pressure P₂ solves instantly, accounting for both the speed change and the elevation change.' },
  ],
};

const formulas = [
  { expr: 'P₁ + ½ρv₁² + ρgh₁ = P₂ + ½ρv₂² + ρgh₂', note: "Bernoulli's equation — conservation of energy along a streamline" },
  { expr: 'P₂ = P₁ + ½ρ(v₁² − v₂²) + ρg(h₁ − h₂)', note: 'rearranged to solve directly for the unknown pressure at point 2' },
  { expr: 'A₁v₁ = A₂v₂', note: 'continuity equation — used alongside Bernoulli to relate velocity to pipe cross-sectional area' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a horizontal pipe constriction (Venturi effect)', tone: 'slate',
    given: 'Water (ρ = 1000 kg/m³) flows through a horizontal pipe (h₁ = h₂). At the wide section, P₁ = 200,000 Pa and v₁ = 2 m/s. At a narrower section, the speed rises to v₂ = 5 m/s. Find P₂.',
    rows: [
      { label: 'Formula (h₁=h₂):', value: 'P₂ = P₁ + ½ρ(v₁² − v₂²)' },
      { label: 'Substitute:', value: 'P₂ = 200,000 + 0.5 × 1000 × (2² − 5²) = 200,000 + 500 × (4 − 25)' },
      { label: 'Result:', value: 'P₂ = 200,000 − 10,500 = 189,500 Pa', full: true },
    ],
    note: 'Pressure drops by 10,500 Pa in the faster, narrower section — the same Venturi effect used in carburetors and perfume atomizers to draw in a second fluid at the low-pressure point.',
  },
  {
    title: 'Worked example 2 — an oil pipeline rising in elevation', tone: 'amber',
    given: 'Oil (ρ = 850 kg/m³) flows through a pipe of constant diameter (so v₁ = v₂ = 3 m/s). P₁ = 300,000 Pa at h₁ = 0 m, rising to h₂ = 10 m.',
    rows: [
      { label: 'Formula (v₁=v₂):', value: 'P₂ = P₁ + ρg(h₁ − h₂)' },
      { label: 'Substitute:', value: 'P₂ = 300,000 + 850 × 9.81 × (0 − 10) = 300,000 − 83,385' },
      { label: 'Result:', value: 'P₂ = 216,615 Pa', full: true },
    ],
    note: 'Even with no speed change, pressure drops by over 83 kPa just from climbing 10 m — the same hydrostatic penalty water pays when pumped up to a rooftop tank.',
  },
];

const comparison = {
  heading: 'The Venturi effect — pipe narrowing vs pressure drop',
  note: 'Fixed inlet v₁ = 2 m/s, P₁ = 200,000 Pa, water (ρ = 1000 kg/m³), horizontal pipe — narrower area ratios force higher exit speeds via continuity, which drop the pressure further.',
  headers: [{ label: 'Area ratio A₁/A₂' }, { label: 'Exit speed v₂' }, { label: 'Pressure P₂' }],
  rows: [
    ['1× (no change)', '2 m/s', '200,000 Pa'],
    ['2× narrower ★', '4 m/s', '194,000 Pa'],
    ['3× narrower', '6 m/s', '184,000 Pa'],
    ['4× narrower', '8 m/s', '170,000 Pa'],
  ],
  highlightIndex: 1,
  footnote: '★ Computed via continuity v₂ = v₁×(A₁/A₂), then Bernoulli P₂ = P₁ + ½ρ(v₁²−v₂²). Pressure keeps falling faster than the area ratio because kinetic energy depends on velocity squared.',
};

const realWorld = [
  { emoji: '✈️', title: 'Airplane wing lift', body: "An airfoil's curved shape speeds up airflow over the top surface; by Bernoulli's principle, that faster air has lower pressure, contributing to the net upward lift force that keeps aircraft airborne." },
  { emoji: '🧪', title: 'Carburetors and atomizers', body: "A Venturi constriction speeds up airflow, dropping local pressure enough to draw fuel or perfume up through a side tube and mix it into the fast-moving stream — a direct engineering application of the pressure-speed tradeoff." },
  { emoji: '🩺', title: 'Blood flow and arterial narrowing', body: "Blood speeding up through a narrowed (stenotic) artery experiences a local pressure drop, described by the same Bernoulli relationship — a principle cardiologists use to help interpret blood flow measurements." },
  { emoji: '🚰', title: 'Water tower and plumbing design', body: "Engineers use Bernoulli's equation to predict how pressure and flow speed trade off across elevation changes and pipe diameter changes in municipal water systems." },
];

const misconceptions = [
  { claim: '"Faster-moving fluid always has higher pressure."', truth: "It's the opposite for a horizontal flow — Bernoulli's equation shows that at the same elevation, faster fluid has lower pressure, not higher. This inverse relationship is the entire basis of the Venturi effect." },
  { claim: '"Bernoulli\'s equation applies to any fluid flow, including turbulent or viscous flows."', truth: "The equation assumes an idealized, incompressible, non-viscous (inviscid) fluid in steady flow along a single streamline. Real flows with turbulence or significant viscosity (like thick oil through a rough pipe) deviate from the ideal prediction." },
  { claim: '"Only speed affects pressure in a flowing fluid — elevation doesn\'t matter."', truth: "Elevation matters just as much through the ρgh term, which behaves exactly like ordinary hydrostatic pressure. Fluid flowing uphill loses pressure (or speed) even if its speed through the pipe never changes." },
  { claim: '"Bernoulli\'s principle is the complete explanation of how airplane wings generate lift."', truth: "While Bernoulli's principle correctly describes a pressure difference from unequal airflow speeds, the complete modern explanation of lift also involves Newton's third law — the wing deflecting air downward and the air pushing back up on the wing in reaction." },
];

const sources = [
  { html: "<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 14, \"Fluid Mechanics\" (free, peer-reviewed). <a href=\"https://openstax.org/books/university-physics-volume-1/pages/14-6-bernoullis-equation\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">openstax.org</a>" },
  { html: "<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 14, Fluids." },
  { html: "<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 14, Fluid Mechanics." },
];
const sourcesNote = "P₂ = P₁ + ½ρ(v₁²−v₂²) + ρg(h₁−h₂), for an idealized incompressible, non-viscous, steady flow. Standard gravity g=9.81 m/s² used. Results are rounded for display.";

const howToUse = [
  { title: 'Enter point-1 conditions', body: 'Provide the fluid density, and the pressure, velocity, and elevation at the first point.' },
  { title: 'Enter point-2 conditions', body: 'Provide the velocity and elevation at the second point (often from a continuity-equation calculation).' },
  { title: 'Read the result', body: 'Pressure at point 2 solves live, showing the combined effect of the speed and elevation change.' },
];

const related = [
  { href: '/tools/pressure-calculator', emoji: '🤿', title: 'Pressure Calculator', desc: 'P = F/A and P = ρgh — solve force, area, or fluid depth.' },
  { href: '/tools/buoyancy-calculator', emoji: '⛴️', title: "Buoyancy (Archimedes' Principle) Calculator", desc: 'F_b = ρVg — float vs sink and submerged fraction.' },
  { href: '/tools/density-calculator', emoji: '⚖️', title: 'Density Calculator', desc: 'Solve density, mass, or volume from any two.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="Bernoulli's equation is really just conservation of energy applied to a flowing fluid — pressure, speed, and height are three different ways the same total energy can be stored, and increasing one at a fixed total means the others must give something back."
  howIntro="Each term in P + ½ρv² + ρgh represents an energy density along the flow: P is the fluid's own pressure energy, ½ρv² is its kinetic energy (from speed), and ρgh is its gravitational potential energy (from height). Because this total stays constant along a streamline for an idealized fluid, rearranging the equation to P₂ = P₁ + ½ρ(v₁²−v₂²) + ρg(h₁−h₂) shows precisely how a change in either speed or height at point 2 must be balanced by an opposite change in pressure."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Bernoulli's equation actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Fluid density ρ (kg/m³)</span>
        <input id="rho" type="number" step="any" value="1000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pressure P₁ (Pa)</span>
        <input id="P1" type="number" step="any" value="200000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Velocity v₁ (m/s)</span>
        <input id="v1" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Elevation h₁ (m)</span>
        <input id="h1" type="number" step="any" value="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Velocity v₂ (m/s)</span>
        <input id="v2" type="number" step="any" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Elevation h₂ (m)</span>
        <input id="h2" type="number" step="any" value="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white sm:col-span-2"><div class="text-sm opacity-80">Pressure at point 2 (P₂)</div><div id="r-p2" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="be-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Bernoulli's principle in action</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-venturi" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A Venturi tube constriction</h3>
          <p class="mt-1 text-sm text-slate-600">A pipe narrows in the middle — flow speeds up through the constriction, and pressure there drops, exactly as Bernoulli's equation predicts.</p>
        </div>
        <div>
          <div id="diag-wing" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. An airfoil generating lift</h3>
          <p class="mt-1 text-sm text-slate-600">Air travels faster over the curved top of the wing than along the flatter bottom, creating a pressure difference that contributes to lift.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Bernoulli's equation graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pressure P₂ vs velocity v₂ (horizontal flow)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-v"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pressure P₂ vs elevation change (constant speed)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-h"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('be-err').textContent = '';
        el('r-p2').textContent = '—';
        const rho = parseFloat(el('rho').value), P1 = parseFloat(el('P1').value);
        const v1 = parseFloat(el('v1').value), h1 = parseFloat(el('h1').value);
        const v2 = parseFloat(el('v2').value), h2 = parseFloat(el('h2').value);
        if ([rho, P1, v1, h1, v2, h2].some((x) => isNaN(x))) return;
        if (rho <= 0) { el('be-err').textContent = 'Fluid density must be greater than 0.'; return; }
        const g = 9.81;
        const P2 = P1 + 0.5 * rho * (v1 * v1 - v2 * v2) + rho * g * (h1 - h2);
        el('r-p2').textContent = fmt(P2) + ' Pa';
      }
      ['rho', 'P1', 'v1', 'h1', 'v2', 'h2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsV = [], dataV = [];
        for (let v = 2; v <= 10; v += 0.5) { labelsV.push(v.toFixed(1)); dataV.push(+(200000 + 0.5 * 1000 * (2 * 2 - v * v)).toFixed(0)); }
        charts.v = new Chart(el('chart-v'), {
          type: 'line',
          data: { labels: labelsV, datasets: [{ label: 'P2 (Pa)', data: dataV, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'v2 (m/s), v1=2 m/s' } }, y: { title: { display: true, text: 'Pressure P2 (Pa)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsH = [], dataH = [];
        for (let h = 0; h <= 20; h += 2) { labelsH.push(h); dataH.push(+(300000 - 850 * 9.81 * h).toFixed(0)); }
        charts.h = new Chart(el('chart-h'), {
          type: 'line',
          data: { labels: labelsH, datasets: [{ label: 'P2 (Pa)', data: dataH, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Elevation rise h2 (m), oil ρ=850' } }, y: { title: { display: true, text: 'Pressure P2 (Pa)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: Venturi tube ----
      let diagVenturi = null;
      function initDiagVenturi() {
        const c = el('diag-venturi'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 0, 0), OPTS);
        const mat = new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.4, transparent: true, opacity: 0.85 });
        const wide1 = new THREE.Mesh(new THREE.CylinderGeometry(1, 1, 2, 24, 1, true), mat);
        wide1.rotation.z = Math.PI / 2; wide1.position.set(-2.5, 0, 0); s.scene.add(wide1);
        const narrow = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 1.5, 24, 1, true), mat);
        narrow.rotation.z = Math.PI / 2; narrow.position.set(0, 0, 0); s.scene.add(narrow);
        const wide2 = new THREE.Mesh(new THREE.CylinderGeometry(1, 1, 2, 24, 1, true), mat);
        wide2.rotation.z = Math.PI / 2; wide2.position.set(2.5, 0, 0); s.scene.add(wide2);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagVenturi = { resize: s.resize };
      }

      // ---- Diagram 2: airfoil ----
      let diagWing = null;
      function initDiagWing() {
        const c = el('diag-wing'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const shape = new THREE.Shape();
        shape.moveTo(-2, 0);
        shape.quadraticCurveTo(0, 0.9, 2, 0.15);
        shape.quadraticCurveTo(0, -0.2, -2, 0);
        const geo = new THREE.ExtrudeGeometry(shape, { depth: 1.2, bevelEnabled: false });
        geo.center();
        const wing = new THREE.Mesh(geo, new THREE.MeshStandardMaterial({ color: 0x334155, roughness: 0.5 }));
        s.scene.add(wing);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagWing = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[bernoulli] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[bernoulli] charts failed', e); }
        if (window.THREE) {
          try { initDiagVenturi(); } catch (e) { console.error('[bernoulli] venturi diagram failed', e); }
          try { initDiagWing(); } catch (e) { console.error('[bernoulli] wing diagram failed', e); }
        }
        mountResize([diagVenturi, diagWing]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
