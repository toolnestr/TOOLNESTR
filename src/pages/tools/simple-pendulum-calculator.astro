---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Simple Pendulum Period Calculator';
const description = 'Simple pendulum period calculator with a live 3D swinging bob and charts. Solve T = 2π√(L/g) for period, length, or gravity, with worked examples.';
const intro = 'Find the period of a simple pendulum from its length and local gravity, or solve for length or gravity given a target period. A live 3D swinging bob and charts show how T = 2π√(L/g) plays out.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is a simple pendulum?', a: 'A simple pendulum is an idealised model: a point mass (the bob) hanging from a massless, inextensible string of length L, swinging under gravity with no friction or air resistance. Real pendulums only approximate this, but the model predicts real behaviour remarkably well for small swings.' },
  { q: 'Does the period depend on the mass of the bob?', a: 'No. Mass cancels out completely in the derivation — a heavier bob has more inertia but also more gravitational force pulling it, and the two effects exactly offset. A bowling ball and a marble on strings of the same length swing with the same period.' },
  { q: 'Does the period depend on the swing amplitude?', a: 'Only weakly, and only for larger swings. The formula T = 2π√(L/g) is the small-angle approximation, accurate to within about 0.5% for amplitudes under 15°. Beyond that, the true period grows slightly longer than the formula predicts as amplitude increases — this is why old pendulum clocks used small, controlled swings.' },
  { q: 'Why does length matter more than mass for the period?', a: 'Length sets the geometry of the swing — a longer string means the bob travels a longer arc but also experiences a smaller restoring effect from gravity per unit displacement, and the balance of these works out to T ∝ √L. Mass, by contrast, drops out of Newton\'s second law entirely (F = ma and the restoring force are both proportional to mass), so it never enters the period at all.' },
  { q: 'How is angular frequency related to the period?', a: 'Angular frequency ω = 2π/T = √(g/L), measured in rad/s. It describes how fast the phase of the oscillation advances, and it is the same ω that appears in the pendulum\'s position equation θ(t) = θ₀cos(ωt) for small-angle swings.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Simple Pendulum Period Calculator',
  description: 'Calculate the period, length, or gravitational acceleration of a simple pendulum from T = 2π√(L/g).',
  steps: [
    { name: 'Pick what to solve for', text: 'Choose Period, Length, or Gravity as the unknown.' },
    { name: 'Enter the other two values', text: 'Type the two known quantities — the calculator solves the third.' },
    { name: 'Read the result', text: 'The period, frequency and angular frequency solve instantly, and the 3D bob swings at the matching rate.' },
  ],
};

const formulas = [
  { expr: 'T = 2π√(L/g)', note: 'period — small-angle approximation (≲15°)' },
  { expr: 'f = 1/T', note: 'frequency, swings per second (Hz)' },
  { expr: 'ω = 2π/T = √(g/L)', note: 'angular frequency (rad/s)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a 1.0 m pendulum on Earth', tone: 'slate',
    given: 'A simple pendulum has length L = 1.0 m, swinging near Earth\'s surface (g = 9.81 m/s²). Find its period.',
    rows: [
      { label: 'Ratio L/g:', value: 'L/g = 1.0 ÷ 9.81 = 0.10194 s²' },
      { label: 'Square root:', value: '√0.10194 = 0.3193 s' },
      { label: 'Period:', value: 'T = 2π × 0.3193 = 2.006 s', full: true },
      { label: 'Frequency:', value: 'f = 1/T = 1 ÷ 2.006 = 0.4985 Hz' },
      { label: 'Angular frequency:', value: 'ω = 2π/T = 3.132 rad/s' },
    ],
  },
  {
    title: 'Worked example 2 — designing a grandfather clock pendulum', tone: 'amber',
    given: 'A clockmaker wants a pendulum with an exact period of T = 2.0 s on Earth (g = 9.81 m/s²). Find the required length.',
    rows: [
      { label: 'Rearrange for L:', value: 'L = g(T/2π)²' },
      { label: 'T/2π:', value: '2.0 ÷ 6.2832 = 0.31831 s' },
      { label: 'Squared:', value: '0.31831² = 0.10132 s²' },
      { label: 'Length:', value: 'L = 9.81 × 0.10132 = 0.994 m', full: true },
    ],
    note: 'This is close to the classic "seconds pendulum" length of about 0.994 m used in real pendulum clocks with a 2-second tick-tock period.',
  },
];

const comparison = {
  heading: 'Pendulum period by length (at Earth gravity, g = 9.81 m/s²)',
  note: 'Because T ∝ √L, quadrupling the length only doubles the period.',
  headers: [{ label: 'Length L' }, { label: 'Period T' }, { label: 'Frequency f' }],
  rows: [
    ['0.25 m', '1.003 s', '0.997 Hz'],
    ['0.50 m', '1.419 s', '0.705 Hz'],
    ['1.00 m', '2.006 s', '0.499 Hz'],
    ['2.00 m', '2.837 s', '0.352 Hz'],
  ],
  highlightIndex: 2,
  footnote: 'T = 2π√(L/g), small-angle approximation. Doubling L multiplies T by √2 ≈ 1.414, not by 2.',
};

const realWorld = [
  { emoji: '🕰️', title: 'Pendulum clocks', body: 'From the 17th century onward, pendulum clocks used the near-constant period of a small swing to keep time to within seconds a day — the "seconds pendulum," about 0.994 m long, was even briefly proposed as a natural length standard.' },
  { emoji: '🌍', title: 'Seismometers', body: 'Early mechanical seismometers used a heavy pendulum whose inertia kept it nearly stationary while the ground (and the instrument frame) moved beneath it, recording the relative motion as an earthquake trace.' },
  { emoji: '🌀', title: 'Foucault pendulum', body: 'A very long, freely swinging pendulum appears to slowly rotate its swing plane over the course of a day — direct visible proof that the Earth is rotating beneath it, independent of the pendulum\'s period formula itself.' },
  { emoji: '🛝', title: 'Playground swings', body: 'A swing is a large-amplitude pendulum, so the small-angle formula is only a rough guide — but the everyday intuition still holds: a swing with a longer chain takes noticeably longer to go back and forth than a short one.' },
];

const misconceptions = [
  { claim: '"A heavier pendulum bob swings slower."', truth: 'False — mass cancels out of the period formula entirely. T = 2π√(L/g) has no mass term, because both the inertia resisting motion and the gravitational restoring force scale with mass in exactly the same way.' },
  { claim: '"The formula T = 2π√(L/g) works for any swing angle."', truth: 'False — it is the small-angle approximation, accurate to within about 0.5% only for amplitudes up to roughly 15°. For larger swings, the true period is longer than the formula predicts, and the difference grows with amplitude.' },
  { claim: '"A harder push makes the pendulum swing faster (shorter period)."', truth: 'False for small angles — the starting push only changes the amplitude of the swing, not how long each swing takes. Only length and gravitational acceleration set the period in the small-angle regime.' },
  { claim: '"Pendulum period depends on where you start measuring from."', truth: 'False — the period is the same whether you time from the highest point, the lowest point, or anywhere else in the cycle, as long as you measure one full back-and-forth swing.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 15, "Oscillations," pendulum section (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/15-5-pendulums" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 15, Oscillations, simple and physical pendulums.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 15, Oscillatory Motion.' },
];
const sourcesNote = 'T = 2π√(L/g) is the small-angle (≲15°) approximation for a simple pendulum. Results are rounded for display.';

const howToUse = [
  { title: 'Choose the unknown', body: 'Solve for Period, Length, or Gravity depending on what you know.' },
  { title: 'Enter the two known values', body: 'Fill in the two remaining fields; the third solves live, along with frequency and ω.' },
  { title: 'Watch the swing', body: 'Use the L and g sliders to see the 3D bob swing faster or slower as the period changes.' },
];

const related = [
  { href: '/tools/angular-acceleration-calculator', emoji: '🌪️', title: 'Angular Acceleration Calculator', desc: 'α = Δω/Δt — solve for any variable.' },
  { href: '/tools/uniform-circular-motion-calculator', emoji: '🔄', title: 'Uniform Circular Motion Calculator', desc: 'Centripetal accel/force, period, ω from r and v.' },
  { href: '/tools/gravitational-force-calculator', emoji: '🌍', title: 'Gravitational Force Calculator', desc: 'F = Gm₁m₂/r² — Newton\'s law of gravitation.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a simple pendulum's period depends only on its length and local gravity — never on its mass or (for small swings) how hard it was pushed."
  howIntro="Rearranged, the formula solves any of the three quantities: L = g(T/2π)² gives the length needed for a target period, and g = L(2π/T)² recovers the local gravitational acceleration from a measured period — the classic method used to measure g with nothing but a string, a bob and a stopwatch."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the pendulum period actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-T" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Solve for Period</button>
      <button id="mode-L" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Solve for Length</button>
      <button id="mode-g" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Solve for Gravity</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Period (T)<span class="text-slate-400"> s</span></span>
        <input id="T" type="number" step="any" placeholder="s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (L)<span class="text-slate-400"> m</span></span>
        <input id="L" type="number" step="any" placeholder="m" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gravity (g)<span class="text-slate-400"> m/s²</span></span>
        <input id="g" type="number" step="any" placeholder="m/s²" value="9.81" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-3 flex flex-wrap gap-2 text-xs">
      <button type="button" data-g="9.81" class="g-preset rounded-full border border-slate-200 px-3 py-1 text-slate-600 hover:border-indigo-300">Earth (9.81)</button>
      <button type="button" data-g="1.62" class="g-preset rounded-full border border-slate-200 px-3 py-1 text-slate-600 hover:border-indigo-300">Moon (1.62)</button>
      <button type="button" data-g="3.71" class="g-preset rounded-full border border-slate-200 px-3 py-1 text-slate-600 hover:border-indigo-300">Mars (3.71)</button>
    </div>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-5">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div id="lab-1" class="text-xs opacity-80">Period</div><div id="r-1" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div id="lab-2" class="text-xs text-slate-500">Length</div><div id="r-2" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div id="lab-3" class="text-xs text-slate-500">Gravity</div><div id="r-3" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Frequency f</div><div id="r-f" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Angular ω</div><div id="r-w" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="pend-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D swinging pendulum + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D swinging pendulum</h2>
      <p class="mt-1 text-sm text-slate-500">Set the length and gravity; the bob swings at the resulting period — a shorter period means a visibly faster swing. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Length L <span id="out-bl" class="font-mono text-indigo-600">1.00 m</span></span>
          <input id="b-l" type="range" min="0.2" max="3" step="0.05" value="1" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Gravity g <span id="out-bg" class="font-mono text-indigo-600">9.81 m/s²</span></span>
          <input id="b-g" type="range" min="0.5" max="25" step="0.05" value="9.81" class="mt-2 w-full accent-indigo-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">Period T = 2π√(L/g) = <span id="out-bt" class="font-mono font-bold">2.01 s</span></div>
      <div id="pend3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="pend3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Pendulum period graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Period vs length (fixed g) — a square-root curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-tl"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Period vs gravity (fixed L) — an inverse-square-root curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-tg"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.1, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };
      const TAU = Math.PI * 2;

      function period(L, g) { return TAU * Math.sqrt(L / g); }

      // ---- calculator ----
      let mode = 'T';
      function switchMode(m) {
        mode = m;
        el('mode-T').className = m === 'T' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-L').className = m === 'L' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-g').className = m === 'g' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('T').disabled = m === 'T';
        el('L').disabled = m === 'L';
        el('g').disabled = m === 'g';
        [el('T'), el('L'), el('g')].forEach((inp) => { inp.classList.toggle('bg-slate-100', inp.disabled); inp.classList.toggle('text-slate-400', inp.disabled); });
        update();
      }
      function update() {
        el('pend-err').textContent = '';
        ['r-1', 'r-2', 'r-3', 'r-f', 'r-w'].forEach((id) => (el(id).textContent = '—'));
        const T = parseFloat(el('T').value), L = parseFloat(el('L').value), g = parseFloat(el('g').value);
        let rT = T, rL = L, rg = g;
        if (mode === 'T') {
          if (isNaN(L) || isNaN(g)) return;
          if (L < 0) { el('pend-err').textContent = 'Length cannot be negative.'; return; }
          if (g <= 0) { el('pend-err').textContent = 'Gravity must be positive.'; return; }
          rT = period(L, g);
        } else if (mode === 'L') {
          if (isNaN(T) || isNaN(g)) return;
          if (T <= 0) { el('pend-err').textContent = 'Period must be positive.'; return; }
          if (g <= 0) { el('pend-err').textContent = 'Gravity must be positive.'; return; }
          rL = g * Math.pow(T / TAU, 2);
        } else {
          if (isNaN(T) || isNaN(L)) return;
          if (T <= 0) { el('pend-err').textContent = 'Period must be positive.'; return; }
          if (L < 0) { el('pend-err').textContent = 'Length cannot be negative.'; return; }
          rg = L * Math.pow(TAU / T, 2);
        }
        el('r-1').textContent = fmt(rT) + ' s';
        el('r-2').textContent = fmt(rL) + ' m';
        el('r-3').textContent = fmt(rg) + ' m/s²';
        el('r-f').textContent = fmt(1 / rT) + ' Hz';
        el('r-w').textContent = fmt(TAU / rT) + ' rad/s';
      }
      el('mode-T').addEventListener('click', () => switchMode('T'));
      el('mode-L').addEventListener('click', () => switchMode('L'));
      el('mode-g').addEventListener('click', () => switchMode('g'));
      ['T', 'L', 'g'].forEach((id) => el(id).addEventListener('input', update));
      document.querySelectorAll('.g-preset').forEach((btn) => btn.addEventListener('click', () => { el('g').value = btn.getAttribute('data-g'); update(); }));

      // ---- 3D + charts ----
      const charts = {};
      let pend = null;
      function bState() { const L = parseFloat(el('b-l').value), g = parseFloat(el('b-g').value); return { L, g, T: period(L, g) }; }
      function onB() {
        const s = bState();
        el('out-bl').textContent = s.L.toFixed(2) + ' m';
        el('out-bg').textContent = s.g.toFixed(2) + ' m/s²';
        el('out-bt').textContent = fmt(s.T) + ' s';
        try { if (pend) pend.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-l').addEventListener('input', onB);
      el('b-g').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.tl = new Chart(el('chart-tl'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'T', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Length (m)' } }, y: { title: { display: true, text: 'Period (s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.tg = new Chart(el('chart-tg'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'T', data: [], borderColor: '#0ea5e9', backgroundColor: 'rgba(14,165,233,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Gravity g (m/s²)' } }, y: { title: { display: true, text: 'Period (s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L1 = [], D1 = [];
        for (let ll = 0.1; ll <= 3.001; ll += 0.1) { L1.push(ll.toFixed(1)); D1.push(+period(ll, s.g).toFixed(4)); }
        charts.tl.data.labels = L1; charts.tl.data.datasets[0].data = D1; charts.tl.update();

        const L2 = [], D2 = [];
        for (let gg = 0.5; gg <= 25.001; gg += 1.0) { L2.push(gg.toFixed(1)); D2.push(+period(s.L, gg).toFixed(4)); }
        charts.tg.data.labels = L2; charts.tg.data.datasets[0].data = D2; charts.tg.update();
      }

      // ---- interactive swinging pendulum ----
      function pendulumMesh(THREE) {
        const g = new THREE.Group();
        const pivot = new THREE.Mesh(new THREE.SphereGeometry(0.12, 16, 16), new THREE.MeshStandardMaterial({ color: 0x334155 }));
        pivot.position.set(0, 3, 0);
        g.add(pivot);
        const stringMat = new THREE.MeshStandardMaterial({ color: 0x94a3b8 });
        const stringMesh = new THREE.Mesh(new THREE.CylinderGeometry(0.025, 0.025, 1, 8), stringMat);
        g.add(stringMesh);
        const bobMat = new THREE.MeshStandardMaterial({ color: 0xef4444, metalness: 0.2, roughness: 0.4 });
        const bob = new THREE.Mesh(new THREE.SphereGeometry(0.32, 24, 24), bobMat);
        g.add(bob);
        return { g, stringMesh, bob, pivotY: 3 };
      }
      function initPendulum() {
        const c = el('pend3d'); if (!c) throw new Error('no pendulum container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 1, 0), OPTS);
        const pm = pendulumMesh(THREE);
        s.scene.add(pm.g);
        let st = { L: 1, g: 9.81, T: period(1, 9.81), t: 0 };
        const AMP = 0.45; // radians, small-angle swing for visual clarity
        function layout() {
          const scale = Math.max(0.6, Math.min(2.2, st.L));
          const len = scale * 2.2;
          pm.stringMesh.scale.y = len;
          pm.stringMesh.position.y = pm.pivotY - len / 2;
          pm.bob.position.y = pm.pivotY - len;
        }
        function update(state) { st.L = state.L; st.g = state.g; st.T = state.T; layout(); }
        function frame() {
          requestAnimationFrame(frame);
          if (!reduceMotion) {
            const dt = 0.016;
            st.t += dt;
            const w = st.T > 0 ? TAU / st.T : 0;
            const theta = AMP * Math.sin(w * st.t);
            pm.g.rotation.z = theta;
          }
          s.renderer.render(s.scene, s.camera);
        }
        layout();
        frame();
        pend = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { switchMode('T'); } catch (e) { console.error('[pendulum] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[pendulum] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[pendulum] charts failed', e); }
        if (window.THREE) {
          try { initPendulum(); } catch (e) { console.error('[pendulum] scene failed', e); el('pend3d-fallback').classList.remove('hidden'); }
        } else { el('pend3d-fallback').classList.remove('hidden'); }
        mountResize([pend]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
