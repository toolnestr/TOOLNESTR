---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Calories Burned Calculator';
const description =
  'Free calories burned calculator. Estimate how many calories you burn during different activities using MET values, your weight and duration.';
const intro =
  'Select an activity, enter your weight and duration to estimate the total calories burned during exercise or daily activities.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is a MET?', a: 'MET stands for Metabolic Equivalent of Task. One MET is the energy cost of sitting quietly — about 1 calorie per kg of body weight per hour. Activities are assigned MET values based on their intensity relative to rest.' },
  { q: 'How accurate is this calculator?', a: 'MET-based estimates are a good general guide, accurate within +-15% for most people. Individual variation depends on fitness level, body composition, temperature and technique.' },
  { q: 'Why do heavier people burn more calories?', a: 'Moving a heavier body requires more energy. That is why weight is a key input — a person weighing 80 kg burns more calories doing the same activity as someone weighing 60 kg.' },
  { q: 'Do fitness trackers give more accurate results?', a: 'Research shows most fitness trackers are within 10-20% of lab measurements for cardio activities. They are less accurate for strength training and non-step activities.' },
  { q: 'Should I eat back the calories I burn?', a: 'Only if your goal is weight maintenance. For weight loss, your activity level setting in the Calorie Calculator already accounts for exercise — eating back exercise calories usually cancels your deficit.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <label class="block"><span class="text-sm font-medium text-slate-700">Activity</span>
      <select id="activity" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="1.3">Resting / Sleeping</option>
        <option value="2.0">Walking (2 mph / 3.2 km/h)</option>
        <option value="2.8">Walking (3 mph / 4.8 km/h)</option>
        <option value="3.5">Walking (3.5 mph / 5.6 km/h)</option>
        <option value="3.8">Hiking</option>
        <option value="4.0">Cycling (leisure, 10-12 mph)</option>
        <option value="4.3">Calisthenics (moderate)</option>
        <option value="5.0">Moderate weightlifting</option>
        <option value="5.8">Cycling (moderate, 12-14 mph)</option>
        <option value="6.0">Swimming (moderate)</option>
        <option value="6.0">Yoga (vigorous)</option>
        <option value="7.0">Jogging (5 mph / 8 km/h)</option>
        <option value="8.0">Cycling (vigorous, 14-16 mph)</option>
        <option value="8.3">Running (6 mph / 9.7 km/h)</option>
        <option value="9.0">Rope jumping (moderate)</option>
        <option value="9.8">Running (7.5 mph / 12 km/h)</option>
        <option value="11.0">Running (8.5 mph / 13.7 km/h)</option>
        <option value="12.0">Rope jumping (vigorous)</option>
        <option value="15.0">Running (10 mph / 16 km/h)</option>
      </select></label>

    <div id="metric" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Duration (minutes)</span>
        <input id="duration" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-2" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Duration (minutes)</span>
        <input id="i-dur" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total calories burned</div>
        <div id="r-cal" class="mt-1 text-3xl font-bold">—</div>
        <div class="text-sm opacity-80">calories during activity</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Calories per minute</div><div id="r-cpm" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Activity MET</div><div id="r-met" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Select an activity and enter your weight and duration.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About calories burned</h2>
    <p class="mt-2 text-slate-600">
      Knowing how many calories you burn during exercise helps you understand your total energy balance. This calculator uses the MET (Metabolic Equivalent of Task) system, a standardised method developed by exercise physiologists to estimate energy expenditure across hundreds of activities. Each activity has a MET value that represents its intensity relative to resting metabolism. The <a href="https://sites.google.com/view/compendium-of-physical-activities/home" rel="noopener">Compendium of Physical Activities</a> provides the reference values used here. Combine this with the <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> for a complete picture of your daily energy balance, and check the <a href="/tools/pace-calculator" class="font-medium text-indigo-600 hover:underline">Pace Calculator</a> for running-specific estimates.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">These are estimates — individual results vary with fitness level, efficiency, temperature and terrain.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" role="img" aria-labelledby="cb-title cb-desc">
      <title id="cb-title">MET values for common activities</title>
      <desc id="cb-desc">Bar chart comparing MET values from resting (1.3) through walking, cycling, jogging and running (up to 15 METs).</desc>
      <rect x="60" y="145" width="100" height="30" rx="4" fill="#6366f1" /><text x="110" y="135" text-anchor="middle" font-size="11" fill="#64748b">Rest</text>
      <rect x="180" y="120" width="100" height="55" rx="4" fill="#6366f1" /><text x="230" y="110" text-anchor="middle" font-size="11" fill="#64748b">Walk</text>
      <rect x="300" y="95" width="100" height="80" rx="4" fill="#6366f1" /><text x="350" y="85" text-anchor="middle" font-size="11" fill="#64748b">Cycle</text>
      <rect x="420" y="65" width="100" height="110" rx="4" fill="#6366f1" /><text x="470" y="55" text-anchor="middle" font-size="11" fill="#64748b">Jog</text>
      <rect x="540" y="40" width="100" height="135" rx="4" fill="#6366f1" /><text x="590" y="30" text-anchor="middle" font-size="11" fill="#64748b">Run</text>
      <rect x="660" y="10" width="100" height="165" rx="4" fill="#6366f1" /><text x="710" y="195" text-anchor="middle" font-size="11" fill="#64748b">Sprint</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">MET values increase with activity intensity — higher bars mean more calories burned per minute</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The MET method is simple: one MET equals the energy you burn at rest (about 1 calorie per kg per hour). An activity with a MET of 5 burns five times as many calories as resting. The calculator multiplies the MET value by your weight in kilograms and the duration in hours. Because MET values are averages, your actual burn may be higher or lower depending on your fitness level (fit people are more efficient and may burn slightly fewer calories for the same work), the terrain, temperature and how vigorously you perform the activity.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Calories burned</strong> = MET × weight (kg) × duration (hours)
    </p>
    <p class="mt-3 text-slate-600">
      For example, cycling at a MET of 5.8 for 45 minutes at 70 kg:<br>
      5.8 × 70 × (45 / 60) = <strong>304.5 calories</strong>
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A person weighing 75 kg goes jogging (MET 7.0) for 30 minutes. How many calories do they burn?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">75 kg</span></div>
        <div><span class="font-medium text-slate-700">Duration:</span> <span class="text-slate-600">30 min = 0.5 hours</span></div>
        <div><span class="font-medium text-slate-700">MET:</span> <span class="text-slate-600">7.0 (jogging)</span></div>
        <div><span class="font-medium text-slate-700">Calculation:</span> <span class="text-slate-600">7.0 × 75 × 0.5 = <strong>262.5 calories</strong></span></div>
        <div><span class="font-medium text-slate-700">Per minute:</span> <span class="text-slate-600">262.5 / 30 = <strong>8.75 cal/min</strong></span></div>
        <div><span class="font-medium text-slate-700">Walking same time (MET 2.8):</span> <span class="text-slate-600">2.8 × 75 × 0.5 = <strong>105 calories</strong></span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏃</span>
      <h3 class="mt-2 font-semibold text-slate-900">Runner tracking TDEE</h3>
      <p class="mt-1 text-sm text-slate-600">Log your run calories burned to add to your daily TDEE. Know exactly how much you can eat while maintaining your weight.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚴</span>
      <h3 class="mt-2 font-semibold text-slate-900">Cyclist fuelling rides</h3>
      <p class="mt-1 text-sm text-slate-600">Estimate ride expenditure to plan pre-ride nutrition and post-ride refuelling. Longer rides need more careful calorie planning.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧘</span>
      <h3 class="mt-2 font-semibold text-slate-900">Yoga practitioner</h3>
      <p class="mt-1 text-sm text-slate-600">Compare the energy cost of different yoga styles — vigorous vinyasa burns significantly more than gentle hatha or restorative.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Fitness instructor</h3>
      <p class="mt-1 text-sm text-slate-600">Share estimated calorie burn with class participants so they understand the energy cost of their workout and can plan nutrition accordingly.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select your activity</h3>
        <p class="mt-1 text-sm text-slate-600">Choose from the dropdown list of common activities. Each has a MET value from the Compendium of Physical Activities.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your weight and time</h3>
        <p class="mt-1 text-sm text-slate-600">Your weight determines the base energy cost. Duration in minutes sets how long you sustain the activity.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your burn</h3>
        <p class="mt-1 text-sm text-slate-600">See total calories burned, calories per minute and the MET value. Use this data for nutrition planning and progress tracking.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for calorie burn tracking</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use duration not distance</h3>
        <p class="mt-1 text-sm text-slate-600">Time under tension is what matters for calorie burn, not distance. A 30-minute run burns roughly the same calories whether you cover 4 km or 5 km — intensity is the difference.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Higher intensity burns more</h3>
        <p class="mt-1 text-sm text-slate-600">Doubling your MET from 5 to 10 doubles your calorie burn for the same duration. High-intensity intervals can boost calorie burn both during and after exercise (the afterburn effect).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Don't trust machines blindly</h3>
        <p class="mt-1 text-sm text-slate-600">Treadmills and ellipticals often overestimate calorie burn by 15-30%. Use this MET-based calculator as a more objective reference point.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/steps-to-calories-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Steps to Calories Calculator</a>
      <a href="/tools/pace-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Pace Calculator</a>
      <a href="/tools/heart-rate-zone-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Heart Rate Zone Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      let kg, dur;
      if (metric) {
        kg = parseFloat(el('m-w').value);
        dur = parseFloat(el('duration').value);
      } else {
        kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
        dur = parseFloat(el('i-dur').value);
      }
      const met = parseFloat(el('activity').value);
      if (!kg || !dur || kg <= 0 || dur <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const hours = dur / 60;
      const total = met * kg * hours;
      const cpm = total / dur;
      el('r-cal').textContent = Math.round(total).toLocaleString();
      el('r-cpm').textContent = cpm.toFixed(1);
      el('r-met').textContent = met.toFixed(1);
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['activity', 'm-w', 'duration', 'i-w', 'i-dur'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
