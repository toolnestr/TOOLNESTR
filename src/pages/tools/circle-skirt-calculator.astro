---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Circle Skirt Calculator';
const description = 'Calculate the waist radius, hem circumference, and fabric needed for a full, half, or quarter circle skirt.';
const intro = 'Calculate the waist radius and fabric needed for a circle skirt from your waist measurement and skirt length.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is the difference between a full, half, and quarter circle skirt?', a: 'A full circle skirt uses the entire 360-degree circle for maximum flare and fullness. A half circle uses 180 degrees (half the waist opening circumference relative to a full circle, achieved by doubling the waist radius calculation), giving less fullness. A quarter circle uses 90 degrees, giving the least flare of the three.' },
  { q: 'Why does the waist radius formula use circumference divided by 2π?', a: 'The waist opening is a circle, and circumference equals 2π times radius — rearranging that formula to solve for radius (waist measurement ÷ 2π) tells you exactly what radius circle to cut so the opening matches your waist.' },
  { q: 'Do I need to add seam allowance to the waist measurement first?', a: 'Yes — add your seam allowance to your waist measurement before entering it, so the finished (sewn) waist opening matches your body, not the pre-seam-allowance cut edge.' },
  { q: 'Can I make a circle skirt from fabric narrower than the skirt diameter?', a: 'Yes, by piecing two or four panels together (quarter or half circles seamed at the sides) instead of cutting one full circle from a single piece — this is the standard approach when fabric width is less than the skirt\'s finished diameter.' },
];
const howTo = {
  name: 'How to calculate a circle skirt',
  steps: [
    { name: 'Choose skirt type', text: 'Select full, half, or quarter circle.' },
    { name: 'Enter waist and length', text: 'Enter your finished waist measurement (with seam allowance) and desired skirt length.' },
    { name: 'Read the cutting radius', text: 'The waist radius and hem radius to mark on your fabric appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Full circle', 'Half circle', 'Quarter circle'].map((d) => (
        <button data-type={d} class="type-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Waist measurement (in)</span>
        <input id="waist" type="number" step="any" placeholder="e.g. 30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Skirt length (in)</span>
        <input id="length" type="number" step="any" placeholder="e.g. 22" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Waist cutting radius</div>
        <div id="r-radius" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Hem radius</div><div id="r-hemradius" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Fabric square needed</div><div id="r-fabric" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="csc2-title csc2-desc">
      <title id="csc2-title">Circle skirt pattern with waist and hem radius marked</title>
      <desc id="csc2-desc">Two concentric circles representing the waist opening and hem edge of a circle skirt, with radius lines labeled</desc>
      <circle cx="400" cy="110" r="90" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <circle cx="400" cy="110" r="30" fill="#fff" stroke="#c026d3" stroke-width="2" />
      <line x1="400" y1="110" x2="400" y2="80" stroke="#1e293b" stroke-width="1.5" />
      <text x="410" y="95" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Waist radius</text>
      <line x1="400" y1="110" x2="460" y2="110" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="4 3" />
      <text x="470" y="115" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Hem radius</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The skirt is the ring between the waist radius circle and the hem radius circle</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How circle skirt sizing works</h2>
    <p class="mt-2 text-slate-600">
      A full circle skirt's waist opening is a complete circle, and since circumference equals 2π times radius, the waist radius to mark and cut is simply your waist measurement divided by 2π. The hem radius is that same waist radius plus your desired skirt length, since the skirt fabric extends outward from the waist circle by the length of the skirt.
    </p>
    <p class="mt-3 text-slate-600">
      A half circle skirt uses only 180 degrees of a circle rather than the full 360, which means the same waist circumference requires a radius twice as large as a full circle skirt would — mathematically, half the circle's edge (its arc) needs to equal the full waist measurement, so the radius is your waist measurement divided by π instead of 2π. A quarter circle uses 90 degrees and needs four times the full-circle radius for the same waist measurement, using waist measurement divided by (π/2).
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows the standard circle-skirt geometry formula (radius = circumference ÷ 2π, adjusted for the fraction of the circle used) referenced across dressmaking pattern-drafting guides.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A full circle skirt for a 30-inch waist, 22 inches long.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Waist radius:</span> <span class="text-slate-600">30 ÷ (2π) ≈ 4.77 in</span></div>
        <div><span class="font-medium text-slate-700">Hem radius:</span> <span class="text-slate-600">4.77 + 22 = <strong>26.77 in</strong></span></div>
        <div><span class="font-medium text-slate-700">Fabric square needed:</span> <span class="text-slate-600">2 × 26.77 ≈ <strong>53.5 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Full circle skirts are a popular beginner-to-intermediate sewing project precisely because there's no complex shaping beyond two circles, but the fabric requirement surprises many first-time makers — a knee-length full circle skirt for an average waist can need a piece of fabric nearly a yard and a half square, far more than the finished skirt's modest silhouette suggests.
    </p>
    <p class="mt-3 text-slate-600">
      Dance and performance costuming frequently specifies circle skirt fullness by fraction (quarter, half, full, or even "double circle") since the amount of movement and flare during spins scales directly with how much of the circle is used — a half circle skirt moves noticeably less dramatically than a full circle of the same waist and length.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A half circle skirt uses half the fabric of a full circle skirt." <strong class="text-slate-900">It's more complicated than that.</strong> A half circle skirt needs a larger radius than a full circle for the same waist measurement, so while it uses less total fabric area than a full circle of the same radius, it isn't simply "half" in an intuitive way.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Circle skirts only work for stretch fabric." <strong class="text-slate-900">Not true.</strong> Circle skirts are traditionally made from wovens with good drape (like cotton lawn or crepe) — the flare comes from the geometry of the cut, not from fabric stretch.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pleated-skirt-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Pleated Skirt Calculator</a>
      <a href="/tools/fabric-yardage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Yardage Calculator</a>
      <a href="/tools/seam-allowance-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Seam Allowance Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let type = 'Full circle';
    const divisors = { 'Full circle': 2 * Math.PI, 'Half circle': Math.PI, 'Quarter circle': Math.PI / 2 };

    function update() {
      const waist = parseFloat(el('waist').value);
      const length = parseFloat(el('length').value);
      if (!waist || !length || waist <= 0 || length <= 0) { el('results').classList.add('hidden'); return; }
      const divisor = divisors[type];
      const waistRadius = waist / divisor;
      const hemRadius = waistRadius + length;
      const fabricSide = 2 * hemRadius;

      el('r-radius').textContent = waistRadius.toFixed(2) + ' in';
      el('r-hemradius').textContent = hemRadius.toFixed(2) + ' in';
      el('r-fabric').textContent = fabricSide.toFixed(1) + ' in square';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.type-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.type-btn').forEach((b) => {
          b.className = 'type-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'type-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        type = btn.dataset.type;
        update();
      });
    });

    ['waist', 'length'].forEach((id) => el(id).addEventListener('input', update));
    document.querySelector('.type-btn').click();
  </script>
</ToolLayout>
