---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Countersink Depth Calculator';
const description = 'Calculate how deep to countersink a flat-head screw so it sits flush, from the head diameter and the countersink included angle (82°, 90° and more).';
const intro = 'Find how deep to countersink a flat-head screw so it seats flush, from the head diameter and cone angle.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How deep should a countersink be?', a: 'For a flat-head screw to sit flush, the countersink depth equals half the head diameter divided by the tangent of half the included angle. For a 0.316-inch head at 82°, that is (0.316 ÷ 2) ÷ tan(41°) = about 0.182 inch deep.' },
  { q: 'What is the countersink included angle?', a: 'It is the full cone angle of the countersink and the matching screw head. Standard inch flat-head wood and machine screws use 82°, metric screws use 90°, and some rivets and aerospace fasteners use 100°, 120°, or others. The countersink must match the screw.' },
  { q: 'How wide should the countersink be at the surface?', a: 'The countersink diameter at the surface should equal the screw head diameter, so the head rim finishes flush with the material. Cutting it wider sinks the head below the surface; cutting it narrower leaves the head proud.' },
  { q: 'Why does the angle have to match the screw?', a: 'A flat-head screw only seats evenly if the cone it sits in has the same included angle. An 82° screw in a 90° countersink touches only at the rim and can spin or crack the surface; matching the angle spreads the load across the whole cone.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Head diameter (in)</span>
        <input id="head" type="number" step="any" placeholder="0.316" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Included angle</span>
        <select id="angle" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="82" selected>82° (inch flat-head)</option>
          <option value="90">90° (metric flat-head)</option>
          <option value="100">100° (aerospace/rivet)</option>
          <option value="120">120° (sheet-metal)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Countersink depth</div>
        <div id="r-depth" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Surface diameter</div><div id="r-surf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Depth (mm)</div><div id="r-mm" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Half-angle</div><div id="r-half" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="cs-title cs-desc">
      <title id="cs-title">Countersink cone and the depth formula</title>
      <desc id="cs-desc">A cross-section of a countersunk screw head with the depth formula</desc>
      <rect x="70" y="70" width="230" height="90" fill="#e2e8f0" stroke="#94a3b8" stroke-width="1.5" />
      <polygon points="120,70 250,70 200,130 170,130" fill="#c7d2fe" stroke="#4338ca" stroke-width="1.5" />
      <line x1="120" y1="60" x2="250" y2="60" stroke="#4338ca" stroke-width="1" stroke-dasharray="4 3" />
      <text x="185" y="52" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">head diameter</text>
      <text x="258" y="105" font-size="11" fill="#475569" font-family="system-ui,sans-serif">depth</text>
      <rect x="360" y="55" width="390" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="380" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Countersink depth</text>
      <text x="380" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">depth = (head&frasl;2) &divide; tan(angle&frasl;2)</text>
      <text x="380" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">surface diameter = head diameter</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The cone must match the screw's angle so the flat head seats flush.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the countersink depth calculator works</h2>
    <p class="mt-2 text-slate-600">
      A flat-head screw sits flush when it drops into a cone-shaped recess that matches its head. The countersink is that cone, and its depth is set by simple geometry. The recess must open at the surface to the full head diameter, and it narrows at the screw's included angle. The depth is half the head diameter divided by the tangent of half the included angle.
    </p>
    <p class="mt-3 text-slate-600">
      The included angle is the full cone angle of both the screw head and the countersink cutter. Inch flat-head wood and machine screws are 82°, metric screws are 90°, and some rivets and sheet-metal fasteners use 100° or 120°. The cutter must match the screw: an 82° head dropped into a 90° recess touches only at the rim, so it can spin, sit crooked, or crack the surface instead of spreading its load across the whole cone.
    </p>
    <p class="mt-3 text-slate-600">
      Cutting to the calculated depth leaves the head exactly flush. Going slightly deeper sinks the head below the surface for filling or plugging; going shallower leaves it proud. Because the surface diameter equals the head diameter, the tool also reports that width so you can watch the growing rim as you cut and stop when it reaches the head size. Values are given in both inches and millimeters.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the head</h3>
        <p class="mt-1 text-sm text-slate-600">The flat-head screw's top diameter.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Match the angle</h3>
        <p class="mt-1 text-sm text-slate-600">82° inch, 90° metric, or another standard.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Cut to depth</h3>
        <p class="mt-1 text-sm text-slate-600">Stop when the rim reaches the head diameter.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Depth</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= (head &divide; 2) &divide; tan(angle &divide; 2)</span>. A 0.316 in head at 82°: 0.158 ÷ tan(41°) = <strong>0.182 in</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Half-angle</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= angle &divide; 2</span> = 82 ÷ 2 = <strong>41°</strong>, the angle of the cone wall from center.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Surface diameter</p>
        <p class="mt-1 text-slate-600">
          Equal to the head diameter, so the rim finishes flush with the material face.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A metric M5 flat-head screw, head diameter 0.394 in (10 mm), 90° cutter.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Half head:</span> <span class="text-slate-600">0.394 ÷ 2 = 0.197 in</span></div>
        <div><span class="font-medium text-slate-700">Half angle:</span> <span class="text-slate-600">90 ÷ 2 = 45°</span></div>
        <div><span class="font-medium text-slate-700">Depth:</span> <span class="text-slate-600">0.197 ÷ tan(45°) = <strong>0.197 in</strong></span></div>
        <div><span class="font-medium text-slate-700">In mm:</span> <span class="text-slate-600">≈ 5.0 mm deep</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/bolt-circle-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Bolt Circle Calculator</a>
      <a href="/tools/miter-angle-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Miter Angle Calculator</a>
      <a href="/tools/metal-weight-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Metal Weight Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const rad = (d) => d * Math.PI / 180;

    function update() {
      const head = parseFloat(el('head').value);
      const angle = parseFloat(el('angle').value);
      if (!(head > 0 && angle > 0 && angle < 180)) { el('results').classList.add('hidden'); return; }
      const half = angle / 2;
      const depth = (head / 2) / Math.tan(rad(half));

      el('r-depth').textContent = depth.toFixed(3) + ' in';
      el('r-note').textContent = 'flush depth for a ' + angle + '° flat head';
      el('r-surf').textContent = head.toFixed(3) + ' in';
      el('r-mm').textContent = (depth * 25.4).toFixed(2) + ' mm';
      el('r-half').textContent = half.toFixed(0) + '°';
      el('results').classList.remove('hidden');
    }

    el('head').addEventListener('input', update);
    el('angle').addEventListener('change', update);
  </script>
</ToolLayout>
