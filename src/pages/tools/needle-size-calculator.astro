---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Needle Size Calculator';
const description = 'Convert sewing machine needle size between European and American numbering, with fabric weight guidance.';
const intro = 'Convert sewing machine needle size between European and American numbering systems.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What does the European needle size number mean?', a: 'The European size is the needle blade\'s diameter in hundredths of a millimeter — a European 90 needle has a blade diameter of 0.90mm. A higher number means a thicker, sturdier needle.' },
  { q: 'What does the American needle size number mean?', a: 'The American size is a separate numbering scale (roughly 8 to 20 for standard machine needles) that runs alongside the European system on most needle packaging, also increasing with needle thickness.' },
  { q: 'How do I choose a needle size for my fabric?', a: 'Match the needle to your fabric weight: a finer needle (European 60-70) for lightweight fabrics like chiffon or voile, a medium needle (75-90) for quilting cotton and shirting, and a heavier needle (100-120) for denim, canvas, or upholstery fabric.' },
  { q: 'Do needle size numbers correspond exactly across brands?', a: 'The European/American numbering pairs shown are standardized across major needle manufacturers (like Schmetz), so a size 80/12 needle means the same thing regardless of brand, unlike some other sewing measurement systems that vary by manufacturer.' },
];
const howTo = {
  name: 'How to find your needle size',
  steps: [
    { name: 'Enter a known size', text: 'Enter either the European or American needle size number you have.' },
    { name: 'Choose which system you entered', text: 'Select European or American to match your input.' },
    { name: 'Read the converted size and fabric guidance', text: 'The matching size in the other system, plus a fabric weight suggestion, appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['European', 'American'].map((d) => (
        <button data-sys={d} class="sys-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Needle size</span>
      <select id="size" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100"></select>
    </div>
    <div id="results" class="mt-6 space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Equivalent size</div>
        <div id="r-size" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Best for</div><div id="r-fabric" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="160" viewBox="0 0 800 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="nsc-title nsc-desc">
      <title id="nsc-title">Three needles of increasing thickness</title>
      <desc id="nsc-desc">Three vertical needle shapes of increasing blade thickness, representing fine, medium, and heavy needle sizes</desc>
      <line x1="200" y1="20" x2="200" y2="140" stroke="#c026d3" stroke-width="1.5" />
      <text x="200" y="155" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Fine (60-70)</text>
      <line x1="400" y1="20" x2="400" y2="140" stroke="#c026d3" stroke-width="3" />
      <text x="400" y="155" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Medium (75-90)</text>
      <line x1="600" y1="20" x2="600" y2="140" stroke="#c026d3" stroke-width="5" />
      <text x="600" y="155" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Heavy (100-120)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Needle blade thickness increases with the size number</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How needle sizing works</h2>
    <p class="mt-2 text-slate-600">
      Sewing machine needles are labeled with two numbers on the same package, following two parallel and standardized numbering scales: a European size, which is the needle's blade diameter in hundredths of a millimeter, and an American size, a separate scale that runs alongside it. Both numbers increase together with needle thickness, so a package marked "90/14" means a European size 90 (0.9mm blade) that's equivalent to an American size 14.
    </p>
    <p class="mt-3 text-slate-600">
      Needle size should be matched to fabric weight: too fine a needle on heavy fabric can bend, break, or skip stitches, while too heavy a needle on delicate fabric leaves visible, hard-to-repair holes. This calculator pairs each size with the fabric weight range it's typically suited for.
    </p>
    <p class="mt-3 text-xs text-slate-400">European and American needle size pairings follow the standardized system used across major needle manufacturers.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A pattern for medium-weight quilting cotton recommends an American size 12 needle, and the sewist needs the European equivalent.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">American size:</span> <span class="text-slate-600">12</span></div>
        <div><span class="font-medium text-slate-700">European equivalent:</span> <span class="text-slate-600"><strong>80</strong></span></div>
        <div><span class="font-medium text-slate-700">Best for:</span> <span class="text-slate-600">Quilting cotton, shirting, medium wovens</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A pattern written by a European designer often lists only the metric needle size, while a needle package bought at a US craft store lists the American size most prominently — cross-referencing the two prevents buying the wrong needle for a project, especially for beginners unfamiliar with the dual-numbering convention.
    </p>
    <p class="mt-3 text-slate-600">
      Skipped stitches and consistent thread breakage are common troubleshooting symptoms traced back to a mismatched needle size — a size that's too fine for a heavier project fabric flexes and deflects rather than penetrating cleanly, which looks like a machine tension problem but is actually a needle sizing issue.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A bigger needle number is always better for a stronger seam." <strong class="text-slate-900">Not for lightweight fabric.</strong> An oversized needle on delicate fabric leaves visible holes and can snag or tear the weave, regardless of how strong the resulting seam might otherwise be.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Needle type (universal, ballpoint, denim) doesn't matter as much as size." <strong class="text-slate-900">It matters just as much.</strong> Needle size describes thickness, but the point shape (sharp for wovens, rounded ballpoint for knits, reinforced for denim) is a separate factor that affects stitch quality just as significantly as the size number.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/stitch-length-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Stitch Length Calculator</a>
      <a href="/tools/thread-consumption-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Thread Consumption Calculator</a>
      <a href="/tools/fabric-weight-gsm-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">GSM / Fabric Weight Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let system = 'European';
    // [European, American, fabric guidance]
    const table = [
      [60, 8, 'Very lightweight: chiffon, voile, silk organza'],
      [65, 9, 'Lightweight: lawn, lightweight cotton'],
      [70, 10, 'Light-medium: rayon, light quilting cotton'],
      [75, 11, 'Medium-light: quilting cotton, poplin'],
      [80, 12, 'Medium: quilting cotton, shirting, medium wovens'],
      [90, 14, 'Medium-heavy: denim (light), twill, linen'],
      [100, 16, 'Heavy: denim, canvas, upholstery fabric'],
      [110, 18, 'Very heavy: heavy canvas, multiple denim layers'],
      [120, 19, 'Extra heavy: leather, heavy upholstery'],
    ];

    function populate() {
      const sizeSel = el('size');
      sizeSel.innerHTML = '';
      const idx = system === 'European' ? 0 : 1;
      table.forEach((row, i) => {
        const opt = document.createElement('option');
        opt.value = i;
        opt.textContent = row[idx];
        sizeSel.appendChild(opt);
      });
      update();
    }

    function update() {
      const idx = parseInt(el('size').value || '0', 10);
      const row = table[idx];
      if (!row) return;
      el('r-size').textContent = system === 'European' ? 'American ' + row[1] : 'European ' + row[0];
      el('r-fabric').textContent = row[2];
    }

    document.querySelectorAll('.sys-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sys-btn').forEach((b) => {
          b.className = 'sys-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'sys-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        system = btn.dataset.sys;
        populate();
      });
    });

    el('size').addEventListener('change', update);
    document.querySelector('.sys-btn').click();
  </script>
</ToolLayout>
