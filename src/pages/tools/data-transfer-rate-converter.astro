---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Data Transfer Rate Converter';
const description =
  'Convert data transfer rates between bits per second, bytes per second, Mbps, Gbps, MB/s, and more with instant results.';
const intro =
  'Convert data transfer rates between bits per second, bytes per second, and their multiples.';
const category = { id: 'converters', name: 'Converters' };
const faqs = [
  { q: 'Why is my download speed in MB/s different from my ISP speed in Mbps?', a: 'ISPs advertise in megabits per second (Mbps). Divide by 8 to get megabytes per second (MB/s). A 100 Mbps connection delivers up to 12.5 MB/s.' },
  { q: 'What is the difference between bps and Bps?', a: 'Lowercase b = bits, uppercase B = bytes. 1 Bps = 8 bps. This is the most common unit mix-up in networking.' },
  { q: 'How fast is 1 Gbps in real-world terms?', a: '1 Gbps = 1000 Mbps = 125 MB/s. A 1 GB file would download in about 8 seconds at full speed.' },
  { q: 'What does Mbps stand for?', a: 'Megabits per second. 1 Mbps = 1,000,000 bps = 125,000 Bps.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Enter value</span>
      <input id="rate" type="number" step="any" min="0" value="100"
        class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </label>
    <label class="block mt-3">
      <span class="text-sm font-medium text-slate-700">From unit</span>
      <select id="from-unit"
        class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="bps">bits/s (bps)</option>
        <option value="kbps">kilobits/s (kbps)</option>
        <option value="Mbps" selected>megabits/s (Mbps)</option>
        <option value="Gbps">gigabits/s (Gbps)</option>
        <option value="Tbps">terabits/s (Tbps)</option>
        <option value="Bps">bytes/s (Bps)</option>
        <option value="KBps">kilobytes/s (KBps)</option>
        <option value="MBps">megabytes/s (MBps)</option>
        <option value="GBps">gigabytes/s (GBps)</option>
      </select>
    </label>
    <div class="mt-6 rounded-xl bg-slate-50 p-4">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Converted results</div>
      <div id="results" class="mt-2 space-y-1 text-sm"></div>
    </div>
    <div id="real-world" class="mt-4 hidden rounded-xl bg-indigo-50 p-4 text-sm text-indigo-800"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dtr-title dtr-desc">
      <title id="dtr-title">Download speed readout diagram</title>
      <desc id="dtr-desc">A smartphone display showing a download progress bar with Mbps readout and equivalent MB/s conversion</desc>
      <rect x="200" y="30" width="400" height="140" rx="20" fill="#1e293b" />
      <rect x="220" y="50" width="360" height="100" rx="12" fill="#334155" />
      <text x="260" y="78" fill="#94a3b8" font-size="12">Downloading&hellip;</text>
      <rect x="260" y="88" width="300" height="16" rx="8" fill="#475569" />
      <rect x="260" y="88" width="240" height="16" rx="8" fill="#6366f1" />
      <text x="580" y="100" fill="#a5b4fc" font-size="11" font-weight="bold" text-anchor="end">75%</text>
      <text x="260" y="130" fill="#e2e8f0" font-size="22" font-weight="bold">100 Mbps</text>
      <text x="260" y="146" fill="#c7d2fe" font-size="13">= 12.5 MB/s</text>
      <path d="M620 160 L620 180" stroke="#94a3b8" stroke-width="1.5" />
      <text x="620" y="178" text-anchor="middle" fill="#64748b" font-size="11">divide by 8</text>
      <rect x="50" y="40" width="100" height="120" rx="12" fill="#f1f5f9" stroke="#e2e8f0" stroke-width="1.5" />
      <text x="100" y="72" text-anchor="middle" fill="#64748b" font-size="11">ISP plan</text>
      <text x="100" y="92" text-anchor="middle" fill="#6366f1" font-size="16" font-weight="bold">100</text>
      <text x="100" y="108" text-anchor="middle" fill="#64748b" font-size="13">Mbps</text>
      <path d="M150 100 L200 100" stroke="#94a3b8" stroke-width="2" marker-end="url(#fa)" />
      <text x="175" y="90" text-anchor="middle" fill="#64748b" font-size="10">÷ 8</text>
      <rect x="650" y="40" width="100" height="120" rx="12" fill="#eef2ff" stroke="#c7d2fe" stroke-width="1.5" />
      <text x="700" y="72" text-anchor="middle" fill="#4f46e5" font-size="11">Real speed</text>
      <text x="700" y="92" text-anchor="middle" fill="#4f46e5" font-size="16" font-weight="bold">12.5</text>
      <text x="700" y="108" text-anchor="middle" fill="#64748b" font-size="13">MB/s</text>
      <defs><marker id="fa" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M0 0 L10 5 L0 10" fill="#94a3b8" /></marker></defs>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">ISP speeds in Mbps must be divided by 8 to get actual MB/s download speed</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How data transfer rate conversion works</h2>
    <p class="mt-2 text-slate-600">
      Data transfer rates measure how much data moves from one place to another over a given time period. The most common confusion is between bits and bytes. Network equipment and ISPs almost always advertise in bits per second (bps, Mbps, Gbps), while file sizes and operating systems display in bytes per second (Bps, MB/s, GB/s). This converter bridges that gap by converting between nine different rate units instantly.
    </p>
    <p class="mt-3 text-slate-600">
      Internally, every value is converted to bits per second as the base unit. From there, it is divided by the appropriate factor for each target unit: divide by 1000 per step up the bit scale (kbps, Mbps, Gbps, Tbps) or divide by 8 then by 1000 per step for the byte scale (Bps, KBps, MBps, GBps). The real-world example section helps contextualise what those numbers mean for actual downloads.
    </p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-1 rounded-xl bg-white p-4 font-mono text-sm text-slate-700">
      <div><span class="font-semibold">bits per second (base)</span> = value × unitFactor</div>
      <div><span class="font-semibold">bytes per second</span> = bps ÷ 8</div>
      <div><span class="font-semibold">kbps</span> = bps ÷ 1000 &nbsp; <span class="font-semibold">Mbps</span> = bps ÷ 1000²</div>
    </div>
    <h3 class="mt-4 font-semibold text-slate-900">Worked example</h3>
    <p class="mt-1 text-sm text-slate-600">Convert <strong>100 Mbps</strong> to all units.</p>
    <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
      <div><span class="font-medium text-slate-700">Base bps:</span> <span class="text-slate-600">100 × 1,000,000 = 100,000,000 bps</span></div>
      <div><span class="font-medium text-slate-700">kB/s:</span> <span class="text-slate-600">100,000,000 ÷ 8 ÷ 1000 = 12,500 kB/s</span></div>
      <div><span class="font-medium text-slate-700">MB/s:</span> <span class="text-slate-600">100,000,000 ÷ 8 ÷ 1000² = 12.5 MB/s</span></div>
      <div><span class="font-medium text-slate-700">Gbps:</span> <span class="text-slate-600">100,000,000 ÷ 1000³ = 0.1 Gbps</span></div>
      <div><span class="font-medium text-slate-700">GB/s:</span> <span class="text-slate-600">100,000,000 ÷ 8 ÷ 1000³ = 0.0125 GB/s</span></div>
      <div><span class="font-medium text-slate-700">File size in 1 min:</span> <span class="text-slate-600">12.5 MB/s × 60 = 750 MB</span></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌐</span>
      <h3 class="mt-2 font-semibold text-slate-900">ISP Plan Comparison</h3>
      <p class="mt-1 text-sm text-slate-600">Compare 50 Mbps vs 100 Mbps vs 500 Mbps plans by converting to MB/s to see real download speed differences.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">⏱️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Download Time Estimation</h3>
      <p class="mt-1 text-sm text-slate-600">Know a file size in GB and your connection speed in Mbps? Convert and calculate how many minutes the download will take.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🖥️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Network Benchmarking</h3>
      <p class="mt-1 text-sm text-slate-600">Speed tests report in Mbps. Convert to MB/s to compare against your storage write speed and find your true bottleneck.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📡</span>
      <h3 class="mt-2 font-semibold text-slate-900">Data Cap Monitoring</h3>
      <p class="mt-1 text-sm text-slate-600">ISPs cap data in GB. Convert your average Mbps usage to GB per hour to stay within your monthly allowance.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the data transfer rate converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your speed</h3>
        <p class="mt-1 text-sm text-slate-600">Type the numeric rate value, for example 100 for a 100 Mbps internet plan.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select the unit</h3>
        <p class="mt-1 text-sm text-slate-600">Choose either a bit-based unit (like Mbps) or a byte-based unit (like MB/s) from the dropdown.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read all results</h3>
        <p class="mt-1 text-sm text-slate-600">Instantly see the equivalent speed in every unit plus a real-world translation like "downloads a 1 GB file in X seconds".</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for data rate conversions</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Remember the bit/byte rule</h3>
        <p class="mt-1 text-sm text-slate-600">Always divide by 8 when converting from bits to bytes. A 1 Gbps connection delivers 125 MB/s maximum, not 1000 MB/s.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Overhead reduces real speed</h3>
        <p class="mt-1 text-sm text-slate-600">Protocol overhead (TCP/IP headers, encryption, WiFi interference) typically reduces throughput by 10–30%. Your real MB/s will be lower than the theoretical maximum.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use MB/s for file transfers</h3>
        <p class="mt-1 text-sm text-slate-600">When copying files between drives or downloading, the speed shown in your OS is in MB/s or GB/s. Convert your ISP plan to these units for realistic expectations.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/data-storage-converter/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">💾</span>
        <h3 class="mt-1 font-semibold text-slate-900">Data Storage Converter</h3>
        <p class="text-sm text-slate-600">Convert between all storage units SI and IEC.</p>
      </a>
      <a href="/tools/bandwidth-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📶</span>
        <h3 class="mt-1 font-semibold text-slate-900">Bandwidth Calculator</h3>
        <p class="text-sm text-slate-600">Calculate bandwidth needs for any application.</p>
      </a>
      <a href="/tools/bandwidth-vs-throughput-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📊</span>
        <h3 class="mt-1 font-semibold text-slate-900">Bandwidth vs Throughput</h3>
        <p class="text-sm text-slate-600">Understand the difference between bandwidth and throughput.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const factors = { bps: 1, kbps: 1e3, Mbps: 1e6, Gbps: 1e9, Tbps: 1e12, Bps: 8, KBps: 8e3, MBps: 8e6, GBps: 8e9 };
    const labels = { bps: 'bits/s', kbps: 'kbps', Mbps: 'Mbps', Gbps: 'Gbps', Tbps: 'Tbps', Bps: 'Bps', KBps: 'kB/s', MBps: 'MB/s', GBps: 'GB/s' };
    const order = ['bps', 'kbps', 'Mbps', 'Gbps', 'Tbps', 'Bps', 'KBps', 'MBps', 'GBps'];

    function fmt(n) {
      if (Math.abs(n) >= 1e12) return n.toExponential(4);
      if (Math.abs(n) >= 1) return n.toLocaleString(undefined, { maximumFractionDigits: 2 });
      if (n === 0) return '0';
      return n.toPrecision(4);
    }

    function update() {
      const val = parseFloat(document.getElementById('rate').value) || 0;
      const from = document.getElementById('from-unit').value;
      const bps = val * factors[from];

      const results = document.getElementById('results');
      results.innerHTML = order.map(u => {
        const v = bps / factors[u];
        return `<div class="flex justify-between py-0.5"><span class="font-medium text-slate-700">${labels[u]}</span><span class="text-slate-600">${fmt(v)}</span></div>`;
      }).join('');

      const rw = document.getElementById('real-world');
      const MBs = bps / 8e6;
      if (MBs > 0) {
        const gb1 = 1 / MBs;
        const gb5 = 5 / MBs;
        const gb50 = 50 / MBs;
        rw.innerHTML = `<span class="font-semibold">Real-world:</span> Downloads 1 GB in ${gb1 < 60 ? Math.round(gb1) + 's' : (gb1 / 60).toFixed(1) + ' min'}, 5 GB in ${gb5 < 60 ? Math.round(gb5) + 's' : (gb5 / 60).toFixed(1) + ' min'}, 50 GB in ${(gb50 / 60).toFixed(1)} min`;
        rw.classList.remove('hidden');
      } else {
        rw.classList.add('hidden');
      }
    }

    document.getElementById('rate').addEventListener('input', update);
    document.getElementById('from-unit').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
