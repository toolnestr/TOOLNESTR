---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Boiling Point Elevation Calculator';
const description = 'Boiling point elevation calculator with a live 3D diagram and charts. Solve ΔTb = i·Kb·m for how much a solute raises a solvent\'s boiling point, with worked examples for salt and sugar solutions.';
const intro = 'Solve ΔTb = i·Kb·m for the boiling point elevation caused by dissolving a solute in a solvent — a colligative property that depends only on how many particles are dissolved, not what they are. Two 3D diagrams compare pure solvent to a solution at the molecular level, and charts show how elevation scales with molality and with the van\'t Hoff factor.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is boiling point elevation?', a: 'Boiling point elevation is the increase in a solvent\'s boiling point caused by dissolving a non-volatile solute in it. The formula is ΔTb = i·Kb·m, where i is the van\'t Hoff factor, Kb is the ebullioscopic constant, and m is molality.' },
  { q: 'What is the van\'t Hoff factor (i)?', a: 'The van\'t Hoff factor is the number of particles a solute dissociates into in solution. Nonelectrolytes like glucose have i=1 (they don\'t dissociate), NaCl has i=2 (splits into Na⁺ and Cl⁻), and CaCl₂ has i=3 (one Ca²⁺ plus two Cl⁻).' },
  { q: 'What is the ebullioscopic constant (Kb)?', a: 'Kb is a property of the solvent itself, describing how much the boiling point rises per unit of molality. For water, Kb = 0.512 °C·kg/mol — different solvents have very different Kb values.' },
  { q: 'Why does boiling point elevation depend on particle count, not identity?', a: 'Boiling point elevation is a colligative property — it depends only on the number of dissolved particles, not their chemical identity. Two solutions with the same total particle concentration raise the boiling point by the same amount, regardless of what the solute actually is.' },
  { q: 'Does concentration or molality matter more for this calculation?', a: 'Molality (moles of solute per kg of solvent) is used specifically because it doesn\'t change with temperature, unlike molarity (which is volume-based and shifts as the solution expands or contracts with heat).' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Boiling Point Elevation Calculator',
  description: 'Solve ΔTb = i·Kb·m for the boiling point elevation from a solute\'s van\'t Hoff factor, the solvent\'s Kb, and molality.',
  steps: [
    { name: 'Enter the van\'t Hoff factor (i)', text: 'Use i=1 for nonelectrolytes (sugars), i=2 for 1:1 salts like NaCl, i=3 for salts like CaCl₂.' },
    { name: 'Enter Kb and molality', text: 'Provide the solvent\'s ebullioscopic constant (0.512 for water) and the solution\'s molality.' },
    { name: 'Read the result', text: 'The boiling point elevation and new boiling point solve instantly.' },
  ],
};

const formulas = [
  { expr: 'ΔTb = i·Kb·m', note: 'boiling point elevation — i = van\'t Hoff factor, Kb = ebullioscopic constant, m = molality (mol/kg)' },
  { expr: 'BP_new = BP_pure + ΔTb', note: 'the solution\'s new boiling point' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — table salt (NaCl) in water', tone: 'slate',
    given: '2 mol of NaCl dissolved in 1 kg of water (m = 2 mol/kg). NaCl dissociates into 2 ions (i=2). Water\'s Kb = 0.512 °C·kg/mol.',
    rows: [
      { label: 'Formula:', value: 'ΔTb = i·Kb·m' },
      { label: 'Substitute:', value: 'ΔTb = 2 × 0.512 × 2' },
      { label: 'Result:', value: 'ΔTb = 2.048°C, so BP_new = 100 + 2.048 = 102.048°C', full: true },
    ],
    note: 'Because NaCl splits into two ions per formula unit, it raises the boiling point twice as much as a nonelectrolyte at the same molality would.',
  },
  {
    title: 'Worked example 2 — glucose (a nonelectrolyte) in water', tone: 'amber',
    given: '1 mol of glucose dissolved in 0.5 kg of water (m = 2 mol/kg). Glucose does not dissociate (i=1). Water\'s Kb = 0.512 °C·kg/mol.',
    rows: [
      { label: 'Formula:', value: 'ΔTb = i·Kb·m' },
      { label: 'Substitute:', value: 'ΔTb = 1 × 0.512 × 2' },
      { label: 'Result:', value: 'ΔTb = 1.024°C, so BP_new = 100 + 1.024 = 101.024°C', full: true },
    ],
    note: 'Same molality as the NaCl example, but exactly half the boiling point elevation — because glucose contributes only one particle per formula unit instead of two.',
  },
];

const comparison = {
  heading: 'How the van\'t Hoff factor changes boiling point elevation',
  note: 'Same molality (2 mol/kg) and solvent (water, Kb=0.512) — only the number of dissolved particles per formula unit changes.',
  headers: [{ label: 'Solute' }, { label: 'i' }, { label: 'ΔTb' }],
  rows: [
    ['Glucose (nonelectrolyte) ★', '1', '1.024°C'],
    ['NaCl', '2', '2.048°C'],
    ['CaCl₂', '3', '3.072°C'],
    ['AlCl₃', '4', '4.096°C'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 2). Elevation scales directly with i — a solute that splits into more ions raises the boiling point proportionally more, at the same molality.',
};

const realWorld = [
  { emoji: '🍝', title: 'Cooking — salting pasta water', body: 'Adding salt to boiling water does technically raise its boiling point, though the effect at typical cooking concentrations is small — usually less than 1°C, more relevant to seasoning than to cooking speed.' },
  { emoji: '🚗', title: 'Engine coolant formulation', body: 'Antifreeze/coolant mixtures use boiling point elevation deliberately, raising the boiling point of the coolant so engines can run hotter without the coolant boiling over.' },
  { emoji: '🧪', title: 'Determining unknown molar masses', body: 'Boiling point elevation measurements can be used in reverse — measuring ΔTb for a solution of known mass lets chemists calculate the molar mass of an unknown solute.' },
  { emoji: '🏭', title: 'Industrial solution processing', body: 'Chemical and food processing industries account for boiling point elevation when concentrating solutions by evaporation, since a more concentrated solution boils at a progressively higher temperature.' },
];

const misconceptions = [
  { claim: '"Boiling point elevation depends on what the solute actually is, chemically."', truth: "It's a colligative property — it depends only on how many particles are dissolved (accounting for dissociation via i), not on the solute's chemical identity. Two different solutes at the same effective particle concentration raise the boiling point by the same amount." },
  { claim: '"Any salt added to water doubles the boiling point elevation compared to sugar."', truth: 'It depends on exactly how many ions the salt dissociates into — NaCl (i=2) does double the effect of a nonelectrolyte like sugar, but CaCl₂ (i=3) triples it, and not all "salts" behave the same way.' },
  { claim: '"Boiling point elevation and freezing point depression use the same constant."', truth: 'They use different solvent-specific constants — Kb (ebullioscopic constant) for boiling point elevation and Kf (cryoscopic constant) for freezing point depression — and for water these have quite different values (0.512 vs 1.86 °C·kg/mol).' },
  { claim: '"Molarity and molality give the same result in this formula."', truth: 'The formula specifically requires molality (moles per kg of solvent), not molarity (moles per litre of solution) — molality is used because it doesn\'t change with temperature, while molarity does as the solution\'s volume expands when heated.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 11, "Solutions and Colloids" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/11-4-colligative-properties" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 13, Properties of Solutions.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Colligative properties of solutions.' },
];
const sourcesNote = 'ΔTb = i·Kb·m. Water Kb = 0.512 °C·kg/mol (standard reference value). Results are rounded for display.';

const howToUse = [
  { title: 'Enter the van\'t Hoff factor', body: 'Use i=1 for molecular solutes, i=2/3/4 for salts based on how many ions they dissociate into.' },
  { title: 'Enter Kb and molality', body: 'Default Kb=0.512 for water — change it for other solvents. Provide the molality in mol/kg.' },
  { title: 'Read the result', body: 'Boiling point elevation and the new boiling point solve instantly.' },
];

const related = [
  { href: '/tools/freezing-point-depression-calculator', emoji: '❄️', title: 'Freezing Point Depression Calculator', desc: 'ΔTf = i·Kf·m — how much a solute lowers the freezing point.' },
  { href: '/tools/molality-calculator', emoji: '🧊', title: 'Molality Calculator', desc: 'm = mol solute / kg solvent — solve any variable.' },
  { href: '/tools/vapor-pressure-calculator', emoji: '💨', title: 'Vapor Pressure Calculator', desc: "Raoult's law — vapor pressure lowering from a dissolved solute." },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="dissolved solute particles get in the way of solvent molecules escaping into vapor, so a solution always needs a bit more heat than the pure solvent to reach its boiling point — and the effect scales directly with how many particles are actually dissolved."
  howIntro="Boiling occurs when a liquid's vapor pressure equals atmospheric pressure. Dissolved solute particles lower the solvent's vapor pressure at any given temperature (by simple dilution of the solvent at the surface), so a higher temperature is needed to reach the same vapor pressure — this vapor-pressure-lowering effect is what ΔTb=i·Kb·m quantifies directly. Because it depends only on particle count, a solute that dissociates into more ions (higher i) produces proportionally more elevation at the same molal concentration."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where boiling point elevation actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Van't Hoff factor (i)</span>
        <input id="ivh" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Kb (°C·kg/mol)</span>
        <input id="kb" type="number" step="any" value="0.512" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Molality (mol/kg)</span>
        <input id="molal" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Pure solvent boiling point (°C)</span>
      <input id="bp0" type="number" step="any" value="100" class="mt-1 w-full max-w-xs rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Boiling point elevation (ΔTb)</div><div id="r-dtb" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">New boiling point</div><div id="r-bp" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="bpe-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Pure solvent vs solution</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-pure" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Pure solvent</h3>
          <p class="mt-1 text-sm text-slate-600">Only solvent molecules (blue) — nothing obstructs their escape into vapor, so boiling starts at the normal boiling point.</p>
        </div>
        <div>
          <div id="diag-solution" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Solution with dissolved solute</h3>
          <p class="mt-1 text-sm text-slate-600">Solute particles (amber) mixed among the solvent — extra heat is needed to reach the same escaping tendency, raising the boiling point.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Boiling point elevation graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ΔTb vs molality (water, i=2)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-molal"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ΔTb vs van't Hoff factor (fixed m=2 mol/kg)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ivh"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('bpe-err').textContent = '';
        el('r-dtb').textContent = '—'; el('r-bp').textContent = '—';
        const i = parseFloat(el('ivh').value), kb = parseFloat(el('kb').value), m = parseFloat(el('molal').value), bp0 = parseFloat(el('bp0').value);
        if (isNaN(i) || isNaN(kb) || isNaN(m) || isNaN(bp0)) return;
        if (i <= 0 || kb <= 0 || m < 0) { el('bpe-err').textContent = 'Van\'t Hoff factor and Kb must be positive; molality cannot be negative.'; return; }
        const dTb = i * kb * m;
        el('r-dtb').textContent = fmt(dTb) + ' °C';
        el('r-bp').textContent = fmt(bp0 + dTb) + ' °C';
      }
      ['ivh', 'kb', 'molal', 'bp0'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsM = [], dataM = [];
        for (let m = 0; m <= 5; m += 0.5) { labelsM.push(m.toFixed(1)); dataM.push(+(2 * 0.512 * m).toFixed(3)); }
        charts.molal = new Chart(el('chart-molal'), {
          type: 'line',
          data: { labels: labelsM, datasets: [{ label: 'ΔTb (°C)', data: dataM, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Molality (mol/kg)' } }, y: { title: { display: true, text: 'ΔTb (°C)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsI = [1, 2, 3, 4], dataI = labelsI.map((i) => +(i * 0.512 * 2).toFixed(3));
        charts.ivh = new Chart(el('chart-ivh'), {
          type: 'bar',
          data: { labels: labelsI, datasets: [{ label: 'ΔTb (°C)', data: dataI, backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: "Van't Hoff factor (i)" } }, y: { title: { display: true, text: 'ΔTb (°C)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function moleculeScene(container, soluteCount) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const box = new THREE.Mesh(new THREE.BoxGeometry(4, 3, 3), new THREE.MeshBasicMaterial({ color: 0x94a3b8, wireframe: true }));
        s.scene.add(box);
        for (let i = 0; i < 20; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.16, 10, 8), new THREE.MeshStandardMaterial({ color: 0x38bdf8 }));
          m.position.set((Math.random() - 0.5) * 3.5, (Math.random() - 0.5) * 2.5, (Math.random() - 0.5) * 2.5);
          s.scene.add(m);
        }
        for (let i = 0; i < soluteCount; i++) {
          const p = new THREE.Mesh(new THREE.SphereGeometry(0.22, 10, 8), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
          p.position.set((Math.random() - 0.5) * 3.5, (Math.random() - 0.5) * 2.5, (Math.random() - 0.5) * 2.5);
          s.scene.add(p);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagPure = null, diagSolution = null;
      function initDiagPure() { const c = el('diag-pure'); if (!c) throw new Error('no container'); diagPure = moleculeScene(c, 0); }
      function initDiagSolution() { const c = el('diag-solution'); if (!c) throw new Error('no container'); diagSolution = moleculeScene(c, 8); }

      function boot() {
        try { update(); } catch (e) { console.error('[boiling-point-elevation] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[boiling-point-elevation] charts failed', e); }
        if (window.THREE) {
          try { initDiagPure(); } catch (e) { console.error('[boiling-point-elevation] pure diagram failed', e); }
          try { initDiagSolution(); } catch (e) { console.error('[boiling-point-elevation] solution diagram failed', e); }
        }
        mountResize([diagPure, diagSolution]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
