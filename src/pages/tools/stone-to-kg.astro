---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Stone to Kg"
  emoji="⚖️"
  fromUnit="stone" toUnit="kilograms"
  fromTitle="Stone" toTitle="Kilograms"
  fromSym="st" toSym="kg"
  quantity="weight"
  kind="factor" factor={6.35029}
  reverseSlug="kg-to-stone" reverseLabel="Kg to Stone Converter"
  hasReverse={true}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Convert a British body weight in stone into kilograms for medical forms, gym apps and international comparison."
/>
