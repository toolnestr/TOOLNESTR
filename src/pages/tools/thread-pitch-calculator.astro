---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Thread Pitch Calculator';
const description = 'Find the thread pitch, threads per inch and pitch diameter for a bolt from its nominal diameter and thread standard — UNC, UNF or ISO metric.';
const intro = 'Find the thread pitch and threads per inch for a bolt, from its diameter and thread standard.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'What is the difference between thread pitch and threads per inch?', a: 'Threads per inch (TPI) is used for inch (UNC/UNF) fasteners and counts how many thread crests fit in one inch. Metric thread pitch is the distance between adjacent threads in millimeters. The two are reciprocals of related units: pitch (mm) = 25.4 ÷ TPI.' },
  { q: 'What is the difference between UNC and UNF threads?', a: 'UNC (Unified Coarse) has fewer, larger threads per inch and is the more common general-purpose choice, offering easier assembly and better resistance to stripping. UNF (Unified Fine) has more threads per inch, giving finer adjustment and slightly higher tensile strength in the same nominal diameter, but is more prone to cross-threading.' },
  { q: 'How do I identify a bolt\'s thread size?', a: 'Measure the nominal outside diameter, then count the threads per inch (for inch bolts) with a thread gauge or by counting threads over a measured length, or measure the distance between threads in millimeters for metric bolts. Compare against a standard thread chart to identify the exact size and pitch.' },
  { q: 'What is pitch diameter?', a: 'Pitch diameter is the diameter measured at the imaginary cylinder where the thread\'s width and the gap between threads are equal — roughly midway between the major (outer) and minor (root) diameters. It\'s the dimension thread gauges actually measure to verify a fastener meets spec.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Common size</span>
      <select id="preset" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="0.25|20|UNC">1/4-20 UNC</option>
        <option value="0.25|28|UNF">1/4-28 UNF</option>
        <option value="0.3125|18|UNC">5/16-18 UNC</option>
        <option value="0.375|16|UNC" selected>3/8-16 UNC</option>
        <option value="0.5|13|UNC">1/2-13 UNC</option>
        <option value="0.5|20|UNF">1/2-20 UNF</option>
        <option value="custom">Custom TPI…</option>
      </select></label>
    <div id="w-custom" class="mt-4 hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Nominal diameter (in)</span>
        <input id="dia" type="number" step="any" placeholder="0.375" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Threads per inch (TPI)</span>
        <input id="tpi" type="number" step="any" placeholder="16" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Thread pitch</div>
        <div id="r-pitch" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">TPI</div><div id="r-tpi" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Approx. pitch diameter</div><div id="r-pd" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Standard</div><div id="r-std" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tp-title tp-desc">
      <title id="tp-title">Bolt thread showing pitch and diameters</title>
      <desc id="tp-desc">A threaded bolt shank with pitch, major diameter, and pitch diameter labeled</desc>
      <rect x="80" y="90" width="220" height="30" fill="#cbd5e1" stroke="#475569" stroke-width="1" />
      <g stroke="#475569" stroke-width="1"><line x1="95" y1="90" x2="95" y2="120" /><line x1="115" y1="90" x2="115" y2="120" /><line x1="135" y1="90" x2="135" y2="120" /><line x1="155" y1="90" x2="155" y2="120" /><line x1="175" y1="90" x2="175" y2="120" /><line x1="195" y1="90" x2="195" y2="120" /><line x1="215" y1="90" x2="215" y2="120" /><line x1="235" y1="90" x2="235" y2="120" /><line x1="255" y1="90" x2="255" y2="120" /><line x1="275" y1="90" x2="275" y2="120" /></g>
      <text x="190" y="150" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">pitch = distance between threads</text>
      <rect x="420" y="55" width="330" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Pitch &amp; TPI</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">pitch (mm) = 25.4 &divide; TPI</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">pitch diameter &approx; major dia &minus; 0.65×pitch</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Pitch (mm) and threads-per-inch describe the same spacing in different units.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the thread pitch calculator works</h2>
    <p class="mt-2 text-slate-600">
      Inch-standard fasteners (UNC and UNF, under the Unified Thread Standard) describe thread spacing as threads per inch (TPI) — literally how many thread crests occur in one inch of length. Metric fasteners instead describe the same spacing as pitch, the linear distance between adjacent threads in millimeters. Since both measure the same physical spacing, they convert directly: pitch in millimeters equals 25.4 divided by TPI.
    </p>
    <p class="mt-3 text-slate-600">
      UNC (Unified Coarse) threads have fewer, larger threads per inch for a given bolt diameter, making them the more common general-purpose choice — coarser threads assemble faster, resist stripping better in softer materials, and are less prone to cross-threading. UNF (Unified Fine) threads pack more threads into the same inch, giving finer holding adjustment and marginally higher tensile strength at the same nominal diameter, at the cost of being more sensitive to cross-threading and slower to run down.
    </p>
    <p class="mt-3 text-slate-600">
      Pitch diameter is a third dimension worth knowing: it's the diameter measured at the imaginary cylinder where the thread width and the gap between threads are equal, sitting roughly between the bolt's major (outside) and minor (root) diameters. It's the dimension a thread gauge actually checks to confirm a fastener meets its stated size and class — this calculator gives an approximate pitch diameter using a common rule of thumb, not the precise value from the full thread standard tables.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a common size</h3>
        <p class="mt-1 text-sm text-slate-600">Or enter a custom diameter and TPI.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read pitch and TPI</h3>
        <p class="mt-1 text-sm text-slate-600">Both units at once for cross-reference.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check pitch diameter</h3>
        <p class="mt-1 text-sm text-slate-600">An approximate value for quick reference.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Pitch from TPI</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">pitch(mm) = 25.4 &divide; TPI</span>. A 3/8-16 bolt: 25.4 ÷ 16 = <strong>1.588 mm</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Pitch in inches</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= 1 &divide; TPI</span> = 1 ÷ 16 = <strong>0.0625 in</strong> between threads.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Approx. pitch diameter</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">&approx; major dia &minus; 0.65 &times; pitch(in)</span> = 0.375 − 0.041 = <strong>0.334 in</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 1/2-20 UNF bolt.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">TPI:</span> <span class="text-slate-600">20</span></div>
        <div><span class="font-medium text-slate-700">Pitch:</span> <span class="text-slate-600">25.4 ÷ 20 = <strong>1.27 mm</strong></span></div>
        <div><span class="font-medium text-slate-700">Pitch (in):</span> <span class="text-slate-600">1 ÷ 20 = 0.05 in</span></div>
        <div><span class="font-medium text-slate-700">Pitch diameter:</span> <span class="text-slate-600">0.5 − 0.0325 ≈ <strong>0.468 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/bolt-circle-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Bolt Circle Calculator</a>
      <a href="/tools/bolt-torque-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Bolt Torque Calculator</a>
      <a href="/tools/rivet-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Rivet Size Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function sync() {
      const isCustom = el('preset').value === 'custom';
      el('w-custom').classList.toggle('hidden', !isCustom);
      update();
    }

    function update() {
      let dia, tpi, std;
      if (el('preset').value === 'custom') {
        dia = parseFloat(el('dia').value);
        tpi = parseFloat(el('tpi').value);
        std = 'Custom';
      } else {
        const parts = el('preset').value.split('|');
        dia = parseFloat(parts[0]);
        tpi = parseFloat(parts[1]);
        std = parts[2];
      }
      if (!(dia > 0 && tpi > 0)) { el('results').classList.add('hidden'); return; }

      const pitchMm = 25.4 / tpi;
      const pitchIn = 1 / tpi;
      const pd = dia - 0.65 * pitchIn;

      el('r-pitch').textContent = pitchMm.toFixed(3) + ' mm';
      el('r-note').textContent = dia.toFixed(4) + ' in nominal diameter, ' + tpi + ' TPI';
      el('r-tpi').textContent = tpi;
      el('r-pd').textContent = pd.toFixed(3) + ' in';
      el('r-std').textContent = std;
      el('results').classList.remove('hidden');
    }

    el('preset').addEventListener('change', sync);
    ['dia', 'tpi'].forEach((id) => el(id).addEventListener('input', update));
    sync();
  </script>
</ToolLayout>
