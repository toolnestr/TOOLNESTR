---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Biomass Calculator';
const description = 'Biomass calculator with a live 3D standing-crop diagram and charts. Solve total biomass from population count and average mass, or from population density and area, with worked examples and a biomass-vs-energy-pyramid comparison.';
const intro = 'Solve total biomass = population × average individual mass, or from population density × area × average mass for a sampled region. Two 3D diagrams compare a low-biomass population of large individuals to a high-biomass population of many small ones, and charts show how biomass accumulates across a population and can behave differently from energy across trophic levels.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is biomass?', a: 'Biomass is the total mass of living organisms in a given population, area, or trophic level — usually measured in kilograms or metric tons, sometimes per unit area (like kg/m²) for ecological comparisons.' },
  { q: 'How is total biomass calculated?', a: 'The simplest calculation is total biomass = population count × average individual mass. For a sampled area, it can also be found from population density × area × average individual mass.' },
  { q: 'Is a biomass pyramid the same as an energy pyramid?', a: 'They usually follow a similar decreasing pattern up the trophic levels, but they measure different things — energy pyramids track energy flow (which always decreases going up) while biomass pyramids track standing mass at an instant in time, which can occasionally invert in certain ecosystems.' },
  { q: 'When can a biomass pyramid invert?', a: 'In some aquatic ecosystems, fast-reproducing phytoplankton (producers) can have a lower standing biomass than the zooplankton that eat them, because the phytoplankton turn over (reproduce and get eaten) so quickly that a small standing biomass still supports a much larger consumer biomass over time.' },
  { q: 'Why does biomass matter separately from population count?', a: 'Population count alone doesn\'t capture body size — 1,000 small insects and 1,000 elephants represent enormously different amounts of actual living material, energy storage, and ecological impact, which is exactly why biomass is tracked as its own measurement.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Biomass Calculator',
  description: 'Solve total biomass from population count and average mass, or from population density and sampled area.',
  steps: [
    { name: 'Choose a mode', text: 'Direct (population count known) or density-based (individuals per unit area known).' },
    { name: 'Enter the required values', text: 'Population (or density and area) plus the average individual mass.' },
    { name: 'Read total biomass', text: 'Total biomass solves instantly, in kilograms and metric tons.' },
  ],
};

const formulas = [
  { expr: 'Biomass = population × average individual mass', note: 'direct calculation when population count is known' },
  { expr: 'Biomass = density × area × average individual mass', note: 'when only population density (individuals per unit area) is known' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a deer population', tone: 'slate',
    given: 'A population of 500 deer, with an average mass of 70 kg per deer.',
    rows: [
      { label: 'Formula:', value: 'Biomass = population × average mass' },
      { label: 'Substitute:', value: 'Biomass = 500 × 70 kg' },
      { label: 'Result:', value: 'Biomass = 35,000 kg = 35 metric tons', full: true },
    ],
    note: 'Total biomass captures both how many individuals there are and how large each one is — a much more complete ecological picture than population count alone.',
  },
  {
    title: 'Worked example 2 — a fish population from density and area', tone: 'amber',
    given: 'A lake survey estimates a fish density of 150 individuals per m² over a sampled area of 5,000 m², with an average mass of 10 g (0.01 kg) per fish.',
    rows: [
      { label: 'Total individuals:', value: '150 × 5,000 = 750,000 fish' },
      { label: 'Formula:', value: 'Biomass = total individuals × average mass' },
      { label: 'Result:', value: 'Biomass = 750,000 × 0.01 kg = 7,500 kg = 7.5 metric tons', full: true },
    ],
    note: 'Density-based biomass estimation is standard practice in aquatic and plant ecology, where directly counting every individual across a large area usually isn\'t practical.',
  },
];

const comparison = {
  heading: 'Biomass vs. energy pyramids: similar shape, different meaning',
  note: 'Both generally decrease up the trophic levels, but they measure fundamentally different things.',
  headers: [{ label: 'Property' }, { label: 'Energy pyramid' }, { label: 'Biomass pyramid' }],
  rows: [
    ['What it measures', 'Energy flow through the ecosystem', 'Standing mass of living organisms at an instant'],
    ['Can it invert? ★', 'Never', 'Occasionally, in fast-turnover systems (e.g., some aquatic food webs)'],
    ['Typical unit', 'kcal or Joules per unit area per year', 'kg or g per unit area'],
    ['Governed by', 'The laws of thermodynamics (always decreases)', 'Population size, individual mass, and turnover rate'],
  ],
  highlightIndex: 1,
  footnote: '★ This single difference is the most commonly tested concept distinguishing biomass pyramids from energy pyramids.',
};

const realWorld = [
  { emoji: '🌲', title: 'Forestry and carbon stock assessment', body: 'Forest biomass estimates (from tree density, area, and average tree mass) are used to calculate how much carbon a forest stores, informing climate policy and carbon credit markets.' },
  { emoji: '🐟', title: 'Fisheries stock assessment', body: 'Fisheries scientists estimate fish biomass (not just population count) to set sustainable catch limits, since a smaller population of larger fish can represent the same harvestable biomass as a larger population of smaller ones.' },
  { emoji: '🌾', title: 'Agricultural yield estimation', body: 'Crop biomass measurements (density × area × average plant mass) are a standard way to estimate yield before harvest, guiding planning decisions.' },
  { emoji: '🦗', title: 'Ecosystem health monitoring', body: 'Tracking biomass across trophic levels over time helps ecologists detect disruptions — a collapsing producer biomass, for example, can be an early warning sign of ecosystem stress.' },
];

const misconceptions = [
  { claim: '"A larger population always means more biomass."', truth: "Biomass depends on both population count and average individual size — a small population of large-bodied organisms (like whales) can vastly outweigh an enormous population of tiny ones (like plankton)." },
  { claim: '"Biomass and energy pyramids always look identical."', truth: "They typically follow a similar shape, but biomass pyramids can occasionally invert in certain ecosystems (especially aquatic ones with fast-reproducing producers), while energy pyramids governed by the laws of thermodynamics never can." },
  { claim: '"Biomass is only relevant for entire ecosystems, not individual species."', truth: "Biomass is calculated and used at any scale — a single population's total biomass (like all the fish of one species in a lake) is just as meaningful and commonly measured as an entire ecosystem's total biomass." },
  { claim: '"Measuring biomass requires weighing every single individual."', truth: "In practice, biomass is almost always estimated from a sample — measuring the average mass of a representative subset of individuals and multiplying by the total population count or density, rather than weighing every organism directly." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 46, "Ecosystems" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/46-3-energy-flow-through-ecosystems" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Odum, <em>Fundamentals of Ecology</em></strong> — Biomass and productivity pyramids chapter.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Ecosystem structure and biomass chapter.' },
];
const sourcesNote = 'Biomass = population × average mass, or density × area × average mass. Results are rounded for display.';

const howToUse = [
  { title: 'Choose direct or density-based mode', body: 'Direct if you know the population count; density-based if you know individuals per unit area.' },
  { title: 'Enter your values', body: 'Population (or density and area) plus average individual mass.' },
  { title: 'Read total biomass', body: 'Result displays in both kilograms and metric tons.' },
];

const related = [
  { href: '/tools/energy-pyramid-calculator', emoji: '🔺', title: 'Energy Pyramid / 10% Rule Calculator', desc: 'Energy transfer efficiency across trophic levels.' },
  { href: '/tools/population-density-calculator', emoji: '🌍', title: 'Population Density Calculator', desc: 'D = N/A — individuals per unit area.' },
  { href: '/tools/mark-recapture-calculator', emoji: '🔎', title: 'Mark-Recapture Population Estimator', desc: 'Lincoln-Petersen index — estimate population size.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="counting individuals only tells half the story — multiplying that count by how much each individual actually weighs is what turns a population number into a true measure of how much living material an ecosystem is supporting."
  howIntro="Biomass captures what a simple population count misses: body size. Whether you know the total population directly or only its density across a sampled area, multiplying by the average mass of one individual converts a headcount into a true measure of standing living mass. This measurement generally follows the same decreasing trend up a food chain as energy does, since more biomass is typically needed at lower trophic levels to support less biomass above — but unlike energy, which is strictly governed by the laws of thermodynamics and can never increase going up a food chain, standing biomass can occasionally invert in ecosystems where producers turn over (reproduce and get consumed) especially quickly."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where biomass actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-direct" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Direct (population known)</button>
      <button id="mode-density" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Density-based (per area)</button>
    </div>
    <div id="panel-direct">
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block"><span class="text-sm font-medium text-slate-700">Population count</span>
          <input id="pop" type="number" step="any" value="500" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Average mass (kg)</span>
          <input id="mass1" type="number" step="any" value="70" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
    </div>
    <div id="panel-density" class="hidden">
      <div class="grid gap-4 sm:grid-cols-3">
        <label class="block"><span class="text-sm font-medium text-slate-700">Density (individuals/m²)</span>
          <input id="density" type="number" step="any" value="150" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Area (m²)</span>
          <input id="area" type="number" step="any" value="5000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Average mass (kg)</span>
          <input id="mass2" type="number" step="any" value="0.01" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Total biomass (kg)</div><div id="r-kg" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Total biomass (metric tons)</div><div id="r-tons" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="bm-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Fewer large individuals vs. many small ones</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-large" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Few large individuals</h3>
          <p class="mt-1 text-sm text-slate-600">A small population count, but each individual contributes a lot of mass.</p>
        </div>
        <div>
          <div id="diag-small" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Many small individuals</h3>
          <p class="mt-1 text-sm text-slate-600">A large population count, but each individual contributes only a little mass.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Biomass charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Biomass vs. average individual mass (fixed population=500)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mass"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Typical trophic-level biomass pyramid</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-trophic"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let mode = 'direct';

      function switchMode(m) {
        mode = m;
        el('mode-direct').className = m === 'direct' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-density').className = m === 'density' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('panel-direct').classList.toggle('hidden', m !== 'direct');
        el('panel-density').classList.toggle('hidden', m !== 'density');
        el('bm-err').textContent = '';
      }

      function update() {
        el('bm-err').textContent = '';
        el('r-kg').textContent = '—'; el('r-tons').textContent = '—';
        let biomassKg = NaN;
        if (mode === 'direct') {
          const pop = parseFloat(el('pop').value), mass = parseFloat(el('mass1').value);
          if (isNaN(pop) || isNaN(mass)) return;
          if (pop <= 0 || mass <= 0) { el('bm-err').textContent = 'Population and mass must be positive.'; return; }
          biomassKg = pop * mass;
        } else {
          const density = parseFloat(el('density').value), area = parseFloat(el('area').value), mass = parseFloat(el('mass2').value);
          if (isNaN(density) || isNaN(area) || isNaN(mass)) return;
          if (density <= 0 || area <= 0 || mass <= 0) { el('bm-err').textContent = 'Density, area, and mass must be positive.'; return; }
          biomassKg = density * area * mass;
        }
        el('r-kg').textContent = fmt(biomassKg) + ' kg';
        el('r-tons').textContent = fmt(biomassKg / 1000) + ' t';
      }
      el('mode-direct').addEventListener('click', () => { switchMode('direct'); update(); });
      el('mode-density').addEventListener('click', () => { switchMode('density'); update(); });
      ['pop', 'mass1', 'density', 'area', 'mass2'].forEach((id) => el(id).addEventListener('input', update));

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const massLabels = [], massData = [];
        for (let m = 5; m <= 100; m += 10) { massLabels.push(m); massData.push(500 * m); }
        new Chart(el('chart-mass'), {
          type: 'line',
          data: { labels: massLabels, datasets: [{ label: 'Biomass (kg)', data: massData, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.2, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Average mass (kg)' } }, y: { title: { display: true, text: 'Total biomass (kg)' } } }, plugins: { legend: { display: false } } }),
        });
        new Chart(el('chart-trophic'), {
          type: 'bar',
          data: { labels: ['Producers', 'Primary consumers', 'Secondary consumers', 'Tertiary consumers'], datasets: [{ label: 'Relative biomass', data: [1000, 100, 10, 1], backgroundColor: ['#10b981', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Relative biomass (log scale)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function individualScene(container, count, size) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < count; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(size, 14, 12), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          const angle = (i / count) * Math.PI * 2;
          const r = 1.8;
          m.position.set(Math.cos(angle) * r, Math.sin(angle) * r * 0.6, (Math.random() - 0.5) * 1.2);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLarge = null, diagSmall = null;
      function initDiagLarge() { const c = el('diag-large'); if (!c) throw new Error('no container'); diagLarge = individualScene(c, 4, 0.6); }
      function initDiagSmall() { const c = el('diag-small'); if (!c) throw new Error('no container'); diagSmall = individualScene(c, 24, 0.16); }

      function boot() {
        try { switchMode('direct'); update(); } catch (e) { console.error('[biomass] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[biomass] charts failed', e); }
        if (window.THREE) {
          try { initDiagLarge(); } catch (e) { console.error('[biomass] large diagram failed', e); }
          try { initDiagSmall(); } catch (e) { console.error('[biomass] small diagram failed', e); }
        }
        mountResize([diagLarge, diagSmall]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
