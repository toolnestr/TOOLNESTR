---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { categories, toolsByCategory, totalInCategory } from '../../data/tools.js';
import { site } from '../../data/site.js';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.id } }));
}

const { category: catId } = Astro.params;
const category = categories.find((c) => c.id === catId);
const catTools = catId ? toolsByCategory(catId).filter((t) => t.enabled && t.status === 'live') : [];

import categoryContent from '../../category-content.js';

const content = categoryContent[catId];
const description = content?.metaDesc ?? `${category.name} tools on ${site.name} — free online calculators, converters and utilities for ${category.name.toLowerCase()}. Fast, private, no sign-up.`;

const catLabel = `${category.emoji} ${category.name}`;
// Emoji-free title for <title> tag — avoid double "Tools" for categories whose name already ends with it
const siteTitle = /tools?$/i.test(category.name) ? category.name : `${category.name} Tools`;

// Category FAQ items — generate rich People Also Ask snippets
const catFaqs = [
  {
    q: `Are ${category.name} tools free to use?`,
    a: `Yes. Every tool in the ${category.name} category on ${site.name} is completely free with no sign-up, no account and no usage limits.`,
  },
  {
    q: `Do these ${category.name} tools work on mobile?`,
    a: `Absolutely. All ${category.name} tools are mobile-first and work smoothly on phones, tablets and desktop browsers without any installation.`,
  },
  {
    q: `Is my data private when I use these tools?`,
    a: `Yes. All calculations and processing happen directly in your browser. Your data is never uploaded to any server or stored anywhere.`,
  },
];

// Combined JSON-LD: ItemList (with descriptions) + BreadcrumbList + FAQPage
const pageJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ItemList',
      numberOfItems: catTools.length,
      itemListElement: catTools.map((t, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${site.url}/tools/${t.slug}/`,
        name: t.title,
        description: t.short,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
        { '@type': 'ListItem', position: 2, name: `${category.name} Tools`, item: `${site.url}/tools/${catId}/` },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: catFaqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};

function splitIntoChunks(text, targetWords = 130) {
  const words = text.trim().split(/\s+/);
  const chunks = [];
  for (let i = 0; i < words.length; i += targetWords) {
    chunks.push(words.slice(i, Math.min(i + targetWords, words.length)).join(' '));
  }
  return chunks;
}

const introChunks = content?.intro ? splitIntoChunks(content.intro) : [];
const paraIcons = ['🎯', '⚡', '🛡️', '💡', '🔧', '🌟'];

const features = [
  { icon: '💯', label: '100% Free', desc: 'No hidden fees or subscriptions — ever.' },
  { icon: '🔑', label: 'No Sign-up', desc: 'Use any tool instantly. No account required.' },
  { icon: '🌐', label: 'Runs in Browser', desc: 'Nothing to download or install.' },
  { icon: '🛡️', label: 'Privacy First', desc: 'All processing happens on your device.' },
  { icon: '🔄', label: 'Regular Updates', desc: 'New tools and improvements every month.' },
  { icon: '📱', label: 'Mobile Friendly', desc: 'Works perfectly on any device or screen.' },
];

---

<BaseLayout title={siteTitle} description={description} jsonLd={pageJsonLd}>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <nav class="mb-4 text-sm text-slate-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-1">›</span>
      <span class="text-slate-700">{category.name} Tools</span>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      {catLabel} Tools
    </h1>
    <p class="mt-2 text-slate-500 dark:text-slate-400">
      {catTools.length} free {category.name.toLowerCase()} tools — no sign-up, runs in your browser
    </p>

    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {catTools.map((tool) => <ToolCard tool={tool} />)}
    </div>

    {catTools.length === 0 && (
      <p class="mt-10 text-center text-slate-500">No tools in this category yet — check back soon.</p>
    )}
  </div>

  <!-- Other categories -->
  <section class="border-t border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/20">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <h2 class="text-center text-lg font-bold text-slate-900 dark:text-white">Explore other categories</h2>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {categories.filter((c) => c.id !== catId).map((c) => {
          const total = totalInCategory(c.id);
          return (
            <a
              href={`/tools/${c.id}/`}
              class="group flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-600 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-300 dark:hover:border-indigo-500/30 dark:hover:text-indigo-400"
            >
              <span>{c.emoji}</span>
              <span class="min-w-0 truncate">{c.name}</span>
              <span class="ml-auto shrink-0 text-xs text-slate-400 dark:text-slate-500">{total} tool{total !== 1 ? 's' : ''}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {content?.intro && (
    <section id="category-desc" class="mx-auto max-w-6xl px-4 py-12">
      <!-- Dynamic stats: tool count for this category + site-wide categories -->
      <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-2">
        <div class="stat-card rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm dark:border-slate-700 dark:bg-slate-800/60">
          <div class="stat-value text-2xl font-bold text-indigo-600 dark:text-indigo-400">{catTools.length}</div>
          <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">Tools in this category</div>
        </div>
        <div class="stat-card rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm dark:border-slate-700 dark:bg-slate-800/60">
          <div class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">100%</div>
          <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">Private &amp; free</div>
        </div>
      </div>

      <!-- Icons per paragraph -->
      <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 dark:border-slate-700 dark:bg-slate-800/60">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">About {category.name} Tools on ToolNestr</h2>
        <div class="mt-4 space-y-6 text-base leading-relaxed text-slate-600 dark:text-slate-300">
          {introChunks.map((chunk, i) => (
            <div class="flex gap-4">
              <span class="mt-0.5 shrink-0 text-2xl">{paraIcons[i % paraIcons.length]}</span>
              <p>{chunk}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Feature Comparison Grid -->
      <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {features.map((f) => (
          <div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 dark:border-slate-700 dark:bg-slate-800/60 dark:hover:border-indigo-500/30">
            <div class="text-2xl">{f.icon}</div>
            <div class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">{f.label}</div>
            <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">{f.desc}</div>
          </div>
        ))}
      </div>
    </section>
  )}

  {content?.highlights && (
    <section class="mx-auto max-w-6xl px-4 pb-12">
      <div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-indigo-50 to-slate-50 p-6 sm:p-8 dark:border-slate-700 dark:from-indigo-950/30 dark:to-slate-900/50">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Why use our {category.name} tools?</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {content.highlights.map((h) => (
            <li class="flex items-start gap-3 text-slate-600 dark:text-slate-300">
              <span class="mt-0.5 shrink-0 text-indigo-500 dark:text-indigo-400">&#10003;</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- FAQ section — drives "People Also Ask" rich results -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 dark:border-slate-700 dark:bg-slate-800/60">
      <h2 class="text-xl font-bold text-slate-900 dark:text-white">Frequently Asked Questions</h2>
      <dl class="mt-5 divide-y divide-slate-100 dark:divide-slate-700">
        {catFaqs.map((f) => (
          <div class="py-4">
            <dt class="font-semibold text-slate-900 dark:text-white">{f.q}</dt>
            <dd class="mt-1 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{f.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</BaseLayout>
