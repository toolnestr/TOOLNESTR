---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { categories, toolsByCategory, totalInCategory } from '../../data/tools.js';
import { site } from '../../data/site.js';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.id } }));
}

const { category: catId } = Astro.params;
const category = categories.find((c) => c.id === catId);
const catTools = catId ? toolsByCategory(catId).filter((t) => t.enabled && t.status === 'live') : [];

// Subcategory tabs — only shown when tools in this category actually carry a `sub` tag
// and there's enough of them to warrant grouping (avoids empty-feeling tabs on small categories).
const subcats = [...new Set(catTools.map((t) => t.sub).filter(Boolean))];
const showSubTabs = subcats.length >= 2 && catTools.length > 12;

// Small icon per subcategory (inline SVG paths, reused across tab pills + shelf headers)
const subIcons = {
  'Cement & Concrete': 'M4 20h16M6 20V10l6-4 6 4v10M9 20v-6h6v6',
  'Materials': 'M21 8l-9-5-9 5 9 5 9-5zM3 8v8l9 5 9-5V8M12 13v8',
  'Home & Garden': 'M3 11l9-8 9 8M5 10v10h14V10M9 20v-6h6v6',
  'Roofing': 'M3 12l9-9 9 9M5 11v9h14v-9M9 20v-5h6v5',
  'Converters': 'M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4',
  'Water & Vessels': 'M12 3c3 4 6 7 6 10.5A6 6 0 016 13.5C6 10 9 7 12 3z',
  'Size Converters': 'M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4',
  'Fit & Measurement': 'M12 3v18M3 12h18M6 6l12 12M18 6L6 18',
  'Fabric & Yardage': 'M4 4h16v4H4zM4 10h16v4H4zM4 16h16v4H4z',
  'Pattern & Sewing': 'M12 2l2.5 6.5H21l-5.5 4 2 6.5-5.5-4-5.5 4 2-6.5L3 8.5h6.5z',
  'Cost & Business': 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33',
  'Care': 'M12 3c3 4 6 7 6 10.5A6 6 0 016 13.5C6 10 9 7 12 3z',
  'Accessories': 'M21 8l-9-5-9 5 9 5 9-5zM3 8v8l9 5 9-5V8',
};
const defaultSubIcon = 'M4 6h16M4 12h16M4 18h16';

// Per-category accent theme. Every class string is written out in full (not interpolated)
// so Tailwind's JIT scanner can find it at build time. Construction gets a distinct
// amber/orange identity, Clothing gets rose/pink; every other category keeps the existing indigo look.
const accents = {
  construction: {
    heroGradient: 'from-amber-500 via-orange-500 to-amber-600',
    heroGlow: 'bg-amber-400/30',
    chipActive: 'border-amber-400 bg-amber-500 text-white shadow-md shadow-amber-500/30',
    chipInactive: 'border-amber-200 bg-white text-amber-700 hover:border-amber-300 hover:bg-amber-50 dark:border-amber-500/20 dark:bg-slate-800/60 dark:text-amber-300 dark:hover:border-amber-500/40',
    ring: 'focus:border-amber-400 focus:ring-amber-100 dark:focus:ring-amber-500/20',
    text: 'text-amber-600 dark:text-amber-400',
    statValue: 'text-amber-600 dark:text-amber-400',
  },
  clothing: {
    heroGradient: 'from-rose-400 via-rose-500 to-rose-600',
    heroGlow: 'bg-rose-400/30',
    chipActive: 'border-rose-400 bg-rose-500 text-white shadow-md shadow-rose-500/30',
    chipInactive: 'border-rose-200 bg-white text-rose-700 hover:border-rose-300 hover:bg-rose-50 dark:border-rose-500/20 dark:bg-slate-800/60 dark:text-rose-300 dark:hover:border-rose-500/40',
    ring: 'focus:border-rose-400 focus:ring-rose-100 dark:focus:ring-rose-500/20',
    text: 'text-rose-600 dark:text-rose-400',
    statValue: 'text-rose-600 dark:text-rose-400',
  },
  default: {
    heroGradient: 'from-indigo-500 via-violet-500 to-indigo-600',
    heroGlow: 'bg-indigo-400/30',
    chipActive: 'border-indigo-400 bg-indigo-600 text-white shadow-md shadow-indigo-500/30',
    chipInactive: 'border-slate-200 bg-white text-slate-600 hover:border-indigo-200 hover:text-indigo-600 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-300',
    ring: 'focus:border-indigo-400 focus:ring-indigo-100 dark:focus:ring-indigo-500/20',
    text: 'text-indigo-600 dark:text-indigo-400',
    statValue: 'text-indigo-600 dark:text-indigo-400',
  },
};
const accent = accents[catId] ?? accents.default;
// Accent name passed to ToolCard so cards match the category hero color.
const accentName = catId === 'construction' ? 'amber' : catId === 'clothing' ? 'rose' : 'indigo';

import categoryContent from '../../category-content.js';

const content = categoryContent[catId];
const description = content?.metaDesc ?? `${category.name} tools on ${site.name} — free online calculators, converters and utilities for ${category.name.toLowerCase()}. Fast, private, no sign-up.`;

const catLabel = `${category.emoji} ${category.name}`;
// Emoji-free title for <title> tag — avoid double "Tools" for categories whose name already ends with it
const siteTitle = /tools?$/i.test(category.name) ? category.name : `${category.name} Tools`;

// Category FAQ items — generate rich People Also Ask snippets
const catFaqs = [
  {
    q: `Are ${category.name} tools free to use?`,
    a: `Yes. Every tool in the ${category.name} category on ${site.name} is completely free with no sign-up, no account and no usage limits.`,
  },
  {
    q: `Do these ${category.name} tools work on mobile?`,
    a: `Absolutely. All ${category.name} tools are mobile-first and work smoothly on phones, tablets and desktop browsers without any installation.`,
  },
  {
    q: `Is my data private when I use these tools?`,
    a: `Yes. All calculations and processing happen directly in your browser. Your data is never uploaded to any server or stored anywhere.`,
  },
];

// Combined JSON-LD: ItemList (with descriptions) + BreadcrumbList + FAQPage
const pageJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ItemList',
      numberOfItems: catTools.length,
      itemListElement: catTools.map((t, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${site.url}/tools/${t.slug}/`,
        name: t.title,
        description: t.short,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
        { '@type': 'ListItem', position: 2, name: `${category.name} Tools`, item: `${site.url}/tools/${catId}/` },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: catFaqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};

function splitIntoChunks(text, targetWords = 130) {
  const words = text.trim().split(/\s+/);
  const chunks = [];
  for (let i = 0; i < words.length; i += targetWords) {
    chunks.push(words.slice(i, Math.min(i + targetWords, words.length)).join(' '));
  }
  return chunks;
}

const introChunks = content?.intro ? splitIntoChunks(content.intro) : [];
const paraIcons = ['🎯', '⚡', '🛡️', '💡', '🔧', '🌟'];

const features = [
  { icon: '💯', label: '100% Free', desc: 'No hidden fees or subscriptions — ever.' },
  { icon: '🔑', label: 'No Sign-up', desc: 'Use any tool instantly. No account required.' },
  { icon: '🌐', label: 'Runs in Browser', desc: 'Nothing to download or install.' },
  { icon: '🛡️', label: 'Privacy First', desc: 'All processing happens on your device.' },
  { icon: '🔄', label: 'Regular Updates', desc: 'New tools and improvements every month.' },
  { icon: '📱', label: 'Mobile Friendly', desc: 'Works perfectly on any device or screen.' },
];

---

<BaseLayout title={siteTitle} description={description} jsonLd={pageJsonLd}>
  <!-- Hero banner -->
  <div class:list={['relative overflow-hidden bg-gradient-to-br', accent.heroGradient]}>
    <div class:list={['pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full blur-3xl', accent.heroGlow]} />
    <div class:list={['pointer-events-none absolute -left-10 bottom-0 h-48 w-48 rounded-full blur-3xl', accent.heroGlow]} />
    <div class="relative mx-auto max-w-6xl px-4 py-12 sm:py-14">
      <nav class="mb-5 text-sm text-white/70" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-1.5">›</span>
        <span class="text-white">{category.name} Tools</span>
      </nav>

      <div class="flex items-center gap-4">
        <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-white/15 text-3xl backdrop-blur-sm ring-1 ring-white/20">
          {category.emoji}
        </span>
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
            {category.name} Tools
          </h1>
          <p class="mt-1.5 text-white/85">
            {catTools.length} free tools — no sign-up, runs entirely in your browser
          </p>
        </div>
      </div>

      {showSubTabs && (
        <div class="mt-8 space-y-4">
          <div class="relative max-w-xl">
            <svg class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
            </svg>
            <input
              id="cat-tool-search"
              type="text"
              placeholder={`Search ${catTools.length} ${category.name.toLowerCase()} tools…`}
              class:list={['w-full rounded-2xl border-0 bg-white py-3.5 pl-11 pr-4 text-sm text-slate-700 shadow-lg shadow-black/10 outline-none ring-2 ring-transparent transition dark:bg-slate-800 dark:text-slate-200', accent.ring]}
            />
          </div>
          <div
            id="cat-sub-tabs"
            class="flex gap-2 overflow-x-auto pb-1 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
            data-active-classes={accent.chipActive}
            data-inactive-classes="border-white/40 bg-white/90 text-slate-600 hover:bg-white"
          >
            <button type="button" data-sub="all" class:list={['cat-tab flex shrink-0 items-center gap-1.5 rounded-full border px-4 py-2 text-sm font-medium transition', accent.chipActive]} aria-pressed="true">
              All <span class="opacity-75">({catTools.length})</span>
            </button>
            {subcats.map((s) => {
              const count = catTools.filter((t) => t.sub === s).length;
              return (
                <button type="button" data-sub={s} class="cat-tab flex shrink-0 items-center gap-1.5 rounded-full border border-white/40 bg-white/90 px-4 py-2 text-sm font-medium text-slate-600 backdrop-blur-sm transition hover:bg-white" aria-pressed="false">
                  <svg class="h-3.5 w-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={subIcons[s] ?? defaultSubIcon} />
                  </svg>
                  {s} <span class="opacity-60">({count})</span>
                </button>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-10">
    <div id="cat-tool-grid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {catTools.map((tool) => (
        <div class="cat-tool-item" data-sub={tool.sub ?? ''} data-name={tool.title.toLowerCase()}>
          <ToolCard tool={tool} accent={accentName} />
        </div>
      ))}
    </div>

    <p id="cat-tool-empty" class="mt-10 hidden text-center text-slate-500">No tools match your search — try a different term.</p>

    {catTools.length === 0 && (
      <p class="mt-10 text-center text-slate-500">No tools in this category yet — check back soon.</p>
    )}
  </div>

  {showSubTabs && (
    <script>
      const grid = document.getElementById('cat-tool-grid');
      const items = grid ? Array.from(grid.querySelectorAll('.cat-tool-item')) : [];
      const tabsContainer = document.getElementById('cat-sub-tabs');
      const tabs = Array.from(document.querySelectorAll('.cat-tab'));
      const searchInput = document.getElementById('cat-tool-search');
      const emptyMsg = document.getElementById('cat-tool-empty');
      const activeClasses = (tabsContainer?.getAttribute('data-active-classes') || '').split(/\s+/).filter(Boolean);
      const inactiveClasses = (tabsContainer?.getAttribute('data-inactive-classes') || '').split(/\s+/).filter(Boolean);
      let activeSub = 'all';

      function applyFilter() {
        const query = (searchInput && 'value' in searchInput ? searchInput.value : '').trim().toLowerCase();
        let visibleCount = 0;
        items.forEach((item) => {
          const matchesSub = activeSub === 'all' || item.getAttribute('data-sub') === activeSub;
          const matchesQuery = !query || (item.getAttribute('data-name') || '').includes(query);
          const show = matchesSub && matchesQuery;
          item.classList.toggle('hidden', !show);
          if (show) visibleCount++;
        });
        if (emptyMsg) emptyMsg.classList.toggle('hidden', visibleCount !== 0);
      }

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          activeSub = tab.getAttribute('data-sub') || 'all';
          tabs.forEach((t) => {
            const isActive = t === tab;
            t.setAttribute('aria-pressed', String(isActive));
            activeClasses.forEach((c) => t.classList.toggle(c, isActive));
            inactiveClasses.forEach((c) => t.classList.toggle(c, !isActive));
          });
          applyFilter();
        });
      });

      if (searchInput) searchInput.addEventListener('input', applyFilter);
    </script>
  )}

  <!-- Other categories -->
  <section class="border-t border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/20">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <h2 class="text-center text-lg font-bold text-slate-900 dark:text-white">Explore other categories</h2>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {categories.filter((c) => c.id !== catId).map((c) => {
          const total = totalInCategory(c.id);
          return (
            <a
              href={`/tools/${c.id}/`}
              class="group flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-600 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-300 dark:hover:border-indigo-500/30 dark:hover:text-indigo-400"
            >
              <span>{c.emoji}</span>
              <span class="min-w-0 truncate">{c.name}</span>
              <span class="ml-auto shrink-0 text-xs text-slate-400 dark:text-slate-500">{total} tool{total !== 1 ? 's' : ''}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {content?.intro && (
    <section id="category-desc" class="mx-auto max-w-6xl px-4 py-12">
      <!-- Dynamic stats: tool count for this category + site-wide categories -->
      <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-2">
        <div class="stat-card rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm dark:border-slate-700 dark:bg-slate-800/60">
          <div class="stat-value text-2xl font-bold text-indigo-600 dark:text-indigo-400">{catTools.length}</div>
          <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">Tools in this category</div>
        </div>
        <div class="stat-card rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm dark:border-slate-700 dark:bg-slate-800/60">
          <div class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">100%</div>
          <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">Private &amp; free</div>
        </div>
      </div>

      <!-- Icons per paragraph -->
      <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 dark:border-slate-700 dark:bg-slate-800/60">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">About {category.name} Tools on ToolNestr</h2>
        <div class="mt-4 space-y-6 text-base leading-relaxed text-slate-600 dark:text-slate-300">
          {introChunks.map((chunk, i) => (
            <div class="flex gap-4">
              <span class="mt-0.5 shrink-0 text-2xl">{paraIcons[i % paraIcons.length]}</span>
              <p>{chunk}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Feature Comparison Grid -->
      <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {features.map((f) => (
          <div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 dark:border-slate-700 dark:bg-slate-800/60 dark:hover:border-indigo-500/30">
            <div class="text-2xl">{f.icon}</div>
            <div class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">{f.label}</div>
            <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">{f.desc}</div>
          </div>
        ))}
      </div>
    </section>
  )}

  {content?.highlights && (
    <section class="mx-auto max-w-6xl px-4 pb-12">
      <div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-indigo-50 to-slate-50 p-6 sm:p-8 dark:border-slate-700 dark:from-indigo-950/30 dark:to-slate-900/50">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Why use our {category.name} tools?</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {content.highlights.map((h) => (
            <li class="flex items-start gap-3 text-slate-600 dark:text-slate-300">
              <span class="mt-0.5 shrink-0 text-indigo-500 dark:text-indigo-400">&#10003;</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- FAQ section — drives "People Also Ask" rich results -->
  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8 dark:border-slate-700 dark:bg-slate-800/60">
      <h2 class="text-xl font-bold text-slate-900 dark:text-white">Frequently Asked Questions</h2>
      <dl class="mt-5 divide-y divide-slate-100 dark:divide-slate-700">
        {catFaqs.map((f) => (
          <div class="py-4">
            <dt class="font-semibold text-slate-900 dark:text-white">{f.q}</dt>
            <dd class="mt-1 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{f.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</BaseLayout>
