---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { categories, toolsByCategory, liveTools } from '../../data/tools.js';
import { site } from '../../data/site.js';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.id } }));
}

const { category: catId } = Astro.params;
const category = categories.find((c) => c.id === catId);
const catTools = catId ? toolsByCategory(catId).filter((t) => t.enabled && t.status === 'live') : [];

const description = `${category.name} tools on ${site.name} — free online calculators, converters and utilities for ${category.name.toLowerCase()}. Fast, private, no sign-up.`;

const categoryContent = {
  everyday: {
    intro: 'From grade converters and date calculators to unit converters and discount tools — everything a student or busy person needs for daily tasks.',
    highlights: [
      'Calculate your exact age down to the day with our Age Calculator',
      'Convert between any units — length, weight, temperature, speed and volume',
      'Figure out discounts, tips, taxes and loan EMIs in seconds',
      'Track your GPA, grades and academic performance with multiple grading systems',
    ],
  },
  health: {
    intro: 'Monitor your fitness, understand your body composition, and plan your training with accurate health calculators.',
    highlights: [
      'Calculate your BMI and understand what your body mass index means',
      'Estimate your BMR and daily calorie needs for weight management',
      'Measure body fat percentage and find your ideal weight range',
      'Optimise your sleep schedule and running pace',
    ],
  },
  finance: {
    intro: 'Plan your finances with confidence — from mortgages and loans to investments, inflation and business metrics.',
    highlights: [
      'Compare loan and EMI options side by side',
      'See how compound interest grows your savings over time',
      'Calculate profit margins, ROAS and break-even for your business',
      'Understand inflation, salary conversions and investment returns',
    ],
  },
  math: {
    intro: 'Crunch numbers with ease — from basic averages to fractions, scientific calculations and statistics.',
    highlights: [
      'Use a full scientific calculator with trig, log and power functions',
      'Add, subtract, multiply and divide fractions step by step',
      'Calculate mean, median, mode, range and standard deviation',
      'Solve triangle geometry — area, perimeter and angles',
    ],
  },
  pdf: {
    intro: 'Edit PDFs directly in your browser — merge, split, and convert between PDF and image formats. Your files never leave your device.',
    highlights: [
      'Combine multiple PDF files into one document in any order',
      'Convert JPG, PNG and WebP images to PDF instantly',
      'Split large PDFs by extracting specific page ranges',
      'Save PDF pages as high-quality JPG images',
    ],
  },
  creators: {
    intro: 'Spruce up your social media, bios and posts with stylish text, hashtags, emojis and fun generators.',
    highlights: [
      'Turn plain text into fancy Unicode fonts for Instagram, TikTok and more',
      'Generate relevant hashtags for any topic or niche',
      'Browse and copy emojis and aesthetic symbols easily',
      'Repeat text or emoji patterns for creative effects',
    ],
  },
  developers: {
    intro: 'Essential utilities for coders, sysadmins and tech pros — format, convert, encode and generate right in your browser.',
    highlights: [
      'Format, validate and minify JSON instantly',
      'Convert between HEX, RGB and HSL colour codes',
      'Encode and decode Base64, Unix timestamps and number bases',
      'Generate QR codes, secure passwords and more',
    ],
  },
};

const content = categoryContent[catId];
const catLabel = `${category.emoji} ${category.name}`;
const siteTitle = `${catLabel} Tools`;

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: catTools.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${site.url}/tools/${t.slug}/`,
    name: t.title,
  })),
  numberOfItems: catTools.length,
};
---

<BaseLayout title={siteTitle} description={description} jsonLd={itemListJsonLd}>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <nav class="mb-4 text-sm text-slate-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-1">›</span>
      <span class="text-slate-700">{category.name} Tools</span>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      {catLabel} Tools
    </h1>
    {content?.intro && <p class="mt-3 max-w-2xl text-lg text-slate-600">{content.intro}</p>}

    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {catTools.map((tool) => <ToolCard tool={tool} />)}
    </div>

    {content?.highlights && (
      <section class="mt-14 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8">
        <h2 class="text-xl font-bold text-slate-900">Why use our {category.name} tools?</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {content.highlights.map((h) => (
            <li class="flex items-start gap-3 text-slate-600">
              <span class="mt-0.5 shrink-0 text-indigo-500">&#10003;</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
        <p class="mt-4 text-sm text-slate-500">
          All tools are free, private (they run in your browser), and work on any device.
          <a href="/" class="ml-1 font-medium text-indigo-600 hover:underline">Browse all categories →</a>
        </p>
      </section>
    )}

    {catTools.length === 0 && (
      <p class="mt-10 text-center text-slate-500">No tools in this category yet — check back soon.</p>
    )}
  </div>
</BaseLayout>
