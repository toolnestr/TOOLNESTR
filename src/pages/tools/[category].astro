---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { categories, toolsByCategory, liveTools, totalInCategory } from '../../data/tools.js';
import { site } from '../../data/site.js';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.id } }));
}

const { category: catId } = Astro.params;
const category = categories.find((c) => c.id === catId);
const catTools = catId ? toolsByCategory(catId).filter((t) => t.enabled && t.status === 'live') : [];

const description = `${category.name} tools on ${site.name} — free online calculators, converters and utilities for ${category.name.toLowerCase()}. Fast, private, no sign-up.`;

import categoryContent from '../../category-content.js';

const content = categoryContent[catId];
const catLabel = `${category.emoji} ${category.name}`;
const siteTitle = `${catLabel} Tools`;

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: catTools.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${site.url}/tools/${t.slug}/`,
    name: t.title,
  })),
  numberOfItems: catTools.length,
};
---

<BaseLayout title={siteTitle} description={description} jsonLd={itemListJsonLd}>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <nav class="mb-4 text-sm text-slate-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-1">›</span>
      <span class="text-slate-700">{category.name} Tools</span>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      {catLabel} Tools
    </h1>

    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {catTools.map((tool) => <ToolCard tool={tool} />)}
    </div>

    {content?.intro && (
      <section class="mt-14 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8">
        <h2 class="text-xl font-bold text-slate-900">About {category.name} Tools on ToolNestr</h2>
        <p class="mt-3 text-base leading-relaxed text-slate-600">{content.intro}</p>
      </section>
    )}

    {content?.highlights && (
      <section class="mt-6 rounded-2xl border border-slate-200 bg-gradient-to-br from-indigo-50 to-slate-50 p-6 sm:p-8">
        <h2 class="text-xl font-bold text-slate-900">Why use our {category.name} tools?</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {content.highlights.map((h) => (
            <li class="flex items-start gap-3 text-slate-600">
              <span class="mt-0.5 shrink-0 text-indigo-500">&#10003;</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {catTools.length === 0 && (
      <p class="mt-10 text-center text-slate-500">No tools in this category yet — check back soon.</p>
    )}
  </div>

  <!-- Other categories -->
  <section class="border-t border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/20">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <h2 class="text-center text-lg font-bold text-slate-900 dark:text-white">More categories</h2>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {categories.filter((c) => c.id !== catId).map((c) => {
          const total = totalInCategory(c.id);
          return (
            <a
              href={`/tools/${c.id}/`}
              class="group flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-600 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-300 dark:hover:border-indigo-500/30 dark:hover:text-indigo-400"
            >
              <span>{c.emoji}</span>
              <span class="min-w-0 truncate">{c.name}</span>
              <span class="ml-auto shrink-0 text-xs text-slate-400 dark:text-slate-500">{total} tool{total !== 1 ? 's' : ''}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
