---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { categories, toolsByCategory, liveTools, totalInCategory } from '../../data/tools.js';
import { site } from '../../data/site.js';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.id } }));
}

const { category: catId } = Astro.params;
const category = categories.find((c) => c.id === catId);
const catTools = catId ? toolsByCategory(catId).filter((t) => t.enabled && t.status === 'live') : [];

const description = `${category.name} tools on ${site.name} — free online calculators, converters and utilities for ${category.name.toLowerCase()}. Fast, private, no sign-up.`;

const categoryContent = {
  everyday: {
    intro: "The Everyday Tools collection on ToolNestr brings together a versatile set of utilities designed to simplify the small but essential tasks that pop up in daily life. From counting characters and generating random numbers to measuring time spans and converting units on the fly, these tools eliminate the need to hunt through multiple websites or dig out a dedicated calculator. Whether you are a student checking a word count before submitting an assignment, a professional timing a presentation, or someone who just needs a quick answer without downloading an app, this category has you covered. Each tool is built for speed, clarity, and accessibility, with straightforward inputs and instant results. ToolNestr keeps these utilities free and ready in your browser so you can focus on what matters instead of wrestling with complicated software.",
    highlights: [
      "Quickly generate secure random numbers or passwords for everyday use without installing any software.",
      "Count words, characters, sentences, and paragraphs in real time to stay within any length requirement.",
      "Measure elapsed time or set countdowns with an accurate online stopwatch and timer tool.",
      "Convert between common units like length, weight, and volume with a single click and no sign-up.",
      "Roll virtual dice or flip a coin for quick decisions, games, or classroom activities.",
      "Access all everyday tools instantly from any device without downloads, accounts, or hidden fees.",
    ],
  },
  health: {
    intro: "ToolNestr's Health and Wellness category provides a suite of calculators and trackers that put actionable health insights right at your fingertips. Whether you are monitoring your body mass index, estimating daily calorie needs, or calculating your ideal weight range, these tools give you a data-driven starting point for making informed lifestyle decisions. The calculators are built around widely accepted medical formulas so you can trust the numbers you see. Beyond the basics, you will find tools for assessing body fat percentage, estimating lean body mass, and understanding metrics like basal metabolic rate. Each tool presents its results clearly and explains what the numbers mean in practical terms. Use them alongside professional medical advice to set realistic fitness goals, track progress over time, and build healthier daily habits.",
    highlights: [
      "Calculate your BMI instantly and see which weight category your result falls into based on standard medical classifications.",
      "Estimate your basal metabolic rate using the Mifflin-St Jeor equation to plan your nutrition more accurately.",
      "Determine your daily calorie needs based on age, gender, weight, height, and activity level for tailored meal planning.",
      "Compute your lean body mass and body fat percentage to better understand your body composition beyond the scale.",
      "Find your ideal weight range using multiple established formulas for a more complete picture of your health targets.",
      "Track key health metrics over time with easy-to-read results that help you spot trends and adjust your routine.",
    ],
  },
  finance: {
    intro: "The Finance section on ToolNestr empowers you to take control of your personal finances with a comprehensive set of calculators that handle everything from loan payments to investment returns. Whether you are comparing mortgage options, figuring out how much you need to save for retirement, or splitting a restaurant bill among friends, these tools remove the guesswork and deliver accurate numbers in seconds. Each calculator is designed with real-world scenarios in mind, using standard financial formulas so you can confidently plan your budget, evaluate debt payoff strategies, or estimate the impact of different interest rates. ToolNestr keeps the interface clean and the results transparent, showing you the math behind each answer so you understand how your money works and where you can make better financial decisions.",
    highlights: [
      "Calculate monthly loan payments with amortization schedules that show exactly how much goes toward principal versus interest.",
      "Compare compound interest scenarios for savings and investments to see how different rates affect long-term growth.",
      "Determine your ideal emergency fund target based on your monthly expenses and personal financial situation.",
      "Estimate take-home pay after taxes and deductions to build a realistic monthly budget that actually works.",
      "Visualize debt payoff timelines using avalanche or snowball methods to choose the strategy that saves you the most.",
      "Split bills, tips, and shared expenses evenly or by custom percentages with a tool built for group spending.",
