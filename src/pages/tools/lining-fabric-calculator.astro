---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Lining Fabric Calculator';
const description = 'Estimate how much lining fabric you need for a jacket, dress, skirt, pants, or vest. Get accurate yardage based on garment type and size before you shop.';
const intro = 'Estimate lining fabric yardage for a garment from garment type and size.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Do I need lining for every garment?', a: 'No — lining is typically added to structured garments (jackets, coats, tailored skirts and dresses) for a cleaner interior finish and easier wear, while casual knits and many everyday garments skip it entirely.' },
  { q: 'Can I use the same fabric width estimate as my main fabric?', a: 'Lining fabric is commonly sold at a similar 45-60 inch width to garment fabric, but always check the specific bolt width you\'re buying, since a narrower or wider lining fabric changes the yardage needed the same way it would for any fabric.' },
  { q: 'Why does size affect lining yardage more for some garments than others?', a: 'Garments with more surface area relative to their base size (like a full-skirted dress) see yardage scale up faster with size than simpler shapes (like a fitted vest), so the multiplier this calculator applies is a general approximation, not an exact fit.' },
  { q: 'Should I round up the estimate?', a: 'Yes — this calculator gives a general planning estimate; buying a quarter to half yard extra beyond the shown range is a reasonable safety margin for cutting layout and mistakes.' },
];
const howTo = {
  name: 'How to estimate lining fabric yardage',
  steps: [
    { name: 'Choose garment type', text: 'Select the garment you\'re lining from the dropdown.' },
    { name: 'Choose size range', text: 'Select small, medium, or large to adjust the base estimate.' },
    { name: 'Read the yardage range', text: 'A typical lining yardage range for that garment and size appears instantly, at standard 45-inch fabric width.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <span class="text-sm font-medium text-slate-700">Garment type</span>
        <select id="garment" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
          <option value="0">Vest</option>
          <option value="1">Skirt</option>
          <option value="2">Pants</option>
          <option value="3" selected>Jacket</option>
          <option value="4">Dress</option>
          <option value="5">Coat</option>
        </select>
      </div>
      <div>
        <span class="text-sm font-medium text-slate-700">Size range</span>
        <select id="size" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
          <option value="0.85">Small</option>
          <option value="1" selected>Medium</option>
          <option value="1.2">Large</option>
          <option value="1.4">XL / plus</option>
        </select>
      </div>
    </div>
    <div id="results" class="mt-6">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated lining needed (45in fabric)</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="lfc-title lfc-desc">
      <title id="lfc-title">Jacket outline with a lining layer inside</title>
      <desc id="lfc-desc">A jacket silhouette with a dashed inner outline representing the lining layer sewn inside</desc>
      <path d="M320 30 L360 15 L400 28 L440 15 L480 30 L495 80 L480 90 L470 180 L330 180 L320 90 L305 80 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <path d="M335 45 L365 35 L400 42 L435 35 L465 45 L475 80 L465 88 L458 165 L342 165 L335 88 L325 80 Z" fill="none" stroke="#94a3b8" stroke-width="2" stroke-dasharray="5 3" />
      <text x="600" y="90" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Lining follows the</text>
      <text x="600" y="108" font-size="13" fill="#475569" font-family="system-ui,sans-serif">shell's shape, inset slightly</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Lining roughly mirrors the outer garment's pattern pieces</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How lining yardage is estimated</h2>
    <p class="mt-2 text-slate-600">
      Lining fabric roughly follows the same pattern pieces as the garment's outer shell, minus facings and areas that don't need a lined interior, so this calculator starts from typical base yardages published across home-sewing references for each garment type at a standard 45-inch fabric width, then scales that base range up or down by size.
    </p>
    <p class="mt-3 text-slate-600">
      A vest needs comparatively little lining since it's a small, simple shape, while a full coat needs considerably more since both the body and sleeves are lined edge to edge. Size scaling is approximate — a plus-size garment doesn't need proportionally more fabric in a perfectly linear way, but the multiplier used here reflects the general trend seen across published sewing yardage charts.
    </p>
    <p class="mt-3 text-xs text-slate-400">Base yardage ranges reflect commonly published home-sewing lining yardage guidance at 45-inch fabric width; always check your specific pattern's fabric requirements chart when one is provided.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">Lining a medium-size blazer jacket.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Base range (jacket):</span> <span class="text-slate-600">2 - 2.5 yd</span></div>
        <div><span class="font-medium text-slate-700">Size multiplier:</span> <span class="text-slate-600">Medium ×1</span></div>
        <div><span class="font-medium text-slate-700">Estimated need:</span> <span class="text-slate-600"><strong>2 - 2.5 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Home sewists tailoring a blazer or coat often underestimate lining needs because it feels like a secondary material compared to the main shell fabric — running out partway through cutting means either an awkward fabric-store return trip mid-project or settling for a mismatched second lining color, both of which this kind of upfront estimate helps avoid.
    </p>
    <p class="mt-3 text-slate-600">
      Costume and formalwear makers lining a structured dress bodice face a similar planning problem, since bridal and eveningwear linings are often a specific slippery fabric (like china silk or Bemberg rayon) that's harder to match if bought in two separate batches from different dye lots.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Lining always needs the same yardage as the shell fabric." <strong class="text-slate-900">Usually less.</strong> Facings, collars, and some structural layers in the shell often aren't duplicated in the lining, so lining yardage typically runs somewhat less than the main fabric, not equal to it.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any lightweight fabric works fine as lining." <strong class="text-slate-900">Not for every project.</strong> Lining fabric is chosen for slip (low friction against clothing worn underneath) and drape as much as weight — a lightweight but grippy fabric can make a jacket hard to put on and take off.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/garment-fabric-estimator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Garment Fabric Estimator</a>
      <a href="/tools/interfacing-stabilizer-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Interfacing/Stabilizer Yardage Calculator</a>
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Yardage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    // [low, high] yards at medium size, 45in fabric
    const bases = [
      [0.75, 1], [1, 1.5], [1.5, 2], [2, 2.5], [2, 2.5], [3.5, 5],
    ];

    function update() {
      const idx = parseInt(el('garment').value, 10);
      const mult = parseFloat(el('size').value);
      const [lo, hi] = bases[idx];
      el('r-yards').textContent = (lo * mult).toFixed(2) + ' - ' + (hi * mult).toFixed(2) + ' yd';
    }

    el('garment').addEventListener('change', update);
    el('size').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
