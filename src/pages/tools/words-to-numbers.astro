---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Words to Numbers Converter';
const description = 'Convert written numbers to digits instantly — turn “one thousand two hundred thirty-four” into 1234. Understands hundreds, thousands, millions and billions.';
const intro = 'Type a number written in words to convert it into digits.';
const category = { id: 'converters', name: 'Converters', emoji: '🔄' };
const faqs = [
  { q: 'How do I convert words to numbers?', a: 'Type the number in plain English — for example “two million five hundred thousand” — and the converter parses the words and scale terms into the digit value 2,500,000 instantly.' },
  { q: 'Which words are understood?', a: 'It recognises units (one to nineteen), tens (twenty to ninety), and scale words: hundred, thousand, million, billion and trillion. Hyphens and the word “and” are handled.' },
  { q: 'Is it accurate for large numbers?', a: 'Yes. The parser combines each value with its scale word the way English number naming works, so large compound numbers convert correctly.' },
  { q: 'How do I convert numbers back to words?', a: 'Use our Number to Words converter for the reverse direction, turning digits into written English.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Number in words</span>
      <input id="words" type="text" placeholder="e.g. one thousand two hundred thirty-four" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-4 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">As digits</div>
      <div id="out" class="mt-1 text-3xl font-bold tabular-nums">—</div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="160" viewBox="0 0 800 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="wn-title wn-desc">
      <title id="wn-title">Words mapped to digits</title>
      <desc id="wn-desc">The words one thousand two hundred thirty-four converting to the number 1234.</desc>
      <rect x="60" y="40" width="430" height="44" rx="8" fill="#eef2ff" stroke="#a5b4fc" /><text x="275" y="68" text-anchor="middle" font-size="15" fill="#3730a3" font-family="system-ui,sans-serif">one thousand two hundred thirty-four</text>
      <path d="M500 62 L560 62" stroke="#94a3b8" stroke-width="2" marker-end="url(#wna)" /><defs><marker id="wna" markerWidth="10" markerHeight="10" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#94a3b8" /></marker></defs>
      <rect x="570" y="40" width="170" height="44" rx="8" fill="#f8fafc" stroke="#cbd5e1" /><text x="655" y="68" text-anchor="middle" font-size="20" fill="#1e293b" font-family="system-ui,sans-serif" font-weight="bold">1,234</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Each value word is multiplied by its scale word to build the final number.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the words-to-numbers converter works</h2>
    <p class="mt-2 text-slate-600">English number names follow a regular pattern, which makes them possible to parse back into digits. This converter reads the words you type, recognises each value word and each scale word, and rebuilds the numeric value. It is the reverse of spelling a number out: instead of going from 1,234 to “one thousand two hundred thirty-four”, it goes from the words back to 1,234.</p>
    <p class="mt-3 text-slate-600">The parser keeps a running total and a current group value. When it meets a unit or tens word it adds to the current group; when it meets “hundred” it multiplies the group by one hundred; and when it meets a larger scale word like “thousand” or “million”, it multiplies the group by that scale and folds it into the total. Connecting words such as “and” are ignored, and hyphenated forms like “thirty-four” are split automatically.</p>
    <p class="mt-3 text-slate-600">This is handy when you receive an amount written out — on a cheque, in a contract, in a spoken figure you have transcribed — and you need it as a number for a spreadsheet or form. The conversion runs entirely in your browser, so it is instant and private. For the opposite task, the Number to Words converter turns digits into written English.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related converters</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/number-to-words" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Number to Words</a>
      <a href="/tools/fraction-to-decimal" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fraction to Decimal</a>
      <a href="/tools/roman-numerals" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Roman Numerals</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const SMALL = { zero: 0, one: 1, two: 2, three: 3, four: 4, five: 5, six: 6, seven: 7, eight: 8, nine: 9, ten: 10, eleven: 11, twelve: 12, thirteen: 13, fourteen: 14, fifteen: 15, sixteen: 16, seventeen: 17, eighteen: 18, nineteen: 19, twenty: 20, thirty: 30, forty: 40, fifty: 50, sixty: 60, seventy: 70, eighty: 80, ninety: 90 };
    const SCALE = { hundred: 100, thousand: 1000, million: 1000000, billion: 1000000000, trillion: 1000000000000 };
    function convert() {
      const raw = el('words').value.toLowerCase().replace(/-/g, ' ').replace(/\band\b/g, ' ').replace(/[^a-z\s]/g, ' ');
      const tokens = raw.split(/\s+/).filter(Boolean);
      if (!tokens.length) { el('out').textContent = '—'; return; }
      let total = 0, current = 0, seen = false;
      for (const t of tokens) {
        if (t in SMALL) { current += SMALL[t]; seen = true; }
        else if (t === 'hundred') { current = (current || 1) * 100; seen = true; }
        else if (t in SCALE) { total += (current || 1) * SCALE[t]; current = 0; seen = true; }
        else { /* ignore unknown word */ }
      }
      if (!seen) { el('out').textContent = 'Enter a number in words'; return; }
      el('out').textContent = (total + current).toLocaleString();
    }
    el('words').addEventListener('input', convert);
  </script>
</ToolLayout>
