---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Series Resistor Calculator';
const description = 'Series resistor calculator with a live 3D resistor chain and charts. Solve R_total = R1 + R2 + ... and the voltage divider V_i = V × R_i/R_total, with worked examples.';
const intro = 'Add up to four resistors in series to find total resistance, then — if you know the supply voltage — see the current and the voltage drop across each resistor. A live 3D resistor chain and charts show how series resistance and the voltage divider work.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What happens to current in a series circuit?', a: 'The current is exactly the same at every point in a series loop, through every resistor, because there is only one path for charge to flow. If 20 mA flows through the first resistor, 20 mA flows through all of them.' },
  { q: 'What happens to voltage in a series circuit?', a: 'The supply voltage divides across the resistors in proportion to their resistance: V_i = V × R_i / R_total. Larger resistors take a larger share of the voltage, and all the individual drops add up to the total supply voltage.' },
  { q: 'Why does adding a resistor in series always increase total resistance?', a: 'Resistors in series are like extra length added to a single narrow pipe — each one adds its own opposition to the same current path, so R_total = R1 + R2 + ... only ever grows as you add terms. There is no way to combine series resistances to get a smaller value.' },
  { q: 'How is series different from parallel?', a: 'In series, resistances add directly and current is shared equally; in parallel, conductances (1/R) add and voltage is shared equally while current splits. Series total resistance is always larger than the largest individual resistor; parallel total resistance is always smaller than the smallest.' },
  { q: 'How do I find the current once I know R_total?', a: 'Apply Ohm\'s law to the whole chain: I = V / R_total, where V is the supply voltage across the entire series combination. That same current I then flows through every resistor in the chain.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Series Resistor Calculator',
  description: 'Calculate total resistance for resistors in series, plus current and per-resistor voltage drop given a supply voltage.',
  steps: [
    { name: 'Enter resistor values', text: 'Type 2 to 4 resistances in ohms; leave unused rows blank.' },
    { name: 'Optionally enter supply voltage', text: 'Add a supply voltage to see circuit current and each voltage drop.' },
    { name: 'Read the results', text: 'Total resistance solves instantly, and the 3D chain and charts update live.' },
  ],
};

const formulas = [
  { expr: 'R<sub>total</sub> = R₁ + R₂ + R₃ + ...', note: 'series resistances simply add' },
  { expr: 'V<sub>i</sub> = V × R<sub>i</sub> / R<sub>total</sub>', note: 'voltage divider — drop across resistor i' },
  { expr: 'I = V / R<sub>total</sub>', note: "Ohm's law — same current through every resistor" },
];

const workedExamples = [
  {
    title: 'Worked example 1 — three resistors with a 9 V supply', tone: 'slate',
    given: 'R₁ = 100 Ω, R₂ = 220 Ω, R₃ = 330 Ω in series, driven by a 9 V supply. Find R_total, the current, and each voltage drop.',
    rows: [
      { label: 'Total resistance:', value: 'R_total = 100 + 220 + 330 = 650 Ω' },
      { label: 'Current:', value: 'I = 9 ÷ 650 = 0.01385 A ≈ 13.85 mA' },
      { label: 'V₁ (across 100 Ω):', value: 'V₁ = 9 × 100/650 = 1.38 V' },
      { label: 'V₂ (across 220 Ω):', value: 'V₂ = 9 × 220/650 = 3.05 V' },
      { label: 'V₃ (across 330 Ω):', value: 'V₃ = 9 × 330/650 = 4.57 V', full: true },
      { label: 'Check:', value: 'V₁ + V₂ + V₃ = 1.38 + 3.05 + 4.57 = 9.00 V ✓ matches the supply', full: true },
    ],
  },
  {
    title: 'Worked example 2 — four resistors with a 5 V supply', tone: 'amber',
    given: 'R₁ = 47 Ω, R₂ = 100 Ω, R₃ = 150 Ω, R₄ = 220 Ω in series, driven by a 5 V supply. Find R_total, the current, and each voltage drop.',
    rows: [
      { label: 'Total resistance:', value: 'R_total = 47 + 100 + 150 + 220 = 517 Ω' },
      { label: 'Current:', value: 'I = 5 ÷ 517 = 0.00967 A ≈ 9.67 mA' },
      { label: 'V₁:', value: '5 × 47/517 = 0.45 V' },
      { label: 'V₂:', value: '5 × 100/517 = 0.97 V' },
      { label: 'V₃ / V₄:', value: '5 × 150/517 = 1.45 V, 5 × 220/517 = 2.13 V', full: true },
    ],
    note: 'Sum of drops: 0.45 + 0.97 + 1.45 + 2.13 = 5.00 V, matching the 5 V supply.',
  },
];

const comparison = {
  heading: 'Series vs parallel resistor combination',
  note: 'The two basic ways to combine resistors behave oppositely.',
  headers: [{ label: 'Property' }, { label: 'Series' }, { label: 'Parallel' }],
  rows: [
    ['Total resistance formula', 'R_total = R₁ + R₂ + ...', '1/R_total = 1/R₁ + 1/R₂ + ...'],
    ['Current', 'Same through every resistor', 'Same voltage; current splits'],
    ['Voltage', 'Divides across resistors', 'Same across every resistor'],
    ['R_total vs individual R', 'Always larger than the largest R', 'Always smaller than the smallest R'],
    ['Adding another resistor', 'Total resistance increases', 'Total resistance decreases'],
  ],
  highlightIndex: 0,
  footnote: 'Series resistors share one current path; parallel resistors share one voltage across multiple paths.',
};

const realWorld = [
  { emoji: '🎄', title: 'Old-style Christmas lights', body: 'Classic strings wired the bulbs in series, so the same small current ran through every bulb — but if one filament failed, the loop broke and the entire string went dark, which is why modern strings use parallel or shunt-protected wiring instead.' },
  { emoji: '🎚️', title: 'Voltage divider circuits', body: 'Two or more resistors in series tap off a fraction of a supply voltage at their junction — the basis of potentiometers, sensor bias circuits, and level-shifting between different logic voltages.' },
  { emoji: '🛡️', title: 'Current-limiting resistors', body: 'A single resistor placed in series with an LED or other component limits the current to a safe value using I = V/R_total, protecting the component from drawing too much current.' },
];

const misconceptions = [
  { claim: '"Current is different through each resistor in series."', truth: 'False — in a series loop there is only one path for charge, so the current is identical through every resistor and every point in the loop. It is the voltage, not the current, that divides.' },
  { claim: '"Adding more resistors in series decreases total resistance."', truth: 'False — series resistances add directly (R_total = R1 + R2 + ...), so every additional resistor can only increase the total, never decrease it.' },
  { claim: '"The largest resistor gets the smallest voltage drop."', truth: 'False — it is the opposite. The voltage divider V_i = V × R_i/R_total means a larger resistance takes a larger share of the supply voltage, since current is fixed and V = IR grows with R.' },
  { claim: '"Series and parallel formulas are interchangeable."', truth: 'False — series adds resistances directly; parallel adds their reciprocals (conductances). Mixing up the two formulas gives a total resistance that is completely wrong.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — Resistors in Series and Parallel (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/10-3-resistors-in-series-and-parallel" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 27, Circuits: resistors in series.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — DC circuits and Kirchhoff\'s rules.' },
];
const sourcesNote = 'R_total = R1 + R2 + ... for any number of series resistors; voltage divides as V_i = V × R_i/R_total. Results are rounded for display.';

const howToUse = [
  { title: 'Enter resistances', body: 'Fill in 2 to 4 resistor values in ohms; leave extra rows blank.' },
  { title: 'Add a supply voltage (optional)', body: 'Enter a supply voltage to also see current and each voltage drop.' },
  { title: 'See it in the chain', body: 'Use the sliders to watch the 3D resistor chain and R_total update live.' },
];

const related = [
  { href: '/tools/ohms-law-calculator', emoji: '🔋', title: "Ohm's Law Calculator", desc: 'V = IR — solve voltage, current, or resistance.' },
  { href: '/tools/parallel-resistor-calculator', emoji: '🔀', title: 'Parallel Resistor Calculator', desc: '1/R_total = 1/R1 + 1/R2 + ... for parallel resistors.' },
  { href: '/tools/force-calculator', emoji: '💥', title: 'Force Calculator (F=ma)', desc: 'Solve for force, mass, or acceleration.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="resistors in series share one current path, so their resistances simply add, and the supply voltage divides across them in proportion to each resistance."
  howIntro="Once R_total is known, Ohm's law gives the single current flowing through the whole chain: I = V / R_total. That same current, multiplied by each individual resistance, gives the voltage drop across that resistor — the <span class='font-mono'>voltage divider</span> rule V_i = V × R_i / R_total."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where series resistance actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">R₁ (Ω)</span>
        <input id="r1" type="number" step="any" placeholder="ohms" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">R₂ (Ω)</span>
        <input id="r2" type="number" step="any" placeholder="ohms" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">R₃ (Ω) <span class="font-normal text-slate-400">optional</span></span>
        <input id="r3" type="number" step="any" placeholder="ohms" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">R₄ (Ω) <span class="font-normal text-slate-400">optional</span></span>
        <input id="r4" type="number" step="any" placeholder="ohms" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block sm:col-span-2"><span class="text-sm font-medium text-slate-700">Supply voltage V <span class="font-normal text-slate-400">optional — adds current &amp; voltage drops</span></span>
        <input id="vsup" type="number" step="any" placeholder="volts" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Total resistance</div><div id="r-total" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Current (I = V/R_total)</div><div id="r-current" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <div id="drops" class="mt-3 hidden grid gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">V₁</div><div id="v1-out" class="mt-1 font-semibold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">V₂</div><div id="v2-out" class="mt-1 font-semibold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">V₃</div><div id="v3-out" class="mt-1 font-semibold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">V₄</div><div id="v4-out" class="mt-1 font-semibold text-slate-800">—</div></div>
    </div>
    <p id="sr-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Two ideas that make series circuits click</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-chain" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Resistors chained end-to-end</h3>
          <p class="mt-1 text-sm text-slate-600">Three resistor blocks wired in a single loop. The bars above each block show a fixed example voltage-drop split — the larger the resistor, the taller its bar, since a bigger resistance always claims a bigger share of the supply voltage.</p>
        </div>
        <div>
          <div id="diag-growth" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. R_total grows in a straight line</h3>
          <p class="mt-1 text-sm text-slate-600">Each line traces R_total as more equal-sized resistors are added — the more resistors in the chain, the higher the line climbs, always linearly, and a bigger per-resistor value produces a steeper line.</p>
        </div>
      </div>
      <p id="diag-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Series resistance graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">R_total vs R₁ (R₂, R₃ fixed) — a straight line, since series adds linearly</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-rr"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Voltage drop per resistor (voltage divider)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vd"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const RES_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function calcUpdate() {
        el('sr-err').textContent = '';
        el('r-total').textContent = '—';
        el('r-current').textContent = '—';
        el('drops').classList.add('hidden');
        ['v1-out', 'v2-out', 'v3-out', 'v4-out'].forEach((id) => (el(id).textContent = '—'));

        const raw = [el('r1').value, el('r2').value, el('r3').value, el('r4').value];
        const vals = raw.map((v) => (v === '' ? NaN : parseFloat(v)));
        const present = vals.filter((v) => !isNaN(v));
        if (present.length < 2) return;
        if (present.some((v) => v < 0)) { el('sr-err').textContent = 'Resistances cannot be negative.'; return; }

        const rTotal = present.reduce((a, b) => a + b, 0);
        el('r-total').textContent = fmt(rTotal) + ' Ω';

        const vsupRaw = el('vsup').value;
        if (vsupRaw !== '') {
          const V = parseFloat(vsupRaw);
          if (!isNaN(V)) {
            if (rTotal === 0) { el('sr-err').textContent = 'Total resistance cannot be zero.'; return; }
            const I = V / rTotal;
            el('r-current').textContent = fmt(I * 1000) + ' mA';
            el('drops').classList.remove('hidden');
            const ids = ['v1-out', 'v2-out', 'v3-out', 'v4-out'];
            vals.forEach((v, i) => { el(ids[i]).textContent = isNaN(v) ? '—' : fmt(V * v / rTotal) + ' V'; });
          }
        }
      }
      ['r1', 'r2', 'r3', 'r4', 'vsup'].forEach((id) => el(id).addEventListener('input', calcUpdate));

      // ---- charts ----
      const charts = {};
      const FIXED = { r1: 100, r2: 220, r3: 330, rTotal: 650 };

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.rr = new Chart(el('chart-rr'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'R_total', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'R₁ (Ω)' } }, y: { title: { display: true, text: 'R_total (Ω)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.vd = new Chart(el('chart-vd'), {
          type: 'bar',
          data: { labels: ['R₁', 'R₂', 'R₃'], datasets: [{ label: 'Voltage drop (V)', data: [0, 0, 0], backgroundColor: ['#6366f1', '#10b981', '#f59e0b'] }] },
          options: Object.assign({}, base, { scales: { x: {}, y: { title: { display: true, text: 'Voltage (V)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(FIXED);
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L = [], D = [];
        for (let rr = 10; rr <= 500; rr += 10) { L.push(rr.toString()); D.push(+(rr + s.r2 + s.r3).toFixed(2)); }
        charts.rr.data.labels = L; charts.rr.data.datasets[0].data = D; charts.rr.update();

        const V = 9; // fixed reference supply voltage for the divider illustration
        const drops = [s.r1, s.r2, s.r3].map((r) => +(V * r / s.rTotal).toFixed(3));
        charts.vd.data.datasets[0].data = drops; charts.vd.update();
      }

      // ---- static resistor block builder (shared by diagram A) ----
      function resistorBlock(THREE, len, colorHex) {
        const g = new THREE.Group();
        const bodyMat = new THREE.MeshStandardMaterial({ color: colorHex, roughness: 0.5 });
        const leadMat = new THREE.MeshStandardMaterial({ color: 0xcbd5e1, metalness: 0.6, roughness: 0.3 });
        const body = new THREE.Mesh(new THREE.CylinderGeometry(0.55, 0.55, len, 24), bodyMat);
        body.rotation.z = Math.PI / 2;
        g.add(body);
        const leadLen = 0.9;
        const lead1 = new THREE.Mesh(new THREE.CylinderGeometry(0.09, 0.09, leadLen, 12), leadMat);
        lead1.rotation.z = Math.PI / 2; lead1.position.x = -(len / 2 + leadLen / 2); g.add(lead1);
        const lead2 = lead1.clone(); lead2.position.x = len / 2 + leadLen / 2; g.add(lead2);
        g.userData.len = len;
        return g;
      }

      let diagChain = null, diagGrowth = null;

      // ---- Diagram A: static resistor chain with fixed voltage-drop bars ----
      function initDiagChain() {
        const c = el('diag-chain'); if (!c) throw new Error('no diag-chain container');
        const s = makeScene(c, 14, new THREE.Vector3(0, 1, 0), RES_OPTS);
        const grid = new THREE.GridHelper(16, 16, 0xe2e8f0, 0xeef2f7); s.scene.add(grid);
        const colors = [0x6366f1, 0x10b981, 0xf59e0b];
        const rs = [FIXED.r1, FIXED.r2, FIXED.r3];
        const lens = rs.map((r) => 1.2 + (r / 500) * 2.4);
        const drops = rs.map((r) => 9 * r / FIXED.rTotal); // fixed 9V reference, matches chart

        let x = -(lens.reduce((a, b) => a + b, 0) + 1.8 * 2) / 2;
        lens.forEach((len, i) => {
          x += 0.9;
          const blk = resistorBlock(THREE, len, colors[i]);
          blk.position.set(x + len / 2, 0.6, 0);
          s.scene.add(blk);

          // static voltage-drop bar above each block
          const barH = 0.6 + drops[i] * 0.5;
          const bar = new THREE.Mesh(
            new THREE.BoxGeometry(len * 0.5, barH, 0.5),
            new THREE.MeshStandardMaterial({ color: colors[i], roughness: 0.4 })
          );
          bar.position.set(x + len / 2, 1.6 + barH / 2, 0);
          s.scene.add(bar);

          x += len + 0.9;
        });

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagChain = { resize: s.resize };
      }

      // ---- Diagram B: family of R_total growth lines as resistors are added ----
      function initDiagGrowth() {
        const c = el('diag-growth'); if (!c) throw new Error('no diag-growth container');
        const s = makeScene(c, 12, new THREE.Vector3(3, 2, 0), RES_OPTS);
        const grid = new THREE.GridHelper(12, 12, 0xe2e8f0, 0xeef2f7); grid.position.set(3, 0, 0); s.scene.add(grid);

        const perResistor = [50, 100, 150]; // ohms per identical resistor, a few series
        const colors = [0x94a3b8, 0x6366f1, 0xf59e0b];
        const n = 5; // number of resistors 1..5
        const maxTotal = Math.max.apply(null, perResistor) * n;
        const scaleX = 6 / n;
        const scaleY = 8 / maxTotal;

        perResistor.forEach((r, i) => {
          const pts = [];
          for (let k = 1; k <= n; k++) pts.push(new THREE.Vector3(k * scaleX, k * r * scaleY, 0));
          const line = new THREE.Line(
            new THREE.BufferGeometry().setFromPoints(pts),
            new THREE.LineBasicMaterial({ color: colors[i] })
          );
          s.scene.add(line);
        });

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagGrowth = { resize: s.resize };
      }

      function boot() {
        try { calcUpdate(); } catch (e) { console.error('[series-resistor] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[series-resistor] charts failed', e); }
        if (window.THREE) {
          try { initDiagChain(); } catch (e) { console.error('[series-resistor] chain diagram failed', e); el('diag-fallback').classList.remove('hidden'); }
          try { initDiagGrowth(); } catch (e) { console.error('[series-resistor] growth diagram failed', e); el('diag-fallback').classList.remove('hidden'); }
        } else { el('diag-fallback').classList.remove('hidden'); }
        mountResize([diagChain, diagGrowth]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
