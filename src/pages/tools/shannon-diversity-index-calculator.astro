---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Shannon Diversity Index Calculator';
const description = "Shannon diversity index calculator. Solve H' = −Σ(pᵢ ln pᵢ) to measure species diversity in an ecological community, with worked examples and evenness.";
const intro = 'Enter species counts from a community sample to compute the Shannon diversity index (H\'), a standard measure combining species richness and evenness into a single diversity score. Two 3D diagrams compare a low-diversity and high-diversity community, and charts show how evenness and richness each affect the final index.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is the Shannon diversity index?', a: "The Shannon diversity index (H') is a widely used measure of biodiversity that accounts for both how many species are present (richness) and how evenly individuals are distributed among those species (evenness), calculated as H' = −Σ(pᵢ × ln(pᵢ))." },
  { q: 'What values can H\' take?', a: "H' is always zero or positive — a value of 0 means only one species is present (no diversity at all), and higher values indicate greater diversity. There's no fixed maximum; it depends on how many species are present and how evenly they're distributed." },
  { q: 'What is species evenness, and how is it calculated from H\'?', a: "Evenness (E) measures how equally individuals are distributed among species, calculated as E = H'/ln(S), where S is the number of species. E ranges from 0 to 1, with 1 meaning perfectly equal distribution across all species." },
  { q: 'Why is the Shannon index preferred over simply counting species?', a: 'Simply counting species (richness) ignores how individuals are distributed — a community with 100 individuals of one species and 1 of another has the same richness as one with 50 of each, but feels far less "diverse." The Shannon index captures this difference that a raw species count misses.' },
  { q: 'Can two very different communities have the same Shannon index?', a: 'Yes — H\' combines richness and evenness into one number, so a species-poor but perfectly even community can produce a similar H\' value to a species-richer but less even one. This is a known limitation, and ecologists often report richness and evenness separately alongside H\' for full context.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Shannon Diversity Index Calculator',
  description: "Compute the Shannon diversity index (H') and evenness from species counts in a community sample.",
  steps: [
    { name: 'Enter species counts', text: 'Provide the number of individuals observed for each species in your sample.' },
    { name: 'Read H\' and evenness', text: 'The Shannon index and evenness score solve instantly.' },
    { name: 'Interpret the result', text: 'Compare against reference communities to judge relative diversity.' },
  ],
};

const formulas = [
  { expr: "H' = −Σ(pᵢ × ln(pᵢ))", note: 'pᵢ = proportion of individuals belonging to species i' },
  { expr: "E = H' / ln(S)", note: 'evenness — S = total number of species, ranges from 0 to 1' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a community with 3 species', tone: 'slate',
    given: 'A sample contains 40 individuals of species A, 30 of species B, and 30 of species C (100 total).',
    rows: [
      { label: 'Proportions:', value: 'p₁ = 0.4, p₂ = 0.3, p₃ = 0.3' },
      { label: 'Formula:', value: "H' = −(0.4×ln(0.4) + 0.3×ln(0.3) + 0.3×ln(0.3))" },
      { label: 'Substitute:', value: '= −(0.4×(−0.9163) + 0.3×(−1.2040) + 0.3×(−1.2040))' },
      { label: 'Result:', value: "H' ≈ 1.089", full: true },
    ],
    note: "The relatively even distribution (40:30:30) across 3 species produces a fairly high H' close to the theoretical maximum for 3 species (ln(3)≈1.099).",
  },
  {
    title: 'Worked example 2 — computing evenness for the same community', tone: 'amber',
    given: "Using H' ≈ 1.089 from Example 1, with S = 3 species.",
    rows: [
      { label: 'Formula:', value: "E = H' / ln(S)" },
      { label: 'Substitute:', value: 'E = 1.089 / ln(3) = 1.089 / 1.0986' },
      { label: 'Result:', value: 'E ≈ 0.991 — very close to 1 (nearly perfectly even)', full: true },
    ],
    note: 'An evenness this close to 1 confirms the community is very evenly distributed among its 3 species — no single species dominates the sample.',
  },
];

const comparison = {
  heading: "How species distribution affects H' (fixed 3 species, 100 individuals)",
  note: 'The same 3 species and total count can produce very different diversity scores depending on how evenly individuals are distributed.',
  headers: [{ label: 'Distribution' }, { label: "H'" }, { label: 'Evenness' }],
  rows: [
    ['98, 1, 1 (one species dominates)', '0.11', '0.10'],
    ['60, 20, 20', '0.95', '0.87'],
    ['40, 30, 30 ★', '1.09', '0.99'],
    ['34, 33, 33 (near-perfect evenness)', '1.10', '1.00'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked examples 1 & 2). Notice how dramatically H\' and evenness both drop when one species dominates — richness alone (3 species in every row) doesn\'t capture this at all.',
};

const realWorld = [
  { emoji: '🌳', title: 'Forest and habitat biodiversity assessment', body: 'Ecologists use the Shannon index to quantify and compare biodiversity across different habitats, tracking changes over time or evaluating the impact of conservation and restoration efforts.' },
  { emoji: '🌊', title: 'Water quality bioindicator studies', body: 'Aquatic ecologists use diversity indices of indicator species (like macroinvertebrates) to assess water quality — polluted waters typically show low diversity, dominated by a few pollution-tolerant species.' },
  { emoji: '🌾', title: 'Agricultural and land-use impact studies', body: 'Comparing Shannon diversity before and after land-use changes (like converting forest to farmland) helps quantify biodiversity loss and informs sustainable land management policy.' },
  { emoji: '🦠', title: 'Microbiome diversity research', body: 'Microbiologists apply the Shannon index to characterize the diversity of bacterial communities in the gut microbiome, soil samples, or other environments, linking diversity patterns to health and ecosystem function.' },
];

const misconceptions = [
  { claim: '"Counting the number of species present is enough to measure diversity."', truth: "Simple species counts (richness) ignore how evenly individuals are distributed — a community dominated by one species with a few rare others feels much less diverse than one with the same species count evenly distributed, and only H' (not richness alone) captures that difference." },
  { claim: '"A higher Shannon index always means a healthier ecosystem."', truth: 'While diversity is often associated with ecosystem health and resilience, H\' alone doesn\'t capture every aspect of ecosystem function — some naturally low-diversity ecosystems (like certain extreme environments) are perfectly healthy and stable for their context.' },
  { claim: '"H\' has a fixed maximum value of 1, like a percentage."', truth: "H' has no fixed universal maximum — its ceiling depends on how many species are present (the theoretical maximum for S species is ln(S)). It's evenness (E), not H' itself, that is bounded between 0 and 1." },
  { claim: '"Two communities with the same H\' value must have identical species distributions."', truth: 'Very different species distributions and even different numbers of species can produce similar H\' values — this is a known limitation of the index, which is why ecologists often report richness and evenness separately for full context.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 19, "Population and Community Ecology" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/19-3-community-ecology" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Shannon, C.E. (1948)</strong> — "A Mathematical Theory of Communication," <em>Bell System Technical Journal</em> (original information-theory source of the formula).' },
  { html: '<strong>Molles, <em>Ecology: Concepts and Applications</em></strong> — Chapter 17, Species Abundance and Diversity.' },
];
const sourcesNote = "H' = −Σ(pᵢ ln pᵢ); E = H'/ln(S). Originally derived from information theory (Shannon 1948), widely adapted for ecological diversity measurement. Results are rounded for display.";

const howToUse = [
  { title: 'Enter species counts', body: 'Provide the individual count for each species observed in your sample (up to several species).' },
  { title: "Read H' and evenness", body: 'Both the Shannon index and evenness score solve instantly.' },
  { title: 'Compare to reference communities', body: 'Use the comparison table to judge whether your community shows high or low relative diversity.' },
];

const related = [
  { href: '/tools/population-density-calculator', emoji: '🌍', title: 'Population Density Calculator', desc: 'D = N/A — individuals per unit area.' },
  { href: '/tools/mark-recapture-calculator', emoji: '🐟', title: 'Mark-Recapture Population Estimator', desc: 'Estimate total population size from marked/recaptured counts.' },
  { href: '/tools/logistic-growth-calculator', emoji: '📉', title: 'Logistic Growth / Carrying Capacity Calculator', desc: 'N(t) with a carrying capacity — a more realistic model.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="the Shannon index measures how unpredictable a randomly picked individual's species identity is — a community where one species dominates is very predictable (low diversity), while one where species are evenly and richly represented is highly unpredictable (high diversity)."
  howIntro="Borrowed directly from Claude Shannon's information theory, the formula H'=−Σ(pᵢ ln pᵢ) treats each species' proportion pᵢ as a probability, and −ln(pᵢ) as the 'surprise' of encountering that species — rare species carry more surprise, common ones less. Weighting each species' surprise by its own proportion and summing across all species produces a single number that rewards both having many species (richness) and having them represented in balanced proportions (evenness), which is exactly why two communities with the same species count can still have very different H' values."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the Shannon diversity index actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Enter the count of individuals for each species (up to 4 species, leave unused fields blank).</p>
    <div class="grid gap-3 sm:grid-cols-4">
      <div><label class="block text-xs font-medium text-slate-700">Species 1</label><input id="s1" type="number" value="40" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Species 2</label><input id="s2" type="number" value="30" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Species 3</label><input id="s3" type="number" value="30" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Species 4 (optional)</label><input id="s4" type="number" value="" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Shannon index (H')</div><div id="r-h" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Evenness (E)</div><div id="r-e" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="sh-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Low vs high diversity communities</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-low" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low diversity (one species dominates)</h3>
          <p class="mt-1 text-sm text-slate-600">Mostly one color (species) with only a few individuals of others — low H'.</p>
        </div>
        <div>
          <div id="diag-high" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High diversity (evenly distributed)</h3>
          <p class="mt-1 text-sm text-slate-600">Multiple species (colors) represented in roughly equal numbers — high H'.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Shannon diversity graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">H' across different distribution evenness (3 species)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-h"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Species proportions in this example</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-props"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      const charts = {};
      function update() {
        el('sh-err').textContent = '';
        el('r-h').textContent = '—'; el('r-e').textContent = '—';
        const counts = ['s1', 's2', 's3', 's4'].map((id) => parseFloat(el(id).value)).filter((v) => !isNaN(v) && v > 0);
        if (counts.length < 2) { el('sh-err').textContent = 'Enter at least 2 species with counts greater than 0.'; return; }
        const total = counts.reduce((a, b) => a + b, 0);
        const props = counts.map((c) => c / total);
        const H = -props.reduce((sum, p) => sum + p * Math.log(p), 0);
        const S = counts.length;
        const E = H / Math.log(S);
        el('r-h').textContent = fmt(H);
        el('r-e').textContent = fmt(E);
        if (charts.props) {
          charts.props.data.labels = counts.map((_, i) => 'Species ' + (i + 1));
          charts.props.data.datasets[0].data = props.map((p) => +(p * 100).toFixed(1));
          charts.props.update();
        }
      }
      ['s1', 's2', 's3', 's4'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const scenarios = [
          { l: '98:1:1', d: [98, 1, 1] },
          { l: '60:20:20', d: [60, 20, 20] },
          { l: '40:30:30', d: [40, 30, 30] },
          { l: '34:33:33', d: [34, 33, 33] },
        ];
        const hVals = scenarios.map((s) => { const t = s.d.reduce((a, b) => a + b, 0); const p = s.d.map((c) => c / t); return -p.reduce((sum, pi) => sum + pi * Math.log(pi), 0); });
        charts.h = new Chart(el('chart-h'), {
          type: 'bar',
          data: { labels: scenarios.map((s) => s.l), datasets: [{ label: "H'", data: hVals.map((v) => +v.toFixed(3)), backgroundColor: ['#94a3b8', '#f59e0b', '#6366f1', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: "H'" } } }, plugins: { legend: { display: false } } }),
        });
        charts.props = new Chart(el('chart-props'), {
          type: 'pie',
          data: { labels: ['Species 1', 'Species 2', 'Species 3'], datasets: [{ data: [40, 30, 30], backgroundColor: ['#6366f1', '#f59e0b', '#10b981'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function communityScene(container, distribution) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const colors = [0x6366f1, 0xf59e0b, 0x10b981, 0xef4444];
        let idx = 0;
        distribution.forEach((count, speciesIdx) => {
          for (let i = 0; i < count; i++) {
            const phi = Math.acos(1 - (2 * (idx + 0.5)) / 30);
            const theta = Math.PI * (1 + Math.sqrt(5)) * idx;
            const r = 2.2;
            const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
            const sph = new THREE.Mesh(new THREE.SphereGeometry(0.22, 10, 8), new THREE.MeshStandardMaterial({ color: colors[speciesIdx] }));
            sph.position.set(x, y, z);
            s.scene.add(sph);
            idx++;
          }
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() { const c = el('diag-low'); if (!c) throw new Error('no container'); diagLow = communityScene(c, [26, 2, 2]); }
      function initDiagHigh() { const c = el('diag-high'); if (!c) throw new Error('no container'); diagHigh = communityScene(c, [10, 10, 10]); }

      function boot() {
        try { initCharts(); } catch (e) { console.error('[shannon-diversity] charts failed', e); }
        try { update(); } catch (e) { console.error('[shannon-diversity] calc init failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[shannon-diversity] low diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[shannon-diversity] high diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
