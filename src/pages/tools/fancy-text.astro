---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Fancy Text Generator';
const description =
  'Free fancy text generator. Turn normal text into stylish fonts — bold, italic, ' +
  'cursive, bubble, squared and more — to copy and paste into Instagram, TikTok and bios.';
const intro =
  'Type your text and instantly get dozens of stylish font variations. Tap “Copy” on any style to paste it into your bio, post or username.';
const category = { id: 'creators', name: 'Creators' };
const faqs = [
  { q: 'How does this work without installing fonts?', a: 'These styles use special Unicode characters that look like fancy fonts. Because they’re real characters, they work in most apps and websites without any font install.' },
  { q: 'Where can I paste fancy text?', a: 'Instagram and TikTok bios, usernames, captions, comments, WhatsApp, Discord and most social apps. A few apps may not support every style.' },
  { q: 'Will every style show on every device?', a: 'Most do, but some rarer styles may appear as plain boxes on older devices. If a style doesn’t look right, pick another.' },
  { q: 'Is my text private?', a: 'Yes. The generator runs in your browser — nothing is uploaded.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea
      id="input"
      rows="3"
      placeholder="Type your text here…"
      class="w-full resize-y rounded-xl border border-slate-300 p-4 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    >ToolNestr</textarea>
    <div id="styles" class="mt-4 space-y-2"></div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this fancy text generator</h2>
    <p class="mt-2 text-slate-600">
      Want your social media bio or username to stand out? This generator converts your text into
      eye-catching styles — bold, italic, cursive, bubble letters, squared letters and more. They
      use special Unicode characters, so you can copy and paste them almost anywhere without
      installing fonts. Perfect for Instagram, TikTok, X, Discord and WhatsApp.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Type or paste your text in the box.</li>
      <li>Browse the styled versions that appear below.</li>
      <li>Tap “Copy” next to the style you like.</li>
      <li>Paste it into your bio, caption or username.</li>
    </ol>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/case-converter" class="font-medium text-indigo-600 hover:underline">Case Converter</a>
      or <a href="/" class="font-medium text-indigo-600 hover:underline">browse all tools →</a>
    </p>
  </Fragment>

  <script is:inline>
    const input = document.getElementById('input');
    const container = document.getElementById('styles');

    // Map a string using contiguous Unicode ranges (safe, no gaps).
    function offset(str, upper, lower, digit) {
      return [...str].map((ch) => {
        const c = ch.codePointAt(0);
        if (c >= 65 && c <= 90) return String.fromCodePoint(upper + (c - 65));
        if (c >= 97 && c <= 122) return String.fromCodePoint(lower + (c - 97));
        if (digit && c >= 48 && c <= 57) return String.fromCodePoint(digit + (c - 48));
        return ch;
      }).join('');
    }

    // Circled letters/numbers
    function circled(str) {
      return [...str].map((ch) => {
        const c = ch.codePointAt(0);
        if (c >= 65 && c <= 90) return String.fromCodePoint(0x24b6 + (c - 65));
        if (c >= 97 && c <= 122) return String.fromCodePoint(0x24d0 + (c - 97));
        if (c === 48) return '⓪';
        if (c >= 49 && c <= 57) return String.fromCodePoint(0x2460 + (c - 49));
        return ch;
      }).join('');
    }

    // Squared letters (uppercase glyphs for both cases)
    function squared(str) {
      return [...str].map((ch) => {
        const c = ch.toUpperCase().codePointAt(0);
        if (c >= 65 && c <= 90) return String.fromCodePoint(0x1f130 + (c - 65));
        return ch;
      }).join('');
    }

    const smallCaps = { a:'ᴀ',b:'ʙ',c:'ᴄ',d:'ᴅ',e:'ᴇ',f:'ꜰ',g:'ɢ',h:'ʜ',i:'ɪ',j:'ᴊ',k:'ᴋ',l:'ʟ',m:'ᴍ',n:'ɴ',o:'ᴏ',p:'ᴘ',q:'q',r:'ʀ',s:'ꜱ',t:'ᴛ',u:'ᴜ',v:'ᴠ',w:'ᴡ',x:'x',y:'ʏ',z:'ᴢ' };
    const upsideMap = { a:'ɐ',b:'q',c:'ɔ',d:'p',e:'ǝ',f:'ɟ',g:'ƃ',h:'ɥ',i:'ᴉ',j:'ɾ',k:'ʞ',l:'l',m:'ɯ',n:'u',o:'o',p:'d',q:'b',r:'ɹ',s:'s',t:'ʇ',u:'n',v:'ʌ',w:'ʍ',x:'x',y:'ʎ',z:'z','.':'˙',',':'\'','?':'¿','!':'¡' };

    function mapWith(str, m) {
      return [...str].map((ch) => m[ch.toLowerCase()] || ch).join('');
    }
    function upsideDown(str) {
      return [...mapWith(str, upsideMap)].reverse().join('');
    }
    function combine(str, mark) {
      return [...str].map((ch) => ch + mark).join('');
    }

    const styles = [
      { name: 'Bold', fn: (s) => offset(s, 0x1d400, 0x1d41a, 0x1d7ce) },
      { name: 'Italic', fn: (s) => offset(s, 0x1d434, 0x1d44e) },
      { name: 'Bold Italic', fn: (s) => offset(s, 0x1d468, 0x1d482) },
      { name: 'Sans Bold', fn: (s) => offset(s, 0x1d5d4, 0x1d5ee, 0x1d7ec) },
      { name: 'Monospace', fn: (s) => offset(s, 0x1d670, 0x1d68a, 0x1d7f6) },
      { name: 'Double-struck', fn: (s) => offset(s, 0x1d538, 0x1d552, 0x1d7d8) },
      { name: 'Fullwidth', fn: (s) => offset(s, 0xff21, 0xff41, 0xff10) },
      { name: 'Circled', fn: circled },
      { name: 'Squared', fn: squared },
      { name: 'Small Caps', fn: (s) => mapWith(s, smallCaps) },
      { name: 'Strikethrough', fn: (s) => combine(s, '̶') },
      { name: 'Underline', fn: (s) => combine(s, '̲') },
      { name: 'Upside down', fn: upsideDown },
    ];

    function render() {
      const text = input.value || '';
      container.innerHTML = '';
      styles.forEach((style) => {
        const out = text ? style.fn(text) : '';
        const row = document.createElement('div');
        row.className = 'flex items-center gap-3 rounded-xl border border-slate-200 bg-white p-3';
        row.innerHTML =
          `<div class="min-w-0 flex-1"><div class="text-[11px] font-medium uppercase tracking-wide text-slate-400">${style.name}</div>` +
          `<div class="truncate text-lg text-slate-800">${out || '&nbsp;'}</div></div>` +
          `<button class="copy shrink-0 rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white transition hover:bg-indigo-700">Copy</button>`;
        const btn = row.querySelector('.copy');
        btn.addEventListener('click', async () => {
          if (!out) return;
          try {
            await navigator.clipboard.writeText(out);
            btn.textContent = 'Copied!';
            setTimeout(() => (btn.textContent = 'Copy'), 1200);
          } catch (e) {}
        });
        container.appendChild(row);
      });
    }

    input.addEventListener('input', render);
    render();
  </script>
</ToolLayout>
