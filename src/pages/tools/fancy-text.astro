---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Fancy Text Generator';
const description =
  'Free fancy text generator. Turn normal text into stylish fonts — bold, italic, ' +
  'cursive, bubble, squared and more — to copy and paste into Instagram, TikTok and bios.';
const intro =
  'Type your text and instantly get dozens of stylish font variations. Tap "Copy" on any style to paste it into your bio, post or username.';
const category = { id: 'creators', name: 'Creators' };
const faqs = [
  { q: 'How does this work without installing fonts?', a: 'These styles use special Unicode characters that look like fancy fonts. Because they\'re real characters, they work in most apps and websites without any font install.' },
  { q: 'Where can I paste fancy text?', a: 'Instagram and TikTok bios, usernames, captions, comments, WhatsApp, Discord and most social apps. A few apps may not support every style.' },
  { q: 'Will every style show on every device?', a: 'Most do, but some rarer styles may appear as plain boxes on older devices. If a style doesn\'t look right, pick another.' },
  { q: 'Is my text private?', a: 'Yes. The generator runs in your browser — nothing is uploaded.' },
  { q: 'How many styles are available?', a: 'The generator offers 13 different styles including bold, italic, cursive, circled, squared, monospace, small caps, strikethrough, and more.' },
  { q: 'Can I use fancy text in usernames?', a: 'Many platforms allow Unicode characters in usernames, but some restrict them. Test the style in your target platform\'s username field before committing.' },
  { q: 'Why does my text look different on someone else\'s phone?', a: 'Unicode font rendering varies by operating system and app. The most common styles (bold, italic, monospace) have the widest cross-platform support.' },
  { q: 'Do all 13 styles support numbers?', a: 'Most do, but styles like Italic and Bold Italic don\'t include number mappings in Unicode, so digits may appear as plain characters.' },
  { q: 'Can I combine multiple styles at once?', a: 'The tool shows each style separately. To combine effects, you\'d need to stack Unicode transforms manually, which may produce unpredictable results.' },
  { q: 'Is there a character limit?', a: 'No hard limit, but very long text may be tedious to scroll through 13 styles. The tool handles any length your browser can render.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea
      id="input"
      rows="3"
      placeholder="Type your text here…"
      class="w-full resize-y rounded-xl border border-slate-300 p-4 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    >ToolNestr</textarea>
    <div id="styles" class="mt-4 space-y-2"></div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fancy text generation works</h2>
    <p class="mt-2 text-slate-600">Fancy text generation maps each standard ASCII character to a corresponding character in a Unicode mathematical alphanumeric block. These blocks include bold, italic, script, monospace, and double-struck variants of the Latin alphabet.</p>
    <p class="mt-3 text-slate-600">Since these are real Unicode characters rather than font styles, they render on any device without installing special fonts — the characters are part of the Unicode standard. Each style uses a different Unicode range, giving each variant a unique visual appearance.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Transforming "Hello" into different fancy styles.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Bold script:</span> <span class="text-slate-600">𝓗𝓮𝓵𝓵𝓸</span></div>
        <div><span class="font-medium text-slate-700">Monospace:</span> <span class="text-slate-600">𝙷𝚎𝚕𝚕𝚘</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this fancy text generator</h2>
    <p class="mt-2 text-slate-600">
      Want your social media bio or username to stand out? This generator converts your text into
      eye-catching styles — bold, italic, cursive, bubble letters, squared letters and more. They
      use special Unicode characters, so you can copy and paste them almost anywhere without
      installing fonts. Perfect for Instagram, TikTok, X, Discord and WhatsApp.
      Pair it with the <a href="/tools/emoji-picker" class="font-medium text-indigo-600 hover:underline">Emoji Picker</a>
      to add decorative symbols, or the <a href="/tools/hashtag-generator" class="font-medium text-indigo-600 hover:underline">Hashtag Generator</a>
      to complete your social media post.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Type or paste your text in the box.</li>
      <li>Browse the styled versions that appear below.</li>
      <li>Tap "Copy" next to the style you like.</li>
      <li>Paste it into your bio, caption or username.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Fancy text helps your social media presence stand out in a crowded feed. Use it to create a distinctive Instagram bio that reflects your personality, write eye-catching TikTok captions that stop the scroll, or design a unique Discord username that your friends will recognise instantly. Content creators use styled text for video thumbnails, channel descriptions, and pinned comments. Even in everyday messaging, a bold or cursive word adds emphasis and flair to your texts.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different font styles mean</h2>
    <p class="mt-2 text-slate-600">Each style uses a different Unicode block. Here is how they compare in terms of readability, device support, and best use.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Monospace</span><span class="text-slate-400">Excellent device support, best for code-like text</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Bold / Sans Bold</span><span class="text-slate-400">Great readability, wide support across platforms</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:95%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Italic / Bold Italic</span><span class="text-slate-400">Good readability, slightly narrower support</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:85%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Circled / Squared</span><span class="text-slate-400">Moderate support, best for short text or symbols</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:70%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Small Caps</span><span class="text-slate-400">Limited glyph coverage, lowercase only transform</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-400" style="width:55%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Upside Down</span><span class="text-slate-400">Novelty style with inconsistent character mapping</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-400" style="width:40%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f469;&#x200d;&#x1f4bb;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Social Media Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Creates distinctive branded bios and captions for clients. Uses fancy text to make posts stop the scroll and reinforce brand personality.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f3a4;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Creator</h3>
      <p class="mt-1 text-sm text-slate-600">Styles video titles, channel descriptions, and pinned comments to build a recognisable visual identity across platforms.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f3ae;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Gamer & Streamer</h3>
      <p class="mt-1 text-sm text-slate-600">Decorates usernames, Twitch panels, and Discord profiles with unique styled text to stand out in crowded gaming communities.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4d6;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Student & Casual User</h3>
      <p class="mt-1 text-sm text-slate-600">Adds flair to school project titles, personal social bios, chat messages, and event invitations with just a few clicks.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Style</th><th class="p-3">Unicode Block</th><th class="p-3">Best For</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Bold</td><td class="p-3">Mathematical Alphanumerics</td><td class="p-3">Headings, emphasis in bios</td></tr>
        <tr><td class="p-3 font-medium">Italic</td><td class="p-3">Mathematical Alphanumerics</td><td class="p-3">Stylised captions, quotes</td></tr>
        <tr><td class="p-3 font-medium">Monospace</td><td class="p-3">Mathematical Alphanumerics</td><td class="p-3">Code snippets, usernames</td></tr>
        <tr><td class="p-3 font-medium">Circled</td><td class="p-3">Enclosed Alphanumerics</td><td class="p-3">Decorative lists, bullet points</td></tr>
        <tr><td class="p-3 font-medium">Squared</td><td class="p-3">Enclosed Alphanumeric Supplement</td><td class="p-3">Button-like text, labels</td></tr>
        <tr><td class="p-3 font-medium">Fullwidth</td><td class="p-3">CJK Compatibility</td><td class="p-3">Monospaced aesthetic, East-Asian layouts</td></tr>
        <tr><td class="p-3 font-medium">Strikethrough</td><td class="p-3">Combining Diacritical Marks</td><td class="p-3">Humorous edits, crossed-out text</td></tr>
        <tr><td class="p-3 font-medium">Upside Down</td><td class="p-3">Custom mapping + reversals</td><td class="p-3">Novelty messages, puzzles</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the fancy text generator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your text</h3>
        <p class="mt-1 text-sm text-slate-600">Type or paste any word, sentence or phrase into the input box above.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Browse the styles</h3>
        <p class="mt-1 text-sm text-slate-600">Scroll through 13 font variations generated instantly as you type.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Copy and paste</h3>
        <p class="mt-1 text-sm text-slate-600">Click the Copy button on your favourite style and paste it anywhere.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for using fancy text</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Prioritise readability</h3>
        <p class="mt-1 text-sm text-slate-600">Fancy styles can be harder to read in long passages. Use them for short highlights — bios, headlines, display names — and keep body text in a normal font.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Test on your target platform</h3>
        <p class="mt-1 text-sm text-slate-600">Not every app renders every Unicode glyph. Before using a style in a permanent place like a username, check it renders correctly on that platform first.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Mix with emojis and hashtags</h3>
        <p class="mt-1 text-sm text-slate-600">Combine styled text with emojis from the Emoji Picker and relevant hashtags from the Hashtag Generator for a complete, eye-catching social media post.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const input = document.getElementById('input');
    const container = document.getElementById('styles');

    // Map a string using contiguous Unicode ranges (safe, no gaps).
    function offset(str, upper, lower, digit) {
      return [...str].map((ch) => {
        const c = ch.codePointAt(0);
        if (c >= 65 && c <= 90) return String.fromCodePoint(upper + (c - 65));
        if (c >= 97 && c <= 122) return String.fromCodePoint(lower + (c - 97));
        if (digit && c >= 48 && c <= 57) return String.fromCodePoint(digit + (c - 48));
        return ch;
      }).join('');
    }

    // Circled letters/numbers
    function circled(str) {
      return [...str].map((ch) => {
        const c = ch.codePointAt(0);
        if (c >= 65 && c <= 90) return String.fromCodePoint(0x24b6 + (c - 65));
        if (c >= 97 && c <= 122) return String.fromCodePoint(0x24d0 + (c - 97));
        if (c === 48) return '⓪';
        if (c >= 49 && c <= 57) return String.fromCodePoint(0x2460 + (c - 49));
        return ch;
      }).join('');
    }

    // Squared letters (uppercase glyphs for both cases)
    function squared(str) {
      return [...str].map((ch) => {
        const c = ch.toUpperCase().codePointAt(0);
        if (c >= 65 && c <= 90) return String.fromCodePoint(0x1f130 + (c - 65));
        return ch;
      }).join('');
    }

    const smallCaps = { a:'ᴀ',b:'ʙ',c:'ᴄ',d:'ᴅ',e:'ᴇ',f:'ꜰ',g:'ɢ',h:'ʜ',i:'ɪ',j:'ᴊ',k:'ᴋ',l:'ʟ',m:'ᴍ',n:'ɴ',o:'ᴏ',p:'ᴘ',q:'q',r:'ʀ',s:'ꜱ',t:'ᴛ',u:'ᴜ',v:'ᴠ',w:'ᴡ',x:'x',y:'ʏ',z:'ᴢ' };
    const upsideMap = { a:'ɐ',b:'q',c:'ɔ',d:'p',e:'ǝ',f:'ɟ',g:'ƃ',h:'ɥ',i:'ᴉ',j:'ɾ',k:'ʞ',l:'l',m:'ɯ',n:'u',o:'o',p:'d',q:'b',r:'ɹ',s:'s',t:'ʇ',u:'n',v:'ʌ',w:'ʍ',x:'x',y:'ʎ',z:'z','.':'˙',',':'\'','?':'¿','!':'¡' };

    function mapWith(str, m) {
      return [...str].map((ch) => m[ch.toLowerCase()] || ch).join('');
    }
    function upsideDown(str) {
      return [...mapWith(str, upsideMap)].reverse().join('');
    }
    function combine(str, mark) {
      return [...str].map((ch) => ch + mark).join('');
    }

    const styles = [
      { name: 'Bold', fn: (s) => offset(s, 0x1d400, 0x1d41a, 0x1d7ce) },
      { name: 'Italic', fn: (s) => offset(s, 0x1d434, 0x1d44e) },
      { name: 'Bold Italic', fn: (s) => offset(s, 0x1d468, 0x1d482) },
      { name: 'Sans Bold', fn: (s) => offset(s, 0x1d5d4, 0x1d5ee, 0x1d7ec) },
      { name: 'Monospace', fn: (s) => offset(s, 0x1d670, 0x1d68a, 0x1d7f6) },
      { name: 'Double-struck', fn: (s) => offset(s, 0x1d538, 0x1d552, 0x1d7d8) },
      { name: 'Fullwidth', fn: (s) => offset(s, 0xff21, 0xff41, 0xff10) },
      { name: 'Circled', fn: circled },
      { name: 'Squared', fn: squared },
      { name: 'Small Caps', fn: (s) => mapWith(s, smallCaps) },
      { name: 'Strikethrough', fn: (s) => combine(s, '̶') },
      { name: 'Underline', fn: (s) => combine(s, '̲') },
      { name: 'Upside down', fn: upsideDown },
    ];

    function render() {
      const text = input.value || '';
      container.innerHTML = '';
      styles.forEach((style) => {
        const out = text ? style.fn(text) : '';
        const row = document.createElement('div');
        row.className = 'flex items-center gap-3 rounded-xl border border-slate-200 bg-white p-3';
        row.innerHTML =
          `<div class="min-w-0 flex-1"><div class="text-[11px] font-medium uppercase tracking-wide text-slate-400">${style.name}</div>` +
          `<div class="truncate text-lg text-slate-800">${out || '&nbsp;'}</div></div>` +
          `<button class="copy shrink-0 rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white transition hover:bg-indigo-700">Copy</button>`;
        const btn = row.querySelector('.copy');
        btn.addEventListener('click', async () => {
          if (!out) return;
          try {
            await navigator.clipboard.writeText(out);
            btn.textContent = 'Copied!';
            setTimeout(() => (btn.textContent = 'Copy'), 1200);
          } catch (e) {}
        });
        container.appendChild(row);
      });
    }

    input.addEventListener('input', render);
    render();
  </script>
</ToolLayout>
