---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Microscope Magnification Calculator';
const description = "Microscope magnification calculator. Solve total magnification (eyepiece x objective), field of view at any power, and actual specimen size.";
const intro = 'Solve total magnification = eyepiece × objective, then use the field-of-view-at-low-power to calculate field of view at any higher magnification, and finally estimate a specimen\'s actual size from how much of that field it occupies. Two 3D diagrams compare low-power (wide field, small magnification) to high-power (narrow field, large magnification) viewing, and charts show how field of view shrinks as magnification increases.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'How is total magnification calculated?', a: 'Total magnification equals the eyepiece (ocular) lens magnification multiplied by the objective lens magnification. A 10x eyepiece with a 40x objective gives 10 × 40 = 400x total magnification.' },
  { q: 'What is field of view?', a: 'Field of view (FOV) is the diameter of the circular area visible when looking through the microscope. It shrinks as magnification increases — you see a smaller area of the specimen, but in much greater detail.' },
  { q: 'How do I find the field of view at a higher magnification?', a: 'If you know the field of view at one magnification, the field of view at a different magnification scales inversely: FOV₂ = FOV₁ × (magnification₁ / magnification₂). Doubling the magnification halves the field of view.' },
  { q: 'How do I estimate a specimen\'s actual size using field of view?', a: "Estimate what fraction of the visible field the specimen spans (e.g., it takes up about 1/5 of the field's diameter), then multiply that fraction by the known field-of-view diameter at that magnification to get the specimen's approximate actual size." },
  { q: 'Why does the low-power objective have a wider field of view?', a: 'Lower magnification objectives are designed with a wider angle of view, capturing more of the specimen at once at lower detail — this is exactly why microscopists start scanning a slide at low power before switching to high power to examine a specific area closely.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Microscope Magnification Calculator',
  description: 'Solve total magnification, field of view at any power, and estimated specimen size.',
  steps: [
    { name: 'Enter eyepiece and objective magnification', text: 'Total magnification is calculated automatically.' },
    { name: 'Enter a known field of view', text: 'Provide the field-of-view diameter at one magnification (often measured directly with a stage micrometer at low power).' },
    { name: 'Estimate specimen size', text: 'Enter what fraction of the field of view the specimen spans to estimate its actual size.' },
  ],
};

const formulas = [
  { expr: 'Total magnification = eyepiece × objective', note: 'e.g., 10x eyepiece × 40x objective = 400x' },
  { expr: 'FOV₂ = FOV₁ × (mag₁ / mag₂)', note: 'field of view at a new magnification, scaled from a known field of view' },
  { expr: 'Specimen size ≈ field fraction × FOV diameter', note: 'estimate actual specimen size from how much of the field it fills' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — total magnification', tone: 'slate',
    given: 'A microscope has a 10x eyepiece and is switched to its 40x objective lens.',
    rows: [
      { label: 'Formula:', value: 'Total magnification = eyepiece × objective' },
      { label: 'Substitute:', value: 'Total magnification = 10 × 40' },
      { label: 'Result:', value: 'Total magnification = 400x', full: true },
    ],
    note: 'This is the single most common calculation in any microscopy lab — always reported alongside any measurement or image taken.',
  },
  {
    title: 'Worked example 2 — field of view and specimen size', tone: 'amber',
    given: 'At 40x total magnification (scanning power), the field of view measures 4.5 mm. Switching to 400x total magnification, a specimen spans about 1/5 of the new field of view.',
    rows: [
      { label: 'FOV at 400x:', value: 'FOV₂ = 4.5 × (40/400) = 0.45 mm = 450 µm' },
      { label: 'Specimen size:', value: 'Specimen size ≈ (1/5) × 450 µm' },
      { label: 'Result:', value: 'Specimen size ≈ 90 µm — a plausible size for a typical animal cell', full: true },
    ],
    note: 'This exact technique — measuring field of view at low power, then estimating specimen size as a fraction of the field at high power — is a standard method for quick size estimates without a calibrated eyepiece micrometer.',
  },
];

const comparison = {
  heading: 'How field of view shrinks as magnification increases',
  note: 'Starting from a 4.5 mm field of view at 40x total magnification.',
  headers: [{ label: 'Total magnification' }, { label: 'Field of view' }],
  rows: [
    ['40x (scanning) ★', '4.5 mm'],
    ['100x (low power)', '1.8 mm'],
    ['400x (high power)', '0.45 mm (450 µm)'],
    ['1000x (oil immersion)', '0.18 mm (180 µm)'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 2). Field of view and magnification are always inversely proportional — this table shows exactly why microscopists start at low power to locate a specimen before zooming in.',
};

const realWorld = [
  { emoji: '🔬', title: 'Clinical and diagnostic microscopy', body: 'Pathologists and lab technicians routinely calculate total magnification and field of view when documenting cell counts, tissue structures, or microorganisms in diagnostic samples.' },
  { emoji: '🧫', title: 'Microbiology and cell counting', body: 'Estimating cell or organism size directly from field-of-view calculations is a standard, fast technique when a calibrated stage micrometer isn\'t immediately available.' },
  { emoji: '🎓', title: 'Biology education and lab courses', body: "Students learn to navigate from low to high magnification specifically because of the field-of-view tradeoff — losing track of this relationship is one of the most common early mistakes in a microscopy lab." },
  { emoji: '🔍', title: 'Microscope and camera system design', body: 'Manufacturers specify field-of-view and magnification relationships precisely so that digital microscope cameras and image-analysis software can convert pixel measurements into real physical units.' },
];

const misconceptions = [
  { claim: '"Only the objective lens magnification matters — the eyepiece is just for viewing."', truth: 'The eyepiece contributes its own magnification too, and total magnification is always the product of both — a 40x objective viewed through a 15x eyepiece gives 600x, not 40x.' },
  { claim: '"Field of view stays the same no matter which objective you use."', truth: 'Field of view shrinks substantially as magnification increases, following an inverse relationship — this is precisely why you see far less of the slide (but in much greater detail) at high power than at low power.' },
  { claim: '"Higher magnification always means a clearer, more useful image."', truth: 'Magnification alone doesn\'t guarantee resolution — beyond a lens\'s resolving power, further magnification just enlarges a blurry image ("empty magnification") without revealing any new detail.' },
  { claim: '"You can accurately measure a specimen\'s size just by eyeballing it against the whole field of view."', truth: "A rough field-fraction estimate is useful for a quick approximation, but precise size measurement requires a calibrated eyepiece micrometer or stage micrometer — visual estimation alone carries meaningful error." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 4, "Cell Structure" (free, peer-reviewed, includes microscopy fundamentals). <a href="https://openstax.org/books/biology-2e/pages/4-1-studying-cells" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Looking at cells and molecules with a microscope, Panel 9-1.' },
  { html: '<strong>Nikon MicroscopyU</strong> — standard reference for field-of-view and magnification relationships.' },
];
const sourcesNote = 'Total magnification = eyepiece × objective. FOV₂ = FOV₁ × (mag₁/mag₂). Results are rounded for display.';

const howToUse = [
  { title: 'Enter eyepiece and objective', body: 'Total magnification calculates automatically as their product.' },
  { title: 'Enter a known field of view', body: 'Provide FOV diameter and its matching total magnification (often measured at low power).' },
  { title: 'Estimate specimen size', body: 'Enter the fraction of the new field of view the specimen occupies.' },
];

const related = [
  { href: '/tools/surface-area-volume-ratio-calculator', emoji: '📦', title: 'Surface Area-to-Volume Ratio Calculator', desc: 'SA:V = 6/s — how cell size limits diffusion.' },
  { href: '/tools/dna-concentration-calculator', emoji: '🧬', title: 'DNA Concentration (A260) Calculator', desc: 'Nucleic acid concentration from absorbance.' },
  { href: '/tools/exponential-population-growth-calculator', emoji: '📈', title: 'Exponential Population Growth Calculator', desc: 'N(t) = N₀e^(rt) — unconstrained population growth.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="every lens in the optical path multiplies the image further, and the tradeoff for that extra size is always a narrower window onto the specimen — magnification and field of view move in exactly opposite directions."
  howIntro="A compound microscope magnifies a specimen twice — once through the objective lens near the specimen, and again through the eyepiece you look through — so the total magnification is simply the product of both lens powers. As magnification increases, the physical area of the slide visible at once (the field of view) necessarily shrinks, following a simple inverse relationship: doubling the magnification halves the field of view. This relationship becomes genuinely useful in reverse — once you know the field-of-view diameter at a given magnification, you can estimate a specimen's actual physical size just from what fraction of that visible field it occupies."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where microscope magnification actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Eyepiece magnification</span>
        <input id="eyepiece" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Objective magnification</span>
        <input id="objective" type="number" step="any" value="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-3 rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Total magnification</div><div id="r-total" class="mt-1 text-2xl font-bold">—</div></div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Known field of view (mm)</span>
        <input id="fov1" type="number" step="any" value="4.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">...at this magnification</span>
        <input id="mag1" type="number" step="any" value="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-3 rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Field of view at total magnification (above)</div><div id="r-fov2" class="mt-1 text-xl font-bold text-slate-800">—</div></div>

    <div class="mt-6">
      <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Specimen's fraction of the field (0-1)</span>
        <input id="fraction" type="number" step="any" value="0.2" min="0" max="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-3 rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Estimated specimen size</div><div id="r-size" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    <p id="mm-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Low power vs. high power view</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-low" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low power (wide field)</h3>
          <p class="mt-1 text-sm text-slate-600">A wide field of view shows many specimens at once, each appearing small.</p>
        </div>
        <div>
          <div id="diag-high" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High power (narrow field)</h3>
          <p class="mt-1 text-sm text-slate-600">A narrow field of view shows fewer specimens, each in much greater detail.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Magnification graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Field of view vs. total magnification</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-fov"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Common objective/eyepiece combinations</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-combos"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('mm-err').textContent = '';
        el('r-total').textContent = '—'; el('r-fov2').textContent = '—'; el('r-size').textContent = '—';
        const eyepiece = parseFloat(el('eyepiece').value), objective = parseFloat(el('objective').value);
        const fov1 = parseFloat(el('fov1').value), mag1 = parseFloat(el('mag1').value);
        const fraction = parseFloat(el('fraction').value);
        if (isNaN(eyepiece) || isNaN(objective)) return;
        if (eyepiece <= 0 || objective <= 0) { el('mm-err').textContent = 'Eyepiece and objective magnification must be positive.'; return; }
        const total = eyepiece * objective;
        el('r-total').textContent = fmt(total) + 'x';
        if (!isNaN(fov1) && !isNaN(mag1) && fov1 > 0 && mag1 > 0) {
          const fov2 = fov1 * (mag1 / total);
          el('r-fov2').textContent = fov2 >= 1 ? fmt(fov2) + ' mm' : fmt(fov2 * 1000) + ' µm';
          if (!isNaN(fraction) && fraction >= 0 && fraction <= 1) {
            const sizeMm = fov2 * fraction;
            el('r-size').textContent = sizeMm >= 1 ? fmt(sizeMm) + ' mm' : fmt(sizeMm * 1000) + ' µm';
          }
        }
      }
      ['eyepiece', 'objective', 'fov1', 'mag1', 'fraction'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const mags = [40, 100, 400, 1000];
        const fovData = mags.map((m) => +(4.5 * (40 / m)).toFixed(3));
        new Chart(el('chart-fov'), {
          type: 'line',
          data: { labels: mags, datasets: [{ label: 'FOV (mm)', data: fovData, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 4 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Total magnification' } }, y: { title: { display: true, text: 'Field of view (mm)' } } }, plugins: { legend: { display: false } } }),
        });
        new Chart(el('chart-combos'), {
          type: 'bar',
          data: { labels: ['4x obj', '10x obj', '40x obj', '100x obj (oil)'], datasets: [{ label: 'Total magnification (10x eyepiece)', data: [40, 100, 400, 1000], backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Total magnification' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function fieldScene(container, specimenCount, specimenSize) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const circle = new THREE.Mesh(new THREE.RingGeometry(2.3, 2.5, 48), new THREE.MeshBasicMaterial({ color: 0x94a3b8, side: THREE.DoubleSide }));
        s.scene.add(circle);
        for (let i = 0; i < specimenCount; i++) {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(specimenSize, 14, 12), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          const angle = (i / specimenCount) * Math.PI * 2;
          const r = 1.2 * Math.random();
          sph.position.set(Math.cos(angle) * r * 1.5, Math.sin(angle) * r * 1.5, 0);
          s.scene.add(sph);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.002); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() { const c = el('diag-low'); if (!c) throw new Error('no container'); diagLow = fieldScene(c, 10, 0.15); }
      function initDiagHigh() { const c = el('diag-high'); if (!c) throw new Error('no container'); diagHigh = fieldScene(c, 2, 0.6); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[microscope-magnification] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[microscope-magnification] low-power diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[microscope-magnification] high-power diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
