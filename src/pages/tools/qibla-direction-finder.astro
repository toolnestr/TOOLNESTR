---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Qibla Direction Finder';
const description = 'Find the Qibla direction to the Kaaba in Makkah from your location — get the exact bearing in degrees from North and a live compass.';
const intro = 'Find the direction of the Qibla from your location, in degrees from North.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'How is the Qibla direction calculated?', a: 'It uses the great-circle (shortest path) bearing from your coordinates to the Kaaba at 21.4225°N, 39.8262°E. This is the standard method used by mosques and Qibla apps to give a single compass direction.' },
  { q: 'How accurate is it?', a: 'The calculated bearing is very accurate. The live compass depends on your device’s magnetometer, which can drift near metal or electronics — move outdoors and away from interference, and calibrate your phone for best results.' },
  { q: 'Can I use it without GPS?', a: 'Yes. Enter your latitude and longitude manually, or your city’s coordinates, and the tool will calculate the bearing without needing location access.' },
  { q: 'What is the difference between magnetic and true north?', a: 'The bearing is measured from true (geographic) north. A magnetic compass points to magnetic north, which differs by a local angle called declination. Many phone compasses correct for this automatically.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} hideDisclaimer={true}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Latitude</span>
        <input id="lat" type="number" step="any" placeholder="e.g. 40.7128" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Longitude</span>
        <input id="lng" type="number" step="any" placeholder="e.g. -74.0060" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white">
        <div class="text-sm opacity-80">Qibla bearing from North</div>
        <div id="r-deg" class="mt-1 text-3xl font-bold tabular-nums">—</div>
        <div id="r-dir" class="text-sm opacity-90"></div>
      </div>
      <div class="mt-5 flex justify-center">
        <svg id="compass" width="240" height="240" viewBox="0 0 240 240" role="img" aria-label="Qibla compass">
          <circle cx="120" cy="120" r="110" fill="#f8fafc" stroke="#cbd5e1" stroke-width="2" />
          <g id="dial">
            <text x="120" y="28" text-anchor="middle" font-size="14" font-weight="bold" fill="#475569" font-family="system-ui">N</text>
            <text x="212" y="125" text-anchor="middle" font-size="14" fill="#94a3b8" font-family="system-ui">E</text>
            <text x="120" y="220" text-anchor="middle" font-size="14" fill="#94a3b8" font-family="system-ui">S</text>
            <text x="28" y="125" text-anchor="middle" font-size="14" fill="#94a3b8" font-family="system-ui">W</text>
          </g>
          <g id="needle">
            <line x1="120" y1="120" x2="120" y2="32" stroke="#e11d48" stroke-width="4" stroke-linecap="round" />
            <polygon points="120,22 113,40 127,40" fill="#e11d48" />
            <text x="120" y="60" text-anchor="middle" font-size="16" fill="#fbbf24" font-family="system-ui">🕋</text>
          </g>
          <circle cx="120" cy="120" r="7" fill="#1e293b" />
        </svg>
      </div>
      <p id="compass-note" class="mt-2 text-center text-xs text-slate-500"></p>
      <p id="compass-prompt" class="mt-2 hidden cursor-pointer text-center text-xs font-medium text-indigo-600 underline">🧭 Tap to enable the live compass</p>
    </div>
    <p id="err" class="mt-3 hidden text-sm text-rose-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the Qibla finder works</h2>
    <p class="mt-2 text-slate-600">The Qibla is the direction Muslims face during prayer — towards the Kaaba in the Sacred Mosque of Makkah. This finder calculates the exact compass bearing from wherever you are to the Kaaba, located at latitude 21.4225° north and longitude 39.8262° east. You can let your device share your location, or type your latitude and longitude (or your city’s coordinates) by hand. Either way, the calculation runs on your device and nothing is stored.</p>
    <p class="mt-3 text-slate-600">The bearing is computed using the great-circle formula, which gives the shortest path across the curved surface of the Earth. The result is an angle measured clockwise from true north — for example, a Qibla of 58° means you face roughly east-northeast. The tool also names the nearest compass direction and draws a compass with a needle pointing towards the Kaaba.</p>
    <p class="mt-3 text-slate-600">If your phone has a magnetometer, you can enable the live compass so the needle aligns with the real world as you turn. Phone compasses can drift near metal, magnets and electronics, so step outside, hold the device flat, and calibrate it by moving it in a figure-of-eight if the reading seems off. For a fixed reference you can always rely on the calculated bearing in degrees.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for an accurate reading</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🧲</span><h3 class="mt-2 font-semibold text-slate-900">Avoid interference</h3><p class="mt-1 text-sm text-slate-600">Keep away from cars, steel furniture, speakers and laptops. Magnetic fields nearby can pull a compass several degrees off.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">📐</span><h3 class="mt-2 font-semibold text-slate-900">Use the degree reading</h3><p class="mt-1 text-sm text-slate-600">If the live compass is unreliable, line up the calculated bearing with a separate compass or a known landmark direction.</p></div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/sehri-iftar-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Sehri &amp; Iftar Times</a>
      <a href="/tools/hijri-date-today" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Today’s Hijri Date</a>
      <a href="/tools/tasbih-counter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Digital Tasbih</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const KAABA_LAT = 21.4225, KAABA_LNG = 39.8262;
    let qibla = null, heading = 0, compassOn = false;
    const rad = (d) => d * Math.PI / 180, deg = (r) => r * 180 / Math.PI;
    const dirName = (b) => ['N', 'NNE', 'NE', 'ENE', 'E', 'ESE', 'SE', 'SSE', 'S', 'SSW', 'SW', 'WSW', 'W', 'WNW', 'NW', 'NNW'][Math.round(b / 22.5) % 16];

    function compute() {
      const la = parseFloat(el('lat').value), lo = parseFloat(el('lng').value);
      if (!isFinite(la) || !isFinite(lo)) { el('result').classList.add('hidden'); return; }
      const dL = rad(KAABA_LNG - lo);
      const y = Math.sin(dL) * Math.cos(rad(KAABA_LAT));
      const x = Math.cos(rad(la)) * Math.sin(rad(KAABA_LAT)) - Math.sin(rad(la)) * Math.cos(rad(KAABA_LAT)) * Math.cos(dL);
      qibla = (deg(Math.atan2(y, x)) + 360) % 360;
      el('r-deg').textContent = qibla.toFixed(1) + '°';
      el('r-dir').textContent = 'Face ' + dirName(qibla) + ' (' + qibla.toFixed(0) + '° from true north)';
      el('result').classList.remove('hidden');
      drawNeedle();
    }
    function drawNeedle() {
      if (qibla === null) return;
      const rot = compassOn ? qibla - heading : qibla;
      el('needle').setAttribute('transform', 'rotate(' + rot + ' 120 120)');
    }
    function onOrient(e) { if (e.absolute || e.webkitCompassHeading != null) { heading = e.webkitCompassHeading != null ? e.webkitCompassHeading : (360 - e.alpha); } else if (e.alpha != null) { heading = 360 - e.alpha; } drawNeedle(); }

    // Enables the live compass with no button where the platform allows it.
    // iOS (13+) only grants motion-sensor permission inside a user-gesture
    // handler, so requesting it automatically on load silently fails there —
    // in that one case a small "tap to enable" prompt appears since there is
    // no way around that OS-level restriction. Everywhere else this just
    // turns on immediately.
    function enableCompass() {
      if (typeof DeviceOrientationEvent !== 'undefined' && typeof DeviceOrientationEvent.requestPermission === 'function') {
        DeviceOrientationEvent.requestPermission().then((s) => {
          if (s === 'granted') {
            compassOn = true; window.addEventListener('deviceorientation', onOrient);
            el('compass-note').textContent = 'Live compass on — hold the phone flat.';
            el('compass-prompt').classList.add('hidden');
          } else { el('compass-prompt').classList.remove('hidden'); }
        }).catch(() => { el('compass-prompt').classList.remove('hidden'); });
      } else if ('ondeviceorientationabsolute' in window) {
        compassOn = true; window.addEventListener('deviceorientationabsolute', onOrient);
        el('compass-note').textContent = 'Live compass on — hold the phone flat.';
      } else if ('ondeviceorientation' in window) {
        compassOn = true; window.addEventListener('deviceorientation', onOrient);
        el('compass-note').textContent = 'Live compass on — accuracy varies by device.';
      } else {
        el('compass-note').textContent = 'Live compass not supported on this device — showing the calculated bearing instead.';
      }
    }
    el('compass-prompt').addEventListener('click', enableCompass);

    // Auto-start: get your location, compute the bearing, and turn on the
    // live compass — no buttons needed.
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (pos) => { el('lat').value = pos.coords.latitude.toFixed(5); el('lng').value = pos.coords.longitude.toFixed(5); compute(); enableCompass(); },
        () => { el('err').textContent = 'Could not get your location automatically. Enter coordinates manually below.'; el('err').classList.remove('hidden'); enableCompass(); }
      );
    } else {
      el('err').textContent = 'Geolocation is not available — enter coordinates manually below.';
      el('err').classList.remove('hidden');
      enableCompass();
    }

    ['lat', 'lng'].forEach((id) => el(id).addEventListener('input', compute));
  </script>
</ToolLayout>
