---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'CSR Decoder';
const description = 'Decode the contents of a Certificate Signing Request (CSR) in PEM format.';
const intro = 'Decode the contents of a Certificate Signing Request (PEM format).';
const category = { id: 'security', name: 'Security Tools' };
const faqs = [
  { q: 'Is my CSR uploaded anywhere?', a: 'No — all decoding happens in your browser using the Web Crypto API. The CSR you paste never leaves your device.' },
  { q: 'What is a CSR used for?', a: 'A Certificate Signing Request (CSR) is sent to a Certificate Authority (CA) when ordering an SSL/TLS certificate. It contains the domain information and public key, signed by the private key to prove ownership.' },
  { q: 'Can I decode a CSR that has a passphrase?', a: 'CSRs themselves are not encrypted. The private key used to generate the CSR may be protected by a passphrase, but the CSR PEM file is always unencrypted base64-encoded DER data.' },
  { q: 'What is the difference between a CSR and a certificate?', a: 'A CSR is a request for a certificate. It contains the information you want the CA to certify (domain, organization, public key). The CA signs it and returns the actual X.509 certificate. The CSR is never installed on a server — only the final certificate is.' },
  { q: 'What key sizes are supported?', a: 'The tool works with any RSA or EC key size. NIST recommends a minimum of 2048-bit RSA or 256-bit ECDSA for production use.' },
];
---
<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="text-sm font-medium text-slate-700" for="csr-input">Paste CSR (PEM format)</label>
    <textarea id="csr-input" rows="6" placeholder="-----BEGIN CERTIFICATE REQUEST-----&#10;MIIC...&#10;-----END CERTIFICATE REQUEST-----" class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-4 font-mono text-xs outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></textarea>
    <button id="decode-btn" class="mt-3 rounded-lg bg-indigo-600 px-5 py-2 text-sm font-semibold text-white transition hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed">Decode</button>
    <div id="csr-status" class="mt-3 hidden rounded-lg px-3 py-2 text-sm font-medium"></div>
    <div id="csr-error" class="mt-3 hidden rounded-lg bg-red-50 px-3 py-2 text-sm font-medium text-red-700"></div>
    <div id="csr-results" class="mt-4 hidden space-y-4">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Subject</h3>
        <table class="mt-2 w-full text-sm" id="subject-table"><tbody></tbody></table>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Public Key</h3>
        <table class="mt-2 w-full text-sm" id="pubkey-table"><tbody></tbody></table>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Signature Algorithm</h3>
        <p id="sig-alg" class="mt-2 font-mono text-sm text-slate-700"></p>
      </div>
      <div id="sans-section" class="hidden rounded-xl border border-slate-200 bg-slate-50 p-4">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Subject Alternative Names (SANs)</h3>
        <div id="sans-list" class="mt-2 flex flex-wrap gap-2"></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 760 360" width="760" height="360" role="img" aria-labelledby="csr-diagram-title csr-diagram-desc">
      <title id="csr-diagram-title">PKCS#10 CSR Structure Diagram</title>
      <desc id="csr-diagram-desc">A diagram showing the ASN.1 structure of a PKCS#10 Certificate Signing Request, including CertificationRequestInfo with version, subject, public key, and attributes, plus signature algorithm and signature value</desc>
      <defs>
        <marker id="csr-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="#6366f1" />
        </marker>
      </defs>
      <rect x="20" y="10" width="720" height="340" rx="12" fill="#f8fafc" stroke="#94a3b8" stroke-width="2" stroke-dasharray="6,3" />
      <text x="380" y="32" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="13" font-weight="700">Certificate Signing Request — PKCS#10 (ASN.1 DER / PEM)</text>
      <rect x="60" y="50" width="640" height="180" rx="8" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
      <text x="380" y="72" text-anchor="middle" fill="#4338ca" font-family="system-ui, sans-serif" font-size="13" font-weight="600">CertificationRequestInfo (SEQUENCE)</text>
      <rect x="90" y="84" width="280" height="28" rx="5" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.2" />
      <text x="230" y="102" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="11">Version (INTEGER 0)</text>
      <rect x="90" y="118" width="280" height="28" rx="5" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.2" />
      <text x="230" y="136" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="11">Subject &#123; CN, O, OU, L, ST, C &#125;</text>
      <rect x="90" y="152" width="280" height="28" rx="5" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.2" />
      <text x="230" y="170" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="11">SubjectPublicKeyInfo (algorithm + key)</text>
      <rect x="90" y="186" width="280" height="28" rx="5" fill="#f0fdf4" stroke="#86efac" stroke-width="1.2" />
      <text x="230" y="204" text-anchor="middle" fill="#15803d" font-family="system-ui, sans-serif" font-size="11">Attributes [0] &#123; extensionRequest &#125;</text>
      <text x="230" y="216" text-anchor="middle" fill="#94a3b8" font-family="system-ui, sans-serif" font-size="10">(optional — includes SANs if present)</text>
      <rect x="420" y="84" width="250" height="130" rx="6" fill="#f0fdf4" stroke="#22c55e" stroke-width="1.5" />
      <text x="545" y="100" text-anchor="middle" fill="#15803d" font-family="system-ui, sans-serif" font-size="11" font-weight="600">PKCS#10 Attributes</text>
      <text x="545" y="118" text-anchor="middle" fill="#16a34a" font-family="system-ui, sans-serif" font-size="10">1.2.840.113549.1.9.14</text>
      <text x="545" y="134" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="10">extensionRequest</text>
      <line x1="90" y1="200" x2="420" y2="108" stroke="#22c55e" stroke-width="1" stroke-dasharray="3,2" marker-end="url(#csr-arrow)" />
      <text x="545" y="160" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="10">Extensions SEQUENCE:</text>
      <text x="545" y="176" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="10">- subjectAltName (SAN)</text>
      <text x="545" y="192" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="10">- keyUsage, extendedKeyUsage</text>
      <text x="545" y="208" text-anchor="middle" fill="#94a3b8" font-family="system-ui, sans-serif" font-size="9">OID: 2.5.29.17 for SANs</text>
      <rect x="60" y="248" width="280" height="40" rx="6" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.2" />
      <text x="200" y="266" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="11">Signature Algorithm (OID)</text>
      <text x="200" y="280" text-anchor="middle" fill="#94a3b8" font-family="system-ui, sans-serif" font-size="10">sha256WithRSAEncryption / ecdsa-with-SHA256</text>
      <rect x="380" y="248" width="320" height="40" rx="6" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.2" />
      <text x="540" y="266" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="11">Signature Value (BIT STRING)</text>
      <text x="540" y="280" text-anchor="middle" fill="#94a3b8" font-family="system-ui, sans-serif" font-size="10">Encrypted hash, signed by requestor's private key</text>
      <rect x="160" y="305" width="440" height="30" rx="6" fill="#d1fae5" stroke="#6ee7b7" stroke-width="1" />
      <text x="380" y="325" text-anchor="middle" fill="#065f46" font-family="system-ui, sans-serif" font-size="11">Signed with the private key — proves possession without revealing it</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">ASN.1 DER structure of a PKCS#10 Certificate Signing Request. The CSR contains identity information and the public key, signed by the corresponding private key to prove key possession.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is a Certificate Signing Request?</h2>
    <p class="mt-2 text-slate-600">A Certificate Signing Request (CSR) is a structured message sent to a Certificate Authority (CA) to apply for an SSL/TLS certificate. It contains the identity information of the organisation requesting the certificate — including the domain name (Common Name), organisation name, locality, and country — along with the applicant's public key. The entire request is signed using the corresponding private key to prove that the requester actually possesses the private key without revealing it.</p>
    <p class="mt-3 text-slate-600">CSRs follow the PKCS#10 standard (Public-Key Cryptography Standard #10), defined in RFC 2986. The data is encoded using ASN.1 (Abstract Syntax Notation One) with DER (Distinguished Encoding Rules) binary encoding, then wrapped in base64 with PEM header and footer lines. This is why a CSR looks like <code class="rounded bg-indigo-100 px-1 text-indigo-700">-----BEGIN CERTIFICATE REQUEST-----</code> followed by a block of base64 text.</p>
    <p class="mt-3 text-slate-600">The three major parts of a CSR are the <strong>certification request info</strong> (version, subject distinguished name, public key, and optional attributes), the <strong>signature algorithm identifier</strong> (which algorithm was used to sign), and the <strong>digital signature value</strong> itself. The CA verifies the signature using the public key contained in the request, then issues a signed X.509 certificate.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the CSR Decoder Works</h2>
    <p class="mt-2 text-slate-600">This decoder processes the CSR entirely in your browser. When you paste a PEM-encoded CSR and click Decode, the tool strips the PEM headers, decodes the base64 content into DER binary data, and parses the ASN.1 TLV (Tag-Length-Value) structure to extract each field.</p>
    <p class="mt-3 text-slate-600">For the public key, the decoder uses the <strong>Web Crypto API</strong> (SubtleCrypto) to import the SubjectPublicKeyInfo from the CSR and export it as a JWK (JSON Web Key). This reveals the key type (RSA or EC), the key size in bits (computed from the modulus length for RSA, or the curve name for EC), and the key usage. The same approach is used by the <a href="/tools/rsa-key-generator" class="text-indigo-600 hover:text-indigo-700">RSA Key Generator</a> tool on this site.</p>
    <p class="mt-3 text-slate-600">Subject fields are extracted by walking the ASN.1 structure of the Name element and matching each attribute's OID (Object Identifier) to a lookup table. Common OIDs include 2.5.4.3 for Common Name (CN), 2.5.4.10 for Organization (O), and 2.5.4.6 for Country (C). If the CSR includes a Subject Alternative Names (SANs) extension, the tool also decodes those and displays each domain name or IP address.</p>
  </section>

  <section class="mt-10 grid gap-6 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 p-4">
      <h3 class="font-semibold text-slate-900">Use Cases</h3>
      <ul class="mt-2 space-y-2 text-sm text-slate-600">
        <li><strong>Verifying CSR contents before submission</strong> — check that the CN, organization, and SANs are correct before sending to a CA to avoid certificate re-issuance delays.</li>
        <li><strong>Debugging certificate ordering issues</strong> — when a CA rejects a CSR, decode it to verify the key size, signature algorithm, and subject fields meet the CA's requirements.</li>
        <li><strong>Server administration</strong> — when taking over management of existing servers, decode the installed CSR or certificate to understand what identity information was used.</li>
        <li><strong>Security audits</strong> — examine CSRs to verify key strength (minimum 2048-bit RSA) and ensure no unexpected SANs or subject fields are present.</li>
        <li><strong>Education and training</strong> — learn how PKI infrastructure works by examining real CSR structures and understanding each ASN.1 field.</li>
      </ul>
    </div>
    <div class="rounded-xl border border-slate-200 p-4">
      <h3 class="font-semibold text-slate-900">Tips &amp; Common Mistakes</h3>
      <ul class="mt-2 space-y-2 text-sm text-slate-600">
        <li><strong>Verify the CN matches your domain</strong> — the Common Name must exactly match the domain name the certificate will secure. A mismatch causes browser security warnings. For wildcard certificates, use <code class="rounded bg-slate-100 px-1 text-xs">*.example.com</code>.</li>
        <li><strong>Check key size is at least 2048 bits</strong> — many CAs reject CSRs with RSA key sizes below 2048 bits. NIST recommends 2048-bit RSA or 256-bit ECDSA as the minimum for production systems through 2030.</li>
        <li><strong>Include SANs for multi-domain certificates</strong> — modern browsers expect Subject Alternative Names (SANs) even when a Common Name is present. Always include all domains the certificate should cover in the SAN extension.</li>
        <li><strong>Keep your private key secure</strong> — the CSR only contains the public key, but you generated it with your private key. Never share the private key file. If the private key is compromised, anyone can create a new CSR and request a certificate for your domain from a CA.</li>
        <li><strong>Use a strong signature algorithm</strong> — prefer SHA-256 over SHA-1 for the signature. SHA-1 is deprecated and most CAs no longer accept CSRs signed with SHA-1.</li>
      </ul>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Typical CSR Generation Workflow</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Generate Key Pair</h3>
        <p class="mt-1 text-sm text-slate-600">Use OpenSSL or your server software to generate a 2048+ bit RSA or EC key pair. The private key stays on your server and <em>must never be shared</em>.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Create CSR</h3>
        <p class="mt-1 text-sm text-slate-600">Generate the CSR using the private key. Provide your domain (CN), organization details, and optionally include SANs for multi-domain coverage.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Submit to CA</h3>
        <p class="mt-1 text-sm text-slate-600">Send the CSR to a trusted Certificate Authority (Let's Encrypt, DigiCert, Sectigo, etc.). The CA verifies domain ownership and issues the signed certificate.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">4</span>
        <h3 class="mt-3 font-semibold text-slate-900">Install Certificate</h3>
        <p class="mt-1 text-sm text-slate-600">Install the returned X.509 certificate on your server alongside the private key. The CSR is no longer needed after the certificate is issued.</p>
      </div>
    </div>
    <p class="mt-4 text-slate-600">The typical OpenSSL command to generate a CSR is <code class="rounded bg-slate-100 px-1 text-xs">openssl req -new -newkey rsa:2048 -nodes -keyout server.key -out server.csr</code>. This creates a 2048-bit RSA key pair and outputs a CSR file. The <code class="rounded bg-slate-100 px-1 text-xs">-nodes</code> flag means the private key is not encrypted with a passphrase — omit it if you want to encrypt the key.</p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-4">
    <h2 class="text-lg font-bold text-slate-900">Privacy &amp; Security</h2>
    <p class="mt-2 text-sm text-slate-600">This tool processes everything locally in your browser using the Web Crypto API. No data is sent to any server, logged, or stored. The CSR you paste never leaves your device. You can verify this by opening your browser developer tools network tab — no network requests are made when you decode a CSR.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/x509-certificate-decoder" class="rounded-xl border border-slate-200 bg-white p-4 text-sm transition hover:border-indigo-300 hover:shadow-sm"><span class="font-semibold text-slate-900">X.509 Certificate Decoder</span><p class="mt-1 text-slate-600">Decode the details of an X.509 SSL/TLS certificate in PEM format.</p></a>
      <a href="/tools/rsa-key-generator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm transition hover:border-indigo-300 hover:shadow-sm"><span class="font-semibold text-slate-900">RSA Key Generator</span><p class="mt-1 text-slate-600">Generate RSA public/private key pairs in PEM or JWK format.</p></a>
      <a href="/tools/ssl-certificate-checker" class="rounded-xl border border-slate-200 bg-white p-4 text-sm transition hover:border-indigo-300 hover:shadow-sm"><span class="font-semibold text-slate-900">SSL/TLS Certificate Checker</span><p class="mt-1 text-slate-600">Check SSL/TLS certificate details for any domain.</p></a>
    </div>
  </section>
</ToolLayout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const input = document.getElementById('csr-input');
  const decodeBtn = document.getElementById('decode-btn');
  const statusEl = document.getElementById('csr-status');
  const errorEl = document.getElementById('csr-error');
  const resultsEl = document.getElementById('csr-results');
  const subjectTbody = document.querySelector('#subject-table tbody');
  const pubkeyTbody = document.querySelector('#pubkey-table tbody');
  const sigAlgEl = document.getElementById('sig-alg');
  const sansSection = document.getElementById('sans-section');
  const sansList = document.getElementById('sans-list');

  const OID_MAP = {
    '2.5.4.3': 'Common Name (CN)',
    '2.5.4.4': 'Surname (SN)',
    '2.5.4.5': 'Serial Number',
    '2.5.4.6': 'Country (C)',
    '2.5.4.7': 'Locality (L)',
    '2.5.4.8': 'State / Province (ST)',
    '2.5.4.9': 'Street Address',
    '2.5.4.10': 'Organization (O)',
    '2.5.4.11': 'Organizational Unit (OU)',
    '2.5.4.12': 'Title',
    '2.5.4.13': 'Description',
    '2.5.4.15': 'Business Category',
    '2.5.4.17': 'Postal Code',
    '2.5.4.42': 'Given Name',
    '2.5.4.43': 'Initials',
    '2.5.4.44': 'Generation Qualifier',
    '1.2.840.113549.1.9.1': 'Email Address',
  };

  const SIG_ALG_MAP = {
    '1.2.840.113549.1.1.2': 'md2WithRSAEncryption',
    '1.2.840.113549.1.1.4': 'md5WithRSAEncryption',
    '1.2.840.113549.1.1.5': 'sha1WithRSAEncryption',
    '1.2.840.113549.1.1.11': 'sha256WithRSAEncryption',
    '1.2.840.113549.1.1.12': 'sha384WithRSAEncryption',
    '1.2.840.113549.1.1.13': 'sha512WithRSAEncryption',
    '1.2.840.10045.4.1': 'ecdsa-with-SHA1',
    '1.2.840.10045.4.3.2': 'ecdsa-with-SHA256',
    '1.2.840.10045.4.3.3': 'ecdsa-with-SHA384',
    '1.2.840.10045.4.3.4': 'ecdsa-with-SHA512',
    '1.2.840.113549.1.1.10': 'RSA-PSS',
    '1.3.14.3.2.29': 'sha1WithRSASignature',
    '1.3.101.112': 'ed25519',
    '1.3.101.113': 'ed448',
  };

  const PK_ALG_MAP = {
    '1.2.840.113549.1.1.1': 'RSA Encryption',
    '1.2.840.10045.2.1': 'Elliptic Curve (EC)',
    '1.2.840.10040.4.1': 'DSA',
    '1.3.101.112': 'Ed25519',
    '1.3.101.113': 'Ed448',
    '1.3.101.110': 'X25519',
    '1.3.101.111': 'X448',
  };

  const TAG_SEQUENCE = 0x30;
  const TAG_SET = 0x31;
  const TAG_INTEGER = 0x02;
  const TAG_BIT_STRING = 0x03;
  const TAG_OCTET_STRING = 0x04;
  const TAG_OID = 0x06;
  const TAG_UTF8_STRING = 0x0C;
  const TAG_PRINTABLE_STRING = 0x13;
  const TAG_IA5_STRING = 0x16;

  class DerDecoder {
    constructor(buf) {
      this.buf = buf;
      this.pos = 0;
    }
    eof() {
      return this.pos >= this.buf.length;
    }
    readByte() {
      return this.buf[this.pos++];
    }
    readLength() {
      let len = this.readByte();
      if (len & 0x80) {
        const count = len & 0x7f;
        len = 0;
        for (let i = 0; i < count; i++) {
          len = (len << 8) | this.readByte();
        }
      }
      return len;
    }
    readTLV() {
      const start = this.pos;
      const tag = this.readByte();
      const len = this.readLength();
      const value = this.buf.slice(this.pos, this.pos + len);
      this.pos += len;
      return { tag, len, value, start };
    }
    expectTag(tag) {
      const tlv = this.readTLV();
      if (tlv.tag !== tag) {
        throw new Error('Expected tag 0x' + tag.toString(16) + ' but got 0x' + tlv.tag.toString(16));
      }
      return tlv;
    }
    readSequence() {
      const tlv = this.expectTag(TAG_SEQUENCE);
      return new DerDecoder(tlv.value);
    }
    readInteger() {
      const tlv = this.expectTag(TAG_INTEGER);
      return tlv.value;
    }
    readOID() {
      const tlv = this.expectTag(TAG_OID);
      return this.decodeOID(tlv.value);
    }
    readBitString() {
      const tlv = this.expectTag(TAG_BIT_STRING);
      return tlv.value.slice(1);
    }
    readString(tag) {
      const tlv = this.readTLV();
      const strTags = [TAG_UTF8_STRING, TAG_PRINTABLE_STRING, TAG_IA5_STRING, 0x14, 0x1E, 0x22, 0x0D, 0x1B];
      if (!strTags.includes(tlv.tag)) {
        throw new Error('Expected string tag but got 0x' + tlv.tag.toString(16));
      }
      return new TextDecoder().decode(tlv.value);
    }
    readAnyString() {
      const tlv = this.readTLV();
      return new TextDecoder().decode(tlv.value);
    }
    decodeOID(bytes) {
      const result = [];
      result.push(Math.floor(bytes[0] / 40));
      result.push(bytes[0] % 40);
      let val = 0;
      for (let i = 1; i < bytes.length; i++) {
        if (bytes[i] & 0x80) {
          val = (val << 7) | (bytes[i] & 0x7f);
        } else {
          val = (val << 7) | bytes[i];
          result.push(val);
          val = 0;
        }
      }
      return result.join('.');
    }
    readContextSpecific(tagNum) {
      const expectedTag = 0xA0 | tagNum;
      const tlv = this.readTLV();
      if (tlv.tag !== expectedTag) {
        throw new Error('Expected context-specific tag [0x' + expectedTag.toString(16) + '] but got 0x' + tlv.tag.toString(16));
      }
      return new DerDecoder(tlv.value);
    }
    readRaw(pos, len) {
      return this.buf.slice(pos, pos + len);
    }
  }

  function parseSubject(decoder) {
    const seq = decoder.readSequence();
    const rdns = [];
    while (!seq.eof()) {
      const set = seq.readTLV();
      if (set.tag !== TAG_SET) {
        break;
      }
      const setDecoder = new DerDecoder(set.value);
      const attrSeq = setDecoder.readSequence();
      const oid = attrSeq.readOID();
      let value;
      try {
        value = attrSeq.readAnyString();
      } catch (e) {
        value = '[binary]';
      }
      rdns.push({ oid, value, label: OID_MAP[oid] || oid });
    }
    return rdns;
  }

  function parsePublicKeyAlgorithm(decoder) {
    const algSeq = decoder.readSequence();
    const oid = algSeq.readOID();
    return oid;
  }

  function showStatus(msg, ok) {
    statusEl.textContent = msg;
    statusEl.className = 'mt-3 rounded-lg px-3 py-2 text-sm font-medium ' + (ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700');
    statusEl.classList.remove('hidden');
  }

  function hideStatus() {
    statusEl.classList.add('hidden');
  }

  function hideError() {
    errorEl.classList.add('hidden');
  }

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }

  function escHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function addRow(tbody, label, value, monospace) {
    const tr = document.createElement('tr');
    tr.className = 'text-slate-700';
    tr.innerHTML = '<td class="py-1.5 pr-4 text-xs font-semibold uppercase tracking-wide text-slate-500">' + escHtml(label) + '</td>' +
      '<td class="py-1.5 font-' + (monospace ? 'mono' : 'sans') + ' text-sm">' + escHtml(value) + '</td>';
    tbody.appendChild(tr);
  }

  function formatKeySize(algorithmOID, jwk) {
    if (algorithmOID === '1.2.840.113549.1.1.1' && jwk && jwk.n) {
      const nBytes = atob(jwk.n.replace(/-/g, '+').replace(/_/g, '/'));
      return (nBytes.length * 8) + ' bits';
    }
    if (algorithmOID === '1.2.840.10045.2.1' && jwk && jwk.crv) {
      return jwk.crv;
    }
    return 'Unknown';
  }

  function parseSANs(extValue) {
    const names = [];
    const decoder = new DerDecoder(extValue);
    try {
      const seq = decoder.readSequence();
      while (!seq.eof()) {
        const tlv = seq.readTLV();
        const tag = tlv.tag;
        const val = new TextDecoder().decode(tlv.value);
        if (tag === 0x82) {
          names.push({ type: 'dNSName', value: val });
        } else if (tag === 0x87) {
          const ip = Array.from(tlv.value).join('.');
          names.push({ type: 'iPAddress', value: ip });
        } else if (tag === 0x81) {
          names.push({ type: 'rfc822Name', value: val });
        } else if (tag === 0x86) {
          names.push({ type: 'uniformResourceIdentifier', value: val });
        }
      }
    } catch (e) {
      return [];
    }
    return names;
  }

  function parseExtensions(attrDecoder) {
    const extSeq = attrDecoder.readSequence();
    const sans = [];
    while (!extSeq.eof()) {
      const extTlv = extSeq.readTLV();
      if (extTlv.tag !== TAG_SEQUENCE) break;
      const extDecoder = new DerDecoder(extTlv.value);
      const extOID = extDecoder.readOID();
      const critical = extDecoder.readByte() === 0x01;
      if (critical) {
        extDecoder.readByte(); // skip boolean length
        extDecoder.readByte(); // skip boolean value
      }
      const extValTlv = extDecoder.readTLV();
      if (extValTlv.tag === TAG_OCTET_STRING) {
        if (extOID === '2.5.29.17') {
          const parsed = parseSANs(extValTlv.value);
          sans.push(...parsed);
        }
      }
    }
    return sans;
  }

  function hasSANs(criDecoder) {
    try {
      const attrContainer = criDecoder.readContextSpecific(0);
      while (!attrContainer.eof()) {
        const attrTlv = attrContainer.readTLV();
        if (attrTlv.tag !== TAG_SEQUENCE) break;
        const attrDecoder = new DerDecoder(attrTlv.value);
        const attrOID = attrDecoder.readOID();
        if (attrOID === '1.2.840.113549.1.9.14') {
          const setTlv = attrDecoder.readTLV();
          if (setTlv.tag === TAG_SET) {
            const setDecoder = new DerDecoder(setTlv.value);
            return parseExtensions(setDecoder);
          }
        }
      }
    } catch (e) {
      return [];
    }
    return [];
  }

  async function decode() {
    const pem = input.value.trim();
    hideStatus();
    hideError();
    resultsEl.classList.add('hidden');
    sansSection.classList.add('hidden');

    if (!pem) {
      subjectTbody.innerHTML = '';
      pubkeyTbody.innerHTML = '';
      sigAlgEl.textContent = '';
      return;
    }

    const match = pem.match(/-----BEGIN\s+(?:NEW\s+)?CERTIFICATE\s+REQUEST-----\s*\n?([\s\S]+?)\n?-----END\s+(?:NEW\s+)?CERTIFICATE\s+REQUEST-----/);
    if (!match) {
      showError('Invalid PEM format. Expected -----BEGIN CERTIFICATE REQUEST----- header and footer.');
      return;
    }

    const b64 = match[1].replace(/\s/g, '');
    let derBytes;
    try {
      const binary = atob(b64);
      derBytes = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i++) {
        derBytes[i] = binary.charCodeAt(i);
      }
    } catch (e) {
      showError('Invalid base64 encoding: ' + e.message);
      return;
    }

    let rootDecoder;
    try {
      rootDecoder = new DerDecoder(derBytes);
    } catch (e) {
      showError('Failed to parse DER data: ' + e.message);
      return;
    }

    let criDecoder, sigAlgOID;
    try {
      const outerSeq = rootDecoder.readSequence();
      criDecoder = outerSeq.readSequence();
      const sigAlgSeq = outerSeq.readSequence();
      const oidDecoder = new DerDecoder(sigAlgSeq.value);
      sigAlgOID = oidDecoder.readOID();
    } catch (e) {
      showError('Failed to parse CSR structure: ' + e.message);
      return;
    }

    subjectTbody.innerHTML = '';
    pubkeyTbody.innerHTML = '';

    try {
      criDecoder.readInteger();
      const rdns = parseSubject(criDecoder);
      for (const rdn of rdns) {
        addRow(subjectTbody, rdn.label, rdn.value, true);
      }

      const pkAlgOID = parsePublicKeyAlgorithm(criDecoder);

      const pkInfoStart = criDecoder.pos;
      criDecoder.readTLV();

      const pkAlgLabel = PK_ALG_MAP[pkAlgOID] || pkAlgOID;
      addRow(pubkeyTbody, 'Algorithm', pkAlgLabel, false);

      let jwkData = null;
      let keySize = 'Unknown';

      if (pkAlgOID === '1.2.840.113549.1.1.1') {
        try {
          const outerSeq2 = new DerDecoder(derBytes);
          outerSeq2.readSequence();
          const criSeq2 = outerSeq2.readSequence();
          criSeq2.readInteger();
          parseSubject(criSeq2);

          const pkSeq = criSeq2.readSequence();
          const pkAlgSeq2 = parsePublicKeyAlgorithm(new DerDecoder(pkSeq.value));

          const pkBitString = criSeq2.readBitString();

          const spkiDer = new Uint8Array(pkBitString.length + 4 + pkSeq.value.length + 4);
          let spkiPos = 0;
          spkiDer[spkiPos++] = 0x30;
          const spkiLen = pkSeq.value.length + pkBitString.length + 4;
          if (spkiLen < 128) {
            spkiDer[spkiPos++] = spkiLen;
          } else {
            spkiDer[spkiPos++] = 0x81;
            spkiDer[spkiPos++] = spkiLen;
          }
          spkiDer.set(pkSeq.value, spkiPos);
          spkiPos += pkSeq.value.length;
          spkiDer.set(pkBitString, spkiPos);

          const spkiTrimmed = spkiDer.slice(0, spkiPos + pkBitString.length);

          const key = await crypto.subtle.importKey(
            'spki',
            spkiTrimmed.buffer,
            { name: 'RSA-OAEP', hash: 'SHA-256' },
            true,
            ['encrypt']
          );
          jwkData = await crypto.subtle.exportKey('jwk', key);
          keySize = formatKeySize(pkAlgOID, jwkData);
        } catch (e) {
          keySize = 'Could not determine';
        }
        addRow(pubkeyTbody, 'Key Size', keySize, false);

        if (jwkData && jwkData.n) {
          const nB64 = jwkData.n.replace(/-/g, '+').replace(/_/g, '/');
          const nHex = Array.from(atob(nB64), c => c.charCodeAt(0).toString(16).padStart(2, '0')).join('');
          const modTrunc = nHex.length > 128 ? nHex.slice(0, 64) + '...' + nHex.slice(-64) : nHex;
          addRow(pubkeyTbody, 'Modulus (hex)', modTrunc, true);
        }

        if (jwkData && jwkData.e) {
          const eB64 = jwkData.e.replace(/-/g, '+').replace(/_/g, '/');
          const eDec = parseInt(atob(eB64).split('').map(c => c.charCodeAt(0).toString(16).padStart(2, '0')).join(''), 16);
          addRow(pubkeyTbody, 'Exponent', '0x' + eDec.toString(16) + ' (' + eDec + ')', true);
        }
      } else if (pkAlgOID === '1.2.840.10045.2.1') {
        try {
          const outerSeq2 = new DerDecoder(derBytes);
          outerSeq2.readSequence();
          const criSeq2 = outerSeq2.readSequence();
          criSeq2.readInteger();
          parseSubject(criSeq2);
          const pkSeq2 = criSeq2.readSequence();
          const pkOID2 = parsePublicKeyAlgorithm(new DerDecoder(pkSeq2.value));
          const pkBS = criSeq2.readBitString();

          const spkiDer2 = new Uint8Array(4 + pkSeq2.value.length + 4 + pkBS.length);
          let sp2 = 0;
          spkiDer2[sp2++] = 0x30;
          const spkiLen2 = pkSeq2.value.length + 4 + pkBS.length;
          spkiDer2[sp2++] = spkiLen2;
          spkiDer2.set(pkSeq2.value, sp2);
          sp2 += pkSeq2.value.length;
          spkiDer2.set(pkBS, sp2);
          sp2 += pkBS.length;
          const spkiTrimmed2 = spkiDer2.slice(0, sp2);

          const key = await crypto.subtle.importKey(
            'spki',
            spkiTrimmed2.buffer,
            { name: 'ECDSA', namedCurve: 'P-256' },
            true,
            ['verify']
          );
          jwkData = await crypto.subtle.exportKey('jwk', key);
          keySize = formatKeySize(pkAlgOID, jwkData);
        } catch (e) {
          keySize = 'Could not determine';
        }
        addRow(pubkeyTbody, 'Key Size', keySize, false);
      } else {
        addRow(pubkeyTbody, 'Key Size', 'N/A', false);
      }

      sigAlgEl.textContent = SIG_ALG_MAP[sigAlgOID] || sigAlgOID;

      const sans = hasSANs(criDecoder);
      if (sans.length > 0) {
        sansSection.classList.remove('hidden');
        sansList.innerHTML = sans.map(s =>
          '<span class="rounded-lg bg-indigo-100 px-3 py-1 text-xs font-medium text-indigo-700">' +
          escHtml(s.type === 'dNSName' ? s.value : s.type === 'iPAddress' ? s.value : s.type + ':' + s.value) +
          '</span>'
        ).join('');
      }

      resultsEl.classList.remove('hidden');
      showStatus('CSR decoded successfully', true);
    } catch (e) {
      showError('Failed to decode CSR: ' + e.message);
    }
  }

  decodeBtn.addEventListener('click', decode);
});
</script>
</ToolLayout>
