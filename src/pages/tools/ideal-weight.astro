---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Ideal Weight Calculator';
const description =
  'Free ideal weight calculator. Find a healthy weight range for your height based on BMI, ' +
  'plus a classic ideal-weight estimate. Works in metric or imperial units.';
const intro =
  'Enter your height and sex to see a healthy weight range for your height, plus a classic ideal-weight estimate.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How is the healthy range worked out?', a: 'The healthy range is the weight that gives a BMI between 18.5 and 24.9 for your height — the range generally considered healthy for adults.' },
  { q: 'What is the "ideal weight" figure?', a: 'It uses the Devine formula, a classic medical estimate. Treat it as a single reference point within the healthy range, not an exact target.' },
  { q: 'Why does sex matter?', a: 'The Devine ideal-weight formula uses slightly different baselines for men and women.' },
  { q: 'Is the healthy range the same for everyone regardless of age?', a: 'Not exactly. Older adults may benefit from a slightly higher BMI (around 22–27) because a little extra weight can protect against bone loss and frailty.' },
  { q: 'Can I be healthy outside the healthy weight range?', a: 'Yes — BMI-based ranges don\u2019t account for muscle mass, bone density or fat distribution. A muscular person may fall above the range while being very healthy.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
      <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>

    <div id="metric" class="mt-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-2" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Healthy weight range</div>
        <div id="r-range" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="mt-3 rounded-xl bg-slate-50 p-4 text-center">
        <div class="text-sm text-slate-500">Ideal weight (Devine formula)</div>
        <div id="r-ideal" class="mt-1 text-xl font-bold text-slate-800">—</div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your height to see your healthy weight range.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About ideal weight</h2>
    <p class="mt-2 text-slate-600">
      There’s no single "perfect" weight — a healthy weight is a range, not a number. This tool
      shows the weight range that corresponds to a healthy BMI for your height, plus a classic
      single-figure estimate for reference. Use it as a guide, not a strict rule. For a fuller picture, check your <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI</a> and <a href="/tools/body-fat" class="font-medium text-indigo-600 hover:underline">body fat percentage</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical advice.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the Ideal Weight Calculator as a reference point when setting weight goals. Personal trainers often use it to help clients understand a realistic target range before starting a programme. It’s also useful during health check-ins — for example, seeing whether your current weight falls within a healthy BMI range for your height is a quick way to gauge overall risk.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Treat the healthy range as your guide, not a single number on the scale — body weight fluctuates daily by 1–2 kg due to water and food.</li>
      <li>Combine this tool with the <a href="/tools/body-fat" class="font-medium text-indigo-600 hover:underline">Body Fat Calculator</a> — two people at the same weight can have very different body compositions.</li>
      <li>Re-check your ideal range if your height changes (unlikely in adulthood) or if you’re assessing a growing teenager against age-specific percentiles.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'block' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    const kgLb = (kg) => `${kg.toFixed(1)} kg (${(kg * 2.20462).toFixed(0)} lb)`;

    function update() {
      let cm;
      if (metric) cm = parseFloat(el('m-h').value);
      else {
        const ft = parseFloat(el('i-ft').value) || 0, inch = parseFloat(el('i-in').value) || 0;
        cm = (ft * 12 + inch) * 2.54;
      }
      if (!cm || cm <= 0) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      const m = cm / 100;
      const low = 18.5 * m * m, high = 24.9 * m * m;
      // Devine formula
      const inchesOver5ft = cm / 2.54 - 60;
      const base = el('sex').value === 'male' ? 50 : 45.5;
      const ideal = Math.max(base + 2.3 * inchesOver5ft, 0);
      el('r-range').textContent = `${low.toFixed(1)}–${high.toFixed(1)} kg (${(low * 2.20462).toFixed(0)}–${(high * 2.20462).toFixed(0)} lb)`;
      el('r-ideal').textContent = kgLb(ideal);
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'm-h', 'i-ft', 'i-in'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
