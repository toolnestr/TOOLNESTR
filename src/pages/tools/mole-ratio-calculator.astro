---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Mole Ratio Calculator';
const description = "Free mole ratio calculator with a live 3D particle-pile view and charts. Enter the coefficients of two species in a balanced equation and moles of one to.";
const intro = 'Enter the stoichiometric coefficients of two species from a balanced equation and the moles of one — get the moles of the other from the mole ratio, with a live 3D view and charts.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is a mole ratio?', a: 'A mole ratio is the ratio of the coefficients of two species in a balanced chemical equation. It tells you how many moles of one substance react with or produce a given number of moles of another — for N₂ + 3H₂ → 2NH₃, the mole ratio of H₂ to NH₃ is 3:2.' },
  { q: 'How do I calculate moles of B from moles of A?', a: 'Use moles_B = moles_A × (coefficient_B / coefficient_A). The coefficients come from the balanced equation; the ratio of coefficients is the conversion factor between the two species.' },
  { q: 'Why do I need a balanced equation first?', a: 'Mole ratios come directly from the coefficients of a balanced equation, and those coefficients are only meaningful once the equation obeys conservation of mass. An unbalanced equation gives the wrong ratio and therefore the wrong answer.' },
  { q: 'Is a mole ratio the same as a mass ratio?', a: 'No. A mole ratio compares particle counts (moles); a mass ratio also depends on each substance\'s molar mass. Two moles of H₂ and one mole of O₂ have a mole ratio of 2:1, but because O₂ is about 16× heavier per mole, the mass ratio is very different from 2:1.' },
  { q: 'Can I use this for more than two species?', a: 'This tool solves one pair at a time (A and B). For an equation with more species, apply the same coefficient-ratio method pairwise — moles of A to B, then B to C, chaining the ratios as needed.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Mole Ratio Calculator',
  description: 'Convert moles of one species to moles of another using coefficients from a balanced equation.',
  steps: [
    { name: 'Enter the coefficients', text: 'Type the balanced-equation coefficient of species A and of species B.' },
    { name: 'Enter known moles', text: 'Type the moles of A (or of B) — leave the other blank.' },
    { name: 'Read the result', text: 'The unknown moles solve instantly using the mole ratio, and the 3D piles update.' },
  ],
};

const formulas = [
  { expr: 'mol<sub>B</sub> = mol<sub>A</sub> × (c<sub>B</sub> / c<sub>A</sub>)', note: 'mole ratio = ratio of balanced coefficients' },
  { expr: 'c<sub>A</sub>A + c<sub>B</sub>B + … → products', note: 'coefficients c come from the balanced equation' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — the Haber process', tone: 'slate',
    given: 'N₂ + 3H₂ → 2NH₃. If 4.0 mol of H₂ reacts completely, how many moles of NH₃ form?',
    rows: [
      { label: 'Mole ratio (NH₃:H₂):', value: '2 : 3' },
      { label: 'Set up:', value: 'mol NH₃ = mol H₂ × (2 / 3)' },
      { label: 'Compute:', value: 'mol NH₃ = 4.0 × (2 / 3) = 2.67 mol', full: true },
    ],
  },
  {
    title: 'Worked example 2 — combustion of propane', tone: 'amber',
    given: 'C₃H₈ + 5O₂ → 3CO₂ + 4H₂O. How many moles of O₂ are needed to react with 0.80 mol of C₃H₈?',
    rows: [
      { label: 'Mole ratio (O₂:C₃H₈):', value: '5 : 1' },
      { label: 'Set up:', value: 'mol O₂ = mol C₃H₈ × (5 / 1)' },
      { label: 'Compute:', value: 'mol O₂ = 0.80 × 5 = 4.0 mol', full: true },
    ],
  },
];

const comparison = {
  heading: 'Mole ratios in common reactions',
  note: 'The ratio is read straight off the balanced coefficients — no other data needed.',
  headers: [{ label: 'Reaction' }, { label: 'Species pair' }, { label: 'Mole ratio' }],
  rows: [
    ['N₂ + 3H₂ → 2NH₃', 'H₂ : NH₃', '3 : 2'],
    ['2H₂ + O₂ → 2H₂O', 'H₂ : H₂O', '2 : 2 (1:1)'],
    ['CH₄ + 2O₂ → CO₂ + 2H₂O', 'O₂ : CO₂', '2 : 1'],
    ['C₃H₈ + 5O₂ → 3CO₂ + 4H₂O', 'O₂ : C₃H₈', '5 : 1'],
    ['4Fe + 3O₂ → 2Fe₂O₃', 'Fe : Fe₂O₃', '4 : 2 (2:1)'],
  ],
  highlightIndex: 0,
  footnote: 'Mole ratios reduce like any fraction — 2:2 is the same ratio as 1:1.',
};

const realWorld = [
  { emoji: '🏭', title: 'Industrial reactor feed ratios', body: 'The Haber process feeds N₂ and H₂ in a 1:3 mole ratio because that is what the balanced equation requires — deviating wastes feedstock or leaves reactant unconverted.' },
  { emoji: '⚗️', title: 'Lab reagent planning', body: 'Before weighing out reagents, chemists convert the target moles of product back through the mole ratio to know exactly how many moles (and then grams) of each reactant to use.' },
  { emoji: '🚀', title: 'Propellant mixing', body: 'Combustion mole ratios (fuel to oxidizer) determine how much of each propellant component to load so the reaction goes to completion without excess unburned fuel or leftover oxidizer.' },
];

const misconceptions = [
  { claim: '"Mole ratio and mass ratio are the same thing."', truth: 'They are not. A mole ratio compares particle counts; converting to a mass ratio requires multiplying each side by its own molar mass. 3:2 moles of H₂:NH₃ is not 3:2 by mass, because H₂ (2 g/mol) and NH₃ (17 g/mol) have very different molar masses.' },
  { claim: '"You can read mole ratios off an unbalanced equation."', truth: 'The coefficients must come from a correctly balanced equation. An unbalanced equation\'s numbers do not reflect a real conservation-of-mass relationship, so any ratio taken from it is wrong.' },
  { claim: '"The mole ratio tells you which reactant is limiting."', truth: 'The mole ratio alone does not — you also need the actual moles of each reactant on hand. Comparing the available mole ratio to the required (stoichiometric) mole ratio is what identifies the limiting reagent.' },
  { claim: '"A 1:1 mole ratio means equal masses react."', truth: 'Equal moles, not equal masses, unless the two substances happen to share the same molar mass. 1 mol of C (12 g) reacting 1:1 with 1 mol of O₂ (32 g) does not use equal masses.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 4.2, Reaction Stoichiometry and mole ratios (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/4-2-classifying-chemical-reactions" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 3, Stoichiometry: Calculations with Chemical Formulas and Equations.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Chapter 3, section on stoichiometric calculations and mole ratios.' },
];
const sourcesNote = 'Mole ratio = ratio of balanced-equation coefficients. This tool solves one species pair (A, B) at a time; results are rounded for display.';

const howToUse = [
  { title: 'Enter both coefficients', body: 'Type the balanced coefficient of species A and of species B.' },
  { title: 'Enter one mole value', body: 'Fill in moles of A or moles of B — the other solves automatically.' },
  { title: 'See the ratio visually', body: 'The 3D diagrams show a fixed mole-ratio pile comparison and the moles-B-vs-moles-A line.' },
];

const related = [
  { href: '/tools/chemical-equation-balancer', emoji: '🧮', title: 'Chemical Equation Balancer', desc: 'Get whole-number coefficients to feed this tool.' },
  { href: '/tools/atomic-mass-calculator', emoji: '🔬', title: 'Molar Mass Calculator', desc: 'Molar mass from a chemical formula.' },
  { href: '/tools/limiting-reagent-calculator', emoji: '⚖️', title: 'Limiting Reagent Calculator', desc: 'Find which reactant runs out first, plus excess.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="the coefficients of a balanced equation are a fixed exchange rate between moles of any two species — multiply the moles you know by that ratio to get the moles you don't."
  howIntro="Because coefficients are whole numbers fixed by conservation of mass, the mole ratio c<sub>B</sub>/c<sub>A</sub> is exact and constant — it does not depend on how much of A you actually have. Doubling moles of A doubles moles of B; the ratio itself never changes."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where mole ratios actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Enter the balanced-equation coefficients of species A and B, then the moles of one of them.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Coefficient of A (c<sub>A</sub>)</span>
        <input id="cA" type="number" step="any" min="0" placeholder="e.g. 1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Coefficient of B (c<sub>B</sub>)</span>
        <input id="cB" type="number" step="any" min="0" placeholder="e.g. 2" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Moles of A</span>
        <input id="molA" type="number" step="any" placeholder="mol" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Moles of B</span>
        <input id="molB" type="number" step="any" placeholder="mol" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mole ratio (B:A)</div><div id="r-ratio" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Moles of A</div><div id="r-molA" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Moles of B</div><div id="r-molB" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="mr-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static auto-rotating diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-piles" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. The ratio fixes relative pile size</h3>
          <p class="mt-1 text-sm text-slate-600">For the Haber process (N₂ + 3H₂ → 2NH₃), a fixed 1:3 mole-ratio pile of <span class="font-semibold text-indigo-600">N₂</span> (indigo) vs <span class="font-semibold text-emerald-600">H₂</span> (green) — three times as many H₂ spheres, always, no matter the actual amount.</p>
        </div>
        <div>
          <div id="diag-ratioline" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Bigger amounts, same ratio</h3>
          <p class="mt-1 text-sm text-slate-600">Three fixed points along the moles-B-vs-moles-A line, all sharing one slope (the ratio) — doubling moles of A always doubles moles of B, no matter which point you start from.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Mole ratio graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Moles A vs moles B at the current ratio</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-bar"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Moles B as moles A varies (slope = ratio)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-line"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('mr-err').textContent = '';
        ['r-ratio', 'r-molA', 'r-molB'].forEach((id) => (el(id).textContent = '—'));
        const cA = parseFloat(el('cA').value), cB = parseFloat(el('cB').value);
        const molA = parseFloat(el('molA').value), molB = parseFloat(el('molB').value);
        if (isNaN(cA) || isNaN(cB) || cA <= 0 || cB <= 0) {
          if (!isNaN(cA) && cA <= 0) el('mr-err').textContent = 'Coefficient of A must be greater than zero.';
          else if (!isNaN(cB) && cB <= 0) el('mr-err').textContent = 'Coefficient of B must be greater than zero.';
          return;
        }
        el('r-ratio').textContent = fmt(cB / cA) + ' : 1';
        const haveA = !isNaN(molA), haveB = !isNaN(molB);
        if (!haveA && !haveB) return;
        if (haveA && !haveB) {
          el('r-molA').textContent = fmt(molA) + ' mol';
          el('r-molB').textContent = fmt(molA * (cB / cA)) + ' mol';
        } else if (haveB && !haveA) {
          el('r-molB').textContent = fmt(molB) + ' mol';
          el('r-molA').textContent = fmt(molB * (cA / cB)) + ' mol';
        } else {
          el('r-molA').textContent = fmt(molA) + ' mol';
          el('r-molB').textContent = fmt(molB) + ' mol';
        }
      }
      ['cA', 'cB', 'molA', 'molB'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts (fixed illustrative state, matches worked example 1) ----
      const charts = {};
      const FIXED_STATE = { a: 4, b: 4 * (2 / 3), r: 2 / 3 };

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.bar = new Chart(el('chart-bar'), {
          type: 'bar',
          data: { labels: ['Species A', 'Species B'], datasets: [{ label: 'Moles', data: [0, 0], backgroundColor: ['#6366f1', '#10b981'], borderRadius: 4 }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Moles' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.line = new Chart(el('chart-line'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Moles B', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Moles A' } }, y: { title: { display: true, text: 'Moles B' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(FIXED_STATE);
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        charts.bar.data.datasets[0].data = [+s.a.toFixed(4), +s.b.toFixed(4)];
        charts.bar.update();
        const L = [], D = [];
        for (let aa = 0; aa <= 10.001; aa += 0.5) { L.push(aa.toFixed(1)); D.push(+(aa * s.r).toFixed(4)); }
        charts.line.data.labels = L; charts.line.data.datasets[0].data = D; charts.line.update();
      }

      // ---- static diagram 1: fixed 1:3 mole-ratio piles ----
      function initDiagPiles() {
        const c = el('diag-piles'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), SCENE_OPTS);
        const geoA = new THREE.SphereGeometry(0.32, 14, 14);
        const matA = new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.4 });
        const matB = new THREE.MeshStandardMaterial({ color: 0x10b981, roughness: 0.4 });
        function pile(count, offsetX, mat) {
          const perRow = 3;
          for (let i = 0; i < count; i++) {
            const row = Math.floor(i / (perRow * perRow));
            const idx2 = i % (perRow * perRow);
            const rr = Math.floor(idx2 / perRow), cc = idx2 % perRow;
            const p = new THREE.Mesh(geoA, mat);
            p.position.set(offsetX + (cc - (perRow - 1) / 2) * 0.75, row * 0.7 - 1.2, (rr - (perRow - 1) / 2) * 0.75);
            s.scene.add(p);
          }
        }
        pile(3, -3, matA);   // N2, fixed illustrative count
        pile(9, 3, matB);    // H2, 3x the N2 count (1:3 ratio)
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagPiles = { resize: s.resize };
      }

      // ---- static diagram 2: fixed points on the moles-B-vs-moles-A line ----
      function initDiagRatioLine() {
        const c = el('diag-ratioline'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(4, 3, 0), SCENE_OPTS);
        const grid = new THREE.GridHelper(10, 10, 0xe2e8f0, 0xeef2f7); grid.position.set(4, 0, 0); s.scene.add(grid);
        const ratio = 2 / 3;
        const pts = [1, 4, 7].map((a) => new THREE.Vector3(a, a * ratio, 0));
        const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, 0, 0), new THREE.Vector3(8, 8 * ratio, 0)]), new THREE.LineBasicMaterial({ color: 0x4f46e5 }));
        s.scene.add(line);
        const dotGeo = new THREE.SphereGeometry(0.18, 12, 12);
        const dotMat = new THREE.MeshStandardMaterial({ color: 0x10b981 });
        pts.forEach((p) => { const m = new THREE.Mesh(dotGeo, dotMat); m.position.copy(p); s.scene.add(m); });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagRatioLine = { resize: s.resize };
      }

      let diagPiles = null, diagRatioLine = null;

      function boot() {
        try { update(); } catch (e) { console.error('[mole-ratio] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[mole-ratio] charts failed', e); }
        if (window.THREE) {
          try { initDiagPiles(); } catch (e) { console.error('[mole-ratio] piles diagram failed', e); }
          try { initDiagRatioLine(); } catch (e) { console.error('[mole-ratio] ratio-line diagram failed', e); }
        }
        mountResize([diagPiles, diagRatioLine]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
