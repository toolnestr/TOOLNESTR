---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Three-Phase Power Calculator';
const description = 'Calculate power, current, or voltage for 3-phase AC systems. Supports line-to-line and line-to-neutral configurations.';
const intro = 'Calculate power, current, or voltage for 3-phase systems.';
const category = { id: 'engineering', name: 'Electrical Engineering' };
const faqs = [
  { q: 'What is the difference between line-to-line and line-to-neutral?', a: 'Line-to-line voltage is measured between two phases; line-to-neutral is between one phase and neutral. Line-to-line = \u221a3 \u00d7 line-to-neutral.' },
  { q: 'What is power factor?', a: 'The ratio of real power (kW) to apparent power (kVA). Typical motor loads are 0.8\u20130.9.' },
  { q: 'How do I calculate 3-phase power?', a: 'P = \u221a3 \u00d7 V<sub>L-L</sub> \u00d7 I \u00d7 PF for line-to-line. P = 3 \u00d7 V<sub>L-N</sub> \u00d7 I \u00d7 PF for line-to-neutral.' },
  { q: 'What is the \u221a3 (1.732) for?', a: 'It is the square root of 3, which relates line-to-line voltage to line-to-neutral voltage in a balanced 3-phase system.' },
];
const sources = [
  { html: "<strong>NFPA 70 — National Electrical Code (NEC)</strong>, conduit fill, box fill and conductor ampacity. <a href=\"https://www.nfpa.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nfpa.org</a>" },
  { html: "<strong>IPC-2221</strong>, Generic Standard on Printed Board Design (trace width / current). <a href=\"https://www.ipc.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">ipc.org</a>" },
  { html: "<strong>NIST</strong> reference constants and unit definitions; <strong>IEEE</strong> standards where applicable. <a href=\"https://www.nist.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nist.gov</a>" },
];
const sourcesNote = "For educational and preliminary use. Verify against full engineering calculations and the governing standard before any real design.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <fieldset class="mb-4 flex gap-4">
      <legend class="sr-only">Voltage configuration</legend>
      <label class="flex cursor-pointer items-center gap-2 rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 has-[:checked]:border-indigo-400 has-[:checked]:bg-indigo-50 has-[:checked]:text-indigo-700">
        <input type="radio" name="config" id="config-ll" value="ll" checked class="sr-only" />
        <span class="flex h-4 w-4 items-center justify-center rounded-full border border-slate-400 has-[:checked]:border-indigo-600"><span class="hidden h-2 w-2 rounded-full bg-indigo-600 has-[:checked]:block"></span></span>
        Line-to-Line
      </label>
      <label class="flex cursor-pointer items-center gap-2 rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 has-[:checked]:border-indigo-400 has-[:checked]:bg-indigo-50 has-[:checked]:text-indigo-700">
        <input type="radio" name="config" id="config-ln" value="ln" class="sr-only" />
        <span class="flex h-4 w-4 items-center justify-center rounded-full border border-slate-400"><span class="hidden h-2 w-2 rounded-full bg-indigo-600"></span></span>
        Line-to-Neutral
      </label>
    </fieldset>

    <p class="mb-4 text-xs text-slate-400">Enter any 2 values to solve for the others &mdash; or enter 3 for a precise result.</p>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Voltage (V)</span>
        <input id="v" type="number" step="any" placeholder="400" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current (A)</span>
        <input id="i" type="number" step="any" placeholder="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Power (kW)</span>
        <input id="kw" type="number" step="any" placeholder="62.35" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Power Factor (0 &ndash; 1)</span>
        <input id="pf" type="number" step="any" placeholder="0.9" min="0" max="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <button id="calc-btn" class="mt-5 w-full rounded-xl bg-indigo-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700 active:bg-indigo-800">Calculate</button>

    <div id="note" class="mt-3 hidden text-center text-xs text-amber-600"></div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Voltage</div><div id="r-v" class="mt-1 text-xl font-bold">&mdash;</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Current</div><div id="r-i" class="mt-1 text-xl font-bold text-emerald-600">&mdash;</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Power (kW)</div><div id="r-kw" class="mt-1 text-xl font-bold text-amber-600">&mdash;</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Power Factor</div><div id="r-pf" class="mt-1 text-xl font-bold text-slate-800">&mdash;</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How three-phase power calculation works</h2>
    <p class="mt-2 text-slate-600">Three-phase power is the dominant method of electrical power distribution for industrial, commercial, and large residential applications. Unlike single-phase systems that deliver power in pulses, three-phase systems deliver constant power because the three waveforms are offset by 120 degrees. This makes three-phase systems more efficient for high-power loads and allows smaller conductor sizes for the same power delivery.</p>
    <p class="mt-3 text-slate-600">For a balanced three-phase system, the relationship between voltage, current, power, and power factor is governed by two key formulas depending on how voltage is measured. If you are working with line-to-line voltage (the voltage between any two phases), the real power in kilowatts is P = &radic;3 &times; V<sub>L-L</sub> &times; I &times; PF / 1000. If you are working with line-to-neutral voltage (the voltage between one phase and the neutral point, available only in wye configurations), the formula becomes P = 3 &times; V<sub>L-N</sub> &times; I &times; PF / 1000.</p>
    <p class="mt-3 text-slate-600">The &radic;3 factor (approximately 1.732) appears because the line-to-line voltage is &radic;3 times larger than the phase voltage in a balanced wye system. This factor adjusts the single-phase power equation to account for the contribution of all three phases. Understanding which voltage configuration your system uses is critical to getting correct results.</p>
  </section>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ph3-title ph3-desc">
      <title id="ph3-title">Three-phase power sine waves 120 degrees apart</title>
      <desc id="ph3-desc">Three sine waves phase-shifted by 120 degrees representing phases A, B, and C in a three-phase AC system</desc>
      <g transform="translate(40,15)">
        <text x="360" y="20" text-anchor="middle" fill="#475569" font-size="14" font-weight="bold">Three-Phase Waveforms (120&deg; apart)</text>
        <line x1="0" y1="95" x2="720" y2="95" stroke="#cbd5e1" stroke-width="1"/>
        <!-- Phase A (red) -->
        <path d="M0 95 C30 15 60 15 90 95 C120 175 150 175 180 95 C210 15 240 15 270 95 C300 175 330 175 360 95 C390 15 420 15 450 95 C480 175 510 175 540 95 C570 15 600 15 630 95 C660 175 690 175 720 95" stroke="#ef4444" stroke-width="2.5" fill="none"/>
        <text x="45" y="85" fill="#ef4444" font-size="11" font-weight="bold">A</text>
        <!-- Phase B (indigo) -->
        <path d="M0 175 C30 95 60 95 90 175 C120 255 150 255 180 175 C210 95 240 95 270 175 C300 255 330 255 360 175 C390 95 420 95 450 175 C480 255 510 255 540 175 C570 95 600 95 630 175 C660 255 690 255 720 175" stroke="#6366f1" stroke-width="2.5" fill="none"/>
        <text x="165" y="85" fill="#6366f1" font-size="11" font-weight="bold">B</text>
        <!-- Phase C (green) -->
        <path d="M0 175 C30 255 60 255 90 175 C120 95 150 95 180 175 C210 255 240 255 270 175 C300 95 330 95 360 175 C390 255 420 255 450 175 C480 95 510 95 540 175 C570 255 600 255 630 175 C660 95 690 95 720 175" stroke="#10b981" stroke-width="2.5" fill="none"/>
        <text x="285" y="85" fill="#10b981" font-size="11" font-weight="bold">C</text>
        <line x1="60" y1="100" x2="60" y2="145" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="2"/>
        <line x1="180" y1="100" x2="180" y2="145" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="2"/>
        <line x1="300" y1="100" x2="300" y2="145" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="2"/>
        <text x="60" y="157" text-anchor="middle" fill="#94a3b8" font-size="10">0&deg;</text>
        <text x="180" y="157" text-anchor="middle" fill="#94a3b8" font-size="10">120&deg;</text>
        <text x="300" y="157" text-anchor="middle" fill="#94a3b8" font-size="10">240&deg;</text>
        <line x1="420" y1="100" x2="420" y2="145" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="2"/>
        <text x="420" y="157" text-anchor="middle" fill="#94a3b8" font-size="10">360&deg;</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Three-phase power: three sine waves phase-shifted by 120 degrees deliver constant combined power</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Three-phase power formulas</h2>
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
        <h3 class="font-semibold text-slate-900">Line-to-Line</h3>
        <div class="mt-2 space-y-1 text-sm text-slate-600">
          <p>P = &radic;3 &times; V<sub>L-L</sub> &times; I &times; PF</p>
          <p>S = &radic;3 &times; V<sub>L-L</sub> &times; I</p>
          <p>Q = &radic;3 &times; V<sub>L-L</sub> &times; I &times; sin(arccos(PF))</p>
        </div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
        <h3 class="font-semibold text-slate-900">Line-to-Neutral (Wye only)</h3>
        <div class="mt-2 space-y-1 text-sm text-slate-600">
          <p>P = 3 &times; V<sub>L-N</sub> &times; I &times; PF</p>
          <p>S = 3 &times; V<sub>L-N</sub> &times; I</p>
          <p>Q = 3 &times; V<sub>L-N</sub> &times; I &times; sin(arccos(PF))</p>
        </div>
      </div>
    </div>
    <p class="mt-3 text-sm text-slate-500">Where P is real power (W), S is apparent power (VA), Q is reactive power (VAR), V is voltage (V), I is current (A), and PF is power factor. Divide by 1000 for kW/kVA/kVAR.</p>

    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Given:</span> <span class="text-slate-600">400 V line-to-line, 100 A, PF 0.9</span></div>
        <div><span class="font-medium text-slate-700">Power:</span> <span class="text-slate-600">P = 1.732 &times; 400 &times; 100 &times; 0.9 = 62,352 W = <strong>62.35 kW</strong></span></div>
        <div><span class="font-medium text-slate-700">Apparent power:</span> <span class="text-slate-600">S = 1.732 &times; 400 &times; 100 = 69,280 VA = <strong>69.28 kVA</strong></span></div>
        <div><span class="font-medium text-slate-700">Reactive power:</span> <span class="text-slate-600">Q = 69.28 &times; sin(arccos(0.9)) = <strong>30.19 kVAR</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#9881;&#65039;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Motor Sizing</h3>
      <p class="mt-1 text-sm text-slate-600">Determine the required current and power for three-phase induction motors based on voltage and power factor. Essential for selecting motor starters, contactors, and overload protection.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#9889;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Electrical Load Calculations</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate total load current when adding new three-phase equipment to an existing panel or distribution board. Ensures you stay within the rated capacity of breakers, busbars, and feeders.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#9889;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Generator Sizing</h3>
      <p class="mt-1 text-sm text-slate-600">Size backup generators correctly by converting load kW to kVA at the expected power factor. A generator rated 500 kVA at 0.8 PF can supply 400 kW of real power continuously.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#128290;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Transformer Rating</h3>
      <p class="mt-1 text-sm text-slate-600">Transformers are rated in kVA because their thermal limit depends on current (heating), not real power. Use this calculator to verify that a transformer can handle both the kW load and the reactive power.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for using the three-phase power calculator</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Balanced load assumption</h3>
        <p class="mt-1 text-sm text-slate-600">This calculator assumes a perfectly balanced three-phase system where all three phases carry equal current and have the same power factor. In real-world installations, some imbalance is normal, but large imbalances should be investigated as they indicate wiring issues or uneven load distribution.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Power factor varies by load type</h3>
        <p class="mt-1 text-sm text-slate-600">Induction motors typically have a power factor of 0.7 to 0.9 at full load, dropping significantly at partial load. Resistive loads like heaters and lighting have PF near 1.0. Variable frequency drives (VFDs) include built-in PF correction and often achieve 0.95 or higher.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Enter 3 values for complete accuracy</h3>
        <p class="mt-1 text-sm text-slate-600">When you enter only voltage and current, the calculator assumes a power factor of 1.0 to compute power. For an accurate result that accounts for reactive power, always enter all three known values: voltage, current, and either power factor or real power.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Know your system configuration</h3>
        <p class="mt-1 text-sm text-slate-600">Always verify whether your system uses line-to-line or line-to-neutral voltage. Selecting the wrong configuration will give results that are off by a factor of &radic;3. If you are unsure, check the nameplate of your equipment or consult the system one-line diagram.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/power-factor-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">Power Factor Calculator</a>
      <a href="/tools/kva-to-kw-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">kVA to kW Converter</a>
      <a href="/tools/transformer-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">Transformer Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const SQRT3 = Math.sqrt(3);
    let updating = false;

    function fmt(n) {
      return parseFloat(n.toFixed(4)).toString();
    }

    function clearResults() {
      ['r-v','r-i','r-kw','r-pf'].forEach(id => el(id).textContent = '\u2014');
      el('note').classList.add('hidden');
    }

    function update(source) {
      if (updating) return;
      updating = true;

      const isLL = el('config-ll').checked;
      const factor = isLL ? SQRT3 : 3;

      const v = parseFloat(el('v').value);
      const i = parseFloat(el('i').value);
      const p = parseFloat(el('kw').value);
      const pf = parseFloat(el('pf').value);

      const hasV = !isNaN(v) && v > 0;
      const hasI = !isNaN(i) && i > 0;
      const hasP = !isNaN(p) && p >= 0;
      const hasPF = !isNaN(pf) && pf >= 0 && pf <= 1;

      const count = (hasV ? 1 : 0) + (hasI ? 1 : 0) + (hasP ? 1 : 0) + (hasPF ? 1 : 0);

      if (count < 2) {
        clearResults();
        updating = false;
        return;
      }

      let rV = NaN, rI = NaN, rP = NaN, rPF = NaN;
      let note = '';

      // P_kW = factor * V * I * PF / 1000
      if (count >= 3) {
        if (!hasV) {
          rV = p * 1000 / (factor * i * pf);
          rI = i; rP = p; rPF = pf;
        } else if (!hasI) {
          rI = p * 1000 / (factor * v * pf);
          rV = v; rP = p; rPF = pf;
        } else if (!hasP) {
          rP = factor * v * i * pf / 1000;
          rV = v; rI = i; rPF = pf;
        } else if (!hasPF) {
          rPF = p * 1000 / (factor * v * i);
          rV = v; rI = i; rP = p;
          if (rPF > 1) { rPF = NaN; note = 'Power factor > 1. Check your values.'; }
        }
      } else {
        if (hasV && hasI) {
          rV = v; rI = i;
          if (hasPF) {
            rPF = pf;
            rP = factor * v * i * pf / 1000;
          } else if (hasP) {
            rP = p;
            rPF = p * 1000 / (factor * v * i);
            if (rPF > 1) { rPF = NaN; note = 'Power factor > 1. Check your values.'; }
          } else {
            rP = factor * v * i / 1000;
            note = 'PF assumed 1.0 \u2014 enter PF or power for accuracy.';
          }
        } else if (hasV && hasP) {
          rV = v; rP = p;
          if (hasPF) {
            rPF = pf;
            rI = p * 1000 / (factor * v * pf);
          } else if (hasI) {
            rI = i;
            rPF = p * 1000 / (factor * v * i);
            if (rPF > 1) { rPF = NaN; note = 'Power factor > 1. Check your values.'; }
          } else {
            rI = p * 1000 / (factor * v);
            note = 'PF assumed 1.0 \u2014 enter PF or current for accuracy.';
          }
        } else if (hasI && hasP) {
          rI = i; rP = p;
          if (hasPF) {
            rPF = pf;
            rV = p * 1000 / (factor * i * pf);
          } else if (hasV) {
            rV = v;
            rPF = p * 1000 / (factor * v * i);
            if (rPF > 1) { rPF = NaN; note = 'Power factor > 1. Check your values.'; }
          } else {
            rV = p * 1000 / (factor * i);
            note = 'PF assumed 1.0 \u2014 enter PF or voltage for accuracy.';
          }
        } else if (hasPF && hasV) {
          note = 'Enter current or power to calculate.';
        } else if (hasPF && hasI) {
          note = 'Enter voltage or power to calculate.';
        } else if (hasPF && hasP) {
          note = 'Enter voltage or current to calculate.';
        }
      }

      if (note) {
        el('note').textContent = note;
        el('note').classList.remove('hidden');
      } else {
        el('note').classList.add('hidden');
      }

      const label = isLL ? ' L-L' : ' L-N';

      el('r-v').textContent = isNaN(rV) ? '\u2014' : rV.toFixed(2) + ' V' + label;
      el('r-i').textContent = isNaN(rI) ? '\u2014' : rI.toFixed(2) + ' A';
      el('r-kw').textContent = isNaN(rP) ? '\u2014' : rP.toFixed(2) + ' kW';
      el('r-pf').textContent = isNaN(rPF) ? '\u2014' : rPF.toFixed(4);

      if (source !== 'v' && !isNaN(rV)) el('v').value = fmt(rV);
      if (source !== 'i' && !isNaN(rI)) el('i').value = fmt(rI);
      if (source !== 'kw' && !isNaN(rP)) el('kw').value = fmt(rP);
      if (source !== 'pf' && !isNaN(rPF) && rPF <= 1) el('pf').value = fmt(rPF);

      updating = false;
    }

    ['v','i','kw','pf'].forEach(id => {
      el(id).addEventListener('input', () => update(id));
    });

    document.querySelectorAll('input[name="config"]').forEach(r => {
      r.addEventListener('change', () => update());
    });

    el('calc-btn').addEventListener('click', () => update());
  </script>
</ToolLayout>
