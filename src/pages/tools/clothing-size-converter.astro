---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Clothing Size Converter (US/UK/EU/Asia)';
const description = 'Convert clothing sizes between US, UK, EU, and Asian sizing systems for women\'s and men\'s tops, dresses, and bottoms.';
const intro = 'Convert a clothing size between US, UK, EU, and Asian charts for women\'s and men\'s apparel.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Are these conversions exact across every brand?', a: 'No. This chart reflects the general industry-standard relationship between sizing systems. Individual brands run their own size charts that can differ by a size or more, especially fast-fashion and luxury labels, so always check the brand\'s own chart when possible.' },
  { q: 'Why does EU sizing use such different numbers than US?', a: 'EU sizing traditionally derives from body measurements in centimeters rather than a separate arbitrary scale, so EU numbers run roughly 32 higher than the equivalent US women\'s number and about 8-10 higher than the men\'s chest-based letter sizes converted to numbers.' },
  { q: 'What does "Asia" sizing mean here?', a: 'Many Asian retailers (particularly Japan, South Korea, and China) publish their own size charts. This converter uses the common general-market Asian numeric equivalent seen on international retail sites; Japanese domestic brands in particular often run smaller than this general chart.' },
  { q: 'Should I size up when ordering from a different country?', a: 'If you are between two converted sizes, sizing up is usually the safer choice for wovens and structured garments, while stretch/knit fabrics have more forgiveness either way.' },
  { q: 'Is men\'s sizing converted the same way as women\'s?', a: 'No — men\'s tops are usually sized by letter (S/M/L/XL) tied to a chest measurement range, not a numeric scale, so this tool uses a separate men\'s chest-based table rather than the women\'s numeric offset.' },
];
const howTo = {
  name: 'How to convert a clothing size between countries',
  steps: [
    { name: 'Choose department', text: 'Select Women\'s or Men\'s, since the two use different sizing logic.' },
    { name: 'Pick your known size', text: 'Choose the size you already know, in whichever system it is labeled.' },
    { name: 'Read the converted sizes', text: 'The equivalent US, UK, EU, and Asia sizes appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Women\'s', 'Men\'s'].map((d) => (
        <button data-dept={d} class="dept-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Known size system</span>
      <select id="system" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
        <option value="US">US</option>
        <option value="UK">UK</option>
        <option value="EU">EU</option>
        <option value="Asia">Asia</option>
      </select>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Size</span>
      <select id="size" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100"></select>
    </div>
    <div id="results" class="mt-6 grid gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">US</div><div id="r-us" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">UK</div><div id="r-uk" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">EU</div><div id="r-eu" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Asia</div><div id="r-asia" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="240" viewBox="0 0 800 240" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="csc-title csc-desc">
      <title id="csc-title">Clothing size conversion scale diagram</title>
      <desc id="csc-desc">A horizontal scale showing how US, UK, EU and Asia clothing sizes line up relative to one another</desc>
      <line x1="80" y1="120" x2="720" y2="120" stroke="#c026d3" stroke-width="3" />
      {[ [80,'US'], [280,'UK'], [480,'EU'], [680,'Asia'] ].map(([x, label]) => (
        <>
          <circle cx={x} cy="120" r="8" fill="#c026d3" />
          <text x={x} y="100" text-anchor="middle" font-size="15" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">{label}</text>
        </>
      ))}
      <text x="400" y="170" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Each system numbers the same body differently — EU runs highest, US lowest</text>
      <text x="400" y="195" text-anchor="middle" font-size="12" fill="#94a3b8" font-family="system-ui,sans-serif">UK ≈ US + 4 · EU ≈ US + 32 · Asia varies by region</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Relative position of each sizing system along the same size range</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How clothing size conversion works</h2>
    <p class="mt-2 text-slate-600">
      This converter translates a clothing size between the four sizing systems shoppers run into most often: US, UK, EU, and a general Asia market equivalent. Women's tops and dresses use a numeric scale in every system, but the numbers themselves are offset — a US size 8 is roughly a UK 12 and an EU 40, even though it is the same garment. Men's tops instead use letter sizes (S, M, L) tied to a chest measurement range, so this tool switches to a chest-based table when you select Men's.
    </p>
    <p class="mt-3 text-slate-600">
      The women's numeric relationship follows the general pattern used across most international retailers: UK size is roughly the US size plus 4, EU is roughly the US size plus 32, and general Asia-market numeric sizing runs its own separate scale that is smaller in number than EU but does not track US or UK by a fixed offset. Men's sizing converts through a chest-circumference lookup table rather than a fixed offset, since letter sizes map to a range rather than a single number.
    </p>
    <p class="mt-3 text-xs text-slate-400">Sizing relationships follow the general international apparel-industry conversion standard also referenced in ASTM D5585 (US Misses sizing) and ISO 3635 (international garment size designation); individual brands publish their own charts that can vary from this general standard.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A shopper wears a US women's size 8 and wants to order a dress from a UK retailer.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">US size:</span> <span class="text-slate-600">8</span></div>
        <div><span class="font-medium text-slate-700">UK equivalent:</span> <span class="text-slate-600">8 + 4 = <strong>UK 12</strong></span></div>
        <div><span class="font-medium text-slate-700">EU equivalent:</span> <span class="text-slate-600">8 + 32 = <strong>EU 40</strong></span></div>
        <div><span class="font-medium text-slate-700">Asia equivalent:</span> <span class="text-slate-600">general market <strong>Asia L</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      International online shopping is the most common reason people reach for a size converter — a US shopper ordering from a UK-based retailer, or a UK shopper buying from a European brand's own site, needs to know that the number on the page does not mean what it would at home. A US women's 8 buyer who orders a European size 8 without converting would end up with a garment several sizes too small, since that EU 8 is closer to a US size -24 on the numeric relationship — effectively impossible, which is exactly why so many first-time cross-border orders come back as returns.
    </p>
    <p class="mt-3 text-slate-600">
      Travelers and expats run into the same gap in person. Someone who has always bought a UK 14 moving to the US will find that number simply does not exist on most American racks, where the equivalent is a US 10 — knowing the conversion in advance saves an awkward changing-room guessing game.
    </p>
    <p class="mt-3 text-slate-600">
      Resale and secondhand shopping across borders (eBay, Vinted, Depop international listings) is a fast-growing use case, since sellers often list the size as originally labeled without noting the country, leaving buyers to convert it themselves before bidding.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A US 8 is always exactly a UK 12 everywhere." <strong class="text-slate-900">Not quite.</strong> That is the general industry relationship, but individual brands shift it by a size or more — a UK fast-fashion brand may run its 12 closer to a US 6, while a UK heritage tailoring brand may run closer to a US 10. Always check brand-specific charts for a precise fit.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Asia sizing is just one universal scale." <strong class="text-slate-900">It isn't.</strong> Japanese, Korean, and Chinese domestic sizing each use their own logic and tend to run smaller than the general international "Asia" size shown on global retail sites, which is itself an approximation aimed at international shoppers rather than a domestic standard.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/dress-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Dress Size Calculator</a>
      <a href="/tools/shoe-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Shoe Size Converter</a>
      <a href="/tools/jacket-suit-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Jacket/Suit Size Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let dept = "Women's";

    // Women's numeric tops/dresses: [US, UK, EU, Asia label]
    const women = [
      [0, 4, 32, 'XXS'], [2, 6, 34, 'XS'], [4, 8, 36, 'S'], [6, 10, 38, 'S'],
      [8, 12, 40, 'M'], [10, 14, 42, 'M'], [12, 16, 44, 'L'], [14, 18, 46, 'L'],
      [16, 20, 48, 'XL'], [18, 22, 50, 'XXL'], [20, 24, 52, 'XXXL'],
    ];
    // Men's tops by chest range: [label US/UK, EU, Asia, chestLowIn, chestHighIn]
    const men = [
      ['XS', 44, 'S', 34, 36], ['S', 46, 'M', 36, 38], ['M', 50, 'L', 38, 40],
      ['L', 52, 'XL', 40, 42], ['XL', 54, 'XXL', 42, 44], ['XXL', 56, 'XXXL', 44, 46],
      ['XXXL', 58, '4XL', 46, 48],
    ];

    function populateSizes() {
      const sizeSel = el('size');
      const sys = el('system').value;
      sizeSel.innerHTML = '';
      const table = dept === "Women's" ? women : men;
      table.forEach((row) => {
        let val;
        if (dept === "Women's") {
          val = sys === 'US' ? row[0] : sys === 'UK' ? row[1] : sys === 'EU' ? row[2] : row[3];
        } else {
          val = sys === 'Asia' ? row[2] : row[0]; // US/UK/EU all use the letter label for men's; Asia uses its own label
          val = sys === 'US' || sys === 'UK' ? row[0] : sys === 'EU' ? row[1] : row[2];
        }
        const opt = document.createElement('option');
        opt.value = table.indexOf(row);
        opt.textContent = val;
        sizeSel.appendChild(opt);
      });
      update();
    }

    function update() {
      const table = dept === "Women's" ? women : men;
      const idx = parseInt(el('size').value || '0', 10);
      const row = table[idx];
      if (!row) return;
      if (dept === "Women's") {
        el('r-us').textContent = 'US ' + row[0];
        el('r-uk').textContent = 'UK ' + row[1];
        el('r-eu').textContent = 'EU ' + row[2];
        el('r-asia').textContent = 'Asia ' + row[3];
      } else {
        el('r-us').textContent = 'US ' + row[0];
        el('r-uk').textContent = 'UK ' + row[0];
        el('r-eu').textContent = 'EU ' + row[1];
        el('r-asia').textContent = 'Asia ' + row[2];
      }
    }

    document.querySelectorAll('.dept-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.dept-btn').forEach((b) => {
          b.className = 'dept-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'dept-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        dept = btn.dataset.dept;
        populateSizes();
      });
    });

    el('system').addEventListener('change', populateSizes);
    el('size').addEventListener('change', update);
    document.querySelector('.dept-btn').click();
  </script>
</ToolLayout>
