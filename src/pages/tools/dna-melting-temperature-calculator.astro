---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'DNA Melting Temperature (Tm) Calculator';
const description = "DNA melting temperature calculator. Compute Tm using the Wallace rule (4(G+C)+2(A+T)) for short oligonucleotides, with worked examples.";
const intro = 'Enter a short DNA sequence to compute its melting temperature (Tm) using the Wallace rule, the classic formula for estimating when a short double-stranded DNA sequence separates into single strands. Two 3D diagrams compare a low-Tm and high-Tm double helix, and charts show how Tm scales with GC content and sequence length.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is DNA melting temperature (Tm)?', a: 'Melting temperature (Tm) is the temperature at which half of a double-stranded DNA sequence has separated into single strands. It depends primarily on sequence length and GC content.' },
  { q: 'What is the Wallace rule?', a: 'The Wallace rule is a simple formula for estimating Tm in short oligonucleotides (under about 14 bases): Tm = 4°C × (G+C count) + 2°C × (A+T count).' },
  { q: 'Why does GC content raise melting temperature?', a: 'G-C base pairs form three hydrogen bonds, while A-T pairs form only two — more hydrogen bonds means more energy (heat) is needed to break them apart, so GC-rich sequences have a higher melting temperature.' },
  { q: 'Does the Wallace rule work for long DNA sequences?', a: 'No — the Wallace rule is only accurate for short oligonucleotides (typically under 14 bases), like PCR primers. Longer sequences require more sophisticated formulas that account for nearest-neighbor base-stacking interactions and salt concentration.' },
  { q: 'How is Tm used in molecular biology techniques?', a: 'Tm is central to PCR primer design (setting the annealing temperature), DNA hybridization assays, and any technique requiring controlled separation and reannealing of DNA strands.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the DNA Melting Temperature Calculator',
  description: 'Compute the melting temperature of a short DNA sequence using the Wallace rule.',
  steps: [
    { name: 'Enter a short DNA sequence', text: 'Type a sequence under about 14 bases for accurate Wallace rule results.' },
    { name: 'Read the Tm', text: 'The estimated melting temperature solves instantly.' },
    { name: 'Check base composition', text: 'See the G/C and A/T counts driving the result.' },
  ],
};

const formulas = [
  { expr: 'Tm = 4°C × (G+C) + 2°C × (A+T)', note: "Wallace rule — valid for short oligonucleotides (<14 bases)" },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a GC-balanced 10-base primer', tone: 'slate',
    given: 'DNA sequence: GCGCATGCAT (10 bases)',
    rows: [
      { label: 'Base counts:', value: 'G=3, C=3, A=2, T=2 (GC total=6, AT total=4)' },
      { label: 'Formula:', value: 'Tm = 4×(G+C) + 2×(A+T)' },
      { label: 'Substitute:', value: 'Tm = 4×6 + 2×4 = 24 + 8' },
      { label: 'Result:', value: 'Tm = 32°C', full: true },
    ],
    note: 'This gives a quick estimate suitable for designing a PCR primer annealing step, though real-world protocols also apply a rule-of-thumb offset below Tm for the actual annealing temperature.',
  },
  {
    title: 'Worked example 2 — a GC-rich short sequence', tone: 'amber',
    given: 'DNA sequence: GCGCGCCGGC (10 bases)',
    rows: [
      { label: 'Base counts:', value: 'G=6, C=4, A=0, T=0 (GC total=10, AT total=0)' },
      { label: 'Formula:', value: 'Tm = 4×(G+C) + 2×(A+T)' },
      { label: 'Substitute:', value: 'Tm = 4×10 + 2×0 = 40 + 0' },
      { label: 'Result:', value: 'Tm = 40°C', full: true },
    ],
    note: 'Compared to the balanced example above, this fully GC sequence has a notably higher Tm (40°C vs 32°C) — a direct consequence of G-C pairs\' extra hydrogen bond.',
  },
];

const comparison = {
  heading: 'How GC content affects Tm for a 10-base sequence',
  note: 'Every base pair matters — replacing an A-T pair with a G-C pair raises the Wallace-rule Tm estimate by exactly 2°C per swap.',
  headers: [{ label: 'GC count (of 10)' }, { label: 'AT count' }, { label: 'Tm' }],
  rows: [
    ['0', '10', '20°C'],
    ['4', '6', '28°C'],
    ['6 ★', '4', '32°C'],
    ['10', '0', '40°C'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). The Wallace rule\'s simplicity — a fixed +4°C per G/C base and +2°C per A/T base — makes it fast for rough estimates, though it ignores base order and neighboring-base effects.',
};

const realWorld = [
  { emoji: '🧪', title: 'PCR primer design', body: 'Molecular biologists calculate primer Tm to choose an appropriate annealing temperature for PCR, typically setting the actual annealing temperature a few degrees below the calculated Tm.' },
  { emoji: '🔬', title: 'DNA probe and hybridization assay design', body: 'Techniques like Southern blotting and fluorescent in situ hybridization (FISH) depend on carefully matched probe Tm values to ensure specific, reliable binding to target sequences.' },
  { emoji: '🧬', title: 'Restriction enzyme reaction optimization', body: 'Understanding local DNA melting behavior helps researchers optimize conditions for enzymes that require specific double-strand or single-strand DNA states to function.' },
  { emoji: '🎓', title: 'Teaching DNA thermodynamics', body: 'The Wallace rule is often students\' first quantitative introduction to how base composition determines a physical property of DNA, bridging chemistry and molecular biology concepts.' },
];

const misconceptions = [
  { claim: '"The Wallace rule accurately predicts Tm for any length of DNA sequence."', truth: 'The Wallace rule is only accurate for very short oligonucleotides (under about 14 bases) — for longer sequences, more sophisticated formulas incorporating nearest-neighbor thermodynamics and salt concentration are needed for accurate predictions.' },
  { claim: '"Two sequences with the same GC content always have the same Tm."', truth: 'The Wallace rule treats all G/C and A/T bases as contributing equally regardless of order, but more precise nearest-neighbor models show that the actual arrangement of bases (not just the overall GC%) does affect real melting behavior, especially for longer sequences.' },
  { claim: '"Melting temperature means the DNA physically melts like ice, into a liquid."', truth: '"Melting" in this context refers specifically to the double helix separating into two single strands (denaturation) — the DNA doesn\'t change physical state like ice to water; the two strands simply come apart from each other.' },
  { claim: '"Higher Tm always makes a PCR reaction work better."', truth: "PCR primers need a Tm in a sensible, moderate range (commonly 50-65°C) and — just as importantly — the two primers in a reaction should have SIMILAR Tm values to each other, not simply the highest possible Tm." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 14, "DNA Structure and Function" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/14-1-historical-basis-of-modern-understanding" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Wallace, Shaffer, et al. (1979)</strong> — "Hybridization of synthetic oligodeoxyribonucleotides," <em>Nucleic Acids Research</em> (original Wallace rule reference).' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Chapter 4, DNA, Chromosomes, and Genomes.' },
];
const sourcesNote = 'Tm = 4(G+C) + 2(A+T), the Wallace rule, valid for short oligonucleotides under ~14 bases. Longer sequences need nearest-neighbor thermodynamic models for accuracy.';

const howToUse = [
  { title: 'Enter a short DNA sequence', body: 'Type a sequence under about 14 bases for the Wallace rule to apply accurately.' },
  { title: 'Read the melting temperature', body: 'Tm solves instantly based on the base composition.' },
  { title: 'Check the base breakdown', body: 'See exactly how many G/C versus A/T bases are driving the result.' },
];

const related = [
  { href: '/tools/gc-content-calculator', emoji: '🔬', title: 'GC Content Calculator', desc: 'GC% = (G+C)/total bases × 100.' },
  { href: '/tools/pcr-annealing-temperature-calculator', emoji: '🧫', title: 'PCR Primer Annealing Temperature Calculator', desc: 'Estimate annealing temperature from primer Tm.' },
  { href: '/tools/reverse-complement-calculator', emoji: '🔄', title: 'Reverse Complement Sequence Tool', desc: 'Find the reverse complement of a DNA strand.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a G-C base pair is held together by three hydrogen bonds while an A-T pair has only two, so every G or C in a short DNA sequence contributes more thermal stability than every A or T — a fact the Wallace rule turns directly into a simple per-base temperature contribution."
  howIntro="The Wallace rule assigns a fixed temperature contribution to each base based purely on its hydrogen-bonding strength: 4°C for every G or C (three hydrogen bonds each) and 2°C for every A or T (two hydrogen bonds each), then sums these contributions across the whole short sequence. This simple additive model works well for short oligonucleotides where neighboring-base interactions have limited room to matter, which is exactly the length range (roughly under 14 bases) most relevant to PCR primer design."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where DNA melting temperature actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">DNA sequence (short, &lt;14 bases recommended)</span>
      <input id="seq" type="text" value="GCGCATGCAT" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Melting temperature (Tm)</div><div id="r-tm" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">GC : AT count</div><div id="r-counts" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="tm-err" class="mt-3 text-center text-sm text-amber-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Low-Tm vs high-Tm double helix</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-low" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. An AT-rich, low-Tm helix (loosely bonded)</h3>
          <p class="mt-1 text-sm text-slate-600">Only two hydrogen bonds per base pair — this helix separates at a relatively low temperature.</p>
        </div>
        <div>
          <div id="diag-high" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. A GC-rich, high-Tm helix (tightly bonded)</h3>
          <p class="mt-1 text-sm text-slate-600">Three hydrogen bonds per base pair — this helix requires more heat to separate into single strands.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Melting temperature graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Tm vs GC count (fixed 10-base length)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-tm"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Hydrogen bonds per base pair</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-bonds"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function update() {
        el('tm-err').textContent = '';
        const raw = (el('seq').value || '').toUpperCase().replace(/[^ATCG]/g, '');
        el('seq').value = el('seq').value.toUpperCase();
        if (!raw) { el('r-tm').textContent = '—'; el('r-counts').textContent = '—'; return; }
        let gc = 0, at = 0;
        raw.split('').forEach((b) => { if (b === 'G' || b === 'C') gc++; else at++; });
        const tm = 4 * gc + 2 * at;
        el('r-tm').textContent = tm + '°C';
        el('r-counts').textContent = gc + ' : ' + at;
        if (raw.length >= 14) el('tm-err').textContent = 'Note: the Wallace rule is most accurate under 14 bases — this sequence is longer, so treat the result as a rough estimate only.';
      }
      el('seq').addEventListener('input', update);

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labels = [], data = [];
        for (let gc = 0; gc <= 10; gc++) { labels.push(gc); data.push(4 * gc + 2 * (10 - gc)); }
        charts.tm = new Chart(el('chart-tm'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'Tm (°C)', data, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'GC count (out of 10)' } }, y: { title: { display: true, text: 'Tm (°C)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.bonds = new Chart(el('chart-bonds'), {
          type: 'bar',
          data: { labels: ['A-T pair', 'G-C pair'], datasets: [{ label: 'Hydrogen bonds', data: [2, 3], backgroundColor: ['#f59e0b', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Hydrogen bonds' }, max: 4 } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function helixScene(container, gcFraction) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const n = 10;
        for (let i = 0; i < n; i++) {
          const t = (i / n) * Math.PI * 2;
          const isGC = i < Math.round(n * gcFraction);
          const color = isGC ? 0x10b981 : 0xf59e0b;
          const y = i * 0.4 - 1.8;
          const b1 = new THREE.Mesh(new THREE.SphereGeometry(0.22, 12, 10), new THREE.MeshStandardMaterial({ color }));
          b1.position.set(1.2 * Math.cos(t), y, 1.2 * Math.sin(t));
          s.scene.add(b1);
          const b2 = new THREE.Mesh(new THREE.SphereGeometry(0.22, 12, 10), new THREE.MeshStandardMaterial({ color }));
          b2.position.set(1.2 * Math.cos(t + Math.PI), y, 1.2 * Math.sin(t + Math.PI));
          s.scene.add(b2);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() { const c = el('diag-low'); if (!c) throw new Error('no container'); diagLow = helixScene(c, 0.1); }
      function initDiagHigh() { const c = el('diag-high'); if (!c) throw new Error('no container'); diagHigh = helixScene(c, 0.9); }

      function boot() {
        try { update(); } catch (e) { console.error('[dna-melting-temperature] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[dna-melting-temperature] charts failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[dna-melting-temperature] low diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[dna-melting-temperature] high diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
