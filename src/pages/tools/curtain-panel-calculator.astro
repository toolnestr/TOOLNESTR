---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Curtain Panel Calculator';
const description = 'Calculate how much fabric and how many panel widths you need for full, gathered curtains. Get an accurate yardage estimate before you buy fabric.';
const intro = 'Calculate fabric yardage and panel widths needed for full, gathered curtains.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What fullness ratio should I use?', a: 'A fullness ratio of 2 to 2.5 times the window width is standard for a gathered or pinch-pleat look with good body. Use 1.5x for a flatter, more tailored look, or up to 3x for very full, luxurious drapery.' },
  { q: 'What allowances should I add to the curtain length?', a: 'Add your hem allowance (commonly 8-12 inches total for a double-turned bottom hem on floor-length curtains) and your heading allowance (commonly 4-8 inches for a rod pocket or header), on top of the finished drop length from rod to floor or sill.' },
  { q: 'How do I know how many fabric widths I need?', a: 'Divide your total fullness width (window width times fullness ratio) by your fabric\'s usable width, then round up — a partial width still requires a full width of fabric to be seamed in.' },
  { q: 'Should I buy extra for pattern matching?', a: 'Yes, for any directional or large-repeat print, add extra length per panel width equal to roughly one pattern repeat, so each seamed width lines up visually with its neighbor.' },
];
const howTo = {
  name: 'How to calculate curtain fabric',
  steps: [
    { name: 'Measure the window and choose fullness', text: 'Measure window width and curtain drop, and pick a fullness ratio.' },
    { name: 'Add hem and heading allowances', text: 'Add your planned hem and heading allowances to the drop length.' },
    { name: 'Read total fabric needed', text: 'The calculator shows panel widths required and total yardage.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Window width (in)</span>
        <input id="winWidth" type="number" step="any" placeholder="e.g. 48" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Curtain drop / finished length (in)</span>
        <input id="drop" type="number" step="any" placeholder="e.g. 84" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fullness ratio</span>
        <input id="fullness" type="number" step="any" value="2.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fabric width (in)</span>
        <input id="fabWidth" type="number" step="any" value="54" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Hem allowance (in)</span>
        <input id="hem" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Heading allowance (in)</span>
        <input id="header" type="number" step="any" value="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total fabric needed</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Fabric widths needed</div><div id="r-widths" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cut length per width</div><div id="r-cutlen" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="cpc-title cpc-desc">
      <title id="cpc-title">Curtain rod with gathered fabric panels</title>
      <desc id="cpc-desc">A curtain rod above gathered fabric panels, showing how fullness ratio creates extra width beyond the window</desc>
      <line x1="80" y1="30" x2="720" y2="30" stroke="#94a3b8" stroke-width="4" />
      <circle cx="80" cy="30" r="8" fill="#94a3b8" />
      <circle cx="720" cy="30" r="8" fill="#94a3b8" />
      {[100, 140, 180, 220, 260, 300].map((x) => (
        <path d={`M${x} 40 Q${x + 20} 90 ${x} 190 Q${x - 20} 90 ${x} 40`} fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      ))}
      <line x1="200" y1="60" x2="500" y2="60" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="350" y="55" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Window width</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Fullness ratio determines how much wider the gathered fabric is than the window</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How curtain fabric is calculated</h2>
    <p class="mt-2 text-slate-600">
      Gathered curtains need significantly more fabric width than the window itself, so the calculator first multiplies window width by your chosen fullness ratio to find the total fabric width required for a properly full, draping look. That total is then divided by your fabric's usable width and rounded up to find how many full fabric widths need to be seamed together.
    </p>
    <p class="mt-3 text-slate-600">
      Each fabric width is cut to the curtain drop plus your hem and heading allowances, and the total yardage is that cut length multiplied by the number of widths needed, converted from inches to yards.
    </p>
    <p class="mt-3 text-xs text-slate-400">Fullness-ratio and allowance conventions follow standard home-decor sewing practice for rod-pocket and pinch-pleat curtains.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 48-inch-wide window, 84-inch drop, 2.5x fullness, 54-inch fabric, 10-inch hem allowance, 6-inch heading allowance.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Total fullness width:</span> <span class="text-slate-600">48 × 2.5 = 120 in</span></div>
        <div><span class="font-medium text-slate-700">Widths needed:</span> <span class="text-slate-600">ceil(120 ÷ 54) = 3</span></div>
        <div><span class="font-medium text-slate-700">Cut length:</span> <span class="text-slate-600">84 + 10 + 6 = 100 in</span></div>
        <div><span class="font-medium text-slate-700">Total fabric:</span> <span class="text-slate-600">3 × 100 = 300 in ÷ 36 ≈ <strong>8.33 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Wide bay windows or a window wall are where fullness-ratio math matters most, since even a modest 1.5x fullness on a 10-foot span requires multiple seamed fabric widths — underestimating widths needed is a common first-time mistake that leaves curtains looking flat and skimpy against a large window rather than the intended full, layered drape.
    </p>
    <p class="mt-3 text-slate-600">
      Matching a set of curtains across several rooms in the same fabric benefits from calculating total yardage for all windows upfront, since ordering fabric from the same dye lot in one purchase avoids subtle color mismatches that can appear between separately dyed batches of the same fabric color.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Curtain fabric only needs to match the window width." <strong class="text-slate-900">It needs much more.</strong> Flat, unglathered fabric at exactly window width looks skimpy when hung — the fullness ratio exists specifically because gathered or pleated fabric needs 1.5 to 3 times the flat window width to drape properly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any leftover partial fabric width can be used as a narrower panel." <strong class="text-slate-900">Rarely a clean solution.</strong> Partial widths usually get seamed into a full-width panel rather than used alone, since a narrow leftover panel looks visibly mismatched next to full-width panels.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/roman-blind-fabric-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Roman Blind Fabric Calculator</a>
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Yardage Calculator</a>
      <a href="/tools/fabric-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Cost Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const winWidth = parseFloat(el('winWidth').value);
      const drop = parseFloat(el('drop').value);
      const fullness = parseFloat(el('fullness').value);
      const fabWidth = parseFloat(el('fabWidth').value);
      const hem = parseFloat(el('hem').value) || 0;
      const header = parseFloat(el('header').value) || 0;
      if (!winWidth || !drop || !fullness || !fabWidth || winWidth <= 0 || drop <= 0 || fullness <= 0 || fabWidth <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const totalFullness = winWidth * fullness;
      const widths = Math.ceil(totalFullness / fabWidth);
      const cutLen = drop + hem + header;
      const totalIn = widths * cutLen;
      const yards = totalIn / 36;

      el('r-widths').textContent = widths;
      el('r-cutlen').textContent = cutLen.toFixed(1) + ' in';
      el('r-yards').textContent = yards.toFixed(2) + ' yd';
      el('results').classList.remove('hidden');
    }

    ['winWidth', 'drop', 'fullness', 'fabWidth', 'hem', 'header'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
