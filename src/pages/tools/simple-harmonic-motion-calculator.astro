---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Simple Harmonic Motion Calculator';
const description = 'Simple harmonic motion calculator with a live 3D oscillator diagram and charts. Find displacement, velocity, and acceleration at any instant from amplitude, angular frequency, and time, with worked examples.';
const intro = 'Solve x(t) = A cos(ωt), v(t) = −Aω sin(ωt), and a(t) = −Aω² cos(ωt) for a mass-spring oscillator, or find ω from spring constant and mass. Two 3D diagrams show the oscillator at its extremes and the phase relationship between displacement, velocity, and acceleration, with charts tracing displacement and velocity over one full period.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is simple harmonic motion?', a: 'Simple harmonic motion (SHM) is periodic back-and-forth motion where the restoring force (and acceleration) is always proportional to displacement and points back toward equilibrium: a = −ω²x. A mass on a spring and a small-angle pendulum are the two classic examples.' },
  { q: 'How do you find the angular frequency of a mass-spring system?', a: 'ω = √(k/m), where k is the spring constant (N/m) and m is the mass (kg). The period is T = 2π/ω = 2π√(m/k), and frequency is f = 1/T.' },
  { q: 'Does the period of SHM depend on amplitude?', a: 'No — for ideal SHM, the period depends only on ω (which comes from k and m for a spring), not on how far the amplitude is. A gentle swing and a wide swing of the same spring-mass system take exactly the same time per cycle.' },
  { q: 'Where is velocity greatest in SHM?', a: 'Velocity is greatest at the equilibrium position (x = 0), where v_max = Aω. Velocity is exactly zero at the two extreme displacements (x = ±A), where the oscillator momentarily reverses direction.' },
  { q: 'Where is acceleration greatest in SHM?', a: 'Acceleration is greatest in magnitude at the extremes of displacement (x = ±A), where a_max = Aω², and it is exactly zero at the equilibrium position — the opposite pattern from velocity.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Simple Harmonic Motion Calculator',
  description: 'Find displacement, velocity, and acceleration at a given instant, from amplitude, angular frequency (or spring constant and mass), and time.',
  steps: [
    { name: 'Enter amplitude and either ω, T, or k & m', text: 'Provide the amplitude A, plus angular frequency ω directly, or the spring constant k and mass m to compute ω = √(k/m).' },
    { name: 'Enter a time t', text: 'Pick any instant to evaluate the motion at.' },
    { name: 'Read the results', text: 'Displacement, velocity, and acceleration at that instant solve instantly, along with the period, frequency, and maximum speed/acceleration.' },
  ],
};

const formulas = [
  { expr: 'x(t) = A cos(ωt)', note: 'displacement — A = amplitude, ω = angular frequency (rad/s)' },
  { expr: 'v(t) = −Aω sin(ωt)', note: 'velocity — maximum magnitude Aω occurs at x = 0' },
  { expr: 'a(t) = −Aω² cos(ωt) = −ω²x', note: 'acceleration — maximum magnitude Aω² occurs at x = ±A' },
  { expr: 'ω = √(k/m), T = 2π/ω', note: 'for a mass-spring system — k = spring constant, m = mass' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — mass-spring system at a mid-cycle instant', tone: 'slate',
    given: 'A 0.5 kg mass on a spring with k = 200 N/m oscillates with amplitude A = 0.1 m. Find x, v, a at t = 0.05 s.',
    rows: [
      { label: 'Angular frequency:', value: 'ω = √(k/m) = √(200/0.5) = √400 = 20 rad/s (T = 2π/20 ≈ 0.314 s)' },
      { label: 'Phase:', value: 'ωt = 20 × 0.05 = 1.0 rad → cos(1.0) ≈ 0.5403, sin(1.0) ≈ 0.8415' },
      { label: 'Displacement:', value: 'x = A cos(ωt) = 0.1 × 0.5403 ≈ 0.0540 m' },
      { label: 'Velocity:', value: 'v = −Aω sin(ωt) = −0.1 × 20 × 0.8415 ≈ −1.683 m/s' },
      { label: 'Acceleration:', value: 'a = −Aω² cos(ωt) = −40 × 0.5403 ≈ −21.61 m/s²', full: true },
    ],
    note: 'v_max = Aω = 2 m/s and a_max = Aω² = 40 m/s² for this system — the instantaneous values above are partway between the extremes.',
  },
  {
    title: 'Worked example 2 — the quarter-period instant (x = 0, v = v_max)', tone: 'amber',
    given: 'A different oscillator has period T = 2 s and amplitude A = 0.2 m. Find x, v, a at t = 0.5 s (exactly one quarter of the period).',
    rows: [
      { label: 'Angular frequency:', value: 'ω = 2π/T = 2π/2 = π ≈ 3.1416 rad/s' },
      { label: 'Phase:', value: 'ωt = π × 0.5 = π/2 (90°) → cos(90°) = 0, sin(90°) = 1' },
      { label: 'Displacement:', value: 'x = A cos(ωt) = 0.2 × 0 = 0 m (passing through equilibrium)' },
      { label: 'Velocity:', value: 'v = −Aω sin(ωt) = −0.2 × 3.1416 × 1 ≈ −0.628 m/s (this is v_max)' },
      { label: 'Acceleration:', value: 'a = −Aω² cos(ωt) = 0 m/s² (zero exactly at equilibrium)', full: true },
    ],
    note: 'This instant lands exactly at equilibrium, which is why velocity peaks at its maximum magnitude while acceleration drops to zero — the two are always 90° out of phase in SHM.',
  },
];

const comparison = {
  heading: 'Period is independent of amplitude',
  note: 'Same spring (k = 200 N/m) and mass (m = 0.5 kg) at four different amplitudes — ω and T stay exactly the same, only the peak displacement, speed, and acceleration change.',
  headers: [{ label: 'Amplitude A' }, { label: 'Period T' }, { label: 'v_max = Aω' }, { label: 'a_max = Aω²' }],
  rows: [
    ['5 cm', '0.314 s', '1.00 m/s', '20.0 m/s²'],
    ['10 cm', '0.314 s', '2.00 m/s', '40.0 m/s²'],
    ['20 cm', '0.314 s', '4.00 m/s', '80.0 m/s²'],
    ['40 cm', '0.314 s', '8.00 m/s', '160.0 m/s²'],
  ],
  highlightIndex: 1,
  footnote: 'Notice the period column never changes — this is the defining, often counter-intuitive feature of ideal simple harmonic motion.',
};

const realWorld = [
  { emoji: '🕰️', title: 'Pendulum clocks', body: 'Mechanical clocks use the near-constant period of a swinging pendulum (a small-angle SHM approximation) to keep reliable time, since the period barely changes as the swing gradually loses energy to friction.' },
  { emoji: '🚗', title: 'Vehicle suspension systems', body: "A car's suspension springs oscillate in a damped version of SHM after hitting a bump — engineers tune the spring constant and damping to control how quickly the oscillation settles down." },
  { emoji: '🎸', title: 'Musical instrument strings', body: 'A plucked guitar string vibrates in a pattern built from combinations of SHM at different frequencies (harmonics), which is why the same string produces a rich, layered tone rather than a single pure note.' },
  { emoji: '🌍', title: 'Seismometers', body: 'Seismographs use a mass suspended on a spring that stays nearly still while the ground moves beneath it — the relative motion, governed by SHM physics, is what gets recorded as an earthquake\'s waveform.' },
];

const misconceptions = [
  { claim: '"SHM moves at constant speed, like a car on cruise control."', truth: 'Speed in SHM constantly changes — it peaks at the equilibrium position (v_max = Aω) and drops to exactly zero at the extreme displacements, where the object momentarily reverses direction.' },
  { claim: '"A bigger swing (larger amplitude) takes longer to complete one cycle."', truth: 'For ideal SHM, period depends only on ω (from k and m for a spring, or g and length for a pendulum), never on amplitude — a small swing and a large swing of the same system complete a cycle in exactly the same time.' },
  { claim: '"Acceleration is greatest where speed is greatest."', truth: 'The opposite is true — acceleration is maximum at the extremes of displacement (where speed is momentarily zero), and acceleration is zero at the equilibrium point (where speed is maximum). Displacement and acceleration are always exactly out of phase.' },
  { claim: '"Any periodic motion is simple harmonic motion."', truth: 'SHM specifically requires the restoring force (and acceleration) to be directly proportional to displacement and always directed back toward equilibrium, a = −ω²x. Many periodic motions — like a bouncing ball or a swinging pendulum at large angles — do not satisfy this and are not true SHM.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 15, "Oscillations" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/15-1-simple-harmonic-motion" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 15, Oscillations.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 15, Oscillatory Motion.' },
];
const sourcesNote = 'x(t)=A cos(ωt), v(t)=−Aω sin(ωt), a(t)=−Aω² cos(ωt), with ω=√(k/m)=2π/T=2πf. Phase offset φ is assumed zero (starting at maximum displacement) unless noted. Results are rounded for display.';

const howToUse = [
  { title: 'Enter A and ω (or k, m, or T)', body: 'Provide amplitude plus angular frequency directly, or spring constant & mass, or the period — the calculator converts between them.' },
  { title: 'Pick a time t', body: 'Choose any instant within the cycle to evaluate displacement, velocity, and acceleration.' },
  { title: 'Compare on the charts', body: 'See how displacement and velocity trace out a full cycle, always 90° out of phase with each other.' },
];

const related = [
  { href: '/tools/simple-pendulum-calculator', emoji: '🕰️', title: 'Simple Pendulum Period Calculator', desc: 'T = 2π√(L/g) — solve period, length, or gravity.' },
  { href: '/tools/wave-speed-calculator', emoji: '🌊', title: 'Wave Speed Calculator', desc: 'v = f×λ — solve for wave speed, frequency, or wavelength.' },
  { href: '/tools/acceleration-calculator', emoji: '🚀', title: 'Acceleration Calculator', desc: 'a = Δv/t — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="in simple harmonic motion, the restoring force (and therefore acceleration) is always proportional to displacement and points back toward equilibrium, producing a smooth, endlessly repeating cosine-shaped oscillation whose period never depends on how far it swings."
  howIntro="Starting from Newton's second law for a spring, F = −kx = ma, dividing through by m gives a = −(k/m)x — exactly the defining equation of SHM with ω² = k/m. Solving that differential equation produces x(t) = A cos(ωt), and differentiating once gives velocity v(t) = −Aω sin(ωt), and again gives acceleration a(t) = −Aω² cos(ωt) = −ω²x. Because ω depends only on k and m (not on A), the period T = 2π/ω is completely independent of amplitude."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where simple harmonic motion actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-omega" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Enter ω directly</button>
      <button id="mode-km" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Enter spring k &amp; mass m</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Amplitude A (m)</span>
        <input id="A" type="number" step="any" value="0.1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-omega" class="block"><span class="text-sm font-medium text-slate-700">Angular frequency ω (rad/s)</span>
        <input id="omega" type="number" step="any" value="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-k" class="hidden"><span class="text-sm font-medium text-slate-700">Spring constant k (N/m)</span>
        <input id="k" type="number" step="any" value="200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-m" class="hidden"><span class="text-sm font-medium text-slate-700">Mass m (kg)</span>
        <input id="m" type="number" step="any" value="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time t (s)</span>
        <input id="t" type="number" step="any" value="0.05" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Displacement x</div><div id="r-x" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Velocity v</div><div id="r-v" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Acceleration a</div><div id="r-a" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Period T</div><div id="r-T" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">v_max</div><div id="r-vmax" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">a_max</div><div id="r-amax" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="shm-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Oscillator extremes and phase</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-extremes" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Mass-spring system at its extremes</h3>
          <p class="mt-1 text-sm text-slate-600">The mass shown at both extreme displacements (±A) with the spring compressed and stretched — the two turning points where velocity is momentarily zero.</p>
        </div>
        <div>
          <div id="diag-phase" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Displacement, velocity, and acceleration vectors</h3>
          <p class="mt-1 text-sm text-slate-600">At equilibrium, the <span class="font-semibold text-indigo-600">velocity arrow</span> (indigo) is longest while displacement and acceleration vanish — the 90° phase relationship in 3D form.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Simple harmonic motion graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Displacement x(t) over one full period</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-x"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Velocity v(t) — 90° out of phase with displacement</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-v"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'omega';
      function switchMode(m) {
        mode = m;
        el('mode-omega').className = m === 'omega' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-km').className = m === 'km' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('field-omega').className = m === 'omega' ? 'block' : 'hidden';
        el('field-k').className = m === 'km' ? 'block' : 'hidden';
        el('field-m').className = m === 'km' ? 'block' : 'hidden';
        update();
      }
      function update() {
        el('shm-err').textContent = '';
        ['r-x', 'r-v', 'r-a', 'r-T', 'r-vmax', 'r-amax'].forEach((id) => (el(id).textContent = '—'));
        const A = parseFloat(el('A').value), t = parseFloat(el('t').value);
        if (isNaN(A) || isNaN(t)) return;
        let omega;
        if (mode === 'omega') {
          omega = parseFloat(el('omega').value);
          if (isNaN(omega)) return;
        } else {
          const k = parseFloat(el('k').value), m = parseFloat(el('m').value);
          if (isNaN(k) || isNaN(m)) return;
          if (m <= 0) { el('shm-err').textContent = 'Mass must be greater than 0.'; return; }
          omega = Math.sqrt(k / m);
        }
        if (omega <= 0) { el('shm-err').textContent = 'Angular frequency must be greater than 0.'; return; }
        const phase = omega * t;
        const x = A * Math.cos(phase);
        const v = -A * omega * Math.sin(phase);
        const a = -A * omega * omega * Math.cos(phase);
        const T = (2 * Math.PI) / omega;
        el('r-x').textContent = fmt(x) + ' m';
        el('r-v').textContent = fmt(v) + ' m/s';
        el('r-a').textContent = fmt(a) + ' m/s²';
        el('r-T').textContent = fmt(T) + ' s';
        el('r-vmax').textContent = fmt(A * omega) + ' m/s';
        el('r-amax').textContent = fmt(A * omega * omega) + ' m/s²';
      }
      el('mode-omega').addEventListener('click', () => switchMode('omega'));
      el('mode-km').addEventListener('click', () => switchMode('km'));
      ['A', 'omega', 'k', 'm', 't'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts (fixed illustrative example: A=0.1, omega=20) ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const A0 = 0.1, w0 = 20, T0 = (2 * Math.PI) / w0;
        const labels = [], dataX = [], dataV = [];
        for (let i = 0; i <= 40; i++) {
          const tt = (T0 * i) / 40;
          labels.push(tt.toFixed(3));
          dataX.push(+(A0 * Math.cos(w0 * tt)).toFixed(4));
          dataV.push(+(-A0 * w0 * Math.sin(w0 * tt)).toFixed(4));
        }
        charts.x = new Chart(el('chart-x'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'x (m)', data: dataX, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.35, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Displacement (m)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.v = new Chart(el('chart-v'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'v (m/s)', data: dataV, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.35, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Velocity (m/s)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: mass-spring at extremes ----
      let diagExtremes = null;
      function initDiagExtremes() {
        const c = el('diag-extremes'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 0, 0), OPTS);
        const springMat = new THREE.LineBasicMaterial({ color: 0x94a3b8 });
        function addSpringAndMass(xEnd, color) {
          const pts = [];
          const coils = 10;
          for (let i = 0; i <= coils * 8; i++) {
            const frac = i / (coils * 8);
            const xx = -4 + frac * (xEnd + 4);
            const yy = Math.sin(frac * coils * Math.PI * 2) * 0.4;
            pts.push(new THREE.Vector3(xx, yy, 0));
          }
          s.scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), springMat));
          const mass = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.8, 0.8), new THREE.MeshStandardMaterial({ color, roughness: 0.4 }));
          mass.position.set(xEnd + 0.5, 0, 0);
          s.scene.add(mass);
        }
        addSpringAndMass(-1.5, 0xf59e0b);
        addSpringAndMass(1.5, 0x6366f1);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagExtremes = { resize: s.resize };
      }

      // ---- Diagram 2: phase vectors at equilibrium ----
      let diagPhase = null;
      function initDiagPhase() {
        const c = el('diag-phase'); if (!c) throw new Error('no container');
        const s = makeScene(c, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const mass = new THREE.Mesh(new THREE.SphereGeometry(0.4, 20, 16), new THREE.MeshStandardMaterial({ color: 0x334155, roughness: 0.4 }));
        s.scene.add(mass);
        s.scene.add(arrow(new THREE.Vector3(0, 0, 0), new THREE.Vector3(0, 0, -3), 0x6366f1));
        s.scene.add(arrow(new THREE.Vector3(0, 0, 0), new THREE.Vector3(2, 0, 0), 0xf59e0b));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagPhase = { resize: s.resize };
      }

      function boot() {
        try { switchMode('omega'); } catch (e) { console.error('[shm] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[shm] charts failed', e); }
        if (window.THREE) {
          try { initDiagExtremes(); } catch (e) { console.error('[shm] extremes diagram failed', e); }
          try { initDiagPhase(); } catch (e) { console.error('[shm] phase diagram failed', e); }
        }
        mountResize([diagExtremes, diagPhase]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
