---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Plywood Sheet Calculator';
const description = 'Find how many 4x8 plywood sheets you need to cover a floor, wall or roof area, with a waste allowance for cuts and seams.';
const intro = 'Find how many plywood sheets you need to cover an area, with a waste allowance.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How many sheets of plywood do I need?', a: 'Divide the total area to cover by the area of one sheet — 32 square feet for a standard 4×8 sheet — then round up and add a waste allowance. A 600 sq ft subfloor needs 600 ÷ 32 = 18.75, rounded up to 19 sheets before waste.' },
  { q: 'What size is a standard plywood sheet?', a: 'The most common size is 4 feet by 8 feet (32 square feet), though 4×10 and other sizes exist for specific applications. This calculator defaults to the standard 4×8 sheet but lets you enter a different sheet size.' },
  { q: 'How much waste allowance should I add for plywood?', a: 'A common allowance is 10% for a simple rectangular area, and up to 15-20% for irregular shapes, lots of cutouts (like for plumbing or electrical), or a roof with many hips and valleys that create more cut edges and waste.' },
  { q: 'Does this account for the layout pattern?', a: 'No — this gives a straightforward area-based sheet count. For a specific layout (like staggered seams on a subfloor for strength), you may need slightly more sheets than the raw area calculation to account for how full sheets fit within the room\'s actual dimensions.' },
];
const howTo = {
  name: 'How to calculate how many plywood sheets you need',
  steps: [
    { name: 'Measure the area', text: 'Total square footage to cover.' },
    { name: 'Pick sheet size', text: 'Standard 4x8 or a larger 4x10 sheet.' },
    { name: 'Add waste and order', text: 'More for irregular shapes and cutouts.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Area to cover (sq ft)</span>
        <input id="area" type="number" step="any" placeholder="600" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Sheet size</span>
        <select id="sheet" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="32" selected>4×8 ft (32 ft²)</option>
          <option value="40">4×10 ft (40 ft²)</option>
        </select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waste (%)</span>
        <input id="waste" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Sheets to buy</div>
        <div id="r-sheets" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Total covered area</div><div id="r-coverage" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="pw-title pw-desc">
      <title id="pw-title">Plywood sheets covering a floor area</title>
      <desc id="pw-desc">4x8 plywood sheets laid across a floor with the sheet-count formula</desc>
      <g stroke="#78350f" stroke-width="1.5">
        <rect x="70" y="70" width="90" height="45" fill="#fde68a" /><rect x="160" y="70" width="90" height="45" fill="#fbbf24" /><rect x="250" y="70" width="90" height="45" fill="#fde68a" />
        <rect x="70" y="115" width="90" height="45" fill="#fbbf24" /><rect x="160" y="115" width="90" height="45" fill="#fde68a" /><rect x="250" y="115" width="90" height="45" fill="#fbbf24" />
      </g>
      <text x="205" y="180" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">each sheet covers 32 ft²</text>
      <rect x="420" y="55" width="330" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Sheet count</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">sheets = ceil(area &divide; 32 &times; (1+waste))</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Full sheets rarely fit a room exactly, so waste and rounding both push the count up.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the plywood sheet calculator works</h2>
    <p class="mt-2 text-slate-600">
      Plywood is sold in sheets, most commonly 4 feet by 8 feet, covering 32 square feet each. Finding how many sheets a job needs starts with dividing the total area to cover by 32 square feet, which gives a raw sheet count — but that number is always rounded up, since you can't buy a fraction of a sheet, and a real room's dimensions rarely divide evenly into whole 4×8 pieces.
    </p>
    <p class="mt-3 text-slate-600">
      On top of the rounded raw count, a waste allowance covers material lost to cuts, offcuts around the room's actual shape, and any cutouts for plumbing, electrical boxes, or vents. A simple rectangular subfloor or wall typically needs about 10% extra; a roof deck with hips and valleys, or a room with many jogs and closets, can need 15 to 20% because those irregular edges create more waste per sheet used.
    </p>
    <p class="mt-3 text-slate-600">
      This calculation is area-based and doesn't account for a specific layout pattern — subfloors, for example, are often installed with staggered seams between rows for added strength, which can occasionally require slightly more sheets than a pure area calculation suggests, depending on how the room's dimensions align with whole sheet widths.
    </p>
    <p class="mt-3 text-xs text-slate-400">Sheet sizing and grading conventions follow ANSI/APA PS 1 (Structural Plywood) and PS 2 performance standards published by APA – The Engineered Wood Association.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the area</h3>
        <p class="mt-1 text-sm text-slate-600">Total square footage to cover.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick sheet size</h3>
        <p class="mt-1 text-sm text-slate-600">Standard 4×8 or a larger 4×10 sheet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Add waste and order</h3>
        <p class="mt-1 text-sm text-slate-600">More for irregular shapes and cutouts.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Raw sheet count</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= area &divide; 32</span>. A 600 sq ft subfloor: 600 ÷ 32 = <strong>18.75</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">With waste</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">&times; 1.10, then round up</span> = 18.75 × 1.10 = 20.6 → <strong>21 sheets</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Total covered area</p>
        <p class="mt-1 text-slate-600">
          21 sheets × 32 ft² = <strong>672 ft²</strong> of material bought.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 900 sq ft roof deck with several valleys, 20% waste.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Raw count:</span> <span class="text-slate-600">900 ÷ 32 = 28.1</span></div>
        <div><span class="font-medium text-slate-700">With waste:</span> <span class="text-slate-600">28.1 × 1.20 = 33.75</span></div>
        <div><span class="font-medium text-slate-700">Sheets to buy:</span> <span class="text-slate-600"><strong>34 sheets</strong></span></div>
        <div><span class="font-medium text-slate-700">Covers:</span> <span class="text-slate-600">1,088 ft² of material</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Where this calculator is used</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏚️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Subfloor replacement</h3>
        <p class="mt-1 text-sm text-slate-600">Tongue-and-groove 3/4-inch plywood is the standard subfloor layer over joists. Order enough for staggered rows, since edge cuts at the walls generate offcuts that don't reuse cleanly elsewhere.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Roof decking</h3>
        <p class="mt-1 text-sm text-slate-600">Sheathing a roof means cutting sheets to fit hips, valleys, and dormers, so waste allowances of 15-20% are typical rather than the 10% used for a flat, rectangular area.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧱</span>
        <h3 class="mt-2 font-semibold text-slate-900">Wall sheathing</h3>
        <p class="mt-1 text-sm text-slate-600">Exterior walls use plywood or OSB sheathing for shear strength and a nailing base for siding. Door and window openings create cutouts that add to the waste factor.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🛠️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Shed and outbuilding builds</h3>
        <p class="mt-1 text-sm text-slate-600">Small structures like sheds, workshops, and chicken coops use plywood for floor, walls, and roof alike, so this calculator can be run three times for one project — once per surface.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A small shed floor is a common small-scale job. At 120 sq ft with 10% waste, the raw count is 120 ÷ 32 = 3.75 sheets, which rounds up and inflates for waste to 3.75 × 1.10 = 4.13, rounding up to 5 sheets — covering 160 sq ft of material for a floor that only needed 120, since partial sheets and rounding both push the final purchase upward at small scales.
    </p>
    <p class="mt-3 text-slate-600">
      A garage subfloor at a more typical 400 sq ft, also with 10% waste, needs 400 ÷ 32 = 12.5 sheets raw, which becomes 12.5 × 1.10 = 13.75, rounding up to 14 sheets and 448 sq ft of coverage — a good illustration of how the waste percentage matters less in absolute sheet count once the job is large enough that rounding error becomes a smaller fraction of the total.
    </p>
    <p class="mt-3 text-slate-600">
      A shed or small outbuilding roof deck with a couple of valleys, at 250 sq ft and a 15% waste allowance for the extra angled cuts, needs 250 ÷ 32 = 7.81 sheets raw, times 1.15 = 8.98, rounding up to 9 sheets covering 288 sq ft — the higher waste percentage compared to a flat subfloor reflects the extra offcuts generated at hips, valleys, and eave lines.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A 4x8 sheet actually measures exactly 4 feet by 8 feet." <strong class="text-slate-900">Not quite.</strong> Like dimensional lumber, plywood is sold under a nominal size — actual sheet dimensions run slightly under 4x8 (commonly by about 1/8 to 1/4 inch total) to account for manufacturing tolerances, so tight layouts should leave a small margin rather than assuming exact full-size coverage.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any plywood thickness works the same for a subfloor, roof deck, or wall sheathing." <strong class="text-slate-900">Thickness and grade both matter.</strong> Subfloors typically need 3/4-inch tongue-and-groove plywood rated for the joist spacing, roof decking is commonly 1/2 to 5/8 inch rated for the rafter or truss spacing, and wall sheathing can often go thinner — using the wrong span rating risks sagging or bouncy floors and roofs that don't meet code.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/drywall-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Drywall Calculator</a>
      <a href="/tools/roofing-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Roofing Calculator</a>
      <a href="/tools/board-and-batten-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Board and Batten Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const area = parseFloat(el('area').value);
      const sheetSize = parseFloat(el('sheet').value);
      let waste = parseFloat(el('waste').value); if (!(waste >= 0)) waste = 0;
      if (!(area > 0)) { el('results').classList.add('hidden'); return; }
      const raw = area / sheetSize;
      const sheets = Math.ceil(raw * (1 + waste / 100));
      const coverage = sheets * sheetSize;

      el('r-sheets').textContent = sheets;
      el('r-note').textContent = area + ' ft² needed, ' + waste + '% waste';
      el('r-coverage').textContent = coverage.toFixed(0) + ' ft²';
      el('results').classList.remove('hidden');
    }

    ['area', 'waste'].forEach((id) => el(id).addEventListener('input', update));
    el('sheet').addEventListener('change', update);
  </script>
</ToolLayout>
