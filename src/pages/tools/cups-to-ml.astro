---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Cups (US) to Ml"
  emoji="🧪"
  fromUnit="US cups" toUnit="milliliters"
  fromTitle="Cups" toTitle="Milliliters"
  fromSym="cup" toSym="mL"
  quantity="volume"
  kind="factor" factor={236.588}
  reverseSlug="ml-to-ounces" reverseLabel="Ml to Fluid Ounces Converter"
  hasReverse={false}
  related={[{"slug":"volume-converter","label":"Volume Converter"}]}
  useCase="Bakers use it to turn US cup measures into the precise milliliters used by digital scales and metric recipes."
/>
