---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Meters per second", sym: "m/s", toBase: 1 }, { name: "Kilometers per hour", sym: "km/h", toBase: 0.2777777778 }, { name: "Miles per hour", sym: "mph", toBase: 0.44704 }, { name: "Knots", sym: "kn", toBase: 0.5144444444 }, { name: "Feet per second", sym: "ft/s", toBase: 0.3048 }];
---
<MultiUnitConverter
  title="Speed Converter"
  emoji="🏎️"
  quantity="speed"
  baseName="meter per second"
  units={units}
  defaultFrom={1} defaultTo={2}
  intro="Convert between speed units — meters per second, kilometers per hour, miles per hour, knots, feet per second and more."
  blurb="Speed measures how fast something moves, used in driving, sport, sailing and flight."
  related={[{"slug":"mph-to-kmh","label":"Mph to Km/h Converter"},{"slug":"kmh-to-mph","label":"Km/h to Mph Converter"},{"slug":"knots-to-mph","label":"Knots to Mph Converter"}]}
/>
