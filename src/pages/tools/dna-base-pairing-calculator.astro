---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'DNA/RNA Base-Pairing Calculator';
const description = "DNA/RNA base-pairing calculator with a live 3D double-helix diagram and charts. Apply Watson-Crick base-pairing rules to find a DNA sequence's complementary DNA and RNA strands, plus hydrogen bond count and Chargaff's rule check.";
const intro = "Enter a DNA sequence to see its base-paired partner strand in both DNA and RNA form, following Watson-Crick pairing rules, plus the total hydrogen bonds holding the double helix together. Two 3D diagrams compare an A-T-rich region (weaker double helix) to a G-C-rich region (stronger double helix), and charts show base composition and hydrogen bond contribution.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What are the DNA base-pairing rules?', a: "In double-stranded DNA, adenine (A) always pairs with thymine (T), and guanine (G) always pairs with cytosine (C) — this is known as complementary base pairing, first described by Watson and Crick." },
  { q: "How is this different from the Reverse Complement tool?", a: "This calculator shows the direct, non-reversed base-paired partner strand (useful for visualizing the double helix rung-by-rung) plus hydrogen bond counts. The Reverse Complement tool instead reverses the paired strand to give its conventional 5'-to-3' reading, which is what's needed for practical applications like primer design." },
  { q: 'Why do A-T pairs have 2 hydrogen bonds but G-C pairs have 3?', a: 'The molecular structures of adenine-thymine and guanine-cytosine allow a different number of hydrogen bonds to form between them — 2 for A-T and 3 for G-C. This is a fixed chemical fact, not something that varies by sequence.' },
  { q: "What is Chargaff's rule?", a: "Chargaff's rule states that in double-stranded DNA, the amount of adenine always equals the amount of thymine, and the amount of guanine always equals the amount of cytosine — a direct consequence of strict A-T and G-C base pairing across the whole molecule." },
  { q: 'Why does GC content affect DNA stability?', a: 'Because G-C pairs form three hydrogen bonds versus only two for A-T pairs, GC-rich DNA regions require more energy to separate the two strands — this is exactly why GC content is a major factor in DNA melting temperature.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the DNA/RNA Base-Pairing Calculator',
  description: 'Apply Watson-Crick pairing rules to find the DNA and RNA partner strands for any DNA sequence.',
  steps: [
    { name: 'Enter a DNA sequence', text: 'Type a sequence using only A, T, C, and G.' },
    { name: 'Read both partner strands', text: 'The complementary DNA strand and the equivalent RNA strand display side by side.' },
    { name: 'Check the hydrogen bond count', text: 'Total hydrogen bonds across the double helix are tallied automatically from the A-T and G-C pair counts.' },
  ],
};

const formulas = [
  { expr: 'A ↔ T (DNA), A ↔ U (RNA)', note: 'adenine pairs with thymine in DNA, or uracil in RNA' },
  { expr: 'G ↔ C', note: 'guanine always pairs with cytosine, in both DNA and RNA' },
  { expr: 'H-bonds = 2×(A+T pairs) + 3×(G+C pairs)', note: 'total hydrogen bonds holding the double helix together' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a mixed sequence', tone: 'slate',
    given: 'DNA strand: 5\'-ATGCGC-3\' (1 A, 1 T, 2 G, 2 C).',
    rows: [
      { label: 'Complementary DNA:', value: "3'-TACGCG-5'" },
      { label: 'Equivalent RNA:', value: "3'-UACGCG-5'" },
      { label: 'A-T pairs:', value: '2 positions × 2 H-bonds = 4 H-bonds' },
      { label: 'G-C pairs:', value: '4 positions × 3 H-bonds = 12 H-bonds, total = 16 H-bonds', full: true },
    ],
    note: "Chargaff's rule holds exactly: this strand has 1 A and the partner strand has 1 T at the matching position, and 2 G paired with 2 C — the counts always mirror each other across the double helix.",
  },
  {
    title: 'Worked example 2 — comparing an A-T-rich vs. G-C-rich sequence', tone: 'amber',
    given: 'Sequence 1: AATTAA (A-T-rich). Sequence 2: GGCCGG (G-C-rich). Both are 6 bases long.',
    rows: [
      { label: 'Sequence 1 H-bonds:', value: '6 A-T pairs × 2 = 12 H-bonds' },
      { label: 'Sequence 2 H-bonds:', value: '6 G-C pairs × 3 = 18 H-bonds' },
      { label: 'Comparison:', value: 'the G-C-rich sequence forms 50% more hydrogen bonds despite being the same length', full: true },
    ],
    note: "This is exactly why GC-rich DNA regions are more thermally stable and require higher temperatures to denature — more hydrogen bonds means more energy is needed to separate the two strands.",
  },
];

const comparison = {
  heading: 'Hydrogen bonds per base pair type',
  note: 'Every double-stranded DNA molecule is held together entirely by these two bond counts.',
  headers: [{ label: 'Base pair' }, { label: 'Hydrogen bonds' }, { label: 'Relative strength' }],
  rows: [
    ['A–T ★', '2', 'Weaker'],
    ['G–C', '3', 'Stronger (50% more bonds)'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row. This single difference — 2 bonds vs. 3 — is the root cause of every GC-content-related property in DNA, from melting temperature to primer design.',
};

const realWorld = [
  { emoji: '🧬', title: 'PCR primer design', body: "Primers with a higher GC content bind more strongly to their target DNA — molecular biologists calculate GC content and hydrogen bonding to choose primers that anneal reliably at the chosen reaction temperature." },
  { emoji: '🔬', title: 'DNA sequencing technology', body: 'Base-pairing rules are the literal working principle behind Sanger and next-generation sequencing — every sequencing read is built by correctly matching bases according to these exact pairing rules.' },
  { emoji: '🧪', title: 'DNA hybridization assays', body: 'Diagnostic tests (like DNA probes for detecting pathogens or genetic mutations) rely entirely on complementary base pairing to determine whether a probe sequence binds to a target sequence.' },
  { emoji: '🌡️', title: 'PCR and qPCR temperature optimization', body: 'Because G-C pairs need more energy to separate than A-T pairs, GC content directly determines the denaturation and annealing temperatures used in PCR protocols.' },
];

const misconceptions = [
  { claim: '"Any base can pair with any other base if the DNA folds the right way."', truth: "Standard Watson-Crick base pairing only allows A-T and G-C pairs — the specific shapes and hydrogen-bonding patterns of these particular base combinations are what make the double helix's uniform width possible. Other combinations don't fit the helix geometry correctly." },
  { claim: '"G-C pairs are simply bigger than A-T pairs, which is why they bond more strongly."', truth: "The extra strength comes from an additional hydrogen bond (3 vs. 2), not from size — in fact, a purine (A or G) always pairs with a pyrimidine (T or C) specifically so that every base pair has the same overall width, regardless of which two bases are paired." },
  { claim: '"A DNA strand\'s complement and its reverse complement are the same thing."', truth: "They differ in directionality. The plain complement pairs each base directly (read in the same 3'-to-5' order as the original 5'-to-3' strand), while the reverse complement additionally reverses that sequence to give the conventional 5'-to-3' reading of the opposite strand." },
  { claim: '"RNA pairs with DNA using the exact same rules as DNA pairs with DNA."', truth: 'The pairing logic is nearly identical, but RNA substitutes uracil (U) for thymine (T) — so DNA adenine pairs with RNA uracil, not RNA thymine (RNA doesn\'t contain thymine at all).' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 14, "DNA Structure and Function" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/14-1-historical-basis-of-modern-understanding" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Watson &amp; Crick (1953)</strong> — original description of the DNA double helix and base-pairing rules, <em>Nature</em>.' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — DNA structure and hydrogen bonding chapter.' },
];
const sourcesNote = "Pairing: A↔T (DNA) or A↔U (RNA), G↔C. Hydrogen bonds: A-T=2, G-C=3. Results assume standard Watson-Crick pairing.";

const howToUse = [
  { title: 'Enter a DNA sequence', body: 'Type a sequence using only the letters A, T, C, and G.' },
  { title: 'Read both partner strands', body: 'Complementary DNA and equivalent RNA strands display side by side, base-by-base.' },
  { title: 'Check hydrogen bonds', body: 'The total bond count and A-T/G-C breakdown compute automatically.' },
];

const related = [
  { href: '/tools/reverse-complement-calculator', emoji: '🔄', title: 'Reverse Complement Sequence Tool', desc: "Find the conventional 5'-to-3' reverse complement." },
  { href: '/tools/gc-content-calculator', emoji: '🧫', title: 'GC Content Calculator', desc: 'Percentage of G and C bases in a sequence.' },
  { href: '/tools/dna-melting-temperature-calculator', emoji: '🌡️', title: 'DNA Melting Temperature Calculator', desc: 'Wallace rule Tm from sequence composition.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="every rung of the DNA double helix is built from exactly one of two possible base pairs, and the only difference between them — two hydrogen bonds versus three — explains nearly everything about how strongly a stretch of DNA holds itself together."
  howIntro="Complementary base pairing is the chemical rule that makes the DNA double helix possible: adenine only pairs with thymine, and guanine only pairs with cytosine, each pairing a two-ringed purine with a one-ringed pyrimidine so every rung of the helix has the same width. In RNA, uracil takes thymine's place in pairing with adenine, but the G-C rule stays identical. Because A-T pairs form only two hydrogen bonds while G-C pairs form three, a stretch of DNA rich in G and C is measurably harder to pull apart than one rich in A and T — a simple bond-counting difference that ripples out into DNA melting temperature, primer design, and sequencing chemistry."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where base-pairing rules actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">DNA sequence (5' → 3')</span>
      <input id="seq" type="text" value="ATGCGC" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 p-4"><div class="text-xs text-slate-500">Complementary DNA (3' → 5')</div><div id="r-dna" class="mt-1 break-all font-mono text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4"><div class="text-xs text-slate-500">Equivalent RNA (3' → 5')</div><div id="r-rna" class="mt-1 break-all font-mono text-lg font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Total H-bonds</div><div id="r-hbonds" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">A-T pairs</div><div id="r-at" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">G-C pairs</div><div id="r-gc" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="bp-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">A-T-rich vs. G-C-rich double helix</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-atrich" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A-T-rich region</h3>
          <p class="mt-1 text-sm text-slate-600">Every rung is a 2-hydrogen-bond A-T pair — a comparatively weaker double helix.</p>
        </div>
        <div>
          <div id="diag-gcrich" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. G-C-rich region</h3>
          <p class="mt-1 text-sm text-slate-600">Every rung is a 3-hydrogen-bond G-C pair — a comparatively stronger double helix.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Base-pairing charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Base composition of your sequence</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-comp"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Hydrogen bonds: A-T vs. G-C contribution</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-bonds"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const dnaPair = { A: 'T', T: 'A', C: 'G', G: 'C' };
      const rnaPair = { A: 'U', T: 'A', C: 'G', G: 'C' };
      let charts = {};

      // ---- calculator ----
      function update() {
        el('bp-err').textContent = '';
        ['r-dna', 'r-rna', 'r-hbonds', 'r-at', 'r-gc'].forEach((id) => el(id).textContent = '—');
        const seq = el('seq').value.toUpperCase().replace(/\s/g, '');
        if (!seq) return;
        if (!/^[ATCG]+$/.test(seq)) { el('bp-err').textContent = 'Sequence must contain only A, T, C, and G.'; return; }
        let dnaOut = '', rnaOut = '', at = 0, gc = 0;
        for (const base of seq) {
          dnaOut += dnaPair[base];
          rnaOut += rnaPair[base];
          if (base === 'A' || base === 'T') at++; else gc++;
        }
        const hbonds = at * 2 + gc * 3;
        el('r-dna').textContent = dnaOut;
        el('r-rna').textContent = rnaOut;
        el('r-hbonds').textContent = String(hbonds);
        el('r-at').textContent = String(at);
        el('r-gc').textContent = String(gc);
        const counts = { A: 0, T: 0, C: 0, G: 0 };
        for (const base of seq) counts[base]++;
        updateCharts(counts, at, gc);
      }
      el('seq').addEventListener('input', update);

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.comp = new Chart(el('chart-comp'), {
          type: 'bar',
          data: { labels: ['A', 'T', 'C', 'G'], datasets: [{ label: 'Count', data: [1, 1, 2, 2], backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Base count' } } }, plugins: { legend: { display: false } } }),
        });
        charts.bonds = new Chart(el('chart-bonds'), {
          type: 'pie',
          data: { labels: ['A-T H-bonds', 'G-C H-bonds'], datasets: [{ data: [4, 12], backgroundColor: ['#6366f1', '#f59e0b'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }
      function updateCharts(counts, at, gc) {
        if (charts.comp) { charts.comp.data.datasets[0].data = [counts.A, counts.T, counts.C, counts.G]; charts.comp.update('none'); }
        if (charts.bonds) { charts.bonds.data.datasets[0].data = [at * 2, gc * 3]; charts.bonds.update('none'); }
      }

      function helixScene(container, pairType) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const rungs = 6;
        for (let i = 0; i < rungs; i++) {
          const y = (i - rungs / 2) * 0.6;
          const angle = i * 0.9;
          const r = 1.4;
          const x1 = Math.cos(angle) * r, z1 = Math.sin(angle) * r;
          const x2 = Math.cos(angle + Math.PI) * r, z2 = Math.sin(angle + Math.PI) * r;
          const color = pairType === 'at' ? 0x6366f1 : 0xf59e0b;
          const rungGeo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(x1, y, z1), new THREE.Vector3(x2, y, z2)]);
          s.scene.add(new THREE.Line(rungGeo, new THREE.LineBasicMaterial({ color })));
          [{ x: x1, z: z1 }, { x: x2, z: z2 }].forEach((p) => {
            const sph = new THREE.Mesh(new THREE.SphereGeometry(0.16, 10, 8), new THREE.MeshStandardMaterial({ color }));
            sph.position.set(p.x, y, p.z);
            s.scene.add(sph);
          });
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.004); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagAt = null, diagGc = null;
      function initDiagAt() { const c = el('diag-atrich'); if (!c) throw new Error('no container'); diagAt = helixScene(c, 'at'); }
      function initDiagGc() { const c = el('diag-gcrich'); if (!c) throw new Error('no container'); diagGc = helixScene(c, 'gc'); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[dna-base-pairing] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagAt(); } catch (e) { console.error('[dna-base-pairing] A-T diagram failed', e); }
          try { initDiagGc(); } catch (e) { console.error('[dna-base-pairing] G-C diagram failed', e); }
        }
        mountResize([diagAt, diagGc]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
