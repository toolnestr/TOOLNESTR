---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Rice to Water Ratio Calculator';
const description =
  'Free rice to water ratio calculator. Find the exact water needed for white rice, brown rice, and other varieties, plus approximate cooking time.';
const intro =
  'Select your rice type and enter the amount of rice to see the precise water needed and approximate cooking time.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'Why do different rice types need different water ratios?', a: 'Each rice variety has a different starch composition and grain structure. White rice has had the bran removed, so it absorbs water faster and needs less water. Brown rice retains the bran layer, which acts as a barrier to water absorption, so it needs more water and a longer cooking time. Basmati and jasmine are long-grain varieties with different starch profiles that affect how much water they absorb while remaining fluffy.' },
  { q: 'What is the standard rice-to-water ratio?', a: 'The most common ratio for white rice is 1:1.5 (1 cup rice to 1.5 cups water). Brown rice typically needs 1:2 or 1:2.25. However, these ratios can vary based on the age of the rice, the cooking method (stovetop vs rice cooker vs Instant Pot), and personal preference for softer or firmer rice.' },
  { q: 'Should I rinse rice before cooking?', a: 'Yes — rinsing rice under cold water until the water runs clear removes excess surface starch that can make rice gummy or sticky. This is especially important for white rice, basmati and jasmine. Brown rice benefits from rinsing too, though it is less critical. Some enriched rice varieties advise against rinsing to preserve added nutrients.' },
  { q: 'Does the cooking method change the water ratio?', a: 'Yes. Rice cookers generally use slightly less water than stovetop methods because less water evaporates during cooking. The absorption method (bring to boil, cover, simmer) typically uses the ratios this calculator provides. The pasta method (cook in abundant water, drain) uses much more water and is not recommended for most rice types as it washes away flavour and nutrients.' },
  { q: 'How much does rice expand when cooked?', a: 'Most rice types approximately triple in volume and weight when cooked. One cup of uncooked white rice yields about 3 cups of cooked rice (enough for 3–4 side servings). Brown rice yields slightly less — about 2.5 to 3 cups of cooked rice per cup of uncooked.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Rice type</span>
        <select id="riceType" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="1.5">White rice (long-grain)</option>
          <option value="1.75">Basmati rice</option>
          <option value="1.5">Jasmine rice</option>
          <option value="2.25">Brown rice</option>
          <option value="2">Brown basmati rice</option>
          <option value="1.5">Sushi rice (short-grain)</option>
          <option value="1.75">Wild rice</option>
          <option value="1.25">Parboiled rice</option>
          <option value="2">Arborio rice (risotto)</option>
        </select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Rice amount (cups)</span>
        <input id="riceAmt" type="number" step="0.25" placeholder="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Water needed</div>
        <div id="r-water" class="mt-1 text-3xl font-bold">— cups</div>
        <div id="r-water-ml" class="mt-1 text-sm opacity-80">— ml</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Rice amount</div><div id="r-rice" class="mt-1 text-xl font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Yield (cooked)</div><div id="r-yield" class="mt-1 text-xl font-bold text-slate-700">— cups</div></div>
      </div>
      <div class="mt-3 rounded-xl bg-slate-50 p-4 text-center">
        <div class="text-sm text-slate-500">Simmer time</div>
        <div id="r-time" class="mt-1 text-lg font-bold text-indigo-600">— minutes</div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Select rice type and enter the amount to see the water ratio.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The Rice to Water Ratio Calculator applies standardised water ratios for each common rice variety. Each rice type has a different water absorption rate determined by its grain structure, starch content and whether the bran layer is intact. The calculator multiplies your rice volume by the appropriate ratio to give you the exact water required, along with the estimated cooked yield and recommended simmering time.
    </p>
    <p class="mt-3 text-slate-600">
      The ratios used in this calculator are derived from recommendations by rice producers, the USA Rice Federation and extensive culinary testing. They assume the standard absorption method: bring rice and water to a boil, reduce to a low simmer, cover tightly and cook without lifting the lid until all water is absorbed. For rice cooker users, these same ratios work well for most electric cookers, though some models may require slightly less water.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="rw-title rw-desc">
      <title id="rw-title">Rice to water ratio diagram</title>
      <desc id="rw-desc">Side-by-side measuring cups showing rice and water in their correct proportional relationship for different rice varieties.</desc>
      <!-- Rice cup -->
      <rect x="120" y="30" width="100" height="140" rx="6" fill="#f1f5f9" stroke="#94a3b8" stroke-width="2" />
      <rect x="130" y="100" width="80" height="60" rx="3" fill="#fef3c7" />
      <text x="170" y="48" text-anchor="middle" font-size="12" font-weight="bold" fill="#475569">RICE</text>
      <text x="170" y="140" text-anchor="middle" font-size="13" font-weight="bold" fill="#92400e">1 cup</text>

      <!-- Plus sign -->
      <text x="270" y="110" text-anchor="middle" font-size="28" font-weight="bold" fill="#6366f1">+</text>

      <!-- Water cup (filled to different levels) -->
      <rect x="310" y="30" width="100" height="140" rx="6" fill="#f1f5f9" stroke="#6366f1" stroke-width="2" />
      <rect x="320" y="55" width="80" height="105" rx="3" fill="#bfdbfe" opacity="0.8" />
      <text x="360" y="48" text-anchor="middle" font-size="12" font-weight="bold" fill="#475569">WATER</text>
      <text x="360" y="200" text-anchor="middle" font-size="13" font-weight="bold" fill="#1e40af">1.5 cups</text>

      <!-- Equals sign -->
      <text x="470" y="110" text-anchor="middle" font-size="28" font-weight="bold" fill="#10b981">=</text>

      <!-- Cooked rice -->
      <rect x="530" y="30" width="140" height="140" rx="6" fill="#f1f5f9" stroke="#10b981" stroke-width="2" />
      <rect x="540" y="60" width="120" height="100" rx="3" fill="#fef3c7" />
      <text x="600" y="48" text-anchor="middle" font-size="12" font-weight="bold" fill="#475569">COOKED</text>
      <text x="600" y="130" text-anchor="middle" font-size="13" font-weight="bold" fill="#92400e">~3 cups</text>

      <!-- Ratio label -->
      <text x="170" y="188" text-anchor="middle" font-size="11" fill="#64748b">(white rice)</text>
      <text x="360" y="215" text-anchor="middle" font-size="11" fill="#64748b">1 : 1.5 ratio</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">The 1:1.5 rice-to-water ratio for white rice yields approximately 3 cups of cooked rice</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the conversion works</h2>
    <p class="mt-2 text-slate-600">
      The calculation is simple: <strong>water = rice × ratio</strong>. Each rice type has a specific ratio stored in the calculator. The cooked yield is estimated as rice × 3 (for most white varieties) or rice × 2.5 (for brown and wild rice). Simmer times are based on standard culinary guidelines.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">You are cooking 1.5 cups of brown rice for a hearty grain bowl. How much water do you need and how long should it cook?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Rice type:</span> <span class="text-slate-600">Brown rice</span></div>
        <div><span class="font-medium text-slate-700">Rice amount:</span> <span class="text-slate-600">1.5 cups</span></div>
        <div><span class="font-medium text-slate-700">Water ratio:</span> <span class="text-slate-600">2.25</span></div>
        <div><span class="font-medium text-slate-700">Water needed:</span> <span class="text-slate-600">1.5 × 2.25 = <strong>3.38 cups</strong> (≈ 800 ml)</span></div>
        <div><span class="font-medium text-slate-700">Cooked yield:</span> <span class="text-slate-600">1.5 × 2.5 = <strong>3.75 cups</strong></span></div>
        <div><span class="font-medium text-slate-700">Simmer time:</span> <span class="text-slate-600"><strong>40–50 minutes</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Daily home cook</h3>
      <p class="mt-1 text-sm text-slate-600">Making rice for weeknight dinners and need consistent, reliable results without having to remember different water ratios for different rice types.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🥗</span>
      <h3 class="mt-2 font-semibold text-slate-900">Meal prepper</h3>
      <p class="mt-1 text-sm text-slate-600">Cooking large batches of rice for the week and need to scale the water accurately to avoid mushy or undercooked results in your meal prep containers.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌍</span>
      <h3 class="mt-2 font-semibold text-slate-900">International cuisine explorer</h3>
      <p class="mt-1 text-sm text-slate-600">Trying recipes from different cuisines — biryani, risotto, sushi, jollof — each requiring a specific rice variety and its correct water ratio.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍱</span>
      <h3 class="mt-2 font-semibold text-slate-900">Rice cooker user</h3>
      <p class="mt-1 text-sm text-slate-600">Translating stovetop rice recipes to your rice cooker by understanding the correct water ratios that work in your specific appliance model.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Rice to Water Ratio Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select your rice type</h3>
        <p class="mt-1 text-sm text-slate-600">Choose from white, brown, basmati, jasmine, sushi, wild, parboiled or arborio rice. Each type has a specific water ratio.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the rice amount</h3>
        <p class="mt-1 text-sm text-slate-600">Type how many cups of uncooked rice you are using. The calculator works with fractional amounts like 0.5, 1.75 or 3.25.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Cook your rice</h3>
        <p class="mt-1 text-sm text-slate-600">Use the calculated water amount and simmer time. Bring to a boil, cover, reduce heat and cook without lifting the lid until done.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always rinse your rice</h3>
        <p class="mt-1 text-sm text-slate-600">Rinse rice in a fine-mesh strainer under cold running water for 30–60 seconds until the water runs mostly clear. This removes surface starch that causes clumping and gives you fluffier, separated grains.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Let it rest after cooking</h3>
        <p class="mt-1 text-sm text-slate-600">Once the cooking time is up, remove the pot from the heat and let it sit, covered, for 5–10 minutes. This allows the steam to finish distributing evenly through the rice, and the grains to firm up slightly before serving.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Fluff with a fork</h3>
        <p class="mt-1 text-sm text-slate-600">After resting, fluff the rice gently with a fork or rice paddle to separate the grains. Avoid stirring vigorously, which can break the grains and release starch that makes the rice gummy.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/cooking-measurement-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🥄</span>
        <h3 class="mt-2 font-semibold text-slate-900">Cooking Measurement Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert cups, tbsp, tsp, ml and fl oz</p>
      </a>
      <a href="/tools/recipe-scaling-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">📝</span>
        <h3 class="mt-2 font-semibold text-slate-900">Recipe Scaling Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Scale recipes up or down by servings</p>
      </a>
      <a href="/tools/baking-conversion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">⚖️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Conversion Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Volume to weight for baking ingredients</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    const riceData = {
      '1.5': { name: 'White rice', ratio: 1.5, yield: 3, time: '15–20' },
      '1.75': { name: 'Basmati rice', ratio: 1.75, yield: 3, time: '15–20' },
      '2.25': { name: 'Brown rice', ratio: 2.25, yield: 2.5, time: '40–50' },
      '2': { name: 'Brown basmati', ratio: 2, yield: 2.5, time: '35–45' },
      '1.25': { name: 'Parboiled rice', ratio: 1.25, yield: 3, time: '20–25' },
    };

    function update() {
      const sel = el('riceType');
      const ratio = parseFloat(sel.value);
      const rice = parseFloat(el('riceAmt').value);
      const data = riceData[sel.value] || { name: 'Rice', ratio, yield: 3, time: '15–20' };

      if (!rice || rice <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      const water = rice * ratio;
      const waterMl = water * 236.588;
      const yieldCooked = rice * data.yield;

      el('r-water').innerHTML = water.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' <span class="text-lg opacity-80">cups</span>';
      el('r-water-ml').textContent = Math.round(waterMl).toLocaleString() + ' ml';
      el('r-rice').textContent = rice.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' cups';
      el('r-yield').textContent = yieldCooked.toLocaleString(undefined, { maximumFractionDigits: 1 }) + ' cups';
      el('r-time').textContent = data.time + ' minutes';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('riceType').addEventListener('input', update);
    el('riceAmt').addEventListener('input', update);
  </script>
</ToolLayout>
