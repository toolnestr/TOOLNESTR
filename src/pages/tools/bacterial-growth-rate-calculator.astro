---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Bacterial Growth Rate Calculator';
const description = 'Bacterial growth rate calculator with a live 3D colony diagram and charts. Solve the specific growth rate constant k = ln(Nt/N0)/t from population counts at two time points, with worked examples.';
const intro = 'Solve k = ln(Nt/N0)/t for the specific growth rate constant of a bacterial population growing exponentially, from an initial count, a later count, and the elapsed time. Two 3D diagrams compare a slow-growing colony to a fast-growing one, and charts show exponential growth curves at different growth rates.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is the bacterial growth rate constant?', a: 'The specific growth rate constant (k or µ) measures how fast a bacterial population grows exponentially, in units of per hour (or per minute) — a higher k means faster growth.' },
  { q: 'How is growth rate calculated from population counts?', a: 'Using k = ln(Nt/N0)/t, where N0 is the initial population, Nt is the population after time t, and ln is the natural logarithm — this comes directly from solving the exponential growth equation Nt = N0·e^(kt) for k.' },
  { q: 'How is growth rate related to doubling time?', a: 'They are directly connected by doubling time = ln(2)/k — a higher growth rate constant always means a shorter doubling time, and vice versa.' },
  { q: 'Does every bacterial population grow at a constant rate forever?', a: 'No — exponential growth with a constant k only holds during the log (exponential) phase of growth. As nutrients deplete and waste accumulates, growth slows into the stationary phase, where the growth rate constant effectively drops toward zero.' },
  { q: 'Why do different bacterial species have very different growth rates?', a: 'Growth rate depends on a species\' metabolic efficiency, the temperature, nutrient availability, and genetic factors — E. coli under ideal lab conditions can double every 20 minutes, while some slow-growing environmental bacteria may take days per generation.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Bacterial Growth Rate Calculator',
  description: 'Solve the exponential growth rate constant k from population counts at two time points.',
  steps: [
    { name: 'Enter initial and final population', text: 'Type the population count at the start (N0) and after some elapsed time (Nt).' },
    { name: 'Enter the elapsed time', text: 'Provide the time between the two counts, in hours.' },
    { name: 'Read the growth rate constant', text: 'k solves instantly, along with the corresponding doubling time.' },
  ],
};

const formulas = [
  { expr: 'Nt = N0·e^(kt)', note: 'exponential growth model — N0=initial population, Nt=population at time t, k=growth rate constant' },
  { expr: 'k = ln(Nt/N0) / t', note: 'solve for the specific growth rate constant' },
  { expr: 'Doubling time = ln(2) / k', note: 'time for the population to double, derived from k' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a culture growing in a lab flask', tone: 'slate',
    given: 'A bacterial culture starts at N0 = 1000 cells and grows to Nt = 8000 cells over t = 3 hours.',
    rows: [
      { label: 'Formula:', value: 'k = ln(Nt/N0) / t' },
      { label: 'Substitute:', value: 'k = ln(8000/1000) / 3 = ln(8) / 3' },
      { label: 'Result:', value: 'k ≈ 0.693 per hour, so doubling time = ln(2)/0.693 ≈ 1.00 hour', full: true },
    ],
    note: 'A doubling time of exactly 1 hour makes sense here — the population doubled three times (1000→2000→4000→8000) in exactly 3 hours.',
  },
  {
    title: 'Worked example 2 — comparing two bacterial species', tone: 'amber',
    given: 'Species A grows from 500 to 4000 cells in 2 hours. Species B grows from 500 to 4000 cells in 6 hours.',
    rows: [
      { label: 'Species A growth rate:', value: 'k = ln(8)/2 ≈ 1.04 per hour (doubling time ≈ 40 min)' },
      { label: 'Species B growth rate:', value: 'k = ln(8)/6 ≈ 0.347 per hour (doubling time ≈ 2 hours)' },
      { label: 'Comparison:', value: 'Species A grows exactly 3× faster than Species B, despite reaching the identical final population', full: true },
    ],
    note: 'Two populations can reach the same final size from the same starting point yet have dramatically different growth rates — the growth rate constant, not the final count alone, is what actually characterizes growth speed.',
  },
];

const comparison = {
  heading: 'Growth rate constant vs. doubling time',
  note: 'These two numbers describe the same growth speed from two different angles.',
  headers: [{ label: 'Growth rate (k, per hour)' }, { label: 'Doubling time' }],
  rows: [
    ['0.10', '6.93 hours'],
    ['0.35', '1.98 hours'],
    ['0.69 ★', '1.00 hour'],
    ['2.08 (E. coli, ~20 min doubling)', '0.33 hours (20 min)'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). Growth rate and doubling time are always inversely related — a threefold increase in k means a threefold decrease in doubling time.',
};

const realWorld = [
  { emoji: '🏭', title: 'Industrial fermentation', body: 'Biotech and food industries (brewing, antibiotic production, yogurt culturing) monitor bacterial or yeast growth rate constants to optimize batch timing and maximize product yield.' },
  { emoji: '💊', title: 'Antibiotic effectiveness testing', body: "Measuring how an antibiotic changes a bacterial population's growth rate constant (slowing it or driving it negative) is a standard way to quantify how effective a treatment is." },
  { emoji: '🧫', title: 'Clinical microbiology', body: "Understanding a pathogen's typical growth rate helps clinicians predict how quickly an infection might progress and how soon lab cultures will produce a usable result." },
  { emoji: '🌊', title: 'Environmental and water-quality monitoring', body: 'Tracking growth rates of bacteria in water samples helps environmental scientists assess contamination risk and predict how quickly a bacterial bloom might develop.' },
];

const misconceptions = [
  { claim: '"A bacterial population always grows at the same rate constant, no matter how long you observe it."', truth: 'The growth rate constant only stays roughly fixed during the log (exponential) phase. As the population approaches its environment\'s carrying capacity, growth slows down (the stationary phase), and the "constant" k effectively drops toward zero.' },
  { claim: '"Growth rate constant (k) and doubling time measure completely different things."', truth: "They describe the exact same growth speed in two different but mathematically equivalent forms — doubling time = ln(2)/k — so knowing one always tells you the other." },
  { claim: '"A bigger final population count always means faster growth."', truth: "Final population size depends on both growth rate and how much time was allowed to pass — a slow-growing population given a long time can reach the same size as a fast-growing population given a short time, as shown in worked example 2." },
  { claim: '"Bacterial growth rate is measured in the same units as chemical reaction rate constants."', truth: 'Bacterial growth rate constants are typically expressed per unit time (like per hour), representing population growth, while chemical rate constants have units that depend on reaction order and describe concentration change — they\'re conceptually related but not interchangeable.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Microbiology</em></strong> — Chapter 9, "Microbial Growth" (free, peer-reviewed). <a href="https://openstax.org/books/microbiology/pages/9-1-how-microbes-grow" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Madigan et al., <em>Brock Biology of Microorganisms</em></strong> — Microbial growth kinetics chapter.' },
  { html: '<strong>Monod (1949)</strong> — foundational work on bacterial growth kinetics, <em>Annual Review of Microbiology</em>.' },
];
const sourcesNote = 'k = ln(Nt/N0)/t. Assumes exponential (log-phase) growth throughout the observed interval. Results are rounded for display.';

const howToUse = [
  { title: 'Enter initial population (N0)', body: 'The population count at the start of your observation window.' },
  { title: 'Enter final population (Nt) and time', body: 'The later count and the elapsed time between the two measurements.' },
  { title: 'Read k and doubling time', body: 'Both the growth rate constant and its corresponding doubling time solve instantly.' },
];

const related = [
  { href: '/tools/exponential-population-growth-calculator', emoji: '📈', title: 'Exponential Population Growth Calculator', desc: 'N(t) = N₀e^(rt) — unconstrained population growth.' },
  { href: '/tools/serial-dilution-calculator', emoji: '🧫', title: 'Serial Dilution Calculator', desc: 'Dilution factor per step and cumulative dilution.' },
  { href: '/tools/cfu-per-ml-calculator', emoji: '🔬', title: 'CFU per mL Calculator', desc: 'Colony forming units from plate count and dilution.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="as long as a bacterial population is dividing freely with unlimited resources, each cell splits into two on the same fixed schedule, and that single repeating doubling schedule is entirely captured by one number: the growth rate constant."
  howIntro="During its exponential (log) growth phase, a bacterial population grows according to Nt = N0·e^(kt), where every cell divides on the same average schedule. Rearranging this relationship to solve for k directly from two population counts and the time between them gives k = ln(Nt/N0)/t — a single number summarizing exactly how fast that population is multiplying. Because growth rate and doubling time describe the same underlying process, converting between them (doubling time = ln(2)/k) is often just as useful as k itself, since doubling time is more intuitive to reason about directly."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where bacterial growth rate actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial population (N0)</span>
        <input id="n0" type="number" step="any" value="1000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Final population (Nt)</span>
        <input id="nt" type="number" step="any" value="8000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Elapsed time, t (hours)</span>
        <input id="t" type="number" step="any" value="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Growth rate constant (k)</div><div id="r-k" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Doubling time</div><div id="r-td" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="bg-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Slow vs. fast growing colony</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-slow" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Slow growth (low k)</h3>
          <p class="mt-1 text-sm text-slate-600">Fewer cells present after the same elapsed time — a longer doubling time.</p>
        </div>
        <div>
          <div id="diag-fast" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Fast growth (high k)</h3>
          <p class="mt-1 text-sm text-slate-600">Many more cells present after the same elapsed time — a much shorter doubling time.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Growth rate graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Exponential growth at different k values</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-growth"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Doubling time vs. growth rate constant</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-doubling"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('bg-err').textContent = '';
        el('r-k').textContent = '—'; el('r-td').textContent = '—';
        const n0 = parseFloat(el('n0').value), nt = parseFloat(el('nt').value), t = parseFloat(el('t').value);
        if (isNaN(n0) || isNaN(nt) || isNaN(t)) return;
        if (n0 <= 0 || nt <= 0 || t <= 0) { el('bg-err').textContent = 'Population counts and time must be positive.'; return; }
        const k = Math.log(nt / n0) / t;
        el('r-k').textContent = fmt(k) + ' /hr';
        if (k > 0) el('r-td').textContent = fmt(Math.log(2) / k) + ' hr';
        else el('r-td').textContent = 'N/A (no growth)';
      }
      ['n0', 'nt', 't'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labels = [];
        const slowData = [], fastData = [];
        for (let t = 0; t <= 5; t += 0.5) { labels.push(t.toFixed(1)); slowData.push(+(1000 * Math.exp(0.2 * t)).toFixed(0)); fastData.push(+(1000 * Math.exp(0.693 * t)).toFixed(0)); }
        new Chart(el('chart-growth'), {
          type: 'line',
          data: {
            labels,
            datasets: [
              { label: 'k=0.2/hr', data: slowData, borderColor: '#94a3b8', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
              { label: 'k=0.693/hr', data: fastData, borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
            ],
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (hours)' } }, y: { title: { display: true, text: 'Population' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        const kLabels = [], tdData = [];
        for (let k = 0.1; k <= 2; k += 0.1) { kLabels.push(k.toFixed(1)); tdData.push(+(Math.log(2) / k).toFixed(2)); }
        new Chart(el('chart-doubling'), {
          type: 'line',
          data: { labels: kLabels, datasets: [{ label: 'Doubling time (hr)', data: tdData, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Growth rate k (/hr)' } }, y: { title: { display: true, text: 'Doubling time (hr)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function colonyScene(container, count) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < count; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.18, 10, 8), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          m.position.set((Math.random() - 0.5) * 4, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 3);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSlow = null, diagFast = null;
      function initDiagSlow() { const c = el('diag-slow'); if (!c) throw new Error('no container'); diagSlow = colonyScene(c, 8); }
      function initDiagFast() { const c = el('diag-fast'); if (!c) throw new Error('no container'); diagFast = colonyScene(c, 40); }

      function boot() {
        try { update(); } catch (e) { console.error('[bacterial-growth-rate] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[bacterial-growth-rate] charts failed', e); }
        if (window.THREE) {
          try { initDiagSlow(); } catch (e) { console.error('[bacterial-growth-rate] slow diagram failed', e); }
          try { initDiagFast(); } catch (e) { console.error('[bacterial-growth-rate] fast diagram failed', e); }
        }
        mountResize([diagSlow, diagFast]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
