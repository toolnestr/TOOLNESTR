---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'EV vs Gas Savings Calculator';
const description =
  'Free EV vs gas savings calculator. Compare total cost of ownership between an electric ' +
  'vehicle and a gasoline vehicle over any ownership period.';
const intro =
  'Enter purchase prices, annual miles, fuel costs, maintenance and other expenses to compare ' +
  'the 5-year (or any period) total cost of EV vs gas.';
const category = { id: 'automotive', name: 'Automotive' };
const faqs = [
  { q: 'How much can I save by switching to an EV?', a: 'On average, EV owners save $5,000–10,000 over 5 years compared to a similar gasoline vehicle. The savings come from cheaper fuel (electricity vs gasoline), lower maintenance (fewer moving parts, no oil changes), and tax incentives of up to $7,500 in the US.' },
  { q: 'What is the break-even point for an EV?', a: 'The break-even point is typically 3–5 years for most buyers. If an EV costs $10,000 more upfront than a gas car but saves $2,500/year in fuel and maintenance, the break-even is 4 years. After that, the EV is pure savings.' },
  { q: 'How much cheaper is EV maintenance?', a: 'EVs have 30–50% lower maintenance costs over their lifetime. No oil changes, no timing belts, no exhaust systems, no spark plugs, and no transmission service. The main EV maintenance items are tires, cabin air filters, brake fluid, and coolant — and regenerative braking means brakes last 2–3x longer.' },
  { q: 'Does the EV tax credit affect the comparison?', a: 'Yes. In the US, the federal tax credit of up to $7,500 significantly changes the total cost equation. Some states add additional incentives. The Inflation Reduction Act (IRA) has specific requirements about battery sourcing and vehicle price caps that determine eligibility.' },
  { q: 'Are EVs more expensive to insure?', a: 'EVs typically cost 10–30% more to insure than comparable gas cars due to higher repair costs and specialized parts. However, some insurers offer EV-specific policies with lower rates. The difference is usually $100–300/year more for an EV.' },
  { q: 'Does resale value differ between EV and gas?', a: 'EV resale values have been improving. Early EVs depreciated faster than gas cars due to battery degradation concerns and rapid technology improvements. Modern EVs with long-range batteries (200+ miles) retain value better, though gas cars still generally have a small edge in resale value.' },
  { q: 'How do electricity and gas prices affect savings?', a: 'The gap widens when gas prices are high and electricity rates are low. At $4/gal gas and $0.14/kWh electricity, an EV saves about $0.08/mile in fuel alone. If gas drops to $2.50/gal, the per-mile saving drops to about $0.04/mile.' },
  { q: 'What costs should I include in a TCO comparison?', a: 'A complete total cost of ownership comparison includes: purchase price (minus incentives), fuel/energy costs, maintenance, repairs, insurance, registration/fees, tires, and resale value. Some regions have higher registration fees for EVs that should be factored in.' },
  { q: 'Are there hidden costs of EV ownership?', a: 'Yes. Level 2 home charger installation costs $500–2,000. Some states charge higher registration fees for EVs ($50–200/year extra to replace gas tax revenue). Battery replacement (rarely needed within the first 10 years) can cost $5,000–15,000, though most batteries last 150,000–200,000+ miles.' },
  { q: 'Do EVs save money in the long run?', a: 'For most drivers, yes. Over 10 years and 150,000 miles, an EV typically saves $10,000–20,000 compared to a gas car. The savings are largest for people who drive many miles (15,000+/year), have access to home charging, and live in states with moderate electricity rates.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">EV purchase price ($)</span>
        <input id="evp" type="number" step="100" placeholder="45000" value="45000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gas car purchase price ($)</span>
        <input id="gcp" type="number" step="100" placeholder="35000" value="35000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Annual miles</span>
        <input id="ann" type="number" step="100" placeholder="12000" value="12000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">EV efficiency (mi/kWh)</span>
        <input id="eff" type="number" step="0.1" placeholder="3.5" value="3.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gas MPG</span>
        <input id="mpg" type="number" step="1" placeholder="30" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Elec. rate ($/kWh)</span>
        <input id="er" type="number" step="0.001" placeholder="0.14" value="0.14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gas price ($/gal)</span>
        <input id="gp" type="number" step="0.01" placeholder="3.50" value="3.50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">EV maint. ($/yr)</span>
        <input id="evm" type="number" step="10" placeholder="300" value="300" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gas maint. ($/yr)</span>
        <input id="gcm" type="number" step="10" placeholder="800" value="800" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Insurance diff. ($/yr)</span>
        <input id="ins" type="number" step="10" placeholder="200" value="200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Tax incentive ($)</span>
        <input id="taxi" type="number" step="100" placeholder="7500" value="7500" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Ownership (years)</span>
        <input id="yrs" type="number" step="1" placeholder="5" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">EV total cost</div><div id="r-ev-total" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-red-600 p-4 text-center text-white"><div class="text-xs opacity-80">Gas total cost</div><div id="r-gas-total" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-emerald-600 p-4 text-center text-white"><div class="text-xs opacity-80">Total savings</div><div id="r-savings" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Break-even year</div><div id="r-be" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Cumulative cost comparison: EV vs Gas by year</h2>
    <p class="mt-2 text-slate-600">The bars below show the estimated cumulative cost of each vehicle year by year.</p>
    <div id="chart-area" class="mt-5 space-y-3"></div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚗</span>
      <h3 class="mt-2 font-semibold text-slate-900">Car Buyer</h3>
      <p class="mt-1 text-sm text-slate-600">Compare the true cost of ownership between an EV and gas car before visiting a dealership so you know which powertrain makes financial sense for you.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📊</span>
      <h3 class="mt-2 font-semibold text-slate-900">Fleet Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Model TCO across your fleet to determine which routes and use cases favor EVs vs gas vehicles and plan your electrification strategy with confidence.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📈</span>
      <h3 class="mt-2 font-semibold text-slate-900">Financial Planner</h3>
      <p class="mt-1 text-sm text-slate-600">Help clients understand the long-term financial implications of EV ownership including incentives, fuel savings, and maintenance cost differences.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌿</span>
      <h3 class="mt-2 font-semibold text-slate-900">Environmentalist</h3>
      <p class="mt-1 text-sm text-slate-600">Show that the financial case for EVs is compelling alongside the environmental benefits — lower carbon emissions from day one, improving with grid decarbonization.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Comparison</th><th class="p-3">EV price</th><th class="p-3">Gas car price</th><th class="p-3">Annual fuel cost (EV)</th><th class="p-3">Annual fuel cost (gas)</th><th class="p-3">5-year savings</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Tesla Model 3 vs Camry</td><td class="p-3">$40,000</td><td class="p-3">$30,000</td><td class="p-3">$480</td><td class="p-3">$1,400</td><td class="p-3">$9,600</td></tr>
        <tr><td class="p-3 font-medium">Model Y vs RAV4</td><td class="p-3">$45,000</td><td class="p-3">$34,000</td><td class="p-3">$600</td><td class="p-3">$1,600</td><td class="p-3">$10,000</td></tr>
        <tr><td class="p-3 font-medium">F-150 Lightning vs F-150</td><td class="p-3">$55,000</td><td class="p-3">$42,000</td><td class="p-3">$900</td><td class="p-3">$2,400</td><td class="p-3">$11,500</td></tr>
        <tr><td class="p-3 font-medium">Chevy Bolt vs Civic</td><td class="p-3">$27,000</td><td class="p-3">$26,000</td><td class="p-3">$480</td><td class="p-3">$1,200</td><td class="p-3">$5,600</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the EV vs Gas Savings Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter purchase prices</h3>
        <p class="mt-1 text-sm text-slate-600">Input the purchase price (after any negotiation) for both the EV and the gas car you are comparing. Add any applicable tax incentive for the EV.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter usage details</h3>
        <p class="mt-1 text-sm text-slate-600">Set annual miles, fuel efficiency for each vehicle, local electric and gas prices, annual maintenance estimates, and your insurance cost difference.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">See break-even point</h3>
        <p class="mt-1 text-sm text-slate-600">View total cost for each vehicle over the ownership period and the year when the EV becomes the cheaper option — at the break-even point.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for an accurate comparison</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Include all incentives</h3>
        <p class="mt-1 text-sm text-slate-600">Federal tax credits (up to $7,500 US), state rebates, utility rebates, and local incentives can significantly reduce the effective EV purchase price. Check current eligibility as rules change frequently.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Maintenance is 30–50% less for EVs</h3>
        <p class="mt-1 text-sm text-slate-600">EVs have fewer moving parts and no oil changes, timing belts, spark plugs, or exhaust systems. Regenerative braking extends brake life by 2–3x. Budget about $300/year for EV maintenance vs $600–1,000 for a gas car.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Resale value matters</h3>
        <p class="mt-1 text-sm text-slate-600">While EVs traditionally depreciated faster, the gap is closing. After 5 years, a gas car might retain 45–50% of its value while an EV retains 40–45%. The savings from lower running costs typically outweigh the depreciation difference.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Total cost of ownership components</h2>
    <p class="mt-2 text-slate-600">
      Total Cost of Ownership (TCO) is the only fair way to compare EV vs gas vehicle costs. It
      includes: purchase price (minus incentives), annual fuel/energy costs, routine maintenance,
      repairs, insurance premiums, registration fees, and estimated resale value at the end of the
      ownership period. A comprehensive TCO analysis often shows that an EV with a $10,000 higher
      purchase price can be cheaper over 5–7 years.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Fuel savings math</h2>
    <p class="mt-2 text-slate-600">
      The fuel cost comparison is straightforward but dramatic. At $0.14/kWh and 3.5 mi/kWh, an EV
      costs $0.04/mile. At $3.50/gal and 30 MPG, a gas car costs $0.117/mile. Over 12,000 miles per
      year, that's $480 vs $1,400 — a $920 annual saving. As gas prices rise or if you charge on
      time-of-use rates ($0.08/kWh), the EV advantage grows. At $5/gal gas, the gas car costs $2,000/year
      while the EV still costs ~$400.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Maintenance savings</h2>
    <p class="mt-2 text-slate-600">
      EVs eliminate most routine ICE maintenance. No oil changes (save $100–200/year), no transmission
      service, no spark plugs, no timing belt, no exhaust system, no starter motor, and no fuel system
      cleaning. The main EV maintenance needs are: tire rotations and replacement, cabin air filters,
      brake fluid flushes (every 2–3 years), and coolant changes (every 5 years). Overall, EV
      maintenance is approximately 30–50% lower over the vehicle's lifetime.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Break-even calculation explained</h2>
    <p class="mt-2 text-slate-600">
      The break-even point is the year when the cumulative cost of owning the EV becomes equal to
      the gas car. It is calculated by dividing the price difference (EV price minus gas price minus
      incentive) by the annual savings in fuel, maintenance and insurance. For example, a $10,000
      higher EV price with $2,500/year in savings breaks even in year 4. Every year after that,
      the EV saves you $2,500/year.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (n) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    function update() {
      const evp = parseFloat(el('evp').value);
      const gcp = parseFloat(el('gcp').value);
      const ann = parseFloat(el('ann').value);
      const eff = parseFloat(el('eff').value);
      const mpg = parseFloat(el('mpg').value);
      const er = parseFloat(el('er').value);
      const gp = parseFloat(el('gp').value);
      const evm = parseFloat(el('evm').value);
      const gcm = parseFloat(el('gcm').value);
      const ins = parseFloat(el('ins').value);
      const taxi = parseFloat(el('taxi').value) || 0;
      const yrs = parseFloat(el('yrs').value);
      if ([evp, gcp, ann, eff, mpg, er, gp, evm, gcm, ins, yrs].some(v => isNaN(v) || v <= 0)) {
        ['r-ev-total','r-gas-total','r-savings','r-be'].forEach(id => el(id).textContent = '—');
        el('chart-area').innerHTML = ''; return;
      }
      const evFuel = ann / eff * er;
      const gasFuel = ann / mpg * gp;
      const evAnnual = evFuel + evm + ins;
      const gasAnnual = gasFuel + gcm;
      const evNet = evp - taxi;
      const evTotal = evNet + evAnnual * yrs;
      const gasTotal = gcp + gasAnnual * yrs;
      const savings = gasTotal - evTotal;
      const annualDiff = gasAnnual - evAnnual;
      const priceDiff = evNet - gcp;
      let be = priceDiff > 0 ? Math.ceil(priceDiff / annualDiff) : 1;
      if (be < 1) be = 1;
      if (be > yrs) be = null;
      el('r-ev-total').textContent = fmt(evTotal);
      el('r-gas-total').textContent = fmt(gasTotal);
      el('r-savings').textContent = fmt(savings);
      el('r-be').textContent = be !== null && be <= yrs ? 'Year ' + be : 'After ' + yrs + ' yrs';
      const maxCost = Math.max(gcp + gasAnnual * yrs, evNet + evAnnual * yrs);
      let html = '';
      for (let y = 1; y <= yrs; y++) {
        const evCum = evNet + evAnnual * y;
        const gasCum = gcp + gasAnnual * y;
        const evW = (evCum / maxCost * 100).toFixed(0);
        const gasW = (gasCum / maxCost * 100).toFixed(0);
        html += '<div><div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Year ' + y + '</span><span class="text-slate-400">EV: ' + fmt(evCum) + ' | Gas: ' + fmt(gasCum) + '</span></div><div class="mt-1 h-5 w-full rounded-full bg-slate-100" style="position:relative"><div class="h-5 rounded-l-full bg-indigo-500" style="width:' + evW + '%;position:absolute;left:0;top:0"></div><div class="h-5 rounded-r-full bg-red-400" style="width:' + gasW + '%;position:absolute;right:0;top:0;opacity:0.7"></div></div></div>';
      }
      el('chart-area').innerHTML = html;
    }
    document.querySelectorAll('input').forEach(e => e.addEventListener('input', update));
  </script>
</ToolLayout>
