---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Yarn Count Converter (Ne ↔ Denier)';
const description = "Convert yarn thickness between English cotton count (Ne) and denier instantly. Enter a value in either unit to get the accurate conversion for spinning.";
const intro = 'Convert yarn thickness between English cotton count (Ne) and denier.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is Ne (English cotton count)?', a: 'Ne is an "indirect" yarn numbering system traditionally used for cotton and cotton-blend yarns, defined as the number of 840-yard hanks of yarn that weigh one pound. A higher Ne number means a finer, thinner yarn — the opposite of denier.' },
  { q: 'Why does a higher Ne mean a thinner yarn, while a higher denier means a thicker one?', a: 'Ne is an indirect system based on length-per-weight (more hanks per pound means thinner thread), while denier is a direct system based on weight-per-length (more grams per fixed length means thicker thread) — the two measure the same physical property from opposite directions.' },
  { q: 'Where does the 5315 conversion constant come from?', a: 'It comes from reconciling the two systems\' reference units: Ne is defined per 840-yard hank per pound, and denier is defined per 9,000 meters in grams — converting those units against each other produces the constant 5,315, a standard figure used throughout the textile industry for cotton-to-denier conversion.' },
  { q: 'Does this work for all fiber types?', a: 'The Ne-to-denier conversion is specifically the cotton count system; wool, worsted, and linen traditionally use their own separate indirect count systems with different constants, so this conversion is most accurate for cotton and cotton-blend yarns.' },
];
const howTo = {
  name: 'How to convert yarn count',
  steps: [
    { name: 'Enter the known value', text: 'Type the yarn count value you already have, in Ne or denier.' },
    { name: 'Choose its unit', text: 'Select which system your starting value is in.' },
    { name: 'Read the converted value', text: 'The equivalent value in the other system appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Ne → Denier', 'Denier → Ne'].map((d) => (
        <button data-mode={d} class="mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span id="input-label" class="text-sm font-medium text-slate-700">Ne (cotton count)</span>
      <input id="value" type="number" step="any" placeholder="e.g. 30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div id="output-label" class="text-sm opacity-80">Denier</div>
        <div id="r-value" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ycc-title ycc-desc">
      <title id="ycc-title">Two arrows pointing opposite directions for Ne and denier</title>
      <desc id="ycc-desc">Two opposing arrows illustrating that higher Ne means finer yarn while higher denier means thicker yarn</desc>
      <line x1="150" y1="60" x2="650" y2="60" stroke="#c026d3" stroke-width="3" marker-end="url(#a1)" />
      <text x="400" y="45" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Higher Ne → finer yarn</text>
      <line x1="650" y1="120" x2="150" y2="120" stroke="#94a3b8" stroke-width="3" marker-end="url(#a2)" />
      <text x="400" y="145" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Higher denier → thicker yarn</text>
      <defs>
        <marker id="a1" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6 Z" fill="#c026d3" /></marker>
        <marker id="a2" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6 Z" fill="#94a3b8" /></marker>
      </defs>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Ne and denier scale in opposite directions for the same yarn</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How Ne-to-denier conversion works</h2>
    <p class="mt-2 text-slate-600">
      English cotton count (Ne) and denier measure the same physical property — how thick or fine a yarn is — but from opposite directions. Ne counts how many 840-yard hanks make up one pound, so a finer yarn needs more hanks to reach a pound, giving it a higher Ne number. Denier weighs a fixed 9,000-meter length in grams, so a thicker yarn weighs more over that same length, giving it a higher denier number.
    </p>
    <p class="mt-3 text-slate-600">
      Reconciling these two opposite-direction systems produces a standard textile-industry constant: denier equals 5,315 divided by Ne, and conversely, Ne equals 5,315 divided by denier. This inverse relationship is why a fine, high-Ne cotton yarn converts to a low denier number, and a coarse, low-Ne yarn converts to a high denier number.
    </p>
    <p class="mt-3 text-xs text-slate-400">The 5,315 constant is the standard cotton-count-to-denier conversion factor used across the textile industry.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A weaving mill specifies 30 Ne cotton yarn, and a supplier's spec sheet needs the equivalent denier.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Ne:</span> <span class="text-slate-600">30</span></div>
        <div><span class="font-medium text-slate-700">Denier:</span> <span class="text-slate-600">5315 ÷ 30 ≈ <strong>177.2</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Cotton spinning mills and yarn traders who work primarily in Ne encounter denier constantly when sourcing blended yarns (cotton-polyester, cotton-spandex) from suppliers who spec the synthetic component in denier — converting one side to match the other is a routine step before comparing two yarn options on equal terms.
    </p>
    <p class="mt-3 text-slate-600">
      Knitwear and woven-fabric designers choosing a yarn weight for a specific hand-feel or drape often reference both systems depending on the fiber content, so being able to move fluently between Ne and denier avoids having to guess at an unfamiliar system's relative scale.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A higher number always means a thicker yarn, in any system." <strong class="text-slate-900">Not in Ne.</strong> This is true for denier and tex (direct systems) but the opposite for Ne (an indirect system) — a 60 Ne yarn is finer than a 20 Ne yarn, not thicker.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"This conversion works the same for wool or linen yarn count." <strong class="text-slate-900">Not exactly.</strong> Wool (worsted or woolen count) and linen (lea count) use their own separate indirect systems with different reference weights and lengths, so the 5,315 constant specifically applies to cotton count, not other fiber count systems.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/denier-tex-dtex-converter/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Denier/Tex/Dtex Converter</a>
      <a href="/tools/fabric-weight-gsm-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">GSM / Fabric Weight Calculator</a>
      <a href="/tools/thread-consumption-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Thread Consumption Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'Ne → Denier';
    const CONST = 5315;

    function update() {
      const v = parseFloat(el('value').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const result = CONST / v; // symmetric formula either direction
      el('r-value').textContent = result.toFixed(2);
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach((b) => {
          b.className = 'mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'mode-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        mode = btn.dataset.mode;
        el('input-label').textContent = mode === 'Ne → Denier' ? 'Ne (cotton count)' : 'Denier';
        el('output-label').textContent = mode === 'Ne → Denier' ? 'Denier' : 'Ne (cotton count)';
        el('value').placeholder = mode === 'Ne → Denier' ? 'e.g. 30' : 'e.g. 177';
        update();
      });
    });

    el('value').addEventListener('input', update);
    document.querySelector('.mode-btn').click();
  </script>
</ToolLayout>
