---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Density Calculator';
const description = 'Density calculator with a live 3D diagram and charts. Solve ρ = m/V for density, mass, or volume, with worked examples and a material density comparison table.';
const intro = 'Solve ρ = m/V for density, mass, or volume — enter any two values to find the third. Two 3D diagrams compare a light, low-density material to a heavy, high-density material at the same volume, and charts show how mass scales with volume for common materials.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is density?', a: 'Density (ρ) is mass per unit volume — how tightly packed the matter in a substance is. The SI unit is kg/m³, though g/cm³ or g/mL is common in chemistry.' },
  { q: 'How do I calculate density?', a: 'Use ρ = m/V: measure the object\'s mass and divide by its volume. For irregular objects, find volume using water displacement first.' },
  { q: 'Why does ice float on water?', a: "Ice has a density of about 0.92 g/cm³, less than liquid water's 1.00 g/cm³. Less dense substances float on denser ones — this is exactly why icebergs float instead of sinking." },
  { q: 'What is the difference between density and specific gravity?', a: 'Specific gravity is the ratio of a substance\'s density to the density of water at 4°C. It is dimensionless — the same number in any unit system — while density itself always carries units.' },
  { q: 'How does temperature affect density?', a: 'Most substances expand when heated, increasing volume and therefore lowering density. Water is the famous exception — its maximum density actually occurs at 4°C, not at its freezing point.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Density Calculator',
  description: 'Solve ρ = m/V for density, mass, or volume from any two known values.',
  steps: [
    { name: 'Enter any two values', text: 'Type density, mass, or volume in compatible units, leaving the value you want to solve for blank.' },
    { name: 'Read the result', text: 'The missing value solves instantly and updates live as you type.' },
  ],
};

const formulas = [
  { expr: 'ρ = m / V', note: 'density = mass ÷ volume' },
  { expr: 'm = ρ × V', note: 'solve for mass' },
  { expr: 'V = m / ρ', note: 'solve for volume' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — identifying a metal', tone: 'slate',
    given: 'A metal cube has a mass of 2700 g and a volume of 1000 cm³.',
    rows: [
      { label: 'Formula:', value: 'ρ = m / V' },
      { label: 'Substitute:', value: 'ρ = 2700 / 1000' },
      { label: 'Result:', value: 'ρ = 2.70 g/cm³ — matches aluminium almost exactly', full: true },
    ],
    note: 'Comparing a measured density to reference tables is one of the most common ways to identify an unknown material without destructive testing.',
  },
  {
    title: 'Worked example 2 — will it float?', tone: 'amber',
    given: 'A block of cork has a mass of 24 g and a volume of 100 cm³. Will it float in water (ρ_water = 1.00 g/cm³)?',
    rows: [
      { label: 'Formula:', value: 'ρ = m / V' },
      { label: 'Substitute:', value: 'ρ = 24 / 100' },
      { label: 'Result:', value: 'ρ = 0.24 g/cm³ — far less dense than water, so it floats easily', full: true },
    ],
    note: "An object floats in a fluid whenever its own density is lower than the fluid's density — the actual mass or size of the object doesn't matter, only the ratio of mass to volume.",
  },
];

const comparison = {
  heading: 'Density of common materials',
  note: 'Same formula, very different results depending on how tightly a material\'s atoms are packed.',
  headers: [{ label: 'Material' }, { label: 'Density (g/cm³)' }, { label: 'Floats in water?' }],
  rows: [
    ['Cork', '0.24', 'Yes'],
    ['Ice', '0.92', 'Yes'],
    ['Water (4°C) ★', '1.00', '—'],
    ['Aluminium', '2.70', 'No'],
    ['Iron/steel', '7.87', 'No'],
    ['Gold', '19.3', 'No'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row. Anything above 1.00 g/cm³ sinks in water; anything below it floats — this single comparison explains iceberg buoyancy, oil slicks, and metal casting alike.',
};

const realWorld = [
  { emoji: '🔍', title: 'Materials identification', body: 'Density is one of the fastest ways to identify an unknown substance without destroying a sample — measure mass and volume, compare the ratio to a reference table, and narrow down the likely material.' },
  { emoji: '⚙️', title: 'Structural and mechanical engineering', body: 'Density determines how much a component weighs for a given size, which drives load calculations, shipping costs, and material selection for anything from aircraft panels to bridge cables.' },
  { emoji: '🚢', title: 'Ship and submarine design', body: 'Naval architecture depends entirely on density and buoyancy — a steel ship floats not because steel is light, but because its hull shape displaces enough water that its average density (hull + air-filled interior) is less than water.' },
  { emoji: '🧪', title: 'Quality control in manufacturing', body: 'Density checks catch porosity, contamination, or incorrect composition in cast metal parts, plastics, and ceramics — a part with unexpected voids inside will measure a lower density than the solid reference material.' },
];

const misconceptions = [
  { claim: '"Heavier objects are always denser."', truth: 'Density depends on the ratio of mass to volume, not on total mass alone. A large block of cork weighs more in total than a small nugget of gold, but the gold is far denser — density is about how tightly packed the matter is, not how much total mass exists.' },
  { claim: '"Density and weight are the same thing."', truth: 'Weight is a force that depends on gravity (W = mg) and total mass; density is an intensive property (mass per unit volume) that stays the same regardless of how much material you have or what planet you\'re on.' },
  { claim: '"All metals are denser than all liquids."', truth: 'Most common metals are denser than water, but liquid mercury (13.6 g/cm³) is actually denser than many solid metals like aluminium (2.70 g/cm³) or even iron in some alloy forms — density comparisons must be checked case by case.' },
  { claim: '"An object\'s shape affects whether it floats."', truth: "Shape affects how much fluid an object displaces (which matters for total buoyant force), but whether a solid, uniform object floats or sinks depends only on comparing its own density to the fluid's density — not on its shape." },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 14, "Fluid Mechanics" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/14-1-fluids-density-and-pressure" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>CRC Handbook of Chemistry and Physics</strong> — standard reference densities.' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Fluid statics chapter.' },
];
const sourcesNote = 'ρ = m/V. Reference densities at standard conditions (~20°C, 1 atm). Results are rounded for display.';

const howToUse = [
  { title: 'Enter any two values', body: 'Type density, mass, or volume in compatible metric units, leaving the field you want blank.' },
  { title: 'Read the instant result', body: 'The missing value solves automatically and updates live as you type any input.' },
  { title: 'Compare to reference materials', body: 'Use the comparison table to check whether your result matches a known material.' },
];

const related = [
  { href: '/tools/gravitational-force-calculator', emoji: '🌍', title: "Newton's Law of Gravitation Calculator", desc: 'F = Gm₁m₂/r² — gravitational force between masses.' },
  { href: '/tools/bernoullis-equation-calculator', emoji: '🛩️', title: "Bernoulli's Equation Calculator", desc: 'Solve pressure at a second point in a moving fluid.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'Solution concentration from moles and volume.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="density packs a material's mass and size into a single number that stays the same no matter how big or small a sample of that material is — which is exactly why it's such a reliable way to identify what something is made of."
  howIntro="Density describes how tightly packed the atoms or molecules of a substance are, expressed as mass divided by volume. Because it's an intensive property, a teaspoon of gold and a gold bar have exactly the same density even though their total mass is wildly different — cutting a sample in half halves both its mass and volume, leaving the ratio unchanged. This is what makes density useful for identifying materials: two objects with the same density (within measurement error) are very likely made of the same substance, regardless of their size or shape."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where density actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values, leave the third blank</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Density (ρ)</span>
        <input id="density" type="number" step="any" placeholder="kg/m³" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mass" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume (V)</span>
        <input id="volume" type="number" step="any" placeholder="m³" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Density</div><div id="r-density" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-mass" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Volume</div><div id="r-volume" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="density-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Same volume, different density</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-light" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low density (cork)</h3>
          <p class="mt-1 text-sm text-slate-600">Same-size cube as the block on the right, but the atoms are more loosely packed — much less mass for the same volume.</p>
        </div>
        <div>
          <div id="diag-heavy" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High density (gold)</h3>
          <p class="mt-1 text-sm text-slate-600">Identical volume, but tightly packed atoms mean far more mass is crammed into the same space.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Density graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Mass vs. volume (three materials)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mv"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Density comparison (g/cm³)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-materials"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        const d = parseFloat(el('density').value);
        const m = parseFloat(el('mass').value);
        const v = parseFloat(el('volume').value);
        const filled = [!isNaN(d), !isNaN(m), !isNaN(v)];
        const count = filled.filter(Boolean).length;
        el('density-err').textContent = '';
        ['r-density', 'r-mass', 'r-volume'].forEach((id) => el(id).textContent = '—');
        if (count < 2) return;
        let rd = NaN, rm = NaN, rv = NaN;
        if (filled[0] && filled[1]) { rv = m / d; rd = d; rm = m; }
        else if (filled[0] && filled[2]) { rm = d * v; rd = d; rv = v; }
        else if (filled[1] && filled[2]) {
          if (v === 0) { el('density-err').textContent = 'Volume cannot be zero.'; return; }
          rd = m / v; rm = m; rv = v;
        }
        if (rd < 0 || rm < 0 || rv < 0) { el('density-err').textContent = 'Values cannot be negative.'; return; }
        if (!isNaN(rd)) el('r-density').textContent = fmt(rd);
        if (!isNaN(rm)) el('r-mass').textContent = fmt(rm);
        if (!isNaN(rv)) el('r-volume').textContent = fmt(rv);
      }
      ['density', 'mass', 'volume'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const vols = [0, 200, 400, 600, 800, 1000];
        new Chart(el('chart-mv'), {
          type: 'line',
          data: {
            labels: vols,
            datasets: [
              { label: 'Cork (0.24 g/cm³)', data: vols.map((v) => +(v * 0.24).toFixed(1)), borderColor: '#94a3b8', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
              { label: 'Water (1.00 g/cm³)', data: vols.map((v) => +(v * 1.00).toFixed(1)), borderColor: '#38bdf8', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
              { label: 'Gold (19.3 g/cm³)', data: vols.map((v) => +(v * 19.3).toFixed(1)), borderColor: '#f59e0b', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
            ],
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Volume (cm³)' } }, y: { title: { display: true, text: 'Mass (g)' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        const matLabels = ['Cork', 'Ice', 'Water', 'Aluminium', 'Iron', 'Gold'];
        const matData = [0.24, 0.92, 1.00, 2.70, 7.87, 19.3];
        new Chart(el('chart-materials'), {
          type: 'bar',
          data: { labels: matLabels, datasets: [{ label: 'Density (g/cm³)', data: matData, backgroundColor: ['#cbd5e1', '#7dd3fc', '#38bdf8', '#94a3b8', '#6b7280', '#f59e0b'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Density (g/cm³)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function blockScene(container, color, sizeScale) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const cube = new THREE.Mesh(new THREE.BoxGeometry(2.4, 2.4, 2.4), new THREE.MeshStandardMaterial({ color, transparent: true, opacity: 0.85 }));
        s.scene.add(cube);
        const dotCount = Math.round(sizeScale);
        for (let i = 0; i < dotCount; i++) {
          const dot = new THREE.Mesh(new THREE.SphereGeometry(0.08, 8, 6), new THREE.MeshStandardMaterial({ color: 0x1e293b }));
          dot.position.set((Math.random() - 0.5) * 2, (Math.random() - 0.5) * 2, (Math.random() - 0.5) * 2);
          s.scene.add(dot);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLight = null, diagHeavy = null;
      function initDiagLight() { const c = el('diag-light'); if (!c) throw new Error('no container'); diagLight = blockScene(c, 0xa16207, 8); }
      function initDiagHeavy() { const c = el('diag-heavy'); if (!c) throw new Error('no container'); diagHeavy = blockScene(c, 0xf59e0b, 45); }

      function boot() {
        try { update(); } catch (e) { console.error('[density] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[density] charts failed', e); }
        if (window.THREE) {
          try { initDiagLight(); } catch (e) { console.error('[density] light diagram failed', e); }
          try { initDiagHeavy(); } catch (e) { console.error('[density] heavy diagram failed', e); }
        }
        mountResize([diagLight, diagHeavy]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
