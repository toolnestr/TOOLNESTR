---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Density Calculator';
const description = 'Free online density calculator. Solve for density (ρ), mass (m), or volume (V) using ρ = m / V. Works with any metric units.';
const intro = 'Enter any two values — density, mass, or volume — to solve for the third using the density formula.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is density?', a: 'Density (ρ) is mass per unit volume. It describes how tightly packed the matter in a substance is. The SI unit is kg/m³, though g/cm³ or g/mL is common in chemistry.' },
  { q: 'How do I calculate density?', a: 'Use ρ = m / V. Measure the mass of the object and divide by its volume. For irregular objects, use water displacement to find volume.' },
  { q: 'Why does ice float on water?', a: 'Ice has a density of about 0.92 g/cm³, which is less than water\'s 1.0 g/cm³. Less dense substances float in denser ones — this is why icebergs float.' },
  { q: 'What is the difference between density and specific gravity?', a: 'Specific gravity is the ratio of a substance\'s density to the density of water at 4°C. It is dimensionless — the same value in any unit system — while density has units.' },
  { q: 'How does temperature affect density?', a: 'Most substances expand when heated, increasing volume and therefore decreasing density. Water is unusual — its maximum density occurs at 4°C, not at its freezing point.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values, leave the third blank</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Density (ρ)</span>
        <input id="density" type="number" step="any" placeholder="kg/m³" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mass" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume (V)</span>
        <input id="volume" type="number" step="any" placeholder="m³" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="density-result" class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Density</div><div id="r-density" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-mass" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Volume</div><div id="r-volume" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="density-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="density-title density-desc">
      <title id="density-title">Density formula cube diagram</title>
      <desc id="density-desc">A cube labelled with mass m on top and volume V inside, with density ρ = m/V displayed alongside</desc>
      <g transform="translate(20,10)">
        <rect x="60" y="80" width="160" height="160" rx="8" fill="#eef2ff" stroke="#6366f1" stroke-width="2.5"/>
        <rect x="60" y="80" width="160" height="160" rx="8" fill="url(#d-grad)" opacity="0.4"/>
        <defs><linearGradient id="d-grad" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#c7d2fe"/><stop offset="100%" stop-color="#818cf8"/></linearGradient></defs>
        <text x="140" y="150" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">V</text>
        <text x="140" y="260" text-anchor="middle" fill="#64748b" font-size="14">Volume</text>
        <rect x="40" y="40" width="50" height="30" rx="6" fill="#fef3c7" stroke="#f59e0b" stroke-width="1.5"/>
        <text x="65" y="60" text-anchor="middle" fill="#d97706" font-size="13" font-weight="bold">m</text>
        <text x="65" y="33" text-anchor="middle" fill="#64748b" font-size="12">Mass</text>
        <line x1="65" y1="70" x2="65" y2="80" stroke="#f59e0b" stroke-width="1.5" stroke-dasharray="3 2"/>
        <text x="300" y="140" text-anchor="middle" fill="#4338ca" font-size="28" font-weight="bold">ρ = m / V</text>
        <text x="300" y="170" text-anchor="middle" fill="#64748b" font-size="16">Density = Mass ÷ Volume</text>
        <rect x="220" y="190" width="160" height="80" rx="10" fill="#ecfdf5" stroke="#10b981" stroke-width="1.5"/>
        <text x="300" y="218" text-anchor="middle" fill="#059669" font-size="14" font-weight="bold">Solve for any variable</text>
        <text x="300" y="240" text-anchor="middle" fill="#047857" font-size="12">m = ρ × V</text>
        <text x="300" y="258" text-anchor="middle" fill="#047857" font-size="12">V = m / ρ</text>
        <rect x="420" y="80" width="160" height="160" rx="8" fill="#fef2f2" stroke="#ef4444" stroke-width="2"/>
        <rect x="420" y="80" width="80" height="80" rx="4" fill="#fca5a5" opacity="0.3"/>
        <text x="500" y="150" text-anchor="middle" fill="#b91c1c" font-size="14">Solid</text>
        <rect x="420" y="170" width="140" height="70" rx="4" fill="#fca5a5" opacity="0.15"/>
        <text x="500" y="215" text-anchor="middle" fill="#b91c1c" font-size="12">Dense packing</text>
        <text x="500" y="270" text-anchor="middle" fill="#64748b" font-size="12">High density example</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The density triangle: mass over volume equals density. Solve for any variable by covering the one you need.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How density is calculated</h2>
    <p class="mt-2 text-slate-600">Density is a fundamental physical property defined as mass per unit volume. The formula is <span class="font-mono">ρ = m / V</span>, where ρ (rho) is density, m is mass, and V is volume. The SI unit for density is kilograms per cubic metre (kg/m³), but grams per cubic centimetre (g/cm³) and grams per millilitre (g/mL) are widely used in chemistry. Density is an intensive property — it does not depend on the amount of material. A small piece of gold has the same density as a large gold bar.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A metal cube has a mass of 2700 g and a volume of 1000 cm³. What is its density?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Mass:</span> <span class="text-slate-600">2700 g</span></div>
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">1000 cm³</span></div>
        <div><span class="font-medium text-slate-700">Density:</span> <span class="text-slate-600">ρ = 2700 / 1000 = 2.70 g/cm³</span></div>
        <div><span class="font-medium text-slate-700">Material:</span> <span class="text-slate-600">Aluminium (typical density ≈ 2.70 g/cm³)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F50C;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Chemistry Student</h3>
      <p class="mt-1 text-sm text-slate-600">Identify unknown substances by measuring their density and comparing against known values. Verify the purity of a sample by checking if its density matches the theoretical value.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x2699;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Mechanical Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the weight of a component from its volume and material density. This is essential for structural load analysis, shipping weight estimates, and material cost calculations.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Materials Scientist</h3>
      <p class="mt-1 text-sm text-slate-600">Characterize new materials by measuring density to understand porosity, crystallinity, and composition. Density changes can reveal structural transitions in polymers and composites.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4DA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Physics Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Use the density calculator to create classroom examples and verify experiment results. Demonstrate the relationship between mass, volume, and density with real-world objects.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the density calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter any two values</h3>
        <p class="mt-1 text-sm text-slate-600">Type values for density, mass, or volume in any compatible metric units. Leave the field you want to solve for blank.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Instant result</h3>
        <p class="mt-1 text-sm text-slate-600">The missing value is calculated automatically as you type. All three result boxes update in real time with the solved values.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check for errors</h3>
        <p class="mt-1 text-sm text-slate-600">If you enter zero for volume or leave too many fields blank, the calculator shows a clear error. Adjust your inputs to correct it.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for density calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use consistent units</h3>
        <p class="mt-1 text-sm text-slate-600">Density, mass, and volume must use compatible units. If you enter mass in grams and volume in mL, density comes out in g/mL — a very common combination in chemistry. For engineering, kilograms and cubic metres give kg/m³.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Temperature matters</h3>
        <p class="mt-1 text-sm text-slate-600">Density varies with temperature because materials expand or contract. Always note the temperature when measuring or comparing densities. Standard tables typically reference 20°C or 4°C.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Irregular objects need displacement</h3>
        <p class="mt-1 text-sm text-slate-600">For objects with irregular shapes, measure volume by water displacement. Submerge the object in a graduated cylinder and record the volume change. This is Archimedes' principle in action.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/force-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4A5;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Force Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Newton's second law — solve for F, m, or a.</p>
      </a>
      <a href="/tools/ideal-gas-law-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1FAEB;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Ideal Gas Law Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">PV=nRT — solve for any variable.</p>
      </a>
      <a href="/tools/molarity-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F9EA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molarity Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Solution concentration from moles and volume.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });
    function update() {
      const d = parseFloat(el('density').value);
      const m = parseFloat(el('mass').value);
      const v = parseFloat(el('volume').value);
      const filled = [!isNaN(d), !isNaN(m), !isNaN(v)];
      const count = filled.filter(Boolean).length;
      el('density-err').textContent = '';
      ['r-density', 'r-mass', 'r-volume'].forEach(id => el(id).textContent = '—');
      if (count < 2) return;
      let rd = NaN, rm = NaN, rv = NaN;
      if (filled[0] && filled[1]) { rv = m / d; rd = d; rm = m; }
      else if (filled[0] && filled[2]) { rm = d * v; rd = d; rv = v; }
      else if (filled[1] && filled[2]) {
        if (v === 0) { el('density-err').textContent = 'Volume cannot be zero.'; return; }
        rd = m / v; rm = m; rv = v;
      }
      if (rd < 0 || rm < 0 || rv < 0) { el('density-err').textContent = 'Values cannot be negative.'; return; }
      if (!isNaN(rd)) el('r-density').textContent = fmt(rd);
      if (!isNaN(rm)) el('r-mass').textContent = fmt(rm);
      if (!isNaN(rv)) el('r-volume').textContent = fmt(rv);
    }
    ['density', 'mass', 'volume'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
