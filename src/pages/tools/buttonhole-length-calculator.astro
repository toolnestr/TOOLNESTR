---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Buttonhole Length Calculator';
const description = 'Calculate the correct buttonhole length from button diameter and thickness.';
const intro = 'Calculate the correct buttonhole length from your button\'s diameter and thickness.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why does button thickness matter, not just diameter?', a: 'A button has to pass through the buttonhole edge-first, so a thick or domed button needs a longer buttonhole than a flat button of the same diameter, since the button\'s full "profile" (diameter plus thickness) has to clear the buttonhole opening.' },
  { q: 'How do I measure button thickness?', a: 'Stand the button on its edge and measure its height from a flat surface, or measure across the button from front to back through its thickest point (including any dome or shank).' },
  { q: 'What if my button has a shank instead of holes?', a: 'Shank buttons still need this same diameter-plus-thickness calculation, though the "thickness" for a shank button includes the shank\'s added height, which can make the buttonhole noticeably longer than for a flat sew-through button of the same diameter.' },
  { q: 'Should I test the buttonhole size before doing all of them?', a: 'Yes — sew one test buttonhole on a scrap of the actual project fabric and check the button passes through smoothly but isn\'t loose, since fabric thickness and interfacing can shift the ideal length slightly from the pure calculation.' },
];
const howTo = {
  name: 'How to calculate buttonhole length',
  steps: [
    { name: 'Measure the button', text: 'Measure the button\'s diameter and its thickness (height).' },
    { name: 'Enter both measurements', text: 'Enter the diameter and thickness into the calculator.' },
    { name: 'Read the buttonhole length', text: 'The recommended buttonhole length, with a small ease allowance, appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Button diameter (in)</span>
        <input id="diameter" type="number" step="any" placeholder="e.g. 0.75" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Button thickness (in)</span>
        <input id="thickness" type="number" step="any" placeholder="e.g. 0.2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Buttonhole length</div>
        <div id="r-length" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="blc-title blc-desc">
      <title id="blc-title">Button next to a buttonhole slightly longer than its diameter</title>
      <desc id="blc-desc">A circular button shown beside a horizontal buttonhole slit slightly longer than the button's diameter to account for its thickness</desc>
      <circle cx="250" cy="90" r="50" fill="#fecdd3" stroke="#e11d48" stroke-width="2" />
      <circle cx="250" cy="90" r="8" fill="#e11d48" />
      <text x="250" y="160" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Diameter + thickness</text>
      <rect x="480" y="82" width="140" height="16" rx="8" fill="none" stroke="#e11d48" stroke-width="2.5" />
      <text x="550" y="130" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Buttonhole (slightly longer)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Buttonhole length must clear both the button's diameter and its thickness</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How buttonhole length is calculated</h2>
    <p class="mt-2 text-slate-600">
      A button doesn't pass through a buttonhole as a flat disc — it has to tip on edge and push through, so the buttonhole needs to accommodate both the button's diameter and its thickness (or dome height) together, plus a small amount of ease so the button moves through smoothly without excessive tightness or looseness. This calculator adds diameter and thickness together, then adds a standard 1/8-inch ease allowance.
    </p>
    <p class="mt-3 text-slate-600">
      A flat, thin button needs a buttonhole barely longer than its diameter, while a thick, domed, or shank button needs a noticeably longer buttonhole — using diameter alone for a thick button typically results in a buttonhole too short to actually close.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows the standard diameter-plus-thickness-plus-ease rule used across home-sewing and tailoring references for buttonhole sizing.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A button measures 0.75 inch in diameter and 0.2 inch thick.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Diameter + thickness:</span> <span class="text-slate-600">0.75 + 0.2 = 0.95 in</span></div>
        <div><span class="font-medium text-slate-700">Plus ease:</span> <span class="text-slate-600">0.95 + 0.125 = <strong>1.075 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Coat and jacket buttons tend to be thicker and more domed than shirt buttons, which is exactly the scenario where using diameter alone produces a noticeably too-short buttonhole — a coat button that measures the same diameter as a shirt button can need a meaningfully longer buttonhole once its extra thickness is accounted for.
    </p>
    <p class="mt-3 text-slate-600">
      Vintage and antique buttons salvaged for a new project often have unusual shapes and thicknesses compared to modern mass-produced buttons, making a direct measurement (rather than assuming a standard button proportion) especially important to avoid a mismatched buttonhole.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Buttonhole length only needs to match button diameter." <strong class="text-slate-900">Incomplete.</strong> Diameter alone ignores the button's thickness, which is exactly what causes a buttonhole to come out too short for a thick or domed button.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A slightly too-large buttonhole is always safer than too small." <strong class="text-slate-900">Not necessarily.</strong> An oversized buttonhole lets the button slip through on its own during wear, causing the garment to come undone — matching size closely, with only the standard small ease, gives the most secure and reliable closure.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/buttonhole-spacing-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Buttonhole Spacing Calculator</a>
      <a href="/tools/interfacing-stabilizer-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Interfacing/Stabilizer Yardage Calculator</a>
      <a href="/tools/zipper-length-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Zipper Length Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const EASE = 0.125;

    function update() {
      const diameter = parseFloat(el('diameter').value);
      const thickness = parseFloat(el('thickness').value) || 0;
      if (!diameter || diameter <= 0) { el('results').classList.add('hidden'); return; }
      const length = diameter + thickness + EASE;
      el('r-length').textContent = length.toFixed(3) + ' in';
      el('results').classList.remove('hidden');
    }

    el('diameter').addEventListener('input', update);
    el('thickness').addEventListener('input', update);
  </script>
</ToolLayout>
