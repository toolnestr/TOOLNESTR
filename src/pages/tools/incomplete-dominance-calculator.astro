---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Incomplete Dominance Calculator';
const description = "Incomplete dominance calculator. Build a Punnett square where heterozygotes show a blended intermediate phenotype, like pink flowers from red and white parents.";
const intro = 'Cross two parents for a gene showing incomplete dominance, where the heterozygote blends into an intermediate phenotype rather than matching either parent, to see the genotype and phenotype ratios. Two 3D diagrams compare red and white homozygous flowers to a blended pink heterozygote, and charts show the resulting 1:2:1 phenotype ratio.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is incomplete dominance?', a: 'Incomplete dominance is an inheritance pattern where the heterozygote shows a phenotype intermediate between the two homozygous parents, rather than matching one of them — like pink flowers resulting from a cross between red and white parents.' },
  { q: 'How is incomplete dominance different from codominance?', a: 'Incomplete dominance blends both alleles into a single intermediate trait (pink from red and white). Codominance keeps both traits fully separate and visible at once (like distinct red and white patches, not blended pink) — the underlying math is identical, only the visual outcome differs.' },
  { q: 'Why does RR × rr produce all pink offspring in incomplete dominance?', a: 'Because RR × rr always produces 100% Rr offspring (every child gets one R and one r), and under incomplete dominance, every Rr individual shows the blended intermediate phenotype — pink, in the classic flower-color example.' },
  { q: 'What happens when you cross two pink (Rr) flowers?', a: 'Rr × Rr follows the same 1:2:1 genotype ratio as any monohybrid cross, giving 1 RR (red) : 2 Rr (pink) : 1 rr (white) — since genotype and phenotype ratios match exactly under incomplete dominance.' },
  { q: 'Are there real human examples of incomplete dominance?', a: 'Yes — familial hypercholesterolemia is a human example, where heterozygotes show an intermediate level of blood cholesterol receptor function between the two homozygous extremes.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Incomplete Dominance Calculator',
  description: 'Build a Punnett square for a gene showing incomplete dominance and see the resulting blended phenotype ratios.',
  steps: [
    { name: 'Enter both parent genotypes', text: 'Use R (red allele) and r (white allele) style notation for the two alleles.' },
    { name: 'View the grid', text: 'The cross grid fills in with every possible offspring genotype.' },
    { name: 'Read the phenotype ratio', text: 'Heterozygotes show a blended intermediate phenotype, distinct from either homozygote.' },
  ],
};

const formulas = [
  { expr: 'RR × rr → all Rr (pink)', note: 'a cross between the two homozygous extremes produces uniformly intermediate offspring' },
  { expr: 'Rr × Rr → 1 RR : 2 Rr : 1 rr', note: 'genotype ratio matches phenotype ratio exactly: 1 red : 2 pink : 1 white' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — crossing red and white flowers (RR × rr)', tone: 'slate',
    given: 'A homozygous red-flowered snapdragon (RR) is crossed with a homozygous white-flowered one (rr).',
    rows: [
      { label: 'Gametes:', value: 'R only from one parent, r only from the other' },
      { label: 'Offspring genotype:', value: '100% Rr' },
      { label: 'Offspring phenotype:', value: '100% pink flowers (the blended intermediate)', full: true },
    ],
    note: 'This is the classic experiment (in snapdragons and four o\'clock flowers) that first revealed inheritance isn\'t always simple dominant/recessive — every single offspring shows the blended pink trait.',
  },
  {
    title: 'Worked example 2 — crossing two pink (Rr) offspring', tone: 'amber',
    given: 'Two of the pink F1 snapdragons (Rr) are crossed with each other.',
    rows: [
      { label: 'Gametes:', value: 'R or r from each parent' },
      { label: 'Genotype ratio:', value: '1 RR : 2 Rr : 1 rr' },
      { label: 'Phenotype ratio:', value: '1 red : 2 pink : 1 white', full: true },
    ],
    note: 'Unlike simple dominance (which would give 3:1), incomplete dominance produces a 1:2:1 ratio because the heterozygote has its own unique, visible phenotype rather than being hidden behind a dominant trait.',
  },
];

const comparison = {
  heading: 'Incomplete dominance vs simple dominance outcomes',
  note: 'Both start from the identical Rr × Rr genotype cross — only the phenotype interpretation differs.',
  headers: [{ label: 'Pattern' }, { label: 'Rr phenotype' }, { label: 'Resulting ratio' }],
  rows: [
    ['Simple dominance', 'Same as RR (dominant)', '3 : 1'],
    ['Incomplete dominance ★', 'Blended intermediate (pink)', '1 : 2 : 1'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 2). The genotype math never changes — only whether the heterozygote\'s phenotype matches a homozygote or forms its own new, visible category.',
};

const realWorld = [
  { emoji: '🌸', title: 'Ornamental flower breeding', body: 'Flower breeders exploit incomplete dominance deliberately, crossing pure red and white varieties to reliably produce pink hybrids for the ornamental plant market.' },
  { emoji: '🧬', title: 'Human cholesterol genetics', body: 'Familial hypercholesterolemia shows incomplete dominance — heterozygotes have an intermediate LDL cholesterol receptor function between the two homozygous extremes, with correspondingly intermediate cholesterol levels.' },
  { emoji: '🐔', title: 'Poultry feather color', body: 'Andalusian chicken feather color is a classic textbook example — black × white parents produce blue-grey (blended) offspring, illustrating incomplete dominance in a way students can visually verify.' },
  { emoji: '🎓', title: 'Teaching non-Mendelian inheritance patterns', body: 'Incomplete dominance is often the first non-Mendelian pattern students learn, helping build the broader understanding that not every trait follows simple dominant/recessive rules.' },
];

const misconceptions = [
  { claim: '"Incomplete dominance means the dominant allele is only partly dominant."', truth: 'Neither allele in incomplete dominance is truly "dominant" in the Mendelian sense at all — both alleles contribute equally and additively to the phenotype, producing a genuinely intermediate blended trait rather than a partially-expressed dominant one.' },
  { claim: '"Crossing two pink flowers (Rr × Rr) will only ever produce more pink flowers."', truth: "Rr × Rr actually produces a 1:2:1 ratio of red, pink, and white offspring — only half of the offspring are expected to be pink; the other half split evenly between the two original homozygous colors." },
  { claim: '"Incomplete dominance and codominance are the same phenomenon."', truth: 'They share the same underlying 1:2:1 genotype ratio, but incomplete dominance blends both alleles into ONE new intermediate trait, while codominance keeps both alleles\' traits fully separate and simultaneously visible — the visual result is completely different even though the math matches.' },
  { claim: '"The blended phenotype means genetic material from the parents literally mixed together."', truth: "The alleles themselves stay completely distinct and unchanged (particulate inheritance) — only the resulting protein/pigment output blends into an intermediate phenotype. The genes themselves are never physically blended or diluted." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 12, "Mendel\'s Experiments and Heredity" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/12-3-laws-of-inheritance" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 4, Extensions of Mendelian Genetics.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 14, Mendel and the Gene Idea (Extending Mendelian Genetics).' },
];
const sourcesNote = 'Underlying genotype math is identical to standard Mendelian segregation — only phenotype interpretation differs. Results are exact probability ratios.';

const howToUse = [
  { title: 'Enter both parent genotypes', body: 'Use R/r style notation for the two alleles of the incompletely-dominant gene.' },
  { title: 'View the cross grid', body: 'The full grid shows every possible offspring genotype combination.' },
  { title: 'Read the blended phenotype ratio', body: 'Heterozygotes get their own intermediate phenotype category, distinct from either homozygote.' },
];

const related = [
  { href: '/tools/codominance-calculator', emoji: '🐄', title: 'Codominance Calculator', desc: 'Both alleles shown fully and separately — a different pattern.' },
  { href: '/tools/punnett-square-calculator', emoji: '🧬', title: 'Punnett Square Calculator', desc: 'Monohybrid cross — the classic 3:1 phenotype ratio.' },
  { href: '/tools/dihybrid-cross-calculator', emoji: '🧬', title: 'Dihybrid Cross Calculator', desc: 'Two-gene cross — the classic 9:3:3:1 phenotype ratio.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="when neither allele can fully mask the other, a heterozygote ends up expressing an intermediate amount of whatever the gene product does — half as much red pigment as a homozygote, for instance — producing a visibly blended trait rather than one that matches either parent."
  howIntro="The Punnett square mechanics behind incomplete dominance are identical to ordinary Mendelian segregation, producing the same 1:2:1 genotype ratio as any Rr × Rr cross. What differs is the phenotype mapping: instead of one allele fully masking the other's contribution, both alleles partially contribute to the same trait (like pigment production), so a heterozygote ends up with an intermediate dose — literally half the pigment of a homozygous red flower and twice that of a homozygous white one — producing the visibly blended pink phenotype."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where incomplete dominance actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Parent 1 genotype (RR, Rr, or rr)</span>
        <input id="p1" type="text" maxlength="2" value="Rr" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Parent 2 genotype (RR, Rr, or rr)</span>
        <input id="p2" type="text" maxlength="2" value="Rr" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 overflow-hidden rounded-xl border border-slate-200">
      <table id="grid" class="w-full table-fixed text-center"></table>
    </div>
    <div class="mt-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Phenotype ratio (red : pink : white)</div><div id="r-pheno" class="mt-1 text-lg font-bold">—</div></div>
    </div>
    <p id="inc-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Red, white, and blended pink</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-parents" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Homozygous red and white parents</h3>
          <p class="mt-1 text-sm text-slate-600">Pure red (RR) and pure white (rr) — each produces only its own pigment.</p>
        </div>
        <div>
          <div id="diag-pink" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Heterozygous pink offspring (Rr)</h3>
          <p class="mt-1 text-sm text-slate-600">A single blended pink color — the true intermediate, not a mix of separate red and white patches.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Incomplete dominance charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Phenotype ratio (Rr × Rr) — 1:2:1</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pheno"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pigment dose per genotype (relative)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dose"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function parseGeno(s) {
        s = (s || '').trim();
        if (s.length !== 2) return null;
        const valid = ['R', 'r'];
        if (!valid.includes(s[0]) || !valid.includes(s[1])) return null;
        return [s[0], s[1]];
      }
      function phenoName(pair) {
        const rCount = pair.filter((a) => a === 'R').length;
        if (rCount === 2) return 'Red';
        if (rCount === 1) return 'Pink';
        return 'White';
      }
      function update() {
        el('inc-err').textContent = '';
        el('r-pheno').textContent = '—';
        el('grid').innerHTML = '';
        const g1 = parseGeno(el('p1').value), g2 = parseGeno(el('p2').value);
        if (!g1 || !g2) { el('inc-err').textContent = 'Enter genotypes using only R and r, e.g. Rr.'; return; }
        const results = [];
        let html = '<tr><td class="bg-slate-50 p-2"></td>';
        g2.forEach((b) => (html += '<td class="bg-slate-50 p-2 font-mono font-bold text-slate-700">' + b + '</td>'));
        html += '</tr>';
        g1.forEach((a) => {
          html += '<tr><td class="bg-slate-50 p-2 font-mono font-bold text-slate-700">' + a + '</td>';
          g2.forEach((b) => {
            const pair = [a, b].sort((x, y) => (x === 'R' ? -1 : 1) - (y === 'R' ? -1 : 1));
            results.push(pair);
            html += '<td class="border border-slate-100 p-3 font-mono font-semibold text-indigo-700">' + pair.join('') + '</td>';
          });
          html += '</tr>';
        });
        el('grid').innerHTML = html;
        const counts = { Red: 0, Pink: 0, White: 0 };
        results.forEach((p) => counts[phenoName(p)]++);
        el('r-pheno').textContent = counts.Red + ' : ' + counts.Pink + ' : ' + counts.White;
      }
      ['p1', 'p2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.pheno = new Chart(el('chart-pheno'), {
          type: 'pie',
          data: { labels: ['Red (RR)', 'Pink (Rr)', 'White (rr)'], datasets: [{ data: [1, 2, 1], backgroundColor: ['#ef4444', '#f9a8d4', '#e2e8f0'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.dose = new Chart(el('chart-dose'), {
          type: 'bar',
          data: { labels: ['RR (red)', 'Rr (pink)', 'rr (white)'], datasets: [{ label: 'Relative pigment dose', data: [2, 1, 0], backgroundColor: ['#ef4444', '#f9a8d4', '#e2e8f0'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Relative pigment dose' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function flowerScene(container, color) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const petalMat = new THREE.MeshStandardMaterial({ color, roughness: 0.4 });
        for (let i = 0; i < 6; i++) {
          const ang = (i / 6) * Math.PI * 2;
          const petal = new THREE.Mesh(new THREE.SphereGeometry(0.6, 16, 14), petalMat);
          petal.position.set(1.3 * Math.cos(ang), 1.3 * Math.sin(ang), 0);
          petal.scale.set(1, 0.5, 0.5);
          s.scene.add(petal);
        }
        const center = new THREE.Mesh(new THREE.SphereGeometry(0.5, 16, 14), new THREE.MeshStandardMaterial({ color: 0xfbbf24 }));
        s.scene.add(center);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function twoFlowerScene(container) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        [[-1.8, 0xef4444], [1.8, 0xe2e8f0]].forEach(([x, color]) => {
          const petalMat = new THREE.MeshStandardMaterial({ color, roughness: 0.4 });
          for (let i = 0; i < 6; i++) {
            const ang = (i / 6) * Math.PI * 2;
            const petal = new THREE.Mesh(new THREE.SphereGeometry(0.4, 14, 12), petalMat);
            petal.position.set(x + 0.9 * Math.cos(ang), 0.9 * Math.sin(ang), 0);
            petal.scale.set(1, 0.5, 0.5);
            s.scene.add(petal);
          }
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagParents = null, diagPink = null;
      function initDiagParents() { const c = el('diag-parents'); if (!c) throw new Error('no container'); diagParents = twoFlowerScene(c); }
      function initDiagPink() { const c = el('diag-pink'); if (!c) throw new Error('no container'); diagPink = flowerScene(c, 0xf9a8d4); }

      function boot() {
        try { update(); } catch (e) { console.error('[incomplete-dominance] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[incomplete-dominance] charts failed', e); }
        if (window.THREE) {
          try { initDiagParents(); } catch (e) { console.error('[incomplete-dominance] parents diagram failed', e); }
          try { initDiagPink(); } catch (e) { console.error('[incomplete-dominance] pink diagram failed', e); }
        }
        mountResize([diagParents, diagPink]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
