---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Round Pen Calculator';
const description = 'Find how many fence panels you need to build a round pen or corral from its diameter and panel length, plus the circumference and enclosed area.';
const intro = 'Find how many fence panels build a round pen of any diameter, plus its circumference and area.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How many panels do I need for a round pen?', a: 'Divide the pen circumference (π × diameter) by the panel length and round up. A 50-foot round pen has a circumference of about 157 feet; with 12-foot panels that is 157 ÷ 12 = 13.1, rounded up to 14 panels including a gate.' },
  { q: 'What size round pen do I need for a horse?', a: 'A common round pen for groundwork and lunging is 50 to 60 feet in diameter. Fifty feet suits general training, while 60 feet gives a horse more room to move at a canter without tight circles that stress the legs.' },
  { q: 'Does the pen come out exactly round?', a: 'No. Straight panels form a many-sided polygon that approximates a circle, so the real enclosed size is slightly smaller than a true circle of the same panel count. The more panels you use, the closer it gets to round. The calculator sizes to the target diameter and rounds panels up.' },
  { q: 'Should I include a gate in the panel count?', a: 'A gate usually replaces one panel section, so the total number of openings stays the same. This calculator counts the gate as one of the sections, meaning one of the pieces you buy is a gate panel rather than a solid panel.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Diameter (ft)</span>
        <input id="dia" type="number" step="any" placeholder="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Panel length (ft)</span>
        <input id="panel" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gate width (ft)</span>
        <input id="gate" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Panels needed</div>
        <div id="r-panels" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Circumference</div><div id="r-circ" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Enclosed area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Includes gate</div><div id="r-gateout" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="240" viewBox="0 0 800 240" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rp-title rp-desc">
      <title id="rp-title">Round pen from straight panels</title>
      <desc id="rp-desc">A round pen made of straight fence panels forming a polygon, with the panel formula</desc>
      <polygon points="140,45 199,66 220,120 199,174 140,195 81,174 60,120 81,66" fill="#f0fdf4" stroke="#16a34a" stroke-width="2" />
      <circle cx="140" cy="120" r="3" fill="#16a34a" />
      <text x="140" y="225" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">panels form a polygon</text>
      <rect x="330" y="55" width="420" height="130" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="350" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Round pen</text>
      <text x="350" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">circumference = &pi; &times; diameter</text>
      <text x="350" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">panels = circumference &divide; panel length</text>
      <text x="350" y="154" font-size="12" fill="#475569" font-family="system-ui,sans-serif">area = &pi; &times; radius&sup2;</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Straight panels ring the pen as a polygon that approximates the target circle.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the round pen calculator works</h2>
    <p class="mt-2 text-slate-600">
      A round pen is built by ringing a circle with straight fence panels. To size it, start from the circumference — the distance around the circle — which is π times the diameter. Dividing that circumference by the length of one panel gives the number of panels needed, rounded up so the ring closes. A 50-foot pen is about 157 feet around, so with 12-foot panels you need 14 sections.
    </p>
    <p class="mt-3 text-slate-600">
      Because the panels are straight, they actually form a many-sided polygon rather than a perfect circle. The more panels used, the closer the shape comes to round; a 14-panel pen is already very close. When a gate is part of the ring, it simply takes the place of one section, so the total count of openings does not change — one of the pieces you buy is a gate panel of its own width instead of a solid panel.
    </p>
    <p class="mt-3 text-slate-600">
      The enclosed area, π times the radius squared, tells you how much footing to prepare and how much room a horse has to work. For training and lunging, 50 to 60 feet across is the common range: 50 feet suits general groundwork, and 60 feet lets a horse canter without the tight circles that strain joints. Sizing panels correctly avoids both a short ring that will not close and an over-order of unused sections.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick the diameter</h3>
        <p class="mt-1 text-sm text-slate-600">The size across the finished pen, in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set panel length</h3>
        <p class="mt-1 text-sm text-slate-600">The length of the panels you plan to buy.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get the count</h3>
        <p class="mt-1 text-sm text-slate-600">Panels needed, plus circumference and area.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Circumference</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= &pi; &times; diameter</span>. A 50 ft pen: π × 50 = <strong>157.1 ft</strong> around.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Panels</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= ceil( (circumference &minus; gate) &divide; panel ) + 1 gate</span>. With a gate the remaining ring is filled by solid panels.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= &pi; &times; radius&sup2;</span> = π × 25² = <strong>1,963 ft²</strong> enclosed.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 60 ft round pen with 12 ft panels and an 8 ft gate.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Circumference:</span> <span class="text-slate-600">π × 60 = 188.5 ft</span></div>
        <div><span class="font-medium text-slate-700">Less gate:</span> <span class="text-slate-600">188.5 − 8 = 180.5 ft</span></div>
        <div><span class="font-medium text-slate-700">Solid panels:</span> <span class="text-slate-600">ceil(180.5 ÷ 12) = 16</span></div>
        <div><span class="font-medium text-slate-700">Total:</span> <span class="text-slate-600"><strong>16 panels + 1 gate</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fence-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fence Calculator</a>
      <a href="/tools/perimeter-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Perimeter Calculator</a>
      <a href="/tools/bolt-circle-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Bolt Circle Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const dia = parseFloat(el('dia').value);
      const panel = parseFloat(el('panel').value);
      let gate = parseFloat(el('gate').value); if (!(gate >= 0)) gate = 0;
      if (!(dia > 0 && panel > 0)) { el('results').classList.add('hidden'); return; }
      const circ = Math.PI * dia;
      const area = Math.PI * Math.pow(dia / 2, 2);
      const remaining = Math.max(circ - gate, 0);
      const solid = Math.ceil(remaining / panel);
      const hasGate = gate > 0;
      const total = solid + (hasGate ? 1 : 0);

      el('r-panels').textContent = hasGate ? (solid + ' panels + 1 gate') : (solid + ' panels');
      el('r-note').textContent = total + ' sections around a ' + dia + ' ft ring';
      el('r-circ').textContent = circ.toFixed(1) + ' ft';
      el('r-area').textContent = area.toFixed(0) + ' ft²';
      el('r-gateout').textContent = hasGate ? (gate + ' ft gate') : 'no gate';
      el('results').classList.remove('hidden');
    }

    ['dia', 'panel', 'gate'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
