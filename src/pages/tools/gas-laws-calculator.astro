---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Combined Gas Law Calculator';
const description = 'Combined gas law calculator with a live 3D diagram and charts. Solve P1V1/T1 = P2V2/T2, plus mode switches for Boyle\'s law and Charles\'s law alone, with worked examples.';
const intro = 'Solve P₁V₁/T₁ = P₂V₂/T₂ for a gas changing pressure, volume, and temperature at once — or switch to Boyle\'s law (constant T) or Charles\'s law (constant P) alone. Two 3D diagrams compare piston compression to balloon heating, and charts show the classic hyperbolic and linear gas-law curves.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is Boyle's law?", a: "Boyle's law states that at constant temperature, the pressure and volume of a gas are inversely proportional: P₁V₁ = P₂V₂. Doubling the pressure halves the volume." },
  { q: "What is Charles's law?", a: "Charles's law states that at constant pressure, the volume of a gas is proportional to its absolute temperature: V₁/T₁ = V₂/T₂. Temperature must be in kelvin." },
  { q: 'What is the combined gas law?', a: "The combined gas law is P₁V₁/T₁ = P₂V₂/T₂, unifying Boyle's, Charles's, and Gay-Lussac's laws into one equation. It applies whenever the amount of gas (moles) stays constant." },
  { q: 'Why must temperature be in kelvin?', a: "Kelvin is an absolute temperature scale starting at absolute zero (−273.15°C). Gas laws depend on proportional relationships that only hold on an absolute scale — using Celsius directly would give badly wrong results." },
  { q: "What is Gay-Lussac's law?", a: "Gay-Lussac's law states that at constant volume, pressure is proportional to temperature: P₁/T₁ = P₂/T₂ — this describes how pressure rises in a sealed, rigid container when heated." },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Combined Gas Law Calculator',
  description: "Solve P₁V₁/T₁ = P₂V₂/T₂ for a changing gas, or isolate Boyle's or Charles's law alone.",
  steps: [
    { name: 'Select a mode', text: "Choose Boyle's law (P and V only), Charles's law (V and T only), or the combined law (all three change)." },
    { name: 'Enter three of the four values', text: 'The fourth solves automatically as you type, with labels updating to match the selected law.' },
    { name: 'Use kelvin for temperature', text: 'Charles\'s law and the combined law require absolute temperature — convert Celsius by adding 273.15 first.' },
  ],
};

const formulas = [
  { expr: 'P₁V₁ = P₂V₂', note: "Boyle's law — constant temperature" },
  { expr: 'V₁/T₁ = V₂/T₂', note: "Charles's law — constant pressure, T in kelvin" },
  { expr: 'P₁V₁/T₁ = P₂V₂/T₂', note: 'combined gas law — all three variables change, moles constant' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a balloon heated at constant pressure', tone: 'slate',
    given: 'A balloon has a volume of 3.0 L at 20°C. What is its volume when heated to 40°C at constant pressure?',
    rows: [
      { label: 'Formula:', value: "Charles's law: V₁/T₁ = V₂/T₂" },
      { label: 'Convert to kelvin:', value: 'T₁ = 293.15 K, T₂ = 313.15 K' },
      { label: 'Substitute:', value: 'V₂ = V₁ × T₂/T₁ = 3.0 × 313.15/293.15' },
      { label: 'Result:', value: 'V₂ ≈ 3.20 L', full: true },
    ],
    note: 'The volume increases by only about 6.8%, even though the temperature rose by 20°C — because the gas law scales with absolute (kelvin) temperature, not the Celsius change directly.',
  },
  {
    title: 'Worked example 2 — a gas compressed and cooled together', tone: 'amber',
    given: 'A gas at P₁ = 1.0 atm, V₁ = 10.0 L, T₁ = 300 K is compressed to V₂ = 4.0 L and cooled to T₂ = 250 K. Find P₂.',
    rows: [
      { label: 'Formula:', value: 'Combined gas law: P₁V₁/T₁ = P₂V₂/T₂' },
      { label: 'Rearrange:', value: 'P₂ = P₁V₁T₂ / (T₁V₂)' },
      { label: 'Substitute:', value: 'P₂ = (1.0 × 10.0 × 250) / (300 × 4.0)' },
      { label: 'Result:', value: 'P₂ ≈ 2.08 atm', full: true },
    ],
    note: 'This is the general case where pressure, volume, and temperature all change together — Boyle\'s and Charles\'s laws are just special cases of this same equation with one variable held fixed.',
  },
];

const comparison = {
  heading: "How Boyle's and Charles's laws are special cases of the combined law",
  note: 'Holding one variable constant in P₁V₁/T₁ = P₂V₂/T₂ collapses it into a simpler, named law.',
  headers: [{ label: 'Law' }, { label: 'Held constant' }, { label: 'Equation' }],
  rows: [
    ["Boyle's law", 'Temperature', 'P₁V₁ = P₂V₂'],
    ["Charles's law ★", 'Pressure', 'V₁/T₁ = V₂/T₂'],
    ["Gay-Lussac's law", 'Volume', 'P₁/T₁ = P₂/T₂'],
    ['Combined gas law', 'Moles of gas only', 'P₁V₁/T₁ = P₂V₂/T₂'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). All four rows describe the exact same underlying physics — they differ only in which variable is held fixed.',
};

const realWorld = [
  { emoji: '🎈', title: 'Weather balloons', body: 'As a weather balloon rises, atmospheric pressure drops sharply while temperature also falls — the combined gas law predicts how much the balloon expands, which engineers must account for so it doesn\'t burst before reaching its target altitude.' },
  { emoji: '🚗', title: 'Tire pressure and temperature', body: "A car tire's pressure reading changes noticeably between a cold morning and a hot afternoon, purely from Gay-Lussac's law (nearly constant volume) — this is why manufacturers specify a 'cold' tire pressure as the standard reference." },
  { emoji: '🏭', title: 'Industrial gas storage and transport', body: 'Compressed gas cylinders are designed using these laws to predict safe pressure limits across a range of storage and transport temperatures, preventing over-pressurization on hot days.' },
  { emoji: '🫁', title: 'Scuba diving physiology', body: "Boyle's law explains why a diver's lungs must never hold their breath while ascending — the pressure drop as they rise causes trapped gas to expand rapidly, which can cause serious lung injury if the diver doesn't exhale continuously." },
];

const misconceptions = [
  { claim: '"You can use Celsius directly in any gas law as long as you\'re consistent."', truth: "Charles's law and the combined gas law rely on temperature ratios (T₂/T₁), which only make physical sense on an absolute scale. Using 20°C and 40°C gives a ratio of 2.0, while the correct kelvin ratio (293.15/313.15) is only about 1.068 — a massive, invalidating error." },
  { claim: '"The combined gas law only works when all three variables change by the same proportion."', truth: 'The combined gas law works for any combination of changes to pressure, volume, and temperature — it doesn\'t require them to change proportionally, only that the total number of gas molecules (moles) stays fixed throughout.' },
  { claim: '"Boyle\'s law and Charles\'s law are unrelated equations that happen to both involve gases."', truth: "Both are special cases of the single combined gas law (and, more fundamentally, of the ideal gas law PV=nRT) obtained by holding one variable constant — they aren't separate physical principles, just different simplified views of the same relationship." },
  { claim: '"Real gases always obey these laws exactly."', truth: 'These are ideal-gas relationships, which assume no intermolecular forces and negligible molecular volume. Real gases deviate from them at high pressure or low temperature, where intermolecular attractions and finite molecular size actually start to matter.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 9, "Gases" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/9-2-relating-pressure-volume-amount-and-temperature-the-ideal-gas-law" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 10, Gases.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Gas laws chapter.' },
];
const sourcesNote = 'P₁V₁/T₁ = P₂V₂/T₂ (moles constant). Temperature must be in kelvin. Results are rounded for display.';

const howToUse = [
  { title: 'Select your law', body: "Choose Boyle's law, Charles's law, or the combined law depending on which variables are changing." },
  { title: 'Enter three values', body: 'The field labels update to match your selection — fill in any three of the four to solve the fourth.' },
  { title: 'Convert to kelvin first', body: 'Add 273.15 to any Celsius temperature before entering it — the calculator flags zero kelvin as invalid.' },
];

const related = [
  { href: '/tools/ideal-gas-law-calculator', emoji: '💨', title: 'Ideal Gas Law Calculator', desc: 'PV=nRT — solve for any variable.' },
  { href: '/tools/daltons-law-calculator', emoji: '🌬️', title: "Dalton's Law (Partial Pressure) Calculator", desc: 'P_total = P1+P2+P3+P4, or partial pressure from mole fraction.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'Solution concentration from moles and volume.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="pressure, volume, and temperature of a fixed amount of gas are all locked together — change any one of them and at least one of the others has to shift to keep P·V/T constant."
  howIntro="A gas sample's pressure, volume, and temperature aren't independent of each other — they're tied together by P·V/T = constant, as long as the number of gas molecules doesn't change. Squeeze a gas into a smaller volume and its pressure must rise to compensate (Boyle's law); heat a gas at constant pressure and it must expand to compensate (Charles's law); heat a gas trapped in a rigid, unchanging volume and its pressure alone must rise (Gay-Lussac's law). The combined gas law is simply the general version of all three, letting pressure, volume, and temperature all shift simultaneously while keeping their overall ratio fixed."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the combined gas law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-boyle" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Boyle's Law (P₁V₁=P₂V₂)</button>
      <button id="mode-charles" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Charles's Law (V₁/T₁=V₂/T₂)</button>
      <button id="mode-combined" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Combined (P₁V₁/T₁=P₂V₂/T₂)</button>
    </div>
    <div id="gas-fields" class="grid gap-4 sm:grid-cols-4">
      <label class="block" id="lbl-1"><span class="text-sm font-medium text-slate-700">P₁</span>
        <input id="v1" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block" id="lbl-2"><span class="text-sm font-medium text-slate-700">V₁</span>
        <input id="v2" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block" id="lbl-3"><span class="text-sm font-medium text-slate-700">P₂</span>
        <input id="v3" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block" id="lbl-4"><span class="text-sm font-medium text-slate-700">V₂</span>
        <input id="v4" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80" id="lbl-r1">P₁</div><div id="r-v1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500" id="lbl-r2">V₁</div><div id="r-v2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500" id="lbl-r3">P₂</div><div id="r-v3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500" id="lbl-r4">V₂</div><div id="r-v4" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="gas2-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Compression vs. heating</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-boyle" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Boyle's law — piston compression</h3>
          <p class="mt-1 text-sm text-slate-600">Squeezing the same gas molecules into a smaller volume raises pressure, at constant temperature.</p>
        </div>
        <div>
          <div id="diag-charles" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Charles's law — heated balloon</h3>
          <p class="mt-1 text-sm text-slate-600">Heating the same gas at constant pressure makes it expand into a larger volume.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Gas law graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">P vs. V at constant T (Boyle's law)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-boyle"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">V vs. T at constant P (Charles's law)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-charles"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });

      // ---- calculator (mode-switch logic preserved) ----
      let mode = 'boyle';
      const full = { boyle: ['P₁', 'V₁', 'P₂', 'V₂'], charles: ['V₁', 'T₁', 'V₂', 'T₂'], combined: ['P₁', 'V₁', 'T₁', 'P₂'] };
      function switchMode(m) {
        mode = m;
        ['mode-boyle', 'mode-charles', 'mode-combined'].forEach((id) => el(id).className = id.includes(m) ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600');
        const f = full[m];
        for (let i = 0; i < 4; i++) { el('lbl-' + (i + 1)).querySelector('span').textContent = f[i]; el('lbl-r' + (i + 1)).textContent = f[i]; }
        for (let i = 1; i <= 4; i++) el('r-v' + i).textContent = '—';
        el('gas2-err').textContent = '';
      }
      function update() {
        const v = [parseFloat(el('v1').value), parseFloat(el('v2').value), parseFloat(el('v3').value), parseFloat(el('v4').value)];
        const filled = v.map((x) => !isNaN(x));
        const count = filled.filter(Boolean).length;
        el('gas2-err').textContent = '';
        for (let i = 1; i <= 4; i++) el('r-v' + i).textContent = '—';
        if (count < 3) return;
        let r = [NaN, NaN, NaN, NaN];
        if (mode === 'boyle') {
          if (!filled[0]) { if (v[1] === 0) { el('gas2-err').textContent = 'V₁ cannot be zero.'; return; } r[0] = v[2] * v[3] / v[1]; r[1] = v[1]; r[2] = v[2]; r[3] = v[3]; }
          else if (!filled[1]) { if (v[2] === 0) { el('gas2-err').textContent = 'P₂ cannot be zero.'; return; } r[1] = v[0] * v[1] / v[2]; r[0] = v[0]; r[2] = v[2]; r[3] = v[3]; }
          else if (!filled[2]) { if (v[3] === 0) { el('gas2-err').textContent = 'V₂ cannot be zero.'; return; } r[2] = v[0] * v[1] / v[3]; r[0] = v[0]; r[1] = v[1]; r[3] = v[3]; }
          else if (!filled[3]) { if (v[2] === 0) { el('gas2-err').textContent = 'P₂ cannot be zero.'; return; } r[3] = v[0] * v[1] / v[2]; r[0] = v[0]; r[1] = v[1]; r[2] = v[2]; }
        } else if (mode === 'charles') {
          if (!filled[0]) { r[0] = v[2] * v[1] / v[3]; r[1] = v[1]; r[2] = v[2]; r[3] = v[3]; }
          else if (!filled[1]) { if (v[2] === 0) { el('gas2-err').textContent = 'V₂ cannot be zero when solving for T₁.'; return; } r[1] = v[0] * v[3] / v[2]; r[0] = v[0]; r[2] = v[2]; r[3] = v[3]; }
          else if (!filled[2]) { if (v[3] === 0) { el('gas2-err').textContent = 'T₂ cannot be zero.'; return; } r[2] = v[0] * v[3] / v[1]; r[0] = v[0]; r[1] = v[1]; r[3] = v[3]; }
          else if (!filled[3]) { if (v[1] === 0) { el('gas2-err').textContent = 'T₁ cannot be zero.'; return; } r[3] = v[0] * v[1] / v[2]; r[0] = v[0]; r[1] = v[1]; r[2] = v[2]; }
        } else if (mode === 'combined') {
          if (!filled[0]) { if (v[2] === 0) { el('gas2-err').textContent = 'T₁ cannot be zero.'; return; } r[0] = v[3] * v[2] / v[1]; r[1] = v[1]; r[2] = v[2]; r[3] = v[3]; }
          else if (!filled[1]) { if (v[3] === 0) { el('gas2-err').textContent = 'P₂ cannot be zero.'; return; } r[1] = v[0] * v[2] / v[3]; r[0] = v[0]; r[2] = v[2]; r[3] = v[3]; }
          else if (!filled[2]) { if (v[3] === 0) { el('gas2-err').textContent = 'P₂ cannot be zero.'; return; } r[2] = v[1] * v[3] / v[0]; r[0] = v[0]; r[1] = v[1]; r[3] = v[3]; }
          else if (!filled[3]) { if (v[2] === 0) { el('gas2-err').textContent = 'T₁ cannot be zero.'; return; } r[3] = v[0] * v[1] / v[2]; r[0] = v[0]; r[1] = v[1]; r[2] = v[2]; }
        }
        for (let i = 0; i < 4; i++) if (!isNaN(r[i])) el('r-v' + (i + 1)).textContent = fmt(r[i]);
      }
      el('mode-boyle').addEventListener('click', () => { switchMode('boyle'); update(); });
      el('mode-charles').addEventListener('click', () => { switchMode('charles'); update(); });
      el('mode-combined').addEventListener('click', () => { switchMode('combined'); update(); });
      ['v1', 'v2', 'v3', 'v4'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const vLabels = [], pData = [];
        for (let v = 1; v <= 10; v += 0.5) { vLabels.push(v.toFixed(1)); pData.push(+(10 / v).toFixed(2)); }
        new Chart(el('chart-boyle'), {
          type: 'line',
          data: { labels: vLabels, datasets: [{ label: 'P (atm)', data: pData, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Volume (L)' } }, y: { title: { display: true, text: 'Pressure (atm)' } } }, plugins: { legend: { display: false } } }),
        });
        const tLabels = [], vData = [];
        for (let t = 200; t <= 400; t += 20) { tLabels.push(t); vData.push(+(3 * t / 293.15).toFixed(3)); }
        new Chart(el('chart-charles'), {
          type: 'line',
          data: { labels: tLabels, datasets: [{ label: 'V (L)', data: vData, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Temperature (K)' } }, y: { title: { display: true, text: 'Volume (L)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function pistonScene(container, compressed) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const h = compressed ? 1.6 : 3.0;
        const cyl = new THREE.Mesh(new THREE.CylinderGeometry(1.4, 1.4, h, 24, 1, true), new THREE.MeshStandardMaterial({ color: 0x94a3b8, side: THREE.DoubleSide, transparent: true, opacity: 0.35 }));
        s.scene.add(cyl);
        const piston = new THREE.Mesh(new THREE.CylinderGeometry(1.45, 1.45, 0.3, 24), new THREE.MeshStandardMaterial({ color: 0x475569 }));
        piston.position.y = h / 2;
        s.scene.add(piston);
        const n = compressed ? 20 : 10;
        for (let i = 0; i < n; i++) {
          const dot = new THREE.Mesh(new THREE.SphereGeometry(0.14, 10, 8), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
          dot.position.set((Math.random() - 0.5) * 2.2, (Math.random() - 0.5) * h * 0.8, (Math.random() - 0.5) * 2.2);
          s.scene.add(dot);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagBoyle = null, diagCharles = null;
      function initDiagBoyle() { const c = el('diag-boyle'); if (!c) throw new Error('no container'); diagBoyle = pistonScene(c, true); }
      function initDiagCharles() { const c = el('diag-charles'); if (!c) throw new Error('no container'); diagCharles = pistonScene(c, false); }

      function boot() {
        try { switchMode('boyle'); } catch (e) { console.error('[combined-gas-law] mode init failed', e); }
        try { initCharts(); } catch (e) { console.error('[combined-gas-law] charts failed', e); }
        if (window.THREE) {
          try { initDiagBoyle(); } catch (e) { console.error('[combined-gas-law] boyle diagram failed', e); }
          try { initDiagCharles(); } catch (e) { console.error('[combined-gas-law] charles diagram failed', e); }
        }
        mountResize([diagBoyle, diagCharles]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
