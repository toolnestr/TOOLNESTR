---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = "Boyle's & Charles's Law Calculator";
const description = 'Free online combined gas law calculator. Solve Boyle\'s law (P₁V₁=P₂V₂) and Charles\'s law (V₁/T₁=V₂/T₂) with mode switching.';
const intro = 'Switch between Boyle\'s law and Charles\'s law. Enter any three values to solve for the fourth.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is Boyle\'s law?', a: 'Boyle\'s law states that at constant temperature, the pressure and volume of a gas are inversely proportional: P₁V₁ = P₂V₂. Doubling the pressure halves the volume.' },
  { q: 'What is Charles\'s law?', a: 'Charles\'s law states that at constant pressure, the volume of a gas is proportional to its absolute temperature: V₁/T₁ = V₂/T₂. Temperature must be in kelvin.' },
  { q: 'What is the combined gas law?', a: 'The combined gas law is P₁V₁/T₁ = P₂V₂/T₂, which unifies Boyle\'s, Charles\'s, and Gay-Lussac\'s laws. It applies when the number of gas molecules stays constant.' },
  { q: 'Why must temperature be in kelvin?', a: 'Kelvin is an absolute temperature scale starting at absolute zero (−273.15°C). Gas laws rely on proportional relationships that only work with an absolute scale. Using Celsius would give wrong results.' },
  { q: 'What is Gay-Lussac\'s law?', a: 'Gay-Lussac\'s law states that at constant volume, pressure is proportional to temperature: P₁/T₁ = P₂/T₂. This describes how pressure increases in a sealed container when heated.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex gap-2">
      <button id="mode-boyle" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Boyle's Law (P₁V₁=P₂V₂)</button>
      <button id="mode-charles" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Charles's Law (V₁/T₁=V₂/T₂)</button>
      <button id="mode-combined" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Combined (P₁V₁/T₁=P₂V₂/T₂)</button>
    </div>
    <div id="gas-fields" class="grid gap-4 sm:grid-cols-4">
      <label class="block" id="lbl-1"><span class="text-sm font-medium text-slate-700">P₁</span>
        <input id="v1" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block" id="lbl-2"><span class="text-sm font-medium text-slate-700">V₁</span>
        <input id="v2" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block" id="lbl-3"><span class="text-sm font-medium text-slate-700">P₂</span>
        <input id="v3" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block" id="lbl-4"><span class="text-sm font-medium text-slate-700">V₂</span>
        <input id="v4" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80" id="lbl-r1">P₁</div><div id="r-v1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500" id="lbl-r2">V₁</div><div id="r-v2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500" id="lbl-r3">P₂</div><div id="r-v3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500" id="lbl-r4">V₂</div><div id="r-v4" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="gas2-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="gas2-title gas2-desc">
      <title id="gas2-title">Two piston diagrams showing Boyle's and Charles's laws</title>
      <desc id="gas2-desc">Two cylinders side by side: left shows Boyle's law with piston compressing gas, right shows Charles's law with temperature change affecting volume</desc>
      <g transform="translate(20,20)">
        <rect x="60" y="40" width="180" height="220" rx="10" fill="#e0f2fe" stroke="#0ea5e9" stroke-width="2"/>
        <rect x="60" y="40" width="180" height="30" rx="6" fill="#94a3b8" stroke="#64748b" stroke-width="2"/>
        <text x="150" y="60" text-anchor="middle" fill="white" font-size="12" font-weight="bold">Piston</text>
        <circle cx="120" cy="130" r="5" fill="#fca5a5" opacity="0.5"/>
        <circle cx="170" cy="110" r="5" fill="#fca5a5" opacity="0.5"/>
        <circle cx="140" cy="160" r="5" fill="#fca5a5" opacity="0.5"/>
        <text x="150" y="205" text-anchor="middle" fill="#0ea5e9" font-size="12">P₁V₁ = P₂V₂</text>
        <text x="150" y="225" text-anchor="middle" fill="#64748b" font-size="10">Boyle's Law</text>
        <line x1="60" y1="40" x2="60" y2="20" stroke="#ef4444" stroke-width="2"/>
        <polygon points="60,20 56,28 64,28" fill="#ef4444"/>
        <text x="45" y="28" fill="#ef4444" font-size="11">P</text>
        <rect x="420" y="70" width="180" height="190" rx="10" fill="#fef3c7" stroke="#f59e0b" stroke-width="2"/>
        <rect x="420" y="70" width="180" height="30" rx="6" fill="#94a3b8" stroke="#64748b" stroke-width="2"/>
        <text x="510" y="90" text-anchor="middle" fill="white" font-size="12" font-weight="bold">Piston</text>
        <circle cx="480" cy="150" r="5" fill="#fca5a5" opacity="0.5"/>
        <circle cx="530" cy="140" r="5" fill="#fca5a5" opacity="0.5"/>
        <circle cx="500" cy="180" r="5" fill="#fca5a5" opacity="0.5"/>
        <circle cx="550" cy="170" r="5" fill="#fca5a5" opacity="0.5"/>
        <text x="510" y="225" text-anchor="middle" fill="#d97706" font-size="12">V₁/T₁ = V₂/T₂</text>
        <text x="510" y="245" text-anchor="middle" fill="#64748b" font-size="10">Charles's Law</text>
        <text x="510" y="30" text-anchor="middle" fill="#f59e0b" font-size="13">Heat ↑ → Volume ↑</text>
        <path d="M 470 30 Q 490 10 510 30" stroke="#ef4444" stroke-width="1.5" fill="none"/>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Left: Boyle's law — compressing the piston increases pressure and decreases volume. Right: Charles's law — heating the gas increases volume at constant pressure.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How Boyle's and Charles's laws work</h2>
    <p class="mt-2 text-slate-600">Boyle's law describes the inverse relationship between pressure and volume at constant temperature: <span class="font-mono">P₁V₁ = P₂V₂</span>. When you compress a gas, its volume decreases and pressure increases proportionally. Charles's law describes the direct relationship between volume and temperature at constant pressure: <span class="font-mono">V₁/T₁ = V₂/T₂</span>. When you heat a gas, its volume increases proportionally. The combined gas law <span class="font-mono">P₁V₁/T₁ = P₂V₂/T₂</span> handles all three variables changing simultaneously.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A balloon has a volume of 3.0 L at 20°C. What is its volume when heated to 40°C at constant pressure?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">V₁:</span> <span class="text-slate-600">3.0 L</span></div>
        <div><span class="font-medium text-slate-700">T₁:</span> <span class="text-slate-600">20°C = 293.15 K</span></div>
        <div><span class="font-medium text-slate-700">T₂:</span> <span class="text-slate-600">40°C = 313.15 K</span></div>
        <div><span class="font-medium text-slate-700">V₂:</span> <span class="text-slate-600">3.0 × 313.15 / 293.15 = 3.20 L</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F9EA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Chemistry Student</h3>
      <p class="mt-1 text-sm text-slate-600">Verify homework problems involving gas law calculations. Understand the relationships between pressure, volume, and temperature through interactive exploration.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Process Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Design systems involving gas compression, heating, and expansion. Use Boyle's and Charles's laws to size pipes, vessels, and heat exchangers in chemical plants.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">HVAC Technician</h3>
      <p class="mt-1 text-sm text-slate-600">Apply gas laws to refrigeration cycles. Understand how compression and expansion of refrigerant gases create heating and cooling effects in air conditioning systems.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F680;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Aerospace Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Design pressurisation systems for aircraft cabins and spacecraft. Calculate how gas volumes change with altitude and temperature to maintain safe conditions.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the gas laws calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select your law</h3>
        <p class="mt-1 text-sm text-slate-600">Choose Boyle's law (P and V at constant T), Charles's law (V and T at constant P), or the combined gas law (P, V, and T all changing).</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter three values</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in any three of the four fields. The labels change to match the selected law. The fourth value is computed live as you type.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Always use kelvin for temperature</h3>
        <p class="mt-1 text-sm text-slate-600">Charles's law and the combined law require temperature in kelvin. Convert Celsius by adding 273.15. The calculator flags zero kelvin as an error.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for gas law calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Temperature must be absolute</h3>
        <p class="mt-1 text-sm text-slate-600">Charles's law uses the ratio T₁/T₂. If you use Celsius (e.g., 20°C and 40°C), the ratio would be 20/40 = 0.5, but the correct kelvin ratio is 293.15/313.15 = 0.936. This massive error highlights why kelvin is essential.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Consistent units matter</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator works with any pressure and volume units as long as you are consistent on both sides of the equation. For example, if P₁ is in atm, P₂ must also be in atm.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">The ideal gas law connects them all</h3>
        <p class="mt-1 text-sm text-slate-900">Both Boyle's and Charles's laws can be derived from the ideal gas law PV = nRT by holding certain variables constant. Use the Ideal Gas Law Calculator for problems involving changing amounts of gas.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/ideal-gas-law-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1FAEB;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Ideal Gas Law Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">PV=nRT — solve for any variable.</p>
      </a>
      <a href="/tools/density-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2696;&#xFE0F;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Density Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">ρ = m/V — solve for any variable.</p>
      </a>
      <a href="/tools/molarity-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F9EA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molarity Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">M = mol/L — solve for any variable.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 4, maximumFractionDigits: 6 });
    let mode = 'boyle';
    const labels = { boyle: ['P₁', 'V₁', 'P₂', 'V₂'], charles: ['V₁', 'T₁', 'V₂', 'T₂'], combined: ['P₁', 'V₁', 'T₁', 'P₂'] };
    function switchMode(m) {
      mode = m;
      ['mode-boyle', 'mode-charles', 'mode-combined'].forEach(id => el(id).className = id.includes(m) ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600');
      const lbl = labels[m];
      const full = { boyle: ['P₁', 'V₁', 'P₂', 'V₂'], charles: ['V₁', 'T₁', 'V₂', 'T₂'], combined: ['P₁', 'V₁', 'T₁', 'P₂'] };
      const f = full[m];
      for (let i = 0; i < 4; i++) { el('lbl-' + (i+1)).querySelector('span').textContent = f[i]; el('lbl-r' + (i+1)).textContent = f[i]; }
      for (let i = 1; i <= 4; i++) el('r-v' + i).textContent = '—';
      el('gas2-err').textContent = '';
    }
    function update() {
      const v = [parseFloat(el('v1').value), parseFloat(el('v2').value), parseFloat(el('v3').value), parseFloat(el('v4').value)];
      const filled = v.map(x => !isNaN(x));
      const count = filled.filter(Boolean).length;
      el('gas2-err').textContent = '';
      for (let i = 1; i <= 4; i++) el('r-v' + i).textContent = '—';
      if (count < 3) return;
      let r = [NaN, NaN, NaN, NaN];
      if (mode === 'boyle') {
        if (!filled[0]) { if (v[1] === 0) { el('gas2-err').textContent = 'V₁ cannot be zero.'; return; } r[0] = v[2] * v[3] / v[1]; r[1] = v[1]; r[2] = v[2]; r[3] = v[3]; }
        else if (!filled[1]) { if (v[2] === 0) { el('gas2-err').textContent = 'P₂ cannot be zero.'; return; } r[1] = v[0] * v[1] / v[2]; r[0] = v[0]; r[2] = v[2]; r[3] = v[3]; }
        else if (!filled[2]) { if (v[3] === 0) { el('gas2-err').textContent = 'V₂ cannot be zero.'; return; } r[2] = v[0] * v[1] / v[3]; r[0] = v[0]; r[1] = v[1]; r[3] = v[3]; }
        else if (!filled[3]) { if (v[2] === 0) { el('gas2-err').textContent = 'P₂ cannot be zero.'; return; } r[3] = v[0] * v[1] / v[2]; r[0] = v[0]; r[1] = v[1]; r[2] = v[2]; }
      } else if (mode === 'charles') {
        if (!filled[0]) { r[0] = v[2] * v[1] / v[3]; r[1] = v[1]; r[2] = v[2]; r[3] = v[3]; }
        else if (!filled[1]) { if (v[2] === 0) { el('gas2-err').textContent = 'V₂ cannot be zero when solving for T₁.'; return; } r[1] = v[0] * v[3] / v[2]; r[0] = v[0]; r[2] = v[2]; r[3] = v[3]; }
        else if (!filled[2]) { if (v[3] === 0) { el('gas2-err').textContent = 'T₂ cannot be zero.'; return; } r[2] = v[0] * v[3] / v[1]; r[0] = v[0]; r[1] = v[1]; r[3] = v[3]; }
        else if (!filled[3]) { if (v[1] === 0) { el('gas2-err').textContent = 'T₁ cannot be zero.'; return; } r[3] = v[0] * v[1] / v[2]; r[0] = v[0]; r[1] = v[1]; r[2] = v[2]; }
      } else if (mode === 'combined') {
        if (!filled[0]) { if (v[2] === 0) { el('gas2-err').textContent = 'T₁ cannot be zero.'; return; } r[0] = v[3] * v[2] / v[1]; r[1] = v[1]; r[2] = v[2]; r[3] = v[3]; }
        else if (!filled[1]) { if (v[3] === 0) { el('gas2-err').textContent = 'P₂ cannot be zero.'; return; } r[1] = v[0] * v[2] / v[3]; r[0] = v[0]; r[2] = v[2]; r[3] = v[3]; }
        else if (!filled[2]) { if (v[3] === 0) { el('gas2-err').textContent = 'P₂ cannot be zero.'; return; } r[2] = v[1] * v[3] / v[0]; r[0] = v[0]; r[1] = v[1]; r[3] = v[3]; }
        else if (!filled[3]) { if (v[2] === 0) { el('gas2-err').textContent = 'T₁ cannot be zero.'; return; } r[3] = v[0] * v[1] / v[2]; r[0] = v[0]; r[1] = v[1]; r[2] = v[2]; }
      }
      for (let i = 0; i < 4; i++) if (!isNaN(r[i])) el('r-v' + (i+1)).textContent = fmt(r[i]);
    }
    el('mode-boyle').addEventListener('click', () => { switchMode('boyle'); update(); });
    el('mode-charles').addEventListener('click', () => { switchMode('charles'); update(); });
    el('mode-combined').addEventListener('click', () => { switchMode('combined'); update(); });
    ['v1', 'v2', 'v3', 'v4'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
