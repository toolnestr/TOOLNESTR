---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Work-Energy Theorem Calculator';
const description = 'Work-energy theorem calculator with a live 3D velocity scene and charts. Solve W_net = ΔKE = ½m(v_f²−v_i²) for net work, mass, initial velocity, or final velocity, with worked examples.';
const intro = 'Find the net work done on an object from its change in kinetic energy — solve for net work, mass, initial velocity, or final velocity. A live 3D scene and charts show the velocity vector and kinetic energy changing together.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the work-energy theorem?', a: 'The work-energy theorem states that the net work done on an object equals its change in kinetic energy: W_net = ΔKE = KE_f − KE_i = ½m(v_f² − v_i²). It connects forces (through the work they do) directly to how fast something moves, without needing to know the motion\'s time history.' },
  { q: 'Does the work-energy theorem only work for constant forces?', a: 'No. It holds for any net force — constant, varying, or even a force that changes direction — as long as W_net is the actual work done by that force over the actual path. For varying forces, W_net is the area under the force-vs-displacement curve (or the integral ∫F·dx), and the theorem still gives W_net = ΔKE exactly.' },
  { q: 'What does negative net work mean?', a: 'Negative net work means kinetic energy decreased — the object slowed down. It does not mean "negative energy" was created; it means the net force had a component opposing the motion (like friction or braking), removing kinetic energy from the object as it travels.' },
  { q: 'How is this different from W = F·d·cos(θ)?', a: 'W = F·d·cos(θ) calculates the work done by one particular force from its magnitude, the displacement, and the angle between them. The work-energy theorem instead uses the *net* work from *all* forces combined, and relates that total directly to the change in speed — so you do not need to know F, d, or θ individually if you know the velocities and mass.' },
  { q: 'Can the work-energy theorem be used to find final velocity?', a: 'Yes. Rearranged, v_f = √(v_i² + 2W_net/m). If you know how much net work was done on an object (from any combination of forces) and its starting speed and mass, you can solve directly for its final speed without tracking acceleration or time.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Work-Energy Theorem Calculator',
  description: 'Calculate net work, mass, initial velocity, or final velocity from the work-energy theorem W_net = ½m(v_f² − v_i²).',
  steps: [
    { name: 'Pick a mode', text: 'Choose "From velocities" (W_net = ½m(v_f²−v_i²)) or "From force & displacement" (W_net = F_net × d).' },
    { name: 'Enter three values', text: 'In the velocity mode, type any three of net work, mass, initial velocity and final velocity.' },
    { name: 'Read the result', text: 'The fourth value solves instantly, along with KE_i and KE_f, and the 3D scene updates.' },
  ],
};

const formulas = [
  { expr: 'W<sub>net</sub> = ΔKE = KE<sub>f</sub> − KE<sub>i</sub>', note: 'net work equals the change in kinetic energy' },
  { expr: 'W<sub>net</sub> = ½m(v<sub>f</sub>² − v<sub>i</sub>²)', note: 'expanded using KE = ½mv²' },
  { expr: 'KE = ½mv²', note: 'kinetic energy at either instant' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — car accelerating from rest', tone: 'slate',
    given: 'A 1000 kg car accelerates from rest (v_i = 0) to v_f = 20 m/s. Find the net work done on it.',
    rows: [
      { label: 'Initial KE:', value: 'KE_i = ½ × 1000 × 0² = 0 J' },
      { label: 'Final KE:', value: 'KE_f = ½ × 1000 × 20² = ½ × 1000 × 400 = 200,000 J' },
      { label: 'Net work:', value: 'W_net = KE_f − KE_i = 200,000 − 0 = 200,000 J (200 kJ)', full: true },
    ],
  },
  {
    title: 'Worked example 2 — ball decelerating due to friction', tone: 'amber',
    given: 'A 0.5 kg ball rolling at v_i = 8 m/s slows to v_f = 3 m/s because of rolling friction. Find the net work done on it.',
    rows: [
      { label: 'Initial KE:', value: 'KE_i = ½ × 0.5 × 8² = ½ × 0.5 × 64 = 16 J' },
      { label: 'Final KE:', value: 'KE_f = ½ × 0.5 × 3² = ½ × 0.5 × 9 = 2.25 J' },
      { label: 'Net work:', value: 'W_net = KE_f − KE_i = 2.25 − 16 = −13.75 J', full: true },
    ],
    note: 'The negative sign shows friction removed 13.75 J of kinetic energy — it did not create "negative energy."',
  },
];

const comparison = {
  heading: 'Net work and ΔKE for different scenarios',
  note: 'The sign of W_net always matches the sign of the kinetic-energy change — positive when speeding up, negative when slowing down.',
  headers: [{ label: 'Scenario' }, { label: 'KE_i → KE_f' }, { label: 'W_net (ΔKE)' }],
  rows: [
    ['Car accelerating (1000 kg, 0→20 m/s)', '0 J → 200,000 J', '+200,000 J'],
    ['Ball rolling to a stop (0.2 kg, 5→0 m/s)', '2.5 J → 0 J', '−2.5 J'],
    ['Roller coaster car dropping (500 kg, 2→22 m/s)', '1,000 J → 121,000 J', '+120,000 J'],
  ],
  highlightIndex: 0,
  footnote: 'W_net = KE_f − KE_i in every case — no need to know the individual forces or the path taken.',
};

const realWorld = [
  { emoji: '🚗', title: 'Braking systems', body: 'Brake engineers use W_net = ΔKE to size brake pads and rotors: the brakes must supply enough negative work (mostly as heat) to remove all of a vehicle\'s kinetic energy within a safe stopping distance.' },
  { emoji: '🎢', title: 'Roller coasters', body: 'Designers track kinetic energy changes through a coaster\'s hills and loops. Where net work is positive (dropping) the car speeds up; where it is negative (climbing) the car slows — all without needing to compute forces at every point on the track.' },
  { emoji: '🏈', title: 'Sports and impact analysis', body: 'The work-energy theorem lets analysts estimate the net force or impact distance in a collision (helmet, pad, or crumple zone) once they know how much kinetic energy was removed — critical for safety-equipment design.' },
];

const misconceptions = [
  { claim: '"The work-energy theorem only applies to constant forces."', truth: 'It holds for any net force, constant or varying, as long as W_net is the actual work done — the integral of force over the real path. Rocket thrust, air resistance, and springs all obey W_net = ΔKE just as well as a constant push.' },
  { claim: '"Negative work means negative energy."', truth: 'Negative net work simply means kinetic energy decreased. Energy itself is never negative — a negative W_net tells you the object slowed down because the net force opposed its motion, not that energy went below zero.' },
  { claim: '"Work-energy theorem gives you the force directly."', truth: 'It gives you W_net, the change in kinetic energy — not the force by itself. To recover a force you also need the displacement (or path) over which that work was done, e.g. F_net = W_net / d for a constant force along a straight line.' },
  { claim: '"If an object returns to its starting speed, no net work was done overall."', truth: 'True only for the total displacement where v_i = v_f again — ΔKE = 0 over that interval. But net work can still be nonzero (and even large) during parts of the motion in between, as long as the positive and negative contributions cancel by the end.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — the work-energy theorem and kinetic energy. <a href="https://openstax.org/books/university-physics-volume-1/pages/7-2-kinetic-energy" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — kinetic energy and the work-kinetic energy theorem.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — work and kinetic energy.' },
];
const sourcesNote = 'W_net = ½m(v_f² − v_i²) assumes m is constant over the interval considered. Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"From velocities" for the ΔKE form; "From force & displacement" for W_net = F_net × d.' },
  { title: 'Enter three values', body: 'Fill any three of the four velocity-mode fields; the fourth solves live, alongside KE_i and KE_f.' },
  { title: 'Watch the scene', body: 'Use the sliders to see the velocity vector and KE gauge respond as the object speeds up or slows down.' },
];

const related = [
  { href: '/tools/kinetic-energy-calculator', emoji: '⚡', title: 'Kinetic Energy Calculator', desc: 'KE = ½mv² — solve for any variable.' },
  { href: '/tools/work-calculator', emoji: '🔧', title: 'Work Calculator', desc: 'W = F·d·cos(θ) — work done by a force.' },
  { href: '/tools/momentum-calculator', emoji: '🎯', title: 'Momentum & Impulse Calculator', desc: 'p = mv plus impulse calculations.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="the net work done on an object — from all forces combined — always equals exactly how much its kinetic energy changes, whether that change is a gain or a loss."
  howIntro="Rearranged, the velocity form solves any variable: v<sub>f</sub> = √(v<sub>i</sub>² + 2W<sub>net</sub>/m), v<sub>i</sub> = √(v<sub>f</sub>² − 2W<sub>net</sub>/m), and m = 2W<sub>net</sub> / (v<sub>f</sub>² − v<sub>i</sub>²). When the net force and displacement are known instead, the same net work can be found more directly from W<sub>net</sub> = F<sub>net</sub> × d."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the work-energy theorem actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-v" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From velocities (W<sub>net</sub> = ½m(v<sub>f</sub>²−v<sub>i</sub>²))</button>
      <button id="mode-fd" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From force &amp; displacement (W<sub>net</sub> = F×d)</button>
    </div>

    <div id="v-fields" class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Net work (W<sub>net</sub>)</span>
        <input id="w" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="m" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial velocity (v<sub>i</sub>)</span>
        <input id="vi" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Final velocity (v<sub>f</sub>)</span>
        <input id="vf" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="fd-fields" class="hidden gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Net work (W<sub>net</sub>)</span>
        <input id="w2" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Net force (F<sub>net</sub>)</span>
        <input id="fnet" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Displacement (d)</span>
        <input id="disp" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Net work</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Mass</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Initial velocity</div><div id="r-3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-4" class="text-sm text-slate-500">Final velocity</div><div id="r-4" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <div id="ke-readouts" class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Initial KE</div><div id="r-kei" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Final KE</div><div id="r-kef" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="we-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D scene + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D velocity &amp; kinetic energy</h2>
      <p class="mt-1 text-sm text-slate-500">Set v_i, v_f and mass; the block speeds up or slows down along the track, its velocity vector grows or shrinks to match, and the KE gauge updates live. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-3">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">v<sub>i</sub> <span id="out-bvi" class="font-mono text-indigo-600">4.0 m/s</span></span>
          <input id="b-vi" type="range" min="-20" max="20" step="0.5" value="4" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">v<sub>f</sub> <span id="out-bvf" class="font-mono text-indigo-600">16.0 m/s</span></span>
          <input id="b-vf" type="range" min="-20" max="20" step="0.5" value="16" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Mass (m) <span id="out-bm" class="font-mono text-indigo-600">10.0 kg</span></span>
          <input id="b-m" type="range" min="1" max="50" step="0.5" value="10" class="mt-2 w-full accent-indigo-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">W<sub>net</sub> = ΔKE = <span id="out-bw" class="font-mono font-bold">1200.0 J</span> (KE<sub>i</sub> = <span id="out-bkei" class="font-mono">80.0 J</span> → KE<sub>f</sub> = <span id="out-bkef" class="font-mono">1280.0 J</span>)</div>
      <div id="we3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="we3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Work-energy graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">KE vs velocity at fixed mass — a parabola, since KE ∝ v²</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-kev"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">W_net vs Δ(v²) at fixed mass — a straight line, since W_net = ½m·Δ(v²)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-wdv2"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup, arrow } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'v';
      function switchMode(m) {
        mode = m;
        el('mode-v').className = m === 'v' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-fd').className = m === 'fd' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('v-fields').className = m === 'v' ? 'grid gap-4 sm:grid-cols-4' : 'hidden';
        el('fd-fields').className = m === 'fd' ? 'grid gap-4 sm:grid-cols-3' : 'hidden gap-4 sm:grid-cols-3';
        el('ke-readouts').className = m === 'v' ? 'mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2' : 'hidden';
        el('we-err').textContent = '';
        if (m === 'v') {
          el('lab-1').textContent = 'Net work'; el('lab-2').textContent = 'Mass';
          el('lab-3').textContent = 'Initial velocity'; el('lab-4').textContent = 'Final velocity';
        } else {
          el('lab-1').textContent = 'Net work'; el('lab-2').textContent = 'Net force';
          el('lab-3').textContent = 'Displacement'; el('lab-4').textContent = '';
        }
        ['r-1', 'r-2', 'r-3', 'r-4', 'r-kei', 'r-kef'].forEach((id) => (el(id).textContent = '—'));
        updateV(); updateFD();
      }

      function updateV() {
        if (mode !== 'v') return;
        el('we-err').textContent = '';
        ['r-1', 'r-2', 'r-3', 'r-4', 'r-kei', 'r-kef'].forEach((id) => (el(id).textContent = '—'));
        const w = parseFloat(el('w').value), m = parseFloat(el('m').value), vi = parseFloat(el('vi').value), vf = parseFloat(el('vf').value);
        const filled = [!isNaN(w), !isNaN(m), !isNaN(vi), !isNaN(vf)];
        if (filled.filter(Boolean).length < 3) return;
        if (filled[1] && m < 0) { el('we-err').textContent = 'Mass cannot be negative.'; return; }
        let rw = w, rm = m, rvi = vi, rvf = vf;
        if (!filled[0]) { // solve W_net
          rw = 0.5 * m * (vf * vf - vi * vi);
        } else if (!filled[1]) { // solve mass
          const denom = vf * vf - vi * vi;
          if (denom === 0) { el('we-err').textContent = 'v_i and v_f cannot be equal when solving for mass with nonzero net work.'; return; }
          rm = (2 * w) / denom;
          if (rm < 0) { el('we-err').textContent = 'These values imply a negative mass — check the sign of W_net relative to v_i and v_f.'; return; }
        } else if (!filled[2]) { // solve v_i
          const inner = vf * vf - (2 * w) / m;
          if (inner < 0) { el('we-err').textContent = 'No real initial velocity solves these values (v_i² would be negative).'; return; }
          rvi = Math.sqrt(inner);
        } else if (!filled[3]) { // solve v_f
          const inner = vi * vi + (2 * w) / m;
          if (inner < 0) { el('we-err').textContent = 'No real final velocity solves these values (v_f² would be negative).'; return; }
          rvf = Math.sqrt(inner);
        }
        const kei = 0.5 * rm * rvi * rvi, kef = 0.5 * rm * rvf * rvf;
        el('r-1').textContent = fmt(rw) + ' J';
        el('r-2').textContent = fmt(rm) + ' kg';
        el('r-3').textContent = fmt(rvi) + ' m/s';
        el('r-4').textContent = fmt(rvf) + ' m/s';
        el('r-kei').textContent = fmt(kei) + ' J';
        el('r-kef').textContent = fmt(kef) + ' J';
      }

      function updateFD() {
        if (mode !== 'fd') return;
        el('we-err').textContent = '';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        const w = parseFloat(el('w2').value), f = parseFloat(el('fnet').value), d = parseFloat(el('disp').value);
        const filled = [!isNaN(w), !isNaN(f), !isNaN(d)];
        if (filled.filter(Boolean).length < 2) return;
        let rw = w, rf = f, rd = d;
        if (!filled[0]) { rw = f * d; }
        else if (!filled[1]) { if (d === 0) { el('we-err').textContent = 'Displacement cannot be zero.'; return; } rf = w / d; }
        else if (!filled[2]) { if (f === 0) { el('we-err').textContent = 'Net force cannot be zero when solving for displacement.'; return; } rd = w / f; }
        el('r-1').textContent = fmt(rw) + ' J';
        el('r-2').textContent = fmt(rf) + ' N';
        el('r-3').textContent = fmt(rd) + ' m';
      }

      el('mode-v').addEventListener('click', () => switchMode('v'));
      el('mode-fd').addEventListener('click', () => switchMode('fd'));
      ['w', 'm', 'vi', 'vf'].forEach((id) => el(id).addEventListener('input', updateV));
      ['w2', 'fnet', 'disp'].forEach((id) => el(id).addEventListener('input', updateFD));

      // ---- 3D + charts ----
      const charts = {};
      let scene = null;
      function bState() {
        const vi = parseFloat(el('b-vi').value), vf = parseFloat(el('b-vf').value), m = parseFloat(el('b-m').value);
        const kei = 0.5 * m * vi * vi, kef = 0.5 * m * vf * vf;
        return { vi, vf, m, kei, kef, w: kef - kei };
      }
      function onB() {
        const s = bState();
        el('out-bvi').textContent = s.vi.toFixed(1) + ' m/s';
        el('out-bvf').textContent = s.vf.toFixed(1) + ' m/s';
        el('out-bm').textContent = s.m.toFixed(1) + ' kg';
        el('out-bw').textContent = fmt(s.w) + ' J';
        el('out-bkei').textContent = fmt(s.kei) + ' J';
        el('out-bkef').textContent = fmt(s.kef) + ' J';
        try { if (scene) scene.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-vi').addEventListener('input', onB);
      el('b-vf').addEventListener('input', onB);
      el('b-m').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.kev = new Chart(el('chart-kev'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'KE', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Velocity (m/s)' } }, y: { title: { display: true, text: 'Kinetic energy (J)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.wdv2 = new Chart(el('chart-wdv2'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'W_net', data: [], borderColor: '#10b981', pointRadius: 0, tension: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Δ(v²) = v_f² − v_i²  (m²/s²)' } }, y: { title: { display: true, text: 'W_net (J)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const vMax = Math.max(20, Math.abs(s.vi), Math.abs(s.vf));
        const L1 = [], D1 = [];
        for (let v = 0; v <= vMax + 0.001; v += vMax / 40) { L1.push(v.toFixed(1)); D1.push(+(0.5 * s.m * v * v).toFixed(3)); }
        charts.kev.data.labels = L1; charts.kev.data.datasets[0].data = D1; charts.kev.update();

        const dv2Max = Math.max(50, Math.abs(s.vf * s.vf - s.vi * s.vi));
        const L2 = [], D2 = [];
        for (let dv2 = -dv2Max; dv2 <= dv2Max + 0.001; dv2 += (2 * dv2Max) / 40) { L2.push(dv2.toFixed(1)); D2.push(+(0.5 * s.m * dv2).toFixed(3)); }
        charts.wdv2.data.labels = L2; charts.wdv2.data.datasets[0].data = D2; charts.wdv2.update();
      }

      // ---- interactive scene: block on a track with a velocity vector + KE bar ----
      function initScene() {
        const c = el('we3d'); if (!c) throw new Error('no scene');
        const s = makeScene(c, 16, new THREE.Vector3(0, 0, 0), OPTS);
        s.scene.add(new THREE.GridHelper(30, 15, 0xcbd5e1, 0xe2e8f0));
        const track = new THREE.Mesh(new THREE.BoxGeometry(30, 0.1, 3), new THREE.MeshStandardMaterial({ color: 0x94a3b8 }));
        track.position.y = -0.15; s.scene.add(track);
        const block = new THREE.Mesh(new THREE.BoxGeometry(1.6, 1.2, 1.2), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
        block.position.set(-6, 0.6, 0); s.scene.add(block);

        // KE gauge: a vertical bar to the side of the track
        const gaugeBase = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.1, 0.9), new THREE.MeshStandardMaterial({ color: 0x94a3b8 }));
        gaugeBase.position.set(12, -1.9, 0); s.scene.add(gaugeBase);
        const keMat = new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.35 });
        let keBar = null, arrowHelper = null;

        function update(state) {
          if (arrowHelper) { s.scene.remove(arrowHelper); arrowHelper = null; }
          const dir = state.vf >= 0 ? 1 : -1;
          const from = new THREE.Vector3(block.position.x, 1.6, 0);
          const to = new THREE.Vector3(block.position.x + dir * Math.max(0.3, Math.abs(state.vf) * 0.18), 1.6, 0);
          if (Math.abs(state.vf) > 1e-6) { arrowHelper = arrow(from, to, 0xef4444); s.scene.add(arrowHelper); }

          const maxKe = Math.max(1, state.kei, state.kef);
          const scale = 6 / Math.max(maxKe, 1);
          const h = Math.max(0.05, state.kef * scale);
          if (keBar) { s.scene.remove(keBar); keBar.geometry.dispose(); }
          keBar = new THREE.Mesh(new THREE.BoxGeometry(0.9, h, 0.9), keMat);
          keBar.position.set(12, -1.85 + h / 2, 0);
          s.scene.add(keBar);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        scene = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { switchMode('v'); } catch (e) { console.error('[work-energy] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[work-energy] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[work-energy] charts failed', e); }
        if (window.THREE) {
          try { initScene(); } catch (e) { console.error('[work-energy] scene failed', e); el('we3d-fallback').classList.remove('hidden'); }
        } else { el('we3d-fallback').classList.remove('hidden'); }
        mountResize([scene]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
