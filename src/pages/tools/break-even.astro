---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Break-even Calculator';
const description =
  'Free break-even calculator. Find how many units you need to sell to cover your costs, plus ' +
  'the break-even revenue. Works in any currency.';
const intro =
  'Enter your fixed costs, price per unit and variable cost per unit to find your break-even point in units and revenue.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'What is the break-even point?', a: 'It’s the number of units you must sell so that total revenue exactly covers total costs — no profit, no loss. Beyond it, you start making a profit.' },
  { q: 'How is it calculated?', a: 'Break-even units = fixed costs ÷ (price per unit − variable cost per unit). The bottom part is your contribution margin per unit.' },
  { q: 'Why must price be above variable cost?', a: 'If each sale doesn’t cover its own variable cost, you lose money on every unit and can never break even.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Currency</span>
        <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option>$</option><option>€</option><option>£</option><option>₹</option><option>₨</option><option>¥</option><option>₦</option><option>A$</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fixed costs (total)</span>
        <input id="fixed" type="number" step="any" placeholder="5000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Price per unit</span>
        <input id="price" type="number" step="any" placeholder="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Variable cost per unit</span>
        <input id="var" type="number" step="any" placeholder="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Break-even units</div><div id="r-units" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Break-even revenue</div><div id="r-rev" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Margin per unit</div><div id="r-cm" class="mt-1 text-2xl font-bold text-emerald-600">—</div></div>
    </div>
    <p id="err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About break-even analysis</h2>
    <p class="mt-2 text-slate-600">
      Every business needs to know its break-even point — the moment sales start turning into
      profit. This calculator tells you exactly how many units you must sell and how much revenue
      that represents, helping you set targets, price products and judge whether an idea is viable.
    </p>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/profit-margin" class="font-medium text-indigo-600 hover:underline">Profit Margin Calculator</a>
      or <a href="/tools/roas-calculator" class="font-medium text-indigo-600 hover:underline">ROAS Calculator</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const cur = el('cur');
    const fmt = (n) => cur.value + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    function update() {
      const fixed = parseFloat(el('fixed').value);
      const price = parseFloat(el('price').value);
      const v = parseFloat(el('var').value);
      el('err').textContent = '';
      if (isNaN(fixed) || isNaN(price) || isNaN(v)) { ['r-units', 'r-rev', 'r-cm'].forEach((id) => (el(id).textContent = '—')); return; }
      const cm = price - v;
      if (cm <= 0) { ['r-units', 'r-rev', 'r-cm'].forEach((id) => (el(id).textContent = '—')); el('err').textContent = 'Price per unit must be greater than the variable cost.'; return; }
      const units = fixed / cm;
      el('r-units').textContent = Math.ceil(units).toLocaleString();
      el('r-rev').textContent = fmt(units * price);
      el('r-cm').textContent = fmt(cm);
    }
    ['cur', 'fixed', 'price', 'var'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
