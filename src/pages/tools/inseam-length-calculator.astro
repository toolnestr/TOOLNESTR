---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Inseam Length Calculator';
const description = 'Estimate inseam length from height, or convert a measured inseam to a pant length category.';
const intro = 'Estimate inseam length from height, or classify a measured inseam as petite, regular, or tall.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I measure inseam directly instead of estimating?', a: 'Measure a pair of well-fitting pants flat, from the crotch seam to the bottom hem, or stand straight and measure from your crotch to the floor with a helper holding the tape level. Direct measurement is always more accurate than a height-based estimate.' },
  { q: 'Why is the height-based estimate only approximate?', a: 'Leg length as a proportion of total height varies by individual — two people of the same height can have noticeably different leg-to-torso ratios, so this estimate is a reasonable starting point, not a substitute for a direct measurement.' },
  { q: 'What do petite, regular, and tall pant lengths mean?', a: 'They are standard inseam bands many retailers use to pre-hem pants for different leg lengths — typically petite for inseams under about 30 inches, regular for 30-32 inches, and tall for 33 inches and above, though exact cutoffs vary by brand.' },
  { q: 'Does inseam length affect belt or waist size?', a: 'No — inseam is entirely about leg length and is independent of waist circumference, which is why pants are usually sold with two separate numbers (waist and inseam) rather than one combined size.' },
];
const howTo = {
  name: 'How to find your inseam length',
  steps: [
    { name: 'Choose estimate or direct measurement', text: 'Use height for a general estimate, or enter a measured inseam directly for accuracy.' },
    { name: 'Enter the value', text: 'Type your height or measured inseam into the calculator.' },
    { name: 'Read the result', text: 'Your estimated or classified inseam length and pant-length category appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Estimate from height', 'I measured directly'].map((d) => (
        <button data-mode={d} class="mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span id="input-label" class="text-sm font-medium text-slate-700">Height (in)</span>
      <input id="value" type="number" step="any" placeholder="e.g. 70" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">Inseam</div><div id="r-inseam" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Pant length category</div><div id="r-cat" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="isc-title isc-desc">
      <title id="isc-title">Pants outline showing inseam measurement line</title>
      <desc id="isc-desc">An outline of pants with a vertical dashed line from the crotch seam to the ankle hem marking the inseam</desc>
      <path d="M340 20 L460 20 L470 100 L440 100 L420 200 L390 200 L385 105 L380 105 L375 200 L345 200 L330 100 L300 100 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <line x1="382" y1="100" x2="382" y2="200" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="500" y="150" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Inseam: crotch to hem</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Inseam is measured along the inner leg seam, from crotch to hem</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How inseam sizing works</h2>
    <p class="mt-2 text-slate-600">
      Inseam is the length of the inner leg seam on a pair of pants, from the crotch to the bottom hem, and is sold as a separate number from waist size because leg length and waist circumference vary independently between individuals. When a direct measurement isn't available, height offers a rough estimate, since leg length generally scales with overall height — a commonly cited approximation is that inseam runs close to 45% of total height, though the actual ratio shifts with individual proportions.
    </p>
    <p class="mt-3 text-slate-600">
      Most pants retailers group finished inseams into petite, regular, and tall categories to pre-hem garments closer to a buyer's actual leg length, typically under 30 inches for petite, 30-32 inches for regular, and 33 inches or more for tall, though the exact cutoffs vary by brand and by whether the pants are casual or tailored.
    </p>
    <p class="mt-3 text-xs text-slate-400">The height-to-inseam estimate reflects a general anthropometric ratio cited across apparel sizing guides; a direct measurement of well-fitting pants or of the body itself is always more reliable.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A shopper is 5'10" (70 inches) tall and has no pants on hand to measure.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Height:</span> <span class="text-slate-600">70 in</span></div>
        <div><span class="font-medium text-slate-700">Estimated inseam:</span> <span class="text-slate-600">70 × 0.45 ≈ <strong>31.5 in</strong></span></div>
        <div><span class="font-medium text-slate-700">Category:</span> <span class="text-slate-600"><strong>Regular</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Buying dress pants or a suit for an event without time for tailoring is the most common place an accurate inseam matters, since even a well-fitted waist looks wrong with pants that break incorrectly at the shoe — too long and they pool at the ankle, too short and they show sock above the shoe in a way that reads as ill-fitting rather than intentionally cropped.
    </p>
    <p class="mt-3 text-slate-600">
      Online-only retailers that don't stock every inseam length in every store rely on the petite/regular/tall category system heavily, and shoppers who don't know their category often end up ordering the default "regular" length and needing a separate hemming trip regardless.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Taller people always need a tall inseam." <strong class="text-slate-900">Not always.</strong> Leg-to-torso ratio varies by individual — some taller people carry more of their height in their torso and still fit a regular inseam, so a direct measurement beats assuming from height alone.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Inseam and outseam are the same measurement." <strong class="text-slate-900">They aren't.</strong> Outseam runs from the waistband to the hem along the outside of the leg and is always longer than inseam, since it includes the rise (crotch-to-waist) distance that inseam excludes.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/belt-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Belt Size Calculator</a>
      <a href="/tools/jacket-suit-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Jacket/Suit Size Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'Estimate from height';

    function category(inseam) {
      if (inseam < 30) return 'Petite';
      if (inseam <= 32) return 'Regular';
      return 'Tall';
    }

    function update() {
      const v = parseFloat(el('value').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const inseam = mode === 'Estimate from height' ? v * 0.45 : v;
      el('r-inseam').textContent = inseam.toFixed(1) + ' in';
      el('r-cat').textContent = category(inseam);
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach((b) => {
          b.className = 'mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'mode-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        mode = btn.dataset.mode;
        el('input-label').textContent = mode === 'Estimate from height' ? 'Height (in)' : 'Measured inseam (in)';
        el('value').placeholder = mode === 'Estimate from height' ? 'e.g. 70' : 'e.g. 32';
        update();
      });
    });

    el('value').addEventListener('input', update);
    document.querySelector('.mode-btn').click();
  </script>
</ToolLayout>
