---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Yeast Converter';
const description =
  'Free yeast converter. Convert between active dry yeast, instant yeast, and fresh yeast amounts for any recipe, with accurate ratios for baking success.';
const intro =
  'Enter the amount of yeast you have, select the type, and see the equivalent amounts of active dry, instant and fresh yeast needed.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'What is the difference between active dry and instant yeast?', a: 'Active dry yeast consists of dormant granules surrounded by a coating of dead yeast cells. It must be proofed (dissolved in warm water with a pinch of sugar) before use. Instant yeast (also called rapid-rise or bread machine yeast) has finer granules and more live cells per gram — it can be mixed directly with dry ingredients without proofing. Instant yeast is about 25% more potent by volume than active dry yeast.' },
  { q: 'Can I substitute dry yeast for fresh yeast?', a: 'Yes, but the conversion ratio is roughly 1:3 — 1 gram of dry yeast (active dry or instant) equals about 3 grams of fresh yeast. Fresh yeast (also called compressed or cake yeast) is a living culture in a moist block that must be crumbled and dissolved in warm liquid before use. It has a very short shelf life of 1–2 weeks in the refrigerator.' },
  { q: 'Does instant yeast need to be proofed?', a: 'No — instant yeast is designed to be mixed directly with flour and other dry ingredients. The moisture in the dough activates it during mixing and kneading. However, if your kitchen is cold or you want to verify the yeast is alive, you can proof it in warm liquid (35–40°C / 95–105°F) for 5–10 minutes until foamy.' },
  { q: 'How should I store different yeast types?', a: 'Active dry and instant yeast should be stored in a cool, dry place or refrigerated after opening. They remain viable for 1–2 years unopened and 4–6 months after opening if sealed tightly. Fresh yeast must always be refrigerated and used within 1–2 weeks. It can be frozen for up to 3 months, though potency decreases over time.' },
  { q: 'What happens if I use too much or too little yeast?', a: 'Too much yeast causes the dough to rise too quickly, producing a coarse, open crumb, a yeasty or alcoholic flavour, and potentially a collapsed loaf. Too little yeast results in slow or incomplete rising, a dense texture and a flat flavour. Using the correct converted amount ensures predictable fermentation and optimal bread quality.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Amount</span>
        <input id="amount" type="number" step="any" placeholder="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Unit</span>
        <select id="unit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="tsp">Teaspoons (tsp)</option>
          <option value="tbsp">Tablespoons (tbsp)</option>
          <option value="g">Grams (g)</option>
          <option value="oz">Ounces (oz)</option>
        </select></label>
    </div>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Yeast type you have</span>
      <select id="fromType" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="active">Active dry yeast</option>
        <option value="instant">Instant yeast (rapid-rise)</option>
        <option value="fresh">Fresh compressed yeast</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Active dry yeast</div>
        <div id="r-active" class="mt-1 text-xl font-bold">—</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Instant yeast</div><div id="r-instant" class="mt-1 text-lg font-bold text-indigo-600">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Fresh yeast</div><div id="r-fresh" class="mt-1 text-lg font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter the yeast amount and type to see all equivalents.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The Yeast Converter uses standard conversion ratios established by yeast manufacturers and baking authorities. The core conversion factors are based on the relative potency of each yeast form. Instant yeast is the most concentrated, with about 25% more live yeast cells per gram than active dry yeast. Fresh yeast has the lowest concentration of live cells per gram because it contains a significant amount of water.
    </p>
    <p class="mt-3 text-slate-600">
      The standard conversion ratios are: 1 gram of instant yeast = 1.25 grams of active dry yeast = 3 grams of fresh yeast. In volume terms, 1 teaspoon of instant yeast weighs approximately 3 g, while 1 teaspoon of active dry yeast weighs about 2.8 g. These small variations matter in baking because yeast directly controls the fermentation rate and therefore the final texture, flavour and volume of your bread.
    </p>
    <p class="mt-3 text-slate-600">
      Understanding these conversions is especially important when adapting recipes from different sources. A French recipe might call for fresh baker's yeast (levure de boulanger), while an American recipe for the same bread might use active dry or instant yeast. Using the wrong amount can lead to over-proofing or under-proofing, affecting everything from crust colour to crumb structure and shelf life.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="320" viewBox="0 0 800 320" role="img" aria-labelledby="yc-title yc-desc">
      <title id="yc-title">Yeast conversion diagram</title>
      <desc id="yc-desc">Three connected yeast packet icons showing active dry, instant and fresh yeast with conversion arrows and ratios between them.</desc>

      <!-- Active dry -->
      <rect x="40" y="30" width="200" height="110" rx="12" fill="#fef3c7" stroke="#f59e0b" stroke-width="2" />
      <rect x="60" y="45" width="160" height="10" rx="3" fill="#f59e0b" />
      <circle cx="100" cy="80" r="20" fill="#fbbf24" opacity="0.5" />
      <circle cx="140" cy="85" r="18" fill="#fbbf24" opacity="0.5" />
      <circle cx="170" cy="78" r="16" fill="#fbbf24" opacity="0.5" />
      <text x="140" y="125" text-anchor="middle" font-size="14" font-weight="bold" fill="#92400e">Active dry</text>
      <text x="140" y="138" text-anchor="middle" font-size="11" fill="#92400e">1 tsp = 2.8 g</text>

      <!-- Arrow 1 -->
      <line x1="240" y1="85" x2="300" y2="85" stroke="#6366f1" stroke-width="2.5" marker-end="url(#y-arr)" />
      <text x="270" y="75" text-anchor="middle" font-size="10" font-weight="bold" fill="#6366f1">×0.8</text>

      <!-- Instant -->
      <rect x="310" y="30" width="200" height="110" rx="12" fill="#e0e7ff" stroke="#6366f1" stroke-width="2" />
      <rect x="330" y="45" width="160" height="10" rx="3" fill="#6366f1" />
      <circle cx="370" cy="80" r="18" fill="#818cf8" opacity="0.5" />
      <circle cx="400" cy="85" r="16" fill="#818cf8" opacity="0.5" />
      <circle cx="440" cy="80" r="14" fill="#818cf8" opacity="0.5" />
      <text x="410" y="125" text-anchor="middle" font-size="14" font-weight="bold" fill="#3730a3">Instant</text>
      <text x="410" y="138" text-anchor="middle" font-size="11" fill="#3730a3">1 tsp = 3 g</text>

      <!-- Arrow 2 -->
      <line x1="510" y1="85" x2="570" y2="85" stroke="#10b981" stroke-width="2.5" marker-end="url(#y-arr)" />
      <text x="540" y="75" text-anchor="middle" font-size="10" font-weight="bold" fill="#10b981">×3</text>

      <!-- Fresh -->
      <rect x="580" y="30" width="180" height="110" rx="12" fill="#f0fdf4" stroke="#22c55e" stroke-width="2" />
      <rect x="600" y="45" width="140" height="10" rx="3" fill="#22c55e" />
      <rect x="620" y="68" width="40" height="35" rx="4" fill="#86efac" opacity="0.6" />
      <rect x="670" y="72" width="40" height="31" rx="4" fill="#86efac" opacity="0.6" />
      <rect x="720" y="72" width="30" height="31" rx="4" fill="#86efac" opacity="0.6" />
      <text x="670" y="125" text-anchor="middle" font-size="14" font-weight="bold" fill="#166534">Fresh</text>
      <text x="670" y="138" text-anchor="middle" font-size="11" fill="#166534">1 tsp = 3.1 g</text>

      <defs><marker id="y-arr" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><path d="M 0 0 L 8 3 L 0 6 Z" fill="#6366f1" /></marker></defs>

      <!-- Bottom key -->
      <rect x="100" y="180" width="600" height="120" rx="10" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" />
      <text x="400" y="205" text-anchor="middle" font-size="13" font-weight="bold" fill="#475569">Conversion ratios (by weight)</text>
      <text x="200" y="230" text-anchor="middle" font-size="12" fill="#f59e0b" font-weight="bold">Active dry</text>
      <text x="400" y="230" text-anchor="middle" font-size="12" fill="#6366f1" font-weight="bold">Instant</text>
      <text x="600" y="230" text-anchor="middle" font-size="12" fill="#22c55e" font-weight="bold">Fresh</text>
      <text x="200" y="250" text-anchor="middle" font-size="11" fill="#64748b">1 g</text>
      <text x="400" y="250" text-anchor="middle" font-size="11" fill="#64748b">0.8 g</text>
      <text x="600" y="250" text-anchor="middle" font-size="11" fill="#64748b">3 g</text>
      <text x="200" y="270" text-anchor="middle" font-size="11" fill="#64748b">—</text>
      <text x="400" y="270" text-anchor="middle" font-size="11" fill="#64748b">1 g</text>
      <text x="600" y="270" text-anchor="middle" font-size="11" fill="#64748b">2.5 g</text>
      <text x="200" y="290" text-anchor="middle" font-size="11" fill="#64748b">3 g</text>
      <text x="400" y="290" text-anchor="middle" font-size="11" fill="#64748b">2.5 g</text>
      <text x="600" y="290" text-anchor="middle" font-size="11" fill="#64748b">1 g</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Conversion ratios between active dry, instant and fresh yeast forms by weight</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the conversion works</h2>
    <p class="mt-2 text-slate-600">
      All conversions route through the gram weight of active dry yeast as the base reference. The key ratios are: instant = active dry × 0.8, fresh = active dry × 3. The calculator also handles volume conversions between teaspoons and tablespoons using standard yeast densities.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A recipe from a French cookbook calls for 15 g of fresh yeast, but you only have instant yeast in your pantry. How much instant yeast should you use?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Recipe calls for:</span> <span class="text-slate-600">15 g fresh yeast</span></div>
        <div><span class="font-medium text-slate-700">Fresh → Active dry:</span> <span class="text-slate-600">15 ÷ 3 = <strong>5 g</strong> active dry</span></div>
        <div><span class="font-medium text-slate-700">Active dry → Instant:</span> <span class="text-slate-600">5 × 0.8 = <strong>4 g</strong> instant</span></div>
        <div><span class="font-medium text-slate-700">In teaspoons:</span> <span class="text-slate-600">4 g ÷ 3 g/tsp ≈ <strong>1.3 tsp</strong> (1 tsp + ¼ tsp)</span></div>
        <div><span class="font-medium text-slate-700">Proofing method:</span> <span class="text-slate-600">Mix instant yeast directly with flour — no proofing needed.</span></div>
        <div><span class="font-medium text-slate-700">Expected result:</span> <span class="text-slate-600">Equivalent fermentation power, same rise time and volume.</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍞</span>
      <h3 class="mt-2 font-semibold text-slate-900">Home bread baker</h3>
      <p class="mt-1 text-sm text-slate-600">Trying new bread recipes from different countries and cultures, each using a different yeast type. Convert everything to the yeast you keep in your pantry.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📖</span>
      <h3 class="mt-2 font-semibold text-slate-900">Recipe translator</h3>
      <p class="mt-1 text-sm text-slate-600">Adapting recipes from European cookbooks (which often use fresh cake yeast) to common US ingredients (active dry or instant) for an American audience.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Pantry manager</h3>
      <p class="mt-1 text-sm text-slate-600">Your local store only stocks one type of yeast. Convert all your recipe bookmarks to use that single yeast type so you never need multiple kinds on hand.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Baking experimenter</h3>
      <p class="mt-1 text-sm text-slate-600">Testing how different yeast types affect the flavour profile and texture of the same bread recipe, and need precise equivalents for a fair comparison.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Yeast Converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your yeast amount</h3>
        <p class="mt-1 text-sm text-slate-600">Type the amount of yeast your recipe calls for and select whether it is in teaspoons, tablespoons, grams or ounces.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select the yeast type</h3>
        <p class="mt-1 text-sm text-slate-600">Choose which type of yeast your entered amount refers to — active dry, instant or fresh. The calculator handles the rest.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the equivalents</h3>
        <p class="mt-1 text-sm text-slate-600">See the exact amounts of active dry, instant and fresh yeast you need. Use the type you have on hand with full confidence.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always check your yeast is alive</h3>
        <p class="mt-1 text-sm text-slate-600">Even with the correct conversion, expired or improperly stored yeast may not rise. For active dry yeast, proof it in warm water with sugar for 5–10 minutes — if it foams, it is active. Instant yeast can be tested the same way if you are unsure of its age.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Adjust liquid temperature carefully</h3>
        <p class="mt-1 text-sm text-slate-600">Yeast is a living organism. Water that is too hot (above 50°C / 120°F) kills it; water that is too cold (below 20°C / 70°F) slows it down. For active dry yeast, use water at 40–46°C (105–115°F). For instant yeast mixed with dry ingredients, the liquid can be slightly warmer, around 43–49°C (110–120°F), as it cools when mixed with flour.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Store yeast properly for longest life</h3>
        <p class="mt-1 text-sm text-slate-600">Keep dry yeast in an airtight container in the refrigerator or freezer. Fresh yeast should stay refrigerated and be used within two weeks. Always bring refrigerated yeast to room temperature before using for the most predictable results.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/baking-ingredient-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🧈</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Ingredient Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert butter, flour and sugar amounts</p>
      </a>
      <a href="/tools/baking-conversion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">⚖️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Conversion Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Volume to weight for all baking ingredients</p>
      </a>
      <a href="/tools/oven-temperature-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🌡️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Oven Temperature Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert °F, °C, gas mark and fan</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    const gPerTsp = { active: 2.8, instant: 3.0, fresh: 3.1 };
    const ratios = {
      'active': { active: 1, instant: 0.8, fresh: 3 },
      'instant': { active: 1.25, instant: 1, fresh: 3.75 },
      'fresh': { active: 1 / 3, instant: 1 / 3.75, fresh: 1 },
    };

    function toGrams(amount, unit, type) {
      switch (unit) {
        case 'tsp': return amount * gPerTsp[type];
        case 'tbsp': return amount * gPerTsp[type] * 3;
        case 'g': return amount;
        case 'oz': return amount * 28.3495;
        default: return 0;
      }
    }

    function fromGrams(grams, unit, type) {
      switch (unit) {
        case 'tsp': return grams / gPerTsp[type];
        case 'tbsp': return grams / (gPerTsp[type] * 3);
        case 'g': return grams;
        case 'oz': return grams / 28.3495;
        default: return 0;
      }
    }

    function formatVal(val, unit) {
      if (val < 0.1) return '< 0.1 ' + unit;
      return val.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' ' + unit;
    }

    function update() {
      const amount = parseFloat(el('amount').value);
      const unit = el('unit').value;
      const fromType = el('fromType').value;

      if (!amount || amount <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      const baseG = toGrams(amount, unit, fromType);
      if (baseG <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      const activeG = baseG * ratios[fromType].active;
      const instantG = baseG * ratios[fromType].instant;
      const freshG = baseG * ratios[fromType].fresh;

      el('r-active').textContent = formatVal(fromGrams(activeG, unit, 'active'), unit);
      el('r-instant').textContent = formatVal(fromGrams(instantG, unit, 'instant'), unit);
      el('r-fresh').textContent = formatVal(fromGrams(freshG, unit, 'fresh'), unit);
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    ['amount', 'unit', 'fromType'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
