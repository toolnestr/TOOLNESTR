---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Lorem Ipsum Generator';
const description =
  'Free online lorem ipsum generator. Generate placeholder text in paragraphs, sentences, words or by character count. Multiple variants available.';
const intro =
  'Choose the amount and type of placeholder text you need — paragraphs, sentences, words or characters.';
const category = { id: 'text', name: 'Text Tools' };
const faqs = [
  { q: 'What is Lorem Ipsum?', a: 'Lorem Ipsum is dummy text used in the printing and typesetting industry. It has been the industry\'s standard dummy text since the 1500s.' },
  { q: 'Why is it called Lorem Ipsum?', a: 'It comes from a Latin text by Cicero written in 45 BC. The passage "Lorem ipsum dolor sit amet..." is a scrambled excerpt from "De Finibus Bonorum et Malorum".' },
  { q: 'Can I generate text by word count?', a: 'Yes. Select "Words" from the type dropdown and enter the number of words you need.' },
  { q: 'Is there a maximum limit?', a: 'You can generate up to 100 paragraphs, sentences, words or bytes. Higher values are capped for performance.' },
  { q: 'Is generated text unique each time?', a: 'The text is deterministic by variant — you will get the same sequence for the same variant and count, making it repeatable for testing.' },
  { q: 'Can I use Lorem Ipsum in production designs?', a: 'Absolutely. It is placeholder text meant to be replaced, but it is safe to use in wireframes, mockups and prototypes.' },
  { q: 'Why does placeholder text not use real words?', a: 'Real words distract from the visual layout. Lorem Ipsum looks like natural text without conveying meaning, keeping focus on design.' },
  { q: 'What variants are available?', a: 'Classic (standard Lorem Ipsum), Cicero (original Latin passages), and Standard (a shorter common variant).' },
  { q: 'Does the generator work offline?', a: 'Yes. Everything runs in your browser — no server requests are made to generate placeholder text.' },
  { q: 'Can I use the generated text commercially?', a: 'Yes. Lorem Ipsum is placeholder text with no copyright restrictions. You may use it freely in commercial mockups and templates.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Type</span>
        <select id="type" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="paragraphs">Paragraphs</option>
          <option value="sentences">Sentences</option>
          <option value="words">Words</option>
          <option value="bytes">Bytes (characters)</option>
        </select>
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Count (1–100)</span>
        <input id="count" type="number" min="1" max="100" value="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Variant</span>
        <select id="variant" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="classic">Classic</option>
          <option value="cicero">Cicero</option>
          <option value="standard">Standard</option>
        </select>
      </label>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <button id="generate-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Generate</button>
      <button id="copy-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Copy result</button>
      <span id="stats" class="ml-auto text-sm text-slate-400">0 chars, 0 words</span>
    </div>

    <textarea id="output" rows="8" readonly placeholder="Generated text will appear here…" class="mt-3 w-full resize-y rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm outline-none"></textarea>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How Lorem Ipsum generation works</h2>
    <p class="mt-2 text-slate-600">Lorem Ipsum generators pull from a fixed bank of scrambled Latin passages originally derived from Cicero's <em>De Finibus Bonorum et Malorum</em>, written in 45 BC. The generator text is not random — it stores collections of words and sentences from these classic sources and assembles them based on your chosen count.</p>
    <p class="mt-3 text-slate-600">When you select "Words", the generator picks individual words from the passage bank until it reaches your specified count. "Sentences" mode returns complete or partial sentences, while "Paragraphs" mode returns whole passages. The standard Lorem Ipsum passage begins with "Lorem ipsum dolor sit amet, consectetur adipiscing elit..." regardless of which variant you choose.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Input:</span> <span class="text-slate-600">Type=Words, Count=50, Variant=Classic</span></div>
        <div><span class="font-medium text-slate-700">Output:</span> <span class="text-slate-600">"Lorem ipsum dolor sit amet, consectetur adipiscing elit..." (standard starter text)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different Lorem Ipsum uses mean</h2>
    <p class="mt-2 text-slate-600">Lorem Ipsum is used across many fields. Here is how its usage breaks down by industry.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Web Design</span><span class="text-slate-400">40%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:40%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Print Layout</span><span class="text-slate-400">25%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:25%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Typography</span><span class="text-slate-400">20%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Template Development</span><span class="text-slate-400">15%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-violet-500" style="width:15%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f3a8;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Web Designer</h3>
      <p class="mt-1 text-sm text-slate-600">Fills wireframes and mockups with realistic-looking text blocks to demonstrate layout, spacing and typography before real content is ready.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4f7;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Graphic Designer</h3>
      <p class="mt-1 text-sm text-slate-600">Uses placeholder text in brochures, posters and flyer mockups to visualise how the final design will look with text in place.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4bb;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Developer</h3>
      <p class="mt-1 text-sm text-slate-600">Generates sample content for database seeding, UI component demos, and front-end testing of text overflow and responsiveness.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4ad;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Strategist</h3>
      <p class="mt-1 text-sm text-slate-600">Plans content hierarchy and reading flow by estimating how much space different amounts of text will occupy on the page.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Lorem Ipsum history timeline</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-sm">
        <thead><tr class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500"><th class="px-4 py-3">Year</th><th class="px-4 py-3">Event</th><th class="px-4 py-3">Significance</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <tr><td class="px-4 py-3 font-medium text-slate-900">45 BC</td><td class="px-4 py-3 text-slate-700">Cicero writes De Finibus</td><td class="px-4 py-3 text-slate-500">Original Latin text that Lorem Ipsum derives from is composed.</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">1500s</td><td class="px-4 py-3 text-slate-700">Typesetter scrambles text</td><td class="px-4 py-3 text-slate-500">An unknown printer took a passage and scrambled it to make type specimen books.</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">1960s</td><td class="px-4 py-3 text-slate-700">Letraset sheets</td><td class="px-4 py-3 text-slate-500">Lorem Ipsum passages became popular with Letraset transfer sheets.</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">1985</td><td class="px-4 py-3 text-slate-700">Aldus PageMaker</td><td class="px-4 py-3 text-slate-500">Lorem Ipsum was included as default dummy text in Aldus PageMaker.</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Today</td><td class="px-4 py-3 text-slate-700">Universal standard</td><td class="px-4 py-3 text-slate-500">Used in every design tool, CMS and wireframing app worldwide.</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this generator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose a type</h3>
        <p class="mt-1 text-sm text-slate-600">Pick paragraphs, sentences, words or character count from the dropdown menu.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set count and variant</h3>
        <p class="mt-1 text-sm text-slate-600">Enter how many units you need and select a variant — Classic, Cicero or Standard.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Generate and copy</h3>
        <p class="mt-1 text-sm text-slate-600">Click Generate to create your text, then Copy result to paste it into your project.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for using placeholder text</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Match the amount to your layout</h3>
        <p class="mt-1 text-sm text-slate-600">Generate roughly the same volume of text that real content will occupy. Too little and the design looks sparse; too much and it feels cramped.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use the Cicero variant for variety</h3>
        <p class="mt-1 text-sm text-slate-600">The Cicero variant uses actual Latin passages from Cicero\'s original text, offering different word distributions and sentence lengths.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Replace before publishing</h3>
        <p class="mt-1 text-sm text-slate-600">Always replace Lorem Ipsum with real content before going live. Search engines penalise pages with placeholder text in production.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is Lorem Ipsum?</h2>
    <p class="mt-2 text-slate-600">
      Lorem Ipsum is simply dummy text of the printing and typesetting industry. It has been the industry\'s standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book. It has survived not only five centuries, but also the leap into electronic typesetting, remaining essentially unchanged.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why it is used</h2>
    <p class="mt-2 text-slate-600">
      Designers and developers use placeholder text to focus attention on layout rather than content. Real text distracts the eye — readers naturally start reading meaningful words instead of evaluating visual elements like spacing, font size, and colour contrast. Lorem Ipsum approximates the distribution of letters and word lengths in English without being readable.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Variants explained</h2>
    <p class="mt-2 text-slate-600">
      The Classic variant is the traditional scrambled Lorem Ipsum passage. Cicero uses real excerpts from Cicero\'s De Finibus Bonorum et Malorum. Standard is a shorter, commonly used variant that begins with "Lorem ipsum dolor sit amet" and is ideal for quick mockups.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const type = el('type'), count = el('count'), variant = el('variant');
    const output = el('output'), stats = el('stats');

    const LOREMS = {
      classic: [
        'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.',
        'Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.',
        'Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium, totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi architecto beatae vitae dicta sunt explicabo.',
        'Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt.',
        'At vero eos et accusamus et iusto odio dignissimos ducimus qui blanditiis praesentium voluptatum deleniti atque corrupti quos dolores et quas molestias excepturi sint occaecati cupiditate non provident.',
      ],
      cicero: [
        'Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatur. Vel illum qui dolorem eum fugiat quo voluptas nulla pariatur.',
        'Neque porro quisquam est, qui dolorem ipsum quia dolor sit amet, consectetur, adipisci velit, sed quia non numquam eius modi tempora incidunt ut labore et dolore magnam aliquam quaerat voluptatem.',
        'Ut enim ad minima veniam, quis nostrum exercitationem ullam corporis suscipit laboriosam, nisi ut aliquid ex ea commodi consequatur.',
        'Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatur. Vel illum qui dolorem eum fugiat quo voluptas nulla pariatur.',
        'At vero eos et accusamus et iusto odio dignissimos ducimus qui blanditiis praesentium voluptatum deleniti atque corrupti quos dolores et quas molestias excepturi sint occaecati cupiditate non provident.',
      ],
      standard: [
        'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer nec odio. Praesent libero. Sed cursus ante dapibus diam.',
        'Sed nisi. Nulla quis sem at nibh elementum imperdiet. Duis sagittis ipsum. Praesent mauris. Fusce nec tellus sed augue semper porta.',
        'Mauris massa. Vestibulum lacinia arcu eget nulla. Class aptent taciti sociosqu ad litora torquent per conubia nostra, per inceptos himenaeos.',
        'Curabitur sodales ligula in libero. Sed dignissim lacinia nunc. Curabitur tortor. Pellentesque nibh. Aenean quam. In scelerisque sem at dolor.',
        'Maecenas mattis. Sed convallis tristique sem. Proin ut ligula vel nunc egestas porttitor. Morbi lectus risus, iaculis vel, suscipit quis, luctus non, massa.',
      ],
    };

    function getWords(n, words) {
      const result = [];
      for (let i = 0; result.length < n; i++) {
        const sentence = words[i % words.length];
        sentence.split(' ').forEach((w) => { if (result.length < n) result.push(w); });
      }
      return result.join(' ');
    }

    function generate() {
      const t = type.value;
      const n = Math.min(Math.max(parseInt(count.value, 10) || 1, 1), 100);
      const v = variant.value;
      const sentences = LOREMS[v];
      let result = '';

      if (t === 'paragraphs') {
        const arr = [];
        for (let i = 0; i < n; i++) arr.push(sentences[i % sentences.length]);
        result = arr.join('\n\n');
      } else if (t === 'sentences') {
        const arr = [];
        for (let i = 0; i < n; i++) {
          const words = sentences[i % sentences.length].split(' ');
          arr.push(words.slice(0, Math.max(1, Math.floor(words.length / 2))).join(' ') + '.');
        }
        result = arr.join(' ');
      } else if (t === 'words') {
        const allWords = sentences.join(' ').split(' ');
        result = getWords(n, allWords);
      } else if (t === 'bytes') {
        const allWords = sentences.join(' ').split(' ');
        const joined = allWords.join(' ');
        result = joined.slice(0, n);
      }

      output.value = result;
      stats.textContent = result.length.toLocaleString() + ' chars, ' + (result ? result.split(/\s+/).length.toLocaleString() : '0') + ' words';
    }

    el('generate-btn').addEventListener('click', generate);
    el('copy-btn').addEventListener('click', async () => {
      if (!output.value) return;
      try { await navigator.clipboard.writeText(output.value); const b = el('copy-btn'); const o = b.textContent; b.textContent = 'Copied!'; setTimeout(() => (b.textContent = o), 1200); } catch (e) {}
    });

    generate();
  </script>
</ToolLayout>
