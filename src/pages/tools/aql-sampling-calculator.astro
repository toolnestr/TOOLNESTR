---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'AQL Sampling & Lead Time Estimator';
const description = 'Find the sample size and accept/reject numbers for an apparel quality inspection using ISO 2859-1 (ANSI/ASQ Z1.4) General Inspection Level II, Normal severity, at 2.5% AQL.';
const intro = 'Enter your lot size to find the standard sample size and accept/reject numbers for a quality inspection.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is AQL?', a: 'AQL (Acceptable Quality Limit) is the maximum percentage of defective units in a batch that\'s still considered acceptable for a given inspection plan. AQL 2.5% for major defects is the most common standard used in apparel quality control, defined by the international ISO 2859-1 sampling standard (equivalent to ANSI/ASQ Z1.4).' },
  { q: 'Why don\'t I need to inspect every unit?', a: 'Statistical sampling lets an inspector check a much smaller, randomly-drawn sample and still draw a reliable conclusion about the whole lot\'s quality, at a small, known risk level — inspecting 100% of a large order is rarely practical or cost-effective for routine QC.' },
  { q: 'What do the accept (Ac) and reject (Re) numbers mean?', a: 'Ac is the maximum number of defective units found in the sample that still allows the lot to pass; Re is the number of defects at which the lot is rejected. Finding a defect count between Ac and Re (exclusive) — i.e. exactly Re defects or more — fails the lot.' },
  { q: 'What sampling severity level does this use?', a: 'General Inspection Level II, Normal severity — the standard default used for most routine apparel shipments. Tightened or reduced inspection levels exist for suppliers with a recent history of failures or consistent passes, respectively, and use different sample sizes.' },
];
const howTo = {
  name: 'How to find an AQL sample size',
  steps: [
    { name: 'Enter total lot size', text: 'The full quantity of units in the production batch or shipment.' },
    { name: 'Read the sample size', text: 'The number of units to randomly inspect, per ISO 2859-1 Level II Normal.' },
    { name: 'Read accept/reject numbers', text: 'The maximum defects allowed to pass (Ac) and the count that fails the lot (Re), at 2.5% AQL.' },
  ],
};

const table = [
  { min: 2, max: 8, sample: 2, ac: 0, re: 1 },
  { min: 9, max: 15, sample: 3, ac: 0, re: 1 },
  { min: 16, max: 25, sample: 5, ac: 0, re: 1 },
  { min: 26, max: 50, sample: 8, ac: 0, re: 1 },
  { min: 51, max: 90, sample: 13, ac: 1, re: 2 },
  { min: 91, max: 150, sample: 20, ac: 1, re: 2 },
  { min: 151, max: 280, sample: 32, ac: 2, re: 3 },
  { min: 281, max: 500, sample: 50, ac: 3, re: 4 },
  { min: 501, max: 1200, sample: 80, ac: 5, re: 6 },
  { min: 1201, max: 3200, sample: 125, ac: 7, re: 8 },
  { min: 3201, max: 10000, sample: 200, ac: 10, re: 11 },
  { min: 10001, max: 35000, sample: 315, ac: 14, re: 15 },
  { min: 35001, max: 150000, sample: 500, ac: 21, re: 22 },
  { min: 150001, max: 500000, sample: 800, ac: 21, re: 22 },
  { min: 500001, max: Infinity, sample: 1250, ac: 21, re: 22 },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Total lot size (units)</span>
      <input id="lot" type="number" step="1" placeholder="e.g. 5000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-fuchsia-600 p-4 text-center text-white"><div class="text-sm opacity-80">Sample size</div><div id="r-sample" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-emerald-50 p-4 text-center"><div class="text-sm text-emerald-700">Accept (Ac)</div><div id="r-ac" class="mt-1 text-2xl font-bold text-emerald-800">—</div></div>
      <div class="rounded-xl bg-red-50 p-4 text-center"><div class="text-sm text-red-700">Reject (Re)</div><div id="r-re" class="mt-1 text-2xl font-bold text-red-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How AQL sample size is determined</h2>
    <p class="mt-2 text-slate-600">
      ISO 2859-1 (equivalent to ANSI/ASQ Z1.4) links lot size to a sample size using published tables rather than a simple percentage — larger lots use a proportionally smaller sampling fraction, since statistical confidence scales efficiently with sample size beyond a certain point. This calculator uses General Inspection Level II, the standard default severity for routine apparel shipment inspections, at Normal inspection tightness.
    </p>
    <p class="mt-3 text-slate-600">
      Once the sample size is known, the accept (Ac) and reject (Re) numbers come from a second table cross-referencing sample size against the chosen AQL — the maximum acceptable defect rate. This tool uses 2.5% AQL for major defects, the most widely used standard in apparel quality control, covering issues like stitching defects, seam slippage, or measurement out-of-tolerance that affect the garment's fitness for sale but aren't necessarily safety-critical.
    </p>
    <p class="mt-3 text-xs text-slate-400">Sample sizes and Ac/Re numbers follow ISO 2859-1 (ANSI/ASQ Z1.4) General Inspection Level II, Normal severity, AQL 2.5%. Always confirm against the full published standard or your QC provider for contractual inspections.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A shipment of 5,000 units needs inspection before release.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Lot size:</span> <span class="text-slate-600">5,000 (falls in 3,201-10,000 range)</span></div>
        <div><span class="font-medium text-slate-700">Sample size:</span> <span class="text-slate-600"><strong>200 units</strong></span></div>
        <div><span class="font-medium text-slate-700">Accept:</span> <span class="text-slate-600">10 or fewer major defects</span></div>
        <div><span class="font-medium text-slate-700">Reject:</span> <span class="text-slate-600">11 or more major defects</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Third-party quality-control agencies performing pre-shipment inspections for apparel brands almost universally reference ISO 2859-1 / ANSI Z1.4 tables like this one, since they give both the brand and the factory a shared, objective, industry-standard basis for a pass/fail decision — rather than a subjective judgment call by whoever happens to be doing the inspection.
    </p>
    <p class="mt-3 text-slate-600">
      Brands often run separate, stricter AQL levels for critical and minor defects alongside the major-defect AQL shown here — a full inspection report typically distinguishes critical defects (safety issues, near-zero tolerance), major defects (this 2.5% AQL), and minor defects (a higher, more lenient AQL, often 4.0%), each with its own Ac/Re numbers.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"AQL sampling means checking a fixed 10% of every order." <strong class="text-slate-900">Not a flat percentage.</strong> Sample size is drawn from published lot-size-based tables, not a simple percentage of the lot — larger lots use a smaller sampling fraction, not a constant one.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Passing AQL inspection guarantees zero defects in the shipment." <strong class="text-slate-900">It doesn't — that's the whole point of sampling.</strong> AQL inspection accepts a lot with a statistically bounded, known level of defect risk; it's a quality-control tool for large-scale production, not a zero-defect guarantee.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/cbm-container-loading-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">CBM & Container Loading Estimator</a>
      <a href="/tools/sam-line-efficiency-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">SAM / Line Efficiency Calculator</a>
      <a href="/tools/cm-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">CM (Cut-Make) Cost Calculator</a>
    </div>
  </section>

  <script is:inline define:vars={{ table }}>
    const el = (id) => document.getElementById(id);

    function update() {
      const lot = parseFloat(el('lot').value);
      if (!(lot >= 2)) { el('results').classList.add('hidden'); return; }
      const row = table.find((r) => lot >= r.min && lot <= r.max);
      if (!row) { el('results').classList.add('hidden'); return; }

      el('r-sample').textContent = row.sample.toLocaleString();
      el('r-ac').textContent = row.ac;
      el('r-re').textContent = row.re;
      el('results').classList.remove('hidden');
    }

    el('lot').addEventListener('input', update);
  </script>
</ToolLayout>
