---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Exponential Growth / Decay Calculator';
const description = 'Project future values using exponential growth and decay models. Free online exponential growth calculator with continuous and discrete compounding.';
const intro = 'Model exponential growth and decay over time. Project future values using initial amount, growth rate, and time period.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is exponential growth?', a: 'Exponential growth occurs when a quantity increases at a rate proportional to its current value. The formula is y = a(1 + r)ᵗ, where a is initial amount, r is growth rate, and t is time.' },
  { q: 'What is exponential decay?', a: 'Exponential decay is the opposite of growth — a quantity decreases at a rate proportional to its current value. The formula is y = a(1 - r)ᵗ, with r positive but subtracted.' },
  { q: 'What is continuous compounding?', a: 'Continuous compounding uses the formula y = ae^(rt), where e is Euler\'s number (≈ 2.71828). This represents growth that compounds at every instant rather than at discrete intervals, common in natural processes.' },
  { q: 'What is the doubling time?', a: 'Doubling time is the time it takes for an exponentially growing quantity to double. It is calculated as t = ln(2) / ln(1 + r) for discrete growth, or t = ln(2) / r for continuous growth.' },
  { q: 'What is the half-life?', a: 'Half-life is the time it takes for an exponentially decaying quantity to halve. It is calculated as t = ln(0.5) / ln(1 - r) for discrete decay, or t = ln(2) / r for continuous decay (using decay constant).' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-3">
      <div class="flex-1 min-w-[120px]">
        <label class="block text-sm font-medium text-slate-700" for="eg-initial">Initial value (a)</label>
        <input id="eg-initial" type="number" step="any" value="1000" placeholder="1000"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="flex-1 min-w-[120px]">
        <label class="block text-sm font-medium text-slate-700" for="eg-rate">Rate (r) as %</label>
        <input id="eg-rate" type="number" step="any" value="5" placeholder="5"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="flex-1 min-w-[120px]">
        <label class="block text-sm font-medium text-slate-700" for="eg-time">Time (t)</label>
        <input id="eg-time" type="number" step="any" value="10" placeholder="10"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      <div id="eg-growth-result" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <span class="text-sm opacity-90">Discrete (annual) =</span>
        <span id="eg-discrete-val" class="ml-2 text-xl font-bold">1,628.89</span>
      </div>
      <div id="eg-continuous-result" class="rounded-xl bg-emerald-600 p-5 text-center text-white">
        <span class="text-sm opacity-90">Continuous =</span>
        <span id="eg-continuous-val" class="ml-2 text-xl font-bold">1,648.72</span>
      </div>
    </div>
    <div id="eg-doubling" class="mt-3 rounded-xl bg-slate-50 p-4 text-center text-sm">
      <span class="text-slate-500">Doubling time:</span>
      <span id="eg-doubling-val" class="ml-1 font-bold text-slate-800">14.2 years</span>
      <span class="ml-3 text-slate-500">| Mode:</span>
      <select id="eg-mode" class="ml-1 rounded-lg border border-slate-300 bg-white px-2 py-1 text-sm outline-none focus:border-indigo-400">
        <option value="growth">Growth (+)</option>
        <option value="decay">Decay (−)</option>
      </select>
    </div>
    <div id="eg-steps" class="mt-3 hidden rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="600" height="360" viewBox="0 0 600 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="eg-title eg-desc">
      <title id="eg-title">Comparison of exponential growth and decay curves over time</title>
      <desc id="eg-desc">Two curves on a coordinate grid. The growth curve (blue) starts at y=1000 and rises steeply upward, reaching about 1629 at time 10. The decay curve (red) starts at y=1000 and falls toward zero, reaching about 599 at time 10.</desc>
      <rect x="60" y="20" width="500" height="300" rx="4" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" />
      <line x1="60" y1="320" x2="560" y2="320" stroke="#94a3b8" stroke-width="1.5" />
      <line x1="100" y1="20" x2="100" y2="320" stroke="#94a3b8" stroke-width="1.5" />
      <path d="M100 290 Q 150 280, 200 260 Q 250 230, 300 200 Q 350 160, 400 120 Q 450 80, 500 50" fill="none" stroke="#6366f1" stroke-width="3" />
      <path d="M100 110 Q 150 120, 200 135 Q 250 155, 300 180 Q 350 200, 400 220 Q 450 240, 500 255" fill="none" stroke="#ef4444" stroke-width="3" stroke-dasharray="6,4" />
      <text x="500" y="45" text-anchor="end" fill="#6366f1" font-size="14" font-weight="bold">Growth (5%)</text>
      <text x="500" y="270" text-anchor="end" fill="#ef4444" font-size="14" font-weight="bold">Decay (5%)</text>
      <text x="100" y="340" text-anchor="middle" fill="#94a3b8" font-size="11">0</text>
      <text x="300" y="340" text-anchor="middle" fill="#94a3b8" font-size="11">5</text>
      <text x="500" y="340" text-anchor="middle" fill="#94a3b8" font-size="11">10</text>
      <text x="55" y="320" text-anchor="end" fill="#94a3b8" font-size="10">0</text>
      <text x="55" y="170" text-anchor="end" fill="#94a3b8" font-size="10">500</text>
      <text x="55" y="60" text-anchor="end" fill="#94a3b8" font-size="10">1000</text>
      <text x="300" y="15" text-anchor="middle" fill="#1e293b" font-size="13">Time</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Exponential growth (blue, solid) and exponential decay (red, dashed) at 5% rate from an initial value of 1,000 over 10 time periods.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How exponential growth and decay work</h2>
    <p class="mt-2 text-slate-600">Exponential growth occurs when a quantity increases by a fixed percentage over each time period. The formula is y = a(1 + r)ᵗ, where a is the initial value, r is the growth rate (as a decimal), and t is the number of time periods. For decay, the formula is y = a(1 - r)ᵗ, where the quantity decreases by a fixed percentage each period.</p>
    <p class="mt-3 text-slate-600">The key characteristic of exponential growth is that the rate of increase accelerates over time — the larger the quantity becomes, the faster it grows. This snowball effect is why exponential growth is often described as "compound growth." In contrast, exponential decay approaches zero but never quite reaches it — there are always traces remaining, which is why radioactive decay half-lives are measurable but complete decay is technically infinite.</p>
    <p class="mt-3 text-slate-600">Continuous compounding uses the natural exponential function y = ae^(rt). This model assumes that growth happens at every instant rather than at discrete intervals (like annually or monthly). Continuous growth is the natural model for many physical and biological processes, including population growth, radioactive decay, and bacterial reproduction.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Discrete model</h3>
        <p class="mt-1 font-mono text-lg font-bold text-indigo-700">y = a(1 &plusmn; r)<sup>t</sup></p>
        <p class="mt-2 text-sm text-slate-600">Use +r for growth, -r for decay. This models annual or periodic compounding like interest payments or population censuses.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Continuous model</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">y = ae<sup>rt</sup></p>
        <p class="mt-2 text-sm text-slate-600">For growth; use y = ae^(-rt) for decay. This models natural processes like radioactive decay, bacterial growth, and continuously compounded interest.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: Investment growth</h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>Initial investment = $1,000, Annual return = 5%, Time = 10 years</p>
        <p>Discrete (annual compounding): y = 1000(1 + 0.05)¹⁰ = 1000 × 1.05¹⁰</p>
        <p>1.05¹⁰ = 1.62889..., so y = 1000 × 1.62889 = $1,628.89</p>
        <p>Continuous compounding: y = 1000 × e^(0.05 × 10) = 1000 × e^0.5</p>
        <p>e^0.5 = 1.64872..., so y = 1000 × 1.64872 = $1,648.72</p>
        <p class="font-semibold text-emerald-700">The continuous model yields about $20 more over 10 years because growth is compounded at every instant rather than once per year.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Investors</h3>
      <p class="mt-1 text-sm text-slate-600">Compound interest follows exponential growth. The Rule of 72 says divide 72 by the interest rate to estimate doubling time. At 5%, money doubles in approximately 72/5 = 14.4 years (close to the exact value of 14.2 years).</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4CA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">Radioactive decay follows exponential decay with a characteristic half-life. Carbon-14 dating, medical isotope decay, and nuclear waste management all use exponential decay models. The decay constant λ = ln(2) / half-life.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F9EC;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Biologists</h3>
      <p class="mt-1 text-sm text-slate-600">Bacterial colonies, viral spread, and cell division follow exponential growth under ideal conditions. Population dynamics, drug clearance from the bloodstream, and enzyme kinetics all use exponential models extensively.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Epidemiologists</h3>
      <p class="mt-1 text-sm text-slate-600">Infectious disease spread follows exponential growth in the early stages: the number of infected people doubles at regular intervals. The basic reproduction number R₀ determines whether an outbreak grows (R₀ > 1) or dies out (R₀ < 1).</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the exponential calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter parameters</h3>
        <p class="mt-1 text-sm text-slate-600">Type the initial value, growth/decay rate (as a percentage), and the time period. Select "Growth (+)" or "Decay (−)" mode.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Compare models</h3>
        <p class="mt-1 text-sm text-slate-600">Both discrete and continuous results are shown. The discrete model assumes periodic compounding; the continuous model assumes instantaneous compounding.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check doubling/half-life</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator shows the doubling time (for growth) or half-life (for decay), giving you insight into the speed of change.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for exponential modeling</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">The Rule of 72</h3>
        <p class="mt-1 text-sm text-slate-600">For quick mental estimates of doubling time, divide 72 by the growth rate percentage. At 8% growth: 72/8 = 9 years (actual is 9.01). At 12%: 72/12 = 6 years (actual is 6.12). The rule is most accurate for rates between 6% and 10%.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Units must be consistent</h3>
        <p class="mt-1 text-sm text-slate-600">Ensure the time unit matches the rate period. If the rate is annual (5% per year), time must be in years. A monthly rate requires time in months. Mixing units (annual rate with monthly time) produces incorrect results. The calculator assumes rate and time share the same unit.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Exponential growth is not sustainable forever</h3>
        <p class="mt-1 text-sm text-slate-600">In the real world, exponential growth eventually hits constraints: limited resources, space, or market saturation. Logistic growth models account for carrying capacity. Use exponential models for short-to-medium term projections, but be aware of limitations for long-range forecasting.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">The difference between discrete and continuous</h3>
        <p class="mt-1 text-sm text-slate-600">As the compounding frequency increases (annual → monthly → daily → continuous), the final value approaches the continuous limit. The continuous model gives the maximum possible growth for a given rate. For most practical purposes, daily compounding is very close to continuous.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/compound-interest" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4B0;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Compound Interest Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate compound interest with different compounding frequencies.</p>
      </a>
      <a href="/tools/natural-log-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4CA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Natural Log Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate ln(x) and apply the change-of-base formula.</p>
      </a>
      <a href="/tools/exponent-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4D0;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Exponent Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate x raised to any power for exponent computations.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const egInitial = document.getElementById('eg-initial');
    const egRate = document.getElementById('eg-rate');
    const egTime = document.getElementById('eg-time');
    const egMode = document.getElementById('eg-mode');
    const egDiscreteVal = document.getElementById('eg-discrete-val');
    const egContinuousVal = document.getElementById('eg-continuous-val');
    const egDoublingVal = document.getElementById('eg-doubling-val');
    const egSteps = document.getElementById('eg-steps');

    function calculate() {
      const a = parseFloat(egInitial.value);
      const rPct = parseFloat(egRate.value);
      const t = parseFloat(egTime.value);
      const isDecay = egMode.value === 'decay';

      if (isNaN(a) || isNaN(rPct) || isNaN(t)) {
        egDiscreteVal.textContent = '—';
        egContinuousVal.textContent = '—';
        egDoublingVal.textContent = '—';
        egSteps.classList.add('hidden');
        return;
      }

      const r = rPct / 100;
      const sign = isDecay ? -1 : 1;

      const discrete = a * Math.pow(1 + sign * r, t);
      const continuous = a * Math.pow(Math.E, sign * r * t);

      egDiscreteVal.textContent = discrete.toLocaleString(undefined, { maximumFractionDigits: 2 });
      egContinuousVal.textContent = continuous.toLocaleString(undefined, { maximumFractionDigits: 2 });

      if (!isDecay) {
        const doubling = r > 0 ? Math.log(2) / Math.log(1 + r) : NaN;
        egDoublingVal.textContent = isNaN(doubling) ? '—' : `${doubling.toFixed(1)} years`;
      } else {
        const halfLife = r > 0 ? Math.log(0.5) / Math.log(1 - r) : NaN;
        egDoublingVal.textContent = isNaN(halfLife) ? '—' : `${halfLife.toFixed(1)} years`;
      }

      let stepsHtml = `<p class="font-semibold text-indigo-700">${isDecay ? 'Decay' : 'Growth'} calculation:</p>`;
      stepsHtml += `<p>${isDecay ? 'Decay' : 'Growth'} formula: y = a(1 ${isDecay ? '−' : '+'} r)<sup>t</sup></p>`;
      stepsHtml += `<p>y = ${a.toLocaleString()} × (1 ${isDecay ? '−' : '+'} ${r})<sup>${t.toLocaleString()}</sup></p>`;
      stepsHtml += `<p>y = ${a.toLocaleString()} × ${(1 + sign * r).toFixed(4)}<sup>${t.toLocaleString()}</sup></p>`;
      stepsHtml += `<p class="mt-1 font-semibold text-emerald-700">Discrete result: ${discrete.toLocaleString(undefined, { maximumFractionDigits: 2 })}</p>`;
      stepsHtml += `<p class="mt-1">Continuous formula: y = ae<sup>${isDecay ? '−' : ''}rt</sup></p>`;
      stepsHtml += `<p>y = ${a.toLocaleString()} × e<sup>${isDecay ? '−' : ''}(${r})(${t.toLocaleString()})</sup></p>`;
      stepsHtml += `<p class="font-semibold text-emerald-700">Continuous result: ${continuous.toLocaleString(undefined, { maximumFractionDigits: 2 })}</p>`;

      if (!isDecay && r > 0) {
        const doubling = Math.log(2) / Math.log(1 + r);
        stepsHtml += `<p class="mt-1 text-xs text-slate-400">Doubling time: ln(2)/ln(1 + ${r}) = ${doubling.toFixed(2)} years</p>`;
      } else if (isDecay && r > 0) {
        const halfLife = Math.log(0.5) / Math.log(1 - r);
        stepsHtml += `<p class="mt-1 text-xs text-slate-400">Half-life: ln(0.5)/ln(1 - ${r}) = ${halfLife.toFixed(2)} years</p>`;
      }

      egSteps.innerHTML = stepsHtml;
      egSteps.classList.remove('hidden');
    }

    egInitial.addEventListener('input', calculate);
    egRate.addEventListener('input', calculate);
    egTime.addEventListener('input', calculate);
    egMode.addEventListener('change', calculate);
    calculate();
  </script>
</ToolLayout>
