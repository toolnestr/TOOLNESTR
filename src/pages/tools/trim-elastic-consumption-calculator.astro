---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Trim/Elastic Consumption Calculator';
const description = 'Calculate total trim or elastic needed for a production run from per-garment consumption, order quantity, and waste allowance.';
const intro = 'Calculate total trim or elastic needed for a production run from per-garment usage and order quantity.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What counts as "trim" in production?', a: 'Trim refers to any non-fabric material used in a garment beyond the main shell — elastic, drawcord, twill tape, piping, ribbing, and similar components — as distinct from the main body fabric itself.' },
  { q: 'How much waste allowance should I use for a production run?', a: 'A 3-5% waste allowance is common for straightforward trims like elastic and drawcord, covering cutting waste, splicing, and minor defects; increase it for trims that are harder to splice invisibly or that come from rolls with more frequent flaws.' },
  { q: 'Does this account for different sizes in a size run?', a: 'This calculator uses one per-garment consumption figure; if trim usage varies significantly across sizes (like elastic length scaling with waistband size), run this calculation separately for each size in the order and sum the totals.' },
  { q: 'How do I convert the total to purchase order units?', a: 'Trim is often purchased by the roll, cone, or a fixed length increment — divide your total length needed by the length per roll/cone to find how many units to order, rounding up to the next whole unit.' },
];
const howTo = {
  name: 'How to calculate trim consumption for a production run',
  steps: [
    { name: 'Enter per-garment trim length', text: 'Enter how much trim one garment uses, in inches.' },
    { name: 'Enter order quantity', text: 'Enter the total number of garments in the production run.' },
    { name: 'Enter waste allowance', text: 'Enter a waste percentage to cover cutting loss and splicing.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Trim per garment (in)</span>
        <input id="perGarment" type="number" step="any" placeholder="e.g. 26" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Order quantity</span>
        <input id="qty" type="number" step="1" placeholder="e.g. 500" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waste allowance (%)</span>
        <input id="waste" type="number" step="any" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total trim needed</div>
        <div id="r-total" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Base length (no waste)</div><div id="r-base" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Waste added</div><div id="r-waste" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tec-title tec-desc">
      <title id="tec-title">Single garment trim multiplied out to a production roll</title>
      <desc id="tec-desc">A short trim strip representing one garment's usage, multiplied into a large roll representing total production consumption</desc>
      <rect x="100" y="80" width="80" height="16" rx="8" fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      <text x="140" y="115" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">1 garment</text>
      <path d="M280 88 L340 88" stroke="#94a3b8" stroke-width="2" marker-end="url(#arrow2)" />
      <text x="310" y="75" text-anchor="middle" font-size="11" fill="#94a3b8" font-family="system-ui,sans-serif">× qty</text>
      <ellipse cx="480" cy="88" rx="30" ry="60" fill="none" stroke="#c026d3" stroke-width="6" />
      <text x="480" y="165" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Total roll needed</text>
      <defs><marker id="arrow2" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6 Z" fill="#94a3b8" /></marker></defs>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Total trim needed scales per-garment usage by order quantity, plus waste</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How production trim consumption is calculated</h2>
    <p class="mt-2 text-slate-600">
      This calculator multiplies the trim length used by a single garment by the total order quantity to find the base length needed for the entire run, then adds a waste allowance percentage on top to cover cutting loss, splicing between rolls, and minor material defects that get discarded during production.
    </p>
    <p class="mt-3 text-slate-600">
      This same base-times-quantity-plus-waste structure applies to elastic, drawcord, piping, twill tape, or any other trim purchased and consumed per garment — only the per-garment length figure changes between different trim types and garment styles.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows standard apparel production planning methodology for scaling per-unit material consumption to full order quantities.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A waistband elastic order for 500 units, using 26 inches per garment, with a 4% waste allowance.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Base length:</span> <span class="text-slate-600">26 × 500 = 13,000 in</span></div>
        <div><span class="font-medium text-slate-700">With 4% waste:</span> <span class="text-slate-600">13,000 × 1.04 = 13,520 in</span></div>
        <div><span class="font-medium text-slate-700">In yards:</span> <span class="text-slate-600">13,520 ÷ 36 ≈ <strong>375.6 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Small apparel brands placing their first bulk trim order with a manufacturer or supplier need this exact calculation to avoid under-ordering, which can delay a production run while waiting for a reorder, or over-ordering, which ties up cash in excess inventory that may not match a future style's trim needs.
    </p>
    <p class="mt-3 text-slate-600">
      Sourcing teams comparing suppliers who sell trim in different roll lengths use this total-length figure as the common basis for comparison, converting each supplier's roll size into "how many rolls does this order actually require" before comparing total cost between options.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Ordering the exact calculated amount with no buffer is fine for a first production run." <strong class="text-slate-900">Risky.</strong> Real-world cutting waste, splicing losses, and quality rejects almost always mean the exact theoretical amount falls short — a waste allowance is standard practice, not overcautious padding.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Per-garment trim consumption is identical across all sizes in a size run." <strong class="text-slate-900">Often not.</strong> Elastic and drawcord length frequently scale with garment size, so a single flat per-garment figure across an entire size run can under- or over-estimate needs for the largest and smallest sizes specifically.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/elastic-length-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Elastic Length Calculator</a>
      <a href="/tools/fabric-waste-overrun-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Waste & Overrun Calculator</a>
      <a href="/tools/garment-costing-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Garment Manufacturing/Costing Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const perGarment = parseFloat(el('perGarment').value);
      const qty = parseFloat(el('qty').value);
      const waste = parseFloat(el('waste').value) || 0;
      if (!perGarment || !qty || perGarment <= 0 || qty <= 0) { el('results').classList.add('hidden'); return; }
      const base = perGarment * qty;
      const wasteAmount = base * (waste / 100);
      const total = base + wasteAmount;

      el('r-base').textContent = (base / 36).toFixed(1) + ' yd';
      el('r-waste').textContent = (wasteAmount / 36).toFixed(1) + ' yd';
      el('r-total').textContent = (total / 36).toFixed(1) + ' yd';
      el('results').classList.remove('hidden');
    }

    ['perGarment', 'qty', 'waste'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
