---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'QR Code Generator';
const description = 'Generate QR codes from any URL or text with custom colors and sizes. Download as PNG. All in your browser.';
const intro = 'Generate QR codes from any URL or text and download as PNG.';
const category = { id: 'security', name: 'Security Tools' };
const seoTitle = 'QR Code Generator — Create Custom QR Codes Online Free';
const seoDesc = 'Generate QR codes from any URL or text with custom colors and sizes. Download as PNG. All in your browser.';
const faqs = [
  { q: 'What is a QR code?', a: 'Quick Response code — a 2D barcode that can be scanned by smartphones to open URLs or display text.' },
  { q: 'Is there a size limit?', a: 'QR codes can hold up to 4296 alphanumeric characters, but larger data creates denser codes.' },
  { q: 'Can I change the color?', a: 'Yes — you can customize the foreground and background colors.' },
  { q: 'Do QR codes expire?', a: 'If the code contains a URL, it depends on whether the URL stays active. The QR code itself never expires.' },
];
---

<ToolLayout title={seoTitle} description={seoDesc} intro={intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="space-y-4">
      <div>
        <label class="text-sm font-medium text-slate-700" for="qr-input">Content (URL or text)</label>
        <textarea id="qr-input" rows="3" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" placeholder="https://example.com or any text">https://example.com</textarea>
      </div>

      <div class="flex flex-wrap gap-4">
        <div>
          <label class="text-sm font-medium text-slate-700" for="fg-color">Foreground</label>
          <input id="fg-color" type="color" value="#000000" class="mt-1 block h-9 w-14 cursor-pointer rounded border border-slate-300" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="bg-color">Background</label>
          <input id="bg-color" type="color" value="#ffffff" class="mt-1 block h-9 w-14 cursor-pointer rounded border border-slate-300" />
        </div>
        <div class="grow">
          <label class="text-sm font-medium text-slate-700" for="qr-size">Size: <span id="size-label">256</span>px</label>
          <input id="qr-size" type="range" min="128" max="512" value="256" step="1" class="mt-1 w-full" />
        </div>
      </div>

      <button id="generate-btn" class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Generate QR Code</button>
    </div>

    <div id="canvas-container" class="mt-6 flex flex-col items-center gap-4">
      <canvas id="qr-canvas"></canvas>
      <a id="download-btn" href="#" download="qrcode.png" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Download as PNG</a>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How QR codes work</h2>
    <p class="mt-2 text-slate-600">A QR (Quick Response) code is a two-dimensional barcode that encodes data in a grid of black and white squares. Unlike traditional one-dimensional barcodes that store data only horizontally, QR codes store data both horizontally and vertically, allowing them to hold significantly more information in a compact space. The three corner squares (finders) allow scanners to detect the code's orientation; smaller alignment and timing patterns help the scanner map the grid even when the code is skewed or partially damaged.</p>
    <p class="mt-3 text-slate-600">QR codes use Reed-Solomon error correction, a mathematical technique that adds redundant data to the code. This allows the scanner to reconstruct the original data even if up to 30% of the code is damaged or obscured. There are four error correction levels: L (7% recovery), M (15%), Q (25%), and H (30%). Higher correction levels produce denser codes because more redundant data must be stored, but they are considerably more robust against damage, logos in the center, or partial obstruction.</p>

    <!-- SVG diagram: QR code being scanned by phone, branching data flow -->
    <div class="mt-6 flex justify-center">
      <svg viewBox="0 0 600 300" class="w-full max-w-xl rounded-xl border border-slate-200 bg-white p-4" xmlns="http://www.w3.org/2000/svg">
        <!-- QR code grid -->
        <rect x="30" y="30" width="140" height="140" fill="white" stroke="#333" stroke-width="1.5" rx="4" />
        <!-- Finder patterns -->
        <rect x="36" y="36" width="36" height="36" fill="black" rx="3" />
        <rect x="44" y="44" width="20" height="20" fill="white" />
        <rect x="128" y="36" width="36" height="36" fill="black" rx="3" />
        <rect x="136" y="44" width="20" height="20" fill="white" />
        <rect x="36" y="128" width="36" height="36" fill="black" rx="3" />
        <rect x="44" y="136" width="20" height="20" fill="white" />
        <!-- Data modules (sample) -->
        <rect x="80" y="36" width="10" height="10" fill="black" />
        <rect x="98" y="36" width="10" height="10" fill="black" />
        <rect x="116" y="36" width="10" height="10" fill="white" />
        <rect x="80" y="54" width="10" height="10" fill="white" />
        <rect x="98" y="54" width="10" height="10" fill="white" />
        <rect x="116" y="54" width="10" height="10" fill="black" />
        <rect x="36" y="80" width="10" height="10" fill="black" />
        <rect x="54" y="80" width="10" height="10" fill="white" />
        <rect x="72" y="80" width="10" height="10" fill="black" />
        <rect x="90" y="80" width="10" height="10" fill="white" />
        <rect x="108" y="80" width="10" height="10" fill="black" />
        <rect x="54" y="98" width="10" height="10" fill="black" />
        <rect x="72" y="98" width="10" height="10" fill="white" />
        <rect x="90" y="98" width="10" height="10" fill="black" />
        <rect x="108" y="98" width="10" height="10" fill="black" />
        <rect x="126" y="54" width="10" height="10" fill="white" />
        <rect x="126" y="72" width="10" height="10" fill="black" />
        <rect x="126" y="90" width="10" height="10" fill="white" />
        <!-- Timing patterns -->
        <rect x="36" y="116" width="10" height="10" fill="black" />
        <rect x="54" y="116" width="10" height="10" fill="white" />
        <rect x="72" y="116" width="10" height="10" fill="black" />
        <rect x="90" y="116" width="10" height="10" fill="white" />
        <rect x="108" y="116" width="10" height="10" fill="black" />
        <rect x="126" y="116" width="10" height="10" fill="white" />
        <!-- Phone scanning -->
        <rect x="220" y="50" width="60" height="120" fill="#1e293b" rx="10" />
        <rect x="226" y="62" width="48" height="96" fill="#334155" rx="4" />
        <circle cx="250" cy="104" r="16" fill="white" opacity="0.9" />
        <line x1="242" y1="104" x2="258" y2="104" stroke="#334155" stroke-width="2" />
        <line x1="250" y1="96" x2="250" y2="112" stroke="#334155" stroke-width="2" />
        <!-- Scan beam from phone to QR -->
        <line x1="226" y1="110" x2="170" y2="100" stroke="#6366f1" stroke-width="2" stroke-dasharray="4,3" marker-end="url(#arrow)" />
        <defs>
          <marker id="arrow" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
            <path d="M0,0 L8,3 L0,6" fill="#6366f1" />
          </marker>
        </defs>
        <!-- Data flow branches -->
        <text x="310" y="70" font-size="11" fill="#64748b" font-family="sans-serif">Scanning</text>
        <line x1="280" y1="100" x2="340" y2="70" stroke="#6366f1" stroke-width="1.5" />
        <!-- Branch: Error correction -->
        <rect x="340" y="55" width="14" height="14" rx="2" fill="#10b981" />
        <text x="358" y="67" font-size="10" fill="#64748b" font-family="sans-serif">RS error correction</text>
        <!-- Branch: Decode -->
        <line x1="280" y1="104" x2="340" y2="130" stroke="#6366f1" stroke-width="1.5" />
        <rect x="340" y="115" width="14" height="14" rx="2" fill="#6366f1" />
        <text x="358" y="127" font-size="10" fill="#64748b" font-family="sans-serif">Decode modules → binary</text>
        <!-- Branch: Output -->
        <line x1="280" y1="108" x2="340" y2="190" stroke="#6366f1" stroke-width="1.5" />
        <rect x="340" y="175" width="14" height="14" rx="2" fill="#f59e0b" />
        <text x="358" y="187" font-size="10" fill="#64748b" font-family="sans-serif">Output: URL or text</text>
        <!-- Phone label -->
        <text x="220" y="190" font-size="10" fill="#94a3b8" font-family="sans-serif">Smartphone camera</text>
        <!-- QR label -->
        <text x="40" y="190" font-size="10" fill="#94a3b8" font-family="sans-serif">QR code</text>
      </svg>
    </div>

    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Input:</span> <span class="text-slate-600 font-mono text-xs">https://example.com</span></div>
        <div><span class="font-medium text-slate-700">Error correction:</span> <span class="text-slate-600">M (15%)</span></div>
        <div><span class="font-medium text-slate-700">Data modules:</span> <span class="text-slate-600">21×21 grid (version 1) for short URLs</span></div>
        <div><span class="font-medium text-slate-700">Output:</span> <span class="text-slate-600">Scan → open URL in browser</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4F1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sharing URLs on print media</h3>
      <p class="mt-1 text-sm text-slate-600">QR codes on posters, flyers, business cards, and product packaging allow readers to instantly open a URL by scanning with their phone camera — no typing required. The seamlessness of print-to-digital makes QR codes ideal for marketing campaigns, restaurant menus, event registration, and real estate listings where driving traffic to a landing page is the primary goal.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4B3;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Contactless payments</h3>
      <p class="mt-1 text-sm text-slate-600">QR codes power payment systems like UPI (India), WeChat Pay, and many point-of-sale solutions worldwide. The customer scans a static or dynamic QR code displayed at the counter, enters the amount, and completes the transaction. The code encodes a payment URI that includes the merchant ID and transaction details, making the process fast, secure, and touch-free.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4F6;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Wi-Fi network sharing</h3>
      <p class="mt-1 text-sm text-slate-600">A QR code can encode Wi-Fi credentials in the format `WIFI:T:WPA;S:networkname;P:password;;`. Guests scan the code to join the network without typing a long password. Many modern smartphones detect this format natively and prompt the user to connect automatically. This is increasingly common in hotels, cafes, co-working spaces, and smart home setups.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4E6;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Product tracking</h3>
      <p class="mt-1 text-sm text-slate-600">Supply chain and logistics operations use QR codes to track inventory, shipments, and assets. Each item or pallet receives a unique QR code that encodes a serial number or URL to a tracking portal. Scanning at each checkpoint updates the system with the item's location and status. QR codes are preferred over RFID in some contexts because they are printable and require no specialized scanning hardware beyond a smartphone camera.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The evolution of QR codes</h2>
    <p class="mt-3 text-slate-600">QR codes were invented in 1994 by Denso Wave, a Toyota subsidiary, to track automotive parts during manufacturing. The standard was deliberately left open — Denso Wave chose not to exercise its patent rights — which enabled widespread adoption. Early use was mostly industrial, but smartphones with built-in cameras turned QR codes into a consumer-facing technology. The COVID-19 pandemic accelerated adoption dramatically as contactless interactions became essential for restaurant menus, check-in systems, and payment.</p>
    <p class="mt-3 text-slate-600">There are 40 versions of the QR code standard, ranging from version 1 (21×21 modules, 25 alphanumeric characters) to version 40 (177×177 modules, 4296 alphanumeric characters). Each version adds four modules per side. The version is encoded in the code itself so scanners can adapt automatically. Most consumer QR codes use version 2 through 6, balancing data capacity with scan reliability at typical printing sizes.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">QR code structure explained</h2>
    <p class="mt-3 text-slate-600">A QR code consists of several functional regions. The finder patterns — three identical squares in the corners — allow the scanner to detect the code's position and orientation regardless of the angle. The timing patterns (alternating black and white modules) help the scanner synchronize data reading row by row. The alignment patterns (smaller squares) assist scanning when the code is skewed or curved. Data is stored in the remaining modules, organized in interleaved blocks for error correction resilience.</p>
    <p class="mt-3 text-slate-600">The Reed-Solomon error correction algorithm works by treating the encoded data as a polynomial, then generating additional "parity" coefficients that encode the same information in a redundant form. When a code is damaged, the scanner uses both surviving data and parity coefficients to reconstruct the original polynomial. Level H (30% recovery) adds roughly twice as much redundant data as Level L (7% recovery), which is why denser codes result from higher error correction levels. The encoding process also includes data masking — a step that rearranges modules to avoid long runs of same-colored modules that could confuse the scanner.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Practical tips for QR codes</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always test your codes before printing</h3>
        <p class="mt-1 text-sm text-slate-600">Generate the QR code, then scan it with multiple devices (iOS, Android, dedicated scanners) to verify it works correctly. A code that looks right may still fail to scan due to contrast issues, incorrect encoding, or a broken URL. Test at the actual print size and under various lighting conditions.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Leave a quiet zone border</h3>
        <p class="mt-1 text-sm text-slate-600">The quiet zone is a blank margin of at least four modules wide around the entire QR code. Without it, scanners may misinterpret nearby text or graphics as part of the code, causing read failures. This is the most common design mistake when embedding QR codes into complex layouts or colored backgrounds.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use higher error correction for printed codes</h3>
        <p class="mt-1 text-sm text-slate-600">Level H (30%) is recommended for codes printed on curved surfaces, fabric, or packaging where damage is likely. Level M (15%) works well for most print-on-paper use cases. Level L (7%) is acceptable only for clean, digital-only display where the code will not be physically stressed.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Mind your contrast</h3>
        <p class="mt-1 text-sm text-slate-600">Dark modules must be significantly darker than light modules for reliable scanning. Avoid light grays for the foreground or dark tints for the background. The best contrast ratio is achieved with pure black on pure white, but high-contrast color combinations (dark blue on light yellow, etc.) can also work if tested thoroughly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this QR code generator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your content</h3>
        <p class="mt-1 text-sm text-slate-600">Type or paste any URL or text into the textarea. The content will be encoded directly into the QR code with no server interaction.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Customize colors and size</h3>
        <p class="mt-1 text-sm text-slate-600">Choose foreground and background colors using the color pickers. Adjust the size from 128 to 512 pixels for your desired resolution. Larger sizes export cleaner for print.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Generate and download</h3>
        <p class="mt-1 text-sm text-slate-600">Click "Generate QR Code" to render the code on the canvas, then click "Download as PNG" to save it. Everything runs in your browser — nothing is uploaded anywhere.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/base64" class="flex items-center gap-3 rounded-lg border border-slate-100 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-indigo-50 hover:text-indigo-700">Base64 Encoder</a>
      <a href="/tools/morse-code-converter" class="flex items-center gap-3 rounded-lg border border-slate-100 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-indigo-50 hover:text-indigo-700">Morse Code Converter</a>
      <a href="/tools/password-generator" class="flex items-center gap-3 rounded-lg border border-slate-100 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-indigo-50 hover:text-indigo-700">Password Generator</a>
    </div>
  </section>

  <script type="module">
    import QRCode from 'https://esm.sh/qrcode@1.5.4';

    const canvas = document.getElementById('qr-canvas');
    const input = document.getElementById('qr-input');
    const fgColor = document.getElementById('fg-color');
    const bgColor = document.getElementById('bg-color');
    const sizeSlider = document.getElementById('qr-size');
    const sizeLabel = document.getElementById('size-label');
    const generateBtn = document.getElementById('generate-btn');
    const downloadBtn = document.getElementById('download-btn');

    function generateQR() {
      const text = input.value.trim();
      if (!text) return;
      const size = parseInt(sizeSlider.value, 10);
      const options = {
        width: size,
        color: {
          dark: fgColor.value,
          light: bgColor.value,
        },
      };
      QRCode.toCanvas(canvas, text, options, (err) => {
        if (err) console.error(err);
      });
    }

    sizeSlider.addEventListener('input', () => {
      sizeLabel.textContent = sizeSlider.value;
    });

    generateBtn.addEventListener('click', generateQR);

    downloadBtn.addEventListener('click', (e) => {
      if (!canvas.querySelector('img') && !canvas.getContext) return;
      canvas.toBlob((blob) => {
        if (!blob) return;
        const url = URL.createObjectURL(blob);
        downloadBtn.href = url;
      });
    });

    generateQR();
  </script>
</ToolLayout>
