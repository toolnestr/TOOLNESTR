---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Percentage Calculator';
const description =
  'Free percentage calculator. Work out X% of a number, what percent one number is of ' +
  'another, and the percentage increase or decrease between two numbers — instantly.';
const intro =
  'Three quick percentage tools in one. Fill in any of the calculators below and the answer appears instantly.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'How do I find a percentage of a number?', a: 'Multiply the number by the percentage and divide by 100. For example, 20% of 150 is 150 × 20 ÷ 100 = 30. The first calculator does this for you.' },
  { q: 'How do I calculate percentage increase?', a: 'Subtract the old value from the new value, divide by the old value, then multiply by 100. The third calculator handles increases and decreases automatically.' },
  { q: 'What is the difference between the three calculators?', a: 'The first finds a percentage of a number, the second finds what percent one number is of another, and the third finds the percentage change between two numbers.' },
  { q: 'Why isn\'t a 20% increase then a 20% decrease back to the start?', a: 'Each percentage applies to a different base. +20% of 100 is 120, but −20% of 120 is 96 — not 100. So equal percentage moves up and down do not cancel out.' },
  { q: 'How do I find the original price before a percentage was added?', a: 'Divide the final amount by (1 + percentage/100). For example, if a price is 120 after a 20% increase, the original was 120 ÷ 1.20 = 100.' },
  { q: 'Is it private?', a: 'Yes — all calculations happen in your browser.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 space-y-4">
    <!-- Mode 1 -->
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">What is X% of a number?</h2>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-slate-700">
        <input id="a1" type="number" step="any" placeholder="20" class="w-24 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>% of</span>
        <input id="a2" type="number" step="any" placeholder="150" class="w-28 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>=</span>
        <span id="a-out" class="text-lg font-bold text-indigo-600">—</span>
      </div>
    </div>

    <!-- Mode 2 -->
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">X is what percent of Y?</h2>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-slate-700">
        <input id="b1" type="number" step="any" placeholder="30" class="w-24 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>is what % of</span>
        <input id="b2" type="number" step="any" placeholder="150" class="w-28 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>=</span>
        <span id="b-out" class="text-lg font-bold text-indigo-600">—</span>
      </div>
    </div>

    <!-- Mode 3 -->
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">Percentage increase / decrease</h2>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-slate-700">
        <span>From</span>
        <input id="c1" type="number" step="any" placeholder="80" class="w-24 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>to</span>
        <input id="c2" type="number" step="any" placeholder="100" class="w-24 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>=</span>
        <span id="c-out" class="text-lg font-bold text-indigo-600">—</span>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this percentage calculator</h2>
    <p class="mt-2 text-slate-600">
      Percentages come up constantly — discounts, test scores, tips, statistics and more. This
      calculator bundles the three most common percentage questions into one page so you can get
      an answer in seconds, whichever type of calculation you need.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Pick the calculator that matches your question.</li>
      <li>Type your numbers into the boxes.</li>
      <li>The answer appears instantly as you type.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">How it works (the formula)</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li><strong>X% of Y</strong> = Y × (X ÷ 100)</li>
      <li><strong>X is what % of Y</strong> = (X ÷ Y) × 100</li>
      <li><strong>Percentage change</strong> = (New − Old) ÷ Old × 100</li>
    </ul>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Worked example</h2>
    <p class="mt-2 text-slate-600">
      20% of 150 = 150 × 0.20 = <strong>30</strong>. And a change from 80 to 100 =
      (100 − 80) ÷ 80 × 100 = <strong>+25%</strong>.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Common uses</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Discounts and sale prices</li>
      <li>Tips and service charges</li>
      <li>Test scores and grades</li>
      <li>Profit, growth, and change rates</li>
    </ul>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips &amp; common mistakes</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>A percentage increase followed by the same percentage decrease does <em>not</em> return the original number — each applies to a different base.</li>
      <li>Always divide the change by the <em>original</em> value, not the new one.</li>
    </ul>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/discount-calculator" class="font-medium text-indigo-600 hover:underline">Discount Calculator</a>
      or <a href="/tools/tip-calculator" class="font-medium text-indigo-600 hover:underline">Tip Calculator</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const num = (id) => parseFloat(el(id).value);
    const round = (n) => Math.round(n * 100) / 100;

    function update() {
      const a1 = num('a1'), a2 = num('a2');
      el('a-out').textContent = (!isNaN(a1) && !isNaN(a2)) ? round(a1 * a2 / 100).toLocaleString() : '—';

      const b1 = num('b1'), b2 = num('b2');
      el('b-out').textContent = (!isNaN(b1) && !isNaN(b2) && b2 !== 0) ? round(b1 / b2 * 100) + '%' : '—';

      const c1 = num('c1'), c2 = num('c2');
      if (!isNaN(c1) && !isNaN(c2) && c1 !== 0) {
        const change = round((c2 - c1) / Math.abs(c1) * 100);
        el('c-out').textContent = (change >= 0 ? '+' : '') + change + '%' + (change >= 0 ? ' (increase)' : ' (decrease)');
      } else el('c-out').textContent = '—';
    }

    ['a1', 'a2', 'b1', 'b2', 'c1', 'c2'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
