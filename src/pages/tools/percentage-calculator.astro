---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Percentage Calculator';
const description =
  'Free percentage calculator. Work out X% of a number, what percent one number is of ' +
  'another, and the percentage increase or decrease between two numbers — instantly.';
const intro =
  'Three quick percentage tools in one. Fill in any of the calculators below and the answer appears instantly.';
const category = { id: 'everyday', name: 'Everyday' };
const faqs = [
  { q: 'How do I find a percentage of a number?', a: 'Multiply the number by the percentage and divide by 100. For example, 20% of 150 is 150 x 20 / 100 = 30. The first calculator does this for you.' },
  { q: 'How do I calculate percentage increase?', a: 'Subtract the old value from the new value, divide by the old value, then multiply by 100. The third calculator handles increases and decreases automatically.' },
  { q: 'What is the difference between the three calculators?', a: 'The first finds a percentage of a number, the second finds what percent one number is of another, and the third finds the percentage change between two numbers.' },
  { q: 'Why isnt a 20% increase then a 20% decrease back to the start?', a: 'Each percentage applies to a different base. +20% of 100 is 120, but -20% of 120 is 96 — not 100. So equal percentage moves up and down do not cancel out.' },
  { q: 'How do I find the original price before a percentage was added?', a: 'Divide the final amount by (1 + percentage/100). For example, if a price is 120 after a 20% increase, the original was 120 / 1.20 = 100.' },
  { q: 'Is it private?', a: 'Yes — all calculations happen in your browser.' },
  { q: 'Can percentages be negative?', a: 'A negative percentage typically indicates a decrease. Mode 3 shows increases with a + sign and decreases with a - sign, making it easy to see the direction of change.' },
  { q: 'How do I calculate a percentage difference between two numbers?', a: 'Use Mode 3. Enter the old value first, then the new value. The calculator shows the percentage change, with a + sign for increases and - for decreases.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 space-y-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">What is X% of a number?</h2>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-slate-700">
        <input id="a1" type="number" step="any" placeholder="20" class="w-24 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>% of</span>
        <input id="a2" type="number" step="any" placeholder="150" class="w-28 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>=</span>
        <span id="a-out" class="text-lg font-bold text-indigo-600">—</span>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">X is what percent of Y?</h2>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-slate-700">
        <input id="b1" type="number" step="any" placeholder="30" class="w-24 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>is what % of</span>
        <input id="b2" type="number" step="any" placeholder="150" class="w-28 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>=</span>
        <span id="b-out" class="text-lg font-bold text-indigo-600">—</span>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">Percentage increase / decrease</h2>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-slate-700">
        <span>From</span>
        <input id="c1" type="number" step="any" placeholder="80" class="w-24 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>to</span>
        <input id="c2" type="number" step="any" placeholder="100" class="w-24 rounded-lg border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span>=</span>
        <span id="c-out" class="text-lg font-bold text-indigo-600">—</span>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How percentage calculations work</h2>
    <p class="mt-2 text-slate-600">
      Three fundamental formulas power every percentage scenario you encounter. Understanding these lets you verify any percentage calculation mentally and catch errors before they cost you money.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Mode 1: X% of Y</h3>
        <p class="mt-1 text-sm text-slate-600">Formula: <code>Result = Y × X ÷ 100</code>. Example: 20% of 150 = 150 × 20 ÷ 100 = <strong>30</strong>. Used for tips, tax, discounts, and commissions.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Mode 2: X is what % of Y</h3>
        <p class="mt-1 text-sm text-slate-600">Formula: <code>Result = X ÷ Y × 100</code>. Example: 30 is what % of 150? 30 ÷ 150 × 100 = <strong>20%</strong>. Used for scores, proportions, and comparisons.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Mode 3: % change</h3>
        <p class="mt-1 text-sm text-slate-600">Formula: <code>Result = (New - Old) ÷ |Old| × 100</code>. Example: 80 to 100 = (100-80) ÷ 80 × 100 = <strong>+25%</strong>. Used for growth, inflation, and performance.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: Asymmetric percentage changes</h3>
      <p class="mt-1 text-sm text-slate-600">A $100 item gets a 50% markup: new price = $150. Then it goes on sale at 50% off: $150 × 0.50 = $75. A 50% increase followed by a 50% decrease does NOT return to the original price — this asymmetry is why percentage changes must always be applied carefully.</p>
    </div>
  </section>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 200" width="800" height="200" role="img" aria-labelledby="pct-title pct-desc">
      <title id="pct-title">Percentage Part vs Whole Diagram</title>
      <desc id="pct-desc">A horizontal bar representing 100%, with a colored portion showing a percentage of the whole</desc>
      <rect x="50" y="30" width="700" height="50" rx="6" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1" />
      <rect x="50" y="30" width="280" height="50" rx="6" fill="#6366f1" />
      <rect x="324" y="30" width="426" height="50" rx="6" fill="#e0e7ff" />
      <text x="190" y="59" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="16" font-weight="700">40% Part</text>
      <text x="537" y="59" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="16" font-weight="600">60% Remaining</text>
      <line x1="50" y1="110" x2="750" y2="110" stroke="#cbd5e1" stroke-width="2" />
      <text x="50" y="135" fill="#64748b" font-family="system-ui, sans-serif" font-size="13">0%</text>
      <text x="400" y="135" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="13">100%</text>
      <text x="750" y="135" text-anchor="end" fill="#64748b" font-family="system-ui, sans-serif" font-size="13">100%</text>
      <polygon points="280,100 260,115 300,115" fill="#6366f1" />
      <text x="280" y="95" text-anchor="middle" fill="#6366f1" font-family="system-ui, sans-serif" font-size="12" font-weight="600">40%</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A percentage represents a part of a whole — here 40% of the total bar is highlighted</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why percentages matter in daily life</h2>
    <p class="mt-2 text-slate-600">
      Percentages are the most common mathematical concept you use outside the classroom. From calculating a restaurant tip to understanding interest rates, from exam scores to investment returns — knowing how to work with percentages saves you money and helps you make informed decisions. This calculator handles the three most common questions so you never need pen and paper.
    </p>

    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Restaurant tip (US)</span><span class="text-slate-400">15–20%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Sales tax (varies)</span><span class="text-slate-400">5–25%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:25%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Credit card interest (APR)</span><span class="text-slate-400">18–28%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:28%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Investment return (annual)</span><span class="text-slate-400">5–12%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:12%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Exam pass mark</span><span class="text-slate-400">40–60%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-violet-500" style="width:60%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🛒</span>
      <h3 class="mt-2 font-semibold text-slate-900">Shoppers</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate sale discounts, compare "X% off" vs "Y% more free" offers, and understand true savings. Mode 1 is your go-to.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏦</span>
      <h3 class="mt-2 font-semibold text-slate-900">Finance & Business</h3>
      <p class="mt-1 text-sm text-slate-600">Model growth rates, profit margins, tax calculations and interest. Mode 3 is essential for tracking period-over-period changes.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate exam scores as percentages, work out grade improvements, and check assignment weightings — all essential for academic tracking.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📊</span>
      <h3 class="mt-2 font-semibold text-slate-900">Data Analysts</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly compute proportions, growth rates and relative changes in datasets. Great for sanity-checking numbers before reporting.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the percentage calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick your mode</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the calculator that matches your question — percent of, percent of another, or change.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your numbers</h3>
        <p class="mt-1 text-sm text-slate-600">Type the values into the input fields. The answer updates instantly as you type.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The answer appears in bold. Use the other modes for different types of percentage questions.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Common percentage mistakes to avoid</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Wrong base for percentage change</h3>
        <p class="mt-1 text-sm text-slate-600">Always divide by the original (old) value, not the new value. An increase from 50 to 100 is +100%, not +50%.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Confusing percentage points with percent</h3>
        <p class="mt-1 text-sm text-slate-600">If an interest rate rises from 5% to 7%, that is a 2 percentage point increase but a 40% increase in the rate. These are not the same.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Adding percentages directly</h3>
        <p class="mt-1 text-sm text-slate-600">A 20% discount followed by an extra 10% off is NOT 30% off. The second discount applies to the already-reduced price. Total saving: 28%, not 30%.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use the percentage calculator</h2>
    <p class="mt-2 text-slate-600">
      The percentage calculator handles three of the most common percentage scenarios encountered in daily life. Use Mode 1 (X% of a number) whenever you need to calculate a portion of a total. Shoppers use it to determine sale discounts: 30% off a $120 jacket equals $36 in savings, bringing the final price to $84. Restaurant diners calculate tips by finding 15% or 20% of their pre-tax bill. Homebuyers estimate their down payment by calculating a percentage of the property price.
    </p>
    <p class="mt-3 text-slate-600">
      Mode 2 (X is what percent of Y) is ideal for proportions and comparisons. Students use it to convert test scores into percentages: a score of 42 out of 60 equals 70%. Business analysts calculate market share by dividing a company's revenue by the total market revenue. Fitness enthusiasts track body fat percentage or macronutrient ratios. Investors calculate the percentage of their portfolio allocated to different asset classes.
    </p>
    <p class="mt-3 text-slate-600">
      Mode 3 (percentage increase or decrease) is essential for tracking change over time. Financial analysts measure quarterly revenue growth: revenue rising from $500,000 to $625,000 represents a 25% increase. Homeowners track property value appreciation. Employers calculate salary increase percentages for annual reviews. Economists measure inflation rates by comparing price indices across periods.
    </p>
    <p class="mt-3 text-slate-600">
      The calculator is also useful for verifying manual calculations. When reviewing a bill with a service charge, a tax addition, or a volume discount, quickly entering the numbers into the appropriate mode confirms whether the applied percentage is correct and helps catch billing errors before payment.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Limitations and considerations</h2>
    <p class="mt-2 text-slate-600">
      The percentage calculator is designed for straightforward percentage operations, but there are scenarios where additional nuance is required. The asymmetric nature of percentage change is one of the most commonly misunderstood concepts. A 50% increase followed by a 50% decrease does not return to the original value. This becomes critical in financial contexts: if an investment drops by 20%, it needs a 25% gain just to break even, not 20%. Understanding this asymmetry prevents costly misinterpretation of percentage changes.
    </p>
    <p class="mt-3 text-slate-600">
      Second, the calculator does not handle compound percentages. If you need to apply multiple sequential percentages such as a 10% discount followed by an additional 5% loyalty discount, the total discount is not 15% but 14.5%. Each percentage applies to a progressively smaller base. Similarly, compound interest calculations require iterative or exponential formulas that go beyond simple percentage operations.
    </p>
    <p class="mt-3 text-slate-600">
      Third, percentage points and percent are different concepts. A rise in interest rates from 5% to 7% is a 2 percentage point increase but a 40% increase in the rate itself. Using the wrong terminology can lead to miscommunication in financial discussions, policy debates, and data reporting.
    </p>
    <p class="mt-3 text-slate-600">
      Fourth, Mode 3 requires a non-zero old value. If the old value is zero, the percentage change is mathematically undefined due to division by zero. Additionally, very small old values can produce extremely large percentage changes that may be misleading. Always consider the absolute magnitude alongside the percentage change for a complete picture.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const num = (id) => parseFloat(el(id).value);
    const round = (n) => Math.round(n * 100) / 100;

    function update() {
      const a1 = num('a1'), a2 = num('a2');
      el('a-out').textContent = (!isNaN(a1) && !isNaN(a2)) ? round(a1 * a2 / 100).toLocaleString() : '—';

      const b1 = num('b1'), b2 = num('b2');
      el('b-out').textContent = (!isNaN(b1) && !isNaN(b2) && b2 !== 0) ? round(b1 / b2 * 100) + '%' : '—';

      const c1 = num('c1'), c2 = num('c2');
      if (!isNaN(c1) && !isNaN(c2) && c1 !== 0) {
        const change = round((c2 - c1) / Math.abs(c1) * 100);
        el('c-out').textContent = (change >= 0 ? '+' : '') + change + '%' + (change >= 0 ? ' (increase)' : ' (decrease)');
      } else el('c-out').textContent = '—';
    }

    ['a1', 'a2', 'b1', 'b2', 'c1', 'c2'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
