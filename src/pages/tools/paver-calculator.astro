---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Paver Calculator';
const description = 'Calculate the number of pavers needed for a patio from area and paver size with joint gap.';
const intro = 'Estimate how many pavers you need for a patio, walkway, or driveway project.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'How many pavers are in a square foot?', a: 'Standard 12x12 inch pavers need exactly 1 per sq ft. 6x6 inch pavers need 4 per sq ft. 8x16 inch pavers need 1.125 per sq ft. The exact count depends on the paver size plus the joint gap.' },
  { q: 'What is the standard paver joint gap?', a: 'Most paver installations use a 1/8 to 1/4 inch gap between pavers. The gap is filled with polymeric sand that hardens to lock the pavers in place and prevent weed growth.' },
  { q: 'What size paver is best for a patio?', a: 'Large pavers (12x12, 12x18, or 18x18 inches) create a more modern look with fewer grout lines. Small pavers (6x6 or 6x9 inches) work well for curved patios and traditional patterns. Mixed sizes create a random, Old World appearance.' },
  { q: 'Do I need a base under pavers?', a: 'Yes, a proper base is essential. Excavate 7-9 inches for a driveway or 5-7 inches for a patio. Add 4-6 inches of compacted gravel base and 1 inch of sand bedding. Without a proper base, pavers will settle unevenly.' },
];
const howTo = {
  name: 'How to calculate how many pavers you need',
  steps: [
    { name: 'Measure the area', text: 'Measure the length and width of the patio or walkway in feet.' },
    { name: 'Choose paver size', text: 'Select a common paver size or enter custom dimensions. Set the joint gap and waste percentage.' },
    { name: 'Order your pavers', text: 'Use the total paver count to order from your supplier. Add extra for future repairs.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Patio length (ft)</span>
        <input id="length" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Patio width (ft)</span>
        <input id="width" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Paver length (in)</span>
        <input id="pl" type="number" step="any" placeholder="12" value="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Paver width (in)</span>
        <input id="pw" type="number" step="any" placeholder="12" value="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Joint gap (in)</span>
        <input id="gap" type="number" step="any" placeholder="0.125" value="0.125" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Common paver sizes</span>
      <div class="mt-1 flex flex-wrap gap-2">
        {['6x6', '6x9', '8x16', '12x12', '12x18', '18x18'].map((s) => (
          <button data-p={s} class="paver-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{s}</button>
        ))}
      </div>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Waste (%)</span>
      <input id="waste" type="number" min="0" step="1" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Pavers needed</div>
        <div id="r-pavers" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-waste" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Patio area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Pavers per sq ft</div><div id="r-ppsf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Total with waste</div><div id="r-total" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="paver-title paver-desc">
      <title id="paver-title">Paver patio grid diagram</title>
      <desc id="paver-desc">A patio area shown with a grid pattern of square pavers with small joint gaps between them</desc>
      <rect x="80" y="60" width="560" height="240" fill="#f8fafc" stroke="#cbd5e1" stroke-width="2" rx="4" />
      <g fill="#d1d5db" stroke="#9ca3af" stroke-width="1">
        <rect x="85" y="65" width="70" height="70" rx="2" />
        <rect x="160" y="65" width="70" height="70" rx="2" />
        <rect x="235" y="65" width="70" height="70" rx="2" />
        <rect x="310" y="65" width="70" height="70" rx="2" />
        <rect x="385" y="65" width="70" height="70" rx="2" />
        <rect x="460" y="65" width="70" height="70" rx="2" />
        <rect x="535" y="65" width="70" height="70" rx="2" />
        <rect x="122.5" y="140" width="70" height="70" rx="2" />
        <rect x="197.5" y="140" width="70" height="70" rx="2" />
        <rect x="272.5" y="140" width="70" height="70" rx="2" />
        <rect x="347.5" y="140" width="70" height="70" rx="2" />
        <rect x="422.5" y="140" width="70" height="70" rx="2" />
        <rect x="497.5" y="140" width="70" height="70" rx="2" />
        <rect x="85" y="215" width="70" height="70" rx="2" />
        <rect x="160" y="215" width="70" height="70" rx="2" />
        <rect x="235" y="215" width="70" height="70" rx="2" />
        <rect x="310" y="215" width="70" height="70" rx="2" />
        <rect x="385" y="215" width="70" height="70" rx="2" />
        <rect x="460" y="215" width="70" height="70" rx="2" />
        <rect x="535" y="215" width="70" height="70" rx="2" />
      </g>
      <g fill="#b91c1c" opacity="0.4">
        <rect x="120" y="65" width="5" height="70" rx="1" />
        <rect x="85" y="135" width="145" height="5" rx="1" />
      </g>
      <text x="360" y="340" text-anchor="middle" font-size="13" fill="#64748b" font-family="system-ui,sans-serif">Running bond paver pattern with uniform joint gaps between each paver</text>
      <text x="105" y="105" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Paver</text>
      <text x="125" y="95" text-anchor="start" font-size="9" fill="#991b1b" font-family="system-ui,sans-serif">Joint gap</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Patio pavers laid in a grid pattern with consistent joint gaps between each paver</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the paver calculator works</h2>
    <p class="mt-2 text-slate-600">
      The paver calculator estimates the number of pavers needed for a rectangular patio or walkway. It calculates the area, determines how many pavers fit per square foot based on the paver size and joint gap, and multiplies to get the total paver count. A waste factor is added for cuts, breakage, and mistakes.
    </p>
    <p class="mt-3 text-slate-600">
      Pavers come in many sizes and shapes. The most common is the 12x12 inch square paver. Rectangular pavers (6x9, 8x16) create interesting patterns like running bond or herringbone. The joint gap between pavers affects the total count — a larger gap means fewer pavers per square foot. Polymeric sand fills these gaps and locks the pavers together.
    </p>
    <p class="mt-3 text-xs text-slate-400">Base preparation and bedding depths follow ICPI (Interlocking Concrete Pavement Institute) construction guidelines, now published by the National Concrete Masonry Association.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the area</h3>
        <p class="mt-1 text-sm text-slate-600">Measure the length and width of the patio or walkway in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose paver size</h3>
        <p class="mt-1 text-sm text-slate-600">Select a common paver size or enter custom dimensions. Set the joint gap and waste percentage.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-slate-600">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Order your pavers</h3>
        <p class="mt-1 text-sm text-slate-600">Use the total paver count to order from your supplier. Add extra for future repairs.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Paver unit area</p>
        <p class="mt-1 text-slate-600">
          Each paver plus its share of the joint gap occupies: <span class="font-mono">(pL + gap) &times; (pW + gap)</span>. For a 12&Prime; paver with 1/8&Prime; gap: (12 + 0.125) &times; (12 + 0.125) = <strong>147.02 sq in</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Pavers per square foot</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">PPsqFt = 144 / unit area in sq in</span>. For 12&Prime; pavers with 1/8&Prime; gap: 144 / 147.02 = <strong>0.98 pavers per sq ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Total needed</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Total = area &times; PPSqFt &times; (1 + waste%)</span>. For a 12&prime; &times; 10&prime; patio with 10% waste: 120 &times; 0.98 &times; 1.1 = <strong>130 pavers</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 16&prime; &times; 12&prime; patio using 6x9 inch pavers with 3/16 inch joint gap and 10% waste.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Area:</span> <span class="text-slate-600">16 &times; 12 = 192 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Unit area:</span> <span class="text-slate-600">(6.1875) &times; (9.1875) = 56.85 sq in</span></div>
        <div><span class="font-medium text-slate-700">Pavers per sq ft:</span> <span class="text-slate-600">144 / 56.85 = 2.53</span></div>
        <div><span class="font-medium text-slate-700">Total with waste:</span> <span class="text-slate-600">192 &times; 2.53 &times; 1.1 = <strong>535 pavers</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the paver calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Patio installation</h3>
        <p class="mt-1 text-sm text-slate-600">Create a beautiful outdoor living space with a paver patio. The calculator handles any size and paver type. Large format pavers create a modern look, while mixed sizes create a rustic, Old World feel.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚶</span>
        <h3 class="mt-2 font-semibold text-slate-900">Walkway and path</h3>
        <p class="mt-1 text-sm text-slate-600">Front walkways and garden paths benefit from pavers. The calculator works for any width path. Choose smaller pavers for curved paths and larger pavers for straight, formal walkways to the front door.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚗</span>
        <h3 class="mt-2 font-semibold text-slate-900">Paver driveway</h3>
        <p class="mt-1 text-sm text-slate-600">Pavers make a durable and attractive driveway. Use heavy-duty pavers at least 2-3/8 inches thick with a deeper gravel base (10-12 inches). Permeable pavers allow water to drain through, reducing runoff.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Pool deck</h3>
        <p class="mt-1 text-sm text-slate-600">Pavers around a pool are slip-resistant and stay cooler than concrete in direct sun. Use light-colored pavers to keep the surface temperature down. The calculator helps you estimate the exact quantity for the pool surround.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for paver projects</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Compact the base thoroughly</h3>
        <p class="mt-1 text-sm text-slate-600">The key to a long-lasting paver surface is a properly compacted base. Compact the gravel base in 2-3 inch lifts with a plate compactor. The base should be level with a slight slope (1/4 inch per foot) for drainage. Skimping on base preparation is the most common cause of paver failure.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use edge restraints</h3>
        <p class="mt-1 text-sm text-slate-600">Pavers need edge restraints to prevent them from spreading apart over time. Install plastic or concrete edge restraints along all exposed edges before laying pavers. Drive spikes through the restraints into the compacted base to hold them securely in place.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Seal for longer life</h3>
        <p class="mt-1 text-sm text-slate-600">Apply a paver sealer after installation to protect the color, prevent weed growth in the joints, and make the surface easier to clean. Sealer also helps the polymeric sand harden properly. Reapply sealer every 2-3 years for best protection.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A 20 ft by 40 ft paver driveway (800 sq ft) using 8x16 inch pavers with a 1/4-inch joint gap and 15% waste for cuts and vehicle-load durability needs 800 &times; 1.074 &times; 1.15 &asymp; <strong>989 pavers</strong>. Driveways use a higher waste allowance than patios because heavy-duty units are often cut around drain grates, expansion joints, and curves, and any breakage under vehicle loads is far more consequential than on a patio.
    </p>
    <p class="mt-3 text-slate-600">
      A narrow 4 ft by 50 ft garden walkway (200 sq ft) laid with small 6x6 inch pavers and a tight 1/8-inch gap needs 200 &times; 3.838 &times; 1.10 &asymp; <strong>845 pavers</strong>. Small-format pavers need far more units per square foot than large-format ones — this walkway uses nearly as many pavers as the driveway above despite covering a quarter of the area, which is why small pavers cost more in labor even when the material price per paver is lower.
    </p>
    <p class="mt-3 text-slate-600">
      A compact 14 ft by 14 ft patio (196 sq ft) using large 18x18 inch pavers with a 1/4-inch gap and 12% waste needs 196 &times; 0.432 &times; 1.12 &asymp; <strong>95 pavers</strong>. Large-format pavers dramatically cut the piece count and installation labor, which is why many homeowners choosing between a rustic small-paver look and a modern large-format look find the labor cost difference is often larger than the material cost difference.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Pavers can go straight on top of compacted dirt if I tamp it down well." <strong class="text-slate-900">Dirt alone is not a stable base.</strong> Without 4-6 inches of compacted crushed gravel beneath the sand bedding layer, the surface will settle unevenly as soil shifts with moisture and freeze-thaw cycles. Base preparation, not the pavers themselves, is what determines whether a patio stays flat for decades.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A bigger joint gap just means more sand — it doesn't affect how many pavers I need." <strong class="text-slate-900">It does.</strong> Each paver's footprint in the layout includes its share of the surrounding joint, so a wider gap increases the effective unit area and reduces pavers per square foot. Going from a 1/8-inch to a 1/4-inch gap can meaningfully lower the count on a large project.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/tile-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Tile Calculator</a>
      <a href="/tools/square-footage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
      <a href="/tools/concrete-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      const pL = parseFloat(el('pl').value);
      const pW = parseFloat(el('pw').value);
      const gap = parseFloat(el('gap').value);
      const waste = parseFloat(el('waste').value);
      if (!L || !W || !pL || !pW || L <= 0 || W <= 0 || pL <= 0 || pW <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const area = L * W;
      const unitArea = (pL + (gap || 0)) * (pW + (gap || 0));
      const ppsf = 144 / unitArea;
      const total = Math.ceil(area * ppsf * (1 + (waste || 0) / 100));

      el('r-pavers').textContent = total.toLocaleString() + ' pavers';
      el('r-waste').textContent = '(incl. ' + (waste || 0) + '% waste)';
      el('r-area').textContent = area.toFixed(1) + ' sq ft';
      el('r-ppsf').textContent = ppsf.toFixed(2);
      el('r-total').textContent = total.toLocaleString() + ' pavers';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.paver-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const [pl, pw] = btn.dataset.p.split('x').map(Number);
        el('pl').value = pl;
        el('pw').value = pw;
        update();
      });
    });

    ['length', 'width', 'pl', 'pw', 'gap', 'waste'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
  </script>
</ToolLayout>
