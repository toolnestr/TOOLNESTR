---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Carbohydrate Calculator';
const description =
  'Free carbohydrate calculator. Estimate your daily carb needs based on calorie target and diet style. Find the right carb intake for your goals.';
const intro =
  'Enter your daily calorie target and select a diet style to see your recommended carbohydrate intake in grams.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How many carbs should I eat per day?', a: 'The Dietary Guidelines recommend 45–65% of total calories from carbs. For a 2,000-calorie diet, that is 225–325 g per day. Active individuals need higher carb intake.' },
  { q: 'Are low-carb diets healthy?', a: 'Low-carb diets (20–30% of calories from carbs) can be effective for weight loss and blood sugar control for some people. However, they are not necessary or suitable for everyone. Very low-carb (keto) should be done with medical supervision.' },
  { q: 'Do I need carbs for exercise?', a: 'Yes — carbohydrates are the primary fuel source for high-intensity exercise. Athletes and active individuals need higher carb intakes to perform and recover. Low-carb training can feel significantly harder.' },
  { q: 'What are the best carb sources?', a: 'Whole food carb sources like fruits, vegetables, whole grains, legumes and starchy vegetables provide fibre, vitamins and minerals alongside energy. Refined carbs (white bread, sugary drinks) offer little nutritional value.' },
  { q: 'Can I eat carbs at night?', a: 'Yes — the idea that eating carbs at night causes weight gain is a myth. Total daily calorie intake determines weight change, not the timing of carbs. Eating carbs at night may even improve sleep quality for some people.' },
];
const sources = [
  { html: "<strong>NIH / National Institutes of Health</strong> and <strong>CDC</strong> reference values and formulas. <a href=\"https://www.nih.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nih.gov</a>" },
  { html: "<strong>Peer-reviewed equations</strong> (e.g. Mifflin-St Jeor, Harris-Benedict) as originally published." },
  { html: "<strong>ACOG</strong> for pregnancy, ovulation and due-date methodology. <a href=\"https://www.acog.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">acog.org</a>" },
];
const sourcesNote = "Not medical advice. Estimates only — consult a qualified healthcare professional for any personal health decision.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Daily calorie target</span>
      <input id="cal-target" type="number" step="any" placeholder="2000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Diet style</span>
      <select id="style" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="45">Moderate (45% — balanced diet)</option>
        <option value="55" selected>Moderate-high (55% — active lifestyle)</option>
        <option value="65">High carb (65% — endurance athlete)</option>
        <option value="30">Low carb (30% — weight loss / metabolic health)</option>
        <option value="5">Keto (5% — ketogenic diet)</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Daily carbohydrate target</div>
        <div id="r-carbs" class="mt-1 text-3xl font-bold">—</div>
        <div class="mt-1 text-sm opacity-80">grams of carbs per day</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Carb calories</div><div id="r-cal" class="mt-1 text-xl font-bold text-emerald-600">—</div><div class="text-xs text-slate-400"><span id="r-pct">—</span>% of total</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Per meal (3 meals)</div><div id="r-meal" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your calorie target and diet style to see your carb goal.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About carbohydrate intake</h2>
    <p class="mt-2 text-slate-600">
      Carbohydrates are the body's preferred fuel source, especially for the brain and during high-intensity exercise. Despite the popularity of low-carb diets, carbs are not inherently unhealthy. The quality and quantity of carbohydrates matter. Whole-food carb sources provide fibre (which supports digestive health and satiety), vitamins and phytonutrients. Refined carbs from added sugars and white flour can spike blood sugar and contribute to metabolic problems when consumed in excess. This calculator helps you set a carb target that matches your lifestyle. For context on how carbs fit into your overall nutrition, pair with the <a href="/tools/macro-calculator" class="font-medium text-indigo-600 hover:underline">Macro Calculator</a> and <a href="/tools/fat-intake-calculator" class="font-medium text-indigo-600 hover:underline">Fat Intake Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only. Individual carb needs vary with activity, metabolism and health conditions.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="carb-title carb-desc">
      <title id="carb-title">Carbohydrate proportions by diet style</title>
      <desc id="carb-desc">Three pie charts side by side showing carb proportions for balanced (55%), low-carb (30%) and keto (5%) diets.</desc>
      <!-- Balanced -->
      <circle cx="160" cy="100" r="50" fill="#e2e8f0" />
      <path d="M160,100 L160,50 A50,50 0 0,1 198.3,130 Z" fill="#22c55e" />
      <path d="M160,100 L198.3,130 A50,50 0 0,1 160,150 Z" fill="#6366f1" />
      <text x="160" y="170" text-anchor="middle" font-size="11" fill="#64748b">Balanced (55%)</text>
      <!-- Low-carb -->
      <circle cx="400" cy="100" r="50" fill="#e2e8f0" />
      <path d="M400,100 L400,50 A50,50 0 0,1 425,146.65 Z" fill="#22c55e" />
      <path d="M400,100 L425,146.65 A50,50 0 0,1 400,150 Z" fill="#6366f1" />
      <text x="400" y="170" text-anchor="middle" font-size="11" fill="#64748b">Low-carb (30%)</text>
      <!-- Keto -->
      <circle cx="640" cy="100" r="50" fill="#e2e8f0" />
      <path d="M640,100 L640,50 A50,50 0 0,1 648.7,149.14 Z" fill="#22c55e" />
      <path d="M640,100 L648.7,149.14 A50,50 0 0,1 640,150 Z" fill="#6366f1" />
      <text x="640" y="170" text-anchor="middle" font-size="11" fill="#64748b">Keto (5%)</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Carb proportions vary dramatically by diet style — from 55% in a balanced diet to 5% in keto</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      Carbohydrates provide 4 calories per gram. This calculator multiplies your total daily calorie target by the carb percentage selected, then divides by 4 to get the gram target. For example, on a 2,500-calorie diet with a moderate 55% carb target: 2,500 × 0.55 = 1,375 calories from carbs, which equals 1,375 ÷ 4 = 344 g of carbs per day. The calculator adjusts the percentage based on your chosen diet style, from keto (5%) to endurance athlete (65%).
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Carbs (g)</strong> = (total calories × carb%) ÷ 4
    </p>
    <p class="mt-3 text-slate-600">
      Fibre is an important part of carb intake — aim for at least 25–30 g of fibre per day for adults. Whole-food carb sources naturally provide fibre, while refined sources do not.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 70 kg endurance athlete eating 3,000 cal/day on a high-carb diet (65%) wants to know their carb target.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Calorie target:</span> <span class="text-slate-600">3,000 cal</span></div>
        <div><span class="font-medium text-slate-700">Carb %:</span> <span class="text-slate-600">65%</span></div>
        <div><span class="font-medium text-slate-700">Carb calories:</span> <span class="text-slate-600">3,000 × 0.65 = <strong>1,950 cal</strong></span></div>
        <div><span class="font-medium text-slate-700">Carb grams:</span> <span class="text-slate-600">1,950 ÷ 4 = <strong>488 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Per meal (5 meals):</span> <span class="text-slate-600">488 ÷ 5 ≈ <strong>98 g per meal</strong></span></div>
        <div><span class="font-medium text-slate-700">Reference:</span> <span class="text-slate-600">1 cup cooked oats = 54 g carbs. 1 banana = 27 g. 1 slice whole wheat bread = 15 g.</span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏃</span>
      <h3 class="mt-2 font-semibold text-slate-900">Marathon runner</h3>
      <p class="mt-1 text-sm text-slate-600">High carb intake (60–65%) ensures muscles are fully glycogen-loaded for endurance events. Carbs are the key performance fuel for distance athletes.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📉</span>
      <h3 class="mt-2 font-semibold text-slate-900">Weight-loss seeker</h3>
      <p class="mt-1 text-sm text-slate-600">A moderate or low-carb approach (30–45%) can help control appetite and blood sugar, making it easier to sustain a calorie deficit.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Strength athlete</h3>
      <p class="mt-1 text-sm text-slate-600">Carbs fuel intense lifting sessions and support recovery. A moderate-high intake (50–55%) is typical for powerlifters and bodybuilders.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🩺</span>
      <h3 class="mt-2 font-semibold text-slate-900">Type 2 diabetic</h3>
      <p class="mt-1 text-sm text-slate-600">A moderate lower-carb approach (30–40%) with emphasis on low-glycaemic, fibre-rich sources can help with blood glucose management.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set your calories</h3>
        <p class="mt-1 text-sm text-slate-600">Enter your daily calorie target. Use the Calorie Calculator or TDEE Calculator if you need a starting point.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose carb level</h3>
        <p class="mt-1 text-sm text-slate-600">Select the carb percentage that matches your activity level and dietary approach — from keto (5%) to high-carb endurance (65%).</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Focus on quality</h3>
        <p class="mt-1 text-sm text-slate-600">Fill your carb target with whole food sources — fruits, vegetables, whole grains and legumes. Minimise added sugars and refined grains.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for healthy carb intake</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Prioritise fibre</h3>
        <p class="mt-1 text-sm text-slate-600">Aim for at least 25–30 g of fibre per day. Fibre slows digestion, stabilises blood sugar and promotes satiety. Whole plant foods are the best source.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Time carbs around exercise</h3>
        <p class="mt-1 text-sm text-slate-600">Eating carbs 1–4 hours before exercise provides fuel. Post-workout carbs replenish glycogen stores. This is especially important for athletes training twice per day.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Limit added sugars</h3>
        <p class="mt-1 text-sm text-slate-600">The WHO recommends keeping added sugars below 10% of total calories (ideally under 5%). For a 2,000-calorie diet, that is a maximum of 50 g of added sugar per day.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/macro-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Macro Calculator</a>
      <a href="/tools/fat-intake-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Fat Intake Calculator</a>
      <a href="/tools/protein-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Protein Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const cal = parseFloat(el('cal-target').value);
      if (!cal || cal <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const pct = parseFloat(el('style').value);
      const carbCal = cal * (pct / 100);
      const carbG = carbCal / 4;
      el('r-carbs').textContent = Math.round(carbG) + ' g';
      el('r-cal').textContent = Math.round(carbCal).toLocaleString() + ' cal';
      el('r-pct').textContent = pct;
      el('r-meal').textContent = Math.round(carbG / 3) + ' g';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    ['cal-target', 'style'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
