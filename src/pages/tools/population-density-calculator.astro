---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Population Density Calculator';
const description = "Population density calculator. Solve D = N/A for individuals per unit area, with worked examples comparing sparse and dense populations.";
const intro = 'Enter a population count and the area it occupies to compute population density (individuals per unit area), a fundamental ecological measurement. Two 3D diagrams compare a sparse and a dense population over the same area, and charts compare density across real ecological examples.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is population density?', a: 'Population density is the number of individuals of a species per unit of area (or volume, for aquatic/aerial species), calculated as D = N/A, where N is population size and A is the area occupied.' },
  { q: 'Why does population density matter in ecology?', a: 'Density affects resource competition, disease transmission, predator-prey dynamics, and social behavior — it\'s one of the most fundamental measurements ecologists use to characterize and compare populations.' },
  { q: 'What is the difference between crude density and ecological density?', a: 'Crude density counts individuals per total area of a region. Ecological (or specific) density counts individuals only per unit of actually usable habitat within that region, excluding unsuitable areas — giving a more biologically meaningful measure.' },
  { q: 'How is population density estimated for hard-to-count species?', a: 'For species that are difficult to count directly (like elusive or wide-ranging animals), ecologists often use methods like mark-recapture sampling to estimate total population size before dividing by area to get density.' },
  { q: 'Does higher population density always mean a healthier population?', a: 'No — very high density can indicate resource stress, increased competition, and higher disease transmission risk, while very low density can signal a population at risk from difficulty finding mates or genetic issues. Optimal density varies enormously by species and context.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Population Density Calculator',
  description: 'Solve D = N/A for population density from population count and area.',
  steps: [
    { name: 'Enter the population count', text: 'Provide the total number of individuals (N).' },
    { name: 'Enter the area', text: 'Provide the total area (A) the population occupies.' },
    { name: 'Read the density', text: 'Population density (individuals per unit area) solves instantly.' },
  ],
};

const formulas = [
  { expr: 'D = N / A', note: 'population density — N = population count, A = area' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a deer population in a forest', tone: 'slate',
    given: 'A survey counts 250 deer living across a 50 km² forest area.',
    rows: [
      { label: 'Formula:', value: 'D = N / A' },
      { label: 'Substitute:', value: 'D = 250 / 50' },
      { label: 'Result:', value: 'D = 5 deer per km²', full: true },
    ],
    note: 'This density figure lets wildlife managers compare this population against sustainable density benchmarks for the local habitat quality.',
  },
  {
    title: 'Worked example 2 — comparing two habitats', tone: 'amber',
    given: 'A second forest patch of only 10 km² supports 80 deer of the same species. Compare density to the first example.',
    rows: [
      { label: 'Formula:', value: 'D = N / A' },
      { label: 'Substitute:', value: 'D = 80 / 10' },
      { label: 'Result:', value: 'D = 8 deer per km² — a notably denser population than the first forest (5 per km²)', full: true },
    ],
    note: 'Even though this second forest has far fewer total deer (80 vs 250), its smaller area means a higher density — a reminder that total population size and density measure very different things.',
  },
];

const comparison = {
  heading: 'Population density across different real-world examples',
  note: 'Density varies enormously depending on species, habitat quality, and scale of measurement.',
  headers: [{ label: 'Example' }, { label: 'Approx. density' }],
  rows: [
    ['Elephants in a savanna reserve', '~0.5 per km²'],
    ['Deer in temperate forest ★', '5-10 per km²'],
    ['Songbirds in suitable woodland', '~50-100 per km²'],
    ['Bacteria in a nutrient-rich culture', 'millions per mL'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference range (both worked examples). Density comparisons are only meaningful within the same species and similar habitat type — comparing across wildly different organisms and scales isn\'t directly informative.',
};

const realWorld = [
  { emoji: '🦌', title: 'Wildlife carrying capacity assessment', body: 'Wildlife managers compare observed population density against a habitat\'s estimated carrying capacity to judge whether a population is sustainable, overcrowded, or has room to grow.' },
  { emoji: '🦠', title: 'Disease transmission risk modeling', body: 'Higher population density generally increases disease transmission rates — epidemiologists and wildlife disease researchers use density estimates to predict outbreak risk in both human and animal populations.' },
  { emoji: '🌾', title: 'Agricultural pest management', body: 'Farmers and agricultural scientists monitor pest population density in crop fields to decide when intervention (like targeted pesticide application) becomes economically and ecologically necessary.' },
  { emoji: '🏙️', title: 'Urban planning and human population studies', body: 'Human population density calculations (people per km²) inform urban planning decisions about infrastructure, public services, and housing policy.' },
];

const misconceptions = [
  { claim: '"A larger total population always means a higher population density."', truth: 'Density depends on both population size AND the area it occupies — a smaller population crowded into a small area can easily have a higher density than a larger population spread across a much bigger area.' },
  { claim: '"Population density is uniform across an entire habitat."', truth: 'Real populations are rarely evenly distributed — most show clumped or patchy distributions based on resource availability, so a single density figure for a large area is often an average that hides significant local variation.' },
  { claim: '"Higher density is always better for a population\'s survival."', truth: "There's an optimal density range for most species — overcrowding increases competition, stress, and disease spread, while very low density can make finding mates difficult and reduce genetic diversity over time." },
  { claim: '"Population density can only be measured for land animals."', truth: 'Density applies to any organism in any environment — aquatic species are measured per unit volume or area of water, microorganisms per unit volume of culture medium, and even plants per unit ground area, using the exact same D=N/A logic.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 19, "Population and Community Ecology" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/19-1-population-demography" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 53, Population Ecology.' },
  { html: '<strong>Molles, <em>Ecology: Concepts and Applications</em></strong> — Chapter 9, Population Distribution and Abundance.' },
];
const sourcesNote = 'D = N/A. Real ecological density estimates often use sampling and statistical methods (like mark-recapture) rather than a complete direct count. Results are rounded for display.';

const howToUse = [
  { title: 'Enter the population count', body: 'Provide N, the total number of individuals surveyed or estimated.' },
  { title: 'Enter the area', body: 'Provide A, the total area (or volume) the population occupies.' },
  { title: 'Read the density', body: 'D = N/A solves instantly, in individuals per unit area.' },
];

const related = [
  { href: '/tools/exponential-population-growth-calculator', emoji: '📈', title: 'Exponential Population Growth Calculator', desc: 'N(t) = N₀e^(rt) — model unconstrained population growth.' },
  { href: '/tools/logistic-growth-calculator', emoji: '📉', title: 'Logistic Growth / Carrying Capacity Calculator', desc: 'N(t) with a carrying capacity — a more realistic model.' },
  { href: '/tools/mark-recapture-calculator', emoji: '🐟', title: 'Mark-Recapture Population Estimator', desc: 'Estimate total population size from marked/recaptured counts.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="population density strips away the misleading impression that total population size alone tells you how crowded a species really is — the same number of individuals can be sparse and thriving or dangerously overcrowded, purely depending on how much space they share."
  howIntro="Density is simply the ratio of population count to the area (or volume) that population occupies: D=N/A. This deceptively simple formula is powerful precisely because it normalizes population size against space, making it possible to meaningfully compare crowding across habitats of very different sizes — a small population in a small area and a large population in a large area can have identical densities, even though their raw population counts look completely different."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where population density actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Population count (N)</span>
        <input id="pop" type="number" step="any" value="250" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Area (km², or your chosen unit)</span>
        <input id="area" type="number" step="any" value="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Population density</div><div id="r-density" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="dens-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Sparse vs dense population</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-sparse" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low density</h3>
          <p class="mt-1 text-sm text-slate-600">Few individuals spread across the same area — low competition, but potentially harder to find mates.</p>
        </div>
        <div>
          <div id="diag-dense" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High density</h3>
          <p class="mt-1 text-sm text-slate-600">Many individuals in the same area — higher competition for resources, faster disease spread.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Population density graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Density across real-world examples (log scale)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-examples"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Density vs area (fixed N=250)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-area"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function update() {
        el('dens-err').textContent = '';
        el('r-density').textContent = '—';
        const pop = parseFloat(el('pop').value), area = parseFloat(el('area').value);
        if (isNaN(pop) || isNaN(area)) return;
        if (area <= 0 || pop < 0) { el('dens-err').textContent = 'Area must be greater than 0; population cannot be negative.'; return; }
        el('r-density').textContent = fmt(pop / area) + ' per unit area';
      }
      ['pop', 'area'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.examples = new Chart(el('chart-examples'), {
          type: 'bar',
          data: { labels: ['Elephants', 'Deer', 'Songbirds', 'Bacteria (per mL)'], datasets: [{ label: 'Density', data: [0.5, 7, 75, 1000000], backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Density (log scale)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsA = [], dataD = [];
        for (let a = 10; a <= 100; a += 10) { labelsA.push(a); dataD.push(+(250 / a).toFixed(2)); }
        charts.area = new Chart(el('chart-area'), {
          type: 'line',
          data: { labels: labelsA, datasets: [{ label: 'Density', data: dataD, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Area (km²)' } }, y: { title: { display: true, text: 'Density (per km²)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function densityScene(container, count) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const boundary = new THREE.Mesh(new THREE.BoxGeometry(4, 0.1, 4), new THREE.MeshStandardMaterial({ color: 0x94a3b8, transparent: true, opacity: 0.3 }));
        s.scene.add(boundary);
        for (let i = 0; i < count; i++) {
          const x = (Math.random() - 0.5) * 3.6, z = (Math.random() - 0.5) * 3.6;
          const dot = new THREE.Mesh(new THREE.SphereGeometry(0.18, 10, 8), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          dot.position.set(x, 0.2, z);
          s.scene.add(dot);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSparse = null, diagDense = null;
      function initDiagSparse() { const c = el('diag-sparse'); if (!c) throw new Error('no container'); diagSparse = densityScene(c, 8); }
      function initDiagDense() { const c = el('diag-dense'); if (!c) throw new Error('no container'); diagDense = densityScene(c, 40); }

      function boot() {
        try { update(); } catch (e) { console.error('[population-density] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[population-density] charts failed', e); }
        if (window.THREE) {
          try { initDiagSparse(); } catch (e) { console.error('[population-density] sparse diagram failed', e); }
          try { initDiagDense(); } catch (e) { console.error('[population-density] dense diagram failed', e); }
        }
        mountResize([diagSparse, diagDense]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
