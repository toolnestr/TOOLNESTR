---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Square Root Calculator';
const description = 'Calculate the square root (√) or any nth root of a number instantly. Free online root calculator with step-by-step explanation.';
const intro = 'Calculate square roots, cube roots, and any nth root of any positive number.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is a square root?', a: 'The square root of a number x is a value that when multiplied by itself gives x. Represented as √x, it is the inverse operation of squaring.' },
  { q: 'What is an nth root?', a: 'An nth root of x is a value that when multiplied by itself n times equals x. For example, the cube root (n=3) of 27 is 3 because 3×3×3=27.' },
  { q: 'Can I calculate roots of negative numbers?', a: 'For odd roots (cube root, fifth root, etc.), negative values are valid. For even roots (square root, fourth root), the result is not a real number for negative inputs.' },
  { q: 'What is the difference between principal root and negative root?', a: 'Every positive number has two square roots: a positive (principal) and a negative one. The calculator shows the principal (positive) root. For example, √9 = 3, even though (-3)² = 9 as well.' },
  { q: 'Are roots irrational?', a: 'Most roots are irrational numbers — they cannot be expressed as a simple fraction and have infinite non-repeating decimal expansions. For example, √2 ≈ 1.41421356... with no repeating pattern.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-3">
      <div class="flex-1 min-w-[180px]">
        <label class="block text-sm font-medium text-slate-700" for="root-number">Number</label>
        <input id="root-number" type="number" step="any" value="144" placeholder="e.g. 144"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="w-28">
        <label class="block text-sm font-medium text-slate-700" for="root-degree">Root (n)</label>
        <input id="root-degree" type="number" step="any" value="2" min="1" placeholder="2"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>
    <div id="root-result" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
      <span class="text-sm opacity-90">&sup3;&radic;144 or &radic;144 =</span>
      <span id="root-value" class="ml-2 text-2xl font-bold">12</span>
    </div>
    <div id="root-alt-sign" class="mt-3 hidden rounded-xl bg-slate-50 p-3 text-center text-sm text-slate-500"></div>
    <div id="root-step-detail" class="mt-3 hidden rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="500" height="400" viewBox="0 0 500 400" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sqrt-title sqrt-desc">
      <title id="sqrt-title">Geometric meaning of square root: a square with area x has side length √x</title>
      <desc id="sqrt-desc">A large square with area labelled x and side labelled √x, showing that the square root is the side length of a square with given area.</desc>
      <rect x="100" y="80" width="240" height="240" fill="#eef2ff" stroke="#6366f1" stroke-width="3" rx="4" />
      <text x="220" y="210" text-anchor="middle" fill="#6366f1" font-size="28" font-weight="bold">Area = x</text>
      <line x1="100" y1="320" x2="140" y2="350" stroke="#6366f1" stroke-width="2" />
      <line x1="340" y1="320" x2="300" y2="350" stroke="#6366f1" stroke-width="2" />
      <text x="220" y="375" text-anchor="middle" fill="#4338ca" font-size="22" font-weight="bold">side = &radic;x</text>
      <line x1="340" y1="80" x2="370" y2="120" stroke="#6366f1" stroke-width="2" />
      <line x1="340" y1="320" x2="370" y2="280" stroke="#6366f1" stroke-width="2" />
      <text x="400" y="210" text-anchor="middle" fill="#4338ca" font-size="22" font-weight="bold">side = &radic;x</text>
      <text x="220" y="60" text-anchor="middle" fill="#64748b" font-size="14">A square with area <tspan font-weight="bold">x</tspan> has side length <tspan font-weight="bold">&radic;x</tspan></text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The square root geometrically represents the side length of a square whose area equals the input number.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How root calculations work</h2>
    <p class="mt-2 text-slate-600">A root answers the question: what number, multiplied by itself <var>n</var> times, produces the input? The square root is the most common case where <var>n</var> = 2. Cube roots (<var>n</var> = 3) and higher-order roots follow the same principle. The notation &sup3;&radic;x means the cube root of x, and &sup4;&radic;x means the fourth root.</p>
    <p class="mt-3 text-slate-600">The calculator uses the mathematical identity that the nth root of x is equivalent to x raised to the power of 1/n. That is, &supn;&radic;x = x<sup>1/n</sup>. This identity connects roots and exponents, making root calculation straightforward once exponentiation is understood.</p>
    <p class="mt-3 text-slate-600">For even roots like square roots, the input must be non-negative to produce a real result. For odd roots, negative inputs yield negative outputs because an odd number of negative factors remains negative. The calculator handles these cases automatically, showing appropriate indicators when a result is not a real number.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Nth root formula</h3>
        <p class="mt-1 font-mono text-lg font-bold text-indigo-700">&supn;&radic;x = x<sup>1/n</sup></p>
        <p class="mt-2 text-sm text-slate-600">The nth root of x equals x raised to the power of 1/n. When n = 2, this is the square root.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Identity check</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">(&supn;&radic;x)<sup>n</sup> = x</p>
        <p class="mt-2 text-sm text-slate-600">Taking the nth root and then raising to the nth power returns the original number — this is the fundamental check.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: Square root of 144</h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>Step 1: Identify the number and root degree. &radic;144 = 144<sup>1/2</sup></p>
        <p>Step 2: Find a value that when squared equals 144. 12 &times; 12 = 144</p>
        <p>Step 3: Verify: 12<sup>2</sup> = 144 &checkmark;</p>
        <p class="font-semibold text-emerald-700">Therefore: &radic;144 = 12</p>
        <p class="mt-1 text-slate-500">For practical purposes, calculators use either the exponent identity (x<sup>0.5</sup>) or numerical methods like Newton-Raphson iteration for non-perfect squares.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Architects &amp; Designers</h3>
      <p class="mt-1 text-sm text-slate-600">When laying out square rooms or tiles, the square root converts total area into side length. A room of 400 sq ft requires a wall length of &radic;400 = 20 ft. Root calculations are essential for scaling blueprints and determining diagonal measurements.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4D0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students &amp; Teachers</h3>
      <p class="mt-1 text-sm text-slate-600">Roots appear throughout algebra, geometry, and calculus. Understanding square roots is essential for solving quadratic equations, working with the Pythagorean theorem, and analyzing parabolic functions. Cube roots appear in volume calculations.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4C8;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Data Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">The root mean square (RMS) is a fundamental statistical measure used to quantify the magnitude of a varying quantity. It appears in error analysis, signal processing, and machine learning evaluation metrics like RMSE.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x2699;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Engineers</h3>
      <p class="mt-1 text-sm text-slate-600">Root calculations appear in electrical engineering (RMS voltage/current), civil engineering (stress-strain relationships), and physics (distance from acceleration). Higher-order roots model complex physical phenomena across all engineering disciplines.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the root calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the number</h3>
        <p class="mt-1 text-sm text-slate-600">Type the number you want to find the root of. This can be any non-negative real number (or negative for odd roots).</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the root degree</h3>
        <p class="mt-1 text-sm text-slate-600">The default is 2 (square root). Change to 3 for cube root, 4 for fourth root, or any positive integer (or decimal) for fractional roots.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The principal root appears instantly. A verification check and step-by-step detail are shown below the result.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with roots</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Perfect squares are your friends</h3>
        <p class="mt-1 text-sm text-slate-600">Numbers like 1, 4, 9, 16, 25, 36, 49, 64, 81, 100, 121, 144, 169, 196, 225 are perfect squares. Learning these values helps you estimate square roots quickly without a calculator. For example, if you need &radic;200, you know it lies between 14 (&radic;196) and 15 (&radic;225).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Fractional exponents are roots</h3>
        <p class="mt-1 text-sm text-slate-600">Remember that x<sup>1/2</sup> = &radic;x, x<sup>1/3</sup> = &sup3;&radic;x, and in general x<sup>m/n</sup> = (&supn;&radic;x)<sup>m</sup>. This connection between exponents and roots is one of the most powerful relationships in algebra, allowing you to switch between the two representations.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use Newton's method for approximations</h3>
        <p class="mt-1 text-sm text-slate-600">If you need to estimate a square root manually, start with a guess g, then repeatedly apply g = (g + x/g) / 2. Each iteration doubles the precision. For &radic;144, any starting guess converges quickly: guess 10 gives (10 + 144/10)/2 = 12.2, then (12.2 + 144/12.2)/2 = 12.003, which is already extremely close to 12.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Roots of fractions and decimals</h3>
        <p class="mt-1 text-sm text-slate-600">The root of a fraction equals the root of the numerator divided by the root of the denominator: &radic;(a/b) = &radic;a / &radic;b. For decimals, you can convert to fraction form or use the calculator directly. This property also works for higher-order roots.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/exponent-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4D0;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Exponent Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate x to the power of y for any real base and exponent, including negative and fractional powers.</p>
      </a>
      <a href="/tools/logarithm-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4CA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Logarithm Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate log base b of x, natural log, and apply the change-of-base formula.</p>
      </a>
      <a href="/tools/factorial-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2757;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Factorial Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Compute n! with step-by-step multiplication breakdown for smaller values.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const rootNumber = document.getElementById('root-number');
    const rootDegree = document.getElementById('root-degree');
    const rootValue = document.getElementById('root-value');
    const rootResult = document.getElementById('root-result');
    const rootAltSign = document.getElementById('root-alt-sign');
    const rootStepDetail = document.getElementById('root-step-detail');

    function formatNthRoot(n) {
      const suffix = { 2: '', 3: '³', 4: '⁴', 5: '⁵', 6: '⁶', 7: '⁷', 8: '⁸', 9: '⁹', 10: '¹⁰' };
      return (suffix[n] || n + '') + '√';
    }

    function primeFactors(n) {
      const factors = [];
      let d = 2;
      let x = n;
      while (d * d <= x) {
        while (x % d === 0) { factors.push(d); x /= d; }
        d++;
      }
      if (x > 1) factors.push(x);
      return factors;
    }

    function calculate() {
      const x = parseFloat(rootNumber.value);
      const n = parseFloat(rootDegree.value);

      if (isNaN(x) || isNaN(n) || n <= 0) {
        rootValue.textContent = '—';
        rootAltSign.classList.add('hidden');
        rootStepDetail.classList.add('hidden');
        rootResult.classList.remove('bg-emerald-600', 'bg-red-600');
        rootResult.classList.add('bg-indigo-600');
        return;
      }

      const isEvenRoot = Number.isInteger(n) && n % 2 === 0;
      const isReal = !(isEvenRoot && x < 0);

      if (!isReal) {
        rootValue.textContent = 'Not a real number';
        rootAltSign.classList.add('hidden');
        rootStepDetail.classList.add('hidden');
        rootResult.classList.remove('bg-emerald-600', 'bg-indigo-600');
        rootResult.classList.add('bg-red-600');
        return;
      }

      rootResult.classList.remove('bg-red-600');
      rootResult.classList.add('bg-indigo-600');

      const result = Math.pow(x, 1 / n);
      const displayResult = result.toLocaleString(undefined, { maximumFractionDigits: 10 });

      const rootSymbol = formatNthRoot(n);
      rootValue.textContent = displayResult;
      rootResult.innerHTML = `<span class="text-sm opacity-90">${rootSymbol}${x.toLocaleString()} =</span> <span id="root-value" class="ml-2 text-2xl font-bold">${displayResult}</span>`;

      if (n === 2 && x > 0 && Number.isInteger(x) && Number.isInteger(result) && result * result === x) {
        rootAltSign.classList.remove('hidden');
        rootAltSign.textContent = `Also note: (-${result}) × (-${result}) = ${x}, so -${result} is also a square root of ${x.toLocaleString()}.`;
      } else {
        rootAltSign.classList.add('hidden');
      }

      if (Number.isInteger(x) && x > 0 && Number.isInteger(n) && n >= 2 && n <= 20 && result > 0) {
        const factors = primeFactors(x);
        let stepHtml = `<p class="font-semibold text-indigo-700">Prime factorization approach</p>`;
        stepHtml += `<p>${x.toLocaleString()} = ${factors.join(' × ')}</p>`;
        const counts = {};
        factors.forEach(f => { counts[f] = (counts[f] || 0) + 1; });
        let combined = '';
        for (const [p, c] of Object.entries(counts)) {
          const groups = Math.floor(c / n);
          if (groups > 0) combined += `${p}^${groups} × `;
        }
        if (combined) {
          combined = combined.slice(0, -3);
          stepHtml += `<p>Grouping in sets of ${n}: ${combined}</p>`;
          stepHtml += `<p>Result = ${combined.replace(/\^(\d+)/g, (_, e) => '^' + e)} = ${displayResult}</p>`;
        } else {
          stepHtml += `<p>No complete groups of ${n} found — result is irrational.</p>`;
        }
        rootStepDetail.innerHTML = stepHtml;
        rootStepDetail.classList.remove('hidden');
      } else {
        rootStepDetail.classList.add('hidden');
      }
    }

    rootNumber.addEventListener('input', calculate);
    rootDegree.addEventListener('input', calculate);
    calculate();
  </script>
</ToolLayout>
