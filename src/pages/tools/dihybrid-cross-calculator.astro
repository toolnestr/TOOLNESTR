---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Dihybrid Cross Calculator';
const description = 'Dihybrid cross calculator with a live 3D gamete diagram and charts. Build the full 16-cell two-gene Punnett square from AaBb × AaBb, with the classic 9:3:3:1 phenotype ratio and worked examples.';
const intro = 'Cross two double-heterozygous parents (AaBb × AaBb) to build the full 16-combination dihybrid Punnett square, showing every genotype and the classic 9:3:3:1 phenotype ratio. Two 3D diagrams show the four gamete types each parent produces, and charts break down the genotype and phenotype distributions.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a dihybrid cross?', a: 'A dihybrid cross tracks the inheritance of two genes at once, typically between two parents that are heterozygous for both genes (AaBb × AaBb). It reveals whether the two genes assort independently of each other.' },
  { q: 'Why does AaBb × AaBb give a 9:3:3:1 ratio?', a: 'Each parent produces 4 equally likely gamete types (AB, Ab, aB, ab) via independent assortment. Combining 4 gamete types from each parent gives 16 equally likely offspring combinations, which sort into phenotype groups in a 9:3:3:1 ratio (both dominant : one dominant one recessive : the reverse : both recessive).' },
  { q: 'What is the law of independent assortment?', a: 'The law of independent assortment states that genes for different traits (located on different chromosomes, or far apart on the same one) are inherited independently of each other — the allele a gamete receives for one gene doesn\'t affect which allele it receives for another gene.' },
  { q: 'Does independent assortment always hold?', a: 'No — genes located close together on the same chromosome tend to be inherited together (linked genes), violating independent assortment. The dihybrid 9:3:3:1 ratio specifically assumes the two genes are unlinked.' },
  { q: 'How many gametes does a double heterozygote produce?', a: 'A double heterozygote (AaBb) produces 4 distinct gamete types in equal proportions: AB, Ab, aB, and ab — one for every combination of the two genes\' alleles.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Dihybrid Cross Calculator',
  description: 'Build the full 16-cell dihybrid Punnett square from two double-heterozygous parents and see the resulting phenotype ratio.',
  steps: [
    { name: 'Confirm both parents are AaBb', text: 'The classic dihybrid cross uses two double heterozygotes.' },
    { name: 'View the 16-cell grid', text: 'All 16 offspring genotype combinations are generated automatically.' },
    { name: 'Read the phenotype ratio', text: 'The classic 9:3:3:1 ratio is tallied and displayed.' },
  ],
};

const formulas = [
  { expr: 'AaBb × AaBb → 9:3:3:1', note: 'phenotype ratio — both dominant : A dominant/B recessive : A recessive/B dominant : both recessive' },
  { expr: '4 gametes × 4 gametes = 16 combinations', note: 'AB, Ab, aB, ab from each parent' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — pea shape and color (round/yellow dominant)', tone: 'slate',
    given: 'Cross two pea plants heterozygous for both seed shape (Aa: round dominant) and seed color (Bb: yellow dominant).',
    rows: [
      { label: 'Gametes per parent:', value: 'AB, Ab, aB, ab (each 1/4 probability)' },
      { label: 'Total combinations:', value: '4 × 4 = 16' },
      { label: 'Phenotype ratio:', value: '9 round-yellow : 3 round-green : 3 wrinkled-yellow : 1 wrinkled-green', full: true },
    ],
    note: 'This exact 9:3:3:1 ratio, observed by Mendel in his original dihybrid experiments, was the key evidence for independent assortment of separate genes.',
  },
  {
    title: 'Worked example 2 — counting one specific phenotype category', tone: 'amber',
    given: 'From the same cross, how many of the 16 combinations show the double-recessive phenotype (wrinkled AND green)?',
    rows: [
      { label: 'Double recessive requires:', value: 'aa AND bb genotype' },
      { label: 'Probability of aa:', value: '1/4 (from Aa × Aa alone)' },
      { label: 'Probability of bb:', value: '1/4 (from Bb × Bb alone)' },
      { label: 'Combined probability:', value: '1/4 × 1/4 = 1/16 — exactly 1 out of 16 combinations', full: true },
    ],
    note: 'Multiplying the individual probabilities for each gene (since they assort independently) gives the same answer as counting cells directly in the 16-cell grid.',
  },
];

const comparison = {
  heading: 'The 9:3:3:1 dihybrid phenotype ratio broken down',
  note: 'Each phenotype category corresponds to a specific combination of dominant/recessive traits for the two genes.',
  headers: [{ label: 'Phenotype' }, { label: 'Count out of 16' }, { label: 'Fraction' }],
  rows: [
    ['Both dominant (A_B_) ★', '9', '9/16 (56.25%)'],
    ['A dominant, b recessive (A_bb)', '3', '3/16 (18.75%)'],
    ['a recessive, B dominant (aaB_)', '3', '3/16 (18.75%)'],
    ['Both recessive (aabb)', '1', '1/16 (6.25%)'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 1). The 9:3:3:1 pattern is the signature result of two independently assorting genes, each showing simple dominance.',
};

const realWorld = [
  { emoji: '🌱', title: "Mendel's dihybrid pea experiments", body: "Mendel's original two-gene crosses in pea plants, yielding the 9:3:3:1 ratio, provided the key evidence for what became the law of independent assortment." },
  { emoji: '🧬', title: 'Testing for gene linkage', body: 'When a real dihybrid cross produces a ratio significantly different from 9:3:3:1, it often signals that the two genes are physically linked on the same chromosome rather than assorting independently.' },
  { emoji: '🐁', title: 'Model organism genetics research', body: 'Researchers studying model organisms like fruit flies and mice use dihybrid cross logic to predict and interpret the inheritance of two traits simultaneously in breeding experiments.' },
  { emoji: '🌾', title: 'Multi-trait crop breeding', body: 'Plant breeders use dihybrid (and more complex multi-gene) cross predictions to combine two desirable traits, like disease resistance and yield, into a single new variety.' },
];

const misconceptions = [
  { claim: '"A dihybrid cross always produces exactly 9:3:3:1 in real life."', truth: 'The 9:3:3:1 ratio is a probability prediction assuming independent assortment and a large sample size — a small real cross may deviate from this ratio just by chance, and linked genes will produce a systematically different ratio altogether.' },
  { claim: '"The two genes in a dihybrid cross must be on the same chromosome to interact."', truth: "For the classic 9:3:3:1 ratio to hold, the genes actually need to be on different chromosomes (or very far apart on the same one) so they assort independently — genes close together on the same chromosome tend to be inherited as a linked unit instead." },
  { claim: '"16 offspring will show exactly 9, 3, 3, and 1 individuals of each phenotype."', truth: '16 is the total number of equally likely gamete combinations in the underlying probability model, not a guaranteed sample size — the ratio describes long-run proportions, most reliably seen with much larger numbers of actual offspring.' },
  { claim: '"Dihybrid crosses only apply to plants."', truth: 'The same independent-assortment logic applies to any diploid organism with two genes on separate chromosomes — animals, fungi, and humans all follow the identical mathematical pattern for unlinked gene pairs.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 12, "Mendel\'s Experiments and Heredity" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/12-2-characteristics-and-traits" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 3, Independent Assortment.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 14, Mendel and the Gene Idea.' },
];
const sourcesNote = 'Assumes both genes are unlinked (independent assortment) and show simple complete dominance. Results are probability ratios, not guaranteed exact counts.';

const howToUse = [
  { title: 'Confirm genotypes', body: 'This calculator models the classic AaBb × AaBb double-heterozygous cross.' },
  { title: 'View the 16-cell grid', body: 'Every possible offspring genotype combination is generated automatically.' },
  { title: 'Read the phenotype breakdown', body: 'The 9:3:3:1 ratio is tallied by phenotype category.' },
];

const related = [
  { href: '/tools/punnett-square-calculator', emoji: '🧬', title: 'Punnett Square Calculator', desc: 'Monohybrid cross — the classic 3:1 phenotype ratio.' },
  { href: '/tools/recombination-frequency-calculator', emoji: '🔗', title: 'Recombination Frequency Calculator', desc: 'Detect gene linkage from crossover frequency.' },
  { href: '/tools/chi-square-genetics-calculator', emoji: '📊', title: 'Chi-Square Goodness of Fit Calculator', desc: 'Test whether observed offspring match a predicted ratio.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="when two genes assort completely independently of each other, the probability of any combined genotype is simply the product of each gene's individual probability — which is exactly why combining two separate 3:1 ratios multiplies out into the distinctive 9:3:3:1 pattern."
  howIntro="Because each gene segregates independently (the law of independent assortment), a double heterozygote produces all four possible gamete combinations (AB, Ab, aB, ab) in exactly equal proportions. Crossing two such parents means combining 4 gamete types from one parent with 4 from the other, producing 16 equally likely offspring genotype combinations. Sorting those 16 outcomes by phenotype — since dominance masks the difference between homozygous dominant and heterozygous — produces the classic 9 (both dominant) : 3 (one dominant, one recessive) : 3 (the reverse) : 1 (both recessive) ratio."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where dihybrid crosses actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Classic double-heterozygous cross: AaBb × AaBb.</p>
    <div class="mt-2 overflow-x-auto rounded-xl border border-slate-200">
      <table id="grid" class="w-full table-fixed text-center text-xs sm:text-sm"></table>
    </div>
    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-3 text-center text-white"><div class="text-xs opacity-80">A_B_</div><div id="r-c1" class="mt-1 text-lg font-bold">9</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">A_bb</div><div id="r-c2" class="mt-1 text-lg font-bold text-slate-800">3</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">aaB_</div><div id="r-c3" class="mt-1 text-lg font-bold text-slate-800">3</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">aabb</div><div id="r-c4" class="mt-1 text-lg font-bold text-slate-800">1</div></div>
    </div>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Four gamete types</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-gametes1" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Parent 1's four gamete types</h3>
          <p class="mt-1 text-sm text-slate-600">AB, Ab, aB, ab — each produced in exactly equal proportions due to independent assortment.</p>
        </div>
        <div>
          <div id="diag-gametes2" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Parent 2's four gamete types</h3>
          <p class="mt-1 text-sm text-slate-600">Identical set of four gamete types — combining both parents' options produces all 16 grid outcomes.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Dihybrid cross charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Phenotype ratio — 9:3:3:1</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pheno"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Genotype distribution across all 16 combinations</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-geno"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const gametes = ['AB', 'Ab', 'aB', 'ab'];

      function combine(g1, g2) {
        const alleles = (g1[0] + g2[0]).split('').sort((a, b) => (a === a.toUpperCase() ? -1 : 1) - (b === b.toUpperCase() ? -1 : 1)).join('');
        const bAlleles = (g1[1] + g2[1]).split('').sort((a, b) => (a === a.toUpperCase() ? -1 : 1) - (b === b.toUpperCase() ? -1 : 1)).join('');
        return alleles + bAlleles;
      }
      function buildGrid() {
        let html = '<tr><td class="bg-slate-50 p-1"></td>';
        gametes.forEach((g) => (html += '<td class="bg-slate-50 p-1 font-mono font-bold text-slate-700">' + g + '</td>'));
        html += '</tr>';
        gametes.forEach((row) => {
          html += '<tr><td class="bg-slate-50 p-1 font-mono font-bold text-slate-700">' + row + '</td>';
          gametes.forEach((col) => { html += '<td class="border border-slate-100 p-1.5 font-mono font-semibold text-indigo-700">' + combine(row, col) + '</td>'; });
          html += '</tr>';
        });
        el('grid').innerHTML = html;
      }

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.pheno = new Chart(el('chart-pheno'), {
          type: 'bar',
          data: { labels: ['A_B_', 'A_bb', 'aaB_', 'aabb'], datasets: [{ label: 'Count (of 16)', data: [9, 3, 3, 1], backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#94a3b8'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Count (out of 16)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.geno = new Chart(el('chart-geno'), {
          type: 'pie',
          data: { labels: ['A_B_ (9/16)', 'A_bb (3/16)', 'aaB_ (3/16)', 'aabb (1/16)'], datasets: [{ data: [9, 3, 3, 1], backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#94a3b8'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function gameteScene(container) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const positions = [[-1.5, 1, 0], [1.5, 1, 0], [-1.5, -1, 0], [1.5, -1, 0]];
        const labels = [[0x6366f1, 0x6366f1], [0x6366f1, 0x94a3b8], [0x94a3b8, 0x6366f1], [0x94a3b8, 0x94a3b8]];
        positions.forEach((pos, i) => {
          const group = new THREE.Group();
          const a = new THREE.Mesh(new THREE.SphereGeometry(0.35, 16, 14), new THREE.MeshStandardMaterial({ color: labels[i][0] }));
          a.position.set(-0.25, 0, 0);
          const b = new THREE.Mesh(new THREE.SphereGeometry(0.35, 16, 14), new THREE.MeshStandardMaterial({ color: labels[i][1] }));
          b.position.set(0.25, 0, 0);
          group.add(a); group.add(b);
          group.position.set(pos[0], pos[1], pos[2]);
          s.scene.add(group);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagG1 = null, diagG2 = null;
      function initDiagG1() { const c = el('diag-gametes1'); if (!c) throw new Error('no container'); diagG1 = gameteScene(c); }
      function initDiagG2() { const c = el('diag-gametes2'); if (!c) throw new Error('no container'); diagG2 = gameteScene(c); }

      function boot() {
        try { buildGrid(); } catch (e) { console.error('[dihybrid-cross] grid build failed', e); }
        try { initCharts(); } catch (e) { console.error('[dihybrid-cross] charts failed', e); }
        if (window.THREE) {
          try { initDiagG1(); } catch (e) { console.error('[dihybrid-cross] gamete1 diagram failed', e); }
          try { initDiagG2(); } catch (e) { console.error('[dihybrid-cross] gamete2 diagram failed', e); }
        }
        mountResize([diagG1, diagG2]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
