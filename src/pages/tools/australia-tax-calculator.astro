---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { auIncomeTax, taxYearsToJson } from '../../data/tax.js';

const taxYears = Object.keys(auIncomeTax.years).sort().reverse();
const latestYear = taxYears[0];
const taxDataJson = taxYearsToJson(auIncomeTax);

const title = 'Australia Tax Calculator';
const description = 'Calculate Australian PAYG tax and net income for any salary, including the Medicare Levy. Get an accurate take-home pay estimate for any income level.';
const intro = 'Calculate Australian PAYG tax and net income for any salary.';
const category = { id: 'finance', name: 'Finance Tools' };
const faqs = [
  { q: 'What are the 2025-26 Australian tax rates?', a: '0% up to $18,200, 19% ($18,201-$45,000), 32.5% ($45,001-$135,000), 37% ($135,001-$190,000), 45% (above $190,000).' },
  { q: 'What is the Medicare Levy?', a: 'A 2% levy on taxable income that funds Australia\'s public healthcare system. Most residents pay it.' },
  { q: 'What is the tax-free threshold?', a: 'The first $18,200 of income is tax-free for Australian residents. Non-residents don\'t get this.' },
  { q: 'How often are tax brackets updated?', a: 'Tax brackets are typically updated each financial year (July 1) and may be indexed for inflation.' },
];
const sources = [
  { html: "<strong>Australian Taxation Office (ATO)</strong> — resident income tax rates, Medicare levy and thresholds. <a href=\"https://www.ato.gov.au/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">ato.gov.au</a>" },
  { html: "<strong>ATO PAYG withholding schedules</strong> for the relevant financial year." },
];
const sourcesNote = "Estimate only, not tax advice. Confirm current rates and your circumstances with the ATO or a registered tax agent.";

---

<ToolLayout {title} {description} {intro} {category} {faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="mb-4">
        <label for="year" class="block text-sm font-medium text-slate-700">Tax year</label>
        <select id="year" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          {taxYears.map((y) => <option value={y} selected={y === latestYear}>{y}</option>)}
        </select>
      </div>
      <!-- Versioned bracket data (one entry per tax year). Infinity serialized as null. -->
      <script type="application/json" id="tax-data" set:html={taxDataJson}></script>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="salary" class="block text-sm font-medium text-slate-700">Annual Salary (AUD)</label>
          <input id="salary" type="number" min="0" step="1000" value="90000" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div class="flex items-end pb-3">
          <label class="flex items-center gap-2 text-sm text-slate-700"><input id="medicare" type="checkbox" checked class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" /> Include Medicare Levy (2%)</label>
        </div>
      </div>
      <button id="calc-btn" class="mt-4 w-full rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700">Calculate</button>

      <div id="results" class="mt-6 hidden space-y-4">
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="rounded-xl bg-green-50 p-3 text-center"><span class="text-xs font-medium text-green-700">Gross Salary</span><p id="gross-val" class="mt-1 text-lg font-bold text-green-800"></p></div>
          <div class="rounded-xl bg-red-50 p-3 text-center"><span class="text-xs font-medium text-red-700">Income Tax</span><p id="tax-val" class="mt-1 text-lg font-bold text-red-800"></p></div>
          <div class="rounded-xl bg-orange-50 p-3 text-center"><span class="text-xs font-medium text-orange-700">Medicare Levy</span><p id="medicare-val" class="mt-1 text-lg font-bold text-orange-800"></p></div>
          <div class="rounded-xl bg-indigo-50 p-3 text-center"><span class="text-xs font-medium text-indigo-700">Net Income</span><p id="net-val" class="mt-1 text-lg font-bold text-indigo-800"></p></div>
        </div>
        <div class="rounded-xl bg-slate-50 p-3 text-center text-sm text-slate-600" id="breakdown"></div>
      </div>
    </div>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">How Australian PAYG tax works</h2>
      <p class="mt-2 text-slate-600">Australia uses a progressive tax system with a tax-free threshold of $18,200. Income is taxed at increasing marginal rates across five brackets. The Pay As You Go (PAYG) system withholds tax from each paycheck. The Medicare Levy is an additional 2% charge that funds Australia's public healthcare system.</p>
      <h3 class="mt-4 font-semibold text-slate-900">Worked example — $90,000 salary (2025-26, resident)</h3>
      <p class="mt-2 text-slate-600">The first $18,200 is tax-free. The next $26,800 (up to $45,000) is taxed at 19% = <strong>$5,092</strong>. The remaining $45,000 (from $45,001 to $90,000) is taxed at 32.5% = <strong>$14,625</strong>, giving <strong>$19,717 income tax</strong>. The 2% Medicare Levy adds $1,800, so net income is roughly $90,000 − $19,717 − $1,800 = <strong>$68,483 a year</strong> (about $5,707 a month). That is an effective tax rate of about 23.9%, well below the 32.5% marginal rate — because only the income inside each bracket is taxed at that bracket's rate.</p>
      <p class="mt-3 text-xs text-slate-400">Figures illustrate the 2025-26 resident rates and exclude offsets such as LITO; use the calculator above for your exact salary and tax year.</p>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="text-lg font-bold text-slate-900">Tips</h2>
      <ul class="mt-3 list-inside list-disc space-y-2 text-sm text-slate-600">
        <li>The tax-free threshold is available to Australian residents only — non-residents pay tax from the first dollar.</li>
        <li>High-income earners without private hospital insurance pay an additional Medicare Levy Surcharge (1-1.5%).</li>
        <li>Tax offsets like the Low Income Tax Offset (LITO) can reduce your tax bill further.</li>
      </ul>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="text-lg font-bold text-slate-900">Related tools</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        <a href="/tools/salary-calculator" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Salary Calculator</a>
        <a href="/tools/uk-take-home-pay-calculator" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">UK Take-Home Pay</a>
      </div>
    </section>
  </div>
</ToolLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var salaryInput = document.getElementById('salary');
    var medicareCheck = document.getElementById('medicare');
    var yearSelect = document.getElementById('year');
    var calcBtn = document.getElementById('calc-btn');
    var results = document.getElementById('results');
    var TAX = JSON.parse(document.getElementById('tax-data').textContent);

    function fmt(v) { return '$' + Math.round(v).toLocaleString('en-AU'); }

    function calculate() {
      var gross = parseFloat(salaryInput.value) || 0;
      var includeMedicare = medicareCheck.checked;
      var yd = TAX[yearSelect.value];

      // Progressive tax using the selected year's brackets. prev starts at 0;
      // the first band (rate 0) is the tax-free threshold.
      var tax = 0, prev = 0;
      for (var i = 0; i < yd.brackets.length; i++) {
        var rate = yd.brackets[i][0];
        var cap = yd.brackets[i][1] === null ? Infinity : yd.brackets[i][1];
        if (gross > prev) {
          var chunk = Math.min(gross, cap) - prev;
          if (chunk > 0) tax += chunk * rate;
          prev = cap;
        }
      }

      var medicare = includeMedicare ? gross * yd.medicareLevy : 0;
      var net = gross - tax - medicare;

      document.getElementById('gross-val').textContent = fmt(gross);
      document.getElementById('tax-val').textContent = fmt(tax);
      document.getElementById('medicare-val').textContent = fmt(medicare);
      document.getElementById('net-val').textContent = fmt(net);

      var monthly = net / 12;
      var fortnightly = net / 26;
      var weekly = net / 52;
      var effectiveRate = gross > 0 ? ((tax + medicare) / gross * 100).toFixed(1) : '0.0';

      document.getElementById('breakdown').innerHTML = 'Monthly: ' + fmt(monthly) + ' | Fortnightly: ' + fmt(fortnightly) + ' | Weekly: ' + fmt(weekly) + '<br />Effective tax rate: ' + effectiveRate + '%' +
        '<br /><span class="mt-2 block text-xs text-slate-400">ATO resident rates for the ' + yearSelect.value + ' tax year, verified ' + yd.verified + '. Estimate only — not tax advice.</span>';

      results.classList.remove('hidden');
    }

    calcBtn.addEventListener('click', calculate);
    yearSelect.addEventListener('change', function () { if (!results.classList.contains('hidden')) calculate(); });
  });
</script>