---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Genotype Frequency Calculator';
const description = "Genotype frequency calculator. Compute observed genotype and allele frequencies directly from population counts (AA, Aa, aa), with worked examples.";
const intro = 'Enter observed counts of each genotype (AA, Aa, aa) in a population to compute their genotype frequencies and the derived allele frequencies (p and q). Two 3D diagrams compare a population dominated by one genotype to a more evenly mixed one, and charts show how genotype counts translate into frequencies and allele proportions.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is genotype frequency?', a: 'Genotype frequency is the proportion of a population with a specific genotype — for example, if 60 out of 100 individuals are AA, the genotype frequency of AA is 0.60 (60%).' },
  { q: 'How is this different from the Hardy-Weinberg Allele Frequency Calculator?', a: 'The Hardy-Weinberg Allele Frequency Calculator starts from a known or assumed allele frequency and predicts what genotype frequencies should look like at equilibrium. This calculator instead starts from real, observed genotype counts and computes the actual frequencies directly — no equilibrium assumption required.' },
  { q: 'How do I get allele frequency from genotype frequency?', a: 'Each homozygote contributes two copies of its allele, and each heterozygote contributes one copy of each — so allele frequency p = freq(AA) + ½freq(Aa), and q = freq(aa) + ½freq(Aa).' },
  { q: 'Do genotype frequencies always add up to 1?', a: 'Yes — every individual in the population must have exactly one of the possible genotypes, so freq(AA) + freq(Aa) + freq(aa) always equals 1 (100%) by definition.' },
  { q: 'Can I use this to check if a population is in Hardy-Weinberg equilibrium?', a: 'This calculator gives you the observed genotype and allele frequencies — comparing those observed genotype frequencies to the Hardy-Weinberg-predicted p², 2pq, q² (using the same p and q) is exactly how equilibrium is tested, typically with a chi-square goodness-of-fit test.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Genotype Frequency Calculator',
  description: 'Compute genotype and allele frequencies directly from observed population counts.',
  steps: [
    { name: 'Enter genotype counts', text: 'Type how many individuals in the population are AA, Aa, and aa.' },
    { name: 'Read the frequencies', text: 'Genotype frequencies and derived allele frequencies (p and q) solve instantly.' },
  ],
};

const formulas = [
  { expr: 'freq(genotype) = count / N', note: 'N = total population size' },
  { expr: 'p = freq(AA) + ½freq(Aa)', note: 'dominant allele frequency from genotype counts' },
  { expr: 'q = freq(aa) + ½freq(Aa)', note: 'recessive allele frequency from genotype counts' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a sampled population of 100', tone: 'slate',
    given: 'A field survey counts 60 AA, 30 Aa, and 10 aa individuals (N = 100).',
    rows: [
      { label: 'Genotype frequencies:', value: 'freq(AA)=0.60, freq(Aa)=0.30, freq(aa)=0.10' },
      { label: 'Allele frequency p:', value: 'p = 0.60 + ½(0.30) = 0.75' },
      { label: 'Allele frequency q:', value: 'q = 0.10 + ½(0.30) = 0.25', full: true },
    ],
    note: 'Notice p+q=0.75+0.25=1.0 exactly, as required — this is a useful built-in check that the counts were entered and computed correctly.',
  },
  {
    title: 'Worked example 2 — a smaller sample of 50', tone: 'amber',
    given: 'A smaller sample counts 32 AA, 15 Aa, and 3 aa individuals (N = 50).',
    rows: [
      { label: 'Genotype frequencies:', value: 'freq(AA)=0.64, freq(Aa)=0.30, freq(aa)=0.06' },
      { label: 'Allele frequency p:', value: 'p = 0.64 + ½(0.30) = 0.79' },
      { label: 'Allele frequency q:', value: 'q = 0.06 + ½(0.30) = 0.21', full: true },
    ],
    note: 'A smaller sample size gives a slightly different result even from a similar underlying population — larger samples generally give more statistically reliable frequency estimates.',
  },
];

const comparison = {
  heading: 'From genotype counts to allele frequency, step by step',
  note: 'Each row uses the population from worked example 1 (N=100).',
  headers: [{ label: 'Quantity' }, { label: 'Formula' }, { label: 'Value' }],
  rows: [
    ['freq(AA)', '60/100', '0.60'],
    ['freq(Aa) ★', '30/100', '0.30'],
    ['freq(aa)', '10/100', '0.10'],
    ['p (dominant allele)', '0.60 + ½(0.30)', '0.75'],
    ['q (recessive allele)', '0.10 + ½(0.30)', '0.25'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row. Heterozygotes contribute to both allele frequencies equally, which is exactly why the ½freq(Aa) term appears in both the p and q formulas.',
};

const realWorld = [
  { emoji: '🔬', title: 'Population genetics field surveys', body: 'Ecologists and geneticists sampling wild populations (plants, insects, fish) count genotypes directly from field or lab data — this is the very first step before any deeper population genetics analysis can happen.' },
  { emoji: '🧬', title: 'Genetic disease screening programs', body: 'Public health genetics programs track genotype frequencies for known disease alleles across populations, using exactly this calculation to estimate carrier rates and plan screening resources.' },
  { emoji: '🐄', title: 'Livestock and crop genetic monitoring', body: 'Breeders and agricultural geneticists track genotype frequencies across generations to monitor whether a desirable or undesirable allele is becoming more or less common in a managed population.' },
  { emoji: '🦋', title: 'Studying evolution in real time', body: 'Comparing genotype frequencies of the same population measured in different years is one of the most direct ways biologists document evolution actually happening, such as shifts in coloration alleles in response to environmental change.' },
];

const misconceptions = [
  { claim: '"Genotype frequency and allele frequency are the same number."', truth: "They measure different things — genotype frequency is the proportion of individuals with a specific genotype (like Aa), while allele frequency is the proportion of a specific allele among all alleles in the population's gene pool. They're related but numerically different." },
  { claim: '"You need to assume Hardy-Weinberg equilibrium to calculate genotype frequency."', truth: 'Genotype frequency is simply an observed proportion from real counts — no equilibrium assumption is needed at all. Hardy-Weinberg equilibrium only becomes relevant when you want to predict or compare against a theoretical expectation.' },
  { claim: '"A rare genotype in a sample means it\'s rare in the whole population."', truth: "A small sample can easily over- or under-represent a genotype's true population frequency by chance — larger, more representative samples are needed before drawing confident conclusions about the actual population." },
  { claim: '"Allele frequency can be read directly from genotype counts without any calculation."', truth: 'Allele frequency must be calculated by counting actual allele copies — homozygotes contribute two copies of the same allele and heterozygotes contribute one of each, which is why the ½freq(Aa) term is essential and can\'t be skipped.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 19, "Population and Community Ecology" and Chapter 20, "Evolution" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/20-1-population-evolution" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Hartl &amp; Clark, <em>Principles of Population Genetics</em></strong> — Allele and genotype frequency chapter.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Population genetics and Hardy-Weinberg chapter.' },
];
const sourcesNote = 'freq = count/N; p = freq(AA)+½freq(Aa); q = freq(aa)+½freq(Aa). Results are rounded for display.';

const howToUse = [
  { title: 'Enter genotype counts', body: 'Type the number of AA, Aa, and aa individuals observed.' },
  { title: 'Read genotype frequencies', body: 'Each genotype\'s proportion of the total population displays instantly.' },
  { title: 'Read allele frequencies', body: 'p and q are derived automatically — they should always sum to 1.' },
];

const related = [
  { href: '/tools/hardy-weinberg-calculator', emoji: '⚖️', title: 'Hardy-Weinberg Allele Frequency Calculator', desc: 'p²+2pq+q²=1 — predicted equilibrium frequencies.' },
  { href: '/tools/chi-square-genetics-calculator', emoji: '📊', title: 'Chi-Square Goodness of Fit Calculator', desc: 'Test whether observed ratios match an expected genetic ratio.' },
  { href: '/tools/codominance-calculator', emoji: '🐄', title: 'Codominance Calculator', desc: 'Both alleles shown fully and separately.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="counting how many individuals have each genotype and dividing by the population size gives genotype frequency directly — no assumptions required — and carefully counting each individual allele copy from those same genotypes gives allele frequency."
  howIntro="Genotype frequency is simply the fraction of a population carrying a specific genotype, calculated by dividing that genotype's count by the total population size — a purely observational measurement requiring no theoretical assumptions. Allele frequency takes this one step further: since homozygotes (AA or aa) contribute two identical allele copies each, and heterozygotes (Aa) contribute one copy of each allele, tallying every allele copy across the whole population and dividing by the total number of alleles gives p and q. These observed frequencies become genuinely powerful once compared against Hardy-Weinberg's theoretical predictions — any mismatch is direct evidence that some evolutionary force is acting on the population."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where genotype frequency actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter observed counts for each genotype</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">AA count</span>
        <input id="c-aa" type="number" step="1" min="0" value="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Aa count</span>
        <input id="c-het" type="number" step="1" min="0" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">aa count</span>
        <input id="c-rec" type="number" step="1" min="0" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">freq(AA)</div><div id="r-faa" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">freq(Aa)</div><div id="r-fhet" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">freq(aa)</div><div id="r-frec" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Allele frequency p</div><div id="r-p" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Allele frequency q</div><div id="r-q" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="gf-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Skewed vs. mixed population</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-skewed" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Dominant-heavy population</h3>
          <p class="mt-1 text-sm text-slate-600">Most individuals are homozygous dominant — a high AA count relative to the others.</p>
        </div>
        <div>
          <div id="diag-mixed" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Evenly mixed population</h3>
          <p class="mt-1 text-sm text-slate-600">All three genotypes present in more comparable numbers.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Genotype and allele frequency charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Genotype frequency breakdown</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-geno"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Allele frequency (p vs. q)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-allele"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};

      // ---- calculator ----
      function update() {
        el('gf-err').textContent = '';
        ['r-faa', 'r-fhet', 'r-frec', 'r-p', 'r-q'].forEach((id) => el(id).textContent = '—');
        const aa = parseFloat(el('c-aa').value), het = parseFloat(el('c-het').value), rec = parseFloat(el('c-rec').value);
        if (isNaN(aa) || isNaN(het) || isNaN(rec)) return;
        if (aa < 0 || het < 0 || rec < 0) { el('gf-err').textContent = 'Counts cannot be negative.'; return; }
        const n = aa + het + rec;
        if (n === 0) { el('gf-err').textContent = 'Total population cannot be zero.'; return; }
        const fAA = aa / n, fHet = het / n, fRec = rec / n;
        const p = fAA + fHet / 2, q = fRec + fHet / 2;
        el('r-faa').textContent = fmt(fAA);
        el('r-fhet').textContent = fmt(fHet);
        el('r-frec').textContent = fmt(fRec);
        el('r-p').textContent = fmt(p);
        el('r-q').textContent = fmt(q);
        updateCharts(fAA, fHet, fRec, p, q);
      }
      ['c-aa', 'c-het', 'c-rec'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.geno = new Chart(el('chart-geno'), {
          type: 'bar',
          data: { labels: ['AA', 'Aa', 'aa'], datasets: [{ label: 'Frequency', data: [0.6, 0.3, 0.1], backgroundColor: ['#6366f1', '#f59e0b', '#94a3b8'] }] },
          options: Object.assign({}, base, { scales: { y: { min: 0, max: 1, title: { display: true, text: 'Frequency' } } }, plugins: { legend: { display: false } } }),
        });
        charts.allele = new Chart(el('chart-allele'), {
          type: 'pie',
          data: { labels: ['p (dominant)', 'q (recessive)'], datasets: [{ data: [0.75, 0.25], backgroundColor: ['#6366f1', '#f59e0b'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }
      function updateCharts(fAA, fHet, fRec, p, q) {
        if (charts.geno) { charts.geno.data.datasets[0].data = [fAA, fHet, fRec]; charts.geno.update('none'); }
        if (charts.allele) { charts.allele.data.datasets[0].data = [p, q]; charts.allele.update('none'); }
      }

      function populationScene(container, counts) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const colors = [0x6366f1, 0xf59e0b, 0x94a3b8];
        let idx = 0;
        counts.forEach((count, ci) => {
          for (let i = 0; i < count; i++) {
            const sph = new THREE.Mesh(new THREE.SphereGeometry(0.18, 10, 8), new THREE.MeshStandardMaterial({ color: colors[ci] }));
            const angle = (idx / 30) * Math.PI * 2;
            const r = 1.5 + (idx % 3) * 0.8;
            sph.position.set(Math.cos(angle) * r, Math.sin(angle) * r * 0.6, (Math.random() - 0.5) * 1.5);
            s.scene.add(sph);
            idx++;
          }
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSkewed = null, diagMixed = null;
      function initDiagSkewed() { const c = el('diag-skewed'); if (!c) throw new Error('no container'); diagSkewed = populationScene(c, [18, 6, 2]); }
      function initDiagMixed() { const c = el('diag-mixed'); if (!c) throw new Error('no container'); diagMixed = populationScene(c, [9, 9, 8]); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[genotype-frequency] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagSkewed(); } catch (e) { console.error('[genotype-frequency] skewed diagram failed', e); }
          try { initDiagMixed(); } catch (e) { console.error('[genotype-frequency] mixed diagram failed', e); }
        }
        mountResize([diagSkewed, diagMixed]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
