---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Ratio & Proportion Calculator';
const description = 'Simplify ratios, convert ratios to fractions/percentages, and solve proportions (a:b = c:d). Free online ratio and proportion calculator.';
const intro = 'Simplify ratios, find missing proportion terms, and convert ratios to fractions and percentages instantly.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is a ratio?', a: 'A ratio compares two or more quantities, showing their relative sizes. For example, a ratio of 3:2 means the first quantity is 3 parts for every 2 parts of the second.' },
  { q: 'How do you simplify a ratio?', a: 'Divide all terms of the ratio by their greatest common divisor (GCD). For example, 12:18 simplifies to 2:3 because GCD(12, 18) = 6, and 12/6 = 2, 18/6 = 3.' },
  { q: 'What is a proportion?', a: 'A proportion states that two ratios are equal: a:b = c:d. This means a/b = c/d, and the cross products a×d = b×c. Proportions are used to solve for unknown values in equivalent ratios.' },
  { q: 'How do I solve a:b = c:x?', a: 'Use cross-multiplication: a × x = b × c, so x = b × c / a. For example, 2:3 = 4:x gives x = 3 × 4 / 2 = 6. This technique is used extensively in scaling problems.' },
  { q: 'What is the difference between a ratio and a fraction?', a: 'A ratio compares two quantities (a:b), while a fraction a/b represents a part-to-whole relationship. A ratio can be converted to a fraction: a:b = a/(a+b) for the first part relative to the total.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-3">
      <div class="w-24">
        <label class="block text-sm font-medium text-slate-700" for="ratio-a">a</label>
        <input id="ratio-a" type="number" step="any" value="12" placeholder="12"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <span class="self-end pb-4 text-lg text-slate-400">:</span>
      <div class="w-24">
        <label class="block text-sm font-medium text-slate-700" for="ratio-b">b</label>
        <input id="ratio-b" type="number" step="any" value="18" placeholder="18"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <span class="self-end pb-4 text-lg text-slate-400">=</span>
      <div class="w-24">
        <label class="block text-sm font-medium text-slate-700" for="ratio-c">c</label>
        <input id="ratio-c" type="number" step="any" value="4" placeholder="4"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <span class="self-end pb-4 text-lg text-slate-400">:</span>
      <div class="w-24">
        <label class="block text-sm font-medium text-slate-700" for="ratio-d">d (solve)</label>
        <input id="ratio-d" type="number" step="any" value="" placeholder="?"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>
    <div id="ratio-result-simplified" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
      <span class="text-sm opacity-90">Simplified ratio =</span>
      <span id="ratio-simple-val" class="ml-2 text-2xl font-bold">2:3</span>
    </div>
    <div class="mt-3 grid gap-3 sm:grid-cols-2">
      <div id="ratio-proportion" class="rounded-xl bg-slate-50 p-4 text-center">
        <span class="text-sm text-slate-500">Proportion: 12:18 = 4:</span>
        <span id="ratio-d-solved" class="ml-1 text-lg font-bold text-emerald-700">6</span>
      </div>
      <div id="ratio-fraction" class="rounded-xl bg-slate-50 p-4 text-center text-sm text-slate-500">
        <span class="text-sm text-slate-500">As fraction: </span>
        <span id="ratio-fraction-val" class="text-lg font-bold text-slate-800">2/3</span>
        <span class="ml-2 text-xs text-slate-400">| As %: </span>
        <span id="ratio-percent-val" class="text-lg font-bold text-slate-800">66.67%</span>
      </div>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="600" height="320" viewBox="0 0 600 320" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ratio-title ratio-desc">
      <title id="ratio-title">Two scaled rectangles showing equivalent ratios</title>
      <desc id="ratio-desc">A 12×18 rectangle (ratio 2:3) and a proportionally smaller 4×6 rectangle (same ratio 2:3), illustrating that equivalent ratios maintain the same relative proportions regardless of absolute size.</desc>
      <rect x="50" y="40" width="500" height="240" rx="10" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" />
      <rect x="80" y="70" width="180" height="120" rx="6" fill="#eef2ff" stroke="#6366f1" stroke-width="2.5" />
      <text x="170" y="105" text-anchor="middle" fill="#4338ca" font-size="14" font-weight="bold">12</text>
      <text x="210" y="210" text-anchor="end" fill="#4338ca" font-size="13">18</text>
      <line x1="80" y1="70" x2="62" y2="55" stroke="#4338ca" stroke-width="1.5" />
      <text x="45" y="55" text-anchor="end" fill="#4338ca" font-size="12">12</text>
      <line x1="260" y1="190" x2="275" y2="205" stroke="#4338ca" stroke-width="1.5" />
      <text x="290" y="220" fill="#4338ca" font-size="12">18</text>
      <text x="170" y="230" text-anchor="middle" fill="#94a3b8" font-size="12">Ratio 12:18 = 2:3</text>
      <rect x="340" y="100" width="90" height="60" rx="6" fill="#ecfdf5" stroke="#10b981" stroke-width="2.5" />
      <text x="385" y="125" text-anchor="middle" fill="#059669" font-size="14" font-weight="bold">4</text>
      <line x1="340" y1="100" x2="322" y2="85" stroke="#059669" stroke-width="1.5" />
      <text x="305" y="85" text-anchor="end" fill="#059669" font-size="12">4</text>
      <text x="430" y="145" fill="#059669" font-size="12">6</text>
      <text x="385" y="195" text-anchor="middle" fill="#94a3b8" font-size="12">Ratio 4:6 = 2:3</text>
      <text x="300" y="290" text-anchor="middle" fill="#64748b" font-size="14">Both rectangles have the same 2:3 aspect ratio</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Two rectangles with the same 2:3 aspect ratio — equivalent ratios preserve proportions regardless of absolute dimensions.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How ratio and proportion calculations work</h2>
    <p class="mt-2 text-slate-600">A ratio a:b expresses the relative magnitude of two quantities. It reads as "a to b" and means that for every a units of the first quantity, there are b units of the second. Ratios can be simplified by dividing both terms by their greatest common divisor, just like simplifying fractions. The simplified ratio preserves the same relationship between the quantities.</p>
    <p class="mt-3 text-slate-600">A proportion is an equation stating that two ratios are equal: a:b = c:d. This is equivalent to the fraction equation a/b = c/d. The fundamental property of proportions is cross-multiplication: a × d = b × c. This allows solving for any unknown term when the other three are known. For example, in the proportion 2:3 = 4:x, cross-multiplying gives 2x = 12, so x = 6.</p>
    <p class="mt-3 text-slate-600">Ratios can also be expressed as fractions and percentages. The ratio a:b means the first quantity is a/(a+b) of the total, which can be expressed as a fraction and converted to a percentage. For the ratio 2:3, the first part is 2/5 = 0.4 = 40% of the whole, and the second part is 3/5 = 0.6 = 60% of the whole.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Ratio simplification</h3>
        <p class="mt-1 font-mono text-lg font-bold text-indigo-700">a:b = (a/GCD):(b/GCD)</p>
        <p class="mt-2 text-sm text-slate-600">Divide both terms by the greatest common divisor to get the simplest form. For 12:18, GCD = 6, so the simplified ratio is 2:3.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Proportion cross-multiplication</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">a:b = c:d &rArr; a×d = b×c</p>
        <p class="mt-2 text-sm text-slate-600">In a proportion, the product of the outer terms equals the product of the inner terms. Use this to solve for the unknown.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: Scaling a recipe</h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>A pancake recipe uses flour and milk in a ratio of 3:2 (3 cups flour to 2 cups milk).</p>
        <p>Problem: If we use 9 cups of flour, how much milk do we need?</p>
        <p>Step 1: Set up the proportion 3:2 = 9:x</p>
        <p>Step 2: Cross-multiply: 3 × x = 2 × 9, so 3x = 18</p>
        <p>Step 3: Divide both sides by 3: x = 6</p>
        <p class="font-semibold text-emerald-700">We need 6 cups of milk. The simplified ratio stays at 3:2 throughout.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F373;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Cooks &amp; Bakers</h3>
      <p class="mt-1 text-sm text-slate-600">Recipes rely on ratios. Flour to liquid, fat to sugar, ingredients to servings — scaling recipes up or down is a practical application of proportions. The ratio calculator handles all scaling tasks instantly.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Architects &amp; Designers</h3>
      <p class="mt-1 text-sm text-slate-600">Blueprints and scale models use ratios to represent real-world dimensions. A 1:100 scale means 1 cm on the plan represents 100 cm (1 meter) in reality. Aspect ratios for screens and images are another common application.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Finance Professionals</h3>
      <p class="mt-1 text-sm text-slate-600">Financial ratios analyze company performance: price-to-earnings (P/E), debt-to-equity, current ratio, and return on equity. These ratios standardize comparisons across companies of different sizes.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Mixologists</h3>
      <p class="mt-1 text-sm text-slate-600">Cocktail recipes are ratios. A classic martini has a 2:1 ratio of gin to vermouth. Adjusting the ratio changes the drink's character. Understanding proportions helps create consistent drinks at any volume.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the ratio & proportion calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the ratio</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in the a and b values of the ratio you want to simplify. The simplified form appears instantly below the inputs.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the proportion</h3>
        <p class="mt-1 text-sm text-slate-600">Enter c to find the missing d term in a:b = c:d. Leave d blank and the calculator solves the proportion automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check the conversions</h3>
        <p class="mt-1 text-sm text-slate-600">The ratio is also displayed as a simplified fraction and a percentage, giving you three ways to understand the relationship.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with ratios</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always simplify for clarity</h3>
        <p class="mt-1 text-sm text-slate-600">A ratio like 24:36 is technically correct, but 2:3 is immediately understandable. Always simplify ratios to their lowest terms by dividing by the GCD. This makes comparisons between ratios much easier — 2:3 vs 3:4 is clearer than 24:36 vs 15:20.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Proportions for scaling</h3>
        <p class="mt-1 text-sm text-slate-600">The most common use of proportions is scaling. If you know that 2 cups of flour serves 4 people, set up the proportion 2:4 = x:6 to find how much flour serves 6 people. Cross-multiply: 2×6 = 4x, so x = 3 cups. This works for any unit or ingredient.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Part-to-whole vs part-to-part</h3>
        <p class="mt-1 text-sm text-slate-600">A part-to-part ratio (like 2:3) compares two parts of a whole. The whole is 2+3 = 5 parts. A part-to-whole ratio compares one part to the total. Be clear about which type you are using. The calculator shows both the simplified ratio and the fraction of the whole.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Continuous ratios</h3>
        <p class="mt-1 text-sm text-slate-600">Ratios can compare more than two quantities. A ratio of 2:3:5 means the first is 2 parts, the second 3 parts, and the third 5 parts out of 10 total. This type appears in concrete mixing (cement:sand:gravel), color mixing, and investment portfolio allocation.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/gcd-lcm-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2797;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">GCD &amp; LCM Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Find the greatest common divisor needed for ratio simplification.</p>
      </a>
      <a href="/tools/fraction-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2795;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Fraction Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Add, subtract, multiply, and divide fractions with simplification.</p>
      </a>
      <a href="/tools/percentage-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4C8;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Percentage Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Convert ratios to percentages and work out percentage relationships.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const rA = document.getElementById('ratio-a');
    const rB = document.getElementById('ratio-b');
    const rC = document.getElementById('ratio-c');
    const rD = document.getElementById('ratio-d');
    const rSimpleVal = document.getElementById('ratio-simple-val');
    const rDSolved = document.getElementById('ratio-d-solved');
    const rFractionVal = document.getElementById('ratio-fraction-val');
    const rPercentVal = document.getElementById('ratio-percent-val');

    function gcd(a, b) {
      a = Math.abs(a);
      b = Math.abs(b);
      while (b) { const t = b; b = a % b; a = t; }
      return a;
    }

    function calculate() {
      const a = parseFloat(rA.value);
      const b = parseFloat(rB.value);
      const c = rC.value.trim() === '' ? null : parseFloat(rC.value);
      const d = rD.value.trim() === '' ? null : parseFloat(rD.value);

      if (isNaN(a) || isNaN(b) || a === 0 || b === 0) {
        rSimpleVal.textContent = '—';
        rDSolved.textContent = '—';
        rFractionVal.textContent = '—';
        rPercentVal.textContent = '—';
        return;
      }

      const g = gcd(a, b);
      const sa = a / g;
      const sb = b / g;
      rSimpleVal.textContent = `${Number.isInteger(sa) ? sa.toLocaleString() : sa.toFixed(4)} : ${Number.isInteger(sb) ? sb.toLocaleString() : sb.toFixed(4)}`;

      if (c !== null && c !== 0 && d === null) {
        const solved = (b * c) / a;
        rDSolved.textContent = solved.toLocaleString(undefined, { maximumFractionDigits: 4 });
      } else if (d !== null && d !== 0 && c === null) {
        const solved = (a * d) / b;
        rDSolved.textContent = solved.toLocaleString(undefined, { maximumFractionDigits: 4 });
      } else if (c !== null && d !== null && a !== 0 && b !== 0) {
        rDSolved.textContent = (d === 0) ? '—' : d.toLocaleString();
      } else {
        rDSolved.textContent = '—';
      }

      const total = a + b;
      const fracA = a / total;
      rFractionVal.textContent = `${a.toLocaleString()}/${total.toLocaleString()}`;
      rPercentVal.textContent = `${(fracA * 100).toFixed(2)}%`;
    }

    rA.addEventListener('input', calculate);
    rB.addEventListener('input', calculate);
    rC.addEventListener('input', calculate);
    rD.addEventListener('input', calculate);
    calculate();
  </script>
</ToolLayout>
