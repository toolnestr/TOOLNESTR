---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Sound Intensity Calculator';
const description = 'Sound intensity calculator with a live 3D wavefront diagram and charts. Convert between intensity (W/m²) and decibel level, and apply the inverse-square law to find intensity at a new distance, with worked examples.';
const intro = 'Convert sound intensity (W/m²) to decibel level, or the reverse, and use the inverse-square law to find how intensity changes with distance from a point source. Two 3D diagrams show sound energy spreading over an expanding sphere and compare common sound levels, with charts showing the logarithmic dB scale and inverse-square distance decay.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is sound intensity?', a: 'Sound intensity (I) is the power carried by a sound wave per unit area, measured in watts per square metre (W/m²). It is an objective physical quantity, unlike loudness, which is a subjective perception.' },
  { q: 'How is sound intensity converted to decibels?', a: 'β = 10 log₁₀(I / I₀), where I₀ = 1×10⁻¹² W/m² is the standard reference intensity (roughly the threshold of human hearing). Decibels compress an enormous range of intensities into a manageable logarithmic scale.' },
  { q: 'Why does sound intensity follow an inverse-square law?', a: 'A point source spreads its power over an expanding sphere, and sphere surface area grows as 4πr². Since intensity is power divided by area, I ∝ 1/r² — doubling the distance from a point source cuts the intensity to one quarter.' },
  { q: 'Why does doubling distance not simply halve the decibel level?', a: 'Decibels are logarithmic, not linear. Doubling distance quarters intensity, which is a drop of 10×log₁₀(4) ≈ 6 dB — not half of whatever the original dB value was. A 100 dB source is 94 dB at twice the distance, not 50 dB.' },
  { q: 'Do two 70 dB sources together produce 140 dB?', a: 'No — intensities add, not decibels. Two identical 70 dB sources together produce about 73 dB, since combining them doubles the intensity, and 10×log₁₀(2) ≈ 3 dB.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Sound Intensity Calculator',
  description: 'Convert between sound intensity and decibel level, or apply the inverse-square law to find intensity at a new distance from a point source.',
  steps: [
    { name: 'Pick a mode', text: '"Intensity → dB" or "dB → Intensity" converts directly; "Inverse-square law" finds intensity at a new distance.' },
    { name: 'Enter the values', text: 'Type the intensity (W/m²), decibel level, or distances as required by the chosen mode.' },
    { name: 'Read the result', text: 'The converted value solves instantly, using the standard reference intensity I₀ = 1×10⁻¹² W/m².' },
  ],
};

const formulas = [
  { expr: 'β = 10 log₁₀(I / I₀)', note: 'decibel level from intensity, I₀ = 1×10⁻¹² W/m² (threshold of hearing)' },
  { expr: 'I = I₀ × 10^(β/10)', note: 'intensity from decibel level (the inverse conversion)' },
  { expr: 'I₂ = I₁ × (r₁ / r₂)²', note: 'inverse-square law — intensity at a new distance from a point source' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — rock concert intensity to decibels', tone: 'slate',
    given: 'Sound intensity near a concert speaker measures I = 0.1 W/m². Find the decibel level.',
    rows: [
      { label: 'Formula:', value: 'β = 10 log₁₀(I / I₀)' },
      { label: 'Substitute:', value: 'β = 10 log₁₀(0.1 / 1×10⁻¹²) = 10 log₁₀(1×10¹¹)' },
      { label: 'Result:', value: 'β = 10 × 11 = 110 dB', full: true },
    ],
    note: '110 dB is loud enough to cause hearing damage after even brief exposure — well above the roughly 85 dB threshold where OSHA recommends hearing protection.',
  },
  {
    title: 'Worked example 2 — inverse-square law with distance', tone: 'amber',
    given: 'A point source measures β₁ = 100 dB at r₁ = 1 m. Find the intensity and decibel level at r₂ = 10 m.',
    rows: [
      { label: 'Intensity at 1 m:', value: 'I₁ = I₀ × 10^(100/10) = 1×10⁻¹² × 10¹⁰ = 0.01 W/m²' },
      { label: 'Inverse-square law:', value: 'I₂ = I₁ × (r₁/r₂)² = 0.01 × (1/10)² = 0.01 × 0.01 = 1×10⁻⁴ W/m²' },
      { label: 'Decibels at 10 m:', value: 'β₂ = 10 log₁₀(1×10⁻⁴ / 1×10⁻¹²) = 10 log₁₀(1×10⁸) = 80 dB', full: true },
    ],
    note: 'A 10× increase in distance drops the level from 100 dB to 80 dB — a clean 20 dB drop, matching the shortcut formula β₂ = β₁ − 20 log₁₀(r₂/r₁).',
  },
];

const comparison = {
  heading: 'Common sound levels, in intensity and decibels',
  note: 'The decibel scale compresses an enormous intensity range (a factor of 10¹⁴ from threshold to jet engine) into a compact, manageable set of numbers.',
  headers: [{ label: 'Sound' }, { label: 'Intensity', sub: 'W/m²' }, { label: 'Level', sub: 'dB' }],
  rows: [
    ['Threshold of hearing', '1 × 10⁻¹²', '0'],
    ['Quiet whisper', '1 × 10⁻¹⁰', '20'],
    ['Normal conversation', '1 × 10⁻⁶', '60'],
    ['Rock concert (near speaker) ★', '1 × 10⁻¹', '110'],
    ['Jet engine at takeoff', '1 × 10²', '140'],
  ],
  highlightIndex: 3,
  footnote: '★ Reference row (worked example 1). Each 10 dB increase corresponds to a 10× increase in intensity — a linear-looking scale hides an exponential reality.',
};

const realWorld = [
  { emoji: '🎧', title: 'Hearing safety and OSHA limits', body: 'Occupational safety standards set maximum daily noise exposure limits in decibels (typically 85–90 dB for an 8-hour shift) because sound intensity above these levels can cause permanent hearing damage over time.' },
  { emoji: '🔊', title: 'Speaker and venue design', body: 'Audio engineers use the inverse-square law to predict how sound intensity falls off across a concert hall or stadium, positioning speakers so every seat receives an acceptable, balanced sound level.' },
  { emoji: '🌊', title: 'Sonar and underwater acoustics', body: 'Sonar systems rely on how sound intensity attenuates with distance underwater to estimate the range to a submarine, seabed feature, or school of fish from the strength of the returning echo.' },
  { emoji: '🏛️', title: 'Architectural acoustics', body: 'Concert hall and auditorium designers model how sound intensity spreads and reflects off surfaces to avoid dead zones (too quiet) or hot spots (uncomfortably loud) throughout the seating area.' },
];

const misconceptions = [
  { claim: '"Doubling the distance from a sound source cuts the loudness in half (in dB)."', truth: 'Doubling distance quarters the intensity (inverse-square law), which is a drop of only about 6 dB (10×log₁₀(4)) — not half of the original decibel value. Decibels are logarithmic, so simple fractions of intensity do not translate to simple fractions of dB.' },
  { claim: '"Two 70 dB sources together make 140 dB."', truth: 'Decibels do not add directly — intensities do. Two identical 70 dB sources together only reach about 73 dB, since doubling intensity adds just 10×log₁₀(2) ≈ 3 dB.' },
  { claim: '"A sound with zero decibels has no sound energy at all."', truth: '0 dB is defined as the reference threshold of human hearing (I₀ = 1×10⁻¹² W/m²), not zero intensity — sounds quieter than this threshold have negative decibel values, they are simply too quiet for humans to detect.' },
  { claim: '"Intensity and loudness are the same thing."', truth: 'Intensity is an objective physical measurement of power per area. Loudness is the subjective, frequency-dependent perception of that intensity by the human ear and brain — two sounds with equal intensity can be perceived as very different in loudness depending on pitch.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 17, "Sound" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/17-3-sound-intensity" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 17, Waves — II (Sound Intensity).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 17, Sound Waves.' },
];
const sourcesNote = 'β = 10 log₁₀(I/I₀) with I₀ = 1×10⁻¹² W/m² (standard reference intensity). Inverse-square law I₂ = I₁(r₁/r₂)² assumes an idealized point source with no absorption or reflection. Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: 'Convert intensity ↔ decibels directly, or use the inverse-square law to find intensity at a new distance.' },
  { title: 'Enter the values', body: 'Use W/m² for intensity, decibels for level, and metres for distance.' },
  { title: 'Read the result', body: 'The converted value solves live, with scientific notation for very small or large intensities.' },
];

const related = [
  { href: '/tools/wave-speed-calculator', emoji: '🌊', title: 'Wave Speed Calculator', desc: 'v = f×λ — solve for wave speed, frequency, or wavelength.' },
  { href: '/tools/doppler-effect-calculator', emoji: '🚨', title: 'Doppler Effect Calculator', desc: 'Approaching or receding source frequency shift.' },
  { href: '/tools/simple-harmonic-motion-calculator', emoji: '🎻', title: 'Simple Harmonic Motion Calculator', desc: 'x(t), v(t), a(t) for an oscillator — solve any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="the decibel scale is logarithmic because the range of sound intensities the human ear can detect spans a factor of roughly a hundred trillion — compressing that into decibels makes a wildly nonlinear phenomenon feel like a compact, manageable number line."
  howIntro="Taking log₁₀ of the ratio I/I₀ turns a multiplicative relationship into an additive one: every extra factor of 10 in intensity adds exactly 10 dB. Because a point source radiates its power outward over an expanding sphere (surface area 4πr²), intensity falls off as 1/r² with distance — combining the two ideas lets you predict both how loud something sounds in absolute terms, and how that loudness changes as you move away from the source."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where sound intensity actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-i2db" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Intensity → dB</button>
      <button id="mode-db2i" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">dB → Intensity</button>
      <button id="mode-inv" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Inverse-square law</button>
    </div>

    <div id="fields-i2db" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Intensity I (W/m²)</span>
        <input id="I1" type="number" step="any" placeholder="e.g. 0.1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="fields-db2i" class="hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Decibel level β (dB)</span>
        <input id="beta1" type="number" step="any" placeholder="e.g. 110" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="fields-inv" class="hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Decibel level at r₁ (dB)</span>
        <input id="beta_r1" type="number" step="any" placeholder="e.g. 100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Distance r₁ (m)</span>
        <input id="r1" type="number" step="any" placeholder="e.g. 1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">New distance r₂ (m)</span>
        <input id="r2" type="number" step="any" placeholder="e.g. 10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Intensity</div><div id="r-int" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Decibel level</div><div id="r-db" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="si-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Spreading sound energy</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-sphere" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Expanding wavefronts from a point source</h3>
          <p class="mt-1 text-sm text-slate-600">The same total power spreads across an ever-larger spherical surface as it travels outward — the geometric root of the inverse-square law.</p>
        </div>
        <div>
          <div id="diag-bars" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Common sound levels compared</h3>
          <p class="mt-1 text-sm text-slate-600">Bar heights for whisper, conversation, concert, and jet engine — visually flattening just how enormous the real intensity gap between them is.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Sound intensity graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Intensity (log scale) vs decibel level — the logarithmic relationship</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-log"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Intensity vs distance from a point source (inverse-square decay)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dist"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const I0 = 1e-12;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function fmtSci(x) {
        if (!isFinite(x)) return '—';
        if (Math.abs(x) !== 0 && (Math.abs(x) < 1e-3 || Math.abs(x) >= 1e5)) return x.toExponential(3);
        return fmt(x);
      }

      // ---- calculator ----
      let mode = 'i2db';
      function setActive(id, active) {
        el(id).className = active ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
      }
      function switchMode(m) {
        mode = m;
        setActive('mode-i2db', m === 'i2db'); setActive('mode-db2i', m === 'db2i'); setActive('mode-inv', m === 'inv');
        el('fields-i2db').className = m === 'i2db' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        el('fields-db2i').className = m === 'db2i' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        el('fields-inv').className = m === 'inv' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        el('si-err').textContent = '';
        update();
      }
      function update() {
        el('si-err').textContent = '';
        el('r-int').textContent = '—'; el('r-db').textContent = '—';
        if (mode === 'i2db') {
          const I = parseFloat(el('I1').value);
          if (isNaN(I)) return;
          if (I <= 0) { el('si-err').textContent = 'Intensity must be greater than 0.'; return; }
          el('r-int').textContent = fmtSci(I) + ' W/m²';
          el('r-db').textContent = fmt(10 * Math.log10(I / I0)) + ' dB';
        } else if (mode === 'db2i') {
          const b = parseFloat(el('beta1').value);
          if (isNaN(b)) return;
          const I = I0 * Math.pow(10, b / 10);
          el('r-int').textContent = fmtSci(I) + ' W/m²';
          el('r-db').textContent = fmt(b) + ' dB';
        } else {
          const b1 = parseFloat(el('beta_r1').value), r1 = parseFloat(el('r1').value), r2 = parseFloat(el('r2').value);
          if (isNaN(b1) || isNaN(r1) || isNaN(r2)) return;
          if (r1 <= 0 || r2 <= 0) { el('si-err').textContent = 'Distances must be greater than 0.'; return; }
          const I1 = I0 * Math.pow(10, b1 / 10);
          const I2 = I1 * Math.pow(r1 / r2, 2);
          el('r-int').textContent = fmtSci(I2) + ' W/m²';
          el('r-db').textContent = fmt(10 * Math.log10(I2 / I0)) + ' dB';
        }
      }
      el('mode-i2db').addEventListener('click', () => switchMode('i2db'));
      el('mode-db2i').addEventListener('click', () => switchMode('db2i'));
      el('mode-inv').addEventListener('click', () => switchMode('inv'));
      ['I1', 'beta1', 'beta_r1', 'r1', 'r2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsLog = [], dataLog = [];
        for (let b = 0; b <= 140; b += 10) { labelsLog.push(b); dataLog.push(I0 * Math.pow(10, b / 10)); }
        charts.log = new Chart(el('chart-log'), {
          type: 'line',
          data: { labels: labelsLog, datasets: [{ label: 'I (W/m²)', data: dataLog, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Decibel level (dB)' } }, y: { type: 'logarithmic', title: { display: true, text: 'Intensity (W/m², log scale)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsDist = [], dataDist = [];
        for (let r = 1; r <= 20; r += 1) { labelsDist.push(r); dataDist.push(+(0.01 * Math.pow(1 / r, 2)).toExponential(4)); }
        charts.dist = new Chart(el('chart-dist'), {
          type: 'line',
          data: { labels: labelsDist, datasets: [{ label: 'I (W/m²)', data: dataDist, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Distance (m), source I=0.01 W/m² at r=1m' } }, y: { title: { display: true, text: 'Intensity (W/m²)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: expanding wavefronts ----
      let diagSphere = null;
      function initDiagSphere() {
        const c = el('diag-sphere'); if (!c) throw new Error('no container');
        const s = makeScene(c, 11, new THREE.Vector3(0, 0, 0), OPTS);
        const source = new THREE.Mesh(new THREE.SphereGeometry(0.25, 16, 14), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
        s.scene.add(source);
        [1.5, 3, 4.5].forEach((rad, i) => {
          const geo = new THREE.SphereGeometry(rad, 20, 16);
          const mat = new THREE.MeshBasicMaterial({ color: [0x6366f1, 0xf59e0b, 0x94a3b8][i], wireframe: true, transparent: true, opacity: 0.5 });
          s.scene.add(new THREE.Mesh(geo, mat));
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagSphere = { resize: s.resize };
      }

      // ---- Diagram 2: comparison bars ----
      let diagBars = null;
      function initDiagBars() {
        const c = el('diag-bars'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 1, 0), OPTS);
        const levels = [{ h: 0.4, c: 0x94a3b8, label: 'whisper' }, { h: 1.2, c: 0x6366f1, label: 'conversation' }, { h: 2.6, c: 0xf59e0b, label: 'concert' }, { h: 3.6, c: 0xef4444, label: 'jet' }];
        levels.forEach((lv, i) => {
          const bar = new THREE.Mesh(new THREE.BoxGeometry(0.7, lv.h, 0.7), new THREE.MeshStandardMaterial({ color: lv.c, roughness: 0.5 }));
          bar.position.set(i * 1.1 - 1.65, lv.h / 2, 0);
          s.scene.add(bar);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagBars = { resize: s.resize };
      }

      function boot() {
        try { switchMode('i2db'); } catch (e) { console.error('[sound-intensity] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[sound-intensity] charts failed', e); }
        if (window.THREE) {
          try { initDiagSphere(); } catch (e) { console.error('[sound-intensity] sphere diagram failed', e); }
          try { initDiagBars(); } catch (e) { console.error('[sound-intensity] bars diagram failed', e); }
        }
        mountResize([diagSphere, diagBars]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
