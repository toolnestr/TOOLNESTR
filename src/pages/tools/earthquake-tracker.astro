  <script is:inline>
  // ══ STATE ══
  let eqAllQuakes = [], eqMarkers = [], eqSelectedId = null, eqHeatMode = false;
  let eqCurrentTab = 'map';
  let eqMap = null;
  let eqLastFetchTime = null;

  // ══ HELPERS ══
  const eqMagColor = m => m>=7?'#dc2626':m>=6?'#ef4444':m>=5?'#f97316':m>=2.5?'#f0b429':'#22c55e';
  const eqMagBg    = m => m>=7?'rgba(220,38,38,0.15)':m>=6?'rgba(239,68,68,0.15)':m>=5?'rgba(249,115,22,0.15)':m>=2.5?'rgba(240,180,41,0.15)':'rgba(34,197,94,0.15)';
  const eqMagSize  = m => m>=7?22:m>=6?17:m>=5?13:m>=2.5?9:6;

  function eqTimeAgo(ts) {
    const s = (Date.now()-ts)/1000;
    if(s<60) return `${Math.floor(s)}s ago`;
    if(s<3600) return `${Math.floor(s/60)}m ago`;
    if(s<86400) return `${Math.floor(s/3600)}h ago`;
    return `${Math.floor(s/86400)}d ago`;
  }
  function eqFmtTime(ts) {
    const d = new Date(ts);
    return d.getUTCHours().toString().padStart(2,'0')+':'+d.getUTCMinutes().toString().padStart(2,'0')+' UTC';
  }

  function eqGetFilters() {
    const isMobile = window.innerWidth <= 680;
    return {
      range:  isMobile ? document.getElementById('eqMTimeRange').value  : document.getElementById('eqTimeRange').value,
      sort:   isMobile ? document.getElementById('eqMSortBy').value     : document.getElementById('eqSortBy').value,
      minMag: isMobile ? parseFloat(document.getElementById('eqMMinMag').value) : parseFloat(document.getElementById('eqMinMag').value),
      search: isMobile ? document.getElementById('eqMListSearch').value.toLowerCase() : document.getElementById('eqSearchInput').value.toLowerCase(),
    };
  }

  async function eqFetchQuakes() {
    const { range } = eqGetFilters();
    const urls = {
      hour:  'https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson',
      day:   'https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson',
      week:  'https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_week.geojson',
      month: 'https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_month.geojson'
    };
    try {
      const res  = await fetch(urls[range]);
      const data = await res.json();
      eqAllQuakes  = data.features.filter(f => f.properties.mag !== null);
      eqLastFetchTime = Date.now();
      document.getElementById('eqUpdatedText').textContent = 'Updated ' + eqTimeAgo(eqLastFetchTime);
    } catch(e) {
      const txt = eqLastFetchTime
        ? 'Updated ' + eqTimeAgo(eqLastFetchTime) + ' · retrying'
        : 'Retrying...';
      document.getElementById('eqUpdatedText').textContent = txt;
      setTimeout(eqFetchQuakes, 5000);
      return;
    }
    // Rendering is outside the fetch try/catch — a Leaflet error here
    // won't be mistaken for a network failure and won't trigger retries.
    eqHideLoading();
    eqUpdateStats(); eqRenderList(); eqRenderMarkers();
  }

  function eqUpdateStats() {
    const { minMag } = eqGetFilters();
    const f = eqAllQuakes.filter(q => q.properties.mag >= minMag);
    const maxM = f.length ? Math.max(...f.map(q=>q.properties.mag)) : 0;
    const avgD = f.length ? Math.round(f.reduce((a,q)=>a+(q.geometry.coordinates[2]||0),0)/f.length) : 0;
    document.getElementById('eqSTotal').textContent  = f.length.toLocaleString();
    document.getElementById('eqSStrong').textContent = f.filter(q=>q.properties.mag>=5).length;
    document.getElementById('eqSMajor').textContent  = f.filter(q=>q.properties.mag>=6).length;
    document.getElementById('eqSMax').textContent    = maxM ? 'M'+maxM.toFixed(1) : '—';
    document.getElementById('eqSDepth').textContent  = avgD+'km';
  }

  function eqRenderList() {
    const { minMag, sort, search } = eqGetFilters();
    let f = eqAllQuakes.filter(q => q.properties.mag >= minMag);
    if (search) f = f.filter(q => (q.properties.place||'').toLowerCase().includes(search));
    if (sort==='magnitude') f.sort((a,b)=>b.properties.mag-a.properties.mag);
    else if (sort==='depth') f.sort((a,b)=>b.geometry.coordinates[2]-a.geometry.coordinates[2]);
    else f.sort((a,b)=>b.properties.time-a.properties.time);

    const count = `${f.length.toLocaleString()} earthquakes`;
    document.getElementById('eqListCount').textContent  = count;
    document.getElementById('eqMListCount').textContent = count;

    const html = f.length === 0
      ? `<div class="eq-empty-state"><div class="eq-empty-icon">🔍</div><div class="eq-empty-text">No earthquakes match your filters</div></div>`
      : f.slice(0,200).map(q => {
          const p   = q.properties;
          const mag = (p.mag||0).toFixed(1);
          const dep = q.geometry.coordinates[2]?.toFixed(0)||'?';
          const ago = eqTimeAgo(p.time);
          const col = eqMagColor(p.mag);
          const bg  = eqMagBg(p.mag);
          const isNew = (Date.now()-p.time)<300000;
          return `<div class="eq-quake-item${eqSelectedId===q.id?' active':''}" data-id="${q.id}" onclick="eqSelectQuake('${q.id}')">
            <div class="eq-mag-badge" style="background:${bg};color:${col}">
              <span class="eq-mag-num">${mag}</span><span class="eq-mag-m">MAG</span>
            </div>
            <div class="eq-quake-info">
              <div class="eq-quake-place">${p.place||'Unknown location'}${isNew?'<span class="eq-new-tag">NEW</span>':''}</div>
              <div class="eq-quake-sub"><span>⬇ ${dep} km</span><span>${(p.type||'earthquake').toUpperCase()}</span></div>
            </div>
            <div class="eq-quake-time">${ago}</div>
          </div>`;
        }).join('');

    document.getElementById('eqQuakeList').innerHTML  = html;
    document.getElementById('eqMQuakeList').innerHTML = html;
    eqUpdateStats();
  }

  function eqRenderMarkers() {
    eqMarkers.forEach(m => eqMap.removeLayer(m));
    eqMarkers = [];
    const { minMag } = eqGetFilters();
    eqAllQuakes.filter(q=>q.properties.mag>=minMag).forEach(q=>{
      const [lng,lat] = q.geometry.coordinates;
      const p = q.properties;
      const col  = eqMagColor(p.mag);
      const size = eqMagSize(p.mag);
      const c = L.circleMarker([lat,lng],{ radius:size, fillColor:col, color:col, weight:1, opacity:0.85, fillOpacity: eqHeatMode?0.9:0.55 });
      c.bindTooltip(`M${(p.mag||0).toFixed(1)} — ${p.place||'Unknown'}`,{direction:'top'});
      c.on('click',()=>eqSelectQuake(q.id));
      c.addTo(eqMap); eqMarkers.push(c);
      if(p.mag>=6){
        const ring = L.circleMarker([lat,lng],{ radius:size+8, fillColor:'transparent', color:col, weight:1.5, opacity:0.3, fillOpacity:0 });
        ring.addTo(eqMap); eqMarkers.push(ring);
      }
    });
  }

  function eqSelectQuake(id) {
    const q = eqAllQuakes.find(x=>x.id===id);
    if(!q) return;
    eqSelectedId = id;
    document.querySelectorAll('.eq-quake-item').forEach(el=>el.classList.toggle('active', el.dataset.id===id));

    const p   = q.properties;
    const [lng,lat,depth] = q.geometry.coordinates;
    const mag = (p.mag||0).toFixed(1);
    const col = eqMagColor(p.mag);

    document.getElementById('eqDMag').textContent    = 'M'+mag;
    document.getElementById('eqDMag').style.color    = col;
    document.getElementById('eqDType').textContent   = (p.type||'earthquake').toUpperCase();
    document.getElementById('eqDPlace').textContent  = p.place||'Unknown location';
    document.getElementById('eqDDepth').textContent  = depth?depth.toFixed(1)+' km':'—';
    document.getElementById('eqDTime').textContent   = eqFmtTime(p.time);
    document.getElementById('eqDCoords').textContent = `${lat.toFixed(3)}, ${lng.toFixed(3)}`;
    document.getElementById('eqDFelt').textContent   = p.felt?p.felt.toLocaleString():'None';
    document.getElementById('eqDUsgs').onclick = ()=>window.open(p.url,'_blank');
    document.getElementById('eqDCenter').onclick= ()=>eqMap.setView([lat,lng],6);
    document.getElementById('eqDetailPanel').classList.add('show');

    document.getElementById('eqSMagNum').textContent  = 'M'+mag;
    document.getElementById('eqSMagNum').style.color  = col;
    document.getElementById('eqSType').textContent    = (p.type||'earthquake').toUpperCase();
    document.getElementById('eqSAgo').textContent     = eqTimeAgo(p.time);
    document.getElementById('eqSPlace').textContent   = p.place||'Unknown location';
    document.getElementById('eqSDepthVal').textContent= depth?depth.toFixed(1)+' km':'—';
    document.getElementById('eqSTime').textContent    = eqFmtTime(p.time);
    document.getElementById('eqSLat').textContent     = lat.toFixed(4)+'°';
    document.getElementById('eqSLng').textContent     = lng.toFixed(4)+'°';
    document.getElementById('eqSFeltVal').textContent = p.felt?p.felt.toLocaleString()+' reports':'None reported';
    document.getElementById('eqSUsgs').onclick  = ()=>window.open(p.url,'_blank');
    document.getElementById('eqSCenter').onclick= ()=>{eqMap.setView([lat,lng],6);eqSwitchTab('map');};

    if(window.innerWidth<=680){ eqOpenSheet(); if(eqCurrentTab==='list') eqSwitchTab('map'); }
    eqMap.setView([lat,lng], Math.max(eqMap.getZoom(),4));

    if(p.mag>=5.5){
      const emoji = p.mag>=7?'🔴':p.mag>=6?'🟠':'🟡';
      eqShowToast(emoji, `M${mag} — ${(p.place||'').split(', ').pop()}`, p.mag>=6?'Major earthquake detected':'Moderate earthquake detected', 5000);
    }
  }

  function eqCloseDetail() {
    document.getElementById('eqDetailPanel').classList.remove('show');
    eqSelectedId = null;
    document.querySelectorAll('.eq-quake-item').forEach(e=>e.classList.remove('active'));
  }

  function eqOpenSheet() {
    document.getElementById('eqBottomSheet').classList.add('show');
    document.getElementById('eqSheetBackdrop').style.display='block';
    requestAnimationFrame(()=>document.getElementById('eqSheetBackdrop').classList.add('show'));
  }
  function eqCloseSheet() {
    document.getElementById('eqBottomSheet').classList.remove('show');
    const bd = document.getElementById('eqSheetBackdrop');
    bd.classList.remove('show');
    bd.style.display='none';
    eqSelectedId = null;
    document.querySelectorAll('.eq-quake-item').forEach(e=>e.classList.remove('active'));
  }

  let eqToastQueue = [];
  function eqShowToast(icon, title, sub, duration=4500) {
    document.querySelectorAll('.eq-toast').forEach(t => eqDismissToast(t.id));
    const id = 'eqt_' + Date.now();
    const el = document.createElement('div');
    el.className = 'eq-toast'; el.id = id;
    el.innerHTML = `<div class="eq-toast-emoji">${icon}</div><div class="eq-toast-body"><div class="eq-toast-title">${title}</div><div class="eq-toast-sub">${sub}</div></div><button class="eq-toast-x" id="eqtx_${id}">✕</button><div class="eq-toast-progress" style="animation-duration:${duration}ms"></div>`;
    el.querySelector(`#eqtx_${id}`).addEventListener('click', e => { e.stopPropagation(); eqDismissToast(id); });
    el.addEventListener('click', () => eqDismissToast(id));
    let tx=0,swiping=false;
    el.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;swiping=true;el.style.transition='none';},{passive:true});
    el.addEventListener('touchmove',e=>{if(!swiping)return;const dx=e.touches[0].clientX-tx;if(dx>0)el.style.transform=`translateX(${dx}px)`;},{passive:true});
    el.addEventListener('touchend',e=>{if(!swiping)return;swiping=false;const dx=e.changedTouches[0].clientX-tx;if(dx>60){eqDismissToast(id);}else{el.style.transition='';el.style.transform='';}},{passive:true});
    document.getElementById('eqToastContainer').appendChild(el);
    requestAnimationFrame(()=>requestAnimationFrame(()=>el.classList.add('show')));
    el._timer = setTimeout(()=>eqDismissToast(id), duration);
  }
  function eqDismissToast(id) {
    const el = document.getElementById(id);
    if(!el||el._dismissing) return;
    el._dismissing=true; clearTimeout(el._timer);
    el.style.transition='transform 0.3s ease, opacity 0.3s ease';
    el.style.transform='translateX(110%)'; el.style.opacity='0';
    setTimeout(()=>el.remove(), 320);
  }

  function eqToggleHeat() {
    eqHeatMode = !eqHeatMode;
    document.getElementById('eqHeatBtn').classList.toggle('active', eqHeatMode);
    eqMarkers.forEach(m=>{ if(m.options.radius) m.setStyle({fillOpacity:eqHeatMode?0.9:0.55}); });
  }

  function eqHideLoading() {
    const el = document.getElementById('eqLoadingOverlay');
    el.classList.add('hide');
    setTimeout(()=>el.remove(), 500);
    // Recalculate map size now that the overlay is gone and the container is fully visible
    setTimeout(()=>{ if(eqMap) eqMap.invalidateSize(); }, 100);
  }

  function eqSwitchTab(tab) {
    eqCurrentTab = tab;
    document.getElementById('eqTabMap').classList.toggle('active', tab==='map');
    document.getElementById('eqTabList').classList.toggle('active', tab==='list');
    document.getElementById('eqMobileListPanel').classList.toggle('show', tab==='list');
    if(tab==='map') { eqCloseSheet(); setTimeout(()=>{ if(eqMap) eqMap.invalidateSize(); }, 50); }
  }

  function eqRefreshData() {
    const btn = document.getElementById('eqRefreshBtn');
    btn.classList.add('spinning');
    eqAllQuakes = [];
    eqRenderList(); eqRenderMarkers(); eqFetchQuakes();
    setTimeout(()=>btn.classList.remove('spinning'), 1000);
  }

  function eqResetMapView() {
    eqMap.fitBounds(L.latLngBounds(L.latLng(-85,-180), L.latLng(85,180)), {animate:true,duration:0.8,padding:[0,0]});
  }

  // ══ INIT — load Leaflet dynamically then boot the app ══
  // Size the tool to exactly fill the viewport below the (now non-sticky) site header.
  function eqSizeWrap() {
    const hdr = document.querySelector('header');
    const h = hdr ? Math.round(hdr.getBoundingClientRect().height) : 64;
    document.getElementById('eq-wrap').style.setProperty('--eq-wrap-h', `calc(100svh - ${h}px)`);
    if (eqMap) eqMap.invalidateSize();
  }

  function eqInitApp() {
    eqMap = L.map('eq-map', { center: [20, 0], zoom: 2, minZoom: 1, maxZoom: 18, zoomControl: false, attributionControl: false });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 18 }).addTo(eqMap);

    // Match tool height to the real header height, and keep map sized correctly on resize
    eqSizeWrap();
    window.addEventListener('resize', eqSizeWrap);
    // Re-measure after fonts/layout settle (header height can shift slightly on first paint)
    setTimeout(eqSizeWrap, 200);

    document.getElementById('eqTimeRange').addEventListener('change', eqRefreshData);
    document.getElementById('eqSortBy').addEventListener('change', eqRenderList);
    document.getElementById('eqSearchInput').addEventListener('input', ()=>{ eqRenderList(); eqRenderMarkers(); });
    document.getElementById('eqMListSearch').addEventListener('input', ()=>{ eqRenderList(); eqRenderMarkers(); });
    document.getElementById('eqMinMag').addEventListener('input', function(){
      document.getElementById('eqMagVal').textContent = 'M '+this.value+'+';
      document.getElementById('eqMMinMag').value = this.value;
      document.getElementById('eqMMagVal').textContent = 'M '+this.value+'+';
      eqRenderList(); eqRenderMarkers();
    });
    // ── Mobile filters: apply live (no separate drawer / Apply button) ──
    document.getElementById('eqMTimeRange').addEventListener('change', function(){
      document.getElementById('eqTimeRange').value = this.value;
      eqRefreshData();
    });
    document.getElementById('eqMSortBy').addEventListener('change', function(){
      document.getElementById('eqSortBy').value = this.value;
      eqRenderList();
    });
    document.getElementById('eqMMinMag').addEventListener('input', function(){
      document.getElementById('eqMMagVal').textContent = 'M '+this.value+'+';
      document.getElementById('eqMinMag').value = this.value;
      document.getElementById('eqMagVal').textContent = 'M '+this.value+'+';
      eqRenderList(); eqRenderMarkers();
    });

    (function(){
      const sheet = document.getElementById('eqBottomSheet');
      let startY=0,currentY=0,dragging=false;
      sheet.addEventListener('touchstart',function(e){ if(e.target.closest('button')||e.target.closest('a')) return; startY=e.touches[0].clientY;currentY=0;dragging=true;sheet.style.transition='none'; },{passive:true});
      sheet.addEventListener('touchmove',function(e){ if(!dragging) return; const dy=e.touches[0].clientY-startY; if(dy>0){currentY=dy;sheet.style.transform='translateY('+dy+'px)';} },{passive:true});
      sheet.addEventListener('touchend',function(){ if(!dragging) return; dragging=false; sheet.style.transition=''; if(currentY>100){eqCloseSheet();}else{sheet.style.transform='';} },{passive:true});
    })();

    document.addEventListener('click', e => { if(!e.target.closest('.eq-toast')) document.querySelectorAll('.eq-toast').forEach(t=>eqDismissToast(t.id)); });
    document.addEventListener('touchend', e => { if(!e.target.closest('.eq-toast')) document.querySelectorAll('.eq-toast').forEach(t=>eqDismissToast(t.id)); }, {passive:true});

    setInterval(eqFetchQuakes, 60000);
    eqFetchQuakes();

    setTimeout(()=>{
      const big = eqAllQuakes.find(q=>q.properties.mag>=6.5);
      if(big) eqShowToast('🔴',`M${big.properties.mag.toFixed(1)} — ${big.properties.place||'Unknown location'}`,'Major earthquake recently detected', 6000);
    }, 4000);
  }

  // Dynamically inject Leaflet JS then initialise
  (function() {
    const s = document.createElement('script');
    s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    s.onload = eqInitApp;
    s.onerror = function() {
      document.getElementById('eqUpdatedText').textContent = 'Map library failed to load';
    };
    document.head.appendChild(s);
  })();
  </script>

</BaseLayout>
