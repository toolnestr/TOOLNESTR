---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Exponent Calculator';
const description = 'Calculate x raised to the power of y (x^y) for any real base and exponent. Free online exponent calculator with step-by-step breakdown.';
const intro = 'Compute any base raised to any power — including positive, negative, fractional, and decimal exponents.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is an exponent?', a: 'An exponent (or power) indicates how many times a base number is multiplied by itself. For example, 2³ = 2 × 2 × 2 = 8. The exponent is 3 and the base is 2.' },
  { q: 'What does a negative exponent mean?', a: 'A negative exponent means the reciprocal: x⁻ⁿ = 1 / xⁿ. For example, 2⁻³ = 1 / 2³ = 1/8 = 0.125.' },
  { q: 'What is a fractional exponent?', a: 'A fractional exponent combines a power and a root: x^(m/n) = (ⁿ√x)ᵐ. For example, 8^(2/3) = (³√8)² = 2² = 4.' },
  { q: 'What is a zero exponent?', a: 'Any non-zero number raised to the power of zero equals 1. That is, x⁰ = 1 for any x ≠ 0. The case 0⁰ is undefined in most contexts.' },
  { q: 'What are the laws of exponents?', a: 'The key laws are: xᵃ × xᵇ = x^(a+b), xᵃ / xᵇ = x^(a-b), (xᵃ)ᵇ = x^(a×b), and (xy)ᵃ = xᵃ × yᵃ. These are the foundation for algebraic manipulation.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-3">
      <div class="flex-1 min-w-[140px]">
        <label class="block text-sm font-medium text-slate-700" for="exp-base">Base (x)</label>
        <input id="exp-base" type="number" step="any" value="2" placeholder="e.g. 2"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="flex-1 min-w-[140px]">
        <label class="block text-sm font-medium text-slate-700" for="exp-exponent">Exponent (y)</label>
        <input id="exp-exponent" type="number" step="any" value="10" placeholder="e.g. 10"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>
    <div id="exp-result" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
      <span id="exp-expression" class="text-sm opacity-90">2<sup>10</sup> =</span>
      <span id="exp-value" class="ml-2 text-2xl font-bold">1,024</span>
    </div>
    <div id="exp-step-detail" class="mt-3 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
      <p class="font-semibold text-indigo-700">Step-by-step</p>
      <p id="exp-steps">2 × 2 × 2 × 2 × 2 × 2 × 2 × 2 × 2 × 2 = 1,024</p>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="700" height="320" viewBox="0 0 700 320" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="exp-title exp-desc">
      <title id="exp-title">Exponent rules reference table</title>
      <desc id="exp-desc">A table showing the five major exponent laws: product of powers, quotient of powers, power of a power, power of a product, and negative exponent rule.</desc>
      <rect x="30" y="20" width="640" height="280" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" />
      <rect x="30" y="20" width="640" height="40" rx="8" fill="#6366f1" />
      <rect x="30" y="56" width="640" height="4" fill="#6366f1" />
      <text x="350" y="47" text-anchor="middle" fill="#fff" font-size="15" font-weight="bold">Exponent Rules</text>
      <text x="50" y="85" fill="#4338ca" font-size="13" font-weight="bold">Rule</text>
      <text x="370" y="85" fill="#4338ca" font-size="13" font-weight="bold">Formula</text>
      <text x="50" y="115" fill="#1e293b" font-size="13">Product</text>
      <text x="370" y="115" fill="#6366f1" font-size="14" font-weight="bold">x<sup>a</sup> · x<sup>b</sup> = x<sup>a+b</sup></text>
      <line x1="50" y1="125" x2="650" y2="125" stroke="#e2e8f0" stroke-width="1" />
      <text x="50" y="152" fill="#1e293b" font-size="13">Quotient</text>
      <text x="370" y="152" fill="#6366f1" font-size="14" font-weight="bold">x<sup>a</sup> / x<sup>b</sup> = x<sup>a−b</sup></text>
      <line x1="50" y1="162" x2="650" y2="162" stroke="#e2e8f0" stroke-width="1" />
      <text x="50" y="189" fill="#1e293b" font-size="13">Power of a Power</text>
      <text x="370" y="189" fill="#6366f1" font-size="14" font-weight="bold">(x<sup>a</sup>)<sup>b</sup> = x<sup>a·b</sup></text>
      <line x1="50" y1="199" x2="650" y2="199" stroke="#e2e8f0" stroke-width="1" />
      <text x="50" y="226" fill="#1e293b" font-size="13">Product Power</text>
      <text x="370" y="226" fill="#6366f1" font-size="14" font-weight="bold">(x·y)<sup>a</sup> = x<sup>a</sup>·y<sup>a</sup></text>
      <line x1="50" y1="236" x2="650" y2="236" stroke="#e2e8f0" stroke-width="1" />
      <text x="50" y="263" fill="#1e293b" font-size="13">Negative Exponent</text>
      <text x="370" y="263" fill="#6366f1" font-size="14" font-weight="bold">x<sup>−a</sup> = 1 / x<sup>a</sup></text>
      <line x1="50" y1="273" x2="650" y2="273" stroke="#e2e8f0" stroke-width="1" />
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The five fundamental exponent laws that govern how powers interact in algebraic expressions.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How exponentiation works</h2>
    <p class="mt-2 text-slate-600">Exponentiation is a mathematical operation that involves two numbers: the base <var>x</var> and the exponent <var>y</var>. When <var>y</var> is a positive integer, x<sup>y</sup> simply means multiplying <var>x</var> by itself <var>y</var> times. For example, 2<sup>5</sup> = 2 × 2 × 2 × 2 × 2 = 32. This is the simplest case and the foundation for understanding more complex exponents.</p>
    <p class="mt-3 text-slate-600">When the exponent is zero, any non-zero base raised to the power of zero equals 1. This follows from the quotient rule: x<sup>a</sup> / x<sup>a</sup> = 1, and by the quotient law, this equals x<sup>a-a</sup> = x<sup>0</sup> = 1. A negative exponent indicates the reciprocal: x<sup>-n</sup> = 1 / x<sup>n</sup>. So 2<sup>-3</sup> = 1 / 2<sup>3</sup> = 1/8.</p>
    <p class="mt-3 text-slate-600">Fractional exponents combine powers and roots. The exponent <var>m/n</var> means taking the nth root first then raising to the mth power (or vice versa): x<sup>m/n</sup> = (ⁿ√x)ᵐ. For instance, 8<sup>2/3</sup> = (³√8)² = 2² = 4. Decimal exponents like 2<sup>0.5</sup> are equivalent to fractional exponents and are computed using the same root-power relationship.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Basic exponent formula</h3>
        <p class="mt-1 font-mono text-lg font-bold text-indigo-700">x<sup>y</sup> = x × x × ... × x (y times)</p>
        <p class="mt-2 text-sm text-slate-600">For positive integer exponents, this is straightforward multiplication repeated y times. For other exponents, the calculator uses the general power function.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">General case</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">x<sup>y</sup> = exp(y × ln(x))</p>
        <p class="mt-2 text-sm text-slate-600">For real exponents, the calculator uses the identity x<sup>y</sup> = e<sup>y × ln(x)</sup>, where ln is the natural logarithm and exp is the exponential function.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: 2<sup>10</sup></h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>Step 1: Base = 2, Exponent = 10 (positive integer)</p>
        <p>Step 2: Multiply 2 by itself 10 times: 2 × 2 × 2 × 2 × 2 × 2 × 2 × 2 × 2 × 2</p>
        <p>Step 3: Compute sequentially: 2² = 4, 2³ = 8, 2⁴ = 16, 2⁵ = 32, 2⁶ = 64, 2⁷ = 128, 2⁸ = 256, 2⁹ = 512, 2¹⁰ = 1,024</p>
        <p class="font-semibold text-emerald-700">Therefore: 2<sup>10</sup> = 1,024</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Investors &amp; Finance</h3>
      <p class="mt-1 text-sm text-slate-600">Compound interest uses exponential growth: A = P(1 + r)<sup>t</sup>. Understanding exponents helps you model investment growth over time, calculate loan amortization, and project future values of assets with compound returns.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4D0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students</h3>
      <p class="mt-1 text-sm text-slate-600">Exponents are the foundation of algebra, appearing in polynomials, exponential functions, and scientific notation. Mastering exponents is essential for calculus, physics, chemistry, and engineering coursework at every level.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Computer Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">Exponents describe algorithm complexity (2<sup>n</sup> for exponential time), data storage (2<sup>10</sup> = 1,024 bytes in a kilobyte), and numeric representation in floating-point systems. Exponents are central to computational theory.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Scientists &amp; Engineers</h3>
      <p class="mt-1 text-sm text-slate-600">Exponential functions model radioactive decay, population growth, signal attenuation, and many natural phenomena. Scientific notation uses powers of 10 to represent very large and very small numbers compactly.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the exponent calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the base</h3>
        <p class="mt-1 text-sm text-slate-600">Type the base number (x) that you want to raise to a power. This can be any real number — positive, negative, integer, or decimal.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the exponent</h3>
        <p class="mt-1 text-sm text-slate-600">Type the exponent (y). This can be any real number — positive, negative, integer, fractional, or decimal. The calculator handles all cases.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The result appears instantly with the expression shown. For integer exponents, a step-by-step multiplication breakdown is displayed below.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with exponents</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Order of operations matters</h3>
        <p class="mt-1 text-sm text-slate-600">In expressions like -2⁴, the exponent is applied before the negative sign by convention: -(2⁴) = -16. The parentheses in (-2)⁴ = 16 change the result. Always use parentheses to avoid ambiguity when the base is negative.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Exponents grow very fast</h3>
        <p class="mt-1 text-sm text-slate-600">Exponential growth is deceptive. 2¹⁰ = 1,024 might seem manageable, but 2²⁰ = 1,048,576, and 2³⁰ = 1,073,741,824. Each addition of 10 to the exponent multiplies the result by roughly 1,000. This rapid growth is why exponentials model compound interest, population explosions, and computing power.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Fractional exponent tricks</h3>
        <p class="mt-1 text-sm text-slate-600">When dealing with fractional exponents, remember that x<sup>1/2</sup> = √x, x<sup>1/3</sup> = ³√x, and x<sup>2/3</sup> = (³√x)². The denominator of the fraction indicates the root and the numerator indicates the power. You can take the root first or apply the power first — the result is the same.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Beware of overflow</h3>
        <p class="mt-1 text-sm text-slate-600">Very large exponents can produce numbers that exceed the maximum representable value in JavaScript (about 1.79 × 10³⁰⁸). The calculator will display "Infinity" in such cases. For practical purposes, most real-world applications stay well within these bounds.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/square-root-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x221A;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Square Root Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate square roots, cube roots, and any nth root of any number.</p>
      </a>
      <a href="/tools/logarithm-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4CA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Logarithm Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate logarithms and apply the change-of-base formula.</p>
      </a>
      <a href="/tools/exponential-growth-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4C8;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Exponential Growth Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Project values over time with exponential growth and decay models.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const expBase = document.getElementById('exp-base');
    const expExponent = document.getElementById('exp-exponent');
    const expExpression = document.getElementById('exp-expression');
    const expValue = document.getElementById('exp-value');
    const expResult = document.getElementById('exp-result');
    const expSteps = document.getElementById('exp-steps');
    const expStepDetail = document.getElementById('exp-step-detail');

    function calculate() {
      const base = parseFloat(expBase.value);
      const exp = parseFloat(expExponent.value);

      if (isNaN(base) || isNaN(exp)) {
        expExpression.innerHTML = '<em>enter values</em>';
        expValue.textContent = '—';
        expStepDetail.classList.add('hidden');
        return;
      }

      const result = Math.pow(base, exp);

      expExpression.innerHTML = `${base.toLocaleString()}<sup>${exp.toLocaleString()}</sup> =`;

      if (!isFinite(result)) {
        expValue.textContent = result > 0 ? 'Infinity' : '-Infinity';
        expStepDetail.classList.add('hidden');
        expResult.classList.remove('bg-emerald-600', 'bg-red-600');
        expResult.classList.add('bg-indigo-600');
        return;
      }

      if (isNaN(result)) {
        expValue.textContent = 'Undefined';
        expStepDetail.classList.add('hidden');
        expResult.classList.remove('bg-emerald-600', 'bg-indigo-600');
        expResult.classList.add('bg-red-600');
        return;
      }

      expResult.classList.remove('bg-red-600');
      expResult.classList.add('bg-indigo-600');

      const displayResult = result.toLocaleString(undefined, { maximumFractionDigits: 10 });
      expValue.textContent = displayResult;

      if (Number.isInteger(exp) && exp > 0 && exp <= 100 && Number.isFinite(result)) {
        const parts = [];
        for (let i = 0; i < exp; i++) parts.push(base);
        const multiplication = parts.join(' × ');
        expSteps.textContent = `${multiplication} = ${displayResult}`;
        expStepDetail.classList.remove('hidden');
      } else if (Number.isInteger(exp) && exp < 0 && exp >= -100) {
        const posExp = Math.abs(exp);
        const parts = [];
        for (let i = 0; i < posExp; i++) parts.push(base);
        const multiplication = parts.join(' × ');
        expSteps.innerHTML = `1 / (${multiplication}) = 1 / ${Math.pow(base, posExp).toLocaleString(undefined, { maximumFractionDigits: 10 })} = ${displayResult}`;
        expStepDetail.classList.remove('hidden');
      } else if (exp % 1 !== 0) {
        const frac = exp.toString();
        expSteps.innerHTML = `${base.toLocaleString()}<sup>${frac}</sup> = exp(${frac} × ln(${base.toLocaleString()})) = ${displayResult}`;
        expStepDetail.classList.remove('hidden');
      } else {
        expStepDetail.classList.add('hidden');
      }
    }

    expBase.addEventListener('input', calculate);
    expExponent.addEventListener('input', calculate);
    calculate();
  </script>
</ToolLayout>
