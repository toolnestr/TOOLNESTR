---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Tote/Bag Size & Fabric Calculator';
const description = 'Calculate fabric needed for a tote bag, including gusseted sides and handles, from finished bag dimensions.';
const intro = 'Calculate fabric needed for a tote bag from finished width, height, gusset depth, and handle length.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is a gusset on a tote bag?', a: 'A gusset is the side/bottom panel that gives a bag depth, turning a flat two-panel pouch into a bag that can actually hold volume — set gusset depth to 0 for a flat tote with no boxed bottom.' },
  { q: 'How long should tote bag handles be?', a: 'Shoulder-carry handles are typically 24-28 inches finished length (before folding/sewing); shorter hand-carry handles are often 18-20 inches — this varies by personal preference and how the bag is meant to be worn or carried.' },
  { q: 'Does this include lining fabric?', a: 'No — this calculates the main shell fabric and handles only. If your tote is lined, use the Lining Fabric Calculator separately, treating the tote body dimensions the same way.' },
  { q: 'Should I add extra for interfacing or stabilizer?', a: 'A structured tote often uses interfacing or a stiff stabilizer on the main panels; calculate that separately using the Interfacing/Stabilizer Yardage Calculator based on the same panel dimensions.' },
];
const howTo = {
  name: 'How to calculate tote bag fabric',
  steps: [
    { name: 'Enter finished bag dimensions', text: 'Enter the finished bag width, height, and gusset depth (0 for a flat tote).' },
    { name: 'Enter seam allowance and handles', text: 'Enter your seam allowance and desired handle length and width.' },
    { name: 'Read total fabric needed', text: 'The total fabric needed for the bag body and handles appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Finished width (in)</span>
        <input id="width" type="number" step="any" placeholder="e.g. 16" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Finished height (in)</span>
        <input id="height" type="number" step="any" placeholder="e.g. 14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gusset depth (in, 0 for flat)</span>
        <input id="gusset" type="number" step="any" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Seam allowance (in)</span>
        <input id="sa" type="number" step="any" value="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Handle length, each (in)</span>
        <input id="handleLen" type="number" step="any" value="26" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Handle width, cut (in)</span>
        <input id="handleWid" type="number" step="any" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block sm:col-span-2"><span class="text-sm font-medium text-slate-700">Fabric width (in)</span>
        <input id="fabWid" type="number" step="any" value="44" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total fabric needed</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tbc-title tbc-desc">
      <title id="tbc-title">Tote bag with body panels, gusset, and handles labeled</title>
      <desc id="tbc-desc">A tote bag outline showing the front and back panels, a side gusset strip, and two handle straps</desc>
      <rect x="300" y="40" width="180" height="130" fill="#fecdd3" stroke="#e11d48" stroke-width="2" />
      <rect x="260" y="60" width="30" height="110" fill="#fda4af" stroke="#e11d48" stroke-width="1.5" />
      <path d="M330 40 Q330 10 360 10 Q390 10 390 40" fill="none" stroke="#e11d48" stroke-width="4" />
      <path d="M400 40 Q400 10 430 10 Q460 10 460 40" fill="none" stroke="#e11d48" stroke-width="4" />
      <text x="390" y="185" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Body + gusset + handles</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A gusseted tote needs body panels, a side/bottom gusset, and handle fabric</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How tote bag fabric is calculated</h2>
    <p class="mt-2 text-slate-600">
      This calculator treats the tote body the same way as a box cushion: two main panels (front and back), each the finished width and height plus seam allowance, plus a gusset strip that wraps around the sides and bottom if the bag has depth. The gusset's length equals the bag's perimeter along the sides and bottom, and its width equals the gusset depth plus seam allowance.
    </p>
    <p class="mt-3 text-slate-600">
      Handles are calculated separately and added to the total: two handles, each cut to your specified length and width (which typically gets folded and stitched down to a narrower finished strap), using a small additional length of fabric on top of the body panels and gusset.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows standard bag-making construction for a basic gusseted or flat tote with sewn-on fabric handles.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 16 × 14 inch tote, 4-inch gusset, 0.5-inch seam allowance, two 26-inch handles, 44-inch fabric.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Panel size (each):</span> <span class="text-slate-600">17 × 15 in</span></div>
        <div><span class="font-medium text-slate-700">Body length (2 panels):</span> <span class="text-slate-600">2 × 15 = 30 in</span></div>
        <div><span class="font-medium text-slate-700">Gusset:</span> <span class="text-slate-600">perimeter ≈ 2×(16+15)=62 in</span></div>
        <div><span class="font-medium text-slate-700">Handles:</span> <span class="text-slate-600">2 × 26 = 52 in</span></div>
        <div><span class="font-medium text-slate-700">Total fabric:</span> <span class="text-slate-600">(30+62+52)/36 ≈ <strong>4.0 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Reusable grocery totes and market bags are one of the most common bag-sewing projects, and getting the gusset depth right upfront determines whether the finished bag can actually hold a reasonable grocery load or ends up too shallow and awkward to pack — planning fabric before cutting avoids discovering a too-small gusset only after construction.
    </p>
    <p class="mt-3 text-slate-600">
      Matching fabric for multiple totes made as a batch (like holiday gift bags for a group) benefits from calculating combined yardage in advance, since buying one larger cut of fabric is often more efficient and cost-effective than several smaller separate purchases.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A flat tote and a gusseted tote need about the same fabric." <strong class="text-slate-900">Not usually.</strong> The gusset strip on a boxed-bottom tote adds meaningfully more fabric than a flat, two-panel tote of the same width and height, similar to how a box cushion needs more fabric than a flat pillow cover.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Handle fabric is negligible and doesn't need planning." <strong class="text-slate-900">It adds up.</strong> Two long handles can use a meaningful amount of extra fabric, especially on a bag already sized close to a fabric width limit — always include handles in the total calculation, not just the body panels.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pillow-box-cushion-fabric-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Pillow/Box Cushion Fabric Calculator</a>
      <a href="/tools/interfacing-stabilizer-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Interfacing/Stabilizer Yardage Calculator</a>
      <a href="/tools/fabric-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Cost Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const width = parseFloat(el('width').value);
      const height = parseFloat(el('height').value);
      const gusset = parseFloat(el('gusset').value) || 0;
      const sa = parseFloat(el('sa').value) || 0;
      const handleLen = parseFloat(el('handleLen').value) || 0;
      const handleWid = parseFloat(el('handleWid').value) || 0;
      const fabWid = parseFloat(el('fabWid').value);
      if (!width || !height || !fabWid || width <= 0 || height <= 0 || fabWid <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const panelW = width + 2 * sa;
      const panelH = height + 2 * sa;
      let totalIn = 2 * panelH; // front + back panel length (assuming fits width-wise)

      if (gusset > 0) {
        const perimeter = 2 * (width + height);
        totalIn += perimeter;
      }

      totalIn += 2 * handleLen; // two handles

      el('r-yards').textContent = (totalIn / 36).toFixed(2) + ' yd';
      el('results').classList.remove('hidden');
    }

    ['width', 'height', 'gusset', 'sa', 'handleLen', 'handleWid', 'fabWid'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
