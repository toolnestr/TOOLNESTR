---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Capacitance Calculator';
const description = 'Capacitance calculator with a live 3D parallel-plate diagram and charts. Solve C = Q/V or the parallel-plate formula C = ε₀εᵣA/d, plus stored energy, with worked examples.';
const intro = 'Solve C = Q/V for capacitance, charge, or voltage, or use the parallel-plate formula C = ε₀εᵣA/d to find capacitance from plate area, separation, and dielectric constant. Two 3D diagrams compare a lightly and heavily charged capacitor, and charts show how capacitance and stored energy scale.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is capacitance?', a: 'Capacitance is a measure of how much electric charge a component can store per volt of potential difference across it: C = Q/V. It is measured in farads (F), though most practical capacitors are in the microfarad (μF), nanofarad (nF), or picofarad (pF) range.' },
  { q: 'What is the parallel-plate capacitor formula?', a: 'For two parallel conducting plates of area A separated by distance d with a dielectric of relative permittivity εᵣ between them, C = ε₀εᵣA/d, where ε₀ ≈ 8.854×10⁻¹² F/m is the permittivity of free space. Larger plates or a closer spacing both increase capacitance.' },
  { q: 'How much energy does a capacitor store?', a: 'A charged capacitor stores energy E = ½CV² = ½QV = Q²/(2C). All three forms are equivalent — pick whichever matches the variables you already know.' },
  { q: 'What does the dielectric constant εᵣ do?', a: 'εᵣ (relative permittivity) describes how much a material between the plates increases capacitance compared to vacuum (εᵣ = 1). Common dielectrics like paper, mica, or ceramic have εᵣ from about 2 to several thousand, letting capacitors pack much more capacitance into the same physical size.' },
  { q: 'Why does capacitance decrease as plate separation increases?', a: 'C = ε₀εᵣA/d is inversely proportional to the separation d. Pulling the plates apart weakens the electric field they can sustain for a given charge, so a larger voltage results from the same charge — and since C = Q/V, a bigger V for the same Q means a smaller C.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Capacitance Calculator',
  description: 'Calculate capacitance, charge, or voltage from C = Q/V, or use plate geometry with C = ε₀εᵣA/d.',
  steps: [
    { name: 'Pick a mode', text: 'Choose "From Q and V" for a simple charge/voltage calculation, or "Parallel-plate" to compute capacitance from plate geometry.' },
    { name: 'Enter the known values', text: 'In Q/V mode, enter charge and voltage (or capacitance) to solve for the third. In parallel-plate mode, enter area, separation, and dielectric constant.' },
    { name: 'Read the result', text: 'Capacitance and stored energy solve instantly, and the 3D diagrams and charts update.' },
  ],
};

const formulas = [
  { expr: 'C = Q / V', note: 'capacitance from charge and voltage' },
  { expr: 'C = ε₀ εᵣ A / d', note: 'parallel-plate capacitance; ε₀ ≈ 8.854×10⁻¹² F/m' },
  { expr: 'E = ½CV² = ½QV = Q²/(2C)', note: 'energy stored in a charged capacitor' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — charge and stored energy', tone: 'slate',
    given: 'A 100 μF (100×10⁻⁶ F) capacitor is charged to 12 V. Find the charge stored and the energy stored.',
    rows: [
      { label: 'Formula:', value: 'Q = C × V' },
      { label: 'Substitute:', value: 'Q = 100×10⁻⁶ × 12 = 0.0012 C = 1.2 mC' },
      { label: 'Energy:', value: 'E = ½CV² = ½ × 100×10⁻⁶ × 12² = 0.0072 J' },
      { label: 'Result:', value: 'Q = 1.2 mC, E = 7.2 mJ', full: true },
    ],
    note: 'All three energy formulas (½CV², ½QV, Q²/2C) give the same 7.2 mJ result — they are algebraically equivalent.',
  },
  {
    title: 'Worked example 2 — parallel-plate capacitance', tone: 'amber',
    given: 'Two parallel plates of area A = 0.02 m² are separated by d = 0.001 m in vacuum/air (εᵣ = 1). Find the capacitance.',
    rows: [
      { label: 'Formula:', value: 'C = ε₀ εᵣ A / d' },
      { label: 'Substitute:', value: 'C = 8.854×10⁻¹² × 1 × 0.02 / 0.001' },
      { label: 'Result:', value: 'C = 1.7708×10⁻¹⁰ F ≈ 177.08 pF', full: true },
    ],
    note: 'Doubling the plate area or halving the separation would each double this capacitance.',
  },
];

const comparison = {
  heading: 'Capacitance vs resistance — series and parallel behavior',
  note: 'Capacitors combine the opposite way resistors do: capacitances add directly in parallel, and add as reciprocals in series.',
  headers: [{ label: 'Property' }, { label: 'Capacitors' }, { label: 'Resistors' }],
  rows: [
    ['Series combination', '1/C_total = 1/C1 + 1/C2 + ...', 'R_total = R1 + R2 + ...'],
    ['Parallel combination', 'C_total = C1 + C2 + ...', '1/R_total = 1/R1 + 1/R2 + ...'],
    ['Stores', 'Charge / energy in an electric field', 'Dissipates energy as heat'],
    ['Units', 'Farad (F)', 'Ohm (Ω)'],
  ],
  highlightIndex: 1,
  footnote: 'This inverse relationship is why capacitors in parallel are used to boost total capacitance, while resistors in series are used to add up total resistance.',
};

const realWorld = [
  { emoji: '🔋', title: 'Energy storage and smoothing', body: 'Capacitors smooth out voltage ripples in power supplies and store short bursts of energy for camera flashes, defibrillators, and backup power during brief outages, releasing their stored charge almost instantly when needed.' },
  { emoji: '📱', title: 'Touchscreens', body: 'Capacitive touchscreens sense the small change in capacitance created when a conductive fingertip approaches the screen\'s grid of electrodes, letting the device pinpoint touch location without any moving parts.' },
  { emoji: '🎚️', title: 'Timing and filter circuits', body: 'Paired with resistors, capacitors set the timing constant (RC) in oscillators, debounce circuits, and audio filters — charging and discharging at a predictable rate that engineers tune by choosing C.' },
  { emoji: '⚡', title: 'Memory and DRAM cells', body: 'Each bit in a computer\'s dynamic RAM (DRAM) is stored as a tiny electric charge on a microscopic capacitor, which is why DRAM must be "refreshed" thousands of times per second before that stored charge leaks away.' },
];

const misconceptions = [
  { claim: '"A bigger capacitor always stores more energy no matter the voltage."', truth: "Energy is E = ½CV², so voltage matters just as much as capacitance — a small capacitor charged to a high voltage can store more energy than a large one at a low voltage, since energy scales with the square of V." },
  { claim: '"Capacitance depends on how much charge is on the plates."', truth: 'Capacitance C = Q/V is actually a fixed geometric property of the capacitor (plate area, separation, dielectric) — it does not change as you charge or discharge it. Q and V both scale together, keeping their ratio C constant.' },
  { claim: '"Adding a dielectric always increases the voltage a capacitor can hold for the same charge."', truth: 'A dielectric with εᵣ > 1 increases capacitance, which for a fixed charge Q actually decreases the voltage (since V = Q/C) — dielectrics let you store more charge at a given voltage, not more voltage at a given charge.' },
  { claim: '"Capacitors in series add like resistors in series."', truth: 'They combine the opposite way: capacitors in series add as reciprocals (1/C_total = 1/C1 + 1/C2 + ...), while capacitors in parallel add directly (C_total = C1 + C2 + ...) — the reverse of how resistors combine.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — §8.1 "Capacitors and Capacitance" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/8-1-capacitors-and-capacitance" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 25, Capacitance.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 26, Capacitance and Dielectrics.' },
];
const sourcesNote = 'C = Q/V and C = ε₀εᵣA/d with ε₀ ≈ 8.854×10⁻¹² F/m. Energy E = ½CV². Results are rounded for display.';

const howToUse = [
  { title: 'Pick a mode', body: 'Use "From Q and V" for the basic C = Q/V relationship, or "Parallel-plate" for geometry-based capacitance.' },
  { title: 'Enter your known values', body: 'Use scientific notation for small values, e.g. 100e-6 for 100 μF or 1e-3 for 1 mm.' },
  { title: 'Check the energy and diagrams', body: 'Stored energy is computed automatically, and the 3D diagrams show field density at different charge levels.' },
];

const related = [
  { href: '/tools/series-resistor-calculator', emoji: '🔌', title: 'Series Resistor Calculator', desc: 'R_total = R1 + R2 + ... for resistors in series.' },
  { href: '/tools/parallel-resistor-calculator', emoji: '🔋', title: 'Parallel Resistor Calculator', desc: 'Total resistance and branch currents for parallel resistors.' },
  { href: '/tools/ohms-law-calculator', emoji: '🔗', title: "Ohm's Law Calculator", desc: 'V = IR — solve voltage, current, or resistance.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="Capacitance measures how much charge a component stores per volt across it — a fixed geometric property set by plate area, separation, and any dielectric material between the plates."
  howIntro="Rearranged, C = Q/V solves any variable: Q = CV and V = Q/C. For a parallel-plate capacitor, C = ε₀εᵣA/d shows that capacitance grows with plate area and dielectric constant, and shrinks as the plates move apart. Once you know C and V (or Q), the energy stored follows from E = ½CV² = ½QV = Q²/(2C) — three equivalent forms of the same result."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where capacitance actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Mode:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-qv" type="button" data-mode="qv" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From Q and V</button>
      <button id="mode-plate" type="button" data-mode="plate" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Parallel-plate</button>
    </div>

    <!-- Q/V panel -->
    <div id="panel-qv">
      <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
      <div class="mb-4 flex flex-wrap gap-2">
        <button id="qvmode-c" type="button" data-solve="c" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Capacitance (C)</button>
        <button id="qvmode-q" type="button" data-solve="q" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Charge (Q)</button>
        <button id="qvmode-v" type="button" data-solve="v" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Voltage (V)</button>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <label id="field-c" class="block"><span class="text-sm font-medium text-slate-700">Capacitance (C)</span>
          <input id="c" type="number" step="any" placeholder="F, e.g. 100e-6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label id="field-q" class="block"><span class="text-sm font-medium text-slate-700">Charge (Q)</span>
          <input id="q" type="number" step="any" placeholder="C" value="0.0012" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label id="field-v" class="block"><span class="text-sm font-medium text-slate-700">Voltage (V)</span>
          <input id="v" type="number" step="any" placeholder="V" value="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div id="box-c" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Capacitance</div><div id="r-c" class="mt-1 text-2xl font-bold">—</div></div>
        <div id="box-q" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Charge</div><div id="r-q" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
        <div id="box-v" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Voltage</div><div id="r-v" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      </div>
      <div class="mt-3 rounded-xl bg-slate-50 p-4 text-center">
        <div class="text-sm text-slate-500">Energy stored</div><div id="r-energy" class="mt-1 text-xl font-bold text-slate-800">—</div>
      </div>
      <p id="cap-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
    </div>

    <!-- Parallel-plate panel -->
    <div id="panel-plate" class="hidden">
      <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
      <div class="mb-4 flex flex-wrap gap-2">
        <button id="platemode-c" type="button" data-solve="c" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Capacitance (C)</button>
        <button id="platemode-a" type="button" data-solve="a" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Area (A)</button>
        <button id="platemode-d" type="button" data-solve="d" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Separation (d)</button>
      </div>
      <div class="grid gap-4 sm:grid-cols-4">
        <label id="field-pc" class="block"><span class="text-sm font-medium text-slate-700">Capacitance (C)</span>
          <input id="pc" type="number" step="any" placeholder="F" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label id="field-a" class="block"><span class="text-sm font-medium text-slate-700">Area (A)</span>
          <input id="a" type="number" step="any" placeholder="m²" value="0.02" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label id="field-d" class="block"><span class="text-sm font-medium text-slate-700">Separation (d)</span>
          <input id="d" type="number" step="any" placeholder="m" value="0.001" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Dielectric const. (εᵣ)</span>
          <input id="er" type="number" step="any" placeholder="1 for vacuum/air" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div id="box-pc" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Capacitance</div><div id="r-pc" class="mt-1 text-2xl font-bold">—</div></div>
        <div id="box-a" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Area</div><div id="r-a" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
        <div id="box-d" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Separation</div><div id="r-d" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      </div>
      <p id="plate-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
    </div>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two states of a charged capacitor</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-lowcharge" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Lightly charged plates</h3>
          <p class="mt-1 text-sm text-slate-600">Two parallel plates at a <span class="font-semibold text-slate-500">lower charge/voltage</span> — the field lines between them are sparse, reflecting a weaker electric field.</p>
        </div>
        <div>
          <div id="diag-highcharge" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Heavily charged plates</h3>
          <p class="mt-1 text-sm text-slate-600">The same plates at a <span class="font-semibold text-amber-500">higher charge/voltage</span> — the field lines are much denser, showing the stronger field between the plates.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Capacitance and energy graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Capacitance vs plate separation d (fixed A = 0.02 m², εᵣ = 1) — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-d"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Energy vs V² (fixed C = 100 μF) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-e"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };
      const EPS0 = 8.854e-12;

      // ---- mode switching (Q/V vs parallel-plate) ----
      let mode = 'qv';
      function switchMode(m) {
        mode = m;
        el('mode-qv').className = m === 'qv' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-plate').className = m === 'plate' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('panel-qv').classList.toggle('hidden', m !== 'qv');
        el('panel-plate').classList.toggle('hidden', m !== 'plate');
      }
      el('mode-qv').addEventListener('click', () => switchMode('qv'));
      el('mode-plate').addEventListener('click', () => switchMode('plate'));

      // ---- Q/V panel ----
      let qvSolve = 'c';
      const qvModeBtns = { c: 'qvmode-c', q: 'qvmode-q', v: 'qvmode-v' };
      const qvFieldEls = { c: 'field-c', q: 'field-q', v: 'field-v' };
      const qvBoxEls = { c: 'box-c', q: 'box-q', v: 'box-v' };

      function switchQvSolve(s) {
        qvSolve = s;
        Object.keys(qvModeBtns).forEach((k) => {
          el(qvModeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(qvFieldEls).forEach((k) => { el(qvFieldEls[k]).style.opacity = k === s ? '0.45' : '1'; });
        Object.keys(qvBoxEls).forEach((k) => {
          el(qvBoxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        updateQv();
      }

      function updateQv() {
        el('cap-err').textContent = '';
        ['r-c', 'r-q', 'r-v'].forEach((id) => (el(id).textContent = '—'));
        el('r-energy').textContent = '—';
        const c = parseFloat(el('c').value);
        const q = parseFloat(el('q').value);
        const v = parseFloat(el('v').value);
        let C, Q, V;
        if (qvSolve === 'c') {
          if (isNaN(q) || isNaN(v)) return;
          if (v === 0) { el('cap-err').textContent = 'Voltage cannot be zero when solving for capacitance.'; return; }
          C = q / v; Q = q; V = v;
        } else if (qvSolve === 'q') {
          if (isNaN(c) || isNaN(v)) return;
          C = c; Q = c * v; V = v;
        } else {
          if (isNaN(c) || isNaN(q)) return;
          if (c === 0) { el('cap-err').textContent = 'Capacitance cannot be zero when solving for voltage.'; return; }
          C = c; Q = q; V = q / c;
        }
        el('r-c').textContent = fmt(C) + ' F';
        el('r-q').textContent = fmt(Q) + ' C';
        el('r-v').textContent = fmt(V) + ' V';
        el('r-energy').textContent = fmt(0.5 * C * V * V) + ' J';
        updateDiagrams(V);
      }
      el('qvmode-c').addEventListener('click', () => switchQvSolve('c'));
      el('qvmode-q').addEventListener('click', () => switchQvSolve('q'));
      el('qvmode-v').addEventListener('click', () => switchQvSolve('v'));
      ['c', 'q', 'v'].forEach((id) => el(id).addEventListener('input', updateQv));

      // ---- parallel-plate panel ----
      let plateSolve = 'c';
      const plateModeBtns = { c: 'platemode-c', a: 'platemode-a', d: 'platemode-d' };
      const plateFieldEls = { c: 'field-pc', a: 'field-a', d: 'field-d' };
      const plateBoxEls = { c: 'box-pc', a: 'box-a', d: 'box-d' };

      function switchPlateSolve(s) {
        plateSolve = s;
        Object.keys(plateModeBtns).forEach((k) => {
          el(plateModeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(plateFieldEls).forEach((k) => { el(plateFieldEls[k]).style.opacity = k === s ? '0.45' : '1'; });
        Object.keys(plateBoxEls).forEach((k) => {
          el(plateBoxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        updatePlate();
      }

      function updatePlate() {
        el('plate-err').textContent = '';
        ['r-pc', 'r-a', 'r-d'].forEach((id) => (el(id).textContent = '—'));
        const c = parseFloat(el('pc').value);
        const a = parseFloat(el('a').value);
        const d = parseFloat(el('d').value);
        const er = parseFloat(el('er').value);
        if (isNaN(er) || er <= 0) { el('plate-err').textContent = 'Dielectric constant must be positive.'; return; }
        let C, A, D;
        if (plateSolve === 'c') {
          if (isNaN(a) || isNaN(d)) return;
          if (d === 0) { el('plate-err').textContent = 'Separation cannot be zero.'; return; }
          C = EPS0 * er * a / d; A = a; D = d;
        } else if (plateSolve === 'a') {
          if (isNaN(c) || isNaN(d)) return;
          A = (c * d) / (EPS0 * er); C = c; D = d;
        } else {
          if (isNaN(c) || isNaN(a)) return;
          if (c === 0) { el('plate-err').textContent = 'Capacitance cannot be zero when solving for separation.'; return; }
          D = (EPS0 * er * a) / c; C = c; A = a;
        }
        el('r-pc').textContent = fmt(C) + ' F';
        el('r-a').textContent = fmt(A) + ' m²';
        el('r-d').textContent = fmt(D) + ' m';
      }
      el('platemode-c').addEventListener('click', () => switchPlateSolve('c'));
      el('platemode-a').addEventListener('click', () => switchPlateSolve('a'));
      el('platemode-d').addEventListener('click', () => switchPlateSolve('d'));
      ['pc', 'a', 'd', 'er'].forEach((id) => el(id).addEventListener('input', updatePlate));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const L1 = [], D1 = [];
        for (let d = 0.0002; d <= 0.005001; d += 0.0002) {
          L1.push((d * 1000).toFixed(2));
          D1.push(+(EPS0 * 1 * 0.02 / d * 1e12).toFixed(3)); // pF
        }
        charts.d = new Chart(el('chart-d'), {
          type: 'line',
          data: { labels: L1, datasets: [{ label: 'C', data: D1, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Separation d (mm)' } }, y: { title: { display: true, text: 'Capacitance (pF)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        const L2 = [], D2 = [];
        const Cfixed = 100e-6;
        for (let vv = 0; vv <= 20.001; vv += 1) {
          const v2 = vv * vv;
          L2.push(v2.toFixed(0));
          D2.push(+(0.5 * Cfixed * v2).toFixed(6));
        }
        charts.e = new Chart(el('chart-e'), {
          type: 'line',
          data: { labels: L2, datasets: [{ label: 'E', data: D2, borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.10)', fill: true, tension: 0.1, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'V² (volts squared)' } }, y: { title: { display: true, text: 'Energy (J), C = 100 μF' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagrams: low-charge vs high-charge parallel plates ----
      let diagLow = null, diagHigh = null;
      function buildPlates(container, fieldLineCount) {
        const c = el(container); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const plateMat = new THREE.MeshStandardMaterial({ color: 0x2563eb, metalness: 0.3, roughness: 0.5 });
        const topPlate = new THREE.Mesh(new THREE.BoxGeometry(4, 0.15, 3), plateMat);
        const botPlate = new THREE.Mesh(new THREE.BoxGeometry(4, 0.15, 3), plateMat.clone());
        topPlate.position.y = 1.5; botPlate.position.y = -1.5;
        s.scene.add(topPlate, botPlate);

        const cols = Math.ceil(Math.sqrt(fieldLineCount));
        const spacing = 3.4 / cols;
        let count = 0;
        for (let i = 0; i < cols && count < fieldLineCount; i++) {
          for (let j = 0; j < cols && count < fieldLineCount; j++) {
            const x = -1.7 + i * spacing;
            const z = -1.3 + j * spacing;
            s.scene.add(arrow(new THREE.Vector3(x, 1.4, z), new THREE.Vector3(x, -1.4, z), 0xf59e0b));
            count++;
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function initDiagLow() { diagLow = buildPlates('diag-lowcharge', 4); }
      function initDiagHigh() { diagHigh = buildPlates('diag-highcharge', 16); }
      function updateDiagrams() { /* diagrams show fixed reference charge levels, not live-updating */ }

      function boot() {
        try { switchQvSolve('c'); updateQv(); } catch (e) { console.error('[capacitance] qv init failed', e); }
        try { switchPlateSolve('c'); updatePlate(); } catch (e) { console.error('[capacitance] plate init failed', e); }
        try { initCharts(); } catch (e) { console.error('[capacitance] charts failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[capacitance] low diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[capacitance] high diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
