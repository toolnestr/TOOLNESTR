---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Jacket/Suit Size Calculator';
const description = 'Find your suit or jacket size — chest number plus Short/Regular/Long — from chest measurement and height.';
const intro = 'Convert chest measurement and height into a men\'s suit jacket size.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I measure my chest for a suit?', a: 'Wrap a tape measure around the fullest part of your chest, under your arms and across your shoulder blades, while wearing a dress shirt but no jacket. Keep the tape level and snug but not tight, in inches.' },
  { q: 'What does the Short/Regular/Long suffix mean?', a: 'It describes the jacket length for a given chest size, matched to overall height — Short suits a shorter torso, Regular the most common average build, and Long a taller frame, so the jacket\'s proportions (sleeve and body length) fit correctly.' },
  { q: 'Why are suit sizes only even numbers?', a: 'Like belt and men\'s dress-shirt sizing, suit jackets are manufactured in even-numbered chest sizes (36, 38, 40...) as an industry convention, so a measured odd chest size rounds up to the next even number.' },
  { q: 'Does suit size relate to shirt collar size?', a: 'Not directly — collar size is based on neck circumference while suit size is based on chest circumference, and the two don\'t track proportionally for every body, so they should be measured and sized separately.' },
];
const howTo = {
  name: 'How to find your suit jacket size',
  steps: [
    { name: 'Measure your chest', text: 'Wrap a tape measure around the fullest part of your chest, over a dress shirt.' },
    { name: 'Enter your height', text: 'Type your height so the calculator can determine Short, Regular, or Long.' },
    { name: 'Read your size', text: 'Your suit size (chest number plus length code) appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Chest (in)</span>
        <input id="chest" type="number" step="any" placeholder="e.g. 41" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="height" type="number" step="any" placeholder="e.g. 70" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Suit jacket size</div>
        <div id="r-size" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="jsc-title jsc-desc">
      <title id="jsc-title">Suit jacket outline with chest measurement line</title>
      <desc id="jsc-desc">A jacket silhouette with a dashed line across the chest showing where the chest measurement is taken</desc>
      <path d="M300 40 L340 20 L400 35 L460 20 L500 40 L520 90 L500 100 L490 190 L310 190 L300 100 L280 90 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <line x1="290" y1="90" x2="510" y2="90" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="560" y="95" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Chest</text>
      <text x="400" y="210" text-anchor="middle" font-size="13" fill="#94a3b8" font-family="system-ui,sans-serif">Length code (S/R/L) depends on height</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Suit size combines a chest number with a length code based on height</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How suit sizing works</h2>
    <p class="mt-2 text-slate-600">
      A men's suit jacket size has two parts: a chest number, rounded to the nearest even inch from your measured chest circumference, and a length code — Short, Regular, or Long — that adjusts the jacket's body and sleeve length to match your height. The chest number alone doesn't guarantee correct proportions, which is why the length code exists as a second, independent adjustment.
    </p>
    <p class="mt-3 text-slate-600">
      The standard menswear convention assigns Short to heights roughly under 5'7" (67 in), Regular to the average band from about 5'7" to 6'1" (67-73 in), and Long to heights above 6'1" (73 in). A 42 Regular and a 42 Long share the same chest circumference but differ in jacket body length by roughly 1.5-2 inches, and in sleeve length similarly.
    </p>
    <p class="mt-3 text-xs text-slate-400">Chest-plus-length-code sizing follows the standard convention used across US menswear and suit manufacturing.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A shopper measures a 41-inch chest and stands 5'10" (70 in) tall.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Chest:</span> <span class="text-slate-600">41 in → rounds to 42</span></div>
        <div><span class="font-medium text-slate-700">Height:</span> <span class="text-slate-600">70 in → Regular</span></div>
        <div><span class="font-medium text-slate-700">Suit size:</span> <span class="text-slate-600"><strong>42R</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Wedding parties are a common trigger for this kind of calculation, since groomsmen often need to order matching suits from an online rental or retail service without a fitting appointment, working only from a self-reported chest measurement and height — getting the length code wrong is the single most common fit complaint in that scenario, since a Short suit on a tall frame or vice versa looks visibly off even at the correct chest size.
    </p>
    <p class="mt-3 text-slate-600">
      Off-the-rack suit buying for a job interview or first professional role follows the same logic: knowing chest size and length code in advance narrows the fitting-room search to a handful of jackets instead of trying on an entire rack.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A bigger chest number always means a longer jacket." <strong class="text-slate-900">No.</strong> Chest size and jacket length are independent — a 38 Long and a 46 Short both exist, since a person can have a smaller chest and a tall torso, or the reverse.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Suit size is the same as dress shirt size." <strong class="text-slate-900">Different measurements entirely.</strong> Dress shirts are sized by neck circumference and sleeve length, not chest circumference, so the two numbers rarely match and should be measured separately.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/clothing-size-converter/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
      <a href="/tools/belt-size-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Belt Size Calculator</a>
      <a href="/tools/inseam-length-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Inseam Length Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const chest = parseFloat(el('chest').value);
      const height = parseFloat(el('height').value);
      if (!chest || !height || chest <= 0 || height <= 0) { el('results').classList.add('hidden'); return; }
      let chestSize = Math.round(chest);
      if (chestSize % 2 !== 0) chestSize += 1;
      let code = 'R';
      if (height < 67) code = 'S';
      else if (height > 73) code = 'L';
      el('r-size').textContent = chestSize + code;
      el('results').classList.remove('hidden');
    }

    el('chest').addEventListener('input', update);
    el('height').addEventListener('input', update);
  </script>
</ToolLayout>
