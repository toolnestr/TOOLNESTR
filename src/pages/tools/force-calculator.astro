---
import ToolLayout from '../../layouts/ToolLayout.astro';
import SubjectToolLibs from '../../components/SubjectToolLibs.astro';

const title = 'Force Calculator (F = ma)';
const description = "Newton's second law calculator with a live 3D push simulator and charts. Solve F = ma for force, mass or acceleration.";
const intro = "Enter any two of force, mass and acceleration to solve the third with Newton's second law. A live 3D block accelerates under the force you set, and charts show how F, m and a interact.";
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };
const faqs = [
  { q: "What is Newton's second law?", a: 'It states that the net force on an object equals its mass times its acceleration: F = ma. Force and acceleration are vectors pointing the same way — the object accelerates in the direction of the net force.' },
  { q: 'What units should I use?', a: 'SI units: newtons (N) for force, kilograms (kg) for mass, metres per second squared (m/s²) for acceleration, where 1 N = 1 kg·m/s². Keep the units consistent or the answer is meaningless.' },
  { q: 'What is the difference between mass and weight?', a: 'Mass (kg) is the amount of matter and never changes. Weight (N) is the gravitational force on that mass, W = mg, and changes with gravity — you weigh six times less on the Moon but your mass is identical.' },
  { q: 'What does F stand for — is it the applied force?', a: 'F is the NET force, the vector sum of all forces acting. If friction or drag opposes the push, subtract them first: it is the resultant force that sets the acceleration.' },
  { q: 'What happens when acceleration is zero?', a: "Zero acceleration means zero net force — the forces are balanced. That is Newton's first law: the object stays at rest or moves at constant velocity. It can still be moving; it just isn't speeding up or slowing down." },
  { q: 'Why do heavier objects need more force to accelerate?', a: 'Because a = F/m. For the same acceleration, force scales directly with mass; for the same force, a heavier object accelerates less. Mass is the measure of an object’s inertia — its resistance to changes in motion.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to use the Force Calculator',
    description: "Calculate force, mass or acceleration using Newton's second law F = ma.",
    step: [
      { '@type': 'HowToStep', name: 'Enter two values', text: 'Type any two of force, mass and acceleration; leave the one you want to find blank.' },
      { '@type': 'HowToStep', name: 'Read the third', text: 'The missing quantity solves instantly using F = ma.' },
      { '@type': 'HowToStep', name: 'See it accelerate', text: 'Drag the mass and force sliders to watch a 3D block speed up, and read a = F/m in the charts.' },
    ],
  })} />

  <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
    <span class="h-2 w-2 rounded-full bg-blue-500"></span> Physics
  </span>

  <style is:global>
    @media print {
      .no-print { display: none !important; }
      a[href]::after { content: none !important; }
      section { break-inside: avoid; }
    }
  </style>

  <!-- ============ CALCULATOR ============ -->
  <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values — the third solves instantly.</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="force" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mass" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Acceleration (a)</span>
        <input id="acc" type="number" step="any" placeholder="m/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Force</div><div id="r-force" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-mass" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Acceleration</div><div id="r-acc" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="force-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ INTERACTIVE 3D ============ -->
  <section class="mt-8 no-print">
    <h2 class="text-lg font-bold text-slate-900">Live 3D — push a block</h2>
    <p class="mt-1 text-sm text-slate-500">Bigger mass = bigger, more sluggish block; bigger force = longer red arrow and faster acceleration. Drag to orbit (touch works too).</p>
    <div class="mt-3 grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Mass <span id="out-bmass" class="font-mono text-indigo-600">2.0 kg</span></span>
        <input id="b-mass" type="range" min="0.5" max="10" step="0.1" value="2" class="mt-2 w-full accent-indigo-600" />
      </label>
      <label class="block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Force <span id="out-bforce" class="font-mono text-indigo-600">10.0 N</span></span>
        <input id="b-force" type="range" min="0" max="50" step="0.5" value="10" class="mt-2 w-full accent-indigo-600" />
      </label>
    </div>
    <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">Acceleration a = F/m = <span id="out-bacc" class="font-mono font-bold">5.00 m/s²</span></div>
    <div id="scene3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
    <p id="scene3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
  </section>

  <!-- ============ LIVE CHARTS ============ -->
  <section class="mt-10 no-print">
    <h2 class="text-lg font-bold text-slate-900">Newton's second law, graphed</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Acceleration vs force (at your current mass) — a straight line</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-af"></canvas></div>
      </figure>
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Acceleration vs mass (at your current force) — a curve</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-am"></canvas></div>
      </figure>
      <figure class="sm:col-span-2">
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Force to give a 1000 kg car various accelerations</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:260px;"><canvas id="chart-car"></canvas></div>
      </figure>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How the force formula works</h2>
    <p class="mt-2 text-slate-600"><strong>The core idea in one line:</strong> the harder you push (bigger F), the faster something speeds up — but the heavier it is (bigger m), the more that push is "watered down."</p>
    <p class="mt-3 text-slate-600">Newton's second law ties the three quantities together, and rearranges three ways so any two give the third:</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">F = m · a</p><p class="mt-1 text-xs text-slate-500">force from mass &amp; acceleration</p></div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">a = F / m</p><p class="mt-1 text-xs text-slate-500">acceleration a force produces</p></div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">m = F / a</p><p class="mt-1 text-xs text-slate-500">mass from force &amp; acceleration</p></div>
    </div>
    <p class="mt-4 text-slate-600">The single most common mistake is forgetting that <strong>F is the net force</strong> — the vector sum of everything acting. If a 100 N push meets 30 N of friction, the object accelerates as if pushed by only 70 N. Balanced forces (net zero) mean zero acceleration, which is Newton's first law hiding inside the second.</p>

    <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 1 — accelerating a car</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> a 1500 kg car speeds up from rest to 20 m/s in 10 s. What net force does that take?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Acceleration:</span> <span class="text-slate-600">a = (20 − 0) / 10 = 2 m/s²</span></div>
        <div><span class="font-medium text-slate-700">Force:</span> <span class="text-slate-600">F = 1500 · 2 = 3000 N</span></div>
        <div class="sm:col-span-2"><span class="font-medium text-slate-700">Sense check:</span> <span class="text-slate-600">3000 N is roughly the weight of a 300 kg object — a believable drive force.</span></div>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 2 — net force with friction</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> you push a 20 kg crate with 100 N, but friction resists with 40 N. Find the acceleration.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Net force:</span> <span class="text-slate-600">F = 100 − 40 = 60 N</span></div>
        <div><span class="font-medium text-slate-700">Acceleration:</span> <span class="text-slate-600">a = 60 / 20 = 3 m/s²</span></div>
        <div class="sm:col-span-2 text-slate-600">Using the full 100 N would overstate the acceleration by 67%. Always subtract opposing forces first.</div>
      </div>
    </div>
  </section>

  <!-- ============ STANDALONE 3D DIAGRAMS ============ -->
  <section class="mt-12 no-print">
    <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <div>
        <div id="diag-mass" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">1. Same force, heavier = slower</h3>
        <p class="mt-1 text-sm text-slate-600">Both blocks get the <strong>same</strong> push, but the small <span class="font-semibold text-sky-500">blue</span> block pulls ahead of the big <span class="font-semibold text-red-500">red</span> one — twice the mass, half the acceleration. That's a = F/m in motion.</p>
      </div>
      <div>
        <div id="diag-net" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">2. Only the net force counts</h3>
        <p class="mt-1 text-sm text-slate-600">A long <span class="font-semibold text-emerald-500">green push</span> and a shorter opposing <span class="font-semibold text-red-500">red friction</span> arrow leave a small leftover — the block accelerates as if only that leftover net force acted.</p>
      </div>
    </div>
  </section>

  <!-- ============ COMPARISON TABLE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Force to accelerate a 1000 kg car</h2>
    <p class="mt-1 text-sm text-slate-600">Force scales directly with the acceleration you want — double the target acceleration, double the force.</p>
    <div class="mt-3 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full table-fixed text-center text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Acceleration<span class="block text-[10px] font-normal text-slate-400">m/s²</span></th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">0–100 km/h in<span class="block text-[10px] font-normal text-slate-400">s</span></th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Net force<span class="block text-[10px] font-normal text-slate-400">N</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700 tabular-nums">
          <tr><td class="px-2 py-2.5 sm:px-3">1</td><td class="px-2 py-2.5 sm:px-3">27.8</td><td class="px-2 py-2.5 sm:px-3">1,000</td></tr>
          <tr><td class="px-2 py-2.5 sm:px-3">3</td><td class="px-2 py-2.5 sm:px-3">9.3</td><td class="px-2 py-2.5 sm:px-3">3,000</td></tr>
          <tr class="bg-indigo-50 font-semibold text-indigo-700"><td class="px-2 py-2.5 sm:px-3">5 ★</td><td class="px-2 py-2.5 sm:px-3">5.6</td><td class="px-2 py-2.5 sm:px-3">5,000</td></tr>
          <tr><td class="px-2 py-2.5 sm:px-3">8</td><td class="px-2 py-2.5 sm:px-3">3.5</td><td class="px-2 py-2.5 sm:px-3">8,000</td></tr>
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-slate-400">★ A brisk 5 m/s² gets a 1-tonne car to 100 km/h (27.8 m/s) in about 5.6 s. Times are 27.8 ÷ a; forces are 1000 × a.</p>
  </section>

  <!-- ============ REAL-WORLD CONTEXT ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Where F = ma actually matters</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🚗 Vehicle &amp; aerospace design</h3>
        <p class="mt-1 text-sm text-slate-600">Engineers size engines, brakes and airframes from the forces needed to accelerate a known mass — and the G-forces those accelerations impose on the structure and the occupants.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🏃 Sports biomechanics</h3>
        <p class="mt-1 text-sm text-slate-600">A sprinter's start, a high-jumper's take-off and a boxer's punch are all F = ma problems. Force plates measure the ground force so coaches can quantify explosive power.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🎢 Rides &amp; machines</h3>
        <p class="mt-1 text-sm text-slate-600">Lift motors, conveyor drives and roller-coaster launch systems are all specced from the force required to accelerate their load — the everyday face of Newton's second law.</p>
      </div>
    </div>
  </section>

  <!-- ============ MISCONCEPTIONS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"A moving object must have a force pushing it forward."</p>
        <p class="mt-1 text-sm text-slate-600">No — constant velocity needs zero net force. A puck sliding on frictionless ice keeps moving with nothing pushing it. Force is needed to <em>change</em> motion, not to maintain it.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Mass and weight are the same."</p>
        <p class="mt-1 text-sm text-slate-600">Mass (kg) is fixed; weight (N) is the force of gravity on it, W = mg, and changes with location. This calculator's F = ma solves force in general — for weight, use a = g.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"F in F = ma is whatever force I apply."</p>
        <p class="mt-1 text-sm text-slate-600">It's the net force. Friction, drag and gravity all combine; you must add them as vectors first, then use the resultant.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Heavier objects fall faster because gravity pulls harder."</p>
        <p class="mt-1 text-sm text-slate-600">Gravity does pull a heavy object harder, but it also has more inertia to move. The two effects cancel: a = F/m = mg/m = g, the same for every mass — which is why they fall together.</p>
      </div>
    </div>
  </section>

  <!-- ============ FORMULA SOURCES ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Formula sources &amp; further reading</h2>
    <p class="mt-2 text-slate-600">Newton's second law is the foundation of classical mechanics, traceable to:</p>
    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      <li>• <strong>OpenStax, <em>University Physics Volume 1</em></strong> — §5.3 "Newton's Second Law" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/5-3-newtons-second-law" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a></li>
      <li>• <strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 5, Force and Motion I.</li>
      <li>• <strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 5, The Laws of Motion.</li>
    </ul>
    <p class="mt-3 text-xs text-slate-400">1 newton = 1 kg·m/s². Results are rounded for display.</p>
  </section>

  <!-- ============ HOW TO USE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter two values</h3>
        <p class="mt-1 text-sm text-slate-600">Fill any two of force, mass and acceleration in SI units (N, kg, m/s²). Leave the one you want blank.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The missing quantity solves instantly, with clear messages if inputs are incomplete or would divide by zero.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Explore in 3D</h3>
        <p class="mt-1 text-sm text-slate-600">Use the mass and force sliders to feel how acceleration responds, and see a = F/m plotted live.</p>
      </div>
    </div>
  </section>

  <!-- ============ RELATED TOOLS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/momentum-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🎯</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Momentum &amp; Impulse Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">p = mv and Δp = FΔt.</p>
      </a>
      <a href="/tools/kinetic-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">⚡</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Kinetic Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">KE = ½mv² — solve for any variable.</p>
      </a>
      <a href="/tools/gravitational-force-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🌍</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Gravitational Force Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Newton's law of universal gravitation.</p>
      </a>
    </div>
  </section>

  <!-- Libraries: Three.js + Chart.js + shared subject kit (window.STK) -->
  <SubjectToolLibs />

  <script is:inline>
  (function () {
    'use strict';
    const { el, reduceMotion, fmt2: fmt, makeScene, mountResize, chartSetup } = window.STK;
    const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

    // ================= CALCULATOR (preserves original solve, adds zero guards) =================
    function update() {
      const f = parseFloat(el('force').value), m = parseFloat(el('mass').value), a = parseFloat(el('acc').value);
      const filled = [!isNaN(f), !isNaN(m), !isNaN(a)];
      el('force-err').textContent = '';
      ['r-force', 'r-mass', 'r-acc'].forEach((id) => (el(id).textContent = '—'));
      if (filled.filter(Boolean).length < 2) return;
      let rf = NaN, rm = NaN, ra = NaN;
      if (filled[0] && filled[1]) { if (m === 0) { el('force-err').textContent = 'Mass cannot be zero.'; return; } ra = f / m; rf = f; rm = m; }
      else if (filled[0] && filled[2]) { if (a === 0) { el('force-err').textContent = 'Acceleration cannot be zero when solving for mass.'; return; } rm = f / a; rf = f; ra = a; }
      else if (filled[1] && filled[2]) { rf = m * a; rm = m; ra = a; }
      if (!isNaN(rf)) el('r-force').textContent = fmt(rf) + ' N';
      if (!isNaN(rm)) el('r-mass').textContent = fmt(rm) + ' kg';
      if (!isNaN(ra)) el('r-acc').textContent = fmt(ra) + ' m/s²';
    }
    ['force', 'mass', 'acc'].forEach((id) => el(id).addEventListener('input', update));

    // ================= 3D + charts shared state =================
    const charts = {};
    let scene = null;
    function bState() {
      const mass = parseFloat(el('b-mass').value), force = parseFloat(el('b-force').value);
      return { mass, force, a: mass > 0 ? force / mass : 0 };
    }
    function onBChange() {
      const s = bState();
      el('out-bmass').textContent = s.mass.toFixed(1) + ' kg';
      el('out-bforce').textContent = s.force.toFixed(1) + ' N';
      el('out-bacc').textContent = fmt(s.a) + ' m/s²';
      try { if (scene) scene.update(s); } catch (e) {}
      try { if (charts.ready) updateCharts(s); } catch (e) {}
    }
    el('b-mass').addEventListener('input', onBChange);
    el('b-force').addEventListener('input', onBChange);

    // ================= CHARTS =================
    function initCharts() {
      if (!window.Chart) return;
      const base = chartSetup();
      charts.af = new Chart(el('chart-af'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'a', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Force (N)' } }, y: { title: { display: true, text: 'Acceleration (m/s²)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.am = new Chart(el('chart-am'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'a', data: [], borderColor: '#0ea5e9', backgroundColor: 'rgba(14,165,233,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Mass (kg)' } }, y: { title: { display: true, text: 'Acceleration (m/s²)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.car = new Chart(el('chart-car'), {
        type: 'bar',
        data: { labels: ['1', '3', '5', '8'], datasets: [{ label: 'Net force (N)', data: [1000, 3000, 5000, 8000], backgroundColor: '#f59e0b' }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Acceleration (m/s²)' } }, y: { title: { display: true, text: 'Force on 1000 kg car (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.ready = true;
      updateCharts(bState());
    }
    function updateCharts(s) {
      if (!charts.ready) return;
      const L = [], D = [];
      for (let ff = 0; ff <= 50.001; ff += 5) { L.push(ff + ''); D.push(+(s.mass > 0 ? ff / s.mass : 0).toFixed(3)); }
      charts.af.data.labels = L; charts.af.data.datasets[0].data = D; charts.af.update();
      const L2 = [], D2 = [];
      for (let mm = 0.5; mm <= 10.001; mm += 0.5) { L2.push(mm.toFixed(1)); D2.push(+(s.force / mm).toFixed(3)); }
      charts.am.data.labels = L2; charts.am.data.datasets[0].data = D2; charts.am.update();
    }

    // ================= 3D push block =================
    function initScene3d() {
      const c = el('scene3d'); if (!c) throw new Error('no container');
      const s = makeScene(c, 14, new THREE.Vector3(0, 0.5, 0), OPTS);
      s.scene.add(new THREE.GridHelper(20, 20, 0xcbd5e1, 0xe2e8f0));
      let cube = null, arrowH = null, st = { size: 1, a: 5, x: -6, v: 0 };
      const cubeMat = new THREE.MeshStandardMaterial({ color: 0x6366f1 });
      function build(size) {
        if (cube) { s.scene.remove(cube); cube.geometry.dispose(); }
        cube = new THREE.Mesh(new THREE.BoxGeometry(size, size, size), cubeMat);
        s.scene.add(cube);
      }
      function update(state) {
        st.size = Math.max(0.4, Math.cbrt(state.mass) * 0.9);
        build(st.size);
        st.a = state.a; st.x = -6; st.v = 0;
        const len = Math.min(6, state.force * 0.14);
        if (arrowH) s.scene.remove(arrowH);
        arrowH = new THREE.ArrowHelper(new THREE.Vector3(1, 0, 0), new THREE.Vector3(0, 0, 0), Math.max(0.3, len), 0xef4444, Math.min(0.6, len * 0.25), 0.35);
        cube.add(arrowH); arrowH.position.set(-st.size / 2, 0, 0);
      }
      function frame() {
        requestAnimationFrame(frame);
        if (!reduceMotion) s.spin(0.0016);
        if (cube) {
          st.v += st.a * 0.016 * 0.3; st.x += st.v * 0.016;
          if (st.x > 8) { st.x = -6; st.v = 0; }
          cube.position.set(st.x, st.size / 2, 0);
        }
        s.renderer.render(s.scene, s.camera);
      }
      frame();
      scene = { update, resize: s.resize };
      update(bState());
    }

    // ---- diagram: same force, different mass ----
    function initDiagMass() {
      const c = el('diag-mass'); if (!c) throw new Error('no container');
      const s = makeScene(c, 13, new THREE.Vector3(0, 0.5, 0), OPTS);
      s.scene.add(new THREE.GridHelper(14, 14, 0xe2e8f0, 0xeef2f7));
      const big = new THREE.Mesh(new THREE.BoxGeometry(1.6, 1.6, 1.6), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
      const small = new THREE.Mesh(new THREE.BoxGeometry(1.0, 1.0, 1.0), new THREE.MeshStandardMaterial({ color: 0x0ea5e9 }));
      big.position.set(-5, 0.8, 1.6); small.position.set(-5, 0.5, -1.6); s.scene.add(big); s.scene.add(small);
      let t = 0;
      function frame() {
        requestAnimationFrame(frame);
        if (!reduceMotion) { s.spin(0.003); t += 0.012; const ph = t % 1.8; const d = ph * ph * 3; big.position.x = -5 + d * 0.5; small.position.x = -5 + d; }
        s.renderer.render(s.scene, s.camera);
      }
      frame();
      diagMass = { resize: s.resize };
    }

    // ---- diagram: net force (push vs friction arrows) ----
    function initDiagNet() {
      const c = el('diag-net'); if (!c) throw new Error('no container');
      const s = makeScene(c, 12, new THREE.Vector3(0, 0.5, 0), OPTS);
      s.scene.add(new THREE.GridHelper(12, 12, 0xe2e8f0, 0xeef2f7));
      const block = new THREE.Mesh(new THREE.BoxGeometry(1.4, 1.4, 1.4), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
      block.position.y = 0.7; s.scene.add(block);
      block.add(new THREE.ArrowHelper(new THREE.Vector3(1, 0, 0), new THREE.Vector3(-0.7, 0, 0), 3.2, 0x10b981, 0.6, 0.35));   // push
      block.add(new THREE.ArrowHelper(new THREE.Vector3(-1, 0, 0), new THREE.Vector3(0.7, 0, 0), 1.6, 0xef4444, 0.5, 0.3));    // friction
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagNet = { resize: s.resize };
    }

    let diagMass = null, diagNet = null;

    // ================= BOOT =================
    function boot() {
      try { update(); } catch (e) { console.error('[force] calc init failed', e); }
      try { onBChange(); } catch (e) { console.error('[force] slider init failed', e); }
      try { initCharts(); } catch (e) { console.error('[force] charts failed', e); }
      if (window.THREE) {
        try { initScene3d(); } catch (e) { console.error('[force] 3D failed', e); el('scene3d-fallback').classList.remove('hidden'); }
        try { initDiagMass(); } catch (e) { console.error('[force] mass diagram failed', e); }
        try { initDiagNet(); } catch (e) { console.error('[force] net diagram failed', e); }
      } else {
        el('scene3d-fallback').classList.remove('hidden');
      }
      mountResize([scene, diagMass, diagNet]);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
  </script>
</ToolLayout>
