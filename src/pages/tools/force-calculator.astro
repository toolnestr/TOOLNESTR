---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Force Calculator (F = ma)';
const description = 'Free online force calculator. Apply Newton\'s second law F = ma to solve for force, mass, or acceleration in any unit system.';
const intro = 'Enter any two values — force, mass, or acceleration — to solve for the third using Newton\'s second law.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is Newton\'s second law?', a: 'Newton\'s second law states that F = ma — the net force on an object equals its mass multiplied by its acceleration. Force and acceleration are vectors pointing in the same direction.' },
  { q: 'What units should I use?', a: 'The SI units are newtons (N) for force, kilograms (kg) for mass, and metres per second squared (m/s²) for acceleration. 1 N = 1 kg·m/s². You can also use pounds-force, pounds-mass, and ft/s² in the imperial system.' },
  { q: 'What is the difference between mass and weight?', a: 'Mass is the amount of matter in an object (kg), while weight is the gravitational force on that mass (N). Your mass stays the same everywhere, but your weight changes with gravity.' },
  { q: 'What happens if acceleration is zero?', a: 'If acceleration is zero, the net force is zero. This is Newton\'s first law — an object at rest stays at rest, and an object in motion stays in motion at constant velocity, unless acted on by an unbalanced force.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values, leave the third blank</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="force" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mass" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Acceleration (a)</span>
        <input id="acc" type="number" step="any" placeholder="m/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="force-result" class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Force</div><div id="r-force" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-mass" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Acceleration</div><div id="r-acc" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="force-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="280" viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="force-title force-desc">
      <title id="force-title">Block with applied force arrow diagram</title>
      <desc id="force-desc">A rectangular block on a surface with a horizontal force arrow pushing it right, showing mass m, acceleration a, and friction</desc>
      <g transform="translate(40,20)">
        <rect x="180" y="90" width="200" height="120" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2.5"/>
        <text x="280" y="155" text-anchor="middle" fill="#4338ca" font-size="20" font-weight="bold">m</text>
        <text x="280" y="175" text-anchor="middle" fill="#64748b" font-size="14">Mass</text>
        <line x1="140" y1="150" x2="380" y2="150" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="6 3"/>
        <line x1="380" y1="185" x2="380" y2="245" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="6 3"/>
        <text x="380" y="265" text-anchor="middle" fill="#64748b" font-size="13">Surface</text>
        <line x1="100" y1="245" x2="480" y2="245" stroke="#94a3b8" stroke-width="3"/>
        <path d="M 50 150 L 390 150" stroke="#ef4444" stroke-width="3" stroke-linecap="round"/>
        <polygon points="390,140 410,150 390,160" fill="#ef4444"/>
        <text x="420" y="155" fill="#ef4444" font-size="18" font-weight="bold">F</text>
        <text x="460" y="155" fill="#64748b" font-size="14">Applied force</text>
        <path d="M 400 210 Q 420 195 440 210" stroke="#f59e0b" stroke-width="2" fill="none"/>
        <text x="460" y="215" fill="#f59e0b" font-size="14" font-weight="bold">a</text>
        <text x="480" y="215" fill="#64748b" font-size="14">Acceleration</text>
        <text x="300" y="30" text-anchor="middle" fill="#4338ca" font-size="22" font-weight="bold">F = m × a</text>
        <text x="300" y="55" text-anchor="middle" fill="#64748b" font-size="14">Force = Mass × Acceleration</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">A mass m accelerated by a horizontal force F, with acceleration a in the same direction as the net force</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the force formula works</h2>
    <p class="mt-2 text-slate-600">Newton's second law of motion states that the net force acting on an object equals its mass multiplied by its acceleration: <span class="font-mono">F = m × a</span>. Force and acceleration are vectors — they have both magnitude and direction. The direction of the acceleration is always the same as the direction of the net force. If multiple forces act on an object, you must use the vector sum (net force) in the equation.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 1500 kg car accelerates from rest to 20 m/s in 10 seconds. What force does the engine produce?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Mass:</span> <span class="text-slate-600">1500 kg</span></div>
        <div><span class="font-medium text-slate-700">Acceleration:</span> <span class="text-slate-600">a = (20 − 0) / 10 = 2 m/s²</span></div>
        <div><span class="font-medium text-slate-700">Force:</span> <span class="text-slate-600">F = 1500 × 2 = 3000 N</span></div>
        <div><span class="font-medium text-slate-700">Check:</span> <span class="text-slate-600">A force of 3000 N is about the weight of a small car</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F697;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Automotive Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the force required to accelerate a vehicle, size braking systems, and design suspension components that must withstand dynamic loads during cornering and braking.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F6E1;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Aerospace Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Determine thrust requirements for aircraft and spacecraft, calculate G-forces during manoeuvres, and analyse the loads on airframes during take-off and landing.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3C3;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sports Scientist</h3>
      <p class="mt-1 text-sm text-slate-600">Analyse the forces an athlete generates when sprinting or jumping. Use F = ma to quantify power output and design training programmes that improve explosive strength.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Physics Student</h3>
      <p class="mt-1 text-sm text-slate-600">Verify homework problems involving Newton's laws. Build intuition for how force, mass, and acceleration relate by testing different scenarios interactively.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the force calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter two known values</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in any two of the three fields — force, mass, or acceleration. Use SI units (N, kg, m/s²) for consistent results.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The missing value is calculated instantly. The highlighted box shows the solved variable. All three boxes update with the complete set of values.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Beginner-friendly errors</h3>
        <p class="mt-1 text-sm text-slate-600">If only one or zero values are entered, or if mass is zero causing division by zero, a helpful message appears. No crashes, no confusion.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for Newton's second law</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Remember the net force</h3>
        <p class="mt-1 text-sm text-slate-600">F in the formula is the net (resultant) force, not any individual force. If friction, air resistance, or other opposing forces exist, subtract them from the applied force before using the formula.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Weight is a force</h3>
        <p class="mt-1 text-sm text-slate-600">Weight (W = mg) is the gravitational force on an object. On Earth, g ≈ 9.81 m/s², so a 10 kg mass has a weight of about 98.1 N. This calculator solves for F in F = ma — for weight, use g as the acceleration.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Always check your units</h3>
        <p class="mt-1 text-sm text-slate-600">Mixing kilograms with miles per hour squared will give nonsense. Stick to SI: kg, m, s. If your inputs are in different units, convert them first using a unit converter.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/work-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F527;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Work Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate work done by force over distance.</p>
      </a>
      <a href="/tools/kinetic-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x26A1;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Kinetic Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">KE = ½mv² — solve for any variable.</p>
      </a>
      <a href="/tools/gravitational-force-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F30D;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Gravitational Force Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Newton's law of universal gravitation.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });
    function update() {
      const f = parseFloat(el('force').value);
      const m = parseFloat(el('mass').value);
      const a = parseFloat(el('acc').value);
      const filled = [!isNaN(f), !isNaN(m), !isNaN(a)];
      const count = filled.filter(Boolean).length;
      el('force-err').textContent = '';
      ['r-force', 'r-mass', 'r-acc'].forEach(id => el(id).textContent = '—');
      if (count < 2) return;
      let rf = NaN, rm = NaN, ra = NaN;
      if (filled[0] && filled[1]) { ra = f / m; rf = f; rm = m; }
      else if (filled[0] && filled[2]) { rm = f / a; rf = f; ra = a; }
      else if (filled[1] && filled[2]) { if (a === 0) { el('force-err').textContent = 'Acceleration cannot be zero when solving for force.'; return; } rf = m * a; rm = m; ra = a; }
      if (!isNaN(rf)) el('r-force').textContent = fmt(rf);
      if (!isNaN(rm)) el('r-mass').textContent = fmt(rm);
      if (!isNaN(ra)) el('r-acc').textContent = fmt(ra);
    }
    ['force', 'mass', 'acc'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
