---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Arrhenius Equation Calculator';
const description = "Arrhenius equation calculator. Find the rate constant k = Ae^(-Ea/RT), or find Ea from two (T,k) points, with worked examples.";
const intro = 'Compute a rate constant from activation energy, or find the activation energy from two rate constants measured at two temperatures. Static 3D diagrams and charts show the energy barrier reactions must climb, and the classic Arrhenius plot.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What does the Arrhenius equation describe?', a: 'The Arrhenius equation, k = Ae^(−Ea/RT), describes how a reaction rate constant k depends on temperature T and activation energy Ea. A is the pre-exponential (frequency) factor, representing how often molecules collide with the right orientation, and R is the gas constant.' },
  { q: 'What is activation energy?', a: 'Activation energy (Ea) is the minimum energy colliding molecules need to react — the height of the energy barrier between reactants and products. Higher Ea means fewer molecules have enough energy to react at a given temperature, so the reaction is slower.' },
  { q: 'How do you find Ea from experimental data at two temperatures?', a: 'Measure the rate constant k at two different temperatures, then use the two-point (linearized) form: Ea = −R × ln(k2/k1) / (1/T2 − 1/T1). This avoids needing to know the pre-exponential factor A at all.' },
  { q: 'Why does a small temperature change cause a large rate change?', a: 'Because Ea/RT sits inside an exponential, small changes in T produce disproportionately large changes in k — this is the basis of the common rule of thumb that reaction rates roughly double for every 10°C rise in temperature, though the exact factor depends on Ea.' },
  { q: 'How do catalysts fit into the Arrhenius equation?', a: 'A catalyst provides an alternative reaction pathway with a lower activation energy (Ea) without being consumed. Because k depends exponentially on −Ea, even a modest reduction in Ea from a catalyst can produce a dramatic increase in reaction rate at the same temperature.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Arrhenius Equation Calculator',
  description: 'Compute a rate constant from A, Ea and T, or find Ea from two rate constants at two temperatures.',
  steps: [
    { name: 'Pick a mode', text: '"Rate constant" solves k = Ae^(−Ea/RT). "Find Ea" solves for activation energy from two (T, k) points.' },
    { name: 'Enter the values', text: 'Type A, Ea (J/mol) and T (K) for mode 1, or k₁, T₁, k₂, T₂ for mode 2.' },
    { name: 'Read the result', text: 'The rate constant (or Ea) solves instantly, shown in scientific notation where needed.' },
  ],
};

const formulas = [
  { expr: 'k = A e<sup>−Ea/RT</sup>', note: 'rate constant from activation energy, A = pre-exponential factor, R = 8.314 J/(mol·K)' },
  { expr: 'ln(k) = ln(A) − Ea/(RT)', note: 'linearized form — a straight line on ln(k) vs 1/T' },
  { expr: 'Ea = −R × ln(k₂/k₁) / (1/T₂ − 1/T₁)', note: 'two-point form — find Ea from rate constants at two temperatures' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — rate constant from Ea, A and T', tone: 'slate',
    given: 'A = 1×10¹³ s⁻¹, Ea = 75,000 J/mol, T = 298 K. Find the rate constant k.',
    rows: [
      { label: 'Exponent:', value: '−Ea/(RT) = −75000 / (8.314×298) = −75000 / 2477.572 ≈ −30.272' },
      { label: 'Formula:', value: 'k = A × e^(−30.272) = 1×10¹³ × e^(−30.272)' },
      { label: 'Rate constant:', value: 'k ≈ 1×10¹³ × 7.132×10⁻¹⁴ ≈ 0.713 s⁻¹', full: true },
    ],
    note: 'k ≈ 0.713 s⁻¹ — the huge negative exponent (about e^−30) shows how strongly a 75 kJ/mol barrier suppresses the reaction rate even though the pre-exponential factor A is enormous (10¹³).',
  },
  {
    title: 'Worked example 2 — finding Ea from two rate constants', tone: 'amber',
    given: 'A reaction has k₁ = 1×10⁻³ s⁻¹ at T₁ = 298 K, and k₂ = 1×10⁻² s⁻¹ at T₂ = 308 K (a 10 K rise). Find the activation energy Ea.',
    rows: [
      { label: 'Ratio:', value: 'k₂/k₁ = 0.01 / 0.001 = 10, so ln(10) ≈ 2.3026' },
      { label: 'Temperature term:', value: '1/T₂ − 1/T₁ = 1/308 − 1/298 ≈ 0.0032468 − 0.0033557 ≈ −1.0893×10⁻⁴' },
      { label: 'Formula:', value: 'Ea = −R × ln(k₂/k₁) / (1/T₂ − 1/T₁) = −8.314 × 2.3026 / (−1.0893×10⁻⁴)' },
      { label: 'Activation energy:', value: 'Ea ≈ 175,708 J/mol ≈ 175.7 kJ/mol', full: true },
    ],
    note: 'A tenfold rate increase from just a 10 K rise implies a fairly high activation energy of roughly 176 kJ/mol — consistent with the rule of thumb that rates near room temperature often roughly double or more per 10°C for reactions with Ea in this range.',
  },
];

const comparison = {
  heading: 'How activation energy affects rate constant sensitivity to temperature',
  note: 'Illustrative k values at T = 298 K vs T = 308 K (a 10 K rise), holding A = 1×10¹³ s⁻¹ fixed — higher Ea means a bigger relative jump in k.',
  headers: [{ label: 'Ea (kJ/mol)' }, { label: 'k at 298 K' }, { label: 'k at 308 K' }, { label: 'Rate ratio' }],
  rows: [
    ['50', '1.90×10⁻⁴ s⁻¹', '5.99×10⁻⁴ s⁻¹', '≈ 3.2×'],
    ['75', '7.13×10⁻¹ s⁻¹', '3.02×10⁰ s⁻¹', '≈ 4.2×'],
    ['100', '2.68×10³ s⁻¹', '1.52×10⁴ s⁻¹', '≈ 5.7×'],
  ],
  highlightIndex: 1,
  footnote: 'Because Ea sits in the exponent, larger activation energies make the rate constant far more sensitive to temperature changes — a key reason some reactions need much more heating to speed up than others.',
};

const realWorld = [
  { emoji: '🧊', title: 'Food storage and refrigeration', body: 'Spoilage reactions follow Arrhenius behavior, so lowering temperature in a fridge or freezer dramatically slows the chemical and microbial reactions that cause food to degrade — a direct, everyday application of how strongly rate depends on T.' },
  { emoji: '⚙️', title: 'Catalyst design in industry', body: 'Catalysts work by lowering Ea for a reaction pathway. Because k depends exponentially on Ea, even a modest reduction can produce an enormous rate increase — the economic basis for catalytic converters, industrial catalysts, and enzyme engineering.' },
  { emoji: '💊', title: 'Pharmaceutical shelf-life prediction', body: 'Drug degradation rates typically follow Arrhenius kinetics, so manufacturers run accelerated stability tests at elevated temperatures and extrapolate back to predict shelf life at normal storage temperatures.' },
  { emoji: '🔥', title: 'Combustion and explosion safety', body: 'Understanding how rapidly reaction rates accelerate with temperature — via the Arrhenius relationship — is essential to predicting thermal runaway risks in industrial reactors and designing safe handling procedures for reactive chemicals.' },
];

const misconceptions = [
  { claim: '"Reaction rate always doubles for every 10°C increase, exactly."', truth: 'That is a rough rule of thumb that holds approximately for many reactions with moderate activation energies near room temperature, not a universal law. The actual rate increase factor depends on Ea and the specific temperatures involved, as the Arrhenius equation shows precisely.' },
  { claim: '"A is just a fudge factor with no physical meaning."', truth: 'The pre-exponential factor A relates to how often molecules collide and how often those collisions have the correct orientation for reaction — it has real physical meaning tied to collision frequency and geometry, even though it is often determined experimentally.' },
  { claim: '"Lowering activation energy changes whether a reaction is thermodynamically favorable."', truth: "Activation energy is a kinetics concept — it affects how fast a reaction proceeds, not whether it is thermodynamically favorable (that is governed by ΔG). A catalyst can make an already-favorable reaction proceed much faster without changing its overall energetics." },
  { claim: '"Ea and ΔH_rxn measure the same thing."', truth: 'Ea is the energy barrier height on the way from reactants to products (always positive, describing kinetics). ΔH_rxn is the net energy difference between reactants and products (can be positive or negative, describing thermodynamics) — a reaction can have a large Ea and still be strongly exothermic overall.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 12, Kinetics: the Arrhenius equation (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/12-6-reaction-mechanisms" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 14, Chemical Kinetics.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — the Arrhenius equation and activation energy.' },
];
const sourcesNote = 'k = Ae^(−Ea/RT); Ea = −R·ln(k₂/k₁)/(1/T₂ − 1/T₁), with R = 8.314 J/(mol·K), T in Kelvin. Results are rounded for display; very small or large k values use scientific notation.';

const howToUse = [
  { title: 'Pick the mode', body: '"Rate constant" solves k from A, Ea and T; "Find Ea" solves Ea from two (T,k) points.' },
  { title: 'Enter the values', body: 'Use consistent units — Ea in J/mol, T in Kelvin, k in your rate constant\'s units.' },
  { title: 'Read the result', body: 'k or Ea solves live, shown in scientific notation for very small or large values.' },
];

const related = [
  { href: '/tools/reaction-rate-calculator', emoji: '⏳', title: 'Reaction Rate Calculator', desc: 'rate = |ΔX| / (coefficient × Δt).' },
  { href: '/tools/equilibrium-constant-calculator', emoji: '🔁', title: 'Equilibrium Constant (Keq) Calculator', desc: 'Kc = [C]^c[D]^d / [A]^a[B]^b.' },
  { href: '/tools/gibbs-free-energy-calculator', emoji: '➡️', title: 'Gibbs Free Energy Calculator', desc: 'ΔG = ΔH − TΔS — solve any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="reaction rate depends exponentially on how high the activation-energy barrier is relative to the thermal energy available — small changes in either can swing the rate by orders of magnitude."
  howIntro="Taking the natural log of both sides turns k = Ae^(−Ea/RT) into a straight line, ln(k) = ln(A) − Ea/(RT), plotted against 1/T — the classic Arrhenius plot chemists use to extract Ea and A from experimental rate data. The two-point form skips A entirely, using just the ratio of two rate constants at two temperatures to isolate Ea directly."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the Arrhenius equation actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-k" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Rate constant (k = Ae^−Ea/RT)</button>
      <button id="mode-ea" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Find Ea from two (T,k) points</button>
    </div>

    <div id="k-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">A (pre-exponential factor)</span>
        <input id="A" type="number" step="any" placeholder="e.g. 1e13" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Ea (J/mol)</span>
        <input id="Ea" type="number" step="any" placeholder="e.g. 75000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">T (K)</span>
        <input id="T" type="number" step="any" placeholder="e.g. 298" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="ea-fields" class="hidden gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">k₁</span>
        <input id="k1" type="number" step="any" placeholder="e.g. 1e-3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">T₁ (K)</span>
        <input id="T1" type="number" step="any" placeholder="e.g. 298" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">k₂</span>
        <input id="k2" type="number" step="any" placeholder="e.g. 1e-2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">T₂ (K)</span>
        <input id="T2" type="number" step="any" placeholder="e.g. 308" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2" id="k-out">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white sm:col-span-2"><div class="text-sm opacity-80">Rate constant k</div><div id="r-k" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 hidden" id="ea-out">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white sm:col-span-2"><div class="text-sm opacity-80">Activation energy Ea</div><div id="r-ea" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="ar-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-lowea" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low activation-energy barrier — fast reaction</h3>
          <p class="mt-1 text-sm text-slate-600">Reactants climb a modest energy hill to the activated complex before dropping to products — a lower barrier means more molecules have enough energy to cross it, so the reaction proceeds faster.</p>
        </div>
        <div>
          <div id="diag-highea" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High activation-energy barrier — slow reaction</h3>
          <p class="mt-1 text-sm text-slate-600">Same reactants and products, but a much taller barrier — far fewer molecules have enough energy to cross it at a given temperature, so the reaction is much slower.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Arrhenius equation graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ln(k) vs 1/T — the classic Arrhenius plot</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-lnk"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">k vs T — the exponential rise in rate constant with temperature</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-kt"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const R = 8.314;

      function fmtSci(x) {
        if (!isFinite(x)) return '—';
        if (Math.abs(x) !== 0 && (Math.abs(x) < 1e-3 || Math.abs(x) >= 1e6)) return x.toExponential(3);
        return fmt(x);
      }

      // ---- calculator ----
      let mode = 'k';
      function switchMode(m) {
        mode = m;
        el('mode-k').className = m === 'k' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-ea').className = m === 'ea' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('k-fields').className = m === 'k' ? 'grid gap-4 sm:grid-cols-3' : 'hidden';
        el('ea-fields').className = m === 'ea' ? 'grid gap-4 sm:grid-cols-2' : 'hidden gap-4 sm:grid-cols-2';
        el('k-out').className = m === 'k' ? 'mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2' : 'mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2 hidden';
        el('ea-out').className = m === 'ea' ? 'mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2' : 'mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 hidden';
        el('ar-err').textContent = '';
        update();
      }
      function update() {
        el('ar-err').textContent = '';
        if (mode === 'k') {
          el('r-k').textContent = '—';
          const A = parseFloat(el('A').value), Ea = parseFloat(el('Ea').value), T = parseFloat(el('T').value);
          if (isNaN(A) || isNaN(Ea) || isNaN(T)) return;
          if (T <= 0) { el('ar-err').textContent = 'Temperature must be greater than 0 K.'; return; }
          const k = A * Math.exp(-Ea / (R * T));
          el('r-k').textContent = fmtSci(k);
        } else {
          el('r-ea').textContent = '—';
          const k1 = parseFloat(el('k1').value), T1 = parseFloat(el('T1').value);
          const k2 = parseFloat(el('k2').value), T2 = parseFloat(el('T2').value);
          if (isNaN(k1) || isNaN(T1) || isNaN(k2) || isNaN(T2)) return;
          if (k1 <= 0 || k2 <= 0 || T1 <= 0 || T2 <= 0) { el('ar-err').textContent = 'Rate constants and temperatures must be greater than 0.'; return; }
          if (T1 === T2) { el('ar-err').textContent = 'T₁ and T₂ must be different.'; return; }
          const Ea = -R * Math.log(k2 / k1) / (1 / T2 - 1 / T1);
          el('r-ea').textContent = fmtSci(Ea) + ' J/mol (' + fmt(Ea / 1000) + ' kJ/mol)';
        }
      }
      el('mode-k').addEventListener('click', () => switchMode('k'));
      el('mode-ea').addEventListener('click', () => switchMode('ea'));
      ['A', 'Ea', 'T', 'k1', 'T1', 'k2', 'T2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts (fixed illustrative example: A=1e13, Ea=75000 J/mol) ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const A0 = 1e13, Ea0 = 75000;
        const labelsInvT = [], dataLnK = [];
        for (let T = 280; T <= 360; T += 10) {
          const invT = 1 / T;
          const k = A0 * Math.exp(-Ea0 / (R * T));
          labelsInvT.push(invT.toExponential(3));
          dataLnK.push(+Math.log(k).toFixed(3));
        }
        charts.lnk = new Chart(el('chart-lnk'), {
          type: 'line',
          data: { labels: labelsInvT, datasets: [{ label: 'ln(k)', data: dataLnK, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: '1/T (K⁻¹)' } }, y: { title: { display: true, text: 'ln(k)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsT = [], dataK = [];
        for (let T = 280; T <= 360; T += 5) { labelsT.push(T); dataK.push(A0 * Math.exp(-Ea0 / (R * T))); }
        charts.kt = new Chart(el('chart-kt'), {
          type: 'line',
          data: { labels: labelsT, datasets: [{ label: 'k (s⁻¹)', data: dataK, borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Temperature (K)' } }, y: { title: { display: true, text: 'k (s⁻¹)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- static diagram: reaction energy barrier at two heights ----
      function barrierScene(container, barrierHeight) {
        const s = makeScene(container, 14, new THREE.Vector3(0, 1, 0), SCENE_OPTS);
        const reactMat = new THREE.MeshStandardMaterial({ color: 0xef4444, roughness: 0.4 });
        const prodMat = new THREE.MeshStandardMaterial({ color: 0x10b981, roughness: 0.4 });
        const peakMat = new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.4 });
        const curveMat = new THREE.LineBasicMaterial({ color: 0x94a3b8 });

        const reactPlat = new THREE.Mesh(new THREE.BoxGeometry(2.4, 0.4, 2.4), reactMat);
        reactPlat.position.set(-4, 0, 0); s.scene.add(reactPlat);

        const prodPlat = new THREE.Mesh(new THREE.BoxGeometry(2.4, 0.4, 2.4), prodMat);
        prodPlat.position.set(4, -1.5, 0); s.scene.add(prodPlat);

        const peak = new THREE.Mesh(new THREE.ConeGeometry(0.6, barrierHeight, 16), peakMat);
        peak.position.set(0, barrierHeight / 2, 0); s.scene.add(peak);

        // curve outline (reactants -> peak -> products)
        const pts = [];
        for (let x = -4; x <= 4; x += 0.2) {
          const t = (x + 4) / 8;
          const y = -1.5 * t + barrierHeight * Math.sin(Math.PI * t) * (1 - t * 0.3);
          pts.push(new THREE.Vector3(x, y, 0));
        }
        const curve = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), curveMat);
        s.scene.add(curve);

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() {
        const c = el('diag-lowea'); if (!c) throw new Error('no container');
        diagLow = barrierScene(c, 2.2);
      }
      function initDiagHigh() {
        const c = el('diag-highea'); if (!c) throw new Error('no container');
        diagHigh = barrierScene(c, 4.8);
      }

      function boot() {
        try { switchMode('k'); } catch (e) { console.error('[arrhenius] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[arrhenius] charts failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[arrhenius] low-Ea diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[arrhenius] high-Ea diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
