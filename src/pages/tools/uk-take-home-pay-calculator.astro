---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { ukIncomeTax, taxYearsToJson } from '../../data/tax.js';

// Available tax years, newest first (keys like "2026/27").
const taxYears = Object.keys(ukIncomeTax.years).sort().reverse();
const latestYear = taxYears[0];
const taxDataJson = taxYearsToJson(ukIncomeTax);

const title = 'UK Take-Home Pay Calculator';
const description = 'Calculate UK net salary after income tax and National Insurance deductions using the latest rates, for an accurate monthly or annual take-home figure.';
const intro = 'Calculate UK net salary after income tax and National Insurance deductions.';
const category = { id: 'finance', name: 'Finance Tools' };
const faqs = [
  { q: 'What are the 2025/26 UK tax rates?', a: 'Personal allowance £12,570 (0%), basic rate 20% (£12,571-£50,270), higher rate 40% (£50,271-£125,140), additional rate 45% (above £125,140).' },
  { q: 'How is National Insurance calculated?', a: 'Employees pay 8% on earnings between £12,570 and £50,270, and 2% on earnings above £50,270.' },
  { q: 'What about Scotland?', a: 'Scottish taxpayers have six income tax bands: starter 19%, basic 20%, intermediate 21%, higher 42%, advanced 45%, and top 48%. Tick the Scotland option to use these bands.' },
  { q: 'How does a pension affect my take-home pay?', a: 'Pension contributions come out of your gross pay before tax, reducing your taxable income.' },
];
const sources = [
  { html: "<strong>HM Revenue &amp; Customs (HMRC)</strong> — Income Tax bands, Personal Allowance and National Insurance rates. <a href=\"https://www.gov.uk/income-tax-rates\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">gov.uk/income-tax-rates</a>" },
  { html: "<strong>HMRC PAYE guidance</strong> for the relevant tax year." },
];
const sourcesNote = "Estimate only, not tax advice. Confirm current thresholds with HMRC or a qualified accountant.";

---

<ToolLayout {title} {description} {intro} {category} {faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="mb-4">
        <label for="year" class="block text-sm font-medium text-slate-700">Tax year</label>
        <select id="year" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          {taxYears.map((y) => <option value={y} selected={y === latestYear}>{y}</option>)}
        </select>
      </div>
      <!-- Versioned bracket data (one entry per tax year). Infinity serialized as null. -->
      <script type="application/json" id="tax-data" set:html={taxDataJson}></script>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="salary" class="block text-sm font-medium text-slate-700">Annual Salary (£)</label>
          <input id="salary" type="number" min="0" step="1000" value="50000" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label for="pension" class="block text-sm font-medium text-slate-700">Pension Contribution (%)</label>
          <input id="pension" type="number" min="0" max="50" step="1" value="0" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
      <div class="mt-4 flex items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-slate-700"><input id="scotland" type="checkbox" class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" /> Scottish taxpayer</label>
        <div>
          <label for="student-loan" class="text-sm text-slate-700">Student loan plan</label>
          <select id="student-loan" class="ml-2 rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400">
            <option value="none">None</option>
            <option value="plan1">Plan 1</option>
            <option value="plan2">Plan 2</option>
            <option value="plan4">Plan 4</option>
          </select>
        </div>
      </div>
      <button id="calc-btn" class="mt-4 w-full rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700">Calculate</button>

      <div id="results" class="mt-6 hidden space-y-4">
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="rounded-xl bg-green-50 p-3 text-center"><span class="text-xs font-medium text-green-700">Gross Salary</span><p id="gross-val" class="mt-1 text-lg font-bold text-green-800"></p></div>
          <div class="rounded-xl bg-red-50 p-3 text-center"><span class="text-xs font-medium text-red-700">Income Tax</span><p id="tax-val" class="mt-1 text-lg font-bold text-red-800"></p></div>
          <div class="rounded-xl bg-orange-50 p-3 text-center"><span class="text-xs font-medium text-orange-700">National Insurance</span><p id="ni-val" class="mt-1 text-lg font-bold text-orange-800"></p></div>
          <div class="rounded-xl bg-indigo-50 p-3 text-center"><span class="text-xs font-medium text-indigo-700">Net Pay</span><p id="net-val" class="mt-1 text-lg font-bold text-indigo-800"></p></div>
        </div>
        <div class="rounded-xl bg-slate-50 p-3 text-center text-sm text-slate-600" id="breakdown"></div>
      </div>
    </div>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">How UK income tax works</h2>
      <p class="mt-2 text-slate-600">The UK uses a progressive tax system: you pay no tax on the first £12,570 (Personal Allowance), 20% on the next £37,700, 40% on earnings from £50,271 to £125,140, and 45% on everything above. National Insurance is a separate contribution that funds the NHS, state pension, and other benefits.</p>
      <h3 class="mt-4 font-semibold text-slate-900">Worked example — £50,000 salary (2025/26, England)</h3>
      <p class="mt-2 text-slate-600">The first £12,570 is tax-free, leaving £37,430 taxed at the 20% basic rate = <strong>£7,486 income tax</strong>. Employee National Insurance is 8% on earnings between £12,570 and £50,270, so 8% of £37,430 = <strong>£2,994</strong>. Take-home pay is therefore roughly £50,000 − £7,486 − £2,994 = <strong>£39,520 a year</strong> (about £3,293 a month) before any pension or student-loan deductions. Adding a 5% pension contribution lowers taxable pay first, so it both cuts the tax bill and moves money into your pension.</p>
      <p class="mt-3 text-xs text-slate-400">Figures illustrate the 2025/26 rest-of-UK rates; use the calculator above for your exact salary, tax year and region.</p>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="text-lg font-bold text-slate-900">Tips</h2>
      <ul class="mt-3 list-inside list-disc space-y-2 text-sm text-slate-600">
        <li>Pension contributions are deducted before tax, reducing your taxable income.</li>
        <li>The Personal Allowance reduces by £1 for every £2 earned over £100,000.</li>
        <li>Marriage Allowance lets couples transfer unused Personal Allowance.</li>
      </ul>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="text-lg font-bold text-slate-900">Related tools</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        <a href="/tools/salary-calculator/" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Salary Calculator</a>
        <a href="/tools/freelancer-tax-calculator/" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Freelancer Tax Estimator</a>
      </div>
    </section>
  </div>
</ToolLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var salaryInput = document.getElementById('salary');
    var pensionInput = document.getElementById('pension');
    var scotlandCheck = document.getElementById('scotland');
    var studentLoan = document.getElementById('student-loan');
    var yearSelect = document.getElementById('year');
    var calcBtn = document.getElementById('calc-btn');
    var results = document.getElementById('results');
    var TAX = JSON.parse(document.getElementById('tax-data').textContent);

    function fmt(v) { return '\u00A3' + Math.round(v).toLocaleString('en-GB'); }

    function calculate() {
      var gross = parseFloat(salaryInput.value) || 0;
      var pensionPct = parseFloat(pensionInput.value) || 0;
      var isScotland = scotlandCheck.checked;
      var slPlan = studentLoan.value;

      var pensionAmount = gross * pensionPct / 100;
      var taxable = Math.max(0, gross - pensionAmount);

      var yd = TAX[yearSelect.value];

      var personalAllowance = yd.personalAllowance;
      if (taxable > 100000) personalAllowance = Math.max(0, personalAllowance - Math.floor((taxable - 100000) / 2));

      // Progressive income tax using the selected year's bands (Scotland or rest of UK).
      var region = isScotland ? yd.scotland : yd.rUK;
      var tax = 0, prev = personalAllowance;
      if (taxable > personalAllowance) {
        for (var i = 0; i < region.bands.length; i++) {
          var cap = region.bands[i] === null ? Infinity : region.bands[i];
          if (taxable > prev) {
            var chunk = Math.min(taxable, cap) - prev;
            if (chunk > 0) tax += chunk * region.rates[i];
            prev = cap;
          }
        }
      }

      // National Insurance (employee Class 1) for the selected year.
      var niCfg = yd.ni;
      var ni = 0;
      if (taxable > niCfg.primaryThreshold) {
        var upper = Math.min(taxable, niCfg.upperEarningsLimit);
        var mid = upper - niCfg.primaryThreshold;
        if (mid > 0) ni += mid * niCfg.mainRate;
        if (taxable > niCfg.upperEarningsLimit) ni += (taxable - niCfg.upperEarningsLimit) * niCfg.upperRate;
      }

      // Student loan thresholds were previously a single hardcoded snapshot
      // that never changed with the year selector above (and had drifted
      // ~2-3 years stale). Now sourced per-year from the same TAX data as
      // everything else on this page.
      var sl = 0;
      if (slPlan !== 'none' && yd.studentLoan) {
        var slThreshold = yd.studentLoan[slPlan];
        if (taxable > slThreshold) sl = (taxable - slThreshold) * yd.studentLoan.rate;
      }

      var net = gross - tax - ni - sl - pensionAmount;

      document.getElementById('gross-val').innerHTML = fmt(gross);
      document.getElementById('tax-val').innerHTML = fmt(Math.round(tax));
      document.getElementById('ni-val').innerHTML = fmt(Math.round(ni));
      document.getElementById('net-val').innerHTML = fmt(Math.round(net));

      var monthly = net / 12;
      var weekly = net / 52;
      var hourly = weekly / 37.5;
      document.getElementById('breakdown').innerHTML = 'Monthly: ' + fmt(Math.round(monthly)) + ' | Weekly: ' + fmt(Math.round(weekly)) + ' | Hourly (37.5h): ' + fmt(Math.round(hourly));

      if (sl > 0) document.getElementById('breakdown').innerHTML += '<br />Student loan repayment: ' + fmt(Math.round(sl));

      var regionName = isScotland ? 'Scotland' : 'England, Wales & N. Ireland';
      document.getElementById('breakdown').innerHTML +=
        '<br /><span class="mt-2 block text-xs text-slate-400">' + regionName + ' rates for the ' + yearSelect.value +
        ' UK tax year (HMRC / Scottish Government), verified ' + yd.verified +
        '. Estimate only — not tax advice.</span>';

      results.classList.remove('hidden');
    }

    calcBtn.addEventListener('click', calculate);
    // Re-calculate when the year changes if results are already showing.
    yearSelect.addEventListener('change', function () { if (!results.classList.contains('hidden')) calculate(); });
  });
</script>