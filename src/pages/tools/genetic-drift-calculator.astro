---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Genetic Drift Simulator';
const description = 'Genetic drift simulator with a live 3D allele-sampling diagram and charts. Solve expected heterozygosity decay Ht = H0(1-1/2N)^t under random drift, plus simulated random allele-frequency trajectories, with worked examples.';
const intro = 'Solve Ht = H0(1−1/2N)^t for how much genetic diversity a population is expected to lose purely by chance over generations, then watch simulated random allele-frequency trajectories for different population sizes. Two 3D diagrams compare a large population (slow drift) to a small one (fast drift), and charts trace several random walk trajectories alongside the expected heterozygosity decay curve.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is genetic drift?', a: 'Genetic drift is random change in allele frequency from one generation to the next, caused purely by chance in which individuals happen to survive and reproduce — distinct from natural selection, which is driven by consistent fitness differences.' },
  { q: 'Why does population size matter so much for genetic drift?', a: 'Smaller populations sample fewer individuals each generation, so random chance has a much bigger relative effect on allele frequency — exactly like how flipping a coin 10 times gives a far less reliable estimate of "50/50" than flipping it 10,000 times.' },
  { q: 'What is expected heterozygosity, and why does it decay under drift?', a: 'Expected heterozygosity (H=2pq) measures genetic diversity at a gene. Random drift causes alleles to be lost by chance over generations (especially in small populations), so average heterozygosity across many replicate populations steadily declines according to Ht = H0(1−1/2N)^t.' },
  { q: 'Can genetic drift alone cause an allele to disappear completely?', a: 'Yes — unlike selection against a rare recessive allele (which slows dramatically as the allele becomes rare), genetic drift can fully eliminate or fix any allele by pure chance, regardless of whether it\'s helpful, harmful, or neutral.' },
  { q: 'What are the founder effect and bottleneck effect?', a: 'Both are extreme, real-world examples of genetic drift: a founder effect occurs when a small group establishes a new population (carrying only a random sample of the original population\'s genetic diversity), and a bottleneck effect occurs when an existing population\'s size crashes sharply, randomly losing much of its diversity in the process.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Genetic Drift Simulator',
  description: 'Solve expected heterozygosity decay under genetic drift and view simulated random allele-frequency trajectories.',
  steps: [
    { name: 'Enter population size and starting frequency', text: 'Effective population size (N) and the starting allele frequency (p0).' },
    { name: 'Enter number of generations', text: 'How many generations to project forward.' },
    { name: 'Read expected heterozygosity', text: 'The expected proportion of original genetic diversity remaining after that many generations.' },
  ],
};

const formulas = [
  { expr: 'Ht = H0 × (1 − 1/2N)ᵗ', note: 'expected heterozygosity after t generations — H0=starting heterozygosity (2p0q0), N=population size' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a moderately sized population', tone: 'slate',
    given: 'A population of N=50 individuals, starting allele frequencies p0=q0=0.5 (H0=0.5), projected 50 generations forward.',
    rows: [
      { label: 'Formula:', value: 'Ht = H0 × (1−1/2N)ᵗ' },
      { label: 'Substitute:', value: 'Ht = 0.5 × (1−1/100)⁵⁰ = 0.5 × (0.99)⁵⁰' },
      { label: 'Result:', value: 'Ht ≈ 0.303 — about 60% of the original heterozygosity remains', full: true },
    ],
    note: 'Even after 50 generations, a population of 50 individuals retains a majority of its original genetic diversity — moderate population sizes drift relatively slowly.',
  },
  {
    title: 'Worked example 2 — a much smaller population', tone: 'amber',
    given: 'A tiny population of N=5 individuals, same starting H0=0.5, projected only 10 generations forward.',
    rows: [
      { label: 'Formula:', value: 'Ht = H0 × (1−1/2N)ᵗ' },
      { label: 'Substitute:', value: 'Ht = 0.5 × (1−0.1)¹⁰ = 0.5 × (0.9)¹⁰' },
      { label: 'Result:', value: 'Ht ≈ 0.174 — down to about 35% of the original heterozygosity, in just 10 generations', full: true },
    ],
    note: 'This tiny population loses proportionally far more diversity in one-fifth the time — small populations lose genetic diversity to drift dramatically faster than larger ones.',
  },
];

const comparison = {
  heading: 'How population size changes the rate of diversity loss',
  note: 'Starting from H0=0.5 in all cases, after 20 generations.',
  headers: [{ label: 'Population size (N)' }, { label: 'Heterozygosity after 20 generations' }],
  rows: [
    ['5 (very small)', '≈0.061'],
    ['20 (small)', '≈0.301'],
    ['50 (moderate) ★', '≈0.409'],
    ['500 (large)', '≈0.490'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row. A tenfold increase in population size (50→500) dramatically slows diversity loss — this is exactly why small, isolated populations are at much greater risk of losing genetic diversity than large ones.',
};

const realWorld = [
  { emoji: '🦏', title: 'Endangered species conservation genetics', body: "Conservation biologists monitor genetic drift closely in small, endangered populations, since rapid diversity loss can reduce a species' ability to adapt to future environmental challenges or disease." },
  { emoji: '🏝️', title: 'Island and isolated population biology', body: 'Species on islands or in other geographically isolated habitats often show strong genetic drift effects (and founder effects), producing genetically distinctive populations compared to their mainland relatives.' },
  { emoji: '🐕', title: 'Purebred animal breeding', body: "Breeding within a small, closed population — as in many purebred dog breeds — accelerates genetic drift and inbreeding, contributing to the reduced genetic diversity and elevated disease risk seen in some breeds." },
  { emoji: '🧬', title: 'Human population genetics history', body: "Genetic drift signatures (like reduced diversity in populations descended from small founding groups) help population geneticists reconstruct historical migration and settlement patterns." },
];

const misconceptions = [
  { claim: '"Genetic drift and natural selection are just two names for the same process."', truth: "They're fundamentally different processes — natural selection is a consistent, directional force based on fitness differences, while genetic drift is purely random chance that can push allele frequency in any direction, including against an allele's own fitness advantage." },
  { claim: '"Genetic drift only matters in very unusual, extreme circumstances."', truth: "Drift is always acting on every finite population to some degree — it's simply far more noticeable and consequential in small populations, while its effects are comparatively minor (though never fully zero) in very large ones." },
  { claim: '"A population can only lose diversity to drift, never regain it."', truth: 'Once an allele is completely lost to drift, it can only return through new mutation or migration from another population — but heterozygosity itself is a population-average measure, and while drift-driven diversity loss is directional on average, individual populations can show real fluctuations along the way.' },
  { claim: '"Larger populations are completely immune to genetic drift."', truth: "Drift technically still occurs in large populations — it just proceeds far more slowly, since the formula's (1−1/2N) term approaches 1 for large N, meaning heterozygosity is lost extremely gradually rather than not at all." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 20, "Evolution" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/20-1-population-evolution" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Wright (1931)</strong> — foundational population genetics drift theory, <em>Genetics</em>.' },
  { html: '<strong>Hartl &amp; Clark, <em>Principles of Population Genetics</em></strong> — Genetic drift chapter.' },
];
const sourcesNote = 'Ht=H0(1−1/2N)ᵗ (Wright-Fisher model expected heterozygosity decay). Simulated trajectories use random binomial sampling each generation. Results are rounded for display.';

const howToUse = [
  { title: 'Enter population size and starting frequency', body: 'Effective population size and the starting allele frequency.' },
  { title: 'Enter number of generations', body: 'How far forward to project expected heterozygosity.' },
  { title: 'Compare to simulated trajectories', body: 'Random walk simulations illustrate the variability drift produces around the expected trend.' },
];

const related = [
  { href: '/tools/hardy-weinberg-calculator', emoji: '⚖️', title: 'Hardy-Weinberg Allele Frequency Calculator', desc: 'p²+2pq+q²=1 — predicted equilibrium frequencies.' },
  { href: '/tools/natural-selection-calculator', emoji: '🦋', title: 'Natural Selection Simulator', desc: 'Allele frequency change over generations under selection.' },
  { href: '/tools/mark-recapture-calculator', emoji: '🔎', title: 'Mark-Recapture Population Estimator', desc: 'Lincoln-Petersen index — estimate population size.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="every generation is a random sample of who happens to survive and reproduce, and the smaller that sample is, the more its results can wander away from the previous generation's true allele frequency by chance alone — exactly like a small poll being a noisier estimate than a huge one."
  howIntro="Genetic drift happens because each new generation's alleles are, in effect, a random sample drawn from the previous generation's gene pool — and any random sample carries sampling error. In a small population, that sample is small, so chance fluctuations are large relative to the total population; in a large population, the same random sampling process averages out much more smoothly. Averaged across many hypothetical replicate populations, this sampling error causes expected heterozygosity to decay predictably according to Ht=H0(1−1/2N)ᵗ — but any single real population's actual trajectory is a genuinely random walk, wandering unpredictably above or below that expected trend line."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where genetic drift actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Population size (N)</span>
        <input id="pop" type="number" step="1" min="2" value="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Starting frequency (p0)</span>
        <input id="p0" type="number" step="any" value="0.5" min="0" max="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Generations</span>
        <input id="gens" type="number" step="1" min="1" max="200" value="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Expected heterozygosity after N generations</div><div id="r-ht" class="mt-1 text-2xl font-bold">—</div></div>
    <p id="gd-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Large vs. small population drift</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-large" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Large population</h3>
          <p class="mt-1 text-sm text-slate-600">Many individuals sampled each generation — drift proceeds slowly.</p>
        </div>
        <div>
          <div id="diag-small" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Small population</h3>
          <p class="mt-1 text-sm text-slate-600">Few individuals sampled each generation — drift proceeds quickly.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Drift charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Simulated random allele-frequency trajectories</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-trajectories"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Expected heterozygosity decay by population size</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-heterozygosity"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};

      function binomialSample(n, p) {
        let count = 0;
        for (let i = 0; i < n; i++) if (Math.random() < p) count++;
        return count;
      }
      function simulateTrajectory(N, p0, gens) {
        const twoN = 2 * N;
        let p = p0;
        const arr = [p];
        for (let i = 0; i < gens; i++) {
          const count = binomialSample(twoN, p);
          p = count / twoN;
          arr.push(p);
          if (p <= 0 || p >= 1) { for (let j = i + 1; j < gens; j++) arr.push(p); break; }
        }
        return arr;
      }
      function expectedH(H0, N, t) { return H0 * Math.pow(1 - 1 / (2 * N), t); }

      // ---- calculator ----
      function update() {
        el('gd-err').textContent = '';
        el('r-ht').textContent = '—';
        const pop = parseInt(el('pop').value, 10), p0 = parseFloat(el('p0').value), gens = parseInt(el('gens').value, 10);
        if (isNaN(pop) || isNaN(p0) || isNaN(gens)) return;
        if (pop < 2 || p0 < 0 || p0 > 1 || gens < 1) { el('gd-err').textContent = 'Population size must be at least 2; p0 between 0 and 1; generations at least 1.'; return; }
        const H0 = 2 * p0 * (1 - p0);
        const Ht = expectedH(H0, pop, gens);
        el('r-ht').textContent = fmt(Ht) + ' (of H0=' + fmt(H0) + ')';
        updateTrajectories(pop, p0, gens);
      }
      ['pop', 'p0', 'gens'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.traj = new Chart(el('chart-trajectories'), {
          type: 'line',
          data: { labels: [], datasets: [] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Generation' } }, y: { min: 0, max: 1, title: { display: true, text: 'Allele frequency (p)' } } }, plugins: { legend: { display: false } } }),
        });
        const gensRange = Array.from({ length: 21 }, (_, i) => i);
        const nVals = [5, 50, 500];
        const colors = ['#ef4444', '#6366f1', '#94a3b8'];
        charts.het = new Chart(el('chart-heterozygosity'), {
          type: 'line',
          data: { labels: gensRange, datasets: nVals.map((n, i) => ({ label: 'N=' + n, data: gensRange.map((t) => expectedH(0.5, n, t)), borderColor: colors[i], backgroundColor: 'transparent', tension: 0.2, pointRadius: 0 })) },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Generation' } }, y: { min: 0, max: 0.5, title: { display: true, text: 'Expected heterozygosity' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }
      function updateTrajectories(pop, p0, gens) {
        if (!charts.traj) return;
        const numTrajectories = 4;
        const colors = ['#6366f1', '#f59e0b', '#10b981', '#ef4444'];
        const datasets = [];
        for (let k = 0; k < numTrajectories; k++) {
          const arr = simulateTrajectory(pop, p0, gens);
          datasets.push({ label: 'Trajectory ' + (k + 1), data: arr, borderColor: colors[k], backgroundColor: 'transparent', tension: 0.1, pointRadius: 0 });
        }
        charts.traj.data.labels = Array.from({ length: gens + 1 }, (_, i) => i);
        charts.traj.data.datasets = datasets;
        charts.traj.update('none');
      }

      function popScene(container, count, jitter) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < count; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.16, 10, 8), new THREE.MeshStandardMaterial({ color: Math.random() < 0.5 ? 0x6366f1 : 0xf59e0b }));
          m.position.set((Math.random() - 0.5) * jitter, (Math.random() - 0.5) * jitter * 0.7, (Math.random() - 0.5) * jitter * 0.5);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLarge = null, diagSmall = null;
      function initDiagLarge() { const c = el('diag-large'); if (!c) throw new Error('no container'); diagLarge = popScene(c, 45, 5); }
      function initDiagSmall() { const c = el('diag-small'); if (!c) throw new Error('no container'); diagSmall = popScene(c, 6, 3); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[genetic-drift] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagLarge(); } catch (e) { console.error('[genetic-drift] large diagram failed', e); }
          try { initDiagSmall(); } catch (e) { console.error('[genetic-drift] small diagram failed', e); }
        }
        mountResize([diagLarge, diagSmall]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
