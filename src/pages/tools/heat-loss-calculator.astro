---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Home Heat Loss Estimator';
const description = 'Estimate the heat loss rate through a wall, roof or floor area from its R-value and the indoor/outdoor temperature difference, in BTUs per hour.';
const intro = 'Estimate the heat loss rate through a surface, in BTUs per hour, from its area, R-value, and the temperature difference across it.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do you calculate heat loss?', a: 'Heat loss follows Q = A / R x deltaT, where A is the area in square feet, R is the R-value of the assembly, and deltaT is the indoor minus outdoor temperature in degrees Fahrenheit. The result is in BTUs per hour, the rate heat is escaping through that surface.' },
  { q: 'What does R-value mean here?', a: 'R-value measures resistance to heat flow — a higher R-value means better insulation and slower heat loss. It is the inverse of U-value (U = 1/R), which some heat-loss references use directly. This calculator uses R-value since it is the number printed on insulation products.' },
  { q: 'Why does temperature difference matter so much?', a: 'Heat loss is directly proportional to the gap between indoor and outdoor temperature — double the temperature difference and you double the heat loss through that surface, which is why the coldest night of the year, not the average temperature, sets the design load.' },
  { q: 'Does this calculate my whole house heating load?', a: 'This tool estimates heat loss through one surface — a wall, roof, floor, or window area — at a time. A full whole-house heat-loss study, following ASHRAE fundamentals or an ACCA Manual J, adds up every surface plus air infiltration.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Surface area (sq ft)</span>
        <input id="area" type="number" step="any" placeholder="1200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">R-value</span>
        <input id="rval" type="number" step="any" placeholder="19" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Indoor temp (°F)</span>
        <input id="tin" type="number" step="any" placeholder="70" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Outdoor design temp (°F)</span>
        <input id="tout" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Heat loss rate</div>
        <div id="r-btu" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-day" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">U-value</div><div id="r-u" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">&Delta;T</div><div id="r-dt" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Loss per sq ft</div><div id="r-perft" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="hl-title hl-desc">
      <title id="hl-title">Heat flow through a wall assembly</title>
      <desc id="hl-desc">A wall cross-section with warm indoor air and cold outdoor air, showing heat flowing outward, with the Q=A/R×ΔT formula</desc>
      <rect x="200" y="70" width="40" height="170" fill="#c7d2fe" stroke="#6366f1" stroke-width="2" />
      <rect x="90" y="70" width="110" height="170" fill="#fde68a" opacity="0.5" />
      <rect x="240" y="70" width="110" height="170" fill="#bfdbfe" opacity="0.6" />
      <text x="145" y="160" text-anchor="middle" font-size="13" fill="#92400e" font-family="system-ui,sans-serif">indoor 70&deg;F</text>
      <text x="295" y="160" text-anchor="middle" font-size="13" fill="#1e40af" font-family="system-ui,sans-serif">outdoor 10&deg;F</text>
      <path d="M170 150 L235 150" stroke="#ef4444" stroke-width="2.5" marker-end="url(#arrow)" />
      <defs><marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#ef4444"/></marker></defs>
      <text x="220" y="60" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">heat flows warm &rarr; cold</text>
      <rect x="440" y="90" width="280" height="120" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="460" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Heat-loss formula</text>
      <text x="460" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Q = A &divide; R &times; &Delta;T</text>
      <text x="460" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">&Delta;T = indoor &minus; outdoor (&deg;F)</text>
      <text x="460" y="188" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Q in BTU per hour</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Heat always flows from warm to cold; the rate depends on the area, the R-value, and the temperature gap.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the heat loss estimator works</h2>
    <p class="mt-2 text-slate-600">
      Heat always moves from warm to cold, and the rate it moves through a wall, roof, or floor follows a simple physical relationship: the area of the surface, divided by its R-value, times the temperature difference across it. This is the standard building-science heat-transfer equation, expressed with R-value since that is the number printed on insulation.
    </p>
    <p class="mt-3 text-slate-600">
      R-value measures resistance to heat flow, so a higher R-value means slower heat loss for the same area and temperature gap. Dividing area by R-value gives the U-value contribution — the conductance — and multiplying by the temperature difference gives the heat-loss rate in BTUs per hour. Double the temperature gap and the loss doubles; double the R-value and the loss is cut in half.
    </p>
    <p class="mt-3 text-slate-600">
      Engineers use an outdoor "design temperature," not the average winter temperature, because a heating system has to keep up on the coldest expected night, not a typical one. This calculator estimates heat loss through one surface at a time, matching the surface-by-surface method in ASHRAE fundamentals; a full whole-house load also sums every wall, window, roof, and floor plus air infiltration.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a surface</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the area and R-value of one wall, roof, floor, or window section.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set temperatures</h3>
        <p class="mt-1 text-sm text-slate-600">Use your target indoor temperature and the local winter design temperature.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the loss rate</h3>
        <p class="mt-1 text-sm text-slate-600">See BTUs per hour, and repeat for each surface to build a full estimate.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Temperature difference</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">&Delta;T = T_in &minus; T_out</span>. 70&deg;F indoors, 10&deg;F design outdoor: 70 &minus; 10 = <strong>60&deg;F</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Heat loss rate</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Q = A &divide; R &times; &Delta;T</span>. A 1200 ft&sup2; wall at R-19: 1200&frasl;19 &times; 60 = <strong>3,789 BTU/hr</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Effect of more insulation</p>
        <p class="mt-1 text-slate-600">
          The same wall at R-38: 1200&frasl;38 &times; 60 = <strong>1,895 BTU/hr</strong> — half the loss for double the R-value.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 400 ft&sup2; window wall at R-2 (typical double-pane), 65&deg;F indoors, 20&deg;F outside.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">&Delta;T:</span> <span class="text-slate-600">65 &minus; 20 = 45&deg;F</span></div>
        <div><span class="font-medium text-slate-700">Q:</span> <span class="text-slate-600">400&frasl;2 &times; 45 = <strong>9,000 BTU/hr</strong></span></div>
        <div><span class="font-medium text-slate-700">Compare an R-19 wall:</span> <span class="text-slate-600">400&frasl;19 &times; 45 = 947 BTU/hr</span></div>
        <div><span class="font-medium text-slate-700">Takeaway:</span> <span class="text-slate-600">windows lose far more heat per ft&sup2;</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Where heat loss adds up</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🪟</span>
        <h3 class="mt-2 font-semibold text-slate-900">Windows and doors</h3>
        <p class="mt-1 text-sm text-slate-600">Glass has a much lower R-value than an insulated wall, so windows and doors lose disproportionately more heat per square foot than the walls around them.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏚️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Attics and roofs</h3>
        <p class="mt-1 text-sm text-slate-600">Heat rises, and an under-insulated attic is one of the biggest single sources of winter heat loss in most homes — often the highest-value place to add insulation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">💨</span>
        <h3 class="mt-2 font-semibold text-slate-900">Air leakage</h3>
        <p class="mt-1 text-sm text-slate-600">This calculator covers conduction through surfaces only. Air leaking through gaps, cracks, and penetrations adds a separate infiltration load that a full heat-loss study also accounts for.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Below-grade and slabs</h3>
        <p class="mt-1 text-sm text-slate-600">Basement walls and slab edges lose heat to the ground, which behaves differently from air, so they are usually calculated with separate below-grade methods rather than this simple formula.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/furnace-btu-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Furnace BTU Calculator</a>
      <a href="/tools/insulation-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Insulation Calculator</a>
      <a href="/tools/ac-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">AC Unit Size Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const A = parseFloat(el('area').value);
      const R = parseFloat(el('rval').value);
      const Tin = parseFloat(el('tin').value);
      const Tout = parseFloat(el('tout').value);
      if (!A || !R || A <= 0 || R <= 0 || isNaN(Tin) || isNaN(Tout)) {
        el('results').classList.add('hidden');
        return;
      }
      const dT = Tin - Tout;
      const U = 1 / R;
      const Q = (A / R) * dT;
      const perFt = Q / A;
      const perDay = Q * 24;

      el('r-btu').textContent = Math.round(Q).toLocaleString() + ' BTU/hr';
      el('r-day').textContent = dT >= 0 ? ('≈ ' + Math.round(perDay).toLocaleString() + ' BTU/day at this ΔT') : 'ΔT is negative — outdoor is warmer than indoor';
      el('r-u').textContent = U.toFixed(3);
      el('r-dt').textContent = dT.toFixed(0) + '°F';
      el('r-perft').textContent = perFt.toFixed(2) + ' BTU/hr·ft²';
      el('results').classList.remove('hidden');
    }

    ['area', 'rval', 'tin', 'tout'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
