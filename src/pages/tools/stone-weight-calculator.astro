---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Stone Weight Calculator';
const description = 'Find the weight of decorative or landscaping stone, boulders and rock from its volume and stone type — granite, limestone, sandstone and river rock density.';
const intro = 'Find the weight of stone or a boulder from its volume and the type of rock.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much does a cubic foot of stone weigh?', a: 'It depends on the rock type: granite runs about 165-170 pounds per cubic foot, limestone about 150-175, sandstone about 130-150, and river rock (mixed) around 150-170. This calculator uses typical mid-range values per type.' },
  { q: 'How do I estimate the volume of an irregular boulder?', a: 'Treat it as a rough sphere or box, whichever it resembles more closely, and measure its widest dimensions. For a roughly round boulder, volume = (4/3) × π × radius³ using half its average diameter as the radius; this overestimates slightly since boulders are rarely perfect spheres.' },
  { q: 'Why does stone weight matter?', a: 'It determines whether a truck, trailer, or lift rated for a certain payload can safely move a boulder or a load of rock, and whether a retaining structure or vehicle can support decorative stone placed on it. Landscaping boulders over a few hundred pounds usually need equipment to place, not manual labor.' },
  { q: 'How much does a yard of decorative rock weigh?', a: 'A cubic yard of typical landscaping stone weighs roughly 2,400 to 2,800 pounds (1.2 to 1.4 tons), varying by rock type and how tightly it\'s packed — loose, larger rock weighs less per cubic yard than smaller, densely packed gravel.' },
];
const howTo = {
  name: 'How to calculate the weight of stone',
  steps: [
    { name: 'Pick the shape', text: 'Choose round boulder (sphere) or a more block-like piece (box) — whichever the stone resembles most closely.' },
    { name: 'Measure it', text: 'Enter the average diameter for a boulder, or length, width, and height for a block, in inches.' },
    { name: 'Match the stone type', text: 'Select the rock type — granite, limestone, sandstone, or river rock — to get a weight estimate for lifting and hauling.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Shape</span>
      <select id="shape" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="sphere" selected>Round boulder (sphere)</option>
        <option value="box">Rough block (box)</option>
      </select></label>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label id="w-dia" class="block"><span class="text-sm font-medium text-slate-700">Average diameter (in)</span>
        <input id="dia" type="number" step="any" placeholder="24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-len" class="hidden"><span class="text-sm font-medium text-slate-700">Length (in)</span>
        <input id="len" type="number" step="any" placeholder="24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-width" class="hidden"><span class="text-sm font-medium text-slate-700">Width (in)</span>
        <input id="width" type="number" step="any" placeholder="18" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-height" class="hidden"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="height" type="number" step="any" placeholder="16" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Stone type</span>
        <select id="density" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="130">Sandstone (~130 lb/ft³)</option>
          <option value="150">River rock (~150 lb/ft³)</option>
          <option value="160" selected>Limestone (~160 lb/ft³)</option>
          <option value="170">Granite (~170 lb/ft³)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated weight</div>
        <div id="r-weight" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Volume</div><div id="r-vol" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">In tons</div><div id="r-tons" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sw-title sw-desc">
      <title id="sw-title">Stone weight from volume and density</title>
      <desc id="sw-desc">A round boulder and a block of stone with the weight formula</desc>
      <circle cx="130" cy="120" r="55" fill="#d6d3d1" stroke="#78716c" stroke-width="2" />
      <path d="M100 90 Q130 100 120 130 Q145 140 150 160" stroke="#a8a29e" stroke-width="2" fill="none" />
      <rect x="260" y="80" width="110" height="80" fill="#e7e5e4" stroke="#78716c" stroke-width="2" />
      <text x="130" y="190" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">boulder</text>
      <text x="315" y="180" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">block</text>
      <rect x="440" y="55" width="310" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="460" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Stone weight</text>
      <text x="460" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">sphere: (4&frasl;3)&pi;r&sup3; &times; density</text>
      <text x="460" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">box: L&times;W&times;H &times; density</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Boulder shapes are approximated as a sphere; blocks as a rectangular box.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the stone weight calculator works</h2>
    <p class="mt-2 text-slate-600">
      Stone weight is volume times density, but the tricky part with natural stone is getting a reasonable volume for an irregular shape. A rounded landscaping boulder is approximated as a sphere, using half its average diameter as the radius in the standard sphere volume formula, (4/3) × π × radius cubed. A more block-like piece of stone is approximated as a rectangular box: length times width times height. Both are estimates — real stone is neither a perfect sphere nor a perfect box, so the true weight will vary from the estimate, usually somewhat lower for a very irregular or flattened boulder.
    </p>
    <p class="mt-3 text-slate-600">
      Density depends heavily on rock type. Granite is among the densest common landscaping stone at roughly 165 to 170 pounds per cubic foot, limestone and river rock fall in a similar 150 to 175 range, and sandstone is noticeably lighter at 130 to 150 pounds per cubic foot due to its higher porosity. Picking the density that matches your actual stone gives a meaningfully more accurate weight than assuming one universal rock density.
    </p>
    <p class="mt-3 text-slate-600">
      Weight matters practically for moving stone: a truck, trailer, or skid steer has a rated payload capacity, and a single landscaping boulder over a few hundred pounds generally needs mechanical lifting rather than manual handling. It also matters for what a retaining wall, patio base, or vehicle deck underneath decorative stone can structurally support — always check load ratings before placing heavy stone on anything but solid ground.
    </p>
    <p class="mt-3 text-xs text-slate-400">Density ranges are consistent with bulk specific gravity data from ASTM C97/C97M (Standard Test Method for Absorption and Bulk Specific Gravity of Dimension Stone) and USGS rock density reference tables.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick the shape</h3>
        <p class="mt-1 text-sm text-slate-600">Round boulder or a more block-like piece.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure it</h3>
        <p class="mt-1 text-sm text-slate-600">Average diameter, or length/width/height.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Match the stone type</h3>
        <p class="mt-1 text-sm text-slate-600">Get a weight estimate for lifting and hauling.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Sphere volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= (4&frasl;3)&pi;(dia&frasl;24)&sup3;</span>. A 24 in boulder: (4/3)π×1³ = <strong>4.19 ft³</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Weight</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= volume &times; density</span>. At 160 lb/ft³ (limestone): 4.19 × 160 = <strong>670 lb</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Box volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= (L&times;W&times;H) &divide; 1728</span>, then × density the same way.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A granite accent boulder, 36 in average diameter.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Radius:</span> <span class="text-slate-600">36 ÷ 24 = 1.5 ft</span></div>
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">(4/3)π×1.5³ = 14.14 ft³</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">14.14 × 170 = <strong>2,404 lb</strong></span></div>
        <div><span class="font-medium text-slate-700">Tons:</span> <span class="text-slate-600">≈ 1.2 tons — needs machine lifting</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the stone weight calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🪨</span>
        <h3 class="mt-2 font-semibold text-slate-900">Landscaping boulder placement</h3>
        <p class="mt-1 text-sm text-slate-600">Before a boulder gets delivered, know whether it needs a mini excavator, skid steer with a grapple, or a two-person carry. Anything over about 300-400 lb generally calls for machinery rather than manual handling.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚚</span>
        <h3 class="mt-2 font-semibold text-slate-900">Hauling and delivery planning</h3>
        <p class="mt-1 text-sm text-slate-600">Trucks and trailers have rated payload capacities. Estimating total stone weight before loading prevents overloading a trailer axle or exceeding a pickup's gross vehicle weight rating.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧱</span>
        <h3 class="mt-2 font-semibold text-slate-900">Retaining wall and structural loading</h3>
        <p class="mt-1 text-sm text-slate-600">Decorative stone placed on a deck, patio, or retaining wall cap adds real dead load. Knowing the weight helps confirm the structure underneath is rated to carry it safely.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">💰</span>
        <h3 class="mt-2 font-semibold text-slate-900">Pricing and quoting stone by weight</h3>
        <p class="mt-1 text-sm text-slate-600">Many quarries and landscaping suppliers price boulders and bulk stone by the ton. Estimating weight from measured dimensions helps you sanity-check a supplier's quote before delivery.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A landscaper sourcing a feature boulder for a front-yard entrance might pick a granite specimen roughly 30 inches in average diameter. Using the sphere formula, (4/3)π×(30/24)³ works out to about 8.18 cubic feet, and at granite's roughly 170 lb/ft³ density that is close to 1,391 lb — nearly 0.7 tons. That single number tells the crew immediately that this boulder needs a mini excavator or skid steer with a grapple attachment, not a two-person lift, and that the delivery truck needs a tailgate or forklift capable of setting it down gently rather than dumping it.
    </p>
    <p class="mt-3 text-slate-600">
      Bulk decorative stone runs into payload limits fast. A standard pickup bed roughly 8 ft by 5 ft (96 in by 60 in) filled just 12 inches deep with river rock works out to 40 cubic feet of stone, and at 150 lb/ft³ that is 6,000 lb — three tons, well beyond the roughly 1,500-2,000 lb payload rating of most half-ton pickups. In practice this is exactly why decorative rock deliveries are usually spread only a few inches deep per load, or hauled on a rated dump trailer instead of a truck bed.
    </p>
    <p class="mt-3 text-slate-600">
      On the smaller end, a sandstone cap block for a retaining wall might measure 24 in by 16 in by 8 in. Using the box formula, (24×16×8)/1728 gives 1.78 cubic feet, and at sandstone's lighter 140 lb/ft³ density that comes out to roughly 249 lb per block — light enough for two people to set by hand, which matters when a wall needs dozens of cap pieces placed individually along its length.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All landscaping stone weighs about the same per cubic foot." <strong class="text-slate-900">Not even close.</strong> Sandstone at roughly 130-150 lb/ft³ can weigh nearly 25% less than granite at 165-170 lb/ft³ for the exact same volume. A boulder that two people can roll into place if it's sandstone may need a machine if the same size specimen is granite.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A round boulder's weight is basically the same as a cube with the same width." <strong class="text-slate-900">It's actually much less.</strong> A sphere holds only about 52% of the volume of a cube with the same diameter (the sphere-to-cube volume ratio is π/6). Estimating a boulder's weight using a box formula instead of the sphere formula can overstate its weight by nearly double — which matters when deciding what equipment can lift it.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/gravel-sand-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gravel &amp; Sand Calculator</a>
      <a href="/tools/retaining-wall-block-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Retaining Wall Block Calculator</a>
      <a href="/tools/box-weight-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Box Weight Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function sync() {
      const sphere = el('shape').value === 'sphere';
      el('w-dia').classList.toggle('hidden', !sphere);
      el('w-len').classList.toggle('hidden', sphere);
      el('w-width').classList.toggle('hidden', sphere);
      el('w-height').classList.toggle('hidden', sphere);
      update();
    }

    function update() {
      const sphere = el('shape').value === 'sphere';
      const density = parseFloat(el('density').value);
      let vol;
      if (sphere) {
        const d = parseFloat(el('dia').value);
        if (!(d > 0)) return hide();
        vol = (4 / 3) * Math.PI * Math.pow(d / 24, 3);
      } else {
        const L = parseFloat(el('len').value), W = parseFloat(el('width').value), H = parseFloat(el('height').value);
        if (!(L > 0 && W > 0 && H > 0)) return hide();
        vol = (L * W * H) / 1728;
      }
      const weight = vol * density;
      const tons = weight / 2000;

      el('r-weight').textContent = weight.toFixed(0) + ' lb';
      el('r-note').textContent = vol.toFixed(2) + ' ft³ at ' + density + ' lb/ft³';
      el('r-vol').textContent = vol.toFixed(2) + ' ft³';
      el('r-tons').textContent = tons.toFixed(2) + ' tons';
      el('results').classList.remove('hidden');
    }
    function hide() { el('results').classList.add('hidden'); }

    el('shape').addEventListener('change', sync);
    ['dia', 'len', 'width', 'height'].forEach((id) => el(id).addEventListener('input', update));
    el('density').addEventListener('change', update);
    sync();
  </script>
</ToolLayout>
