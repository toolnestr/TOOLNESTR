---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Garment Fabric Estimator';
const description = 'Estimate how much fabric a specific garment style needs, from t-shirts to coats, at your chosen fabric width.';
const intro = 'Estimate fabric yardage for a specific garment style, adjusted for fabric width.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How accurate is a per-style estimate?', a: 'It\'s a solid planning figure based on typical yardage ranges published across home-sewing pattern companies, but the exact amount always depends on the specific pattern\'s pieces, your size, and any style variations (sleeve length, fullness) — always check the pattern envelope\'s fabric requirements when one is available.' },
  { q: 'Why does narrower fabric need proportionally more yardage?', a: 'Pattern pieces that don\'t fit efficiently across a narrower width waste more fabric per row, so the same garment can need noticeably more total length from 44-inch fabric than from 60-inch fabric, even though the finished garment is identical.' },
  { q: 'Does this include lining or interfacing?', a: 'No — this estimates the main shell fabric only. Use the Lining Fabric Calculator and Interfacing/Stabilizer Yardage Calculator separately for those additional materials.' },
  { q: 'What if my garment has long sleeves versus sleeveless?', a: 'This estimator uses a typical mid-range version of each style; sleeveless versions generally need somewhat less fabric, and styles with a lot of fullness (maxi length, wide sleeves) need somewhat more — treat the shown range as a starting point.' },
];
const howTo = {
  name: 'How to estimate garment fabric',
  steps: [
    { name: 'Choose garment style', text: 'Select the garment type you\'re making from the dropdown.' },
    { name: 'Choose fabric width', text: 'Select the usable width of the fabric you plan to buy.' },
    { name: 'Read the yardage estimate', text: 'A typical fabric range for that style at your chosen width appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <span class="text-sm font-medium text-slate-700">Garment style</span>
        <select id="garment" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
          <option value="0">T-shirt</option>
          <option value="1">A-line skirt</option>
          <option value="2" selected>Button-up shirt</option>
          <option value="3">Pants</option>
          <option value="4">Fitted dress</option>
          <option value="5">Maxi dress</option>
          <option value="6">Jacket</option>
          <option value="7">Coat</option>
        </select>
      </div>
      <div>
        <span class="text-sm font-medium text-slate-700">Fabric width</span>
        <select id="width" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
          <option value="44">44-45 in</option>
          <option value="54" selected>54-58 in</option>
          <option value="60">60 in</option>
        </select>
      </div>
    </div>
    <div id="results" class="mt-6">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated fabric needed</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="gfe-title gfe-desc">
      <title id="gfe-title">Row of garment silhouettes from simple to complex</title>
      <desc id="gfe-desc">A row of simplified garment shapes from a t-shirt to a coat, showing increasing fabric needs</desc>
      <path d="M100 40 L120 30 L150 40 L150 100 L100 100 Z" fill="none" stroke="#c026d3" stroke-width="2" />
      <text x="125" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">T-shirt</text>
      <path d="M280 40 L340 40 L350 110 L270 110 Z" fill="none" stroke="#c026d3" stroke-width="2" />
      <text x="310" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Dress</text>
      <path d="M470 30 L530 30 L545 160 L455 160 Z" fill="none" stroke="#c026d3" stroke-width="2" />
      <text x="500" y="180" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Maxi dress</text>
      <path d="M650 20 L720 20 L735 175 L635 175 Z" fill="none" stroke="#c026d3" stroke-width="2" />
      <text x="685" y="192" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Coat</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Fabric needs scale with a garment's complexity and coverage</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How garment fabric is estimated</h2>
    <p class="mt-2 text-slate-600">
      Each garment style has a typical published yardage range at a reference fabric width, reflecting how much fabric its pattern pieces generally consume once laid out efficiently. This estimator starts from that base range for a mid-size garment, then adjusts it for the fabric width you select — narrower fabric generally needs more total length since fewer or less efficiently arranged pieces fit across each row.
    </p>
    <p class="mt-3 text-slate-600">
      A t-shirt or A-line skirt sits at the lower end of most fabric requirements since their pattern pieces are small and simple, while a maxi dress or coat sits much higher since more fabric length and, for a coat, more structural pieces (collar, larger sleeves, back vents) are involved.
    </p>
    <p class="mt-3 text-xs text-slate-400">Base ranges reflect commonly published yardage requirements across home-sewing pattern companies at standard reference widths; specific pattern envelopes, when available, are more precise.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">Sewing a button-up shirt from 54-58 inch wide fabric.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Base range (button-up):</span> <span class="text-slate-600">2 - 2.5 yd</span></div>
        <div><span class="font-medium text-slate-700">Fabric width:</span> <span class="text-slate-600">54-58 in</span></div>
        <div><span class="font-medium text-slate-700">Estimated need:</span> <span class="text-slate-600"><strong>1.75 - 2.2 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Shopping for fabric before choosing a specific pattern — browsing a fabric sale and wanting to know "could I make a dress from this?" — is exactly where a per-style estimate is most useful, since it lets a shopper make a purchase decision on the spot without first tracking down a specific pattern's exact yardage chart.
    </p>
    <p class="mt-3 text-slate-600">
      Estimating a large batch purchase (fabric for several matching garments, like a set of holiday pajamas for a family) also benefits from a quick per-style figure, since multiplying a solid estimate by the number of garments avoids either an expensive over-purchase or an inconvenient mid-project reorder.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All dresses need roughly the same fabric." <strong class="text-slate-900">Not close.</strong> A fitted knee-length dress and a full maxi dress can differ by 1.5 yards or more for the same size, since length and fullness both scale fabric needs independently of the garment category.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Wider fabric is always cheaper overall." <strong class="text-slate-900">Not necessarily.</strong> Wider fabric often costs more per yard, so while it needs less total yardage, the overall project cost doesn't automatically drop — compare using the Fabric Cost Calculator with each width's actual price.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Yardage Calculator</a>
      <a href="/tools/lining-fabric-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Lining Fabric Calculator</a>
      <a href="/tools/fabric-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Cost Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    // base [low, high] yards at 44-45in width
    const bases = [
      [1.5, 2], [1.5, 2], [2, 2.5], [2, 2.5], [2, 2.75], [3, 4], [2.5, 3.5], [3.5, 5],
    ];
    const widthFactor = { '44': 1, '54': 0.85, '60': 0.75 };

    function update() {
      const idx = parseInt(el('garment').value, 10);
      const width = el('width').value;
      const [lo, hi] = bases[idx];
      const f = widthFactor[width];
      el('r-yards').textContent = (lo * f).toFixed(2) + ' - ' + (hi * f).toFixed(2) + ' yd';
    }

    el('garment').addEventListener('change', update);
    el('width').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
