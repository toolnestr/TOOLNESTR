---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fabric Care / Wash Temperature Guide';
const description = 'Find the recommended wash temperature, drying method, and iron setting for any common fabric type.';
const intro = 'Find the recommended wash temperature, drying method, and iron setting for a fabric type.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why do different fabrics need different wash temperatures?', a: 'Fiber types react differently to heat and agitation — protein fibers like wool and silk can felt, shrink, or weaken in hot water, while sturdy plant fibers like cotton and linen tolerate higher heat well and often need it to fully clean and sanitize.' },
  { q: 'Is this guide a substitute for the garment\'s own care label?', a: 'No — always follow the specific garment\'s care label when available, since blends, special finishes, and construction details (like structured linings) can require different care than the general fiber-type guidance shown here.' },
  { q: 'What does "hand wash or dry clean" mean for delicate fabrics?', a: 'It means both methods are generally safe, and the choice depends on convenience and the specific garment\'s construction — heavily structured or embellished delicate garments often do better with professional dry cleaning, while simpler delicate pieces can usually be hand washed safely at home.' },
  { q: 'Should I always use cold water to be safe?', a: 'Cold water is a safe default for preventing shrinkage and color bleeding, but it doesn\'t clean as effectively as warmer water for heavily soiled sturdy fabrics like cotton towels or work clothes, so match temperature to both the fabric and how soiled the item actually is.' },
];
const howTo = {
  name: 'How to find the right wash temperature for a fabric',
  steps: [
    { name: 'Select the fabric type', text: 'Choose the fabric your garment is made from.' },
    { name: 'Read the recommended settings', text: 'See the suggested wash temperature, drying method, and iron setting.' },
    { name: 'Check the garment\'s own label', text: 'Confirm against the specific garment\'s care label when one is available.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <span class="text-sm font-medium text-slate-700">Fabric type</span>
    <select id="fabric" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100">
      <option value="0">Cotton</option>
      <option value="1">Linen</option>
      <option value="2">Wool</option>
      <option value="3">Silk</option>
      <option value="4">Synthetic (polyester, nylon)</option>
      <option value="5">Denim</option>
      <option value="6">Delicates / lace</option>
    </select>
    <div id="results" class="mt-6 grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-rose-600 p-3 text-center"><div class="text-sm text-rose-100">Wash temperature</div><div id="r-temp" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Drying</div><div id="r-dry" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Ironing</div><div id="r-iron" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="160" viewBox="0 0 800 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fctg-title fctg-desc">
      <title id="fctg-title">Thermometer scale showing cold to hot wash ranges by fabric</title>
      <desc id="fctg-desc">A horizontal thermometer-style scale from cold to hot, illustrating that different fabrics suit different points on the temperature range</desc>
      <line x1="100" y1="80" x2="700" y2="80" stroke="#94a3b8" stroke-width="4" />
      <circle cx="150" cy="80" r="10" fill="#93c5fd" />
      <text x="150" y="110" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Silk/Wool</text>
      <circle cx="400" cy="80" r="10" fill="#fda4af" />
      <text x="400" y="110" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Synthetic</text>
      <circle cx="650" cy="80" r="10" fill="#e11d48" />
      <text x="650" y="110" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Cotton/Linen</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Sturdier plant fibers generally tolerate higher wash temperatures than delicate protein fibers</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fabric care recommendations work</h2>
    <p class="mt-2 text-slate-600">
      Different fibers respond differently to heat, agitation, and moisture. Cotton and linen are sturdy plant fibers that hold up well to warm or hot water and higher iron heat, which also helps sanitize heavily used items like towels and bedding. Wool and silk are protein fibers that can felt, shrink, or weaken under heat and agitation, so cold water, gentle handling, and low iron heat (or no ironing at all) protect them. Synthetic fibers like polyester and nylon are generally heat-sensitive in a different way — high heat can melt or distort the fibers — so cooler washing and lower iron settings are recommended.
    </p>
    <p class="mt-3 text-slate-600">
      This guide reflects general fiber-type behavior; blended fabrics, special finishes, and structural details (linings, interfacing, trims) can shift the safest care approach, which is why a garment's own care label should always take precedence when available.
    </p>
    <p class="mt-3 text-xs text-slate-400">Recommendations reflect general textile-care guidance for common fiber types; always defer to a specific garment's care label when provided.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 100% wool sweater with no care label needs a safe default care approach.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Wash:</span> <span class="text-slate-600">Cold, hand wash or gentle cycle</span></div>
        <div><span class="font-medium text-slate-700">Dry:</span> <span class="text-slate-600">Dry flat, do not tumble</span></div>
        <div><span class="font-medium text-slate-700">Iron:</span> <span class="text-slate-600"><strong>Low heat, with a press cloth</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Handling an inherited or secondhand garment with a faded or missing care label is a common trigger for needing general fiber-based guidance — identifying the fabric (by feel, burn test, or a fabric content tag elsewhere on the garment) and matching it to safe general care is often the only option when the original label is gone.
    </p>
    <p class="mt-3 text-slate-600">
      Mixing a laundry load of different fabric types is another common real-world case — knowing that wool and silk need the coldest, gentlest treatment in a mixed load means sorting those out separately rather than washing everything together at a cotton-appropriate hot setting that could damage the more delicate items.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Hot water always cleans better, so use it whenever possible." <strong class="text-slate-900">Not for every fabric.</strong> Hot water can permanently damage protein fibers (wool, silk) and some synthetics, so "cleaner" isn't worth the risk of shrinking, felting, or melting a garment that can't be undone.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Dry clean only always means hand washing will ruin it." <strong class="text-slate-900">Not always true.</strong> Some "dry clean only" labels are a cautious default from the manufacturer rather than a strict fiber requirement, though testing an inconspicuous area first (or defaulting to professional cleaning for valuable garments) is the safer approach.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/laundry-symbol-decoder" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Laundry Symbol Decoder</a>
      <a href="/tools/fabric-shrinkage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Shrinkage Calculator</a>
      <a href="/tools/knit-stretch-test-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Knit Stretch % Test Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    // [temp, dry, iron]
    const table = [
      ['Warm-Hot, 40-60°C (104-140°F)', 'Tumble dry, medium heat', 'High heat'],
      ['Warm, 40°C (104°F)', 'Line dry preferred', 'High heat, with steam'],
      ['Cold, 30°C (86°F), hand wash', 'Dry flat, do not tumble', 'Low heat, with press cloth'],
      ['Cold, 30°C (86°F), hand wash or dry clean', 'Dry flat', 'Low heat or do not iron'],
      ['Cool, 30-40°C (86-104°F)', 'Tumble dry, low heat', 'Low heat'],
      ['Cold-warm, 30-40°C (86-104°F), inside out', 'Tumble dry, medium heat', 'Medium heat'],
      ['Cold, 30°C (86°F), hand wash', 'Dry flat', 'Do not iron, or very low heat'],
    ];

    function update() {
      const idx = parseInt(el('fabric').value, 10);
      const row = table[idx];
      el('r-temp').textContent = row[0];
      el('r-dry').textContent = row[1];
      el('r-iron').textContent = row[2];
    }

    el('fabric').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
