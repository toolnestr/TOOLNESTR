---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Atomic Mass Calculator';
const description = 'Atomic mass calculator with a live 3D diagram and charts. Look up any element\'s standard atomic weight, atomic number, and estimated proton/neutron count, with worked examples.';
const intro = 'Look up any of the 118 elements to see its standard atomic weight, atomic number, and an estimated neutron count for its most abundant isotope. A 3D diagram compares a light element to a heavy one, and charts show how atomic weight climbs across the periodic table.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is standard atomic weight?", a: 'Standard atomic weight is the abundance-weighted average mass of all of an element\'s naturally occurring isotopes, measured in atomic mass units (u). It is the number shown on every periodic table.' },
  { q: 'How is this different from the Isotope Calculator?', a: 'The Isotope Calculator computes a weighted average atomic mass from isotope masses and abundances you provide yourself. This tool instead looks up the already-published standard atomic weight for a chosen element directly, with no manual isotope data entry required.' },
  { q: 'How is this different from the Molar Mass Calculator?', a: 'The Molar Mass Calculator sums atomic weights across a chemical formula (like H₂O) to find a compound\'s molar mass. This tool looks up a single element\'s own atomic weight, not a compound.' },
  { q: 'Why is the neutron count only an estimate?', a: "Standard atomic weight is a weighted average across all isotopes, not the mass of one specific isotope. Rounding it to the nearest whole number and subtracting the atomic number gives a good estimate of the most abundant isotope's neutron count, but for elements with several isotopes of similar abundance, the true most-abundant isotope can differ slightly from this estimate." },
  { q: 'Why do some elements show a bracketed value like [98]?', a: 'Elements with no stable isotopes (like technetium or all elements past bismuth) don\'t have a natural abundance to average — the bracketed number is instead the mass number of their longest-lived or most-studied known isotope.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Atomic Mass Calculator',
  description: 'Select any element to see its atomic number, standard atomic weight, and estimated proton/neutron count.',
  steps: [
    { name: 'Choose an element', text: 'Pick any element from the dropdown by name or symbol.' },
    { name: 'Read the results', text: 'Atomic number, standard atomic weight, and proton/neutron/electron counts display instantly.' },
  ],
};

const formulas = [
  { expr: 'Protons = electrons = Z', note: 'atomic number Z defines the element and equals both proton and (neutral-atom) electron count' },
  { expr: 'Neutrons (estimate) ≈ round(atomic weight) − Z', note: 'approximates the neutron count of the most abundant isotope from the standard atomic weight' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — chlorine', tone: 'slate',
    given: 'Chlorine, Z = 17, standard atomic weight = 35.45 u.',
    rows: [
      { label: 'Protons = electrons:', value: '17' },
      { label: 'Round atomic weight:', value: 'round(35.45) = 35' },
      { label: 'Estimated neutrons:', value: '35 − 17 = 18, matching chlorine-35, its most abundant isotope (≈76%)', full: true },
    ],
    note: 'Chlorine is a textbook case where the estimate lines up exactly with the true most-abundant isotope, because chlorine-35 so dominates the natural abundance mixture.',
  },
  {
    title: 'Worked example 2 — copper (a case where two isotopes are close in abundance)', tone: 'amber',
    given: 'Copper, Z = 29, standard atomic weight = 63.546 u.',
    rows: [
      { label: 'Protons = electrons:', value: '29' },
      { label: 'Round atomic weight:', value: 'round(63.546) = 64' },
      { label: 'Estimated neutrons:', value: '64 − 29 = 35, but copper\'s actual most abundant isotope is copper-63 (34 neutrons, ≈69% abundance) — the estimate is off by one', full: true },
    ],
    note: 'This shows the estimate\'s limit: copper-65 (≈31% abundant) pulls the average weight up enough that simple rounding slightly overshoots — a reminder that this method estimates, it doesn\'t look up exact isotope data.',
  },
];

const comparison = {
  heading: 'Atomic weight across a period vs. down a group',
  note: 'Atomic weight generally increases with atomic number, but not perfectly smoothly, since it also depends on each element\'s specific isotope mix.',
  headers: [{ label: 'Element' }, { label: 'Atomic number' }, { label: 'Atomic weight' }],
  rows: [
    ['Lithium', '3', '6.94 u'],
    ['Carbon ★', '6', '12.011 u'],
    ['Oxygen', '8', '15.999 u'],
    ['Sodium', '11', '22.990 u'],
    ['Iron', '26', '55.845 u'],
    ['Gold', '79', '196.967 u'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row. Carbon-12 is the actual defined reference point for the entire atomic mass unit system — by definition, one atomic mass unit is exactly 1/12 the mass of a carbon-12 atom.',
};

const realWorld = [
  { emoji: '🧪', title: 'Stoichiometry calculations', body: 'Every mole-to-mass conversion in chemistry starts from atomic weight — it is the single most-used number in balancing chemical equations and calculating reaction yields.' },
  { emoji: '⚖️', title: 'Analytical chemistry and quality control', body: 'Atomic weight underlies mass spectrometry interpretation, allowing chemists to identify unknown compounds and verify sample purity by comparing measured masses to expected values.' },
  { emoji: '🎓', title: 'Chemistry education', body: 'Atomic weight is usually the very first quantitative property students learn to read off the periodic table, and it underlies nearly every calculation that follows it throughout a chemistry course.' },
  { emoji: '☢️', title: 'Nuclear chemistry and dating', body: "Comparing an element's standard atomic weight to the mass of its individual isotopes is a starting point for radiometric dating techniques, which rely on knowing precisely how isotope ratios shift over time." },
];

const misconceptions = [
  { claim: '"Atomic weight is just the mass of the most common isotope."', truth: "It's a weighted average across every naturally occurring isotope, accounting for each one's relative abundance — not simply the mass of whichever isotope happens to be most common." },
  { claim: '"Atomic weight and mass number are interchangeable terms."', truth: 'Mass number is a whole number (protons + neutrons) for one specific isotope. Atomic weight is a decimal-valued weighted average across all of an element\'s naturally occurring isotopes — they are related but not the same number.' },
  { claim: '"An element only has one possible neutron count."', truth: 'Most elements have multiple naturally occurring isotopes with different neutron counts — only the proton count (atomic number) is fixed for a given element; neutron count can vary between its isotopes.' },
  { claim: '"Heavier elements always have proportionally more neutrons than protons."', truth: "Light elements tend to have roughly equal protons and neutrons, but heavier stable elements need progressively more neutrons than protons to remain stable — the neutron-to-proton ratio itself increases as atomic number rises, it isn't fixed." },
];

const sources = [
  { html: '<strong>IUPAC</strong> — Standard Atomic Weights (official periodic reference). <a href="https://iupac.org/what-we-do/periodic-table-of-elements/" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">iupac.org</a>' },
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 2, "Atoms, Molecules, and Ions" (free, peer-reviewed).' },
  { html: '<strong>CRC Handbook of Chemistry and Physics</strong> — standard reference atomic weights and isotope abundances.' },
];
const sourcesNote = 'Standard atomic weights follow IUPAC values (rounded). Neutron counts are estimated as round(atomic weight) − Z and may differ slightly from the true most-abundant isotope for elements with closely competing isotope abundances. Results are rounded for display.';

const howToUse = [
  { title: 'Pick an element', body: 'Search the dropdown by element name or symbol.' },
  { title: 'Read the atomic weight', body: 'Standard atomic weight displays instantly, along with atomic number.' },
  { title: 'Check the estimated neutron count', body: 'A quick approximation for the most abundant isotope, clearly marked as an estimate.' },
];

const related = [
  { href: '/tools/isotope-calculator', emoji: '☢️', title: 'Isotope Calculator', desc: 'Protons, neutrons, electrons — plus weighted average atomic mass.' },
  { href: '/tools/atomic-mass-calculator', emoji: '🔬', title: 'Molar Mass Calculator', desc: 'Molar mass from a chemical formula.' },
  { href: '/tools/periodic-table', emoji: '🔠', title: 'Interactive Periodic Table', desc: 'All 118 elements, click for atomic number and weight.' },
];

// Compact dataset: [symbol, name, Z, weight]
const elements = [
  ['H','Hydrogen',1,1.008],['He','Helium',2,4.003],['Li','Lithium',3,6.94],['Be','Beryllium',4,9.012],
  ['B','Boron',5,10.81],['C','Carbon',6,12.011],['N','Nitrogen',7,14.007],['O','Oxygen',8,15.999],
  ['F','Fluorine',9,18.998],['Ne','Neon',10,20.180],['Na','Sodium',11,22.990],['Mg','Magnesium',12,24.305],
  ['Al','Aluminium',13,26.982],['Si','Silicon',14,28.085],['P','Phosphorus',15,30.974],['S','Sulfur',16,32.06],
  ['Cl','Chlorine',17,35.45],['Ar','Argon',18,39.948],['K','Potassium',19,39.098],['Ca','Calcium',20,40.078],
  ['Sc','Scandium',21,44.956],['Ti','Titanium',22,47.867],['V','Vanadium',23,50.942],['Cr','Chromium',24,51.996],
  ['Mn','Manganese',25,54.938],['Fe','Iron',26,55.845],['Co','Cobalt',27,58.933],['Ni','Nickel',28,58.693],
  ['Cu','Copper',29,63.546],['Zn','Zinc',30,65.38],['Ga','Gallium',31,69.723],['Ge','Germanium',32,72.630],
  ['As','Arsenic',33,74.922],['Se','Selenium',34,78.971],['Br','Bromine',35,79.904],['Kr','Krypton',36,83.798],
  ['Rb','Rubidium',37,85.468],['Sr','Strontium',38,87.62],['Y','Yttrium',39,88.906],['Zr','Zirconium',40,91.224],
  ['Nb','Niobium',41,92.906],['Mo','Molybdenum',42,95.95],['Tc','Technetium',43,98],['Ru','Ruthenium',44,101.07],
  ['Rh','Rhodium',45,102.906],['Pd','Palladium',46,106.42],['Ag','Silver',47,107.868],['Cd','Cadmium',48,112.414],
  ['In','Indium',49,114.818],['Sn','Tin',50,118.710],['Sb','Antimony',51,121.760],['Te','Tellurium',52,127.60],
  ['I','Iodine',53,126.904],['Xe','Xenon',54,131.293],['Cs','Caesium',55,132.905],['Ba','Barium',56,137.327],
  ['La','Lanthanum',57,138.905],['Ce','Cerium',58,140.116],['Pr','Praseodymium',59,140.908],['Nd','Neodymium',60,144.242],
  ['Pm','Promethium',61,145],['Sm','Samarium',62,150.36],['Eu','Europium',63,151.964],['Gd','Gadolinium',64,157.25],
  ['Tb','Terbium',65,158.925],['Dy','Dysprosium',66,162.500],['Ho','Holmium',67,164.930],['Er','Erbium',68,167.259],
  ['Tm','Thulium',69,168.934],['Yb','Ytterbium',70,173.045],['Lu','Lutetium',71,174.967],['Hf','Hafnium',72,178.49],
  ['Ta','Tantalum',73,180.948],['W','Tungsten',74,183.84],['Re','Rhenium',75,186.207],['Os','Osmium',76,190.23],
  ['Ir','Iridium',77,192.217],['Pt','Platinum',78,195.084],['Au','Gold',79,196.967],['Hg','Mercury',80,200.592],
  ['Tl','Thallium',81,204.38],['Pb','Lead',82,207.2],['Bi','Bismuth',83,208.980],['Po','Polonium',84,209],
  ['At','Astatine',85,210],['Rn','Radon',86,222],['Fr','Francium',87,223],['Ra','Radium',88,226],
  ['Ac','Actinium',89,227],['Th','Thorium',90,232.038],['Pa','Protactinium',91,231.036],['U','Uranium',92,238.029],
  ['Np','Neptunium',93,237],['Pu','Plutonium',94,244],['Am','Americium',95,243],['Cm','Curium',96,247],
  ['Bk','Berkelium',97,247],['Cf','Californium',98,251],['Es','Einsteinium',99,252],['Fm','Fermium',100,257],
  ['Md','Mendelevium',101,258],['No','Nobelium',102,259],['Lr','Lawrencium',103,266],['Rf','Rutherfordium',104,267],
  ['Db','Dubnium',105,268],['Sg','Seaborgium',106,269],['Bh','Bohrium',107,270],['Hs','Hassium',108,269],
  ['Mt','Meitnerium',109,278],['Ds','Darmstadtium',110,281],['Rg','Roentgenium',111,282],['Cn','Copernicium',112,285],
  ['Nh','Nihonium',113,286],['Fl','Flerovium',114,289],['Mc','Moscovium',115,290],['Lv','Livermorium',116,293],
  ['Ts','Tennessine',117,294],['Og','Oganesson',118,294],
];
const elementsJson = JSON.stringify(elements);
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="an element's standard atomic weight is a single number that quietly encodes the natural mixture of every isotope of that element found on Earth, weighted by how common each one actually is."
  howIntro="Every atom of a given element has the same number of protons (its atomic number), but different atoms of that element can have different numbers of neutrons — these variants are called isotopes. Standard atomic weight averages the masses of all naturally occurring isotopes of an element, weighting each one by how abundant it actually is in nature. That's why atomic weight is almost never a clean whole number: it's a blend, not a single isotope's mass. Rounding it to the nearest whole number and subtracting the atomic number gives a reasonable estimate of the neutron count for that element's most abundant isotope."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where atomic weight actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-sm"><span class="text-sm font-medium text-slate-700">Choose an element</span>
      <select id="element-select" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></select>
    </label>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Atomic weight</div><div id="r-weight" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Atomic number (Z)</div><div id="r-z" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Protons / electrons</div><div id="r-pe" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Est. neutrons</div><div id="r-n" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="aw-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
    <p class="mt-2 text-xs text-slate-400">Neutron count is an estimate from the standard atomic weight, not exact isotope data — see the FAQ below.</p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Light element vs. heavy element</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-light" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Light element (e.g., helium)</h3>
          <p class="mt-1 text-sm text-slate-600">A small nucleus with very few nucleons — low atomic weight.</p>
        </div>
        <div>
          <div id="diag-heavy" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Heavy element (e.g., gold)</h3>
          <p class="mt-1 text-sm text-slate-600">A dense nucleus packed with far more protons and neutrons — high atomic weight.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Atomic weight graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Atomic weight vs. atomic number (Z 1–54)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-weight"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Estimated neutron-to-proton ratio (Z 1–92)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ratio"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline define:vars={{ elementsJson }}>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const elements = JSON.parse(elementsJson);

      // ---- calculator ----
      function buildSelect() {
        const sel = el('element-select');
        elements.forEach((e, i) => {
          const opt = document.createElement('option');
          opt.value = String(i);
          opt.textContent = e[1] + ' (' + e[0] + ') — Z=' + e[2];
          sel.appendChild(opt);
        });
        sel.value = '5'; // carbon
      }
      function update() {
        el('aw-err').textContent = '';
        const idx = parseInt(el('element-select').value, 10);
        const e = elements[idx];
        if (!e) { el('aw-err').textContent = 'Select an element.'; return; }
        const [, , z, weight] = e;
        el('r-weight').textContent = weight + ' u';
        el('r-z').textContent = String(z);
        el('r-pe').textContent = String(z);
        el('r-n').textContent = String(Math.round(weight) - z);
      }
      el('element-select').addEventListener('change', update);

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const first54 = elements.slice(0, 54);
        new Chart(el('chart-weight'), {
          type: 'line',
          data: { labels: first54.map((e) => e[0]), datasets: [{ label: 'Atomic weight (u)', data: first54.map((e) => e[3]), borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.2, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { ticks: { maxTicksLimit: 12 } }, y: { title: { display: true, text: 'Atomic weight (u)' } } }, plugins: { legend: { display: false } } }),
        });
        const first92 = elements.slice(0, 92);
        const ratioData = first92.map((e) => +(((Math.round(e[3]) - e[2]) / e[2])).toFixed(3));
        new Chart(el('chart-ratio'), {
          type: 'line',
          data: { labels: first92.map((e) => e[2]), datasets: [{ label: 'N/Z ratio', data: ratioData, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { ticks: { maxTicksLimit: 10 }, title: { display: true, text: 'Atomic number (Z)' } }, y: { title: { display: true, text: 'Neutron/proton ratio' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function nucleusScene(container, nucleonCount) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const group = new THREE.Group();
        const n = Math.min(nucleonCount, 60);
        const radius = 0.3 + Math.cbrt(n) * 0.32;
        for (let i = 0; i < n; i++) {
          const phi = Math.acos(1 - (2 * (i + 0.5)) / n);
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const x = radius * Math.sin(phi) * Math.cos(theta);
          const y = radius * Math.sin(phi) * Math.sin(theta);
          const z = radius * Math.cos(phi);
          const nucleon = new THREE.Mesh(new THREE.SphereGeometry(0.22, 10, 8), new THREE.MeshStandardMaterial({ color: i % 2 === 0 ? 0xef4444 : 0x6366f1 }));
          nucleon.position.set(x, y, z);
          group.add(nucleon);
        }
        s.scene.add(group);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLight = null, diagHeavy = null;
      function initDiagLight() { const c = el('diag-light'); if (!c) throw new Error('no container'); diagLight = nucleusScene(c, 4); }
      function initDiagHeavy() { const c = el('diag-heavy'); if (!c) throw new Error('no container'); diagHeavy = nucleusScene(c, 50); }

      function boot() {
        try { buildSelect(); update(); } catch (e) { console.error('[atomic-weight] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[atomic-weight] charts failed', e); }
        if (window.THREE) {
          try { initDiagLight(); } catch (e) { console.error('[atomic-weight] light diagram failed', e); }
          try { initDiagHeavy(); } catch (e) { console.error('[atomic-weight] heavy diagram failed', e); }
        }
        mountResize([diagLight, diagHeavy]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
