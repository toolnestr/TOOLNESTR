---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'CFU per mL Calculator';
const description = 'CFU per mL calculator with a live 3D agar plate diagram and charts. Solve CFU/mL = colonies × dilution factor / volume plated for bacterial concentration from a plate count, with worked examples and the 30-300 countable range rule.';
const intro = 'Solve CFU/mL = colonies × dilution factor / volume plated to back-calculate the original bacterial concentration from a countable agar plate. Two 3D diagrams compare an undercountable, overgrown plate to a properly countable one, and charts show how plate colony count and dilution factor relate to final CFU/mL.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What does CFU stand for?', a: 'CFU stands for Colony Forming Unit — a measure of viable, culturable bacterial (or fungal) cells, based on the assumption that each visible colony grew from one original living cell (or small cluster).' },
  { q: 'What is the standard formula for CFU/mL?', a: 'CFU/mL = (number of colonies counted) × (dilution factor) / (volume plated in mL) — this reverses the dilution and plating steps to estimate the concentration in the original, undiluted sample.' },
  { q: 'What is the 30-300 rule?', a: 'Plates with fewer than 30 colonies give statistically unreliable counts (too few for confidence), while plates with more than 300 colonies often have overlapping colonies that are difficult or impossible to count accurately — the 30-300 range is the standard target window for a countable plate.' },
  { q: 'Why do labs plate several different dilutions of the same sample?', a: "Since you don't know the sample's concentration in advance, plating several dilutions in parallel increases the chance that at least one plate lands within the reliable 30-300 colony countable range." },
  { q: 'Does CFU/mL count dead bacteria?', a: "No — CFU/mL specifically measures viable, culturable cells, since only living cells capable of dividing will form a visible colony. This is a key difference from total cell counts (like a direct microscope count), which count every cell whether alive or dead." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the CFU per mL Calculator',
  description: 'Solve CFU/mL from a plate colony count, the dilution factor used, and the volume plated.',
  steps: [
    { name: 'Enter the colony count', text: 'The number of countable colonies observed on the plate.' },
    { name: 'Enter the dilution factor and volume plated', text: 'The total dilution factor applied before plating, and how much diluted sample was spread on the plate.' },
    { name: 'Read the CFU/mL', text: 'The original sample\'s concentration solves instantly, with a note if the count falls outside the reliable 30-300 range.' },
  ],
};

const formulas = [
  { expr: 'CFU/mL = colonies × dilution factor / volume plated (mL)', note: 'back-calculates original concentration from a countable plate' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a well-diluted, countable plate', tone: 'slate',
    given: '150 colonies counted on a plate made from a 10⁻⁵ dilution (dilution factor = 100,000), with 0.1 mL plated.',
    rows: [
      { label: 'Formula:', value: 'CFU/mL = colonies × DF / volume' },
      { label: 'Substitute:', value: 'CFU/mL = 150 × 100,000 / 0.1' },
      { label: 'Result:', value: 'CFU/mL = 1.5 × 10⁸ CFU/mL', full: true },
    ],
    note: 'A count of 150 falls comfortably within the reliable 30-300 countable range, making this a statistically trustworthy result.',
  },
  {
    title: 'Worked example 2 — a lighter dilution', tone: 'amber',
    given: '45 colonies counted on a plate made from a 1,000-fold dilution, with 0.5 mL plated.',
    rows: [
      { label: 'Formula:', value: 'CFU/mL = colonies × DF / volume' },
      { label: 'Substitute:', value: 'CFU/mL = 45 × 1,000 / 0.5' },
      { label: 'Result:', value: 'CFU/mL = 9 × 10⁴ CFU/mL', full: true },
    ],
    note: 'A count of 45 is at the lower edge of the reliable range — still usable, but a slightly less dilute plate would generally give a more statistically confident count.',
  },
];

const comparison = {
  heading: 'Interpreting colony counts against the 30-300 rule',
  note: 'The same plate count can be reliable or unusable depending on where it falls.',
  headers: [{ label: 'Colony count' }, { label: 'Interpretation' }],
  rows: [
    ['<30', 'Too few — statistically unreliable, use a less dilute plate'],
    ['30-300 ★', 'Countable range — use this count'],
    ['>300', 'Too many (likely overlapping) — use a more dilute plate'],
    ['TNTC (too numerous to count)', 'Confluent growth — count is not usable at all'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference range. Because dilution level is chosen before the true concentration is known, labs typically plate several dilutions in parallel to ensure at least one lands in this window.',
};

const realWorld = [
  { emoji: '🍔', title: 'Food safety testing', body: 'Food industry labs quantify bacterial contamination in products using CFU/mL (or CFU/g for solids), comparing results against regulatory safety thresholds.' },
  { emoji: '💧', title: 'Water quality monitoring', body: 'Drinking water and recreational water testing reports bacterial concentration (like E. coli or coliform CFU/mL) to assess contamination risk against public health standards.' },
  { emoji: '💊', title: 'Pharmaceutical and vaccine production', body: 'Bioprocessing facilities monitor CFU/mL throughout fermentation to track culture growth and ensure production batches meet target cell densities.' },
  { emoji: '🏥', title: 'Clinical microbiology diagnostics', body: 'Urine and other clinical sample cultures are quantified in CFU/mL, with a threshold count often used to distinguish a genuine infection from incidental contamination.' },
];

const misconceptions = [
  { claim: '"CFU/mL counts every bacterial cell in the sample, dead or alive."', truth: 'CFU specifically counts viable, colony-forming cells — dead cells or those that can\'t grow under the plating conditions used simply won\'t form a colony and are not counted, which is exactly why CFU counts are typically lower than total microscopic cell counts.' },
  { claim: '"Any colony count from a plate can be used directly in the formula."', truth: "Counts below 30 or above 300 fall outside the statistically reliable range and shouldn't be trusted at face value — labs are expected to select a dilution that produces a plate within the 30-300 countable window before reporting a result." },
  { claim: '"One colony always comes from exactly one original bacterial cell."', truth: "A colony usually originates from a single cell, but it can occasionally arise from a small clump of cells that were plated together — this is one reason CFU is described as an estimate of viable cell count, not a perfectly exact one." },
  { claim: '"Higher dilution factor always means a more accurate result."', truth: 'The dilution factor itself doesn\'t determine accuracy — what matters is whether the resulting colony count falls within the reliable 30-300 range. Too high a dilution can just as easily produce an unreliable (too-few) count as too low a dilution can produce an uncountable (too-many) one.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Microbiology</em></strong> — Chapter 9, "Microbial Growth" (free, peer-reviewed, standard plate count methodology). <a href="https://openstax.org/books/microbiology/pages/9-2-measuring-microbial-growth" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>American Public Health Association, <em>Standard Methods for the Examination of Water and Wastewater</em></strong> — standard plate count procedure.' },
  { html: '<strong>Tortora, Funke &amp; Case, <em>Microbiology: An Introduction</em></strong> — Standard plate count chapter.' },
];
const sourcesNote = 'CFU/mL = colonies × dilution factor / volume plated (mL). The 30-300 colony rule is the standard reference range for reliable plate counting.';

const howToUse = [
  { title: 'Enter colony count', body: 'The number of colonies counted on the plate.' },
  { title: 'Enter dilution factor and volume plated', body: 'The total dilution applied and the volume of diluted sample spread on the plate.' },
  { title: 'Read CFU/mL', body: 'Original concentration solves instantly, with a countable-range check.' },
];

const related = [
  { href: '/tools/serial-dilution-calculator', emoji: '🧫', title: 'Serial Dilution Calculator', desc: 'Dilution factor per step and cumulative dilution.' },
  { href: '/tools/bacterial-growth-rate-calculator', emoji: '⏱️', title: 'Bacterial Growth Rate Calculator', desc: 'k = ln(Nt/N0)/t — exponential growth rate constant.' },
  { href: '/tools/dilution-calculator', emoji: '💧', title: 'Dilution Calculator', desc: 'C1V1=C2V2 — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a countable agar plate is really just a small, diluted snapshot of the original sample, so multiplying its colony count back up by exactly how much the sample was diluted (and how little of it was actually plated) reconstructs the original bacterial concentration."
  howIntro="Plating an undiluted, heavily-populated bacterial sample would produce so many overlapping colonies that counting becomes impossible — so samples are diluted first to bring the colony count down into a reliably countable range. To reverse this and recover the original concentration, the observed colony count is scaled back up by the dilution factor (how much the sample was diluted) and back down by the fraction of a millilitre actually spread on the plate. The resulting CFU/mL figure represents an estimate of viable, colony-forming cells in the original, undiluted sample — reliable only when the plate's colony count itself falls within the standard 30-300 countable window."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where CFU/mL actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Colony count</span>
        <input id="colonies" type="number" step="1" min="0" value="150" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Dilution factor</span>
        <input id="df" type="number" step="any" value="100000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume plated (mL)</span>
        <input id="vol" type="number" step="any" value="0.1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">CFU/mL</div><div id="r-cfu" class="mt-1 text-2xl font-bold">—</div></div>
    <p id="range-note" class="mt-3 text-center text-sm font-medium"></p>
    <p id="cfu-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Overgrown vs. countable plate</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-overgrown" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Overgrown (too many colonies)</h3>
          <p class="mt-1 text-sm text-slate-600">Colonies overlap and merge — impossible to count accurately, outside the 30-300 rule.</p>
        </div>
        <div>
          <div id="diag-countable" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Countable plate</h3>
          <p class="mt-1 text-sm text-slate-600">Well-separated colonies within the 30-300 reliable counting range.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">CFU/mL graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">CFU/mL vs. colony count (fixed DF and volume)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-colonies"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">The 30-300 countable window</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-range"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('cfu-err').textContent = ''; el('range-note').textContent = '';
        el('r-cfu').textContent = '—';
        const colonies = parseFloat(el('colonies').value), df = parseFloat(el('df').value), vol = parseFloat(el('vol').value);
        if (isNaN(colonies) || isNaN(df) || isNaN(vol)) return;
        if (colonies < 0 || df <= 0 || vol <= 0) { el('cfu-err').textContent = 'Colony count cannot be negative; dilution factor and volume must be positive.'; return; }
        const cfu = (colonies * df) / vol;
        el('r-cfu').textContent = fmt(cfu) + ' CFU/mL';
        if (colonies < 30) { el('range-note').textContent = '⚠ Below 30 colonies — statistically unreliable, consider a less dilute plate.'; el('range-note').className = 'mt-3 text-center text-sm font-medium text-amber-600'; }
        else if (colonies > 300) { el('range-note').textContent = '⚠ Above 300 colonies — likely overlapping, consider a more dilute plate.'; el('range-note').className = 'mt-3 text-center text-sm font-medium text-amber-600'; }
        else { el('range-note').textContent = '✓ Within the reliable 30-300 countable range.'; el('range-note').className = 'mt-3 text-center text-sm font-medium text-emerald-600'; }
      }
      ['colonies', 'df', 'vol'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labels = [], data = [];
        for (let c = 0; c <= 400; c += 40) { labels.push(c); data.push(+((c * 100000) / 0.1).toExponential(2)); }
        new Chart(el('chart-colonies'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'CFU/mL', data, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.2, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Colony count' } }, y: { type: 'logarithmic', title: { display: true, text: 'CFU/mL' } } }, plugins: { legend: { display: false } } }),
        });
        new Chart(el('chart-range'), {
          type: 'bar',
          data: { labels: ['<30 (too few)', '30-300 (countable)', '>300 (too many)'], datasets: [{ label: 'Reliability', data: [1, 3, 1], backgroundColor: ['#f59e0b', '#10b981', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { display: false } }, plugins: { legend: { display: false } } }),
        });
      }

      function plateScene(container, colonyCount, colonySize) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const plate = new THREE.Mesh(new THREE.CylinderGeometry(2.4, 2.4, 0.15, 32), new THREE.MeshStandardMaterial({ color: 0xfef3c7, transparent: true, opacity: 0.5 }));
        s.scene.add(plate);
        for (let i = 0; i < colonyCount; i++) {
          const dot = new THREE.Mesh(new THREE.SphereGeometry(colonySize, 10, 8), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
          const angle = Math.random() * Math.PI * 2, r = Math.random() * 2.1;
          dot.position.set(Math.cos(angle) * r, 0.12, Math.sin(angle) * r);
          s.scene.add(dot);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagOvergrown = null, diagCountable = null;
      function initDiagOvergrown() { const c = el('diag-overgrown'); if (!c) throw new Error('no container'); diagOvergrown = plateScene(c, 80, 0.16); }
      function initDiagCountable() { const c = el('diag-countable'); if (!c) throw new Error('no container'); diagCountable = plateScene(c, 15, 0.12); }

      function boot() {
        try { update(); } catch (e) { console.error('[cfu-per-ml] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[cfu-per-ml] charts failed', e); }
        if (window.THREE) {
          try { initDiagOvergrown(); } catch (e) { console.error('[cfu-per-ml] overgrown diagram failed', e); }
          try { initDiagCountable(); } catch (e) { console.error('[cfu-per-ml] countable diagram failed', e); }
        }
        mountResize([diagOvergrown, diagCountable]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
