---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Image to WebP';
const description =
  'Free online image to WebP converter. Convert JPG, PNG, AVIF and other formats ' +
  'to Google\u2019s modern WebP format for smaller, faster-loading images.';
const intro =
  'Upload any image and convert it to WebP format with adjustable quality. ' +
  'WebP delivers 25\u201335% smaller files than JPEG at the same quality.';
const category = { id: 'images', name: 'Image Tools' };
const faqs = [
  { q: 'What is WebP?', a: 'WebP is an image format developed by Google that provides superior lossy and lossless compression. It supports transparency like PNG and animation like GIF, all in a single format with smaller file sizes.' },
  { q: 'Is WebP better than JPEG?', a: 'For most web images, yes. WebP typically delivers 25\u201335% smaller files than JPEG at the same visual quality, which means faster page loads and less bandwidth usage.' },
  { q: 'Does WebP support transparency?', a: 'Yes. WebP supports alpha transparency (like PNG) but with significantly smaller file sizes, making it an excellent choice for logos and icons on the web.' },
  { q: 'What is the difference between lossy and lossless WebP?', a: 'Lossy WebP uses predictive coding to compress images with some quality loss (similar to JPEG). Lossless WebP preserves every pixel exactly (like PNG) but achieves smaller file sizes than PNG.' },
  { q: 'Which browsers support WebP?', a: 'WebP is supported by approximately 97% of browsers globally, including Chrome, Firefox, Safari (14+), Edge, and Opera. Only very old browsers lack support.' },
  { q: 'Can I use WebP for animation?', a: 'Yes. WebP supports animated images, functioning as a modern replacement for animated GIFs with much smaller file sizes and better color support.' },
  { q: 'How do I use WebP on my website?', a: 'Use the <picture> element with WebP as the primary source and a fallback format like JPEG or PNG for older browsers. Most CMS platforms also have WebP plugins.' },
  { q: 'Does WebP work for all types of images?', a: 'WebP works best for photographs and complex images. For simple graphics with few colors, PNG may sometimes produce smaller files, though lossless WebP is usually competitive.' },
  { q: 'Will I lose quality converting to WebP?', a: 'Lossy conversion reduces file size by discarding some visual information. The quality slider lets you control this tradeoff. At quality 80\u201390, the difference is barely noticeable but file sizes drop significantly.' },
  { q: 'How do I convert WebP back to JPG or PNG?', a: 'You can use this tool\u2019s reverse conversion or any image editor. However, once converted to lossy WebP, the discarded data cannot be recovered, so keep your original files.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="UtilitiesApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <input id="file-input" type="file" accept="image/*" class="w-full cursor-pointer rounded-lg border border-slate-300 p-2 text-sm file:mr-3 file:rounded-lg file:border-0 file:bg-indigo-50 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-indigo-700 hover:file:bg-indigo-100" />

    <div id="controls" class="mt-4 hidden">
      <label class="flex items-center gap-3">
        <span class="text-sm font-medium text-slate-700">Quality</span>
        <input id="quality" type="range" min="10" max="100" value="80" class="flex-1 accent-indigo-600" />
        <span id="quality-label" class="w-10 text-right text-sm font-semibold text-slate-700">80</span>
      </label>
    </div>

    <div id="preview-area" class="mt-4 hidden">
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <p class="mb-1 text-xs font-medium text-slate-500">Original</p>
          <img id="original-preview" class="max-h-64 w-full rounded-lg border border-slate-200 object-contain bg-slate-50" />
          <p id="original-size" class="mt-1 text-xs text-slate-400"></p>
        </div>
        <div>
          <p class="mb-1 text-xs font-medium text-slate-500">WebP</p>
          <img id="webp-preview" class="max-h-64 w-full rounded-lg border border-slate-200 object-contain bg-slate-50" />
          <p id="webp-size" class="mt-1 text-xs text-slate-400"></p>
        </div>
      </div>
    </div>

    <button id="download-btn" class="mt-4 hidden rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">
      Download WebP
    </button>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How WebP conversion works</h2>
    <p class="mt-2 text-slate-600">WebP conversion uses VP8 or VP8L (lossless) intra-frame encoding derived from the WebM video codec. For lossy compression, it employs block-based predictive coding that analyzes neighboring pixels to predict values, then encodes only the differences. This approach is more efficient than JPEG's independent block processing, resulting in smaller files at equivalent quality.</p>
    <p class="mt-3 text-slate-600">WebP supports both lossy and lossless modes along with alpha transparency and animation. The quality slider controls lossy compression — higher values preserve more detail while lower values achieve greater size reduction. Lossless WebP uses a different compression path that preserves every pixel exactly.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Original:</span> <span class="text-slate-600">500 KB JPEG at quality 80</span></div>
        <div><span class="font-medium text-slate-700">Conversion:</span> <span class="text-slate-600">Lossy WebP at quality 80</span></div>
        <div><span class="font-medium text-slate-700">Result:</span> <span class="text-slate-600">~300 KB WebP</span></div>
        <div><span class="font-medium text-slate-700">Saving:</span> <span class="text-slate-600">~40% smaller than JPEG at same quality</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">File size comparison by format</h2>
    <p class="mt-2 text-slate-600">Average file sizes relative to the original JPEG file at similar quality.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">JPEG (original)</span><span class="text-slate-400">100%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-slate-400" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">WebP (lossy)</span><span class="text-slate-400">~65%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:65%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">AVIF</span><span class="text-slate-400">~50%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">PNG (lossless)</span><span class="text-slate-400">~280%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:65%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F468;&#x200D;&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Marcus Chen</h3>
      <p class="mt-1 text-sm text-slate-600">Web developer who converts all site images to WebP to slash page weight and improve Lighthouse performance scores for client projects.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x26A1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Priya Sharma</h3>
      <p class="mt-1 text-sm text-slate-600">Site speed optimizer who runs WebP conversion on e-commerce product images to reduce load times and increase conversion rates.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x270F;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Jake Thompson</h3>
      <p class="mt-1 text-sm text-slate-600">Blogger who converts high-res travel photos to WebP to keep his WordPress site fast without sacrificing image quality for readers.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F464;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Lisa Park</h3>
      <p class="mt-1 text-sm text-slate-600">WordPress user who uses WebP via plugins and needs to batch-convert media library images for a faster, better-ranked site.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Format</th><th class="p-3">Browser support</th><th class="p-3">Transparency</th><th class="p-3">Animation</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">WebP</td><td class="p-3">~97%</td><td class="p-3">Yes</td><td class="p-3">Yes</td></tr>
        <tr><td class="p-3 font-medium">AVIF</td><td class="p-3">~85%</td><td class="p-3">Yes</td><td class="p-3">Yes</td></tr>
        <tr><td class="p-3 font-medium">JPEG</td><td class="p-3">100%</td><td class="p-3">No</td><td class="p-3">No</td></tr>
        <tr><td class="p-3 font-medium">PNG</td><td class="p-3">100%</td><td class="p-3">Yes</td><td class="p-3">No</td></tr>
        <tr><td class="p-3 font-medium">GIF</td><td class="p-3">100%</td><td class="p-3">Yes (binary)</td><td class="p-3">Yes</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to convert an image to WebP</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Upload your image</h3>
        <p class="mt-1 text-sm text-slate-600">Click the file input and select any image from your device. JPG, PNG, AVIF, GIF and BMP are all supported.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Adjust quality</h3>
        <p class="mt-1 text-sm text-slate-600">Use the slider to control compression. Higher quality means larger files. The preview updates in real time so you can compare.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Download WebP</h3>
        <p class="mt-1 text-sm text-slate-600">Click the download button to save your WebP file. Your original image never leaves your device.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for using WebP</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">WebP supports transparency like PNG</h3>
        <p class="mt-1 text-sm text-slate-600">Unlike JPEG, WebP handles alpha channels natively. You can replace PNG images with WebP for transparent assets and save 25\u201330% file size.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use WebP for web only</h3>
        <p class="mt-1 text-sm text-slate-600">WebP is optimised for web delivery. For print, archiving, or editing, stick with JPEG or PNG as your master copy and convert to WebP only for the final web output.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Always check browser support</h3>
        <p class="mt-1 text-sm text-slate-600">While 97% of browsers support WebP, always use the <picture> element with a JPEG or PNG fallback to ensure your images work everywhere.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is WebP?</h2>
    <p class="mt-2 text-slate-600">WebP is a modern image format developed by Google that provides superior compression for images on the web. It was first announced in 2010 and has since gained broad industry support. WebP supports both lossy and lossless compression, as well as transparency and animation, making it a versatile replacement for JPEG, PNG, and GIF in many web contexts.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why is WebP smaller?</h2>
    <p class="mt-2 text-slate-600">WebP achieves smaller file sizes through predictive coding. For lossy compression, it uses block prediction similar to VP8 video codec to encode image data more efficiently than JPEG\u2019s discrete cosine transform. For lossless compression, it uses advanced techniques like spatial prediction, color cache, and entropy coding to outperform PNG by 25\u201330%.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Transparency support</h2>
    <p class="mt-2 text-slate-600">WebP supports alpha transparency channels with both lossy and lossless compression. This means you can use WebP for logos, icons, and other transparent assets that previously required PNG, while benefiting from significantly smaller file sizes. Lossless WebP with transparency is typically 20\u201330% smaller than PNG.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Lossy vs lossless WebP</h2>
    <p class="mt-2 text-slate-600">Lossy WebP discards some visual information to achieve much smaller file sizes, ideal for photographs and complex images where minor quality loss is acceptable. Lossless WebP preserves every pixel exactly, making it suitable for graphics, screenshots, and images where quality must be maintained precisely. The quality slider in this tool controls lossy compression only.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Browser compatibility</h2>
    <p class="mt-2 text-slate-600">WebP is supported by approximately 97% of web browsers globally. Chrome has supported it since 2011, Firefox since 2013, Edge since 2018, and Safari since version 14 (2020). For the remaining 3% of users on older browsers, use the <picture> element with a JPEG or PNG fallback to ensure universal compatibility.</p>
  </section>

  <script is:inline>
    const fileInput = document.getElementById('file-input');
    const controls = document.getElementById('controls');
    const previewArea = document.getElementById('preview-area');
    const qualitySlider = document.getElementById('quality');
    const qualityLabel = document.getElementById('quality-label');
    const originalPreview = document.getElementById('original-preview');
    const webpPreview = document.getElementById('webp-preview');
    const originalSize = document.getElementById('original-size');
    const webpSize = document.getElementById('webp-size');
    const downloadBtn = document.getElementById('download-btn');

    let currentFile = null;
    let originalDataUrl = null;

    function formatBytes(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(2) + ' MB';
    }

    function processImage() {
      if (!currentFile) return;
      const quality = parseInt(qualitySlider.value) / 100;
      const img = new Image();
      img.onload = function () {
        originalPreview.src = originalDataUrl;
        originalSize.textContent = 'Size: ' + formatBytes(currentFile.size);

        const canvas = document.createElement('canvas');
        canvas.width = img.width;
        canvas.height = img.height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0);

        canvas.toBlob(function (blob) {
          if (blob) {
            webpPreview.src = URL.createObjectURL(blob);
            webpSize.textContent = 'Size: ' + formatBytes(blob.size) + ' (' + Math.round(blob.size / currentFile.size * 100) + '% of original)';
            downloadBtn.onclick = function () {
              const a = document.createElement('a');
              a.href = URL.createObjectURL(blob);
              const name = currentFile.name.replace(/\.[^.]+$/, '');
              a.download = name + '.webp';
              a.click();
            };
          }
        }, 'image/webp', quality);
      };
      img.src = originalDataUrl;
    }

    fileInput.addEventListener('change', function (e) {
      const file = e.target.files[0];
      if (!file) return;
      currentFile = file;
      controls.classList.remove('hidden');
      previewArea.classList.remove('hidden');
      downloadBtn.classList.remove('hidden');
      const reader = new FileReader();
      reader.onload = function (ev) {
        originalDataUrl = ev.target.result;
        processImage();
      };
      reader.readAsDataURL(file);
    });

    qualitySlider.addEventListener('input', function () {
      qualityLabel.textContent = qualitySlider.value;
      processImage();
    });
  </script>
</ToolLayout>
