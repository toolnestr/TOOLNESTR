---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Crontab to Human-Readable Translator';
const description = 'Paste a cron expression to read what it does in plain English and preview the next run times. Free instant cron translator.';
const intro = 'Paste a cron expression and read what it actually does in plain English.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'What does 0 0 * * * mean?', a: 'Every day at midnight.' },
  { q: 'What does */15 mean?', a: 'Every 15 units — e.g. every 15 minutes in the minute field.' },
  { q: 'Does it show the timezone?', a: 'It describes the schedule; actual time depends on your server timezone.' },
  { q: 'What if my cron has 6 fields?', a: 'Some cron versions have a 6th field for year — this parser handles the standard 5 fields.' },
];
const seoTitle = 'Crontab to Human-Readable — Explain Any Cron Expression';
const seoDesc = 'Paste a cron expression to read what it does in plain English and preview the next run times. Free, instant cron translator.';
---

<ToolLayout title={title} description={description} intro={intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div>
      <label class="text-sm font-medium text-slate-700" for="cron-input">Paste cron expression</label>
      <div class="mt-1 flex items-stretch gap-2">
        <input
          id="cron-input"
          type="text"
          placeholder="e.g. 30 2 * * 0"
          spellcheck="false"
          class="w-full rounded-xl border border-slate-300 px-4 py-3 font-mono text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
        />
      </div>
    </div>

    <div id="result" class="mt-4 hidden">
      <div class="rounded-xl border border-slate-100 bg-slate-50 p-4">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p id="description" class="text-sm font-medium text-slate-900"></p>
            <p id="error" class="hidden text-sm text-red-600"></p>
          </div>
          <button id="copy-btn" class="shrink-0 rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-600 transition hover:bg-slate-100">Copy</button>
        </div>
        <div id="next-times" class="mt-3 space-y-1"></div>
      </div>
    </div>

    <div id="invalid-result" class="mt-4 hidden rounded-xl border border-red-100 bg-red-50 p-4 text-sm text-red-700">
      Could not parse — expected 5 fields
    </div>

    <div class="mt-4 rounded-xl border border-slate-100 bg-slate-50 p-3 text-xs text-slate-500">
      <span class="font-medium">Privacy:</span> Everything stays in your browser. No cron expressions are sent to any server.
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How cron-to-human translation works</h2>
    <p class="mt-2 text-slate-600">A cron expression is a string of five space-separated fields that define a schedule: minute, hour, day of month, month, and day of week. Each field can contain a wildcard (<code class="font-mono">*</code>), a step value (<code class="font-mono">*/n</code>), a range (<code class="font-mono">1-5</code>), a list (<code class="font-mono">1,3,5</code>), or a fixed number. The parser reads each field independently and builds a plain-English sentence from the combined constraints.</p>

    <figure class="mt-5">
      <svg xmlns="http://www.w3.org/2000/svg" width="800" height="200" viewBox="0 0 800 200">
        <title>Cron to Human Pipeline</title>
        <desc>Flow diagram showing a cron expression string being parsed into five fields then combined into a plain English description</desc>
        <rect width="800" height="200" fill="#f8fafc" rx="8"/>
        <rect x="20" y="55" width="170" height="60" fill="#e2e8f0" rx="8"/>
        <text x="105" y="79" font-family="sans-serif" font-size="13" fill="#475569" text-anchor="middle" font-weight="bold">Cron Expression</text>
        <text x="105" y="97" font-family="monospace" font-size="11" fill="#64748b" text-anchor="middle">"30 2 * * 0"</text>
        <line x1="190" y1="85" x2="240" y2="85" stroke="#6366f1" stroke-width="2"/>
        <polygon points="240,80 255,85 240,90" fill="#6366f1"/>
        <rect x="260" y="15" width="240" height="140" fill="#6366f1" rx="8"/>
        <text x="380" y="38" font-family="sans-serif" font-size="13" fill="#ffffff" text-anchor="middle" font-weight="bold">Parser</text>
        <text x="380" y="60" font-family="monospace" font-size="11" fill="#c7d2fe" text-anchor="middle">minute: 30</text>
        <text x="380" y="78" font-family="monospace" font-size="11" fill="#c7d2fe" text-anchor="middle">hour: 2</text>
        <text x="380" y="96" font-family="monospace" font-size="11" fill="#c7d2fe" text-anchor="middle">day-of-month: *</text>
        <text x="380" y="114" font-family="monospace" font-size="11" fill="#c7d2fe" text-anchor="middle">month: *</text>
        <text x="380" y="132" font-family="monospace" font-size="11" fill="#c7d2fe" text-anchor="middle">day-of-week: 0</text>
        <line x1="500" y1="85" x2="550" y2="85" stroke="#6366f1" stroke-width="2"/>
        <polygon points="550,80 565,85 550,90" fill="#6366f1"/>
        <rect x="570" y="35" width="210" height="100" fill="#f0fdf4" rx="8" stroke="#22c55e" stroke-width="1"/>
        <text x="675" y="60" font-family="sans-serif" font-size="13" fill="#16a34a" text-anchor="middle" font-weight="bold">English Description</text>
        <text x="675" y="82" font-family="sans-serif" font-size="11" fill="#1e293b" text-anchor="middle">"At 02:30 every Sunday"</text>
        <text x="675" y="110" font-family="sans-serif" font-size="10" fill="#64748b" text-anchor="middle">+ Next 5 run times</text>
        <text x="105" y="170" font-family="sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">5 fields: minute hour dom month dow</text>
        <text x="380" y="170" font-family="sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">Supports *, */n, ranges, lists, names</text>
        <text x="675" y="170" font-family="sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">Human-readable schedule summary</text>
      </svg>
      <figcaption class="mt-2 text-xs text-slate-500">Pipeline: cron string → individual field parser → natural language sentence</figcaption>
    </figure>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Logic: how each field is interpreted</h2>
    <p class="mt-2 text-slate-600">The five cron fields follow a strict order: minute (0–59), hour (0–23), day of month (1–31), month (1–12 or JAN–DEC), and day of week (0–7 or SUN–SAT, where 0 and 7 both represent Sunday). Each field is parsed independently and the results are combined into a single sentence that describes all the constraints together.</p>
    <p class="mt-3 text-slate-600">The parser builds the English description by checking the specificity of each field. A wildcard (<code class="font-mono">*</code>) means "every" — it imposes no constraint. A fixed value means "at exactly this value." A range means "between X and Y." A step (<code class="font-mono">*/n</code>) means "every n units starting from 0." Lists combine multiple values with "and" or commas. The sentence is assembled as "At [minute] past [hour] on [days] in [months]" and then trimmed to remove redundant parts — for example, if all months are selected, the "in [months]" part is omitted.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example: 30 2 * * 0</h2>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <div class="grid gap-2 text-sm sm:grid-cols-5">
        <div><span class="font-medium text-slate-700">Minute</span><br/><span class="font-mono text-indigo-600">30</span></div>
        <div><span class="font-medium text-slate-700">Hour</span><br/><span class="font-mono text-indigo-600">2</span></div>
        <div><span class="font-medium text-slate-700">Day of month</span><br/><span class="font-mono text-indigo-600">*</span></div>
        <div><span class="font-medium text-slate-700">Month</span><br/><span class="font-mono text-indigo-600">*</span></div>
        <div><span class="font-medium text-slate-700">Day of week</span><br/><span class="font-mono text-indigo-600">0</span></div>
      </div>
      <p class="mt-4 text-slate-600">The parser reads <code class="font-mono">30</code> in the minute field — "at minute 30." The hour field <code class="font-mono">2</code> means "past hour 2" (02:30 in 24-hour time). The day-of-month and month fields are both wildcards, meaning "every day of every month." The day-of-week field <code class="font-mono">0</code> restricts to Sunday only. The combined result: <strong class="text-slate-900">"At 02:30, only on Sunday"</strong> or more naturally <strong class="text-slate-900">"At 02:30 every Sunday."</strong></p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Pattern</th><th class="p-3">Meaning</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-mono">* * * * *</td><td class="p-3">Every minute</td></tr>
        <tr><td class="p-3 font-mono">0 * * * *</td><td class="p-3">Every hour at minute 0</td></tr>
        <tr><td class="p-3 font-mono">0 0 * * *</td><td class="p-3">Every day at midnight</td></tr>
        <tr><td class="p-3 font-mono">0 0 * * 0</td><td class="p-3">Every Sunday at midnight</td></tr>
        <tr><td class="p-3 font-mono">30 2 * * *</td><td class="p-3">Every day at 02:30</td></tr>
        <tr><td class="p-3 font-mono">*/15 * * * *</td><td class="p-3">Every 15 minutes</td></tr>
        <tr><td class="p-3 font-mono">0 9-17 * * 1-5</td><td class="p-3">Every hour 09:00–17:00 on weekdays</td></tr>
        <tr><td class="p-3 font-mono">0 0 1 * *</td><td class="p-3">First day of every month at midnight</td></tr>
        <tr><td class="p-3 font-mono">0 0 * JAN,JUN *</td><td class="p-3">Midnight every day in January and June</td></tr>
        <tr><td class="p-3 font-mono">0 0 * * 0,6</td><td class="p-3">Midnight every Saturday and Sunday</td></tr>
        <tr><td class="p-3 font-mono">*/10 9-17 * * 1-5</td><td class="p-3">Every 10 minutes during business hours on weekdays</td></tr>
        <tr><td class="p-3 font-mono">45 23 * * 5</td><td class="p-3">Every Friday at 23:45</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F50D;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Auditing existing cron jobs</h3>
      <p class="mt-1 text-sm text-slate-600">When inheriting a server with dozens of cron jobs in the crontab, translating each expression to plain English helps you quickly understand what runs when without decoding five-field syntax manually.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F91D;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Code review</h3>
      <p class="mt-1 text-sm text-slate-600">During pull request reviews, cron expressions can be hard to spot-check. Paste them here to verify the intended schedule matches the code — no mental arithmetic needed.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4DA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Learning an inherited crontab</h3>
      <p class="mt-1 text-sm text-slate-600">Taking over a system where the previous admin left cryptic cron entries? Translate them all to understand the maintenance schedule, backup timing, and batch job frequency.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Writing new cron expressions</h3>
      <p class="mt-1 text-sm text-slate-600">When setting up a new scheduled task, type your intended cron expression and verify the English description matches what you want. Catch mistakes before they go into production.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with cron expressions</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Day-of-month vs day-of-week interactions</h3>
        <p class="mt-1 text-sm text-slate-600">When both the day-of-month (3rd field) and day-of-week (5th field) are specified (neither is <code class="font-mono">*</code>), cron runs the job when <em>either</em> condition matches. For example, <code class="font-mono">0 0 15 * 5</code> runs at midnight on the 15th <em>and</em> every Friday — not only on Fridays that fall on the 15th. This is a common source of confusion. To run on a specific weekday of the month (e.g., the second Tuesday), you need to either use advanced syntax (like <code class="font-mono">0 0 8-14 * 2</code>) or add a conditional check in your script.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Server timezone awareness</h3>
        <p class="mt-1 text-sm text-slate-600">Cron uses the local timezone of the server. If your server is set to UTC and you intend a job to run at 9 AM Eastern Time, you need to subtract the UTC offset. For 9 AM EST (UTC-5), the expression would be <code class="font-mono">0 14 * * *</code>. This is a frequent source of bugs when teams span multiple timezones. Consider setting your server to UTC and always converting intended times explicitly.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Special strings (@daily, @hourly, etc.)</h3>
        <p class="mt-1 text-sm text-slate-600">Many cron implementations support shorthand strings like <code class="font-mono">@daily</code> (equivalent to <code class="font-mono">0 0 * * *</code>), <code class="font-mono">@hourly</code> (<code class="font-mono">0 * * * *</code>), <code class="font-mono">@weekly</code> (<code class="font-mono">0 0 * * 0</code>), <code class="font-mono">@monthly</code> (<code class="font-mono">0 0 1 * *</code>), and <code class="font-mono">@yearly</code> (<code class="font-mono">0 0 1 1 *</code>). This tool expects standard 5-field numeric expressions — expand shorthands to their equivalent form before pasting.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Leap years and month lengths</h3>
        <p class="mt-1 text-sm text-slate-600">Be careful with day-of-month values like 31 on months that have fewer days, or 29 on non-leap-year Februarys. Cron will silently skip those dates. If you set <code class="font-mono">0 0 31 * *</code>, the job will not run in April, June, September, or November. Some cron implementations also handle 29 Feb differently in non-leap years (silently skipped). Always test edge dates when scheduling monthly jobs near month boundaries.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common use cases for cron expression translation</h2>
    <p class="mt-3 text-slate-600">Translating cron expressions to human-readable text is valuable whenever you encounter an unfamiliar crontab. System administrators reviewing a server for the first time often find a mix of legacy cron jobs with no documentation. Translating each expression reveals the maintenance schedule — backups at 2 AM, log rotation at midnight, report generation at 8 AM weekdays — without having to trace each script individually.</p>
    <p class="mt-3 text-slate-600">Developers working in teams benefit when cron expressions are included in configuration files, deployment scripts, or infrastructure-as-code repositories. A quick translation during code review ensures that <code class="font-mono">0 0 * * 0</code> was intended as "weekly" and not mistakenly written by someone who thought the day-of-week field was day-of-month. The same applies when debugging why a job ran unexpectedly — translating the expression is often the fastest way to spot the error.</p>
    <p class="mt-3 text-slate-600">DevOps engineers and SREs use cron translation during incident response. When a scheduled job runs at the wrong time or fails to run at all, checking the actual cron expression against the intended schedule is the first diagnostic step. Having a quick translator avoids mental parsing errors that can lead to misdiagnosis. It is also useful when migrating cron jobs between servers that might have different timezone settings — translating helps confirm the adjusted expression before deployment.</p>
    <p class="mt-3 text-slate-600">Students and new engineers learning Linux system administration find cron translation helpful as a learning tool. By experimenting with different field combinations, they develop an intuition for how the five fields interact. Typing <code class="font-mono">*/15 9-17 * * 1-5</code> and reading "every 15 minutes between 09:00 and 17:00, Monday through Friday" reinforces the field order and syntax rules much faster than memorizing reference charts.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the parser handles different field patterns</h2>
    <p class="mt-3 text-slate-600">The parser recognises several patterns within each field. A bare number like <code class="font-mono">5</code> means "exactly 5." A step like <code class="font-mono">*/15</code> means "every 15 starting from 0," which is equivalent to 0, 15, 30, and 45. A range like <code class="font-mono">9-17</code> means "every value from 9 to 17 inclusive." A list like <code class="font-mono">1,15,30</code> means "only at these specific values." Combinations like <code class="font-mono">1-5,10-15</code> are also supported.</p>
    <p class="mt-3 text-slate-600">Month and day names are case-insensitive. The parser accepts three-letter abbreviations (JAN, Feb, mar) and maps them to their numeric equivalents. Similarly, day names (SUN, Mon, tue) are mapped to 0–6. This means <code class="font-mono">0 0 * JAN *</code> and <code class="font-mono">0 0 * 1 *</code> produce the same result — "Midnight every day in January." The parser normalises these names before building the description, so the English output always uses the numeric values expressed as names (e.g., "January" not "1").</p>
    <p class="mt-3 text-slate-600">The next 5 run times feature computes upcoming execution times based on the parsed schedule and the current time. It tests candidate times minute by minute, checking each field's constraints, and collects the next 5 matches. This preview is especially useful for verifying that complex expressions behave as expected — for example, confirming that <code class="font-mono">0 0 31 * *</code> will not fire in April because April has only 30 days. The next-run calculation is done entirely in the browser using the visitor's local time.</p>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Security and privacy</h2>
    <p class="mt-3 text-slate-600">All cron expression parsing happens in your browser. No data is sent to any server — the text you type never leaves your device. This means you can safely paste cron expressions from production systems without worrying about data leakage. There are no cookies, trackers, or analytics scripts associated with the translation functionality.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/cron-expression-generator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm transition hover:border-indigo-200 hover:shadow-sm">
        <span class="font-semibold text-slate-900">Cron Expression Generator</span>
        <p class="mt-1 text-slate-600">Build cron schedules with dropdowns — no syntax needed.</p>
      </a>
      <a href="/tools/jwt-decoder" class="rounded-xl border border-slate-200 bg-white p-4 text-sm transition hover:border-indigo-200 hover:shadow-sm">
        <span class="font-semibold text-slate-900">JWT Decoder</span>
        <p class="mt-1 text-slate-600">Decode and inspect JSON Web Tokens.</p>
      </a>
      <a href="/tools/uuid-generator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm transition hover:border-indigo-200 hover:shadow-sm">
        <span class="font-semibold text-slate-900">UUID Generator</span>
        <p class="mt-1 text-slate-600">Generate v4 UUIDs in your browser.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    var MONTH_NAMES = { jan: 1, feb: 2, mar: 3, apr: 4, may: 5, jun: 6, jul: 7, aug: 8, sep: 9, oct: 10, nov: 11, dec: 12 };
    var DAY_NAMES = { sun: 0, mon: 1, tue: 2, wed: 3, thu: 4, fri: 5, sat: 6 };

    function parseField(val, min, max, names) {
      val = val.trim().toLowerCase();
      if (val === '*') return { type: 'all' };
      if (names && names[val] !== undefined) return { type: 'exact', value: names[val] };
      var stepMatch = val.match(/^\*\/(\d+)$/);
      if (stepMatch) return { type: 'step', step: parseInt(stepMatch[1], 10), min: min, max: max };
      var parts = val.split(',');
      if (parts.length > 1) {
        var items = parts.map(function(p) { return parseField(p.trim(), min, max, names); });
        var values = [];
        for (var i = 0; i < items.length; i++) {
          if (items[i].type === 'exact') values.push(items[i].value);
          else if (items[i].type === 'range') { for (var v = items[i].from; v <= items[i].to; v++) values.push(v); }
          else if (items[i].type === 'step') { for (var v = items[i].min; v <= items[i].max; v += items[i].step) values.push(v); }
        }
        if (values.length) return { type: 'list', values: values };
        return items[0];
      }
      var rangeMatch = val.match(/^(\d+)-(\d+)$/);
      if (rangeMatch) return { type: 'range', from: parseInt(rangeMatch[1], 10), to: parseInt(rangeMatch[2], 10) };
      var n = parseInt(val, 10);
      if (!isNaN(n) && n >= min && n <= max) return { type: 'exact', value: n };
      return null;
    }

    function describeField(parsed, unit, units) {
      if (!parsed) return '';
      if (parsed.type === 'all') return 'every ' + unit;
      if (parsed.type === 'exact') return 'at ' + parsed.value;
      if (parsed.type === 'range') return 'from ' + parsed.from + ' to ' + parsed.to;
      if (parsed.type === 'step') return 'every ' + parsed.step + ' ' + units + ' (from ' + parsed.min + ' to ' + parsed.max + ')';
      if (parsed.type === 'list') {
        if (parsed.values.length <= 2) return 'at ' + parsed.values.join(' and ');
        return 'at ' + parsed.values.slice(0, -1).join(', ') + ' and ' + parsed.values[parsed.values.length - 1];
      }
      return '';
    }

    var DOW_NAMES = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    var MONTH_NAMES_FULL = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

    function formatList(values, names) {
      var named = values.map(function(v) { return names ? names[v] || v : v; });
      if (named.length <= 2) return named.join(' and ');
      return named.slice(0, -1).join(', ') + ' and ' + named[named.length - 1];
    }

    function describeCron(fields) {
      var min = parseField(fields[0], 0, 59);
      var hr = parseField(fields[1], 0, 23);
      var dom = parseField(fields[2], 1, 31);
      var mon = parseField(fields[3], 1, 12, MONTH_NAMES);
      var dow = parseField(fields[4], 0, 6, DAY_NAMES);

      if (!min || !hr || !dom || !mon || !dow) return null;

      var parts = [];

      // Minute
      var minuteStr = '';
      if (min.type === 'all') minuteStr = 'every minute';
      else if (min.type === 'exact') minuteStr = 'at minute ' + min.value;
      else if (min.type === 'step') minuteStr = 'every ' + min.step + ' minutes';
      else if (min.type === 'list') minuteStr = 'at minute ' + formatList(min.values);

      // Hour
      var hourStr = '';
      if (hr.type === 'all') hourStr = 'every hour';
      else if (hr.type === 'exact') {
        var h = hr.value;
        var ampm = h >= 12 ? 'PM' : 'AM';
        var h12 = h % 12 || 12;
        var m = min.type === 'exact' ? String(min.value).padStart(2, '0') : '';
        if (min.type === 'all') hourStr = 'every minute of ' + h12 + ':00 ' + ampm;
        else if (min.type === 'exact') hourStr = 'at ' + h12 + ':' + m + ' ' + ampm;
        else if (min.type === 'step' || min.type === 'list') hourStr = describeField(min, 'minute', 'minutes') + ' past ' + h12 + ':00 ' + ampm;
      } else if (hr.type === 'range') hourStr = 'between ' + hr.from + ':00 and ' + hr.to + ':00';
      else if (hr.type === 'step') hourStr = 'every ' + hr.step + ' hours';

      // Build the full description
      var timePart = '';
      if (hr.type === 'exact' && (min.type === 'exact' || min.type === 'all')) {
        // Handled above
      } else if (hr.type === 'exact') {
        timePart = hourStr;
      } else if (hr.type === 'all' && min.type === 'exact') {
        timePart = 'at minute ' + min.value + ' of every hour';
      } else if (hr.type === 'all' && min.type === 'all') {
        timePart = 'every minute';
      } else if (hr.type === 'all' && min.type === 'step') {
        timePart = 'every ' + min.step + ' minutes';
      } else if (hr.type === 'all' && min.type === 'list') {
        timePart = 'at minute ' + formatList(min.values) + ' of every hour';
      } else {
        timePart = hourStr;
      }

      // If minute is exact and hour is exact, build a clean time string
      if (min.type === 'exact' && hr.type === 'exact') {
        var h = hr.value;
        var ampm = h >= 12 ? 'PM' : 'AM';
        var h12 = h % 12 || 12;
        timePart = 'At ' + h12 + ':' + String(min.value).padStart(2, '0') + ' ' + ampm;
      } else if (min.type === 'exact' && hr.type === 'all') {
        timePart = 'At minute ' + min.value + ' past every hour';
      } else if (min.type === 'step' && hr.type === 'all') {
        timePart = 'Every ' + min.step + ' minutes';
      } else if (min.type === 'all' && hr.type === 'all') {
        timePart = 'Every minute';
      } else if (min.type === 'all' && hr.type === 'exact') {
        var h = hr.value;
        var ampm = h >= 12 ? 'PM' : 'AM';
        var h12 = h % 12 || 12;
        timePart = 'Every minute of ' + h12 + ':00 ' + ampm;
      } else if (min.type === 'list' && hr.type === 'exact') {
        var h = hr.value;
        var ampm = h >= 12 ? 'PM' : 'AM';
        var h12 = h % 12 || 12;
        timePart = 'At minute ' + formatList(min.values) + ' past ' + h12 + ':00 ' + ampm;
      } else {
        var desc = [];
        if (min.type === 'exact' && hr.type !== 'exact') desc.push(minuteStr);
        if (hr.type !== 'all' && !(hr.type === 'exact' && min.type === 'exact')) {
          if (hr.type === 'exact') {
            var h = hr.value;
            var ampm = h >= 12 ? 'PM' : 'AM';
            var h12 = h % 12 || 12;
            desc.push('past ' + h12 + ':00 ' + ampm);
          } else {
            desc.push(hourStr);
          }
        }
        timePart = desc.join(' ');
      }

      parts.push(timePart);

      // Day of month
      var domStr = '';
      if (dom.type === 'all') domStr = '';
      else if (dom.type === 'exact') domStr = 'on day ' + dom.value;
      else if (dom.type === 'list') domStr = 'on days ' + formatList(dom.values);
      else if (dom.type === 'range') domStr = 'on days ' + dom.from + ' to ' + dom.to;

      // Month
      var monStr = '';
      if (mon.type === 'all') monStr = '';
      else if (mon.type === 'exact') monStr = ' in ' + MONTH_NAMES_FULL[mon.value];
      else if (mon.type === 'list') monStr = ' in ' + formatList(mon.values, MONTH_NAMES_FULL);
      else if (mon.type === 'range') monStr = ' from ' + MONTH_NAMES_FULL[mon.from] + ' to ' + MONTH_NAMES_FULL[mon.to];

      // Day of week
      var dowStr = '';
      if (dow.type === 'all') dowStr = '';
      else if (dow.type === 'exact') dowStr = ' on ' + DOW_NAMES[dow.value];
      else if (dow.type === 'list') dowStr = ' on ' + formatList(dow.values, DOW_NAMES);
      else if (dow.type === 'range') dowStr = ' on ' + DOW_NAMES[dow.from] + ' to ' + DOW_NAMES[dow.to];

      // Combine: if dom and dow are both set, use "OR" logic
      if (dom.type !== 'all' && dow.type !== 'all') {
        if (domStr) parts.push(domStr);
        if (dowStr) parts.push('or' + dowStr);
      } else {
        if (domStr) parts.push(domStr);
        if (dowStr) parts.push(dowStr);
      }

      if (monStr) parts.push(monStr);

      // Clean up
      var result = parts.join(' ').replace(/\s+/g, ' ').trim();
      // Capitalize first letter
      return result.charAt(0).toUpperCase() + result.slice(1);
    }

    function fieldMatches(val, field) {
      if (field.type === 'all') return true;
      if (field.type === 'exact') return val === field.value;
      if (field.type === 'range') return val >= field.from && val <= field.to;
      if (field.type === 'step') return val >= field.min && val <= field.max && (val - field.min) % field.step === 0;
      if (field.type === 'list') return field.values.indexOf(val) !== -1;
      return false;
    }

    function getNextRunTimes(fields) {
      var min = parseField(fields[0], 0, 59);
      var hr = parseField(fields[1], 0, 23);
      var dom = parseField(fields[2], 1, 31);
      var mon = parseField(fields[3], 1, 12, MONTH_NAMES);
      var dow = parseField(fields[4], 0, 6, DAY_NAMES);

      if (!min || !hr || !dom || !mon || !dow) return [];
      if (min.type === 'all' && hr.type === 'all' && dom.type === 'all' && mon.type === 'all' && dow.type === 'all') {
        return []; // every minute — too many to list
      }

      var now = new Date();
      var times = [];
      var MAX_CHECK = 525600; // 1 year of minutes
      // Start from the next minute
      var current = new Date(now);
      current.setSeconds(0, 0);
      current.setMinutes(current.getMinutes() + 1);

      for (var i = 0; i < MAX_CHECK && times.length < 5; i++) {
        var m = current.getMinutes();
        var h = current.getHours();
        var d = current.getDate();
        var mo = current.getMonth() + 1;
        var y = current.getFullYear();
        var w = current.getDay();

        // Check month
        if (!fieldMatches(mo, mon)) { current.setMinutes(m + 1); continue; }
        // Check day of month OR day of week (if both are specified)
        var domMatch = fieldMatches(d, dom);
        var dowMatch = fieldMatches(w, dow);
        if (dom.type !== 'all' && dow.type !== 'all') {
          if (!domMatch && !dowMatch) { current.setMinutes(m + 1); continue; }
        } else {
          if (!domMatch) { current.setMinutes(m + 1); continue; }
          if (!dowMatch) { current.setMinutes(m + 1); continue; }
        }
        // Check hour
        if (!fieldMatches(h, hr)) { current.setMinutes(m + 1); continue; }
        // Check minute
        if (!fieldMatches(m, min)) { current.setMinutes(m + 1); continue; }

        times.push(new Date(current));
        current.setMinutes(m + 1);
      }
      return times;
    }

    function formatDate(d) {
      var days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      var h = d.getHours();
      var m = String(d.getMinutes()).padStart(2, '0');
      var ampm = h >= 12 ? 'PM' : 'AM';
      var h12 = h % 12 || 12;
      return days[d.getDay()] + ', ' + d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear() + ' — ' + h12 + ':' + m + ' ' + ampm;
    }

    function parseAndDisplay(cron) {
      var resultDiv = document.getElementById('result');
      var invalidDiv = document.getElementById('invalid-result');
      var descEl = document.getElementById('description');
      var errorEl = document.getElementById('error');
      var nextEl = document.getElementById('next-times');

      resultDiv.classList.add('hidden');
      invalidDiv.classList.add('hidden');

      cron = cron.trim();
      if (!cron) return;

      var fields = cron.split(/\s+/);
      if (fields.length !== 5) {
        invalidDiv.classList.remove('hidden');
        return;
      }

      var desc = describeCron(fields);
      if (!desc) {
        invalidDiv.classList.remove('hidden');
        return;
      }

      descEl.textContent = desc;
      descEl.classList.remove('hidden');
      errorEl.classList.add('hidden');

      // Next run times
      nextEl.innerHTML = '';
      var times = getNextRunTimes(fields);
      if (times && times.length > 0) {
        var heading = document.createElement('p');
        heading.className = 'text-xs font-semibold text-slate-500';
        heading.textContent = 'Next 5 run times:';
        nextEl.appendChild(heading);
        for (var i = 0; i < times.length; i++) {
          var li = document.createElement('p');
          li.className = 'text-xs font-mono text-slate-700';
          li.textContent = (i + 1) + '. ' + formatDate(times[i]);
          nextEl.appendChild(li);
        }
      }

      resultDiv.classList.remove('hidden');
    }

    var input = document.getElementById('cron-input');
    var copyBtn = document.getElementById('copy-btn');
    var debounceTimer = null;

    input.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() {
        parseAndDisplay(input.value);
      }, 200);
    });

    copyBtn.addEventListener('click', async function() {
      var text = document.getElementById('description').textContent;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        var orig = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(function() { copyBtn.textContent = orig; }, 1200);
      } catch (e) {}
    });
  </script>
</ToolLayout>
