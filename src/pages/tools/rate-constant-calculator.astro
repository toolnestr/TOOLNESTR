---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Rate Constant Calculator';
const description = 'Rate constant calculator with a live 3D diagram and charts. Solve k = rate / ([A]^m[B]^n) for the rate constant of a reaction given its rate law, reaction orders, and concentrations, with worked examples.';
const intro = 'Solve k = rate / ([A]^m[B]^n) for the rate constant of a reaction, given the reaction orders and concentrations of up to two reactants. Two 3D diagrams compare a dilute, slow-reacting mixture to a concentrated, fast-reacting one, and charts show how rate scales with concentration for different reaction orders.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is a rate constant?', a: 'The rate constant (k) is the proportionality factor in a rate law that connects reactant concentrations to reaction rate. A larger k means a faster reaction at the same concentrations.' },
  { q: 'How do I find the units of k?', a: "The units of k depend on the overall reaction order (m+n). For a rate law with overall order p, k carries units of M^(1−p)·s⁻¹ — for example, a second-order reaction (p=2) gives k units of M⁻¹s⁻¹." },
  { q: 'What is the difference between reaction order and molecularity?', a: 'Reaction order is determined experimentally from how rate actually changes with concentration, and can be any value. Molecularity refers to the number of molecules colliding in a single elementary step, and is always a small whole number — the two only match for simple, single-step reactions.' },
  { q: 'How is reaction order determined experimentally?', a: 'The method of initial rates compares how the measured rate changes when one reactant\'s concentration is changed while others are held constant — doubling [A] and seeing the rate double means first order in A; seeing it quadruple means second order.' },
  { q: 'Does the rate constant change over the course of a reaction?', a: 'No — at a fixed temperature, k stays constant throughout the reaction. What changes as the reaction proceeds is the concentration of reactants, which is exactly why the rate itself slows down over time even though k does not.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Rate Constant Calculator',
  description: 'Solve k = rate / ([A]^m[B]^n) from a measured rate, reactant concentrations, and reaction orders.',
  steps: [
    { name: 'Enter the measured rate', text: 'The experimentally observed reaction rate, in M/s.' },
    { name: 'Enter concentrations and orders', text: 'Provide [A] and its order m; add [B] and its order n if the rate law has a second reactant.' },
    { name: 'Read the rate constant', text: 'k solves instantly, along with its correct units for the overall reaction order.' },
  ],
};

const formulas = [
  { expr: 'rate = k[A]^m[B]^n', note: 'general rate law — m and n are the reaction orders in A and B, found experimentally' },
  { expr: 'k = rate / ([A]^m[B]^n)', note: 'solve for the rate constant' },
  { expr: 'units of k = M^(1−p)·s⁻¹', note: 'p = m+n = overall reaction order' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — second order in a single reactant', tone: 'slate',
    given: 'rate = k[A]², measured rate = 0.0345 M/s at [A] = 0.10 M.',
    rows: [
      { label: 'Formula:', value: 'k = rate / [A]²' },
      { label: 'Substitute:', value: 'k = 0.0345 / (0.10)²' },
      { label: 'Result:', value: 'k = 3.45 M⁻¹s⁻¹ (overall order 2, so units are M⁻¹s⁻¹)', full: true },
    ],
    note: 'Because the reaction is second order overall, doubling [A] would quadruple the rate — the exponent directly sets how sensitive the reaction is to concentration changes.',
  },
  {
    title: 'Worked example 2 — two reactants with different orders', tone: 'amber',
    given: 'rate = k[A][B]², measured rate = 4.5×10⁻³ M/s at [A] = 0.20 M, [B] = 0.30 M.',
    rows: [
      { label: 'Formula:', value: 'k = rate / ([A]¹[B]²)' },
      { label: 'Substitute:', value: 'k = 4.5×10⁻³ / (0.20 × 0.30²) = 4.5×10⁻³ / 0.018' },
      { label: 'Result:', value: 'k = 0.25 M⁻²s⁻¹ (overall order 3, so units are M⁻²s⁻¹)', full: true },
    ],
    note: "This reaction is first order in A but second order in B — doubling [B] alone would quadruple the rate, while doubling [A] alone would only double it.",
  },
];

const comparison = {
  heading: 'How rate responds to doubling concentration, by reaction order',
  note: 'The reaction order sets exactly how sensitive rate is to a change in concentration.',
  headers: [{ label: 'Order' }, { label: 'Rate law' }, { label: 'Effect of doubling [A]' }, { label: 'Units of k' }],
  rows: [
    ['Zero order', 'rate = k', 'No change', 'M·s⁻¹'],
    ['First order', 'rate = k[A]', 'Rate doubles', 's⁻¹'],
    ['Second order ★', 'rate = k[A]²', 'Rate quadruples', 'M⁻¹s⁻¹'],
    ['Third order', 'rate = k[A]³', 'Rate is 8× larger', 'M⁻²s⁻¹'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). This table is exactly how chemists identify reaction order from experimental data — measure how the rate multiplies when concentration is doubled.',
};

const realWorld = [
  { emoji: '💊', title: 'Drug metabolism and dosing', body: 'Many drugs break down in the body following first-order kinetics, where the rate constant directly determines a drug\'s half-life — critical information for setting safe, effective dosing schedules.' },
  { emoji: '🏭', title: 'Industrial reactor design', body: 'Chemical engineers use measured rate constants to size reactors and predict how long a reaction needs to run to reach a target conversion, directly affecting plant throughput and cost.' },
  { emoji: '🌫️', title: 'Atmospheric chemistry', body: 'Rate constants for reactions like ozone depletion or smog formation are measured precisely because they determine how quickly pollutants accumulate or break down in the atmosphere.' },
  { emoji: '🍞', title: 'Food science and shelf-life prediction', body: 'Spoilage reactions (oxidation, microbial growth) follow rate laws with measurable rate constants, letting food scientists predict shelf life and design accurate expiration dating.' },
];

const misconceptions = [
  { claim: '"The exponents in a rate law match the coefficients in the balanced chemical equation."', truth: "This is only true for a single-step elementary reaction. For any multi-step reaction (the vast majority of real reactions), the rate law's exponents must be determined experimentally — they cannot be read directly off the balanced overall equation." },
  { claim: '"A larger rate constant always means a faster-completing reaction."', truth: "A larger k does mean the reaction proceeds faster at any given concentration, but the actual rate also depends on concentration itself — a large-k reaction at very low concentration can still proceed slower than a small-k reaction at high concentration." },
  { claim: '"Rate constants are unitless, like equilibrium constants are sometimes treated."', truth: "Rate constants carry units that depend on the overall reaction order, and those units are essential — without them, the rate constant's numerical value is meaningless and can't be compared correctly between reactions of different order." },
  { claim: '"Doubling the concentration of every reactant always doubles the rate."', truth: 'The effect depends entirely on the reaction order in each reactant — doubling a reactant with order 2 quadruples its contribution to rate, and doubling a zero-order reactant has no effect on rate at all.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 12, "Kinetics" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/12-3-rate-laws" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Atkins &amp; de Paula, <em>Physical Chemistry</em></strong> — Chemical kinetics chapters.' },
  { html: '<strong>Chang, <em>Chemistry</em></strong> — Reaction rate laws and mechanisms.' },
];
const sourcesNote = 'k = rate / ([A]^m[B]^n). Units of k = M^(1−p)·s⁻¹ where p is the overall order. Results are rounded for display.';

const howToUse = [
  { title: 'Enter the measured rate', body: 'Type the experimentally observed rate in M/s.' },
  { title: 'Enter concentration and order for A', body: 'Add B\'s concentration and order too, if the rate law involves a second reactant.' },
  { title: 'Read k and its units', body: 'The rate constant and its correctly-derived units solve automatically.' },
];

const related = [
  { href: '/tools/reaction-rate-calculator', emoji: '⏳', title: 'Reaction Rate Calculator', desc: 'rate = |ΔX| / (coefficient × Δt) — reactant or product.' },
  { href: '/tools/arrhenius-equation-calculator', emoji: '🏔️', title: 'Arrhenius Equation Calculator', desc: 'k = Ae^(−Ea/RT), or find Ea from two (T,k) points.' },
  { href: '/tools/equilibrium-constant-calculator', emoji: '🔁', title: 'Equilibrium Constant (Keq) Calculator', desc: 'Kc from concentrations of reactants and products.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="the rate constant is what's left of a reaction's speed once you strip away the effect of concentration — it captures everything else about how fast a reaction goes, from molecular collision frequency to how favorably the molecules are oriented when they collide."
  howIntro="A reaction's observed rate depends on both how concentrated the reactants are and on an intrinsic rate constant k that reflects the reaction's own chemistry — its activation energy, temperature, and collision geometry. The rate law rate = k[A]^m[B]^n separates these two effects: raise a reactant's concentration and the [A]^m or [B]^n term grows, but k itself stays fixed at a given temperature. Solving for k isolates that intrinsic reaction speed, which is exactly why comparing k values (not raw rates) is the correct way to compare how fast two different reactions truly are."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the rate constant actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Measured rate (M/s)</span>
      <input id="rate" type="number" step="any" value="0.0345" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">[A] (M)</span>
        <input id="ca" type="number" step="any" value="0.10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Order in A (m)</span>
        <input id="ma" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">[B] (M) — optional</span>
        <input id="cb" type="number" step="any" placeholder="leave blank if only one reactant" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Order in B (n)</span>
        <input id="nb" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Rate constant (k)</div><div id="r-k" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Overall order</div><div id="r-order" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="rc-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Dilute vs. concentrated reaction mixture</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-dilute" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low concentration</h3>
          <p class="mt-1 text-sm text-slate-600">Fewer reactant molecules — fewer collisions per second, so a slower reaction rate.</p>
        </div>
        <div>
          <div id="diag-concentrated" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High concentration</h3>
          <p class="mt-1 text-sm text-slate-600">Many more reactant molecules — far more collisions per second, so a faster reaction rate.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Reaction order graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Rate vs. [A] for orders 0, 1, 2</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-orders"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ln(rate) vs. ln[A] — slope reveals the order</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-log"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('rc-err').textContent = '';
        el('r-k').textContent = '—'; el('r-order').textContent = '—';
        const rate = parseFloat(el('rate').value);
        const ca = parseFloat(el('ca').value), ma = parseFloat(el('ma').value);
        const cbRaw = el('cb').value, nbRaw = el('nb').value;
        const cb = cbRaw === '' ? null : parseFloat(cbRaw);
        const nb = nbRaw === '' ? 0 : parseFloat(nbRaw);
        if (isNaN(rate) || isNaN(ca) || isNaN(ma)) return;
        if (rate <= 0 || ca <= 0) { el('rc-err').textContent = 'Rate and [A] must be positive.'; return; }
        if (cb !== null && (isNaN(cb) || cb <= 0)) { el('rc-err').textContent = '[B] must be positive if provided.'; return; }
        const bTerm = cb !== null ? Math.pow(cb, nb) : 1;
        const aTerm = Math.pow(ca, ma);
        if (aTerm * bTerm === 0) { el('rc-err').textContent = 'Concentration terms cannot evaluate to zero.'; return; }
        const k = rate / (aTerm * bTerm);
        const order = ma + (cb !== null ? nb : 0);
        el('r-k').textContent = fmt(k) + ' M^' + (1 - order).toFixed(2).replace(/\.00$/, '') + '·s⁻¹';
        el('r-order').textContent = order.toFixed(2).replace(/\.00$/, '');
      }
      ['rate', 'ca', 'ma', 'cb', 'nb'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const conc = [0.05, 0.1, 0.15, 0.2, 0.25, 0.3, 0.35, 0.4];
        new Chart(el('chart-orders'), {
          type: 'line',
          data: {
            labels: conc,
            datasets: [
              { label: 'Order 0', data: conc.map(() => 1), borderColor: '#94a3b8', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
              { label: 'Order 1', data: conc.map((c) => +(10 * c).toFixed(2)), borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
              { label: 'Order 2', data: conc.map((c) => +(10 * c * c).toFixed(2)), borderColor: '#f59e0b', backgroundColor: 'transparent', tension: 0.2, pointRadius: 0 },
            ],
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: '[A] (M)' } }, y: { title: { display: true, text: 'Relative rate' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        const lnA = conc.map((c) => +Math.log(c).toFixed(3));
        const lnRate2 = conc.map((c) => +Math.log(10 * c * c).toFixed(3));
        new Chart(el('chart-log'), {
          type: 'scatter',
          data: { datasets: [{ label: 'ln(rate) vs ln[A], order=2', data: lnA.map((x, i) => ({ x, y: lnRate2[i] })), borderColor: '#6366f1', backgroundColor: '#6366f1', showLine: true, pointRadius: 3 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'ln[A]' } }, y: { title: { display: true, text: 'ln(rate)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function moleculeScene(container, count) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const box = new THREE.Mesh(new THREE.BoxGeometry(4, 3, 3), new THREE.MeshBasicMaterial({ color: 0x94a3b8, wireframe: true }));
        s.scene.add(box);
        for (let i = 0; i < count; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.18, 10, 8), new THREE.MeshStandardMaterial({ color: i % 2 === 0 ? 0x6366f1 : 0xf59e0b }));
          m.position.set((Math.random() - 0.5) * 3.5, (Math.random() - 0.5) * 2.5, (Math.random() - 0.5) * 2.5);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagDilute = null, diagConcentrated = null;
      function initDiagDilute() { const c = el('diag-dilute'); if (!c) throw new Error('no container'); diagDilute = moleculeScene(c, 6); }
      function initDiagConcentrated() { const c = el('diag-concentrated'); if (!c) throw new Error('no container'); diagConcentrated = moleculeScene(c, 28); }

      function boot() {
        try { update(); } catch (e) { console.error('[rate-constant] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[rate-constant] charts failed', e); }
        if (window.THREE) {
          try { initDiagDilute(); } catch (e) { console.error('[rate-constant] dilute diagram failed', e); }
          try { initDiagConcentrated(); } catch (e) { console.error('[rate-constant] concentrated diagram failed', e); }
        }
        mountResize([diagDilute, diagConcentrated]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
