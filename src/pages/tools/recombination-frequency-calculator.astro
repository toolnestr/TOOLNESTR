---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Recombination Frequency Calculator';
const description = "Recombination frequency calculator. Compute RF% from recombinant vs parental offspring counts to detect gene linkage and estimate genetic map distance.";
const intro = 'Enter parental and recombinant offspring counts to compute recombination frequency (RF%), a direct measure of how far apart two genes are on a chromosome. Two 3D diagrams show a chromosome pair before and after a crossover event, and charts compare RF% against genetic map distance.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is recombination frequency?', a: 'Recombination frequency (RF) is the percentage of offspring showing a new combination of alleles (different from either parent) due to crossing over during meiosis, calculated as recombinant offspring divided by total offspring.' },
  { q: 'How does recombination frequency indicate gene linkage?', a: 'Genes located close together on the same chromosome are inherited together more often (low RF, strong linkage). Genes far apart, or on different chromosomes, assort independently, producing RF close to 50% (the same as no linkage at all).' },
  { q: 'What is a map unit (centimorgan)?', a: 'One map unit (or centimorgan, cM) is defined as 1% recombination frequency. RF% translates directly into an estimated physical distance between two genes on a genetic linkage map.' },
  { q: 'Why can RF never exceed 50%, even for genes very far apart?', a: 'Once two genes are far enough apart that crossovers happen essentially at random between them, they behave exactly like unlinked genes, capping recombination frequency at 50% — the same result as genes on entirely separate chromosomes.' },
  { q: 'What produces recombinant offspring?', a: 'Recombinant offspring arise from crossing over — a physical exchange of DNA segments between homologous chromosomes during meiosis — which shuffles allele combinations that were originally linked together on the same chromosome.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Recombination Frequency Calculator',
  description: 'Compute recombination frequency (RF%) from parental and recombinant offspring counts to assess gene linkage.',
  steps: [
    { name: 'Enter offspring counts', text: 'Provide the number of parental-type and recombinant-type offspring.' },
    { name: 'Read RF%', text: 'Recombination frequency and estimated map distance (in map units) solve instantly.' },
    { name: 'Interpret linkage', text: 'Low RF% suggests tight linkage; RF% near 50% suggests no linkage (independent assortment).' },
  ],
};

const formulas = [
  { expr: 'RF% = (recombinants / total offspring) × 100', note: 'the fraction of offspring showing new allele combinations' },
  { expr: '1 map unit (cM) = 1% recombination frequency', note: 'converts RF% directly into estimated genetic map distance' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — linked genes with a modest crossover rate', tone: 'slate',
    given: 'A test cross produces 1000 total offspring: 940 parental-type and 60 recombinant-type.',
    rows: [
      { label: 'Formula:', value: 'RF% = (recombinants / total) × 100' },
      { label: 'Substitute:', value: 'RF% = (60 / 1000) × 100' },
      { label: 'Result:', value: 'RF = 6%, so the genes are about 6 map units (cM) apart', full: true },
    ],
    note: 'A low RF like 6% indicates the two genes are physically close together on the same chromosome, since crossovers between them are relatively rare.',
  },
  {
    title: 'Worked example 2 — genes far apart or unlinked', tone: 'amber',
    given: 'A different test cross produces 800 total offspring: 410 parental-type and 390 recombinant-type.',
    rows: [
      { label: 'Formula:', value: 'RF% = (recombinants / total) × 100' },
      { label: 'Substitute:', value: 'RF% = (390 / 800) × 100' },
      { label: 'Result:', value: 'RF ≈ 48.75% — very close to 50%, suggesting the genes are either unlinked or very far apart on the same chromosome', full: true },
    ],
    note: 'An RF this close to 50% cannot reliably distinguish "unlinked" from "linked but very far apart" — additional genetic mapping data would be needed to tell the two apart.',
  },
];

const comparison = {
  heading: 'Interpreting recombination frequency values',
  note: 'RF% translates directly into how tightly two genes are linked on a chromosome.',
  headers: [{ label: 'RF%' }, { label: 'Map distance' }, { label: 'Interpretation' }],
  rows: [
    ['1%', '1 cM', 'Extremely tight linkage'],
    ['6% ★', '6 cM', 'Moderate linkage'],
    ['25%', '25 cM', 'Loose linkage'],
    ['~50%', 'N/A', 'Unlinked (or very far apart)'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Beyond a certain distance, map units stop scaling linearly with physical distance because multiple crossovers can occur, but RF near 50% always signals effectively independent assortment.',
};

const realWorld = [
  { emoji: '🗺️', title: 'Genetic linkage mapping', body: 'Recombination frequency data across many gene pairs is used to build genetic linkage maps, ordering genes along a chromosome and estimating relative distances between them.' },
  { emoji: '🧬', title: 'Disease gene localization', body: 'Before modern DNA sequencing, recombination frequency with known genetic markers was a primary method for localizing disease-causing genes to a specific chromosome region.' },
  { emoji: '🌾', title: 'Marker-assisted crop breeding', body: 'Plant breeders use recombination frequency data to select genetic markers linked to desirable traits, speeding up breeding programs without waiting for the trait itself to appear.' },
  { emoji: '🔬', title: 'Model organism genetics (fruit flies)', body: "Thomas Hunt Morgan's classic fruit fly experiments used recombination frequency to build the first genetic linkage maps, establishing that genes are arranged linearly along chromosomes." },
];

const misconceptions = [
  { claim: '"Recombination frequency can be any value from 0% to 100%."', truth: 'Recombination frequency is capped at 50% — once genes are far enough apart (or on different chromosomes), crossovers effectively randomize their inheritance, producing the same 50% ceiling as complete independent assortment.' },
  { claim: '"A recombination frequency of 50% definitely means the genes are on different chromosomes."', truth: "It's ambiguous — genes on different chromosomes will show 50% RF, but genes on the SAME chromosome that are simply very far apart can also show RF very close to 50%, since crossovers become essentially certain to happen between them somewhere." },
  { claim: '"Map units convert perfectly and linearly to physical DNA distance (base pairs) everywhere."', truth: 'Recombination rates vary along a chromosome — some regions have much higher or lower crossover rates than others — so map units (genetic distance) don\'t translate into a perfectly uniform physical distance in base pairs across the whole genome.' },
  { claim: '"Recombinant offspring are genetically abnormal or damaged."', truth: 'Recombinant offspring are a completely normal result of ordinary meiotic crossing over — a healthy, expected process that actually increases genetic diversity, not a sign of any genetic damage or error.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 12, "Mendel\'s Experiments and Heredity" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/12-3-laws-of-inheritance" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 5, Gene Mapping in Eukaryotes.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 15, The Chromosomal Basis of Inheritance.' },
];
const sourcesNote = 'RF% = (recombinants/total) × 100. 1 map unit (cM) = 1% RF, valid for relatively short genetic distances. Results are rounded for display.';

const howToUse = [
  { title: 'Enter offspring counts', body: 'Provide the number of parental-type and recombinant-type offspring from a test cross.' },
  { title: 'Read RF% and map distance', body: 'Recombination frequency and its equivalent map units solve instantly.' },
  { title: 'Interpret the linkage strength', body: 'Compare your result against the reference table to judge how tightly linked the genes are.' },
];

const related = [
  { href: '/tools/dihybrid-cross-calculator', emoji: '🧬', title: 'Dihybrid Cross Calculator', desc: 'Two-gene cross — the classic 9:3:3:1 phenotype ratio.' },
  { href: '/tools/chi-square-genetics-calculator', emoji: '📊', title: 'Chi-Square Goodness of Fit Calculator', desc: 'Test whether observed offspring match a predicted ratio.' },
  { href: '/tools/sex-linked-trait-calculator', emoji: '🔬', title: 'Sex-Linked Trait Punnett Calculator', desc: 'X-linked inheritance crosses.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="genes sitting close together on the same chromosome tend to travel together into gametes, so the fraction of offspring that show a new, shuffled combination directly measures — and is caused by — how often a crossover event happens to land physically between the two genes."
  howIntro="During meiosis, homologous chromosomes can exchange segments through crossing over, and the farther apart two genes sit on a chromosome, the more physical space there is for a crossover to occur somewhere between them. Because each crossover event that happens between two linked genes shuffles their alleles into new combinations, the observed fraction of recombinant offspring (RF%) directly reflects — and is used to estimate — the physical distance between them, calibrated in map units where 1 map unit is defined as exactly 1% recombination frequency."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where recombination frequency actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Parental-type offspring</span>
        <input id="parental" type="number" step="any" value="940" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Recombinant-type offspring</span>
        <input id="recomb" type="number" step="any" value="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Recombination frequency</div><div id="r-rf" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Estimated map distance</div><div id="r-map" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="rf-verdict" class="mt-3 text-center text-sm font-semibold"></p>
    <p id="rf-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Chromosomes before and after crossover</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-before" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Homologous chromosomes before crossover</h3>
          <p class="mt-1 text-sm text-slate-600">Each chromosome (indigo and amber) still carries its original, unshuffled set of alleles.</p>
        </div>
        <div>
          <div id="diag-after" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. After a crossover event</h3>
          <p class="mt-1 text-sm text-slate-600">A segment has swapped between the two chromosomes — this is exactly what produces recombinant offspring.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Recombination frequency graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">RF% vs map distance — a direct 1:1 relationship</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-map"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Parental vs recombinant offspring proportions</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-props"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function update() {
        el('rf-err').textContent = ''; el('rf-verdict').textContent = '';
        el('r-rf').textContent = '—'; el('r-map').textContent = '—';
        const parental = parseFloat(el('parental').value), recomb = parseFloat(el('recomb').value);
        if (isNaN(parental) || isNaN(recomb)) return;
        if (parental < 0 || recomb < 0) { el('rf-err').textContent = 'Counts cannot be negative.'; return; }
        const total = parental + recomb;
        if (total === 0) { el('rf-err').textContent = 'Total offspring must be greater than 0.'; return; }
        const rf = (recomb / total) * 100;
        el('r-rf').textContent = fmt(rf) + '%';
        el('r-map').textContent = fmt(rf) + ' map units (cM)';
        let verdict, cls;
        if (rf < 10) { verdict = 'Tight linkage'; cls = 'text-green-600'; }
        else if (rf < 40) { verdict = 'Moderate linkage'; cls = 'text-amber-600'; }
        else { verdict = 'Weak/no linkage (near 50%)'; cls = 'text-slate-600'; }
        el('rf-verdict').textContent = verdict;
        el('rf-verdict').className = 'mt-3 text-center text-sm font-semibold ' + cls;
      }
      ['parental', 'recomb'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labels = [], data = [];
        for (let rf = 0; rf <= 50; rf += 5) { labels.push(rf); data.push(rf); }
        charts.map = new Chart(el('chart-map'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'Map units (cM)', data, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'RF%' } }, y: { title: { display: true, text: 'Map units (cM)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.props = new Chart(el('chart-props'), {
          type: 'pie',
          data: { labels: ['Parental (94%)', 'Recombinant (6%)'], datasets: [{ data: [940, 60], backgroundColor: ['#6366f1', '#f59e0b'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function chromScene(container, crossed) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        function chromosome(x, colorTop, colorBottom, swapTop) {
          const topColor = swapTop ? colorBottom : colorTop;
          const botColor = swapTop ? colorTop : colorBottom;
          const top = new THREE.Mesh(new THREE.CapsuleGeometry(0.3, 1.5, 8, 16), new THREE.MeshStandardMaterial({ color: topColor, roughness: 0.5 }));
          top.position.set(x, 1, 0);
          const bot = new THREE.Mesh(new THREE.CapsuleGeometry(0.3, 1.5, 8, 16), new THREE.MeshStandardMaterial({ color: botColor, roughness: 0.5 }));
          bot.position.set(x, -1, 0);
          s.scene.add(top); s.scene.add(bot);
        }
        chromosome(-1.5, 0x6366f1, 0x6366f1, false);
        chromosome(1.5, 0xf59e0b, 0xf59e0b, crossed);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagBefore = null, diagAfter = null;
      function initDiagBefore() { const c = el('diag-before'); if (!c) throw new Error('no container'); diagBefore = chromScene(c, false); }
      function initDiagAfter() { const c = el('diag-after'); if (!c) throw new Error('no container'); diagAfter = chromScene(c, true); }

      function boot() {
        try { update(); } catch (e) { console.error('[recombination-frequency] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[recombination-frequency] charts failed', e); }
        if (window.THREE) {
          try { initDiagBefore(); } catch (e) { console.error('[recombination-frequency] before diagram failed', e); }
          try { initDiagAfter(); } catch (e) { console.error('[recombination-frequency] after diagram failed', e); }
        }
        mountResize([diagBefore, diagAfter]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
