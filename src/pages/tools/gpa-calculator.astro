---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'GPA Calculator';
const description =
  'Free GPA calculator. Enter your courses, grades and credit hours to calculate your grade ' +
  'point average on a 4.0 scale. Add as many courses as you need.';
const intro =
  'Add your courses with their letter grade and credit hours to calculate your weighted GPA on a 4.0 scale.';
const category = { id: 'everyday', name: 'Everyday' };
const faqs = [
  { q: 'How is GPA calculated?', a: 'Each letter grade is worth grade points (A = 4.0, A- = 3.7, B+ = 3.3, B = 3.0, etc.). We multiply each course\'s points by its credit hours, add them all up, and divide by the total credit hours.' },
  { q: 'What is a good GPA on the 4.0 scale?', a: 'Generally, 3.0 (B average) is considered good, 3.5 (B+ average) is very good, and 4.0 (A average) is excellent. Requirements vary by program and institution.' },
  { q: 'Can I add more courses?', a: 'Yes — click the "Add course" button for as many rows as you need. You can also remove any row with the X button.' },
  { q: 'Does this work for plus/minus grading?', a: 'Yes — the calculator includes A, A-, B+, B, B-, C+, C, C-, D+, D, D- and F, covering standard plus/minus systems used by most US colleges.' },
  { q: 'What if my school uses a different GPA scale?', a: 'This calculator uses the standard US 4.0 scale. If your school uses a different scale (e.g. 5.0), your official GPA may differ slightly.' },
  { q: 'What is a weighted vs unweighted GPA?', a: 'Unweighted GPA treats all courses equally (max 4.0). Weighted GPA gives extra points for honors, AP or IB courses (max 5.0). This calculator computes unweighted GPA.' },
  { q: 'How do I calculate my cumulative GPA?', a: 'Add all courses from all semesters with their grades and credits. The calculator combines everything into a single weighted average.' },
  { q: 'Can I save or print my results?', a: 'Not directly — but you can take a screenshot or copy the displayed GPA and credit total for your records.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-2 grid grid-cols-[1fr_auto_auto] gap-2 text-xs font-semibold uppercase tracking-wide text-slate-400">
      <span>Course (optional)</span><span class="w-28 text-center">Grade</span><span class="w-20 text-center">Credits</span>
    </div>
    <div id="rows" class="space-y-2"></div>
    <button id="add" class="mt-3 rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">+ Add course</button>

    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Your GPA</div>
      <div id="gpa" class="mt-1 text-3xl font-bold">—</div>
      <div id="credits" class="mt-1 text-sm opacity-80"></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How GPA calculation works</h2>
    <p class="mt-2 text-slate-600">
      GPA is calculated as a weighted average: each course's grade points are multiplied by its credit hours, the products are summed, and the total is divided by the sum of all credit hours. The formula is <code>GPA = Σ(GradePoint × Credits) ÷ Σ(Credits)</code>.
    </p>
    <p class="mt-3 text-slate-600">
      Our calculator uses the standard US 4.0 scale where A = 4.0, A- = 3.7, B+ = 3.3, B = 3.0, down to F = 0.0. A course with more credit hours has a proportionally larger impact on your GPA. This weighted approach means a B in a 4-credit course affects your GPA more than an A in a 1-credit course.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Courses: Biology (A, 4 credits), Math (B+, 3 credits), English (A-, 3 credits)</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Points:</span> <span class="text-slate-600">(4.0×4) + (3.3×3) + (3.7×3) = 16.0 + 9.9 + 11.1 = 37.0</span></div>
        <div><span class="font-medium text-slate-700">Credits:</span> <span class="text-slate-600">4 + 3 + 3 = 10</span></div>
        <div><span class="font-medium text-slate-700">GPA:</span> <span class="text-slate-600">37.0 ÷ 10 = <strong>3.70</strong></span></div>
        <div><span class="font-medium text-slate-700">Grade:</span> <span class="text-slate-600">A- average — excellent standing</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different GPA ranges mean</h2>
    <p class="mt-2 text-slate-600">Where your GPA falls on the 4.0 scale tells you a lot about your academic standing and what opportunities lie ahead.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">3.5 – 4.0 (Excellent)</span><span class="text-slate-400">Dean's list, top graduate schools</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:87.5%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">3.0 – 3.4 (Good)</span><span class="text-slate-400">Most grad programs, many scholarships</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:75%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">2.5 – 2.9 (Satisfactory)</span><span class="text-slate-400">Many employers, some grad options</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:62.5%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">2.0 – 2.4 (Passing)</span><span class="text-slate-400">Minimum for most programs</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Below 2.0 (At risk)</span><span class="text-slate-400">Academic probation</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:40%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎓</span>
      <h3 class="mt-2 font-semibold text-slate-900">College Students</h3>
      <p class="mt-1 text-sm text-slate-600">Track your semester GPA, see if you meet the dean's list threshold, and plan what grades you need next term to raise your cumulative average.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">High School Students</h3>
      <p class="mt-1 text-sm text-slate-600">Monitor your GPA throughout high school to stay on track for college admissions, scholarship eligibility, and honors programs.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📋</span>
      <h3 class="mt-2 font-semibold text-slate-900">Graduate Applicants</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate your cumulative GPA for graduate school applications and compare against program minimums and competitive averages.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Academic Advisors</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly compute a student's GPA during advising sessions to discuss academic standing, course load adjustments, and graduation requirements.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Letter Grade</th><th class="p-3">Grade Points</th><th class="p-3">Percentage Range</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">A</td><td class="p-3">4.0</td><td class="p-3">93–100%</td></tr>
        <tr><td class="p-3 font-medium">A-</td><td class="p-3">3.7</td><td class="p-3">90–92%</td></tr>
        <tr><td class="p-3 font-medium">B+</td><td class="p-3">3.3</td><td class="p-3">87–89%</td></tr>
        <tr><td class="p-3 font-medium">B</td><td class="p-3">3.0</td><td class="p-3">83–86%</td></tr>
        <tr><td class="p-3 font-medium">B-</td><td class="p-3">2.7</td><td class="p-3">80–82%</td></tr>
        <tr><td class="p-3 font-medium">C+</td><td class="p-3">2.3</td><td class="p-3">77–79%</td></tr>
        <tr><td class="p-3 font-medium">C</td><td class="p-3">2.0</td><td class="p-3">73–76%</td></tr>
        <tr><td class="p-3 font-medium">C-</td><td class="p-3">1.7</td><td class="p-3">70–72%</td></tr>
        <tr><td class="p-3 font-medium">D+</td><td class="p-3">1.3</td><td class="p-3">67–69%</td></tr>
        <tr><td class="p-3 font-medium">D</td><td class="p-3">1.0</td><td class="p-3">63–66%</td></tr>
        <tr><td class="p-3 font-medium">D-</td><td class="p-3">0.7</td><td class="p-3">60–62%</td></tr>
        <tr><td class="p-3 font-medium">F</td><td class="p-3">0.0</td><td class="p-3">Below 60%</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the GPA calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Add your courses</h3>
        <p class="mt-1 text-sm text-slate-600">Enter each course name (optional), select its letter grade, and type in the credit hours. Click "Add course" to add more rows.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check your GPA</h3>
        <p class="mt-1 text-sm text-slate-600">Your weighted GPA and total credit hours update automatically at the bottom as you enter or change each row.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Plan ahead</h3>
        <p class="mt-1 text-sm text-slate-600">Use "what if" scenarios — add hypothetical grades for future courses to see what you'd need to reach a target GPA.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate GPA calculation</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Include all courses</h3>
        <p class="mt-1 text-sm text-slate-600">Enter every course from the term, even pass/fail ones — enter the grade you received or leave it out if it doesn't affect GPA.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Verify credit hours</h3>
        <p class="mt-1 text-sm text-slate-600">Credit hours vary between courses (commonly 3 or 4). Double-check each course's hours — they significantly affect the weighted average.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Know your school's scale</h3>
        <p class="mt-1 text-sm text-slate-600">Some high schools use a 5.0 scale for honors courses. This calculator uses the standard 4.0 scale. Check with your institution for their specific weighting.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why GPA accuracy matters</h2>
    <p class="mt-2 text-slate-600">
      Your GPA is one of the most important numbers in your academic life. It determines eligibility for scholarships, admission to graduate programs, honors society membership, and even some job interviews. A small miscalculation of 0.1 points can push you below a cutoff for a competitive program or scholarship. Many students rely on rough mental averages that fail to account for the weighted nature of GPA. A B in a 4-credit science course pulls your GPA down three times as much as an A in a 1-credit elective, so understanding the weighted calculation is essential for accurate self-assessment.
    </p>
    <p class="mt-3 text-slate-600">
      This calculator uses the standard 4.0 scale with plus and minus grades, matching the system used by most US colleges and universities. By entering your actual letter grades and credit hours, you receive a GPA that reflects your transcript exactly. The what-if capability is invaluable for planning. If your current GPA is 3.2 and you want to reach 3.5, you can add hypothetical grades for next semester to see what combination of As and Bs gets you to your target. Without this insight, students often set grade goals without knowing whether they are realistic or achievable.
    </p>
    <p class="mt-3 text-slate-600">
      Academic advisors use GPA calculations to guide students on course load, major selection, and graduation planning. A student on academic probation needs to know exactly how many credit hours of A and B grades are required to raise their GPA above the 2.0 threshold. Graduate school applicants calculate their cumulative GPA to compare against program minimums, often discovering that a few low grades from early semesters have a lingering effect that requires explanation in their application essays.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const points = { 'A': 4, 'A-': 3.7, 'B+': 3.3, 'B': 3, 'B-': 2.7, 'C+': 2.3, 'C': 2, 'C-': 1.7, 'D+': 1.3, 'D': 1, 'D-': 0.7, 'F': 0 };
    const rows = el('rows');

    function addRow() {
      const div = document.createElement('div');
      div.className = 'grid grid-cols-[1fr_auto_auto] gap-2 items-center';
      const opts = Object.keys(points).map((g) => `<option value="${g}">${g}</option>`).join('');
      div.innerHTML =
        `<input type="text" placeholder="e.g. Biology" class="rounded-lg border border-slate-300 p-2.5 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">` +
        `<select class="gpa-grade w-28 rounded-lg border border-slate-300 p-2.5 text-sm outline-none focus:border-indigo-400">${opts}</select>` +
        `<div class="flex items-center gap-1"><input type="number" min="0" step="0.5" value="3" class="gpa-cred w-16 rounded-lg border border-slate-300 p-2.5 text-center text-sm outline-none focus:border-indigo-400"><button class="del rounded p-1 text-red-500 hover:bg-red-50" title="Remove">✕</button></div>`;
      rows.appendChild(div);
      div.querySelector('.del').addEventListener('click', () => { div.remove(); update(); });
      div.querySelectorAll('select, input').forEach((i) => i.addEventListener('input', update));
      update();
    }

    function update() {
      let totalPts = 0, totalCred = 0;
      rows.querySelectorAll('.grid').forEach((row) => {
        const g = row.querySelector('.gpa-grade').value;
        const c = parseFloat(row.querySelector('.gpa-cred').value) || 0;
        totalPts += points[g] * c; totalCred += c;
      });
      el('gpa').textContent = totalCred ? (totalPts / totalCred).toFixed(2) : '—';
      el('credits').textContent = totalCred ? `${totalCred} total credit hours` : '';
    }

    el('add').addEventListener('click', addRow);
    addRow(); addRow(); addRow();
  </script>
</ToolLayout>
