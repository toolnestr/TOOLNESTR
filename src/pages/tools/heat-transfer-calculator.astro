---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Heat Transfer Calculator';
const description = 'Heat transfer calculator with a live 3D block and charts. Solve Q = mcΔT for heat energy, mass, specific heat, or temperature change, with worked examples.';
const intro = 'Find the heat energy needed to change a material’s temperature with Q = m × c × ΔT. A live 3D block and charts show why some materials heat up faster than others.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is specific heat capacity?', a: 'Specific heat capacity (c) is the amount of energy, in joules, needed to raise the temperature of 1 kg of a substance by 1 K (or 1°C). It is a property of the material — water is 4186 J/(kg·K), while metals like copper (385) and iron (449) are much lower.' },
  { q: 'Why does water have such a high specific heat capacity?', a: 'Water molecules form extensive hydrogen bonds. Raising water’s temperature means giving molecules enough energy to move faster despite these bonds constantly forming and breaking, which takes much more energy per degree than in metals, where atoms are held by simpler, more uniform bonding.' },
  { q: 'What is the difference between heat and temperature?', a: 'Heat (Q) is energy transferred between objects, measured in joules. Temperature is a measure of the average kinetic energy of particles in a substance, measured in kelvin or °C. Two objects can be at the same temperature but hold very different amounts of thermal energy if their mass or specific heat differs.' },
  { q: 'Does Q = mcΔT apply during a phase change, like boiling or melting?', a: 'No. Q = mcΔT only applies to "sensible heat" — heating or cooling within a single phase (solid, liquid, or gas), where temperature actually changes. During a phase change (melting, freezing, boiling, condensing) temperature stays constant while energy is absorbed or released as latent heat, calculated instead with Q = mL, using the substance’s latent heat of fusion or vaporization.' },
  { q: 'Can Q be negative?', a: 'Yes. A negative Q simply means heat is released rather than absorbed — for example, when ΔT is negative because the final temperature is lower than the initial temperature, as in a cooling object.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Heat Transfer Calculator',
  description: 'Solve Q = m × c × ΔT for heat energy, mass, specific heat capacity, or temperature change.',
  steps: [
    { name: 'Pick a material or enter custom c', text: 'Choose a preset specific heat capacity, or type your own value.' },
    { name: 'Enter the known values', text: 'Fill in any two of mass, ΔT, and Q — leave the value you want to solve for blank.' },
    { name: 'Read the result', text: 'The missing quantity solves instantly, and the 3D block updates its color.' },
  ],
};

const formulas = [
  { expr: 'Q = m × c × ΔT', note: 'heat energy from mass, specific heat &amp; temperature change' },
  { expr: 'ΔT = T<sub>final</sub> − T<sub>initial</sub>', note: 'temperature change (K or °C — same magnitude)' },
  { expr: 'm = Q / (c × ΔT)', note: 'rearranged for mass, or c = Q / (m × ΔT)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — heating water', tone: 'slate',
    given: '2.0 kg of water is heated from 20°C to 80°C. Specific heat of water c = 4186 J/(kg·K). Find the heat energy required.',
    rows: [
      { label: 'Temperature change:', value: 'ΔT = 80 − 20 = 60 K' },
      { label: 'Heat energy:', value: 'Q = m × c × ΔT = 2.0 × 4186 × 60' },
      { label: 'Result:', value: 'Q = 502,320 J ≈ 502.3 kJ', full: true },
    ],
  },
  {
    title: 'Worked example 2 — cooling aluminum', tone: 'amber',
    given: '0.5 kg of aluminum cools from 100°C to 25°C. Specific heat of aluminum c = 897 J/(kg·K). Find the heat energy transferred.',
    rows: [
      { label: 'Temperature change:', value: 'ΔT = 25 − 100 = −75 K' },
      { label: 'Heat energy:', value: 'Q = m × c × ΔT = 0.5 × 897 × (−75)' },
      { label: 'Result:', value: 'Q = −33,637.5 J', full: true },
    ],
    note: 'The negative sign means 33,637.5 J of heat is released by the aluminum as it cools, not absorbed.',
  },
];

const comparison = {
  heading: 'Specific heat capacity of common materials',
  note: 'Higher c means a material needs more energy to change temperature by the same amount — this is why water resists temperature swings so well.',
  headers: [{ label: 'Material' }, { label: 'c — J/(kg·K)' }, { label: 'Energy for 1 kg, ΔT = 1 K' }],
  rows: [
    ['Water (liquid)', '4186', '4186 J'],
    ['Steam (water vapor)', '2010', '2010 J'],
    ['Ice (solid water)', '2100', '2100 J'],
    ['Aluminum', '897', '897 J'],
    ['Iron', '449', '449 J'],
    ['Copper', '385', '385 J'],
  ],
  highlightIndex: 0,
  footnote: 'Values are standard reference specific heat capacities at typical conditions, rounded to 3–4 significant figures.',
};

const realWorld = [
  { emoji: '🍳', title: 'Cooking science', body: 'Water’s high specific heat is why a pot of water takes so long to boil compared to an empty metal pan heating up — the same burner output raises the pan’s temperature far faster because metals have much lower c.' },
  { emoji: '🌊', title: 'Ocean climate moderation', body: 'Oceans absorb and release enormous amounts of heat with only small temperature changes, which is why coastal regions have milder, more stable climates than inland areas at the same latitude.' },
  { emoji: '🚗', title: 'Engine cooling systems', body: 'Car radiators use water (or water-glycol mixtures) as a coolant specifically because its high specific heat lets it absorb large amounts of engine heat without its own temperature rising too quickly.' },
  { emoji: '🧱', title: 'Insulation material selection', body: 'Engineers pick building and insulation materials partly based on specific heat and thermal mass, balancing how quickly a material heats up or cools down against how well it resists heat flow.' },
];

const misconceptions = [
  { claim: '"Heat and temperature are the same thing."', truth: 'Heat is energy transferred between objects (joules); temperature is a measure of average particle kinetic energy (kelvin or °C). A large mass of water at 40°C holds far more thermal energy than a small nail at 40°C, even though they are the same temperature.' },
  { claim: '"All materials heat up at the same rate for the same energy input."', truth: 'False — specific heat capacity varies widely between materials. Water needs about 11 times more energy per kilogram per degree than copper does, so the same heat input raises copper’s temperature far more than water’s.' },
  { claim: '"Q = mcΔT works for melting ice or boiling water too."', truth: 'It does not. During a phase change, temperature stays constant while energy goes into breaking or forming molecular bonds. That energy is latent heat, Q = mL, a completely separate calculation from sensible heat.' },
  { claim: '"A negative Q means the calculation is wrong."', truth: 'A negative Q is a valid result — it simply indicates heat leaving the object (cooling) rather than entering it (heating), because the final temperature is lower than the initial temperature.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — Chapter 1, Temperature and Heat (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/1-3-heat-capacity-and-equilibrium-temperature" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 18, Temperature, Heat, and the First Law of Thermodynamics.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — specific heat capacity and calorimetry.' },
];
const sourcesNote = 'Q = m × c × ΔT applies to sensible heat (within one phase) only. Specific heat values are standard reference figures; results are rounded for display.';

const howToUse = [
  { title: 'Choose a material', body: 'Pick a preset (water, aluminum, copper, iron, ice, steam) or select "Custom" to enter your own c value.' },
  { title: 'Fill in two of three values', body: 'Enter mass, ΔT, and/or Q — leave one blank and it solves automatically.' },
  { title: 'Watch the block change color', body: 'Use the sliders to see the block shift from blue (cool) to red (hot) as ΔT changes.' },
];

const related = [
  { href: '/tools/mechanical-efficiency-calculator', emoji: '⚙️', title: 'Mechanical Efficiency Calculator', desc: 'η = output/input × 100% — from work or power.' },
  { href: '/tools/kinetic-energy-calculator', emoji: '🏃', title: 'Kinetic Energy Calculator', desc: 'KE = ½mv² — solve for any variable.' },
  { href: '/tools/potential-energy-calculator', emoji: '⛰️', title: 'Potential Energy Calculator', desc: 'PE = mgh — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="the heat energy needed to change a material's temperature depends on how much of it there is, what it's made of, and how big the temperature change is — Q = m × c × ΔT."
  howIntro="Rearranged, the same equation solves any missing quantity: m = Q / (cΔT) gives the mass that a known amount of heat can warm by a known amount, and c = Q / (mΔT) lets you back out an unknown material's specific heat capacity from a measurement. A negative Q or ΔT just means heat is flowing out rather than in."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where specific heat actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Material</span>
        <select id="material" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="4186">Water — 4186 J/(kg·K)</option>
          <option value="897">Aluminum — 897 J/(kg·K)</option>
          <option value="385">Copper — 385 J/(kg·K)</option>
          <option value="449">Iron — 449 J/(kg·K)</option>
          <option value="2100">Ice — 2100 J/(kg·K)</option>
          <option value="2010">Steam — 2010 J/(kg·K)</option>
          <option value="custom">Custom…</option>
        </select>
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Specific heat capacity (c)</span>
        <input id="c" type="number" step="any" value="4186" placeholder="J/(kg·K)" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="m" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature change (ΔT)</span>
        <input id="dT" type="number" step="any" placeholder="K or °C" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Heat energy (Q)</span>
        <input id="Q" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Heat energy</div><div id="r-Q" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-m" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">ΔT</div><div id="r-dT" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="ht-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D block + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D heat block</h2>
      <p class="mt-1 text-sm text-slate-500">Set the mass, ΔT, and material; the block's color shifts from blue (cool) to red (hot) and its size reflects mass. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-3">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Mass <span id="out-bm" class="font-mono text-blue-600">1.00 kg</span></span>
          <input id="b-m" type="range" min="0.1" max="5" step="0.05" value="1" class="mt-2 w-full accent-blue-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">ΔT <span id="out-bdt" class="font-mono text-blue-600">50 K</span></span>
          <input id="b-dt" type="range" min="-100" max="100" step="1" value="50" class="mt-2 w-full accent-blue-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Material</span>
          <select id="b-mat" class="mt-2 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400">
            <option value="4186">Water</option>
            <option value="897">Aluminum</option>
            <option value="385">Copper</option>
            <option value="449">Iron</option>
          </select>
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-blue-50 p-3 text-center text-sm text-blue-700">Heat energy Q = <span id="out-bq" class="font-mono font-bold">—</span></div>
      <div id="block3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="block3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Heat transfer graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Heat energy Q vs ΔT (fixed mass &amp; material) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-qdt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Q needed for the same mass &amp; ΔT, by material</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mat"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const MATERIALS = { 4186: 'Water', 897: 'Aluminum', 385: 'Copper', 449: 'Iron', 2100: 'Ice', 2010: 'Steam' };

      // ---- calculator ----
      function onMaterialChange() {
        const v = el('material').value;
        if (v !== 'custom') el('c').value = v;
      }
      function onCInput() {
        const c = el('c').value;
        const match = Object.keys(MATERIALS).find((k) => k === c);
        el('material').value = match || 'custom';
      }
      function update() {
        el('ht-err').textContent = '';
        ['r-Q', 'r-m', 'r-dT'].forEach((id) => (el(id).textContent = '—'));
        const c = parseFloat(el('c').value);
        const m = parseFloat(el('m').value);
        const dT = parseFloat(el('dT').value);
        const Q = parseFloat(el('Q').value);
        if (isNaN(c) || c <= 0) { el('ht-err').textContent = 'Specific heat capacity must be a positive number.'; return; }
        const filled = [!isNaN(m), !isNaN(dT), !isNaN(Q)];
        if (filled.filter(Boolean).length < 2) return;
        let rm = m, rdT = dT, rQ = Q;
        if (filled[0] && filled[1]) { rQ = m * c * dT; }
        else if (filled[0] && filled[2]) { if (m === 0) { el('ht-err').textContent = 'Mass cannot be zero when solving for ΔT.'; return; } rdT = Q / (m * c); }
        else if (filled[1] && filled[2]) { if (dT === 0) { el('ht-err').textContent = 'ΔT cannot be zero when solving for mass.'; return; } rm = Q / (c * dT); }
        if (!isNaN(rQ)) el('r-Q').textContent = fmt(rQ) + ' J';
        if (!isNaN(rm)) el('r-m').textContent = fmt(rm) + ' kg';
        if (!isNaN(rdT)) el('r-dT').textContent = fmt(rdT) + ' K';
      }
      el('material').addEventListener('change', onMaterialChange);
      el('material').addEventListener('change', update);
      el('c').addEventListener('input', onCInput);
      ['c', 'm', 'dT', 'Q'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let block = null;
      function bState() {
        const m = parseFloat(el('b-m').value);
        const dT = parseFloat(el('b-dt').value);
        const c = parseFloat(el('b-mat').value);
        return { m, dT, c, Q: m * c * dT };
      }
      function tempColor(dT) {
        // map dT in [-100,100] to a blue->red gradient
        const t = Math.max(0, Math.min(1, (dT + 100) / 200));
        const cold = { r: 0x38, g: 0xbd, b: 0xf8 }; // sky-400
        const hot = { r: 0xef, g: 0x44, b: 0x44 };  // red-500
        const r = Math.round(cold.r + (hot.r - cold.r) * t);
        const g = Math.round(cold.g + (hot.g - cold.g) * t);
        const b = Math.round(cold.b + (hot.b - cold.b) * t);
        return (r << 16) | (g << 8) | b;
      }
      function onB() {
        const s = bState();
        el('out-bm').textContent = s.m.toFixed(2) + ' kg';
        el('out-bdt').textContent = s.dT.toFixed(0) + ' K';
        el('out-bq').textContent = fmt(s.Q) + ' J';
        try { if (block) block.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-m').addEventListener('input', onB);
      el('b-dt').addEventListener('input', onB);
      el('b-mat').addEventListener('change', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.qdt = new Chart(el('chart-qdt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Q', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'ΔT (K)' } }, y: { title: { display: true, text: 'Q (J)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.mat = new Chart(el('chart-mat'), {
          type: 'bar',
          data: { labels: ['Water', 'Aluminum', 'Copper', 'Iron'], datasets: [{ label: 'Q (J)', data: [0, 0, 0, 0], backgroundColor: ['#38bdf8', '#94a3b8', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Material' } }, y: { title: { display: true, text: 'Q (J)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L = [], D = [];
        for (let dt = -100; dt <= 100.001; dt += 10) { L.push(dt.toFixed(0)); D.push(+(s.m * s.c * dt).toFixed(2)); }
        charts.qdt.data.labels = L; charts.qdt.data.datasets[0].data = D; charts.qdt.update();
        const cs = [4186, 897, 385, 449];
        charts.mat.data.datasets[0].data = cs.map((c) => +(s.m * c * s.dT).toFixed(2));
        charts.mat.update();
      }

      // ---- interactive block ----
      function initBlock() {
        const cvs = el('block3d'); if (!cvs) throw new Error('no block canvas');
        const s = makeScene(cvs, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        const mat = new THREE.MeshStandardMaterial({ color: 0x38bdf8, roughness: 0.35, metalness: 0.1 });
        let mesh = new THREE.Mesh(new THREE.BoxGeometry(2, 2, 2), mat);
        s.scene.add(mesh);
        function update(state) {
          const side = 1.4 + Math.min(2.4, Math.pow(Math.max(0.05, state.m), 1 / 3) * 1.4);
          mesh.scale.set(side / 2, side / 2, side / 2);
          mat.color.setHex(tempColor(state.dT));
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        block = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { onMaterialChange(); } catch (e) {}
        try { update(); } catch (e) { console.error('[heat-transfer] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[heat-transfer] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[heat-transfer] charts failed', e); }
        if (window.THREE) {
          try { initBlock(); } catch (e) { console.error('[heat-transfer] block failed', e); el('block3d-fallback').classList.remove('hidden'); }
        } else { el('block3d-fallback').classList.remove('hidden'); }
        mountResize([block]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
