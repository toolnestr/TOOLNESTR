---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Belt Size Calculator';
const description = 'Find the right belt size from your pants waist size or waist measurement, in inches and centimeters.';
const intro = 'Convert a pants waist size or waist measurement into the correct belt size.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why is belt size bigger than pants waist size?', a: 'Belt size is measured to the middle hole, not the very end of the strap, and needs to sit over the waistband rather than exactly at the body — adding roughly 2 inches to your pants waist size accounts for both, which is the standard rule most belt makers use.' },
  { q: 'What if I wear my pants below my natural waist?', a: 'Measure where the pants actually sit, not your natural waistline, since the belt needs to fit the waistband location, not an anatomical reference point.' },
  { q: 'Do women\'s belts follow the same rule?', a: 'Yes, the same "waist plus 2 inches" rule applies regardless of gender, since it is based on how a belt physically sits over a waistband, not on a gendered sizing scale.' },
  { q: 'What if I am between two belt sizes?', a: 'Choose the larger size — a belt that is slightly too big can be buckled tighter using an inner hole, while a belt that is too small cannot be worn at all.' },
];
const howTo = {
  name: 'How to find your belt size',
  steps: [
    { name: 'Find your waist size', text: 'Use your known pants waist size, or measure your waist with a tape measure where your pants normally sit.' },
    { name: 'Add the belt allowance', text: 'The calculator adds approximately 2 inches to account for the waistband and buckle.' },
    { name: 'Read your belt size', text: 'Your recommended belt size appears in both inches and centimeters.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Inches', 'Centimeters'].map((d) => (
        <button data-unit={d} class="unit-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Pants waist size / waist measurement</span>
      <input id="waist" type="number" step="any" placeholder="e.g. 34" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">Belt size (in)</div><div id="r-in" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Belt size (cm)</div><div id="r-cm" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="bsc-title bsc-desc">
      <title id="bsc-title">Belt strap with buckle and adjustment holes</title>
      <desc id="bsc-desc">A belt strap diagram showing the buckle end, the middle sizing hole, and the extra length beyond it</desc>
      <rect x="80" y="90" width="600" height="30" rx="6" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <rect x="60" y="80" width="40" height="50" rx="6" fill="#c026d3" />
      <circle cx="420" cy="105" r="6" fill="#fff" stroke="#c026d3" stroke-width="1.5" />
      <circle cx="450" cy="105" r="6" fill="#fff" stroke="#c026d3" stroke-width="1.5" />
      <circle cx="480" cy="105" r="6" fill="#fff" stroke="#c026d3" stroke-width="1.5" />
      <line x1="100" y1="140" x2="450" y2="140" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="275" y="160" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Waist size (to middle hole)</text>
      <text x="580" y="160" text-anchor="middle" font-size="12" fill="#94a3b8" font-family="system-ui,sans-serif">Belt size = waist + 2&Prime;</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Belt size is measured to the middle adjustment hole, not the strap tip</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How belt sizing works</h2>
    <p class="mt-2 text-slate-600">
      A belt's labeled size is the length from the buckle to the middle hole, not to the end of the strap — the extra length past the middle hole exists so the belt can be worn a notch looser or tighter without running out of strap. Because of this, a belt sized exactly to your waist measurement would sit too small once buckled at the middle hole, which is why the industry-standard rule adds roughly 2 inches (about 5 cm) to your pants waist size or measured waist.
    </p>
    <p class="mt-3 text-slate-600">
      This calculator applies that same 2-inch allowance whether you enter a known pants waist size or a raw tape-measure waist reading, since both represent the same underlying waistband circumference the belt needs to close comfortably around.
    </p>
    <p class="mt-3 text-xs text-slate-400">The waist-plus-2-inch rule is the standard convention used by leather goods and belt manufacturers across the menswear and womenswear industry.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">Someone wears a size 34 pants waist and wants to buy a new leather belt.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Pants waist:</span> <span class="text-slate-600">34 in</span></div>
        <div><span class="font-medium text-slate-700">Belt allowance:</span> <span class="text-slate-600">+2 in</span></div>
        <div><span class="font-medium text-slate-700">Belt size:</span> <span class="text-slate-600"><strong>36 in</strong></span></div>
        <div><span class="font-medium text-slate-700">In centimeters:</span> <span class="text-slate-600">36 × 2.54 ≈ <strong>91.4 cm</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Gift-buying is one of the most common reasons people reach for a belt-sizing rule rather than trying one on — knowing someone's pants size (from a tag inside a jacket, or from asking casually) is much easier than getting an exact waist measurement, and the plus-2 rule turns that indirect information into a workable belt size.
    </p>
    <p class="mt-3 text-slate-600">
      Weight fluctuation is the other common trigger: someone who has changed pants size since their last belt purchase often forgets the belt needs resizing too, and ends up buckling at the very last hole (too tight) or the very first hole (too loose) instead of buying a belt sized correctly for their current waist.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Belt size should exactly match pants waist size." <strong class="text-slate-900">It shouldn't.</strong> A belt sized identically to the waist would only close at its very last hole, leaving no adjustment room — the plus-2-inch allowance exists specifically to avoid that.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All brands measure belt length the same way." <strong class="text-slate-900">Not universally.</strong> Some brands measure total strap length instead of buckle-to-middle-hole, so always check the specific brand's measuring method for uncommon or designer belts before assuming the plus-2 rule applies exactly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/clothing-size-converter/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
      <a href="/tools/inseam-length-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Inseam Length Calculator</a>
      <a href="/tools/jacket-suit-size-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Jacket/Suit Size Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let unit = 'Inches';

    function update() {
      const v = parseFloat(el('waist').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const waistIn = unit === 'Centimeters' ? v / 2.54 : v;
      const beltIn = waistIn + 2;
      const beltCm = beltIn * 2.54;
      el('r-in').textContent = beltIn.toFixed(0) + ' in';
      el('r-cm').textContent = beltCm.toFixed(1) + ' cm';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.unit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.unit-btn').forEach((b) => {
          b.className = 'unit-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'unit-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        unit = btn.dataset.unit;
        update();
      });
    });

    el('waist').addEventListener('input', update);
    document.querySelector('.unit-btn').click();
  </script>
</ToolLayout>
