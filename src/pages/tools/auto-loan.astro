---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Auto Loan Calculator';
const description =
  'Free auto loan calculator. Work out your car loan monthly payment, total interest and total ' +
  'cost from the price, down payment, trade-in, sales tax, rate and term. Any currency.';
const intro =
  'Enter the vehicle price and loan details to see your monthly car payment, total interest and total cost.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'How is the loan amount calculated?', a: 'We add sales tax to the vehicle price, then subtract your down payment and any trade-in value. That’s the amount you finance.' },
  { q: 'What loan term should I choose?', a: 'Common car loans run 36–72 months. A longer term lowers the monthly payment but increases the total interest you pay.' },
  { q: 'Does it work in my currency?', a: 'Yes — choose your currency symbol. The math is the same everywhere.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Currency</span>
        <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option>$</option><option>€</option><option>£</option><option>₹</option><option>₨</option><option>¥</option><option>₦</option><option>A$</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Vehicle price</span>
        <input id="price" type="number" step="any" placeholder="25000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Down payment</span>
        <input id="down" type="number" step="any" placeholder="5000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Trade-in value (optional)</span>
        <input id="trade" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Sales tax % (optional)</span>
        <input id="tax" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Interest rate % / year</span>
        <input id="rate" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Loan term (months)</span>
        <input id="months" type="number" step="1" placeholder="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Monthly payment</div><div id="r-month" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Loan amount</div><div id="r-loan" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Total interest</div><div id="r-interest" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Total cost</div><div id="r-total" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this auto loan calculator</h2>
    <p class="mt-2 text-slate-600">
      Before you buy a car, it pays to know the real monthly cost. This calculator factors in your
      down payment, trade-in and sales tax to work out exactly what you’ll finance, your monthly
      payment, and how much interest you’ll pay over the life of the loan — so there are no
      surprises at the dealership.
    </p>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/mortgage-calculator" class="font-medium text-indigo-600 hover:underline">Mortgage Calculator</a>
      or <a href="/tools/emi-calculator" class="font-medium text-indigo-600 hover:underline">Loan / EMI Calculator</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const cur = el('cur');
    const fmt = (n) => cur.value + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    function update() {
      const price = parseFloat(el('price').value) || 0;
      const down = parseFloat(el('down').value) || 0;
      const trade = parseFloat(el('trade').value) || 0;
      const tax = parseFloat(el('tax').value) || 0;
      const rate = parseFloat(el('rate').value);
      const months = parseFloat(el('months').value);
      const loan = price * (1 + tax / 100) - down - trade;
      if (loan <= 0 || isNaN(rate) || isNaN(months) || months <= 0) { ['r-month', 'r-loan', 'r-interest', 'r-total'].forEach((id) => (el(id).textContent = '—')); return; }
      const r = rate / 100 / 12;
      const pmt = r === 0 ? loan / months : loan * r * Math.pow(1 + r, months) / (Math.pow(1 + r, months) - 1);
      el('r-month').textContent = fmt(pmt);
      el('r-loan').textContent = fmt(loan);
      el('r-interest').textContent = fmt(pmt * months - loan);
      el('r-total').textContent = fmt(pmt * months);
    }
    ['cur', 'price', 'down', 'trade', 'tax', 'rate', 'months'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
