---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Age in Seconds Calculator';
const description = 'Free online age in seconds calculator. Your exact age in seconds, minutes, hours, days, weeks, months and years — down to the second.';
const intro = 'Enter your birth date and time to see your exact age in every time unit from seconds to years.';
const category = { id: 'time-date', name: 'Time & Date' };
const faqs = [
  { q: 'How is age in seconds calculated?', a: 'Age in seconds is calculated by finding the exact difference between the current moment and the birth moment. The difference in milliseconds is divided by 1000 to get seconds.' },
  { q: 'Why does age in seconds matter?', a: 'It is a fascinating way to appreciate the passage of time. Knowing your age in seconds puts life into perspective — a 30-year-old has lived roughly 946 million seconds, and a 70-year-old about 2.2 billion seconds.' },
  { q: 'Are leap seconds included?', a: 'Leap seconds are not included in standard JavaScript Date calculations. Since 1972, 27 leap seconds have been added, so your exact age may be off by up to 27 seconds depending on the period.' },
  { q: 'How many seconds are in a year?', a: 'A common year has 31,536,000 seconds (365 × 24 × 60 × 60). A leap year has 31,622,400 seconds. The average year (accounting for leap years) is approximately 31,556,952 seconds.' },
  { q: 'What are dog years?', a: 'Dog years are a rough approximation of a dog\'s age relative to human years. The common rule of thumb is that the first year of a dog\'s life equals 15 human years, the second year equals 9, and each subsequent year equals 4-5 human years.' },
  { q: 'How many seconds old is the Earth?', a: 'The Earth is approximately 4.54 billion years old, which equals roughly 143 quadrillion seconds (1.43 × 10^17 seconds).' },
  { q: 'Can I calculate age in seconds for someone else?', a: 'Yes, simply enter their birth date and time. The calculator works for anyone\'s age at the current moment.' },
  { q: 'Do I need to enter the time of birth?', a: 'Time of birth is optional. If not provided, midnight (00:00) is assumed. For the most precise result, enter the exact time of birth.' },
  { q: 'How often does the display update?', a: 'The display updates every second to show your age in real-time. You can watch the seconds increase as you stay on the page.' },
  { q: 'What is the 100-year life progress bar?', a: 'The progress bar shows what percentage of a 100-year lifespan you have lived. For example, a 25-year-old has lived 25% of 100 years, represented as a progress bar.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="space-y-3">
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div>
          <label class="block text-sm font-medium text-slate-700" for="ais-dob">Date of birth</label>
          <input id="ais-dob" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700" for="ais-tob">Time of birth (optional)</label>
          <input id="ais-tob" type="time" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700" for="ais-tz">Timezone</label>
          <select id="ais-tz" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></select>
        </div>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Seconds</div><div id="ais-seconds" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-emerald-600 p-4 text-center text-white"><div class="text-xs opacity-80">Minutes</div><div id="ais-minutes" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-violet-600 p-4 text-center text-white"><div class="text-xs opacity-80">Hours</div><div id="ais-hours" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-amber-600 p-4 text-center text-white"><div class="text-xs opacity-80">Days</div><div id="ais-days" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Weeks</div><div id="ais-weeks" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Months</div><div id="ais-months" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Years</div><div id="ais-years" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Dog Years</div><div id="ais-dog" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-4 rounded-xl bg-slate-50 p-4">
      <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Next birthday in</span><span id="ais-bday" class="text-slate-600">—</span></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Life lived percentage</h2>
    <div class="mt-3">
      <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Progress through 100-year life</span><span id="ais-life-pct-label" class="text-slate-400">0.0%</span></div>
      <div class="mt-1 h-4 w-full rounded-full bg-slate-100"><div id="ais-life-bar" class="h-4 rounded-full bg-indigo-500 transition-all" style="width:0%"></div></div>
    </div>
    <p class="mt-2 text-xs text-slate-400">Based on an estimated 100-year life expectancy. Move the slider to adjust.</p>
    <input id="ais-life-expect" type="range" min="50" max="120" value="100" step="1" class="mt-2 w-full" />
    <div class="text-center text-sm text-slate-500">Life expectancy: <span id="ais-life-expect-label">100</span> years</div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🤔</span>
      <h3 class="mt-2 font-semibold text-slate-900">Curious Person</h3>
      <p class="mt-1 text-sm text-slate-600">Ever wondered exactly how long you have been alive? See your age in every time unit for a fascinating perspective on your life.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👶</span>
      <h3 class="mt-2 font-semibold text-slate-900">Parent</h3>
      <p class="mt-1 text-sm text-slate-600">Track your child's age down to the second. Perfect for baby books, milestone tracking, and celebrating precise age anniversaries.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Use age in seconds as a math teaching tool. Help students understand large numbers, unit conversion, and the scale of time.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎂</span>
      <h3 class="mt-2 font-semibold text-slate-900">Birthday Celebrant</h3>
      <p class="mt-1 text-sm text-slate-600">See how many seconds old you are on your birthday. A fun fact to share at parties and celebrate your exact age.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Milestone ages in seconds</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead><tr class="border-b border-slate-200 text-slate-500"><th class="pb-2 pr-4 font-medium">Age</th><th class="pb-2 pr-4 font-medium">Seconds (approx)</th><th class="pb-2 pr-4 font-medium">Minutes</th><th class="pb-2 font-medium">Hours</th></tr></thead>
        <tbody class="text-slate-700">
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">1 year</td><td class="py-2 pr-4 font-mono">31,536,000</td><td class="py-2 pr-4 font-mono">525,600</td><td class="py-2 font-mono">8,760</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">5 years</td><td class="py-2 pr-4 font-mono">157,680,000</td><td class="py-2 pr-4 font-mono">2,628,000</td><td class="py-2 font-mono">43,800</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">10 years</td><td class="py-2 pr-4 font-mono">315,360,000</td><td class="py-2 pr-4 font-mono">5,256,000</td><td class="py-2 font-mono">87,600</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">18 years</td><td class="py-2 pr-4 font-mono">567,648,000</td><td class="py-2 pr-4 font-mono">9,460,800</td><td class="py-2 font-mono">157,680</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">21 years</td><td class="py-2 pr-4 font-mono">662,256,000</td><td class="py-2 pr-4 font-mono">11,037,600</td><td class="py-2 font-mono">183,960</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">30 years</td><td class="py-2 pr-4 font-mono">946,080,000</td><td class="py-2 pr-4 font-mono">15,768,000</td><td class="py-2 font-mono">262,800</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">50 years</td><td class="py-2 pr-4 font-mono">1,576,800,000</td><td class="py-2 pr-4 font-mono">26,280,000</td><td class="py-2 font-mono">438,000</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">100 years</td><td class="py-2 pr-4 font-mono">3,153,600,000</td><td class="py-2 pr-4 font-mono">52,560,000</td><td class="py-2 font-mono">876,000</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the age in seconds calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter birth details</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in date of birth, time (optional), and timezone for precise calculation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Watch it tick</h3>
        <p class="mt-1 text-sm text-slate-600">The display updates every second, showing your age in real-time across all units.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Explore the data</h3>
        <p class="mt-1 text-sm text-slate-600">Check dog years, next birthday, and adjust life expectancy for the progress bar.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Age calculation tips</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Precision increases with birth time</h3>
        <p class="mt-1 text-sm text-slate-600">Without a birth time, the calculator assumes midnight (00:00). For the most accurate result, enter the exact time of birth. The difference can be up to 86,399 seconds.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Timezone matters</h3>
        <p class="mt-1 text-sm text-slate-600">If you were born in a different timezone than your current one, select your birth timezone for accuracy. The calculator accounts for the offset automatically.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Dog years are approximate</h3>
        <p class="mt-1 text-sm text-slate-600">The dog year calculation uses the common formula: 15 years for year 1, 9 for year 2, then 4 per year after that. Different breeds age differently, so consider this an estimate.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How age is calculated</h2>
    <p class="mt-2 text-slate-600">Age is calculated as the difference between the current date and time and the birth date and time. The JavaScript Date object represents time as milliseconds since January 1, 1970 (Unix epoch). By subtracting the birth timestamp from the current timestamp, we get the age in milliseconds, which we then convert to seconds, minutes, hours, days, weeks, months, and years.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Age:</span> <span class="text-slate-600">30 years</span></div>
        <div><span class="font-medium text-slate-700">Calculation:</span> <span class="text-slate-600">30 × 365.25 × 24 × 60 × 60</span></div>
        <div><span class="font-medium text-slate-700">Total seconds:</span> <span class="text-slate-600">~946,708,000 seconds</span></div>
        <div><span class="font-medium text-slate-700">Note:</span> <span class="text-slate-600">Includes leap day adjustments (365.25 days/year)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Time unit conversions</h2>
    <p class="mt-2 text-slate-600">One minute = 60 seconds. One hour = 3,600 seconds. One day = 86,400 seconds. One week = 604,800 seconds. One month = approximately 2,629,746 seconds (30.44 days on average). One common year = 31,536,000 seconds. These conversions are used to display your age in each unit.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">Leap seconds</h2>
    <p class="mt-2 text-slate-600">Leap seconds are added occasionally to keep Coordinated Universal Time (UTC) aligned with astronomical time. Since 1972, 27 leap seconds have been added. Standard JavaScript Date objects do not account for leap seconds, so for precise scientific calculations, specialized time libraries should be used.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">Fun facts about age</h2>
    <p class="mt-2 text-slate-600">The oldest verified human lived to 122 years (Jeanne Calment, 3.85 billion seconds). The average human heart beats about 2.5 billion times in a lifetime. If you are 30, you have slept approximately 87,600 hours (10 full years). A 40-year-old has taken roughly 420 million breaths.</p>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);

    function populateTimezones() {
      const sel = $('ais-tz');
      try {
        const tzs = Intl.supportedValuesOf('timeZone');
        tzs.forEach(tz => {
          const opt = document.createElement('option');
          opt.value = tz;
          opt.textContent = tz.replace(/_/g, ' ');
          sel.appendChild(opt);
        });
      } catch {
        const fallback = ['UTC', 'America/New_York', 'America/Chicago', 'America/Denver', 'America/Los_Angeles', 'Europe/London', 'Europe/Paris', 'Europe/Berlin', 'Europe/Moscow', 'Asia/Dubai', 'Asia/Kolkata', 'Asia/Shanghai', 'Asia/Tokyo', 'Australia/Sydney', 'Pacific/Auckland'];
        fallback.forEach(tz => {
          const opt = document.createElement('option');
          opt.value = tz;
          opt.textContent = tz.replace(/_/g, ' ');
          sel.appendChild(opt);
        });
      }
      sel.value = Intl.DateTimeFormat().resolvedOptions().timeZone;
    }

    function getDogYears(years) {
      if (years <= 1) return years * 15;
      if (years <= 2) return 15 + (years - 1) * 9;
      return 24 + (years - 2) * 4;
    }

    function formatNum(n) {
      return Math.floor(n).toLocaleString();
    }

    function updateAge() {
      const dobVal = $('ais-dob').value;
      if (!dobVal) return;
      const tobVal = $('ais-tob').value || '00:00';
      const tz = $('ais-tz').value;

      const [h, m] = tobVal.split(':').map(Number);
      const birthStr = dobVal + 'T' + tobVal + ':00';

      const birthDate = new Date(birthStr);

      const now = new Date();
      const diffMs = now - birthDate;
      const diffSec = diffMs / 1000;

      if (diffSec < 0) return;

      const sec = Math.floor(diffSec);
      const min = Math.floor(diffSec / 60);
      const hours = Math.floor(diffSec / 3600);
      const days = Math.floor(diffSec / 86400);
      const weeks = Math.floor(diffSec / 604800);

      const birthYear = birthDate.getFullYear();
      const birthMonth = birthDate.getMonth();
      const birthDay = birthDate.getDate();
      const nowYear = now.getFullYear();
      const nowMonth = now.getMonth();
      const nowDay = now.getDate();

      let months = (nowYear - birthYear) * 12 + (nowMonth - birthMonth);
      if (nowDay < birthDay) months--;

      let years = nowYear - birthYear;
      if (nowMonth < birthMonth || (nowMonth === birthMonth && nowDay < birthDay)) years--;

      const dogYears = getDogYears(Math.max(0, years));

      $('ais-seconds').textContent = formatNum(sec);
      $('ais-minutes').textContent = formatNum(min);
      $('ais-hours').textContent = formatNum(hours);
      $('ais-days').textContent = formatNum(days);
      $('ais-weeks').textContent = formatNum(weeks);
      $('ais-months').textContent = formatNum(months);
      $('ais-years').textContent = years;
      $('ais-dog').textContent = dogYears.toFixed(1);

      const nextBday = new Date(nowYear, birthMonth, birthDay);
      if (nextBday <= now) nextBday.setFullYear(nowYear + 1);
      const bdayDiff = Math.ceil((nextBday - now) / 86400000);
      $('ais-bday').textContent = bdayDiff + ' days';

      const lifeExpect = parseInt($('ais-life-expect').value, 10) || 100;
      const lifePct = Math.min((years / lifeExpect) * 100, 100);
      $('ais-life-bar').style.width = lifePct + '%';
      $('ais-life-pct-label').textContent = lifePct.toFixed(1) + '%';
    }

    populateTimezones();
    $('ais-dob').valueAsDate = new Date('1990-01-01');
    $('ais-dob').addEventListener('change', updateAge);
    $('ais-tob').addEventListener('change', updateAge);
    $('ais-tz').addEventListener('change', updateAge);
    $('ais-life-expect').addEventListener('input', () => {
      $('ais-life-expect-label').textContent = $('ais-life-expect').value;
      updateAge();
    });

    updateAge();
    setInterval(updateAge, 1000);
  </script>
</ToolLayout>
