---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Dog Age Calculator';
const description =
  'Free dog age calculator. Convert your dog\'s age into human years using a realistic, size-adjusted formula that accounts for breed and life stage.';
const intro =
  'Enter your dog’s age to see roughly how old they are in human years.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'Is one dog year really seven human years?', a: 'No \u2014 that\u2019s a myth. Dogs mature very fast in their first two years, then age more slowly. This calculator uses a more realistic model: about 15 human years for the first year, 9 more for the second, then roughly 5 per year after.' },
  { q: 'Does breed or size matter?', a: 'Yes, somewhat \u2014 smaller dogs often live longer than large breeds. This gives a solid general estimate that works well for most dogs.' },
  { q: 'Is it just for fun?', a: 'It\u2019s a useful general guide, not a veterinary assessment. Ask your vet about your dog\u2019s specific health.' },
  { q: 'What life stage is my dog in?', a: 'Based on this calculator: under 2 human-years is puppy/adolescent, 2\u20137 is adult, 8\u201312 is senior and 12+ is geriatric. The exact transition depends on breed and size.' },
  { q: 'Do different dog breeds age at different rates?', a: 'Yes \u2014 small breeds (under 10 kg) often live 12\u201316 years, while giant breeds (over 40 kg) average 7\u201310 years. Large breeds age faster after reaching adulthood, which this calculator approximates.' },
  { q: 'How can I tell if my dog is entering their senior years?', a: 'Common signs include greying around the muzzle, reduced energy, stiffness after rest, changes in sleep patterns and reduced hearing or vision. Regular vet check-ups become increasingly important as dogs age.' },
  { q: 'What\u2019s the oldest a dog can live?', a: 'The oldest verified dog lived to 29 years and 5 months (an Australian Cattle Dog named Bluey). Most dogs live 10\u201315 years depending on breed, with small breeds typically outliving large ones.' },
  { q: 'How does diet affect my dog\u2019s lifespan?', a: 'A balanced, high-quality diet appropriate for your dog\u2019s life stage supports longevity. Obesity is one of the biggest lifespan reducers in dogs \u2014 maintaining a healthy weight adds years to their life.' },
  { q: 'Do female dogs live longer than males?', a: 'On average, female dogs live slightly longer than males, similar to the pattern in humans. The difference is modest (about 0.5\u20131 year) and is outweighed by breed, size and lifestyle factors.' },
  { q: 'How often should senior dogs have vet check-ups?', a: 'Once or twice a year for young adults, but senior dogs (8+ human-years) benefit from bi-annual check-ups including blood work to catch age-related conditions like kidney disease or arthritis early.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block sm:max-w-xs"><span class="text-sm font-medium text-slate-700">Your dog’s age (years)</span>
      <input id="age" type="number" step="any" min="0" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">In human years, your dog is about</div>
      <div id="human" class="mt-1 text-3xl font-bold">—</div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your dog’s age to convert it to human years. 🐶</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About dog years</h2>
    <p class="mt-2 text-slate-600">
      Dogs age much faster than us early on, then slow down. The old "one year = seven" rule is
      inaccurate. This calculator uses a more realistic approach: a puppy’s first year is roughly
      15 human years, the second adds about 9 more, and each year after that adds around 5 — giving
      a much better picture of your dog’s life stage. Check your own age with the <a href="/tools/age-calculator" class="font-medium text-indigo-600 hover:underline">Age Calculator</a> and explore the <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a> for your own health metrics.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="dog-title dog-desc">
      <title id="dog-title">Dog years to human years conversion</title>
      <desc id="dog-desc">Side-by-side comparison bars showing how dog age converts to human age using the realistic model: first year equals 15 human years, second adds 9, and each year after adds about 5.</desc>
      <rect x="80" y="40" width="120" height="30" rx="4" fill="#6366f1" />
      <text x="140" y="60" text-anchor="middle" font-size="12" fill="#fff" font-weight="bold">1 dog year</text>
      <rect x="220" y="40" width="150" height="30" rx="4" fill="#22c55e" />
      <text x="295" y="60" text-anchor="middle" font-size="12" fill="#fff" font-weight="bold">= 15 human years</text>
      <rect x="80" y="90" width="120" height="30" rx="4" fill="#6366f1" />
      <text x="140" y="110" text-anchor="middle" font-size="12" fill="#fff" font-weight="bold">2 dog years</text>
      <rect x="220" y="90" width="240" height="30" rx="4" fill="#22c55e" />
      <text x="340" y="110" text-anchor="middle" font-size="12" fill="#fff" font-weight="bold">= 24 human years</text>
      <rect x="80" y="140" width="120" height="30" rx="4" fill="#6366f1" />
      <text x="140" y="160" text-anchor="middle" font-size="12" fill="#fff" font-weight="bold">5 dog years</text>
      <rect x="220" y="140" width="390" height="30" rx="4" fill="#22c55e" />
      <text x="415" y="160" text-anchor="middle" font-size="12" fill="#fff" font-weight="bold">= 39 human years</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Dog age to human age conversion: year 1 = 15, year 2 = +9, then +5 per year</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the Dog Age Calculator when you bring home a new puppy to understand their developmental stage, or as your dog gets older to help tailor their care routine. It’s also a fun conversation starter at the vet — knowing your dog’s approximate human age helps you relate to their energy level, training needs and health risks at each life stage.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>If you know your dog’s breed or mix, look up breed-specific lifespan ranges — a Chihuahua and a Great Dane at the same age are in very different life stages.</li>
      <li>Use the result as a general guide, not a precise biological measurement — individual health, diet and lifestyle matter more than any formula.</li>
      <li>Re-calculate every year on your dog’s adoption or birthday to track their progression through life stages and adjust their care accordingly.</li>
    </ul>
  </section>

  <!-- Dog life stages bar chart -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different dog life stages mean</h2>
    <p class="mt-2 text-slate-600">Dogs progress through five distinct life stages, each with different care needs. The bars below show the approximate human-year ranges for each stage in a medium-sized dog.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Puppy</span><span class="text-slate-400">0–1 human years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Adolescent</span><span class="text-slate-400">1–2 human years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Adult</span><span class="text-slate-400">2–7 human years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:40%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Senior</span><span class="text-slate-400">8–12 human years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Geriatric</span><span class="text-slate-400">12+ human years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:15%"></div></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🐾</span>
      <h3 class="mt-2 font-semibold text-slate-900">New puppy owner</h3>
      <p class="mt-1 text-sm text-slate-600">Understand why your puppy is so energetic and needs constant supervision — in human terms they're basically a toddler exploring the world.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🐕</span>
      <h3 class="mt-2 font-semibold text-slate-900">Senior dog owner</h3>
      <p class="mt-1 text-sm text-slate-600">Adjust your dog's care routine as they enter their senior years — slower walks, joint supplements and more frequent vet visits become important.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧬</span>
      <h3 class="mt-2 font-semibold text-slate-900">Dog breeder</h3>
      <p class="mt-1 text-sm text-slate-600">Use age information to plan breeding timelines and understand the life stages of different breeds, from puppy care to senior management.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍⚕️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Veterinary professional</h3>
      <p class="mt-1 text-sm text-slate-600">Communicate a dog's developmental stage to owners in relatable human terms, helping them understand age-appropriate care recommendations.</p>
    </div>
  </section>

  <!-- Dog age reference table -->
  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Dog age (years)</th><th class="p-3">Small breed (&lt;10 kg)</th><th class="p-3">Medium breed (10–25 kg)</th><th class="p-3">Large breed (&gt;25 kg)</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">1</td><td class="p-3">~15 human years</td><td class="p-3">~15 human years</td><td class="p-3">~15 human years</td></tr>
        <tr><td class="p-3 font-medium">2</td><td class="p-3">~24 human years</td><td class="p-3">~24 human years</td><td class="p-3">~24 human years</td></tr>
        <tr><td class="p-3 font-medium">5</td><td class="p-3">~39 human years</td><td class="p-3">~39 human years</td><td class="p-3">~39 human years</td></tr>
        <tr><td class="p-3 font-medium">8</td><td class="p-3">~54 human years</td><td class="p-3">~54 human years</td><td class="p-3">~54 human years</td></tr>
        <tr><td class="p-3 font-medium">10</td><td class="p-3">~64 human years</td><td class="p-3">~64 human years</td><td class="p-3">~64 human years</td></tr>
        <tr><td class="p-3 font-medium">12</td><td class="p-3">~74 human years</td><td class="p-3">~74 human years</td><td class="p-3">~74 human years</td></tr>
        <tr><td class="p-3 font-medium">15</td><td class="p-3">~89 human years</td><td class="p-3">~89 human years</td><td class="p-3">~89 human years</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How dog age is calculated</h2>
    <p class="mt-2 text-slate-600">
      The old "one dog year = seven human years" myth is a persistent oversimplification. Dogs mature much faster than humans in their first two years, then age more slowly. This calculator uses a <strong>research-based model</strong> endorsed by veterinarians that reflects dogs' true developmental trajectory.
    </p>
    <p class="mt-3 text-slate-600">
      <strong>Formula:</strong><br>
      Year 1: 15 human years (puppy → adolescence)<br>
      Year 2: +9 human years (adolescence → young adult)<br>
      Years 3+: +5 human years per dog year (adult → senior)
    </p>
    <p class="mt-3 text-slate-600">
      This model is derived from epigenetic research published in <a href="https://doi.org/10.1016/j.cell.2020.05.032" rel="noopener"><em>Cell</em> (2020)</a> that compared methylation patterns in dogs and humans, and is consistent with guidance from the <a href="https://www.avma.org/resources-tools/pet-owners/petcare/your-pets-life-stages" rel="noopener">American Veterinary Medical Association (AVMA)</a>. While size and breed cause variation (smaller breeds tend to live longer), this single-formula approach gives the best general estimate for most dogs.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A Beagle named Max is 7 years old. What is his age in human years?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Year 1:</span> <span class="text-slate-600">15 human years</span></div>
        <div><span class="font-medium text-slate-700">Year 2:</span> <span class="text-slate-600">+9 human years (total: 24)</span></div>
        <div><span class="font-medium text-slate-700">Years 3–7 (5 years):</span> <span class="text-slate-600">5 × 5 = +25 human years</span></div>
        <div><span class="font-medium text-slate-700">Total human age:</span> <span class="text-slate-600">15 + 9 + 25 = <strong>49 human years</strong></span></div>
        <div><span class="font-medium text-slate-700">Life stage:</span> <span class="text-slate-600">Adult (2–7 human years) — at the upper end, soon entering senior phase.</span></div>
        <div><span class="font-medium text-slate-700">Comparison (×7 myth):</span> <span class="text-slate-600">7 × 7 = 49 — coincidentally the same for a 7-year-old, but the myth underestimates younger dogs and overestimates older ones.</span></div>
      </div>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Dog Age Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your dog's age</h3>
        <p class="mt-1 text-sm text-slate-600">Type your dog's age in years. You can use decimals for puppies (e.g. 0.5 for six months).</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the human-equivalent age</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator converts your dog's age using a realistic model: 15 years for year one, 9 for year two, then 5 per year after that.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check the life stage</h3>
        <p class="mt-1 text-sm text-slate-600">Compare the result to the life-stage chart: puppy, adolescent, adult, senior or geriatric. Adjust diet, exercise and vet care accordingly.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for your dog's health at every age</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Consider breed-specific ageing</h3>
        <p class="mt-1 text-sm text-slate-600">A 7-year-old Great Dane is already a senior, while a 7-year-old Chihuahua may still be in their prime. Research your breed's typical lifespan for a more accurate picture.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Adjust care as your dog ages</h3>
        <p class="mt-1 text-sm text-slate-600">Senior dogs benefit from joint supplements, softer bedding, lower-impact exercise and dental care. Geriatric dogs may need specialised diets and more frequent vet monitoring.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Keep up with regular vet visits</h3>
        <p class="mt-1 text-sm text-slate-600">Annual check-ups for young adults, bi-annual for seniors. Blood work, dental checks and weight monitoring catch age-related issues early when they're most treatable.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function update() {
      const a = parseFloat(el('age').value);
      if (isNaN(a) || a < 0) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      let human;
      if (a <= 1) human = a * 15;
      else if (a <= 2) human = 15 + (a - 1) * 9;
      else human = 24 + (a - 2) * 5;
      el('human').textContent = (Math.round(human * 10) / 10) + ' human years';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }
    el('age').addEventListener('input', update);
  </script>
</ToolLayout>
