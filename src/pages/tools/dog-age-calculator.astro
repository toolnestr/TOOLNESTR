---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Dog Age Calculator';
const description =
  'Free dog age calculator. Convert your dog’s age into human years using a realistic, ' +
  'vet-informed formula — not the old “multiply by 7” myth.';
const intro =
  'Enter your dog’s age to see roughly how old they are in human years.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'Is one dog year really seven human years?', a: 'No — that’s a myth. Dogs mature very fast in their first two years, then age more slowly. This calculator uses a more realistic model: about 15 human years for the first year, 9 more for the second, then roughly 5 per year after.' },
  { q: 'Does breed or size matter?', a: 'Yes, somewhat — smaller dogs often live longer than large breeds. This gives a solid general estimate that works well for most dogs.' },
  { q: 'Is it just for fun?', a: 'It’s a useful general guide, not a veterinary assessment. Ask your vet about your dog’s specific health.' },
  { q: 'What life stage is my dog in?', a: 'Based on this calculator: under 2 human-years is puppy/adolescent, 2–7 is adult, 8–12 is senior and 12+ is geriatric. The exact transition depends on breed and size.' },
  { q: 'Do different dog breeds age at different rates?', a: 'Yes — small breeds (under 10 kg) often live 12–16 years, while giant breeds (over 40 kg) average 7–10 years. Large breeds age faster after reaching adulthood, which this calculator approximates.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block sm:max-w-xs"><span class="text-sm font-medium text-slate-700">Your dog’s age (years)</span>
      <input id="age" type="number" step="any" min="0" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">In human years, your dog is about</div>
      <div id="human" class="mt-1 text-3xl font-bold">—</div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your dog’s age to convert it to human years. 🐶</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About dog years</h2>
    <p class="mt-2 text-slate-600">
      Dogs age much faster than us early on, then slow down. The old "one year = seven" rule is
      inaccurate. This calculator uses a more realistic approach: a puppy’s first year is roughly
      15 human years, the second adds about 9 more, and each year after that adds around 5 — giving
      a much better picture of your dog’s life stage. Check your own age with the <a href="/tools/age-calculator" class="font-medium text-indigo-600 hover:underline">Age Calculator</a> and explore the <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a> for your own health metrics.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the Dog Age Calculator when you bring home a new puppy to understand their developmental stage, or as your dog gets older to help tailor their care routine. It’s also a fun conversation starter at the vet — knowing your dog’s approximate human age helps you relate to their energy level, training needs and health risks at each life stage.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>If you know your dog’s breed or mix, look up breed-specific lifespan ranges — a Chihuahua and a Great Dane at the same age are in very different life stages.</li>
      <li>Use the result as a general guide, not a precise biological measurement — individual health, diet and lifestyle matter more than any formula.</li>
      <li>Re-calculate every year on your dog’s adoption or birthday to track their progression through life stages and adjust their care accordingly.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function update() {
      const a = parseFloat(el('age').value);
      if (isNaN(a) || a < 0) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      let human;
      if (a <= 1) human = a * 15;
      else if (a <= 2) human = 15 + (a - 1) * 9;
      else human = 24 + (a - 2) * 5;
      el('human').textContent = (Math.round(human * 10) / 10) + ' human years';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }
    el('age').addEventListener('input', update);
  </script>
</ToolLayout>
