---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Magnetic Force Calculator';
const description = "Magnetic force calculator. Find the force on a moving charge (F = qvB sinθ) or a current-carrying wire (F = BIL sinθ), with worked examples.";
const intro = 'Compute the magnetic force on a moving charge, or on a current-carrying wire in a magnetic field. Two 3D diagrams show the right-hand-rule geometry for both cases, with charts showing how force depends on angle and field strength.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the formula for magnetic force on a moving charge?', a: 'F = qvB sin(θ), where q is the charge (C), v is its speed (m/s), B is the magnetic flux density (T), and θ is the angle between the velocity and field vectors. The force is always perpendicular to both v and B.' },
  { q: 'What is the formula for the force on a current-carrying wire?', a: 'F = BIL sin(θ), where I is the current (A), L is the length of wire in the field (m), B is the field strength (T), and θ is the angle between the wire and the field. This follows directly from summing the force on every moving charge in the wire.' },
  { q: 'Why is the force zero when velocity is parallel to the field?', a: 'Because the formula depends on sin(θ), and sin(0°) = 0. A charge moving exactly along the field lines experiences no magnetic force — sideways deflection only happens when there is a velocity component perpendicular to B.' },
  { q: 'How do you find the direction of the magnetic force?', a: 'Use the right-hand rule: point your fingers in the direction of v (or current I), curl them toward B, and your thumb points along v × B — this is the direction of the force for a positive charge (reverse it for a negative charge).' },
  { q: 'Does magnetic force do work on a moving charge?', a: 'No. Because the magnetic force is always perpendicular to the velocity, it can only change the charge\'s direction, never its speed — so it does zero work and never changes the particle\'s kinetic energy.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Magnetic Force Calculator',
  description: 'Compute the magnetic force on a moving charge, or on a current-carrying wire, from field strength and angle.',
  steps: [
    { name: 'Pick a mode', text: '"Moving charge" solves F = qvB sinθ. "Current-carrying wire" solves F = BIL sinθ.' },
    { name: 'Enter the values', text: 'Type charge/velocity or current/length, plus the field strength B and the angle θ.' },
    { name: 'Read the result', text: 'The magnetic force solves instantly in newtons, shown in scientific notation where needed.' },
  ],
};

const formulas = [
  { expr: 'F = qvB sin(θ)', note: 'force on a moving charge — q in coulombs, v in m/s, B in tesla' },
  { expr: 'F = BIL sin(θ)', note: 'force on a current-carrying wire — I in amps, L in metres' },
  { expr: 'Direction: right-hand rule', note: 'point fingers along v (or I), curl toward B — thumb gives the force direction' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — electron in a magnetic field', tone: 'slate',
    given: 'An electron moves at v = 2×10⁶ m/s perpendicular (θ = 90°) to a field B = 0.5 T. Charge q = 1.6×10⁻¹⁹ C. Find the force.',
    rows: [
      { label: 'Formula:', value: 'F = qvB sin(θ)' },
      { label: 'Substitute:', value: 'F = 1.6×10⁻¹⁹ × 2×10⁶ × 0.5 × sin(90°)' },
      { label: 'Result:', value: 'F = 1.6×10⁻¹³ N', full: true },
    ],
    note: 'This is the same physics used in mass spectrometers and old CRT televisions to steer charged particles along curved paths.',
  },
  {
    title: 'Worked example 2 — current-carrying wire in a motor', tone: 'amber',
    given: 'A straight wire segment carries I = 5 A over a length L = 0.3 m, perpendicular (θ = 90°) to a field B = 0.8 T.',
    rows: [
      { label: 'Formula:', value: 'F = BIL sin(θ)' },
      { label: 'Substitute:', value: 'F = 0.8 × 5 × 0.3 × sin(90°)' },
      { label: 'Result:', value: 'F = 1.2 N', full: true },
    ],
    note: 'This is exactly the force that spins the rotor coil in a DC electric motor — many turns of wire multiply this force many times over.',
  },
];

const comparison = {
  heading: 'How angle affects magnetic force',
  note: 'Force scales with sin(θ) — holding qvB (or BIL) fixed at 1 (arbitrary units) shows how the force changes with the angle between velocity and field.',
  headers: [{ label: 'Angle θ' }, { label: 'sin(θ)' }, { label: 'Relative force' }],
  rows: [
    ['0°', '0', '0 (no force)'],
    ['30°', '0.500', '0.500'],
    ['60°', '0.866', '0.866'],
    ['90°', '1.000', '1.000 (maximum)'],
  ],
  highlightIndex: 3,
  footnote: 'Force is maximum when velocity (or current) is perpendicular to the field, and zero when it runs parallel to the field lines.',
};

const realWorld = [
  { emoji: '🧲', title: 'Electric motors', body: 'The force on current-carrying coils inside a magnetic field (F = BIL sinθ) is exactly what makes electric motors spin, converting electrical energy into rotational mechanical work.' },
  { emoji: '🔬', title: 'Mass spectrometers', body: 'Charged particles moving through a magnetic field curve along a radius that depends on their mass-to-charge ratio, letting scientists identify unknown compounds by their curved paths.' },
  { emoji: '🏥', title: 'MRI machines', body: 'Powerful magnetic fields interact with the magnetic moments of hydrogen nuclei in the body — a specialized quantum version of the same underlying magnetic force principles.' },
  { emoji: '⚛️', title: 'Particle accelerators', body: 'Magnetic fields steer and focus beams of charged particles around circular accelerator rings, using precisely calculated magnetic forces to keep particles on their intended path at near light speed.' },
];

const misconceptions = [
  { claim: '"Magnetic force does work on a moving charge, speeding it up or slowing it down."', truth: 'Magnetic force is always perpendicular to velocity, so it can only change the direction of motion, never the speed. It does zero work and never changes the particle\'s kinetic energy — only electric fields can do that.' },
  { claim: '"The magnetic force is strongest when a charge moves along the field lines."', truth: "It's the opposite — force depends on sin(θ), which is zero when velocity is parallel to the field (θ=0°) and maximum when velocity is perpendicular to the field (θ=90°)." },
  { claim: '"A stationary charge in a magnetic field feels a force."', truth: 'F = qvB sinθ requires the charge to be moving (v > 0). A charge at rest in a purely magnetic field feels no magnetic force at all — only electric fields exert force on stationary charges.' },
  { claim: '"Reversing the current direction has no effect on the force on a wire."', truth: 'Reversing the current reverses the direction of the force (though not its magnitude) — this is exactly how commutators in DC motors keep the rotor spinning in one consistent direction.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — Chapter 11, "Magnetic Forces and Fields" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/11-4-magnetic-force-on-a-current-carrying-conductor" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 28, Magnetic Fields.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 29, Magnetic Fields.' },
];
const sourcesNote = 'F = qvB sin(θ) for a moving charge; F = BIL sin(θ) for a current-carrying wire. Direction found via the right-hand rule. Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"Moving charge" solves F = qvB sinθ; "Current-carrying wire" solves F = BIL sinθ.' },
  { title: 'Enter the values', body: 'Use consistent SI units — charge in coulombs, velocity in m/s, current in amps, length in metres, B in tesla.' },
  { title: 'Read the result', body: 'Force solves live in newtons, shown in scientific notation for very small or large values.' },
];

const related = [
  { href: '/tools/electric-field-calculator', emoji: '📡', title: 'Electric Field Calculator', desc: 'E = F/q and E = kQ/r² — solve field, force, charge, or distance.' },
  { href: '/tools/coulombs-law-calculator', emoji: '⚡', title: "Coulomb's Law Calculator", desc: 'F = k|q1q2|/r² — solve force, either charge, or distance.' },
  { href: '/tools/electric-power-calculator', emoji: '💡', title: 'Electric Power Calculator', desc: 'P = V×I plus energy (kWh) and electricity cost.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a magnetic field only pushes on charges that are actually moving through it, and only on the part of their motion that runs perpendicular to the field — that's why the force always depends on sin(θ), never on the parallel component of motion."
  howIntro="For a single moving charge, F = qvB sin(θ) gives the magnitude of the force, always directed perpendicular to both v and B via the right-hand rule. A current-carrying wire is just a huge number of moving charges together, so summing their individual forces gives the wire equation F = BIL sin(θ), where the current I and length L replace the single charge's q and v."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where magnetic force actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-charge" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Moving charge (F = qvB sinθ)</button>
      <button id="mode-wire" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Current-carrying wire (F = BIL sinθ)</button>
    </div>

    <div id="charge-fields" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Charge q (C)</span>
        <input id="q" type="number" step="any" placeholder="e.g. 1.6e-19" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Velocity v (m/s)</span>
        <input id="v" type="number" step="any" placeholder="e.g. 2e6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="wire-fields" class="hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Current I (A)</span>
        <input id="I" type="number" step="any" placeholder="e.g. 5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Length L (m)</span>
        <input id="L" type="number" step="any" placeholder="e.g. 0.3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Field strength B (T)</span>
        <input id="B" type="number" step="any" placeholder="e.g. 0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Angle θ (degrees)</span>
        <input id="theta" type="number" step="any" placeholder="e.g. 90" value="90" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white sm:col-span-2"><div class="text-sm opacity-80">Magnetic force F</div><div id="r-f" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="mf-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Right-hand-rule geometry</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-charge" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Moving charge in a field</h3>
          <p class="mt-1 text-sm text-slate-600">Velocity (amber), field lines (slate), and the resulting force (indigo) — all mutually perpendicular, exactly as the right-hand rule predicts.</p>
        </div>
        <div>
          <div id="diag-wire" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Current-carrying wire in a field</h3>
          <p class="mt-1 text-sm text-slate-600">A straight wire (amber) carrying current through a field (slate arrows) feels a force (indigo) perpendicular to both — the working principle of every electric motor.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Magnetic force graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Force vs angle θ — the sin(θ) dependence</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-angle"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Force vs field strength B (fixed I, L, θ=90°)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-field"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function fmtSci(x) {
        if (!isFinite(x)) return '—';
        if (Math.abs(x) !== 0 && (Math.abs(x) < 1e-3 || Math.abs(x) >= 1e6)) return x.toExponential(3) + ' N';
        return fmt(x) + ' N';
      }

      // ---- calculator ----
      let mode = 'charge';
      function switchMode(m) {
        mode = m;
        el('mode-charge').className = m === 'charge' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-wire').className = m === 'wire' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('charge-fields').className = m === 'charge' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        el('wire-fields').className = m === 'wire' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        el('mf-err').textContent = '';
        update();
      }
      function update() {
        el('mf-err').textContent = '';
        el('r-f').textContent = '—';
        const B = parseFloat(el('B').value), theta = parseFloat(el('theta').value);
        if (isNaN(B) || isNaN(theta)) return;
        const rad = (theta * Math.PI) / 180;
        let F;
        if (mode === 'charge') {
          const q = parseFloat(el('q').value), v = parseFloat(el('v').value);
          if (isNaN(q) || isNaN(v)) return;
          F = Math.abs(q) * v * B * Math.sin(rad);
        } else {
          const I = parseFloat(el('I').value), L = parseFloat(el('L').value);
          if (isNaN(I) || isNaN(L)) return;
          F = B * Math.abs(I) * L * Math.sin(rad);
        }
        el('r-f').textContent = fmtSci(F);
      }
      el('mode-charge').addEventListener('click', () => switchMode('charge'));
      el('mode-wire').addEventListener('click', () => switchMode('wire'));
      ['q', 'v', 'I', 'L', 'B', 'theta'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsA = [], dataA = [];
        for (let a = 0; a <= 180; a += 10) { labelsA.push(a); dataA.push(+Math.sin((a * Math.PI) / 180).toFixed(4)); }
        charts.angle = new Chart(el('chart-angle'), {
          type: 'line',
          data: { labels: labelsA, datasets: [{ label: 'sin(θ)', data: dataA, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Angle θ (degrees)' } }, y: { title: { display: true, text: 'Relative force (sinθ)' }, min: 0, max: 1 } }, plugins: { legend: { display: false } } }),
        });
        const labelsB = [], dataB = [];
        for (let b = 0; b <= 2; b += 0.1) { labelsB.push(b.toFixed(1)); dataB.push(+(5 * 0.3 * b).toFixed(3)); }
        charts.field = new Chart(el('chart-field'), {
          type: 'line',
          data: { labels: labelsB, datasets: [{ label: 'F (N)', data: dataB, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Field strength B (T)' } }, y: { title: { display: true, text: 'Force (N), I=5A L=0.3m' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: moving charge in a field ----
      let diagCharge = null;
      function initDiagCharge() {
        const c = el('diag-charge'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 0, 0), OPTS);
        for (let x = -3; x <= 3; x += 1.5) {
          for (let z = -2; z <= 2; z += 2) {
            const a = arrow(new THREE.Vector3(x, -2, z), new THREE.Vector3(x, 2, z), 0x94a3b8);
            s.scene.add(a);
          }
        }
        const chargeMat = new THREE.MeshStandardMaterial({ color: 0xef4444, roughness: 0.4 });
        const charge = new THREE.Mesh(new THREE.SphereGeometry(0.35, 20, 16), chargeMat);
        s.scene.add(charge);
        s.scene.add(arrow(new THREE.Vector3(0, 0, 0), new THREE.Vector3(3, 0, 0), 0xf59e0b));
        s.scene.add(arrow(new THREE.Vector3(0, 0, 0), new THREE.Vector3(0, 0, -3), 0x6366f1));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagCharge = { resize: s.resize };
      }

      // ---- Diagram 2: current-carrying wire in a field ----
      let diagWire = null;
      function initDiagWire() {
        const c = el('diag-wire'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 0, 0), OPTS);
        const wireMat = new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5 });
        const wire = new THREE.Mesh(new THREE.CylinderGeometry(0.12, 0.12, 5, 16), wireMat);
        wire.rotation.z = Math.PI / 2;
        s.scene.add(wire);
        for (let x = -2.5; x <= 2.5; x += 1.5) {
          s.scene.add(arrow(new THREE.Vector3(x, -2.2, 0), new THREE.Vector3(x, -0.4, 0), 0x94a3b8));
        }
        s.scene.add(arrow(new THREE.Vector3(0, 0, 0), new THREE.Vector3(0, 0, -2.6), 0x6366f1));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagWire = { resize: s.resize };
      }

      function boot() {
        try { switchMode('charge'); } catch (e) { console.error('[magnetic-force] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[magnetic-force] charts failed', e); }
        if (window.THREE) {
          try { initDiagCharge(); } catch (e) { console.error('[magnetic-force] charge diagram failed', e); }
          try { initDiagWire(); } catch (e) { console.error('[magnetic-force] wire diagram failed', e); }
        }
        mountResize([diagCharge, diagWire]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
