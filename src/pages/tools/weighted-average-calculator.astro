---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Weighted Average Calculator';
const description = 'Calculate the weighted average (weighted mean) of a set of values with different weights. Free online weighted average calculator.';
const intro = 'Compute the weighted mean when different values contribute with different levels of importance.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is a weighted average?', a: 'A weighted average assigns different weights (importance) to each data point before averaging. It is calculated as the sum of (value × weight) divided by the sum of weights.' },
  { q: 'When should I use a weighted average instead of a simple average?', a: 'Use a weighted average when data points have different levels of importance or frequency. For example, course grades weighted by credit hours, or investment returns weighted by allocation size.' },
  { q: 'What if all weights are equal?', a: 'If all weights are equal, the weighted average equals the simple average. This can serve as a useful check: if your weights are all 1, the result is the same as the arithmetic mean.' },
  { q: 'Can weights be percentages?', a: 'Yes, weights can be percentages that sum to 100%. The calculator handles both raw weights (like 2, 3, 5) and percentage weights that sum to 100. The result is the same either way.' },
  { q: 'What happens if weights are zero?', a: 'A value with zero weight is effectively excluded from the average. This is useful when you want to calculate the average of a subset without removing the data entirely from your list.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700" for="wa-input">Values and weights (format: value:weight, comma-separated)</label>
      <input id="wa-input" type="text" value="85:3, 92:2, 78:5, 95:1" placeholder="e.g. 85:3, 92:2, 78:5"
        class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </div>
    <div id="wa-result-main" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
      <span class="text-sm opacity-90">Weighted average =</span>
      <span id="wa-value" class="ml-2 text-2xl font-bold">83.27</span>
    </div>
    <div id="wa-detail" class="mt-3 hidden rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
      <p id="wa-numerator-display"></p>
      <p id="wa-denominator-display"></p>
      <p id="wa-simple-compare" class="mt-1 text-xs text-slate-400"></p>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="600" height="360" viewBox="0 0 600 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="wa-title wa-desc">
      <title id="wa-title">Balance beam with different weights showing weighted average concept</title>
      <desc id="wa-desc">A balance beam with four blocks of different sizes at different positions. The fulcrum represents the weighted average. Larger weights pull the balance point toward them.</desc>
      <rect x="50" y="200" width="500" height="20" rx="4" fill="#cbd5e1" />
      <polygon points="300,220 285,250 315,250" fill="#64748b" />
      <rect x="80" y="140" width="40" height="60" rx="4" fill="#6366f1" />
      <text x="100" y="130" text-anchor="middle" fill="#4338ca" font-size="14" font-weight="bold">W=3</text>
      <text x="100" y="120" text-anchor="middle" fill="#94a3b8" font-size="11">85</text>
      <rect x="180" y="160" width="35" height="40" rx="4" fill="#10b981" />
      <text x="197" y="150" text-anchor="middle" fill="#059669" font-size="14" font-weight="bold">W=2</text>
      <text x="197" y="140" text-anchor="middle" fill="#94a3b8" font-size="11">92</text>
      <rect x="350" y="120" width="50" height="80" rx="4" fill="#f59e0b" />
      <text x="375" y="110" text-anchor="middle" fill="#d97706" font-size="14" font-weight="bold">W=5</text>
      <text x="375" y="100" text-anchor="middle" fill="#94a3b8" font-size="11">78</text>
      <rect x="470" y="170" width="30" height="30" rx="4" fill="#ef4444" />
      <text x="485" y="160" text-anchor="middle" fill="#dc2626" font-size="14" font-weight="bold">W=1</text>
      <text x="485" y="150" text-anchor="middle" fill="#94a3b8" font-size="11">95</text>
      <text x="300" y="285" text-anchor="middle" fill="#1e293b" font-size="16" font-weight="bold">&triangle; Balance point (weighted avg = 83.27)</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The weighted average is the balance point of a lever where heavier weights exert more influence.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How weighted averaging works</h2>
    <p class="mt-2 text-slate-600">A weighted average (or weighted mean) is a calculation that takes into account the varying degrees of importance of the numbers in a data set. Unlike a simple arithmetic mean where each data point contributes equally, a weighted average multiplies each data point by a predetermined weight before summing and dividing by the total weight.</p>
    <p class="mt-3 text-slate-600">The fundamental formula is: Weighted Average = &Sigma;(value&nbsp;&times;&nbsp;weight) / &Sigma;(weight). The numerator is the sum of each value multiplied by its corresponding weight. The denominator is the sum of all weights. The weights represent the relative importance of each value — a value with a weight of 5 contributes five times as much to the average as a value with a weight of 1.</p>
    <p class="mt-3 text-slate-600">Weights must be non-negative numbers. They do not need to sum to any particular value — the formula handles any set of non-negative weights naturally. If the weights sum to zero, the weighted average is undefined. In practice, weights are often percentages summing to 100%, or frequencies representing how many times each value occurs in the data set.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Weighted average formula</h3>
        <p class="mt-1 font-mono text-lg font-bold text-indigo-700">&nbsp;x&#772; = &Sigma;(x<sub>i</sub>w<sub>i</sub>) / &Sigma;w<sub>i</sub></p>
        <p class="mt-2 text-sm text-slate-600">Multiply each value by its weight, sum these products, then divide by the sum of all weights.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Connection to simple mean</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">Simple: w<sub>i</sub> = 1 &rArr; x&#772; = &Sigma;x<sub>i</sub> / n</p>
        <p class="mt-2 text-sm text-slate-600">The simple arithmetic mean is a special case of the weighted mean where all weights are equal.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: Course grade calculation</h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>Scores: Homework = 85 (weight 3), Quiz = 92 (weight 2), Exam = 78 (weight 5), Project = 95 (weight 1)</p>
        <p>Step 1: Weighted sum = 85×3 + 92×2 + 78×5 + 95×1 = 255 + 184 + 390 + 95 = 924</p>
        <p>Step 2: Total weight = 3 + 2 + 5 + 1 = 11</p>
        <p>Step 3: Weighted average = 924 / 11 = 84.0</p>
        <p class="font-semibold text-emerald-700">The weighted average of 84.0 is lower than the simple average of 87.5 because the exam (lowest score) has the highest weight.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students &amp; Educators</h3>
      <p class="mt-1 text-sm text-slate-600">Course grades are the classic example of weighted averages. Different assignments have different weights (homework 10%, quizzes 20%, midterm 30%, final 40%). The weighted average calculates the final course grade accurately.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Investors</h3>
      <p class="mt-1 text-sm text-slate-600">Portfolio returns are weighted by allocation. If 60% of your portfolio returns 8% and 40% returns 12%, the weighted return is 0.6×8 + 0.4×12 = 9.6%. Weighted average cost of capital (WACC) is another key financial application.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4CA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Data Analysts</h3>
      <p class="mt-1 text-sm text-slate-600">Survey data often requires weighting to match population demographics. If a survey under-represents a group, their responses get higher weights. Weighted averages correct for sampling bias and produce more representative results.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Supply Chain Managers</h3>
      <p class="mt-1 text-sm text-slate-600">Inventory valuation methods like weighted average cost calculate the cost of goods sold by averaging the cost of all units, weighted by the number of units purchased at each price. This smooths out price fluctuations in inventory accounting.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the weighted average calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter value:weight pairs</h3>
        <p class="mt-1 text-sm text-slate-600">Type each value followed by a colon and its weight, separated by commas. For example, "85:3, 92:2, 78:5".</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Results update automatically</h3>
        <p class="mt-1 text-sm text-slate-600">The weighted average appears instantly. The detail section shows the numerator, denominator, and a comparison with the simple average.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Adjust and compare</h3>
        <p class="mt-1 text-sm text-slate-600">Change weights to see how they affect the result. The simple average comparison helps you understand the impact of the weighting scheme.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for weighted averaging</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Weights can be normalized</h3>
        <p class="mt-1 text-sm text-slate-600">If your weights sum to 1 (or 100%), you can skip the division step: the weighted average is simply &Sigma;(value × weight). For example, if three assets in a portfolio have weights 0.5, 0.3, and 0.2, the weighted return is 0.5×R₁ + 0.3×R₂ + 0.2×R₃ directly.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Beware of extreme weights</h3>
        <p class="mt-1 text-sm text-slate-600">A single very large weight can dominate the weighted average, making it almost equal to that value. Conversely, a value with a negligible weight contributes almost nothing. Check that your weights reflect the true importance of each data point in your analysis.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Weighted averages can be biased</h3>
        <p class="mt-1 text-sm text-slate-600">If weights are chosen subjectively or based on unreliable data, the weighted average can be misleading. Always document how weights are determined and consider sensitivity analysis — how much would the result change if weights were adjusted by 10-20%?</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Frequency as weight</h3>
        <p class="mt-1 text-sm text-slate-600">When data is grouped by frequency, the weighted average formula naturally computes the mean. For example, if 3 students scored 85, 2 scored 92, and 5 scored 78, the frequency (number of students) serves as the weight: (85×3 + 92×2 + 78×5) / (3+2+5).</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/average-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F522;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Average Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate the arithmetic mean, median, and mode of a data set.</p>
      </a>
      <a href="/tools/standard-deviation" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4CA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Standard Deviation</h3>
        <p class="mt-0.5 text-xs text-slate-500">Measure the spread and variation in your data.</p>
      </a>
      <a href="/tools/percentage-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4C8;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Percentage Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Work out percentages, proportions, and percentage changes.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const waInput = document.getElementById('wa-input');
    const waValue = document.getElementById('wa-value');
    const waResultMain = document.getElementById('wa-result-main');
    const waDetail = document.getElementById('wa-detail');
    const waNumeratorDisplay = document.getElementById('wa-numerator-display');
    const waDenominatorDisplay = document.getElementById('wa-denominator-display');
    const waSimpleCompare = document.getElementById('wa-simple-compare');

    function calculate() {
      const raw = waInput.value.trim();
      if (!raw) {
        waValue.textContent = '—';
        waDetail.classList.add('hidden');
        waResultMain.classList.remove('bg-red-600');
        waResultMain.classList.add('bg-indigo-600');
        return;
      }

      const pairs = raw.split(',').map(s => s.trim()).filter(s => s);
      const values = [];
      const weights = [];

      let valid = true;
      for (const pair of pairs) {
        const parts = pair.split(':');
        if (parts.length !== 2) { valid = false; break; }
        const v = parseFloat(parts[0].trim());
        const w = parseFloat(parts[1].trim());
        if (isNaN(v) || isNaN(w) || w < 0) { valid = false; break; }
        values.push(v);
        weights.push(w);
      }

      if (!valid || values.length === 0) {
        waValue.textContent = 'Invalid input';
        waDetail.classList.add('hidden');
        waResultMain.classList.remove('bg-indigo-600');
        waResultMain.classList.add('bg-red-600');
        return;
      }

      waResultMain.classList.remove('bg-red-600');
      waResultMain.classList.add('bg-indigo-600');

      const totalWeight = weights.reduce((s, w) => s + w, 0);
      if (totalWeight === 0) {
        waValue.textContent = 'Total weight is zero';
        waDetail.classList.add('hidden');
        return;
      }

      const weightedSum = values.reduce((s, v, i) => s + v * weights[i], 0);
      const result = weightedSum / totalWeight;
      const simpleAvg = values.reduce((s, v) => s + v, 0) / values.length;

      waValue.textContent = result.toLocaleString(undefined, { maximumFractionDigits: 4 });

      const numeratorParts = values.map((v, i) => `${v.toLocaleString()}×${weights[i].toLocaleString()}`);
      waNumeratorDisplay.innerHTML = `<span class="font-medium">Weighted sum:</span> ${numeratorParts.join(' + ')} = ${weightedSum.toLocaleString(undefined, { maximumFractionDigits: 2 })}`;
      waDenominatorDisplay.innerHTML = `<span class="font-medium">Total weight:</span> ${weights.join(' + ')} = ${totalWeight.toLocaleString()}`;
      waSimpleCompare.textContent = `Result = ${weightedSum.toLocaleString(undefined, { maximumFractionDigits: 2 })} / ${totalWeight.toLocaleString()} = ${result.toLocaleString(undefined, { maximumFractionDigits: 4 })} (simple average would be ${simpleAvg.toLocaleString(undefined, { maximumFractionDigits: 4 })})`;
      waDetail.classList.remove('hidden');
    }

    waInput.addEventListener('input', calculate);
    calculate();
  </script>
</ToolLayout>
