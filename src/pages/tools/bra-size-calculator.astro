---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Bra Size Calculator';
const description = 'Find your bra band and cup size in US and UK sizing from underbust and bust measurements.';
const intro = 'Convert underbust and bust measurements into a band and cup size.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I measure underbust and bust correctly?', a: 'Measure underbust snugly around your ribcage directly under the bust, keeping the tape level. Measure bust around the fullest part of your chest while wearing a non-padded bra, keeping the tape level and not pulled tight. Both should be in inches for this calculator.' },
  { q: 'Why is band size always an even number in US sizing?', a: 'US and UK band sizes are conventionally sold only in even numbers (30, 32, 34, 36...), so the underbust measurement is rounded to the nearest even number rather than used exactly as measured.' },
  { q: 'Do US and UK cup letters mean the same thing?', a: 'Not past D. US and UK sizing agree through A, B, C, and D, but the US then uses DD, DDD, and so on, while the UK uses DD, E, F, FF, G — so a US DDD is roughly a UK F, which causes real confusion when shopping across countries.' },
  { q: 'Why might my calculated size feel wrong once I try it on?', a: 'Bra fit depends heavily on brand, wire shape, and fabric stretch, not just the two measurements used here — this calculator gives a solid starting point for which sizes to try on, not a guaranteed exact fit.' },
];
const howTo = {
  name: 'How to calculate your bra size',
  steps: [
    { name: 'Measure underbust', text: 'Wrap a tape measure snugly around your ribcage, directly under the bust, in inches.' },
    { name: 'Measure bust', text: 'Wrap a tape measure around the fullest part of your bust, not pulled tight, in inches.' },
    { name: 'Read your size', text: 'Your band size and cup letter appear based on the difference between the two measurements.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Underbust (in)</span>
        <input id="under" type="number" step="any" placeholder="e.g. 30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Bust (in)</span>
        <input id="bust" type="number" step="any" placeholder="e.g. 34" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">US size</div><div id="r-us" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">UK size</div><div id="r-uk" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="brc-title brc-desc">
      <title id="brc-title">Underbust and bust measurement lines diagram</title>
      <desc id="brc-desc">Two horizontal dashed lines on a torso outline showing where to measure underbust and bust</desc>
      <path d="M340 20 Q300 20 290 60 Q280 110 300 160 Q320 190 400 190 Q480 190 500 160 Q520 110 510 60 Q500 20 460 20Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <line x1="270" y1="90" x2="530" y2="90" stroke="#1e293b" stroke-width="2" stroke-dasharray="6 3" />
      <text x="560" y="95" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Bust (fullest point)</text>
      <line x1="285" y1="140" x2="515" y2="140" stroke="#1e293b" stroke-width="2" stroke-dasharray="6 3" />
      <text x="545" y="145" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Underbust (band)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Band size comes from underbust; cup size comes from the difference to bust</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How bra sizing works</h2>
    <p class="mt-2 text-slate-600">
      Bra size is built from two separate measurements. Band size comes from your underbust circumference, rounded to the nearest even number since bands are conventionally sold only in even sizes (30, 32, 34, and so on). Cup size comes from the difference between your bust measurement and that band size — each full inch of difference steps up one cup letter, starting at AA for less than one inch of difference, A for one inch, B for two inches, C for three inches, D for four inches, and continuing upward from there.
    </p>
    <p class="mt-3 text-slate-600">
      This two-part system is why cup size is not a fixed physical size on its own — a D cup on a 30 band covers meaningfully less volume than a D cup on a 38 band, since cup size only measures the difference relative to that specific band, not an absolute size.
    </p>
    <p class="mt-3 text-xs text-slate-400">Sizing follows the standard band-plus-difference method used across the US and UK lingerie industry, cross-checked against common professional bra-fitting guidance.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A measured underbust of 29 inches and a bust of 36 inches.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Underbust:</span> <span class="text-slate-600">29 in → rounds to <strong>30</strong> (band)</span></div>
        <div><span class="font-medium text-slate-700">Bust:</span> <span class="text-slate-600">36 in</span></div>
        <div><span class="font-medium text-slate-700">Difference:</span> <span class="text-slate-600">36 − 30 = 6 in</span></div>
        <div><span class="font-medium text-slate-700">US size:</span> <span class="text-slate-600"><strong>30DDD</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Studies cited by professional bra fitters have long suggested a large majority of people wear the wrong band or cup size, most often a band that is too large paired with a cup that is too small — the two-measurement method here exists specifically to correct that common self-sizing error, since guessing based on a remembered size from years ago rarely accounts for weight or body changes since the last professional fitting.
    </p>
    <p class="mt-3 text-slate-600">
      Online shopping across US and UK retailers is where the cup-letter difference matters most in practice — a shopper who knows they wear a US DDD needs to look for a UK F on a British site, not a UK DDD, since the two countries' letter systems diverge above D.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A D cup is a specific, fixed size regardless of band." <strong class="text-slate-900">It isn't.</strong> Cup size is only meaningful relative to its band — a 30D and a 40D differ enormously in actual volume, even though both are labeled "D."</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Sister sizing means any nearby size will fit the same." <strong class="text-slate-900">Not quite.</strong> Sister sizes (like 32C and 34B) have the same cup volume but a different band circumference, so they fit differently around the ribcage even though the cup holds a similar volume.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/dress-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Dress Size Calculator</a>
      <a href="/tools/body-shape-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Body Shape Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const usCups = ['AA', 'A', 'B', 'C', 'D', 'DD', 'DDD', 'G', 'H', 'I', 'J'];
    const ukCups = ['AA', 'A', 'B', 'C', 'D', 'DD', 'E', 'F', 'FF', 'G', 'H'];

    function update() {
      const under = parseFloat(el('under').value);
      const bust = parseFloat(el('bust').value);
      if (!under || !bust || under <= 0 || bust <= 0 || bust < under) { el('results').classList.add('hidden'); return; }
      let band = Math.round(under);
      if (band % 2 !== 0) band += 1;
      let diff = Math.round(bust - band);
      if (diff < 0) diff = 0;
      if (diff > usCups.length - 1) diff = usCups.length - 1;
      el('r-us').textContent = band + usCups[diff];
      el('r-uk').textContent = band + ukCups[diff];
      el('results').classList.remove('hidden');
    }

    el('under').addEventListener('input', update);
    el('bust').addEventListener('input', update);
  </script>
</ToolLayout>
