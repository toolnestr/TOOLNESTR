    const RATINGS = [
      { min: 0,   label: '🐌 Beginner',  color: '#94a3b8' },
      { min: 20,  label: '📝 Learning',  color: '#64748b' },
      { min: 40,  label: '⚡ Average',   color: '#10b981' },
      { min: 60,  label: '🏃 Good',      color: '#3b82f6' },
      { min: 80,  label: '🏆 Fast',      color: '#6366f1' },
      { min: 100, label: '🚀 Pro',       color: '#f59e0b' },
      { min: 130, label: '🔥 Elite',     color: '#ef4444' },
    ];

    function getRating(wpm) {
      let r = RATINGS[0];
      for (const rt of RATINGS) { if (wpm >= rt.min) r = rt; }
      return r;
    }

    let state = 'idle';
    let selectedDur = 30;
    let selectedMode = 'general';
    let textIndex = {};
    let sourceText = '';
    let typedChars = [];
    let startTime = null;
    let timerInterval = null;
    let history = [];

    // DOM refs
    const displayWrap   = document.getElementById('displayWrap');
    const textDisplay   = document.getElementById('textDisplay');
    const hiddenInput   = document.getElementById('hiddenInput');
    const idleOverlay   = document.getElementById('idleOverlay');
    const idleSub       = document.getElementById('idleSub');
    const liveWpm       = document.getElementById('liveWpm');
    const liveAcc       = document.getElementById('liveAcc');
    const liveTimer     = document.getElementById('liveTimer');
    const liveErrors    = document.getElementById('liveErrors');
    const progFill      = document.getElementById('progFill');
    const resultsPanel  = document.getElementById('resultsPanel');
    const histWrap      = document.getElementById('histWrap');
    const histList      = document.getElementById('histList');

    function durLabel() {
      return selectedDur < 60 ? selectedDur + 's' : (selectedDur / 60) + ' min';
    }

    function modeLabel() {
      return selectedMode.charAt(0).toUpperCase() + selectedMode.slice(1);
    }

    function pickText(newText) {
      const pool = TEXTS[selectedMode];
      if (newText) {
        textIndex[selectedMode] = ((textIndex[selectedMode] || 0) + 1) % pool.length;
      }
      sourceText = pool[textIndex[selectedMode] || 0];
    }

    function renderSourceText() {
      textDisplay.innerHTML = sourceText.split('').map((ch, i) =>
        `<span class="char" data-i="${i}">${ch === ' ' ? '&nbsp;' : ch.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>`
      ).join('');
    }

    function updateDisplay() {
      const len = typedChars.length;
      sourceText.split('').forEach((_, i) => {
        const el = textDisplay.querySelector(`.char[data-i="${i}"]`);
        if (!el) return;
        el.className = 'char';
        if (i < len) el.classList.add(typedChars[i] === sourceText[i] ? 'correct' : 'wrong');
        else if (i === len) el.classList.add('current');
      });
      const cursor = textDisplay.querySelector('.char.current');
      if (cursor) cursor.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }

    function calcStats(elapsedSecs) {
      let correct = 0, errors = 0;
      typedChars.forEach((ch, i) => { ch === sourceText[i] ? correct++ : errors++; });
      const mins = Math.max(elapsedSecs, 0.1) / 60;
      const wpm  = Math.round((correct / 5) / mins);
      const acc  = typedChars.length > 0 ? Math.round((correct / typedChars.length) * 100) : 100;
      return { wpm, acc, correct, errors };
    }

    function updateLiveStats() {
      if (!startTime) return;
      const elapsed = (performance.now() - startTime) / 1000;
      const { wpm, acc, errors } = calcStats(elapsed);
      const remaining = Math.max(0, selectedDur - elapsed);
      liveWpm.textContent    = wpm;
      liveAcc.textContent    = acc + '%';
      liveTimer.textContent  = Math.ceil(remaining);
      liveErrors.textContent = errors;
      progFill.style.width   = ((remaining / selectedDur) * 100) + '%';
      if (remaining <= 0) { clearInterval(timerInterval); finishTest(); }
    }

    function revealText() {
      if (state !== 'idle') return;
      idleOverlay.style.display = 'none';
      displayWrap.classList.add('active');
      updateDisplay();
      hiddenInput.focus();
    }

    function startTest() {
      state = 'testing';
      startTime = performance.now();
      idleOverlay.style.display = 'none';
      displayWrap.classList.add('active');
      liveWpm.textContent = '0'; liveAcc.textContent = '100%'; liveErrors.textContent = '0';
      timerInterval = setInterval(updateLiveStats, 200);
    }

    function finishTest() {
      if (state !== 'testing') return;
      state = 'done';
      clearInterval(timerInterval);
      const elapsed = (performance.now() - startTime) / 1000;
      const { wpm, acc, correct, errors } = calcStats(elapsed);
      const rating = getRating(wpm);

      history.unshift({ wpm, acc, correct, errors, dur: selectedDur, mode: selectedMode });
      if (history.length > 5) history.pop();

      document.getElementById('rpRating').textContent = rating.label;
      document.getElementById('rpRating').style.background = rating.color;
      document.getElementById('rpWpm').textContent     = wpm;
      document.getElementById('rpAcc').textContent     = acc + '%';
      document.getElementById('rpCorrect').textContent = correct;
      document.getElementById('rpErrors').textContent  = errors;
      resultsPanel.classList.add('show');
      progFill.style.width  = '0%';
      liveTimer.textContent = '0';

      const done = document.createElement('div');
      done.className = 'done-overlay';
      done.innerHTML = `<div class="do-wpm">${wpm}</div><div class="do-label">WPM</div><div class="do-sub">${acc}% accuracy · ${modeLabel()} · click to retry</div>`;
      done.addEventListener('click', () => resetTest(false));
      displayWrap.appendChild(done);

      renderHistory();
    }

    function renderHistory() {
      if (!history.length) return;
      histWrap.style.display = 'block';
      const best = Math.max(...history.map(h => h.wpm));
      histList.innerHTML = history.map((h, i) => `
        <div class="hist-item ${h.wpm === best ? 'best' : ''}">
          <div class="hr">${i + 1}</div>
          <div class="hw">${h.wpm} WPM</div>
          <div class="hm">${h.acc}% · ${h.dur}s · ${h.mode} ${h.wpm === best ? '⭐ Best' : ''}</div>
        </div>`).join('');
    }

    function resetTest(newText) {
      clearInterval(timerInterval);
      state = 'idle'; typedChars = []; startTime = null; hiddenInput.value = '';
      if (newText) pickText(true); else pickText(false);
      renderSourceText();
      displayWrap.classList.remove('active');
      idleOverlay.style.display = '';
      idleSub.textContent = `${durLabel()} test · ${modeLabel()}`;
      resultsPanel.classList.remove('show');
      progFill.style.width = '100%';
      liveWpm.textContent = '–'; liveAcc.textContent = '–';
      liveTimer.textContent = selectedDur; liveErrors.textContent = '0';
      const done = displayWrap.querySelector('.done-overlay');
      if (done) done.remove();
    }

    // ── Input handling ──
    hiddenInput.addEventListener('input', () => {
      if (state === 'idle') startTest();
      if (state !== 'testing') return;
      typedChars = hiddenInput.value.split('').slice(0, sourceText.length);
      hiddenInput.value = typedChars.join('');
      updateDisplay();
      if (typedChars.length === sourceText.length) { clearInterval(timerInterval); finishTest(); }
    });
    hiddenInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') resetTest(false);
      if (['ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Home','End'].includes(e.key)) e.preventDefault();
    });

    idleOverlay.addEventListener('click', (e) => { e.stopPropagation(); revealText(); });
    displayWrap.addEventListener('click', () => { if (state === 'idle') revealText(); else hiddenInput.focus(); });
    document.addEventListener('keydown', (e) => {
      if (state === 'idle' && e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) hiddenInput.focus();
    });

    // Duration pills
    document.getElementById('durRow').addEventListener('click', (e) => {
      const pill = e.target.closest('.dur-pill');
      if (!pill) return;
      document.querySelectorAll('.dur-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      selectedDur = parseInt(pill.dataset.dur);
      resetTest(false);
    });

    // Mode pills
    document.getElementById('modeRow').addEventListener('click', (e) => {
      const pill = e.target.closest('.mode-pill');
      if (!pill) return;
      document.querySelectorAll('.mode-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      selectedMode = pill.dataset.mode;
      resetTest(true);
    });

    document.getElementById('heroShuffle').addEventListener('click', () => resetTest(true));
    document.getElementById('restartBtn').addEventListener('click', () => resetTest(false));
    document.getElementById('newTextBtn').addEventListener('click', () => resetTest(true));

    // Init
    pickText(false);
    renderSourceText();
    liveTimer.textContent = selectedDur;
  })();
  </script>
</BaseLayout>
