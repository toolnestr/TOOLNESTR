---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Pattern Grading Calculator';
const description = 'Scale a pattern piece measurement from one size to another using a target body measurement ratio, for accurate grading in pattern making.';
const intro = 'Scale a pattern piece measurement from one size to another target size.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is pattern grading?', a: 'Grading is the process of scaling a pattern up or down between sizes, adjusting every pattern piece so the finished garment matches a different size\'s body measurements while keeping the same style and proportions.' },
  { q: 'Does every part of a pattern grade by the same ratio?', a: 'No — professional grading uses different amounts of change at different points (a grade rule), since bust, waist, and length don\'t always grow at the same rate between sizes. This calculator applies one uniform scale ratio, which is a reasonable approximation for simple shapes but less precise than a full professional grade rule for complex garments.' },
  { q: 'Can I use this to grade between two different pattern brands?', a: 'Only roughly — this scales one specific measurement using a ratio, so it works best for adjusting a single pattern piece\'s dimension, not for translating an entire multi-piece pattern between brands with different base blocks.' },
  { q: 'Should I grade length the same way as width?', a: 'Not necessarily — height/length adjustments (like for a petite or tall size) often use a different ratio than width-based sizing (bust/waist/hip), so grade length changes separately using the appropriate target measurements.' },
];
const howTo = {
  name: 'How to grade a pattern piece',
  steps: [
    { name: 'Enter the original piece measurement', text: 'Enter the pattern piece\'s current measurement at the size it was drafted for.' },
    { name: 'Enter both body measurements', text: 'Enter the body measurement for the original size and your target size.' },
    { name: 'Read the scaled measurement', text: 'The new pattern piece measurement for your target size appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Original piece measurement (in)</span>
        <input id="piece" type="number" step="any" placeholder="e.g. 10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Original size body measurement (in)</span>
        <input id="origBody" type="number" step="any" placeholder="e.g. 36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Target size body measurement (in)</span>
        <input id="targetBody" type="number" step="any" placeholder="e.g. 40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Scaled piece measurement</div>
        <div id="r-new" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Scale factor</div><div id="r-factor" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="pgc-title pgc-desc">
      <title id="pgc-title">Small pattern piece scaled up to a larger version</title>
      <desc id="pgc-desc">A small trapezoid pattern shape next to a larger, proportionally scaled version of the same shape</desc>
      <path d="M150 80 L230 80 L245 140 L135 140 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <text x="190" y="160" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Original size</text>
      <path d="M420 50 L560 50 L585 160 L395 160 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <text x="490" y="180" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Target size</text>
      <path d="M270 105 L370 105" stroke="#94a3b8" stroke-width="2" marker-end="url(#arr)" />
      <defs><marker id="arr" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6 Z" fill="#94a3b8" /></marker></defs>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Grading scales every pattern piece by the same proportional ratio</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How pattern grading works</h2>
    <p class="mt-2 text-slate-600">
      This calculator finds a scale factor by dividing your target size's body measurement by the original size's body measurement, then applies that same factor to the pattern piece measurement. If a pattern is drafted for a 36-inch bust and you need it for a 40-inch bust, the scale factor is 40 ÷ 36 ≈ 1.111, and every relevant piece dimension gets multiplied by that same 1.111 factor.
    </p>
    <p class="mt-3 text-slate-600">
      This uniform-ratio approach is a simplification of professional grading, which typically applies different amounts of change at different points on a pattern (a "grade rule") since a body doesn't grow perfectly proportionally in every direction between sizes — but for straightforward pieces or a rough first-pass adjustment, scaling by a single ratio gives a reasonable working result.
    </p>
    <p class="mt-3 text-xs text-slate-400">This uses the standard proportional-scaling method as a simplified alternative to full professional grade-rule tables.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A bodice front piece measures 10 inches at the bust for a size drafted at a 36-inch bust, and needs scaling to a 40-inch bust.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Scale factor:</span> <span class="text-slate-600">40 ÷ 36 ≈ 1.111</span></div>
        <div><span class="font-medium text-slate-700">New piece measurement:</span> <span class="text-slate-600">10 × 1.111 ≈ <strong>11.11 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Sewists working from a pattern that only comes in one size, or that stops short of their actual measurements, use grading to extend it — self-published independent patterns and vintage patterns especially often have a narrower size range than major commercial pattern companies, making manual grading a practical necessity rather than an advanced-only skill.
    </p>
    <p class="mt-3 text-slate-600">
      Small production runs and made-to-order businesses use grading constantly to generate a full size range from one base pattern, though at production scale they typically rely on proper grade-rule software rather than a single uniform ratio, since customer fit complaints compound quickly across a full size run if proportions are off.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Grading a pattern up always makes it fit a bigger person perfectly." <strong class="text-slate-900">Not guaranteed.</strong> A simple ratio scale assumes proportional growth across the whole body, which isn't always true — a real fitting session or muslin test is still worthwhile after grading a pattern significantly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"The same scale factor works for both width and length changes." <strong class="text-slate-900">Often not.</strong> Bust/waist/hip width and body height/length don't necessarily scale by the same ratio between sizes, so grading vertical dimensions may need a separate calculation using height-based measurements instead.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/ease-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Ease Calculator</a>
      <a href="/tools/fba-sba-bust-adjustment-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">FBA/SBA Bust Adjustment Calculator</a>
      <a href="/tools/seam-allowance-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Seam Allowance Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const piece = parseFloat(el('piece').value);
      const origBody = parseFloat(el('origBody').value);
      const targetBody = parseFloat(el('targetBody').value);
      if (!piece || !origBody || !targetBody || piece <= 0 || origBody <= 0 || targetBody <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const factor = targetBody / origBody;
      const newPiece = piece * factor;
      el('r-factor').textContent = factor.toFixed(4);
      el('r-new').textContent = newPiece.toFixed(3) + ' in';
      el('results').classList.remove('hidden');
    }

    ['piece', 'origBody', 'targetBody'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
