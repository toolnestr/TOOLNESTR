---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Triangle Calculator';
const description =
  'Free triangle calculator. Enter the three side lengths to find the area, perimeter, all ' +
  'three angles and the triangle type. Instant and private.';
const intro =
  'Enter the three side lengths of a triangle to calculate its area, perimeter, angles and type.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'How is the area calculated?', a: 'From the three sides we use Heron\'s formula, which gives the exact area without needing the height.' },
  { q: 'How are the angles found?', a: 'Using the law of cosines, which calculates each angle from the three side lengths.' },
  { q: 'Why does it say "not a valid triangle"?', a: 'For a triangle to exist, each side must be shorter than the sum of the other two (the triangle inequality). If that fails, no triangle is possible.' },
  { q: 'What does "scalene" mean?', a: 'A scalene triangle has all three sides of different lengths. If two sides are equal, it\'s isosceles; if all three are equal, it\'s equilateral.' },
  { q: 'Can I enter decimal side lengths?', a: 'Yes — use decimal values like 4.5 for any side. The calculator handles decimals perfectly.' },
  { q: 'What does "obtuse" and "acute" mean?', a: 'An acute triangle has all angles less than 90°. An obtuse triangle has one angle greater than 90°. A right triangle has exactly one 90° angle.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Side a</span>
        <input id="a" type="number" step="any" value="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Side b</span>
        <input id="b" type="number" step="any" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Side c</span>
        <input id="c" type="number" step="any" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-sm opacity-80">Area</div><div id="r-area" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Perimeter</div><div id="r-perim" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Type</div><div id="r-type" class="mt-1 text-sm font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Angle A</div><div id="r-A" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Angle B</div><div id="r-B" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Angle C</div><div id="r-C" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="err" class="mt-3 hidden text-center text-sm text-red-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter the lengths of sides a, b and c of your triangle.</li>
      <li>The area, perimeter, triangle type and all three angles are calculated instantly.</li>
      <li>If the sides don’t form a valid triangle, an error message explains why.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Triangle calculations come up constantly in real-world problem solving. Architects and carpenters verify right angles in building layouts using the 3-4-5 rule. Surveyors calculate land areas from measured side lengths. Graphic designers compute angles for geometric logo designs. Students use it to check their geometry homework or prepare for exams. Even gardeners use it when planning triangular flower beds or diagonal paths.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Ensure every side length is positive and that the triangle inequality holds — the sum of any two sides must exceed the third.</li>
      <li>Use the same unit for all three sides (e.g., all in centimetres). The area will be in square units of whatever you entered.</li>
      <li>For right triangles, try a 3-4-5 triangle first to verify the calculator gives a right angle (90°) and area of 6.</li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this triangle calculator</h2>
    <p class="mt-2 text-slate-600">
      Give this calculator the three side lengths of any triangle and it works out everything else —
      the area (using Heron’s formula), the perimeter, all three interior angles, and whether the
      triangle is equilateral, isosceles or scalene, and right, acute or obtuse.
      Need trigonometry to solve for unknown sides? Use the <a href="/tools/scientific-calculator" class="font-medium text-indigo-600 hover:underline">Scientific Calculator</a>
      with sin, cos and tan functions to complement your triangle calculations.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const round = (n) => Math.round(n * 1e4) / 1e4;
    const deg = (r) => round(r * 180 / Math.PI);

    function update() {
      const a = parseFloat(el('a').value), b = parseFloat(el('b').value), c = parseFloat(el('c').value);
      const ids = ['area', 'perim', 'type', 'A', 'B', 'C'];
      if ([a, b, c].some((x) => isNaN(x) || x <= 0)) { ids.forEach((k) => (el('r-' + k).textContent = '—')); el('err').classList.add('hidden'); return; }
      if (a + b <= c || a + c <= b || b + c <= a) {
        ids.forEach((k) => (el('r-' + k).textContent = '—'));
        el('err').textContent = 'These sides don’t form a valid triangle.'; el('err').classList.remove('hidden'); return;
      }
      el('err').classList.add('hidden');
      const s = (a + b + c) / 2;
      const area = Math.sqrt(s * (s - a) * (s - b) * (s - c));
      const A = Math.acos((b * b + c * c - a * a) / (2 * b * c));
      const B = Math.acos((a * a + c * c - b * b) / (2 * a * c));
      const C = Math.PI - A - B;
      // type by sides
      let bySides = (a === b && b === c) ? 'Equilateral' : (a === b || b === c || a === c) ? 'Isosceles' : 'Scalene';
      const maxAngle = Math.max(A, B, C) * 180 / Math.PI;
      let byAngle = Math.abs(maxAngle - 90) < 0.01 ? 'right' : maxAngle > 90 ? 'obtuse' : 'acute';
      el('r-area').textContent = round(area);
      el('r-perim').textContent = round(a + b + c);
      el('r-type').textContent = `${bySides}, ${byAngle}`;
      el('r-A').textContent = deg(A) + '°';
      el('r-B').textContent = deg(B) + '°';
      el('r-C').textContent = deg(C) + '°';
    }
    ['a', 'b', 'c'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
