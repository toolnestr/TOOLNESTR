---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Triangle Calculator';
const description =
  'Free triangle calculator. Enter the three side lengths to find the area, perimeter, all ' +
  'three angles and the triangle type. Instant and private.';
const intro =
  'Enter the three side lengths of a triangle to calculate its area, perimeter, angles and type.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'How is the area calculated?', a: 'From the three sides we use Heron\'s formula, which gives the exact area without needing the height.' },
  { q: 'How are the angles found?', a: 'Using the law of cosines, which calculates each angle from the three side lengths.' },
  { q: 'Why does it say "not a valid triangle"?', a: 'For a triangle to exist, each side must be shorter than the sum of the other two (the triangle inequality). If that fails, no triangle is possible.' },
  { q: 'What does "scalene" mean?', a: 'A scalene triangle has all three sides of different lengths. If two sides are equal, it\'s isosceles; if all three are equal, it\'s equilateral.' },
  { q: 'Can I enter decimal side lengths?', a: 'Yes — use decimal values like 4.5 for any side. The calculator handles decimals perfectly.' },
  { q: 'What does "obtuse" and "acute" mean?', a: 'An acute triangle has all angles less than 90°. An obtuse triangle has one angle greater than 90°. A right triangle has exactly one 90° angle.' },
  { q: 'What is Heron\'s formula?', a: 'Heron\'s formula uses the semi-perimeter s = (a + b + c) / 2 and computes area as &radic;(s(s-a)(s-b)(s-c)). It works for any triangle.' },
  { q: 'Can I enter sides in any order?', a: 'Yes — the calculator labels angles A, B, C opposite sides a, b, c respectively, but the order of entry does not matter.' },
  { q: 'What if I only know two sides and an angle?', a: 'This calculator requires all three side lengths. Use the Scientific Calculator with trig functions for side-angle-side problems.' },
  { q: 'What units does the result use?', a: 'The area is in square units of whatever you entered (e.g., cm² if sides are in cm). Angles are shown in degrees.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Side a</span>
        <input id="a" type="number" step="any" value="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Side b</span>
        <input id="b" type="number" step="any" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Side c</span>
        <input id="c" type="number" step="any" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-sm opacity-80">Area</div><div id="r-area" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Perimeter</div><div id="r-perim" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Type</div><div id="r-type" class="mt-1 text-sm font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Angle A</div><div id="r-A" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Angle B</div><div id="r-B" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Angle C</div><div id="r-C" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="err" class="mt-3 hidden text-center text-sm text-red-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How common each triangle type is</h2>
    <p class="mt-2 text-slate-600">Triangles come in different shapes depending on their side lengths and angles. Here is how often each type appears in practice.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Scalene, acute</span><span class="text-slate-400">Most common — all sides and angles different</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Scalene, obtuse</span><span class="text-slate-400">One angle &gt; 90°, all sides different</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:75%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Isosceles</span><span class="text-slate-400">Two equal sides, two equal base angles</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:55%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Right</span><span class="text-slate-400">One 90° angle — common in construction</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:40%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Equilateral</span><span class="text-slate-400">All sides and angles equal — least common</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:15%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏗️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Architect</h3>
      <p class="mt-1 text-sm text-slate-600">Verify right angles in building layouts using the 3-4-5 rule and calculate roof pitch angles from side measurements.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Student</h3>
      <p class="mt-1 text-sm text-slate-600">Check geometry homework, verify triangle classifications and practise applying Heron\'s formula and the law of cosines.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🗺️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Surveyor</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate land parcel areas from measured boundary lengths without needing to survey every angle in the field.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎨</span>
      <h3 class="mt-2 font-semibold text-slate-900">Graphic Designer</h3>
      <p class="mt-1 text-sm text-slate-600">Compute precise angles for geometric logo designs, triangular UI elements and isometric illustration grids.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Triangle Type</th><th class="p-3">Side Properties</th><th class="p-3">Angle Properties</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Equilateral</td><td class="p-3">All three sides equal</td><td class="p-3">All angles are 60°</td></tr>
        <tr><td class="p-3 font-medium">Isosceles</td><td class="p-3">Two sides equal</td><td class="p-3">Two base angles equal</td></tr>
        <tr><td class="p-3 font-medium">Scalene</td><td class="p-3">All sides different</td><td class="p-3">All angles different</td></tr>
        <tr><td class="p-3 font-medium">Right</td><td class="p-3">Satisfies a² + b² = c²</td><td class="p-3">One angle = 90°</td></tr>
        <tr><td class="p-3 font-medium">Acute</td><td class="p-3">Any valid triangle</td><td class="p-3">All angles &lt; 90°</td></tr>
        <tr><td class="p-3 font-medium">Obtuse</td><td class="p-3">One side squared &gt; sum of squares of other two</td><td class="p-3">One angle &gt; 90°</td></tr>
        <tr><td class="p-3 font-medium">Degenerate</td><td class="p-3">One side equals sum of the other two</td><td class="p-3">Area = 0, points are collinear</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the triangle calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the three sides</h3>
        <p class="mt-1 text-sm text-slate-600">Type the lengths of sides a, b and c into the input fields. Use decimals if needed — any positive number works.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check the results</h3>
        <p class="mt-1 text-sm text-slate-600">The area, perimeter, triangle type and all three interior angles are calculated and displayed instantly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Validate your triangle</h3>
        <p class="mt-1 text-sm text-slate-600">If the sides do not satisfy the triangle inequality, the calculator tells you exactly why no triangle can exist.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accuracy</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Check the triangle inequality first</h3>
        <p class="mt-1 text-sm text-slate-600">Every side must be shorter than the sum of the other two. If one side equals the sum exactly, the triangle is degenerate (area = 0).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use consistent units for all sides</h3>
        <p class="mt-1 text-sm text-slate-600">If side a is in metres and side b in centimetres, convert first. The area is in square units of the unit you entered for all three sides.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Test with a 3-4-5 triangle first</h3>
        <p class="mt-1 text-sm text-slate-600">A 3-4-5 triangle should give a right angle (90° at the corner opposite the longest side) and area of exactly 6 — a great sanity check.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const round = (n) => Math.round(n * 1e4) / 1e4;
    const deg = (r) => round(r * 180 / Math.PI);

    function update() {
      const a = parseFloat(el('a').value), b = parseFloat(el('b').value), c = parseFloat(el('c').value);
      const ids = ['area', 'perim', 'type', 'A', 'B', 'C'];
      if ([a, b, c].some((x) => isNaN(x) || x <= 0)) { ids.forEach((k) => (el('r-' + k).textContent = '—')); el('err').classList.add('hidden'); return; }
      if (a + b <= c || a + c <= b || b + c <= a) {
        ids.forEach((k) => (el('r-' + k).textContent = '—'));
        el('err').textContent = 'These sides don\'t form a valid triangle.'; el('err').classList.remove('hidden'); return;
      }
      el('err').classList.add('hidden');
      const s = (a + b + c) / 2;
      const area = Math.sqrt(s * (s - a) * (s - b) * (s - c));
      const A = Math.acos((b * b + c * c - a * a) / (2 * b * c));
      const B = Math.acos((a * a + c * c - b * b) / (2 * a * c));
      const C = Math.PI - A - B;
      // type by sides
      let bySides = (a === b && b === c) ? 'Equilateral' : (a === b || b === c || a === c) ? 'Isosceles' : 'Scalene';
      const maxAngle = Math.max(A, B, C) * 180 / Math.PI;
      let byAngle = Math.abs(maxAngle - 90) < 0.01 ? 'right' : maxAngle > 90 ? 'obtuse' : 'acute';
      el('r-area').textContent = round(area);
      el('r-perim').textContent = round(a + b + c);
      el('r-type').textContent = `${bySides}, ${byAngle}`;
      el('r-A').textContent = deg(A) + '°';
      el('r-B').textContent = deg(B) + '°';
      el('r-C').textContent = deg(C) + '°';
    }
    ['a', 'b', 'c'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
