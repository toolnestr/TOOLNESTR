---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Cm to Feet"
  emoji="📏"
  fromUnit="centimeters" toUnit="feet"
  fromTitle="Centimeters" toTitle="Feet"
  fromSym="cm" toSym="ft"
  quantity="length"
  kind="factor" factor={0.0328084}
  reverseSlug="feet-to-cm" reverseLabel="Feet to Cm Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Great for height and room dimensions when you have a metric figure but think in feet."
/>
