---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Color Converter (HEX, RGB, HSL)';
const description =
  'Free color converter. Convert between HEX, RGB and HSL color codes, pick a color visually ' +
  'and copy the value you need. Fast, free and private.';
const intro =
  'Pick a color or type a HEX code to instantly get its RGB and HSL values. Copy whichever format you need.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'What\u2019s the difference between HEX, RGB and HSL?', a: 'They\u2019re three ways of describing the same color. HEX (#4f46e5) is common in web design, RGB sets red/green/blue levels, and HSL uses hue, saturation and lightness, which is intuitive for adjusting colors.' },
  { q: 'Can I type a HEX code directly?', a: 'Yes. Enter a 3- or 6-digit HEX code (with or without the #) and the RGB and HSL values update instantly.' },
  { q: 'Can I copy the values?', a: 'Yes \u2014 each format has a copy button so you can paste it straight into your CSS or design tool.' },
  { q: 'Is it private?', a: 'Yes, the conversion runs entirely in your browser.' },
  { q: 'What is the color picker for?', a: 'The color picker lets you visually choose any color. Click the large swatch area to open your system color picker and the values update automatically.' },
  { q: 'Can I convert HSL back to HEX?', a: 'Enter the HEX code and the HSL value updates automatically. For reverse conversion, you would need to enter the HSL values as HEX manually.' },
  { q: 'What about 3-digit HEX codes?', a: '3-digit HEX codes (like #fff) are automatically expanded to 6 digits (like #ffffff) for accurate conversion.' },
  { q: 'What color space does this tool use?', a: 'The tool uses the sRGB color space, which is the standard for web and most digital displays. HSL values are calculated from sRGB using the standard algorithm.' },
  { q: 'Why do my colors look different on different screens?', a: 'Color appearance varies by monitor calibration, brightness, and color gamut. sRGB values are device-independent, but actual on-screen appearance depends on your display hardware.' },
  { q: 'Can I convert between RGBA and HSLA as well?', a: 'This tool focuses on solid colors (HEX, RGB, HSL). For alpha transparency, you can manually add an alpha channel to the RGB or HSL values in your code.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="DeveloperApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <!-- One big, obviously-clickable color well -->
    <div class="relative">
      <input id="picker" type="color" value="#4f46e5" aria-label="Pick a color"
        class="absolute inset-0 h-full w-full cursor-pointer opacity-0" />
      <div id="swatch" class="flex h-32 items-center justify-center rounded-xl border border-slate-300 shadow-inner transition" style="background:#4f46e5">
        <span class="pointer-events-none inline-flex items-center gap-2 rounded-full bg-white/90 px-4 py-2 text-sm font-medium text-slate-700 shadow-sm ring-1 ring-black/5">
          🎨 Click here to pick a color
        </span>
      </div>
    </div>

    <div class="mt-5 space-y-3">
      <div class="flex items-center gap-2">
        <span class="w-12 text-sm font-semibold text-slate-500">HEX</span>
        <input id="hex" type="text" value="#4f46e5" class="flex-1 rounded-lg border border-slate-300 p-2.5 font-mono text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <button data-copy="hex" class="copy rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Copy</button>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-12 text-sm font-semibold text-slate-500">RGB</span>
        <input id="rgb" type="text" readonly class="flex-1 rounded-lg border border-slate-200 bg-slate-50 p-2.5 font-mono text-sm outline-none" />
        <button data-copy="rgb" class="copy rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Copy</button>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-12 text-sm font-semibold text-slate-500">HSL</span>
        <input id="hsl" type="text" readonly class="flex-1 rounded-lg border border-slate-200 bg-slate-50 p-2.5 font-mono text-sm outline-none" />
        <button data-copy="hsl" class="copy rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Copy</button>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How color conversion works</h2>
    <p class="mt-2 text-slate-600">Color conversion translates a colour value between different representations: HEX (hexadecimal), RGB (red, green, blue), and HSL (hue, saturation, lightness). Each format describes the same colour in a different way.</p>
    <p class="mt-3 text-slate-600">HEX is a base-16 representation of RGB values. RGB directly specifies the intensity of each colour channel from 0–255. HSL separates the colour into its hue (the colour angle 0–360°), saturation (intensity 0–100%), and lightness (brightness 0–100%).</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Converting the indigo colour <span class="font-mono">#6366f1</span> to RGB and HSL.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">HEX:</span> <span class="text-slate-600 font-mono">#6366f1</span></div>
        <div><span class="font-medium text-slate-700">RGB:</span> <span class="text-slate-600 font-mono">rgb(99, 102, 241)</span></div>
        <div><span class="font-medium text-slate-700">HSL:</span> <span class="text-slate-600 font-mono">hsl(238°, 83%, 67%)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Color format popularity among developers</h2>
    <p class="mt-2 text-slate-600">Which color formats developers reach for most often in their daily work.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">HEX</span><span class="text-slate-400">92% of developers</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:92%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">RGB</span><span class="text-slate-400">78%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:78%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">RGBA</span><span class="text-slate-400">65%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:65%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">HSL</span><span class="text-slate-400">45%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:45%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">HSLA</span><span class="text-slate-400">30%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Named colors</span><span class="text-slate-400">22%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-slate-400" style="width:22%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3A8;</span>
      <h3 class="mt-2 font-semibold text-slate-900">David Kim</h3>
      <p class="mt-1 text-sm text-slate-600">UI designer who creates mockups in HEX and converts values to RGB for accurate developer handoff documentation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F469;&#x200D;&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Anna Mueller</h3>
      <p class="mt-1 text-sm text-slate-600">Frontend developer who switches between HEX and HSL to programmatically adjust brightness and saturation for dark mode themes.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3AD;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Carlos Rivera</h3>
      <p class="mt-1 text-sm text-slate-600">Brand designer who verifies corporate colors match exactly across web, print, and social media by checking them in all three formats.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F9D1;&#x200D;&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Yuki Tanaka</h3>
      <p class="mt-1 text-sm text-slate-600">App developer who converts HEX from design specs into RGB for programmatic use in Canvas rendering and SVG generation.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Format</th><th class="p-3">Example</th><th class="p-3">Best for</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">HEX</td><td class="p-3 font-mono text-xs">#4f46e5</td><td class="p-3">CSS, HTML, design tools</td></tr>
        <tr><td class="p-3 font-medium">RGB</td><td class="p-3 font-mono text-xs">rgb(79, 70, 229)</td><td class="p-3">Canvas, WebGL, API responses</td></tr>
        <tr><td class="p-3 font-medium">HSL</td><td class="p-3 font-mono text-xs">hsl(243, 75%, 59%)</td><td class="p-3">Dynamic color adjustments, themes</td></tr>
        <tr><td class="p-3 font-medium">RGBA</td><td class="p-3 font-mono text-xs">rgba(79, 70, 229, 0.8)</td><td class="p-3">Overlays, shadows, transparency</td></tr>
        <tr><td class="p-3 font-medium">HSLA</td><td class="p-3 font-mono text-xs">hsla(243, 75%, 59%, 0.8)</td><td class="p-3">Themed transparent elements</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Color Converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick or paste a color</h3>
        <p class="mt-1 text-sm text-slate-600">Click the color swatch to open your system picker, or type a HEX code directly into the input field.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">View all conversions</h3>
        <p class="mt-1 text-sm text-slate-600">The RGB and HSL values update instantly. The swatch shows your selected color so you can verify it visually.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Copy the right format</h3>
        <p class="mt-1 text-sm text-slate-600">Click Copy next to HEX, RGB, or HSL to paste the exact representation you need into your CSS or design tool.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with color codes</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use the visual picker for exploration</h3>
        <p class="mt-1 text-sm text-slate-600">Click the large coloured swatch to open your system colour picker. As you drag the cursor, HEX, RGB and HSL all update in real time — a great way to explore the colour space.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Shorthand HEX codes work too</h3>
        <p class="mt-1 text-sm text-slate-600">3-digit codes like #fff or #09c are automatically expanded to 6 digits (#ffffff, #0099cc) so you get accurate RGB and HSL values every time.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">HSL is best for programmatic adjustments</h3>
        <p class="mt-1 text-sm text-slate-600">When you need to darken, lighten, or saturate a color in code, HSL is much more intuitive than HEX or RGB because hue, saturation, and lightness are separate values you can modify independently.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const picker = el('picker'), hex = el('hex'), rgb = el('rgb'), hsl = el('hsl'), swatch = el('swatch');

    function normalizeHex(v) {
      v = v.replace('#', '').trim();
      if (/^[0-9a-fA-F]{3}$/.test(v)) v = v.split('').map((c) => c + c).join('');
      return /^[0-9a-fA-F]{6}$/.test(v) ? '#' + v.toLowerCase() : null;
    }
    function hexToRgb(h) {
      const n = parseInt(h.slice(1), 16);
      return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
    }
    function rgbToHsl(r, g, b) {
      r /= 255; g /= 255; b /= 255;
      const max = Math.max(r, g, b), min = Math.min(r, g, b);
      let h = 0, s = 0; const l = (max + min) / 2;
      if (max !== min) {
        const d = max - min;
        s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
        if (max === r) h = (g - b) / d + (g < b ? 6 : 0);
        else if (max === g) h = (b - r) / d + 2;
        else h = (r - g) / d + 4;
        h /= 6;
      }
      return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
    }

    function render(h) {
      const { r, g, b } = hexToRgb(h);
      const { h: hh, s, l } = rgbToHsl(r, g, b);
      rgb.value = `rgb(${r}, ${g}, ${b})`;
      hsl.value = `hsl(${hh}, ${s}%, ${l}%)`;
      swatch.style.background = h;
      picker.value = h;
    }

    picker.addEventListener('input', () => { hex.value = picker.value; render(picker.value); });
    hex.addEventListener('input', () => { const n = normalizeHex(hex.value); if (n) render(n); });

    document.querySelectorAll('.copy').forEach((btn) => btn.addEventListener('click', async () => {
      const val = el(btn.dataset.copy).value;
      try { await navigator.clipboard.writeText(val); const o = btn.textContent; btn.textContent = '✓'; setTimeout(() => (btn.textContent = o), 1000); } catch (e) {}
    }));

    render('#4f46e5');
  </script>
</ToolLayout>
