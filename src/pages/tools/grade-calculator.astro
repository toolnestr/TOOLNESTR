---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Grade Calculator';
const description =
  'Free weighted grade calculator. Enter each assignment or exam score and its weight to work ' +
  'out your overall grade for the class. Add as many items as you need.';
const intro =
  'Enter each assessment’s score and how much it’s worth (its weight) to calculate your overall weighted grade.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'How is a weighted grade calculated?', a: 'Each score is multiplied by its weight, those are added together, and the total is divided by the sum of the weights. Weights don’t have to add up to 100.' },
  { q: 'What if my weights don’t total 100?', a: 'That’s fine — the calculator divides by whatever your weights add up to, so the result is always a correct weighted average.' },
  { q: 'Can I add more rows?', a: 'Yes — click “Add item” for each assignment, quiz or exam.' },
  { q: 'What if I don’t know the weight of an assignment?', a: 'Check your syllabus — most instructors publish the weight breakdown on the first day. You can also estimate and adjust later as you get more information.' },
  { q: 'How do I figure out what score I need on the final exam?', a: 'Add all your known grades with their weights, then add a row for the final with your target overall grade as the score. Adjust the final exam score until the overall grade matches your goal.' },
  { q: 'Can I use this for pass/fail classes?', a: 'Not directly — pass/fail grades don’t have percentage scores. For graded classes only.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-2 grid grid-cols-[1fr_auto_auto] gap-2 text-xs font-semibold uppercase tracking-wide text-slate-400">
      <span>Assessment (optional)</span><span class="w-24 text-center">Score %</span><span class="w-24 text-center">Weight %</span>
    </div>
    <div id="rows" class="space-y-2"></div>
    <button id="add" class="mt-3 rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">+ Add item</button>

    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Your overall grade</div>
      <div id="grade" class="mt-1 text-3xl font-bold">—</div>
      <div id="wsum" class="mt-1 text-sm opacity-80"></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this grade calculator</h2>
    <p class="mt-2 text-slate-600">
      Most classes weight assignments, quizzes and exams differently. This calculator combines all
      your scores by their weights to show your true overall grade — handy for tracking where you
      stand and figuring out what you need on what's left. For your overall semester performance, check our <a href="/tools/gpa-calculator" class="font-medium text-indigo-600 hover:underline">GPA Calculator</a>.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter an assessment name (optional), your score (as a percentage), and its weight towards the final grade.</li>
      <li>Click "Add item" for each graded component — assignments, quizzes, midterms, finals, etc.</li>
      <li>Your weighted overall grade and the total weight entered are shown at the bottom.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use this calculator throughout the semester to track your progress in any weighted class. It's especially useful before final exams to determine the score you need on the final to achieve a desired overall grade. Teachers can also use it to calculate final grades for their students.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Weights do not need to add up to 100% — the calculator handles any total correctly.</li>
      <li>To find out what score you need on a final exam, add it with your target overall grade as the score and see what's required.</li>
      <li>Enter scores as percentages (e.g. 85 for 85%) regardless of the original point values — the weight handles the scaling.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const rows = el('rows');

    function addRow(score = '', weight = '') {
      const div = document.createElement('div');
      div.className = 'gradeRow grid grid-cols-[1fr_auto_auto] gap-2 items-center';
      div.innerHTML =
        `<input type="text" placeholder="e.g. Midterm" class="rounded-lg border border-slate-300 p-2.5 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">` +
        `<input type="number" value="${score}" placeholder="0" class="g-score w-24 rounded-lg border border-slate-300 p-2.5 text-center text-sm outline-none focus:border-indigo-400">` +
        `<div class="flex items-center gap-1"><input type="number" value="${weight}" placeholder="0" class="g-weight w-20 rounded-lg border border-slate-300 p-2.5 text-center text-sm outline-none focus:border-indigo-400"><button class="del rounded p-1 text-red-500 hover:bg-red-50">✕</button></div>`;
      rows.appendChild(div);
      div.querySelector('.del').addEventListener('click', () => { div.remove(); update(); });
      div.querySelectorAll('input').forEach((i) => i.addEventListener('input', update));
      update();
    }

    function update() {
      let weighted = 0, wsum = 0;
      rows.querySelectorAll('.gradeRow').forEach((row) => {
        const s = parseFloat(row.querySelector('.g-score').value);
        const w = parseFloat(row.querySelector('.g-weight').value);
        if (!isNaN(s) && !isNaN(w)) { weighted += s * w; wsum += w; }
      });
      el('grade').textContent = wsum ? (weighted / wsum).toFixed(2) + '%' : '—';
      el('wsum').textContent = wsum ? `Total weight entered: ${wsum}%` : '';
    }

    el('add').addEventListener('click', () => addRow());
    addRow(90, 30); addRow(85, 30); addRow(80, 40);
  </script>
</ToolLayout>
