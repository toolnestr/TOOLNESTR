---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Grade Calculator';
const description =
  'Free weighted grade calculator. Enter each assignment or exam score and its weight to work out your overall weighted grade for the course.';
const intro =
  'Enter each assessment\'s score and how much it\'s worth (its weight) to calculate your overall weighted grade.';
const category = { id: 'everyday', name: 'Everyday' };
const faqs = [
  { q: 'How is a weighted grade calculated?', a: 'Each score is multiplied by its weight, those products are added together, and the total is divided by the sum of the weights. Weights don\'t have to add up to 100.' },
  { q: 'What if my weights don\'t total 100?', a: 'That\'s fine — the calculator divides by whatever your weights add up to, so the result is always a correct weighted average.' },
  { q: 'How do I figure out what I need on the final exam?', a: 'Add all your known grades with their weights, then add a row for the final with your target overall grade as the score. Adjust the final exam score until the overall grade matches your goal.' },
  { q: 'Can I add more rows?', a: 'Yes — click "Add item" for each assignment, quiz or exam. You can remove any row with the X button.' },
  { q: 'What if I don\'t know the weight of an assignment?', a: 'Check your syllabus — most instructors publish the weight breakdown on the first day. You can also estimate and adjust later as you get more information.' },
  { q: 'Can I use this for pass/fail classes?', a: 'Not directly — pass/fail grades don\'t have percentage scores. For graded classes only.' },
  { q: 'What is the difference between weighted and unweighted grades?', a: 'Weighted grades take into account that some assignments count more toward your final grade than others. Unweighted averages treat all assignments equally.' },
  { q: 'How accurate is this calculator?', a: 'It is mathematically exact for weighted averages. The accuracy depends on you entering the correct scores and weights from your syllabus.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-2 grid grid-cols-[1fr_auto_auto] gap-2 text-xs font-semibold uppercase tracking-wide text-slate-400">
      <span class="min-w-0 truncate">Assessment (optional)</span><span class="w-24 text-center">Score %</span><span class="w-24 text-center">Weight %</span>
    </div>
    <div id="rows" class="space-y-2"></div>
    <button id="add" class="mt-3 rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">+ Add item</button>

    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Your overall grade</div>
      <div id="grade" class="mt-1 text-3xl font-bold">—</div>
      <div id="wsum" class="mt-1 text-sm opacity-80"></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How weighted grade calculation works</h2>
    <p class="mt-2 text-slate-600">
      A weighted grade is calculated using the same principle as GPA: each score (as a percentage) is multiplied by its weight, the products are summed, and the total is divided by the sum of all weights. The formula is <code>Overall Grade = Σ(Score × Weight) ÷ Σ(Weight)</code>.
    </p>
    <p class="mt-3 text-slate-600">
      The key difference from a simple average is that assignments with higher weights contribute more to your final grade. If your final exam is worth 40% and homework is worth 10%, scoring well on the final has four times the impact of homework. This calculator handles any combination of weights — they don't need to sum to 100%.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Midterm: 90% (worth 30%), Final: 85% (worth 40%), Homework: 92% (worth 30%)</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Weighted sum:</span> <span class="text-slate-600">(90×30) + (85×40) + (92×30) = 8,860</span></div>
        <div><span class="font-medium text-slate-700">Total weight:</span> <span class="text-slate-600">30 + 40 + 30 = 100</span></div>
        <div><span class="font-medium text-slate-700">Final grade:</span> <span class="text-slate-600">8,860 ÷ 100 = <strong>88.60% (B+)</strong></span></div>
        <div><span class="font-medium text-slate-700">What-if:</span> <span class="text-slate-600">If final was 95% instead, grade becomes <strong>90.60% (A-)</strong></span></div>
      </div>
    </div>
  </section>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 200" width="800" height="200" role="img" aria-labelledby="grade-title grade-desc">
      <title id="grade-title">Letter Grade Threshold Scale</title>
      <desc id="grade-desc">A horizontal scale from 0 to 100 percent with colored segments showing F, D, C, B, and A letter grade boundaries</desc>
      <rect x="50" y="50" width="700" height="36" rx="18" fill="#f1f5f9" />
      <rect x="50" y="50" width="140" height="36" rx="18" fill="#ef4444" />
      <rect x="190" y="50" width="105" height="36" fill="#f97316" />
      <rect x="295" y="50" width="105" height="36" fill="#eab308" />
      <rect x="400" y="50" width="140" height="36" fill="#6366f1" />
      <rect x="540" y="50" width="210" height="36" rx="18" fill="#10b981" />
      <text x="120" y="73" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="15" font-weight="700">F</text>
      <text x="242" y="73" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="15" font-weight="700">D</text>
      <text x="347" y="73" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="15" font-weight="700">C</text>
      <text x="470" y="73" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="15" font-weight="700">B</text>
      <text x="645" y="73" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="15" font-weight="700">A</text>

      <line x1="50" y1="110" x2="750" y2="110" stroke="#cbd5e1" stroke-width="2" />
      <text x="50" y="135" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">0%</text>
      <text x="190" y="135" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">60%</text>
      <text x="295" y="135" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">70%</text>
      <text x="400" y="135" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">80%</text>
      <text x="540" y="135" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">90%</text>
      <text x="750" y="135" text-anchor="end" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">100%</text>

      <line x1="190" y1="93" x2="190" y2="110" stroke="#94a3b8" stroke-width="1" />
      <line x1="295" y1="93" x2="295" y2="110" stroke="#94a3b8" stroke-width="1" />
      <line x1="400" y1="93" x2="400" y2="110" stroke="#94a3b8" stroke-width="1" />
      <line x1="540" y1="93" x2="540" y2="110" stroke="#94a3b8" stroke-width="1" />

      <text x="400" y="170" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">Percentage score determines the letter grade</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Letter grades are assigned based on percentage thresholds along the grading scale</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different grade ranges mean</h2>
    <p class="mt-2 text-slate-600">Your overall percentage grade tells you where you stand and what you need to aim for.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">90–100% (A)</span><span class="text-slate-400">Excellent — top of the class</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">80–89% (B)</span><span class="text-slate-400">Good — above average</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:80%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">70–79% (C)</span><span class="text-slate-400">Satisfactory — meets expectations</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:70%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">60–69% (D)</span><span class="text-slate-400">Passing — below average</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:60%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Below 60% (F)</span><span class="text-slate-400">Failing — needs improvement</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:50%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📝</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students</h3>
      <p class="mt-1 text-sm text-slate-600">Track your progress in each class throughout the semester. Know exactly where you stand before final exams and what you need to hit your target grade.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teachers</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly calculate final grades for your students by entering their scores and the weight breakdown from your syllabus.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Parents</h3>
      <p class="mt-1 text-sm text-slate-600">Help your child understand their grade standing and work out what scores they need on upcoming assignments to improve.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎯</span>
      <h3 class="mt-2 font-semibold text-slate-900">Goal Setters</h3>
      <p class="mt-1 text-sm text-slate-600">Use the "what if" feature to set grade goals. Add hypothetical scores for unfinished assignments to see what you need to achieve an A or B.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Percentage</th><th class="p-3">Letter Grade</th><th class="p-3">GPA Points</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3">93–100%</td><td class="p-3 font-medium">A</td><td class="p-3">4.0</td></tr>
        <tr><td class="p-3">90–92%</td><td class="p-3 font-medium">A-</td><td class="p-3">3.7</td></tr>
        <tr><td class="p-3">87–89%</td><td class="p-3 font-medium">B+</td><td class="p-3">3.3</td></tr>
        <tr><td class="p-3">83–86%</td><td class="p-3 font-medium">B</td><td class="p-3">3.0</td></tr>
        <tr><td class="p-3">80–82%</td><td class="p-3 font-medium">B-</td><td class="p-3">2.7</td></tr>
        <tr><td class="p-3">77–79%</td><td class="p-3 font-medium">C+</td><td class="p-3">2.3</td></tr>
        <tr><td class="p-3">73–76%</td><td class="p-3 font-medium">C</td><td class="p-3">2.0</td></tr>
        <tr><td class="p-3">70–72%</td><td class="p-3 font-medium">C-</td><td class="p-3">1.7</td></tr>
        <tr><td class="p-3">67–69%</td><td class="p-3 font-medium">D+</td><td class="p-3">1.3</td></tr>
        <tr><td class="p-3">63–66%</td><td class="p-3 font-medium">D</td><td class="p-3">1.0</td></tr>
        <tr><td class="p-3">60–62%</td><td class="p-3 font-medium">D-</td><td class="p-3">0.7</td></tr>
        <tr><td class="p-3">Below 60%</td><td class="p-3 font-medium">F</td><td class="p-3">0.0</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the grade calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your assessments</h3>
        <p class="mt-1 text-sm text-slate-600">Add each assignment, quiz, or exam with your score (as a percentage) and its weight towards the final grade.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Watch it update</h3>
        <p class="mt-1 text-sm text-slate-600">Your weighted overall grade and total weight entered appear at the bottom, updating instantly as you type.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Run what-if scenarios</h3>
        <p class="mt-1 text-sm text-slate-600">Add future or hypothetical assessments to see what score you'd need to reach your target grade for the class.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate grade calculation</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Weights don't need to sum to 100</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator handles any total correctly. If you only know partial weights, enter them and the result adjusts automatically.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Find your final exam target</h3>
        <p class="mt-1 text-sm text-slate-600">Add all known grades, then add a row for the final exam. Adjust its score until the overall grade matches your goal — that's the score you need.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Enter percentages, not points</h3>
        <p class="mt-1 text-sm text-slate-600">Enter scores as percentages (e.g. 85 for 85%) regardless of the original point values. The weight handles any scaling differences.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why grade calculator accuracy matters</h2>
    <p class="mt-2 text-slate-600">
      Accurate grade calculation directly affects academic decisions that carry real consequences. A single percentage point miscalculation can mean the difference between an A- and a B+, which in turn affects your GPA, scholarship eligibility, and graduate school applications. Many students underestimate how heavily weighted final exams impact their overall grade. A final worth 40 percent combined with a midterm worth 30 percent means those two assessments alone determine 70 percent of your final grade. Knowing this early lets you allocate study time where it matters most rather than distributing effort evenly across all assignments.
    </p>
    <p class="mt-3 text-slate-600">
      The weighted average formula used by this calculator is the same method instructors and university systems use. By entering your scores and weights as they appear in your syllabus, you get the exact same result your professor will compute at the end of the term. This transparency eliminates the guessing game and lets you focus on improvement. The what-if feature is particularly powerful for goal setting. If you currently have an 82 percent with two assignments remaining, you can adjust hypothetical scores to see exactly what you need on each to reach an 85 or a 90. Without this insight, students often aim blindly or set unrealistic targets.
    </p>
    <p class="mt-3 text-slate-600">
      Parents helping their children with schoolwork benefit from the same clarity. Instead of vague conversations about doing better, you can point to specific assessment weights and target scores. Tutors use the calculator to show students exactly how their current performance maps to a final letter grade, making the connection between daily effort and semester outcomes visible and concrete.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const rows = el('rows');

    function addRow(score = '', weight = '') {
      const div = document.createElement('div');
      div.className = 'gradeRow grid grid-cols-[1fr_auto_auto] gap-2 items-center';
      div.innerHTML =
        `<input type="text" placeholder="e.g. Midterm" class="min-w-0 rounded-lg border border-slate-300 p-2.5 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">` +
        `<input type="number" value="${score}" placeholder="0" class="g-score w-24 rounded-lg border border-slate-300 p-2.5 text-center text-sm outline-none focus:border-indigo-400">` +
        `<div class="flex items-center gap-1"><input type="number" value="${weight}" placeholder="0" class="g-weight w-20 rounded-lg border border-slate-300 p-2.5 text-center text-sm outline-none focus:border-indigo-400"><button class="del rounded p-1 text-red-500 hover:bg-red-50">✕</button></div>`;
      rows.appendChild(div);
      div.querySelector('.del').addEventListener('click', () => { div.remove(); update(); });
      div.querySelectorAll('input').forEach((i) => i.addEventListener('input', update));
      update();
    }

    function update() {
      let weighted = 0, wsum = 0;
      rows.querySelectorAll('.gradeRow').forEach((row) => {
        const s = parseFloat(row.querySelector('.g-score').value);
        const w = parseFloat(row.querySelector('.g-weight').value);
        if (!isNaN(s) && !isNaN(w)) { weighted += s * w; wsum += w; }
      });
      el('grade').textContent = wsum ? (weighted / wsum).toFixed(2) + '%' : '—';
      el('wsum').textContent = wsum ? `Total weight entered: ${wsum}%` : '';
    }

    el('add').addEventListener('click', () => addRow());
    addRow(90, 30); addRow(85, 30); addRow(80, 40);
  </script>
</ToolLayout>
