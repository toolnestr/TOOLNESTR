---
import ToolLayout from '../../layouts/ToolLayout.astro';
import SubjectToolLibs from '../../components/SubjectToolLibs.astro';

const title = 'Free Fall Calculator';
const description = "Free fall calculator with a live 3D drop simulator and charts. Find time, final velocity and distance fallen for an object dropped under gravity (no air resistance), with worked examples.";
const intro = 'Enter a drop height, time, or final speed — the other two solve instantly, and a live 3D drop plus charts show the motion. Full worked examples and a physics explainer are below.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };
const faqs = [
  { q: 'What is free fall?', a: 'Free fall is the motion of an object under gravity alone, with no other force acting (air resistance neglected). In a vacuum every object falls at the same rate regardless of mass — a feather and a hammer dropped together land together.' },
  { q: 'What is the acceleration due to gravity?', a: "On Earth g ≈ 9.81 m/s² downward, so a falling object's speed increases by 9.81 m/s every second. On the Moon g = 1.62 m/s²; on Mars 3.71 m/s²; on Jupiter about 24.79 m/s²." },
  { q: 'How far does an object fall in one second?', a: 'From rest, an object falls about 4.9 m in the first second (h = ½ · 9.81 · 1²), then 14.7 m in the next second, then 24.5 m in the third. The distance in each successive second follows the odd-number ratio 1 : 3 : 5 : 7.' },
  { q: 'Does a heavier object fall faster?', a: 'No. In the free-fall model mass cancels out of the equations, so all objects accelerate at g and reach the ground together. Mass only matters once air resistance is included, which this calculator ignores.' },
  { q: 'How is free fall related to projectile motion?', a: 'Free fall is exactly the vertical part of projectile motion. A ball thrown horizontally falls at the same rate as one simply dropped from the same height — both hit the ground at the same instant.' },
  { q: 'Why does a skydiver stop speeding up?', a: 'Air resistance grows with speed. When the upward drag equals the downward weight the net force is zero, acceleration stops, and the skydiver coasts at terminal velocity (~53 m/s belly-down). That regime is beyond this idealised, drag-free calculator.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to use the Free Fall Calculator',
    description: 'Calculate the time, final velocity and distance fallen for an object dropped from rest under gravity.',
    step: [
      { '@type': 'HowToStep', name: 'Enter one known value', text: 'Type the drop height, the fall time, or the final velocity. Leave the ones you want to find blank.' },
      { '@type': 'HowToStep', name: 'Choose gravity', text: "Keep Earth's 9.81 m/s² or tap Moon, Mars or Jupiter to change g." },
      { '@type': 'HowToStep', name: 'Read the results', text: 'Height, time and final velocity all update instantly, and the 3D drop and charts redraw to match.' },
    ],
  })} />

  <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
    <span class="h-2 w-2 rounded-full bg-blue-500"></span> Physics
  </span>

  <style is:global>
    @media print {
      .no-print { display: none !important; }
      a[href]::after { content: none !important; }
      section { break-inside: avoid; }
    }
  </style>

  <!-- ============ CALCULATOR ============ -->
  <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
      <p class="text-sm text-slate-500">Enter any one value — the others solve instantly.</p>
      <div class="flex items-center gap-2">
        <div class="inline-flex overflow-hidden rounded-lg border border-slate-300 text-xs font-semibold">
          <button id="u-metric" type="button" class="bg-indigo-600 px-3 py-1.5 text-white">Metric</button>
          <button id="u-imperial" type="button" class="bg-white px-3 py-1.5 text-slate-600">Imperial</button>
        </div>
        <button id="btn-clear" type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 hover:bg-slate-50">Clear</button>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Drop height (h) <span class="u-len text-slate-400">m</span></span>
        <input id="height" type="number" step="any" placeholder="height fallen" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fall time (t) <span class="text-slate-400">s</span></span>
        <input id="time" type="number" step="any" placeholder="seconds" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Final velocity (v) <span class="u-vel text-slate-400">m/s</span></span>
        <input id="vel" type="number" step="any" placeholder="impact speed" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-4">
      <span class="flex items-center justify-between text-sm font-medium text-slate-700">Gravity (g) <span id="out-grav" class="font-mono text-indigo-600">9.81 <span class="u-acc">m/s²</span></span></span>
      <input id="grav" type="range" min="0.5" max="40" step="0.01" value="9.81" class="mt-2 w-full accent-indigo-600" />
      <div class="mt-2 flex flex-wrap gap-1.5 text-xs">
        <button type="button" class="planet rounded-md border border-slate-300 px-2 py-1 hover:bg-slate-50" data-g="9.81">Earth</button>
        <button type="button" class="planet rounded-md border border-slate-300 px-2 py-1 hover:bg-slate-50" data-g="1.62">Moon</button>
        <button type="button" class="planet rounded-md border border-slate-300 px-2 py-1 hover:bg-slate-50" data-g="3.71">Mars</button>
        <button type="button" class="planet rounded-md border border-slate-300 px-2 py-1 hover:bg-slate-50" data-g="24.79">Jupiter</button>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Height fallen</div><div id="r-height" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Time</div><div id="r-time" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Final velocity</div><div id="r-vel" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="fall-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ INTERACTIVE 3D DROP ============ -->
  <section class="mt-8 no-print">
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-bold text-slate-900">Live 3D drop</h2>
      <button id="btn-drop" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">▶ Drop</button>
    </div>
    <p class="mt-1 text-sm text-slate-500">Drag to orbit (touch works too). The ball falls the height you enter; press Drop to replay.</p>
    <div id="scene3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
    <p id="scene3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
  </section>

  <!-- ============ LIVE CHARTS ============ -->
  <section class="mt-10 no-print">
    <h2 class="text-lg font-bold text-slate-900">Motion graphs</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Distance fallen vs time (a parabola)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dist"></canvas></div>
      </figure>
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Velocity vs time (a straight line)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vel"></canvas></div>
      </figure>
      <figure class="sm:col-span-2">
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Distance fallen in each successive second — the 1 : 3 : 5 : 7 rule</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:260px;"><canvas id="chart-odd"></canvas></div>
      </figure>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How free fall is calculated</h2>
    <p class="mt-2 text-slate-600"><strong>The core idea in one line:</strong> a dropped object starts at rest and gains speed at a steady rate g, so the distance it covers grows with the <em>square</em> of the time while its speed grows straight in proportion to time.</p>
    <p class="mt-3 text-slate-600">Everything comes from the constant-acceleration kinematic equations with initial velocity zero. Each variable is defined right after it:</p>
    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      <li><span class="font-mono text-slate-800">h = ½ · g · t²</span> — the <strong>distance fallen</strong> after time t. Here g is gravity (9.81 m/s² on Earth).</li>
      <li><span class="font-mono text-slate-800">v = g · t</span> — the <strong>velocity</strong> after time t. Speed rises by g every second.</li>
      <li><span class="font-mono text-slate-800">v = √(2 · g · h)</span> — the <strong>impact velocity</strong> after falling a height h, obtained by eliminating t between the two equations above.</li>
    </ul>
    <p class="mt-4 text-slate-600">Rearranged, the same three formulas let you start from whichever quantity you know: given a height, the fall time is <span class="font-mono">t = √(2h / g)</span>; given a time, the height is <span class="font-mono">½gt²</span>; given a final speed, the time is <span class="font-mono">v / g</span>. That is exactly what the calculator does.</p>

    <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 1 — drop from a cliff</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> a stone is dropped from a 45 m cliff on Earth (g = 9.81 m/s²). Find the fall time and impact speed.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Time:</span> <span class="text-slate-600">t = √(2 · 45 / 9.81) = 3.03 s</span></div>
        <div><span class="font-medium text-slate-700">Impact speed:</span> <span class="text-slate-600">v = 9.81 · 3.03 = 29.71 m/s</span></div>
        <div class="sm:col-span-2"><span class="font-medium text-slate-700">Check (energy):</span> <span class="text-slate-600">v = √(2 · 9.81 · 45) = 29.71 m/s ✓</span></div>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 2 — the same drop on the Moon</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> the identical 45 m drop, but on the Moon (g = 1.62 m/s²). Gravity is about 6× weaker, so the fall is slower.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Time:</span> <span class="text-slate-600">t = √(2 · 45 / 1.62) = 7.45 s</span></div>
        <div><span class="font-medium text-slate-700">Impact speed:</span> <span class="text-slate-600">v = 1.62 · 7.45 = 12.07 m/s</span></div>
      </div>
      <p class="mt-2 text-xs text-slate-500">The time grows as 1/√g and the impact speed as √g, so a 6.05× weaker gravity gives a 2.46× longer fall and a 2.46× gentler landing. Tap "Moon" above to reproduce these numbers.</p>
    </div>
  </section>

  <!-- ============ STANDALONE 3D DIAGRAMS ============ -->
  <section class="mt-12 no-print">
    <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <div>
        <div id="diag-drop" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">1. Mass does not change the fall</h3>
        <p class="mt-1 text-sm text-slate-600">The heavy <span class="font-semibold text-red-500">red</span> ball and the light <span class="font-semibold text-sky-500">blue</span> ball are released together and stay level the whole way down — in a vacuum they hit the ground at the same instant, exactly as Apollo 15 showed with a hammer and a feather.</p>
      </div>
      <div>
        <div id="diag-strobe" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">2. The gaps grow as odd numbers</h3>
        <p class="mt-1 text-sm text-slate-600">Snapshots at equal time steps spread further and further apart on the way down — the spacing follows 1 : 3 : 5 : 7. That widening is what "accelerating" actually looks like.</p>
      </div>
    </div>
  </section>

  <!-- ============ COMPARISON TABLE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">A 20 m drop on different worlds</h2>
    <p class="mt-1 text-sm text-slate-600">Same height, same physics — only g changes. Weaker gravity means a longer, gentler fall.</p>
    <div class="mt-3 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full table-fixed text-center text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-2 py-2.5 text-left font-semibold sm:px-3">World</th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">g<span class="block text-[10px] font-normal text-slate-400">m/s²</span></th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Fall time<span class="block text-[10px] font-normal text-slate-400">s</span></th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Impact speed<span class="block text-[10px] font-normal text-slate-400">m/s</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700 tabular-nums">
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Moon</td><td class="px-2 py-2.5 sm:px-3">1.62</td><td class="px-2 py-2.5 sm:px-3">4.97</td><td class="px-2 py-2.5 sm:px-3">8.05</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Mars</td><td class="px-2 py-2.5 sm:px-3">3.71</td><td class="px-2 py-2.5 sm:px-3">3.28</td><td class="px-2 py-2.5 sm:px-3">12.18</td></tr>
          <tr class="bg-indigo-50 font-semibold text-indigo-700"><td class="px-2 py-2.5 text-left sm:px-3">Earth ★</td><td class="px-2 py-2.5 sm:px-3">9.81</td><td class="px-2 py-2.5 sm:px-3">2.02</td><td class="px-2 py-2.5 sm:px-3">19.81</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Jupiter</td><td class="px-2 py-2.5 sm:px-3">24.79</td><td class="px-2 py-2.5 sm:px-3">1.27</td><td class="px-2 py-2.5 sm:px-3">31.49</td></tr>
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-slate-400">★ Earth reference. Fall time scales as √(2h/g) and impact speed as √(2gh), so a 15× stronger gravity (Moon→Jupiter) shortens the fall ~3.9× and quadruples the landing speed.</p>
  </section>

  <!-- ============ REAL-WORLD CONTEXT ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Where free fall actually shows up</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🏗️ Construction &amp; workplace safety</h3>
        <p class="mt-1 text-sm text-slate-600">A dropped tool from height gains dangerous speed fast: a spanner falling 20 m hits at ~20 m/s (72 km/h). Safety engineers use v = √(2gh) to size netting, exclusion zones and hard-hat ratings.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🪂 Skydiving &amp; parachutes</h3>
        <p class="mt-1 text-sm text-slate-600">The first seconds of a jump are near-ideal free fall before drag matters. Canopy designers need the deployment speed to work out the opening shock the fabric and jumper must survive.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🎢 Rides, stunts &amp; games</h3>
        <p class="mt-1 text-sm text-slate-600">Drop-tower rides, film stunt falls onto air bags, and the gravity in countless video games all run on h = ½gt². Getting the deceleration distance right is the difference between a thrill and an injury.</p>
      </div>
    </div>
  </section>

  <!-- ============ MISCONCEPTIONS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Heavier things fall faster."</p>
        <p class="mt-1 text-sm text-slate-600">In a vacuum they don't — mass cancels out and everything accelerates at g. A bowling ball and a marble dropped together land together. The only reason a feather loses in air is drag, which this model ignores.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"An object falls a constant distance each second."</p>
        <p class="mt-1 text-sm text-slate-600">It falls further every second, because it keeps speeding up. The per-second distances follow 1 : 3 : 5 : 7 — the object covers 4.9 m in the first second but 34.3 m in the fourth.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Doubling the height doubles the fall time."</p>
        <p class="mt-1 text-sm text-slate-600">Time grows with the square root of height, not linearly. Doubling the drop height multiplies the fall time by only √2 ≈ 1.41. To double the time you need four times the height.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Free fall means weightless because there's no gravity."</p>
        <p class="mt-1 text-sm text-slate-600">It's the opposite — gravity is the <em>only</em> force acting. The floating "weightless" feeling comes from everything accelerating together, so there's no support force pushing back; gravity is fully present.</p>
      </div>
    </div>
  </section>

  <!-- ============ ASSUMPTIONS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Assumptions — and where this model breaks down</h2>
    <p class="mt-2 text-slate-600">This is the <strong>ideal (drag-free) free-fall model</strong>: exact in a vacuum and a good approximation for dense, compact objects over short drops. Its honest limits:</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="text-sm font-semibold text-slate-900">Air resistance is ignored</h3>
        <p class="mt-1 text-sm text-slate-600">Real drag grows with speed and eventually balances weight at terminal velocity. Light or long-falling objects reach far lower speeds than the formula predicts.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="text-sm font-semibold text-slate-900">Starts from rest</h3>
        <p class="mt-1 text-sm text-slate-600">This calculator assumes zero initial velocity. If the object is thrown downward, add v₀: v = v₀ + gt and h = v₀t + ½gt².</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="text-sm font-semibold text-slate-900">Gravity is constant</h3>
        <p class="mt-1 text-sm text-slate-600">g is treated as fixed. That holds near a planet's surface but not for falls from great altitude, where g weakens with distance.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="text-sm font-semibold text-slate-900">Purely vertical</h3>
        <p class="mt-1 text-sm text-slate-600">Any sideways motion turns the problem into projectile motion — but the vertical fall is still governed by these exact equations.</p>
      </div>
    </div>
  </section>

  <!-- ============ FORMULA SOURCES ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Formula sources &amp; further reading</h2>
    <p class="mt-2 text-slate-600">These are the standard constant-acceleration kinematics of introductory physics, traceable to:</p>
    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      <li>• <strong>OpenStax, <em>University Physics Volume 1</em></strong> — §3.5 "Free Fall" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/3-5-free-fall" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a></li>
      <li>• <strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 2, Motion Along a Straight Line (Free-Fall Acceleration).</li>
      <li>• <strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 2, Freely Falling Objects.</li>
    </ul>
    <p class="mt-3 text-xs text-slate-400">Standard gravity g = 9.80665 m/s² (rounded to 9.81), per the CGPM definition. Results rounded to two decimal places.</p>
  </section>

  <!-- ============ HOW TO USE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter one value</h3>
        <p class="mt-1 text-sm text-slate-600">Type the height, time, or final velocity. Leave the fields you want to find blank; switch metric/imperial with the toggle.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read all three</h3>
        <p class="mt-1 text-sm text-slate-600">Height, time and final velocity fill in together, and the 3D drop plus charts redraw to match.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Change worlds</h3>
        <p class="mt-1 text-sm text-slate-600">Tap Moon, Mars or Jupiter to change g and see how the same drop plays out elsewhere.</p>
      </div>
    </div>
  </section>

  <!-- ============ RELATED TOOLS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/projectile-motion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🎯</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Projectile Motion Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Range, height and time from launch speed.</p>
      </a>
      <a href="/tools/kinetic-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">⚡</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Kinetic Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">KE = ½mv² — solve for any variable.</p>
      </a>
      <a href="/tools/potential-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">📈</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Potential Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">PE = mgh — gravitational potential energy.</p>
      </a>
    </div>
  </section>

  <!-- Libraries: Three.js + Chart.js + shared subject kit (window.STK) -->
  <SubjectToolLibs />

  <script is:inline>
  (function () {
    'use strict';
    const { el, reduceMotion, fmt2: fmt, makeScene, mountResize, chartSetup } = window.STK;
    const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };
    const FT = 3.28084;
    let imperial = false;
    const units = () => imperial ? { vel: 'ft/s', len: 'ft', acc: 'ft/s²', g: 32.174 } : { vel: 'm/s', len: 'm', acc: 'm/s²', g: 9.81 };

    // ---- pure physics (from rest; units-agnostic, g just has to match) ----
    function solve(h, t, v, g) {
      let rh = NaN, rt = NaN, rv = NaN;
      if (!isNaN(h)) { if (h < 0) return { err: 'Height cannot be negative.' }; rt = Math.sqrt(2 * h / g); rv = g * rt; rh = h; }
      else if (!isNaN(t)) { if (t < 0) return { err: 'Time cannot be negative.' }; rh = 0.5 * g * t * t; rv = g * t; rt = t; }
      else if (!isNaN(v)) { if (v < 0) return { err: 'Velocity cannot be negative.' }; rt = v / g; rh = 0.5 * g * rt * rt; rv = v; }
      else return { empty: true };
      return { rh, rt, rv };
    }

    const charts = {};
    let scene3d = null, diagDrop = null, diagStrobe = null;
    let last = null;

    function updateAll() {
      const u = units();
      const h = parseFloat(el('height').value);
      const t = parseFloat(el('time').value);
      const v = parseFloat(el('vel').value);
      const g = parseFloat(el('grav').value) || u.g;
      el('out-grav').innerHTML = fmt(g) + ' <span class="u-acc">' + u.acc + '</span>';
      const errEl = el('fall-err');
      ['r-height', 'r-time', 'r-vel'].forEach((id) => (el(id).textContent = '—'));
      if (g <= 0) { errEl.textContent = 'Gravity must be positive.'; return; }
      const r = solve(h, t, v, g);
      if (r.empty) { errEl.textContent = ''; last = { h: 10, t: null, v: null, g, r: solve(10, NaN, NaN, g) }; drawWidgets(); return; }
      if (r.err) { errEl.textContent = r.err; return; }
      errEl.textContent = '';
      el('r-height').textContent = fmt(r.rh) + ' ' + u.len;
      el('r-time').textContent = fmt(r.rt) + ' s';
      el('r-vel').textContent = fmt(r.rv) + ' ' + u.vel;
      last = { h: r.rh, t: r.rt, v: r.rv, g, r };
      drawWidgets();
      syncUrl();
    }

    function drawWidgets() {
      try { if (charts.ready) updateCharts(); } catch (e) {}
      try { if (scene3d) scene3d.setDrop(); } catch (e) {}
    }

    function syncUrl() {
      if (!last) return;
      const p = new URLSearchParams();
      if (!isNaN(parseFloat(el('height').value))) p.set('h', el('height').value);
      else if (!isNaN(parseFloat(el('time').value))) p.set('t', el('time').value);
      else if (!isNaN(parseFloat(el('vel').value))) p.set('v', el('vel').value);
      p.set('g', el('grav').value); p.set('u', imperial ? 'i' : 'm');
      history.replaceState(null, '', '?' + p.toString());
    }

    ['height', 'time', 'vel'].forEach((id) => el(id).addEventListener('input', () => {
      // only one input drives the solve; clear the others so the intent is unambiguous
      ['height', 'time', 'vel'].forEach((o) => { if (o !== id) el(o).value = ''; });
      updateAll();
    }));
    el('grav').addEventListener('input', updateAll);
    document.querySelectorAll('.planet').forEach((b) => b.addEventListener('click', () => { el('grav').value = b.getAttribute('data-g'); updateAll(); }));
    el('btn-clear').addEventListener('click', () => { ['height', 'time', 'vel'].forEach((id) => (el(id).value = '')); updateAll(); });

    // unit toggle
    function setUnits(toImperial) {
      if (toImperial === imperial) return;
      const factor = toImperial ? FT : 1 / FT;
      // convert whichever length/velocity field the user has filled
      const hv = parseFloat(el('height').value); if (!isNaN(hv)) el('height').value = Math.round(hv * factor * 100) / 100;
      const vv = parseFloat(el('vel').value); if (!isNaN(vv)) el('vel').value = Math.round(vv * factor * 100) / 100;
      imperial = toImperial;
      el('grav').value = units().g;
      el('u-metric').className = 'px-3 py-1.5 ' + (imperial ? 'bg-white text-slate-600' : 'bg-indigo-600 text-white');
      el('u-imperial').className = 'px-3 py-1.5 ' + (imperial ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600');
      document.querySelectorAll('.u-vel').forEach((x) => (x.textContent = units().vel));
      document.querySelectorAll('.u-len').forEach((x) => (x.textContent = units().len));
      document.querySelectorAll('.u-acc').forEach((x) => (x.textContent = units().acc));
      updateAll();
    }
    el('u-metric').addEventListener('click', () => setUnits(false));
    el('u-imperial').addEventListener('click', () => setUnits(true));

    // restore from URL
    (function restore() {
      const p = new URLSearchParams(location.search);
      if (p.get('u') === 'i') { imperial = true; el('u-metric').className = 'bg-white px-3 py-1.5 text-slate-600'; el('u-imperial').className = 'bg-indigo-600 px-3 py-1.5 text-white'; document.querySelectorAll('.u-vel').forEach((x) => (x.textContent = 'ft/s')); document.querySelectorAll('.u-len').forEach((x) => (x.textContent = 'ft')); document.querySelectorAll('.u-acc').forEach((x) => (x.textContent = 'ft/s²')); }
      if (p.has('h')) el('height').value = p.get('h');
      else if (p.has('t')) el('time').value = p.get('t');
      else if (p.has('v')) el('vel').value = p.get('v');
      if (p.has('g')) el('grav').value = p.get('g');
    })();

    // ================= CHARTS =================
    function initCharts() {
      if (!window.Chart) return;
      const base = chartSetup();
      charts.dist = new Chart(el('chart-dist'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'Distance fallen', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Distance' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.vel = new Chart(el('chart-vel'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'Velocity', data: [], borderColor: '#0ea5e9', pointRadius: 0, tension: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Velocity' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.odd = new Chart(el('chart-odd'), {
        type: 'bar',
        data: { labels: [], datasets: [{ label: 'Distance in that second', data: [], backgroundColor: '#f59e0b' }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Second number' } }, y: { title: { display: true, text: 'Distance fallen' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.ready = true;
      updateCharts();
    }
    function updateCharts() {
      if (!charts.ready || !last) return;
      const g = last.g, tF = Math.max(last.t || Math.sqrt(2 * last.h / g), 0.1);
      const T = [], D = [], V = [];
      for (let i = 0; i <= 40; i++) { const t = tF * i / 40; T.push(+t.toFixed(2)); D.push(+(0.5 * g * t * t).toFixed(3)); V.push(+(g * t).toFixed(3)); }
      charts.dist.data.labels = T; charts.dist.data.datasets[0].data = D; charts.dist.update();
      charts.vel.data.labels = T; charts.vel.data.datasets[0].data = V; charts.vel.update();
      // per-second distances (integer seconds up to ceil(tF), capped at 8)
      const n = Math.max(1, Math.min(8, Math.ceil(tF)));
      const L = [], B = [];
      for (let s = 1; s <= n; s++) { L.push(s + ''); B.push(+(0.5 * g * (s * s - (s - 1) * (s - 1))).toFixed(2)); }
      charts.odd.data.labels = L; charts.odd.data.datasets[0].data = B; charts.odd.update();
    }

    // ================= 3D DROP =================
    function initScene3d() {
      const c = el('scene3d'); if (!c) throw new Error('no container');
      const s = makeScene(c, 15, new THREE.Vector3(0, 3, 0), OPTS);
      const grid = new THREE.GridHelper(16, 16, 0xcbd5e1, 0xe2e8f0); s.scene.add(grid);
      const ball = new THREE.Mesh(new THREE.SphereGeometry(0.4, 24, 24), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
      s.scene.add(ball);
      const H = 9; // scene-space top height the drop maps to
      let animating = false, animT = 0, dur = 1;
      function setDrop() {
        if (!last) return;
        ball.position.set(0, H, 0);
        dur = Math.max(0.4, Math.min(4, last.t || Math.sqrt(2 * last.h / last.g)));
        animT = 0; animating = true;
      }
      el('btn-drop').addEventListener('click', setDrop);
      let prev = performance.now();
      function frame(now) {
        requestAnimationFrame(frame);
        const dt = Math.min(0.05, (now - prev) / 1000); prev = now;
        if (!reduceMotion) s.spin(0.0016);
        if (animating) {
          animT += dt;
          const frac = Math.min(1, animT / dur);
          // quadratic ease matches h ∝ t²
          ball.position.y = H * (1 - frac * frac);
          if (frac >= 1) animating = false;
        }
        s.renderer.render(s.scene, s.camera);
      }
      requestAnimationFrame(frame);
      scene3d = { setDrop, resize: s.resize };
      setDrop();
    }

    // ---- diagram: two balls, equal fall ----
    function initDiagDrop() {
      const c = el('diag-drop'); if (!c) throw new Error('no container');
      const s = makeScene(c, 13, new THREE.Vector3(0, 2, 0), OPTS);
      s.scene.add(new THREE.GridHelper(12, 12, 0xe2e8f0, 0xeef2f7));
      const heavy = new THREE.Mesh(new THREE.SphereGeometry(0.6, 20, 20), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
      const light = new THREE.Mesh(new THREE.SphereGeometry(0.3, 20, 20), new THREE.MeshStandardMaterial({ color: 0x0ea5e9 }));
      heavy.position.x = -1.6; light.position.x = 1.6; s.scene.add(heavy); s.scene.add(light);
      const H = 7; let t = 0;
      function frame() {
        requestAnimationFrame(frame);
        if (!reduceMotion) { s.spin(0.003); t += 0.012; const frac = (t % 1.6) / 1.6; const y = H * (1 - frac * frac); heavy.position.y = y; light.position.y = y; }
        s.renderer.render(s.scene, s.camera);
      }
      frame();
      diagDrop = { resize: s.resize };
    }

    // ---- diagram: strobe snapshots (odd-number spacing) ----
    function initDiagStrobe() {
      const c = el('diag-strobe'); if (!c) throw new Error('no container');
      const s = makeScene(c, 14, new THREE.Vector3(0, 0, 0), OPTS);
      const mat = new THREE.MeshStandardMaterial({ color: 0x6366f1 });
      const top = 6;
      for (let i = 0; i <= 5; i++) {
        const frac = i / 5;                 // equal time steps
        const y = top - 12 * frac * frac;   // position ∝ t² (downward)
        const m = new THREE.Mesh(new THREE.SphereGeometry(0.32, 16, 16), mat);
        m.position.set(0, y, 0); s.scene.add(m);
      }
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagStrobe = { resize: s.resize };
    }

    // ================= BOOT =================
    function boot() {
      try { updateAll(); } catch (e) { console.error('[free-fall] calc init failed', e); }
      try { initCharts(); } catch (e) { console.error('[free-fall] charts failed', e); }
      if (window.THREE) {
        try { initScene3d(); } catch (e) { console.error('[free-fall] 3D failed', e); el('scene3d-fallback').classList.remove('hidden'); }
        try { initDiagDrop(); } catch (e) { console.error('[free-fall] drop diagram failed', e); }
        try { initDiagStrobe(); } catch (e) { console.error('[free-fall] strobe diagram failed', e); }
      } else {
        el('scene3d-fallback').classList.remove('hidden');
      }
      updateAll();
      mountResize([scene3d, diagDrop, diagStrobe]);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
  </script>
</ToolLayout>
