---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Concrete Driveway Cost Calculator';
const description = 'Estimate the cost to pour a concrete driveway from its area, slab thickness and a price-per-square-foot range for basic, standard or decorative finishes.';
const intro = 'Estimate the cost to pour a concrete driveway, from its size and finish quality.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much does a concrete driveway cost?', a: 'A rough estimate runs $6-8 per square foot for a basic broom-finished driveway, $8-12 for a standard finish with rebar reinforcement, and $12-20+ for decorative finishes like stamped or colored concrete. A 600 sq ft basic driveway: 600 × $7 = $4,200.' },
  { q: 'What drives concrete driveway cost up?', a: 'Thicker slabs (6 inches for driveways vs. 4 for sidewalks), rebar or wire mesh reinforcement, decorative stamping or coloring, site preparation for poor soil, and any demolition of an existing driveway all push cost toward the higher end of a range.' },
  { q: 'Does this include the base preparation?', a: 'This is a rough all-in estimate covering typical base prep, forming, reinforcement, and the pour itself for a straightforward site. Difficult access, poor drainage, or unusual soil conditions can add cost beyond this estimate.' },
  { q: 'How thick should a concrete driveway be?', a: 'A standard residential driveway for cars is typically poured 4 to 6 inches thick; areas expecting heavier vehicles like RVs or trucks often go thicker, around 6 to 8 inches, sometimes with additional reinforcement.' },
];
const howTo = {
  name: 'How to estimate concrete driveway cost',
  steps: [
    { name: 'Measure the driveway', text: 'Measure the length and width of the driveway area in feet.' },
    { name: 'Pick a finish tier', text: 'Choose basic, standard with reinforcement, or decorative/stamped finish.' },
    { name: 'Get a local quote', text: 'Use the estimate as a starting point, then confirm the exact price with a contractor.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="len" type="number" step="any" placeholder="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="width" type="number" step="any" placeholder="15" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Finish tier</span>
        <select id="tier" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="7" selected>Basic broom finish ($6-8/ft²)</option>
          <option value="10">Standard w/ reinforcement ($8-12/ft²)</option>
          <option value="16">Decorative/stamped ($12-20+/ft²)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated cost</div>
        <div id="r-cost" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Driveway area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dc-title dc-desc">
      <title id="dc-title">Concrete driveway cost from area and finish tier</title>
      <desc id="dc-desc">A concrete driveway slab with the cost-per-square-foot formula</desc>
      <rect x="70" y="100" width="240" height="70" fill="#e2e8f0" stroke="#94a3b8" stroke-width="1.5" />
      <line x1="70" y1="100" x2="310" y2="100" stroke="#cbd5e1" stroke-width="1" />
      <text x="190" y="188" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">driveway area</text>
      <rect x="420" y="55" width="330" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Driveway cost</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">cost = area &times; $/ft&sup2;</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">finish tier sets the rate</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Reinforcement and decorative finishes push the per-square-foot rate higher.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the concrete driveway cost calculator works</h2>
    <p class="mt-2 text-slate-600">
      Concrete driveway cost scales with area, so the estimate starts with length times width, then multiplies by a cost-per-square-foot figure that depends on the finish quality. A basic broom-finished driveway, the simplest and most common residential option, runs roughly $6 to $8 per square foot installed. Adding rebar or wire mesh reinforcement for extra durability pushes a standard driveway to about $8 to $12 per square foot, and decorative options like stamped patterns or integral coloring run $12 to $20 or more.
    </p>
    <p class="mt-3 text-slate-600">
      These figures are an all-in estimate covering typical site prep, forming, reinforcement appropriate to the tier, and the pour itself for a straightforward, accessible site. Difficult access for concrete trucks, poor soil requiring extra excavation or base material, demolition of an existing driveway, or unusual drainage needs can all add cost beyond this baseline estimate — get a site-specific quote from a concrete contractor for an accurate number.
    </p>
    <p class="mt-3 text-slate-600">
      Slab thickness is a separate factor from finish tier in real-world pricing, though it's folded into these general per-square-foot ranges. Standard residential driveways for passenger vehicles are typically 4 to 6 inches thick; areas that need to support heavier vehicles like RVs or box trucks are often poured thicker, around 6 to 8 inches, sometimes with more robust reinforcement.
    </p>
    <p class="mt-3 text-xs text-slate-400">Slab thickness and reinforcement guidance follow ACI 330 (Guide for Design and Construction of Concrete Parking Lots) and typical residential practice recommended by the American Concrete Institute.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the driveway</h3>
        <p class="mt-1 text-sm text-slate-600">Length and width in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a finish tier</h3>
        <p class="mt-1 text-sm text-slate-600">Basic, standard, or decorative.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get a local quote</h3>
        <p class="mt-1 text-sm text-slate-600">Confirm the exact price with a contractor.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= L &times; W</span>. A 40×15 ft driveway: 40 × 15 = <strong>600 ft²</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Basic finish cost</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= area &times; $7/ft&sup2;</span> = 600 × 7 = <strong>$4,200</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Decorative finish cost</p>
        <p class="mt-1 text-slate-600">
          Same driveway: 600 × $16 = <strong>$9,600</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 50×18 ft standard-tier driveway with reinforcement.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Area:</span> <span class="text-slate-600">50 × 18 = 900 ft²</span></div>
        <div><span class="font-medium text-slate-700">Rate:</span> <span class="text-slate-600">$10/ft² (standard)</span></div>
        <div><span class="font-medium text-slate-700">Cost:</span> <span class="text-slate-600">900 × 10 = <strong>$9,000</strong></span></div>
        <div><span class="font-medium text-slate-700">Note:</span> <span class="text-slate-600">confirm with a local contractor quote</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the driveway cost calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏡</span>
        <h3 class="mt-2 font-semibold text-slate-900">Single-car driveway replacement</h3>
        <p class="mt-1 text-sm text-slate-600">A compact 20 × 10 ft driveway at the basic tier costs roughly 200 ft² × $7 = $1,400 — a useful baseline before soliciting bids for a small residential replacement.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚗</span>
        <h3 class="mt-2 font-semibold text-slate-900">Two-car or wide driveway</h3>
        <p class="mt-1 text-sm text-slate-600">Wider driveways that fit two vehicles side by side scale the area quickly, and a standard reinforced finish adds meaningful durability for the extra traffic load.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">✨</span>
        <h3 class="mt-2 font-semibold text-slate-900">Curb-appeal upgrades</h3>
        <p class="mt-1 text-sm text-slate-600">Stamped or colored concrete raises resale appeal but roughly doubles or triples the per-square-foot rate versus a basic broom finish, so comparing tiers side by side helps set a realistic budget.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚚</span>
        <h3 class="mt-2 font-semibold text-slate-900">RV or heavy-vehicle pads</h3>
        <p class="mt-1 text-sm text-slate-600">Driveways or pads meant for RVs, boats, or trucks typically need thicker slabs and more reinforcement, pushing cost toward the standard or decorative tier even without decorative finishing.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A small single-car driveway replacement is the low end of the range this calculator covers. At 20 ft by 10 ft with a basic broom finish, the area is 200 square feet, and at $7 per square foot the estimated cost is 200 × 7 = $1,400. Homeowners with tight budgets or small lots often land in this range, and because the total dollar amount is modest, the difference between contractor bids can matter more than the finish tier itself.
    </p>
    <p class="mt-3 text-slate-600">
      A wide, long driveway for a two-car garage with a circular turnaround shows how quickly area — and therefore cost — scales. A 60 ft by 25 ft driveway at the standard reinforced tier covers 1,500 square feet, and at $10 per square foot that comes to 1,500 × 10 = $15,000. This is a realistic range for larger suburban properties, and it illustrates why getting the area measurement right matters more than fine-tuning the rate: a 10% error in length or width is a 10% error in the final bid.
    </p>
    <p class="mt-3 text-slate-600">
      A decorative, stamped driveway on the higher end shows the cost of finish quality directly. A 70 ft by 20 ft driveway — 1,400 square feet — priced at the decorative rate of $16 per square foot comes to 1,400 × 16 = $22,400, more than 15 times the cost of the small basic driveway above despite having only 7 times the area. Decorative finishes are a legitimate way to raise curb appeal and resale value, but they are also the single biggest lever on total project cost.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A quote from one contractor tells me what the going rate is." <strong class="text-slate-900">Rates vary widely by region and by contractor.</strong> Labor cost, local concrete pricing, permit requirements, and demand all shift the per-square-foot range. Use this calculator's ranges as a sanity check on bids, not as a substitute for getting two or three local quotes.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Doubling the driveway's thickness doubles its strength for the same cost." <strong class="text-slate-900">Thickness and reinforcement aren't interchangeable.</strong> A thicker slab does add load capacity, but properly placed rebar or wire mesh often delivers more strength per dollar than simply pouring more concrete, and combining a modest thickness increase with reinforcement is usually the more cost-effective route for driveways that need to support heavier vehicles.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/concrete-slab-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Slab Calculator</a>
      <a href="/tools/asphalt-driveway-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Asphalt Driveway Calculator</a>
      <a href="/tools/concrete-weight-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Weight Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('len').value);
      const W = parseFloat(el('width').value);
      const rate = parseFloat(el('tier').value);
      if (!(L > 0 && W > 0)) { el('results').classList.add('hidden'); return; }
      const area = L * W;
      const cost = area * rate;

      el('r-cost').textContent = '$' + Math.round(cost).toLocaleString();
      el('r-note').textContent = area.toFixed(0) + ' ft² at $' + rate + '/ft²';
      el('r-area').textContent = area.toFixed(0) + ' ft²';
      el('results').classList.remove('hidden');
    }

    ['len', 'width'].forEach((id) => el(id).addEventListener('input', update));
    el('tier').addEventListener('change', update);
  </script>
</ToolLayout>
