---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Probability Calculator';
const description = 'Calculate probabilities of single events, AND (intersection), OR (union), and conditional probability. Free online probability calculator.';
const intro = 'Compute probabilities for single events, combined events, and conditional probabilities with instant results.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is probability?', a: 'Probability measures the likelihood of an event occurring on a scale from 0 (impossible) to 1 (certain). It is calculated as the number of favorable outcomes divided by the total number of possible outcomes.' },
  { q: 'How does P(A AND B) differ from P(A OR B)?', a: 'P(A AND B) is the probability that both events occur simultaneously (intersection). P(A OR B) is the probability that at least one event occurs (union). For mutually exclusive events, P(A AND B) = 0 and P(A OR B) = P(A) + P(B).' },
  { q: 'What is conditional probability?', a: 'Conditional probability P(A|B) is the probability of event A occurring given that event B has already occurred. It is calculated as P(A AND B) / P(B).' },
  { q: 'What are independent events?', a: 'Events A and B are independent if the occurrence of one does not affect the probability of the other. For independent events, P(A AND B) = P(A) × P(B) and P(A|B) = P(A).' },
  { q: 'What is the range of probability values?', a: 'Probabilities always range from 0 to 1 (or 0% to 100%). A probability of 0 means the event is impossible, 0.5 means equally likely as not, and 1 means certain to occur.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-3">
      <div class="flex-1 min-w-[120px]">
        <label class="block text-sm font-medium text-slate-700" for="prob-a">P(A) (0 to 1)</label>
        <input id="prob-a" type="number" step="any" value="0.5" min="0" max="1" placeholder="0.5"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="flex-1 min-w-[120px]">
        <label class="block text-sm font-medium text-slate-700" for="prob-b">P(B) (0 to 1)</label>
        <input id="prob-b" type="number" step="any" value="0.4" min="0" max="1" placeholder="0.4"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="flex-1 min-w-[120px]">
        <label class="block text-sm font-medium text-slate-700" for="prob-and">P(A AND B) (optional)</label>
        <input id="prob-and-input" type="number" step="any" value="0.2" min="0" max="1" placeholder="0.2"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      <div id="prob-result-a" class="rounded-xl bg-indigo-600 p-4 text-center text-white">
        <span class="text-sm opacity-90">P(A) =</span>
        <span id="prob-a-val" class="ml-2 text-xl font-bold">0.5</span>
      </div>
      <div id="prob-result-b" class="rounded-xl bg-indigo-600 p-4 text-center text-white">
        <span class="text-sm opacity-90">P(B) =</span>
        <span id="prob-b-val" class="ml-2 text-xl font-bold">0.4</span>
      </div>
    </div>
    <div id="prob-more" class="mt-3 space-y-2">
      <div class="rounded-xl bg-emerald-600 p-4 text-center text-white">
        <span class="text-sm opacity-90">P(A AND B) =</span>
        <span id="prob-and-val" class="ml-2 text-xl font-bold">0.2</span>
      </div>
      <div class="rounded-xl bg-slate-50 p-4 text-center">
        <span class="text-sm text-slate-500">P(A OR B) =</span>
        <span id="prob-or-val" class="ml-2 text-lg font-bold text-slate-800">0.7</span>
        <span class="ml-2 text-xs text-slate-400">(70%)</span>
      </div>
      <div class="rounded-xl bg-slate-50 p-4 text-center">
        <span class="text-sm text-slate-500">P(A|B) =</span>
        <span id="prob-cond-a-given-b" class="ml-2 text-lg font-bold text-slate-800">0.5</span>
        <span class="ml-2 text-xs text-slate-400">| P(B|A) =</span>
        <span id="prob-cond-b-given-a" class="ml-2 text-lg font-bold text-slate-800">0.4</span>
      </div>
    </div>
    <div id="prob-indep" class="mt-2 hidden rounded-xl border border-slate-200 bg-slate-50 p-3 text-center text-xs text-slate-400"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="600" height="360" viewBox="0 0 600 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="prob-title prob-desc">
      <title id="prob-title">Venn diagram showing two overlapping events A and B with their intersection</title>
      <desc id="prob-desc">Two overlapping circles labeled A and B. The left circle represents event A (P(A)), the right represents event B (P(B)). The overlapping region represents P(A AND B). The total shaded area represents P(A OR B).</desc>
      <rect x="40" y="20" width="520" height="320" rx="10" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" />
      <circle cx="230" cy="180" r="110" fill="#eef2ff" stroke="#6366f1" stroke-width="2.5" fill-opacity="0.6" />
      <circle cx="370" cy="180" r="110" fill="#ecfdf5" stroke="#10b981" stroke-width="2.5" fill-opacity="0.6" />
      <text x="175" y="140" text-anchor="middle" fill="#4338ca" font-size="24" font-weight="bold">A</text>
      <text x="425" y="140" text-anchor="middle" fill="#059669" font-size="24" font-weight="bold">B</text>
      <text x="300" y="180" text-anchor="middle" fill="#1e293b" font-size="18" font-weight="bold">A &cap; B</text>
      <text x="175" y="260" text-anchor="middle" fill="#94a3b8" font-size="13">P(A) = 0.5</text>
      <text x="425" y="260" text-anchor="middle" fill="#94a3b8" font-size="13">P(B) = 0.4</text>
      <text x="300" y="213" text-anchor="middle" fill="#64748b" font-size="13">P(A &cap; B) = 0.2</text>
      <text x="300" y="310" text-anchor="middle" fill="#64748b" font-size="14">P(A &cup; B) = P(A) + P(B) &minus; P(A &cap; B) = 0.7</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Venn diagram of two events A and B showing their intersection (A AND B) and union (A OR B). The overlap reduces double-counting in the union formula.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How probability calculations work</h2>
    <p class="mt-2 text-slate-600">Probability quantifies uncertainty on a scale from 0 (impossible) to 1 (certain). The simplest case is a single event: P(A) = number of favorable outcomes / total number of possible outcomes. For example, the probability of rolling a 4 on a fair six-sided die is 1/6 ≈ 0.167. This basic formula assumes all outcomes are equally likely.</p>
    <p class="mt-3 text-slate-600">When combining two events, the relationship between them determines the correct formula. The probability of A OR B (the union) accounts for potential overlap: P(A OR B) = P(A) + P(B) - P(A AND B). Without subtracting the intersection, the overlapping outcomes would be counted twice. When A and B are mutually exclusive (cannot both occur), P(A AND B) = 0 and the formula simplifies to P(A OR B) = P(A) + P(B).</p>
    <p class="mt-3 text-slate-600">Conditional probability measures how the probability of one event changes when we know another has occurred. P(A|B) = P(A AND B) / P(B). Events are independent when P(A|B) = P(A) — knowing B occurred does not change the probability of A. For independent events, P(A AND B) = P(A) × P(B), which provides a way to check the independence assumption using the calculator.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Union (OR)</h3>
        <p class="mt-1 font-mono text-lg font-bold text-indigo-700">P(A &cup; B) = P(A) + P(B) &minus; P(A &cap; B)</p>
        <p class="mt-2 text-sm text-slate-600">The addition rule. Subtract the intersection to avoid double-counting overlapping outcomes.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Conditional</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">P(A|B) = P(A &cap; B) / P(B)</p>
        <p class="mt-2 text-sm text-slate-600">The probability of A given that B has occurred. Only defined when P(B) > 0.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: Drawing from a deck of cards</h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>A = drawing a heart (13/52 = 0.25), B = drawing a face card (12/52 ≈ 0.231)</p>
        <p>P(A AND B) = drawing a heart that is also a face card = 3/52 ≈ 0.058</p>
        <p>P(A OR B) = 0.25 + 0.231 - 0.058 = 0.423 (42.3%)</p>
        <p>P(A|B) = 0.058 / 0.231 = 0.25 (if you have a face card, 25% chance it is a heart)</p>
        <p class="font-semibold text-emerald-700">Since P(A|B) = P(A) = 0.25, suit and face card are independent events.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Gamblers &amp; Game Designers</h3>
      <p class="mt-1 text-sm text-slate-600">Probability is the foundation of all games of chance. Understanding P(A OR B) and P(A AND B) helps calculate winning odds in card games, dice games, roulette, and lottery systems. Game designers use these formulas to balance mechanics.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4CA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Data Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">Probability theory underpins machine learning: Naive Bayes classifiers use conditional probability, random forests use probability thresholds, and hypothesis testing relies on p-values. Bayesian inference updates probabilities as new evidence arrives.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Risk Analysts</h3>
      <p class="mt-1 text-sm text-slate-600">Insurance, finance, and safety professionals use probability to quantify risk. The probability of multiple independent failures (P AND P AND ...) decreases exponentially, which is why redundant safety systems are effective.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4D6;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students</h3>
      <p class="mt-1 text-sm text-slate-600">Probability is a core topic in statistics and mathematics curricula. Understanding the OR/AND distinction, conditional probability, and Bayes' theorem is essential for exams and real-world statistical reasoning.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the probability calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter probabilities</h3>
        <p class="mt-1 text-sm text-slate-600">Type P(A) and P(B) as decimals between 0 and 1. Optionally enter P(A AND B) if known, or leave blank to use the independence assumption.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Review all results</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator automatically computes P(A AND B), P(A OR B), and both conditional probabilities P(A|B) and P(B|A), displayed as decimals and percentages.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check independence</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator shows whether A and B are independent, mutually exclusive, or neither, based on the values you entered.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with probability</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always check bounds</h3>
        <p class="mt-1 text-sm text-slate-600">Probabilities must be between 0 and 1 inclusive. If P(A) + P(B) exceeds 1 but P(A AND B) is small, P(A OR B) will still be ≤ 1 because the intersection subtraction corrects the sum. Never report a probability outside [0, 1].</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Complement rule</h3>
        <p class="mt-1 text-sm text-slate-600">The probability that an event does NOT occur is P(not A) = 1 - P(A). This is often easier to calculate than P(A) directly. For example, the probability of rolling at least one 6 in three dice rolls is 1 - (5/6)³ ≈ 0.421.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Bayes' theorem connects conditionals</h3>
        <p class="mt-1 text-sm text-slate-600">Bayes' theorem states P(A|B) = P(B|A) × P(A) / P(B). This powerful formula allows you to reverse conditional probabilities and is the foundation of Bayesian statistics, spam filters, and diagnostic testing.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Law of total probability</h3>
        <p class="mt-1 text-sm text-slate-600">If events B₁, B₂, ..., Bₙ form a partition of the sample space, then P(A) = Σ P(A|Bᵢ) × P(Bᵢ). This law allows breaking complex probability calculations into simpler conditional pieces and is commonly used in decision trees.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/factorial-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2757;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Factorial Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Compute n! with step-by-step multiplication for combinatorics.</p>
      </a>
      <a href="/tools/combination-permutation-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F3B2;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Combination &amp; Permutation</h3>
        <p class="mt-0.5 text-xs text-slate-500">Count arrangements and selections using nPr and nCr formulas.</p>
      </a>
      <a href="/tools/standard-deviation/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4CA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Standard Deviation Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate standard deviation and variance for a data set.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const probA = document.getElementById('prob-a');
    const probB = document.getElementById('prob-b');
    const probAndInput = document.getElementById('prob-and-input');
    const probAVal = document.getElementById('prob-a-val');
    const probBVal = document.getElementById('prob-b-val');
    const probAndVal = document.getElementById('prob-and-val');
    const probOrVal = document.getElementById('prob-or-val');
    const probCondAGivenB = document.getElementById('prob-cond-a-given-b');
    const probCondBGivenA = document.getElementById('prob-cond-b-given-a');
    const probIndep = document.getElementById('prob-indep');
    const probMore = document.getElementById('prob-more');

    function calculate() {
      const a = parseFloat(probA.value);
      const b = parseFloat(probB.value);
      const andVal = probAndInput.value.trim() === '' ? null : parseFloat(probAndInput.value);

      const validA = !isNaN(a) && a >= 0 && a <= 1;
      const validB = !isNaN(b) && b >= 0 && b <= 1;
      const validAnd = andVal === null || (!isNaN(andVal) && andVal >= 0 && andVal <= 1);

      if (validA && validB) {
        probAVal.textContent = a.toLocaleString(undefined, { maximumFractionDigits: 4 });
        probBVal.textContent = b.toLocaleString(undefined, { maximumFractionDigits: 4 });
      } else {
        probAVal.textContent = '—';
        probBVal.textContent = '—';
        probAndVal.textContent = '—';
        probOrVal.textContent = '—';
        probCondAGivenB.textContent = '—';
        probCondBGivenA.textContent = '—';
        probIndep.classList.add('hidden');
        return;
      }

      if (!validAnd) {
        probAndVal.textContent = 'Invalid';
        probOrVal.textContent = '—';
        probCondAGivenB.textContent = '—';
        probCondBGivenA.textContent = '—';
        probIndep.classList.add('hidden');
        return;
      }

      const pAnd = andVal !== null ? andVal : a * b;
      const pOr = a + b - pAnd;
      const pAGivenB = b > 0 ? pAnd / b : NaN;
      const pBGivenA = a > 0 ? pAnd / a : NaN;

      probAndVal.textContent = pAnd.toLocaleString(undefined, { maximumFractionDigits: 4 });
      probOrVal.textContent = pOr.toLocaleString(undefined, { maximumFractionDigits: 4 }) + ` (${(pOr * 100).toFixed(1)}%)`;
      probCondAGivenB.textContent = isNaN(pAGivenB) ? 'Undefined' : pAGivenB.toLocaleString(undefined, { maximumFractionDigits: 4 });
      probCondBGivenA.textContent = isNaN(pBGivenA) ? 'Undefined' : pBGivenA.toLocaleString(undefined, { maximumFractionDigits: 4 });

      if (validA && validB) {
        const isIndep = Math.abs(pAnd - a * b) < 1e-10;
        const isMutExcl = pAnd === 0;
        let msg = '';
        if (isMutExcl && isIndep) msg = 'Events are mutually exclusive (and trivially independent only if at least one has P=0).';
        else if (isMutExcl) msg = 'Events are mutually exclusive — they cannot occur simultaneously.';
        else if (isIndep) msg = 'Events are independent — P(A AND B) = P(A) × P(B).';
        else msg = 'Events are neither independent nor mutually exclusive.';
        probIndep.textContent = msg;
        probIndep.classList.remove('hidden');
      } else {
        probIndep.classList.add('hidden');
      }
    }

    probA.addEventListener('input', calculate);
    probB.addEventListener('input', calculate);
    probAndInput.addEventListener('input', calculate);
    calculate();
  </script>
</ToolLayout>
