---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Fat Intake Calculator';
const description =
  'Free fat intake calculator. Estimate your daily fat needs as a percentage of total calorie intake. Metric or imperial.';
const intro =
  'Enter your daily calorie target and dietary preference to see your recommended fat intake in grams and the percentage breakdown.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How much fat should I eat per day?', a: 'The Dietary Guidelines for Americans recommend 20–35% of total daily calories from fat. For a 2,000-calorie diet, that is 44–78 g of fat per day.' },
  { q: 'What types of fat should I eat?', a: 'Focus on unsaturated fats (olive oil, avocados, nuts, seeds, fatty fish) and limit saturated fat to less than 10% of total calories. Avoid trans fats entirely.' },
  { q: 'Is dietary fat bad for weight loss?', a: 'No — fat is essential for hormone production, vitamin absorption and cell health. It is also calorie-dense (9 cal/g), so portion control matters, but healthy fats are a crucial part of any balanced diet.' },
  { q: 'Do I need more fat on a keto diet?', a: 'Yes — a ketogenic diet typically provides 70–80% of calories from fat. This is a therapeutic ratio for nutritional ketosis and should be approached with medical guidance.' },
  { q: 'What is the minimum fat I should eat?', a: 'The Acceptable Macronutrient Distribution Range (AMDR) sets a minimum of 20% of calories from fat for adults. Dropping below 15–20% can impair hormone function, especially for women (menstrual cycle disruption).' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Daily calorie target</span>
      <input id="cal-target" type="number" step="any" placeholder="2000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Diet style</span>
      <select id="style" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="20">Low fat (20% — heart health / fat loss)</option>
        <option value="30" selected>Moderate (30% — balanced diet)</option>
        <option value="35">Moderate-high (35% — Mediterranean style)</option>
        <option value="45">High fat (45% — low carb)</option>
        <option value="75">Keto (75% — ketogenic diet)</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Daily fat target</div>
        <div id="r-fat" class="mt-1 text-3xl font-bold">—</div>
        <div class="mt-1 text-sm opacity-80">grams of fat per day</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Fat calories</div><div id="r-cal" class="mt-1 text-xl font-bold text-emerald-600">—</div><div class="text-xs text-slate-400"><span id="r-pct">—</span>% of total</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Per meal (3 meals)</div><div id="r-meal" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your calorie target and diet style to see your fat goal.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About dietary fat</h2>
    <p class="mt-2 text-slate-600">
      Fat is an essential macronutrient that plays critical roles in hormone production, vitamin absorption (A, D, E, K), cell membrane integrity and brain function. Despite its reputation in diet culture, fat is not inherently fattening — excess calories of any kind cause weight gain. The type of fat matters more than the total amount. <a href="https://www.heart.org/en/healthy-living/healthy-eating/eat-smart/fats" rel="noopener">The American Heart Association</a> recommends replacing saturated fats with unsaturated fats from plants and fish for cardiovascular health. This calculator helps you set your fat intake based on your total calories and diet style. For a complete macro picture, pair it with the <a href="/tools/macro-calculator/" class="font-medium text-indigo-600 hover:underline">Macro Calculator</a> and <a href="/tools/protein-calculator/" class="font-medium text-indigo-600 hover:underline">Protein Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only. Consult a professional before starting therapeutic diets like keto.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" role="img" aria-labelledby="fat-title fat-desc">
      <title id="fat-title">Fat as a proportion of total calories</title>
      <desc id="fat-desc">Pie chart showing fat as 30% of total daily calories compared to the 70% from protein and carbohydrates combined.</desc>
      <circle cx="400" cy="110" r="80" fill="#e2e8f0" />
      <path d="M400,110 L400,30 A80,80 0 0,1 469.28,158.41 Z" fill="#f59e0b" />
      <path d="M400,110 L469.28,158.41 A80,80 0 0,1 400,190 Z" fill="#6366f1" />
      <circle cx="400" cy="110" r="40" fill="#fff" />
      <text x="400" y="115" text-anchor="middle" font-size="18" fill="#1e293b" font-weight="bold">30%</text>
      <text x="500" y="100" font-size="13" fill="#d97706" font-weight="bold">Fat (30%)</text>
      <text x="500" y="130" font-size="13" fill="#6366f1" font-weight="bold">Protein + Carbs (70%)</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">On a balanced diet, roughly 30% of calories come from fat, or about 67 g on a 2,000-calorie diet</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      This calculator takes your total daily calorie target and multiplies it by the fat percentage that matches your chosen diet style. Since fat provides 9 calories per gram, the total fat calories are divided by 9 to give the gram target. For example, on a 2,000-calorie diet with a moderate 30% fat goal: 2,000 × 0.30 = 600 calories from fat, which equals 600 ÷ 9 = 67 g of fat per day. Different diet styles require different fat proportions — low-fat diets for heart health, moderate fat for general wellness, and high fat for low-carb or ketogenic approaches.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Fat (g)</strong> = (total calories × fat%) ÷ 9
    </p>
    <p class="mt-3 text-slate-600">
      Fat is the most calorie-dense macronutrient at 9 calories per gram, more than double that of protein and carbs (4 cal/g each). This is why high-fat foods are calorie-rich in small portions.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A person eating 2,200 calories per day on a Mediterranean-style diet (35% fat) wants to know their fat target.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Calorie target:</span> <span class="text-slate-600">2,200 cal</span></div>
        <div><span class="font-medium text-slate-700">Fat %:</span> <span class="text-slate-600">35%</span></div>
        <div><span class="font-medium text-slate-700">Fat calories:</span> <span class="text-slate-600">2,200 × 0.35 = <strong>770 cal</strong></span></div>
        <div><span class="font-medium text-slate-700">Fat grams:</span> <span class="text-slate-600">770 ÷ 9 = <strong>86 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Per meal (3):</span> <span class="text-slate-600">86 ÷ 3 ≈ <strong>29 g per meal</strong></span></div>
        <div><span class="font-medium text-slate-700">Reference:</span> <span class="text-slate-600">2 tbsp olive oil = 28 g fat. 100 g salmon = 13 g fat. 1 oz almonds = 14 g fat.</span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">❤️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Heart health focused</h3>
      <p class="mt-1 text-sm text-slate-600">Keep total fat at 20–25% with an emphasis on unsaturated fats from olive oil, avocados and nuts to support cardiovascular health.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🥑</span>
      <h3 class="mt-2 font-semibold text-slate-900">Keto dieter</h3>
      <p class="mt-1 text-sm text-slate-600">Set fat to 70–80% of total calories to maintain nutritional ketosis. High fat intake replaces carbohydrates as the primary fuel source.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏋️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Bodybuilder</h3>
      <p class="mt-1 text-sm text-slate-600">Keep fat at 25–30% of total calories during a bulk or cut. Fats support hormone health, including testosterone production, which is crucial for muscle growth.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧑‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Mediterranean diet follower</h3>
      <p class="mt-1 text-sm text-slate-600">Aim for 35% of calories from fat, mainly from olive oil, oily fish and nuts. This style is associated with longevity and reduced inflammation.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set your calories</h3>
        <p class="mt-1 text-sm text-slate-600">Enter your daily calorie target. Use the TDEE or Calorie Calculator to get a starting point if you are unsure.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a diet style</h3>
        <p class="mt-1 text-sm text-slate-600">Choose from low fat (20%), moderate (30%), Mediterranean (35%), low carb (45%) or keto (75%). Each reflects a real-world dietary approach.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your grams</h3>
        <p class="mt-1 text-sm text-slate-600">See how many grams of fat to eat per day and per meal. Track with a food diary or app to stay within your target.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for healthy fat intake</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Choose quality over quantity</h3>
        <p class="mt-1 text-sm text-slate-600">Replacing saturated fats (butter, red meat, dairy) with unsaturated fats (olive oil, avocados, nuts, fish) has well-documented cardiovascular benefits.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Watch the hidden fats</h3>
        <p class="mt-1 text-sm text-slate-600">Processed foods, baked goods, salad dressings and takeaway meals often contain surprising amounts of fat — both saturated and trans. Check labels carefully.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Don't fear healthy fats</h3>
        <p class="mt-1 text-sm text-slate-600">Fat is not the enemy. A moderate fat intake supports hormone production, satiety and vitamin absorption. Extremely low-fat diets (below 15%) can do more harm than good.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/macro-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Macro Calculator</a>
      <a href="/tools/carbohydrate-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Carb Calculator</a>
      <a href="/tools/keto-macro-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Keto Macro Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const cal = parseFloat(el('cal-target').value);
      if (!cal || cal <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const pct = parseFloat(el('style').value);
      const fatCal = cal * (pct / 100);
      const fatG = fatCal / 9;
      el('r-fat').textContent = Math.round(fatG) + ' g';
      el('r-cal').textContent = Math.round(fatCal).toLocaleString() + ' cal';
      el('r-pct').textContent = pct;
      el('r-meal').textContent = Math.round(fatG / 3) + ' g';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    ['cal-target', 'style'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
