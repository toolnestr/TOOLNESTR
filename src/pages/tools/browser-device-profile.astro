---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Browser & Device Profile';
const description =
  'Free browser and device info tool — instantly see your browser, OS, screen resolution, device type, language, timezone, connection type, hardware concurrency and more. No sign-up needed.';

const faqs = [
  { q: 'What information does this tool detect?', a: 'It detects your browser name and version, operating system, device type (desktop, tablet, mobile), screen resolution and pixel density, color depth, installed languages, timezone and UTC offset, online status, network connection type, hardware concurrency (CPU threads), device memory, touch support, cookie status, JavaScript enabled status, and whether you are using a dark mode preference.' },
  { q: 'Is any of this data sent to a server?', a: 'No. All detection is done entirely in your browser using standard Web APIs. Nothing is uploaded, logged or shared. The information is read directly from your browser and displayed only to you.' },
  { q: 'Why might my location timezone be different from my actual timezone?', a: 'The timezone shown is the system timezone configured in your device settings, not your physical GPS location. If your device is set to a different timezone than where you currently are, this tool will show your device setting. Travelers who forget to update their device timezone will see their home timezone.' },
  { q: 'What is hardware concurrency?', a: 'Hardware concurrency is the number of logical CPU cores available to your browser, reported by navigator.hardwareConcurrency. Modern CPUs have multiple cores with hyperthreading, so an 8-core CPU typically reports 16 logical threads. This value helps websites decide how many Web Workers to spawn for parallel processing.' },
  { q: 'What is the User Agent string used for?', a: 'The User Agent (UA) string is sent with every HTTP request your browser makes, allowing servers to identify your browser and OS. It is used for analytics, serving compatible content, and debugging. Some privacy tools spoof or rotate the UA string to reduce fingerprinting.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Browser & Device Profile',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  browserRequirements: 'Requires JavaScript',
  description: 'Instantly see your browser, OS, screen, hardware and network details.',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to check your browser and device profile',
  description: 'See the browser, operating system, screen and network details your device exposes.',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Open the page', text: 'Open the Browser & Device Profile — it reads your details instantly, with nothing to install.' },
    { '@type': 'HowToStep', position: 2, name: 'Review your details', text: 'Read your user agent, OS, screen size, timezone, language and hardware information.' },
    { '@type': 'HowToStep', position: 3, name: 'Copy what you need', text: 'Use the copy buttons to grab any value for a bug report, support ticket or compatibility check.' },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={[faqSchema, toolSchema, howToSchema]}>
  <style is:inline>
    :root {
      --primary: #6366f1; --success: #10b981;
      --bg: #f8fafc; --card: #ffffff; --text: #1e293b; --muted: #64748b; --border: #e2e8f0;
      --section-bg: #f1f5f9;
    }
    .dark body {
      --bg: #0f172a; --card: #1e293b; --text: #f1f5f9; --muted: #94a3b8; --border: #334155;
      --section-bg: #0f172a;
    }

    /* ── Hero ── */
    .bdp-hero {
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 30%, #4c1d95 65%, #2e1065 100%);
      position: relative; overflow: hidden; padding: 44px 20px 56px; text-align: center;
    }
    .bdp-hero::before { content:''; position:absolute; top:-80px; right:-80px; width:320px; height:320px; background:radial-gradient(circle,rgba(167,139,250,.22) 0%,transparent 70%); pointer-events:none; }
    .bdp-hero::after  { content:''; position:absolute; bottom:-60px; left:-60px; width:240px; height:240px; background:radial-gradient(circle,rgba(99,102,241,.18) 0%,transparent 70%); pointer-events:none; }
    .bdp-badge {
      display:inline-flex; align-items:center; gap:5px; margin-bottom:14px;
      background:rgba(255,255,255,.12); backdrop-filter:blur(8px);
      border:1px solid rgba(255,255,255,.22); color:#e0e7ff;
      font-size:.72rem; font-weight:700; letter-spacing:.08em;
      padding:4px 14px; border-radius:20px; position:relative; z-index:1;
    }
    .bdp-hero h1 { font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#fff; margin-bottom:8px; letter-spacing:-.02em; position:relative; z-index:1; }
    .bdp-hero p  { font-size:1rem; color:#c4b5fd; position:relative; z-index:1; }

    /* ── Wrap ── */
    .bdp-wrap { max-width: 860px; margin: 0 auto; padding: 28px 16px 0; }

    /* ── Summary cards ── */
    .summary-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 24px; }
    @media(min-width: 600px) { .summary-grid { grid-template-columns: repeat(4, 1fr); } }
    .summary-card {
      background: var(--card); border: 1.5px solid var(--border); border-radius: 14px;
      padding: 14px; text-align: center;
    }
    .sc-icon { font-size: 1.6rem; }
    .sc-val  { font-size: .95rem; font-weight: 700; color: var(--text); margin-top: 6px; line-height: 1.2; }
    .sc-lbl  { font-size: .68rem; color: var(--muted); margin-top: 3px; text-transform: uppercase; letter-spacing: .06em; }

    /* ── Section ── */
    .bdp-section { background: var(--card); border: 1.5px solid var(--border); border-radius: 16px; margin-bottom: 16px; overflow: hidden; }
    .section-head {
      display: flex; align-items: center; gap: 10px; padding: 14px 16px;
      border-bottom: 1px solid var(--border); background: var(--section-bg);
    }
    .section-head .sh-icon { font-size: 1.2rem; }
    .section-head .sh-title { font-weight: 700; font-size: .95rem; color: var(--text); }
    .info-grid { display: grid; grid-template-columns: 1fr; }
    @media(min-width: 500px) { .info-grid { grid-template-columns: 1fr 1fr; } }
    .info-row {
      display: flex; flex-direction: column; padding: 11px 16px;
      border-bottom: 1px solid var(--border);
    }
    .info-row:last-child { border-bottom: none; }
    @media(min-width: 500px) {
      .info-row:nth-last-child(-n+2) { border-bottom: none; }
    }
    .ir-label { font-size: .72rem; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
    .ir-val   { font-size: .9rem; font-weight: 600; color: var(--text); margin-top: 2px; word-break: break-all; }
    .ir-val.mono { font-family: 'Courier New', monospace; font-size: .8rem; }

    /* Status badges */
    .badge-ok  { display:inline-block; padding:1px 8px; border-radius:20px; font-size:.72rem; font-weight:700; background:#dcfce7; color:#166534; }
    .badge-off { display:inline-block; padding:1px 8px; border-radius:20px; font-size:.72rem; font-weight:700; background:#fee2e2; color:#991b1b; }
    .dark body .badge-ok  { background:#14532d; color:#bbf7d0; }
    .dark body .badge-off { background:#450a0a; color:#fca5a5; }

    /* Copy button */
    .copy-ua-btn {
      margin: 12px 16px; padding: 7px 16px; border-radius: 8px;
      background: transparent; border: 1.5px solid var(--border);
      color: var(--muted); font-size: .82rem; font-weight: 600;
      cursor: pointer; transition: all .15s;
    }
    .copy-ua-btn:hover { border-color: var(--primary); color: var(--primary); }

    /* ── About ── */
    .about-section { max-width: 860px; margin: 28px auto 0; padding: 0 16px; }
    .about-card { background: var(--card); border: 1.5px solid var(--border); border-radius: 16px; padding: 28px; }
    .about-card h2 { font-size: 1.3rem; font-weight: 800; margin-bottom: 16px; }
    .about-card p  { font-size: .92rem; line-height: 1.8; color: var(--muted); margin-bottom: 14px; }
    .about-card p:last-child { margin-bottom: 0; }
    .about-card h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 20px 0 8px; }

    /* ── FAQ ── */
    .faq-section { max-width: 860px; margin: 28px auto 40px; padding: 0 16px; }
    .faq-title { font-size: 1.2rem; font-weight: 800; margin-bottom: 16px; }
    .faq-item { background: var(--card); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 10px; }
    .faq-q { padding: 14px 16px; font-weight: 600; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-size: .93rem; }
    .faq-q:hover { color: var(--primary); }
    .faq-a { padding: 0 16px 14px; font-size: .88rem; color: var(--muted); line-height: 1.65; display: none; }
    .faq-item.open .faq-a { display: block; }
    .faq-item.open .faq-arrow { transform: rotate(180deg); }
    .faq-arrow { transition: transform .2s; font-size: .75rem; color: var(--muted); }
  </style>

  <!-- Hero -->
  <div class="bdp-hero">
    <div class="bdp-badge">★ FLAGSHIP TOOL</div>
    <h1>🖥️ Browser & Device Profile</h1>
    <p>Your complete browser fingerprint — detected instantly in your browser</p>
  </div>

  <div class="bdp-wrap">
    <!-- Summary cards -->
    <div class="summary-grid">
      <div class="summary-card"><div class="sc-icon">🌐</div><div class="sc-val" id="scBrowser">–</div><div class="sc-lbl">Browser</div></div>
      <div class="summary-card"><div class="sc-icon">💻</div><div class="sc-val" id="scOs">–</div><div class="sc-lbl">OS</div></div>
      <div class="summary-card"><div class="sc-icon">📱</div><div class="sc-val" id="scDevice">–</div><div class="sc-lbl">Device Type</div></div>
      <div class="summary-card"><div class="sc-icon">📐</div><div class="sc-val" id="scScreen">–</div><div class="sc-lbl">Screen</div></div>
    </div>

    <!-- Browser section -->
    <div class="bdp-section">
      <div class="section-head"><span class="sh-icon">🌐</span><span class="sh-title">Browser</span></div>
      <div class="info-grid">
        <div class="info-row"><div class="ir-label">Browser Name</div><div class="ir-val" id="browserName">–</div></div>
        <div class="info-row"><div class="ir-label">Browser Version</div><div class="ir-val" id="browserVersion">–</div></div>
        <div class="info-row"><div class="ir-label">Engine</div><div class="ir-val" id="browserEngine">–</div></div>
        <div class="info-row"><div class="ir-label">Cookies Enabled</div><div class="ir-val" id="cookies">–</div></div>
        <div class="info-row"><div class="ir-label">Do Not Track</div><div class="ir-val" id="dnt">–</div></div>
        <div class="info-row"><div class="ir-label">Java Enabled</div><div class="ir-val" id="java">–</div></div>
      </div>
    </div>

    <!-- OS & Device section -->
    <div class="bdp-section">
      <div class="section-head"><span class="sh-icon">💻</span><span class="sh-title">OS & Device</span></div>
      <div class="info-grid">
        <div class="info-row"><div class="ir-label">Operating System</div><div class="ir-val" id="osName">–</div></div>
        <div class="info-row"><div class="ir-label">Device Type</div><div class="ir-val" id="deviceType">–</div></div>
        <div class="info-row"><div class="ir-label">CPU Threads</div><div class="ir-val" id="cpuThreads">–</div></div>
        <div class="info-row"><div class="ir-label">Device Memory</div><div class="ir-val" id="deviceMemory">–</div></div>
        <div class="info-row"><div class="ir-label">Touch Support</div><div class="ir-val" id="touchSupport">–</div></div>
        <div class="info-row"><div class="ir-label">Max Touch Points</div><div class="ir-val" id="maxTouch">–</div></div>
      </div>
    </div>

    <!-- Screen section -->
    <div class="bdp-section">
      <div class="section-head"><span class="sh-icon">📐</span><span class="sh-title">Display</span></div>
      <div class="info-grid">
        <div class="info-row"><div class="ir-label">Screen Resolution</div><div class="ir-val" id="screenRes">–</div></div>
        <div class="info-row"><div class="ir-label">Available Resolution</div><div class="ir-val" id="availRes">–</div></div>
        <div class="info-row"><div class="ir-label">Viewport Size</div><div class="ir-val" id="viewport">–</div></div>
        <div class="info-row"><div class="ir-label">Pixel Ratio (DPR)</div><div class="ir-val" id="dpr">–</div></div>
        <div class="info-row"><div class="ir-label">Color Depth</div><div class="ir-val" id="colorDepth">–</div></div>
        <div class="info-row"><div class="ir-label">Dark Mode</div><div class="ir-val" id="darkMode">–</div></div>
      </div>
    </div>

    <!-- Network & Locale section -->
    <div class="bdp-section">
      <div class="section-head"><span class="sh-icon">🌍</span><span class="sh-title">Network & Locale</span></div>
      <div class="info-grid">
        <div class="info-row"><div class="ir-label">Online Status</div><div class="ir-val" id="onlineStatus">–</div></div>
        <div class="info-row"><div class="ir-label">Connection Type</div><div class="ir-val" id="connType">–</div></div>
        <div class="info-row"><div class="ir-label">Effective Speed</div><div class="ir-val" id="connSpeed">–</div></div>
        <div class="info-row"><div class="ir-label">Timezone</div><div class="ir-val" id="timezone">–</div></div>
        <div class="info-row"><div class="ir-label">UTC Offset</div><div class="ir-val" id="utcOffset">–</div></div>
        <div class="info-row"><div class="ir-label">Languages</div><div class="ir-val" id="languages">–</div></div>
      </div>
    </div>

    <!-- User Agent section -->
    <div class="bdp-section">
      <div class="section-head"><span class="sh-icon">🔍</span><span class="sh-title">User Agent</span></div>
      <div style="padding:12px 16px;">
        <div class="ir-label" style="margin-bottom:6px;">Full User Agent String</div>
        <div class="ir-val mono" id="userAgent" style="font-size:.78rem;line-height:1.5;background:var(--section-bg);padding:10px;border-radius:8px;">–</div>
      </div>
      <button class="copy-ua-btn" id="copyUaBtn">📋 Copy User Agent</button>
    </div>
  </div>

  <!-- About -->
  <section class="about-section">
    <div class="about-card">
      <h2>About the Browser &amp; Device Profile Tool</h2>
      <p>The ToolNestr Browser and Device Profile tool instantly reveals everything your browser exposes about your device and environment. No software installation, no sign-up, no plug-ins — every data point is read directly from browser APIs and displayed in real time. This tool is useful for web developers testing responsive designs, for security-conscious users who want to understand what websites know about them, and for technical support teams gathering system information from end users quickly.</p>
      <p>Modern web browsers expose a surprisingly large amount of information to websites through standard JavaScript APIs. While none of this data uniquely identifies you on its own, combinations of these characteristics can form a "browser fingerprint" that is statistically unique to your device and browser configuration. Understanding what your browser broadcasts helps you make informed decisions about browser privacy settings and extensions.</p>

      <h3>Browser and operating system detection</h3>
      <p>The tool detects your browser name and version, rendering engine (Blink, Gecko, or WebKit), and operating system — including the specific version where available. Browser and OS detection uses the User-Agent string and modern browser API features rather than unreliable string parsing alone. The full raw User-Agent string is also displayed and can be copied to the clipboard with a single click, which is useful when filing bug reports or checking compatibility tables.</p>

      <h3>Hardware and performance data</h3>
      <p>The hardware section shows the number of logical CPU cores available through the navigator.hardwareConcurrency API, and the device memory in gigabytes through navigator.deviceMemory (where supported by the browser). Touch support detection reports the maximum number of simultaneous touch points your device supports. These values help developers understand the performance tier of a user's device without requiring any special permissions.</p>

      <h3>Screen and display metrics</h3>
      <p>Screen resolution shows the total pixel dimensions of your display, while the Device Pixel Ratio (DPR) indicates how many physical pixels correspond to each CSS pixel. A DPR of 2 indicates a Retina or HiDPI display; a DPR of 1 indicates a standard display. Color depth shows how many bits per pixel your display supports — 24-bit is standard for modern displays, enabling over 16 million colours. The viewport section shows the current browser window dimensions and updates in real time as you resize the window, which is useful for testing responsive breakpoints.</p>

      <h3>Network and connectivity information</h3>
      <p>The Network API, where supported, reports your connection type (4G, WiFi, Ethernet, etc.), estimated effective bandwidth in megabits per second, and round-trip time in milliseconds. This information helps developers build adaptive applications that serve different content quality based on connection speed. The online status indicator shows whether your browser currently has a network connection.</p>

      <h3>Timezone and locale settings</h3>
      <p>The tool detects your browser's timezone (as an IANA timezone identifier such as America/New_York), your UTC offset in hours, and the list of languages configured in your browser in preference order. These values are commonly used by websites for localisation — displaying dates in the correct timezone, formatting numbers and currencies, and selecting the appropriate language for content. Your primary language is the first value in the language list and typically corresponds to your operating system's primary language setting.</p>

      <h3>Privacy and data handling</h3>
      <p>All data collection and processing happens entirely within your browser. Nothing is sent to any server. The tool reads values from standard browser APIs — the same APIs that any website you visit can access — and displays them on screen for your reference. No data is stored between sessions. Refreshing or closing the page removes everything, and no cookies or local storage are used.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <h2 class="faq-title">Frequently Asked Questions</h2>
    {faqs.map((f) => (
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
          {f.q}<span class="faq-arrow">▼</span>
        </div>
        <div class="faq-a">{f.a}</div>
      </div>
    ))}
  </section>

  <script is:inline>
  (function () {
    const ua = navigator.userAgent;

    // ── Browser detection ──
    function detectBrowser() {
      if (/Edg\//.test(ua))      return ['Edge',    ua.match(/Edg\/([\d.]+)/)?.[1] ?? ''];
      if (/OPR\//.test(ua))      return ['Opera',   ua.match(/OPR\/([\d.]+)/)?.[1] ?? ''];
      if (/Chrome\//.test(ua))   return ['Chrome',  ua.match(/Chrome\/([\d.]+)/)?.[1] ?? ''];
      if (/Firefox\//.test(ua))  return ['Firefox', ua.match(/Firefox\/([\d.]+)/)?.[1] ?? ''];
      if (/Safari\//.test(ua))   return ['Safari',  ua.match(/Version\/([\d.]+)/)?.[1] ?? ''];
      return ['Unknown', ''];
    }

    function detectEngine() {
      if (/Gecko\//.test(ua) && /Firefox/.test(ua)) return 'Gecko';
      if (/WebKit/.test(ua) && /Chrome/.test(ua))   return 'Blink';
      if (/WebKit/.test(ua))                         return 'WebKit';
      if (/Trident/.test(ua))                        return 'Trident';
      return 'Unknown';
    }

    function detectOS() {
      if (/Windows NT 10/.test(ua)) return 'Windows 10/11';
      if (/Windows NT 6\.3/.test(ua)) return 'Windows 8.1';
      if (/Windows NT 6\.1/.test(ua)) return 'Windows 7';
      if (/Windows/.test(ua))        return 'Windows';
      if (/Mac OS X/.test(ua)) {
        const v = ua.match(/Mac OS X ([\d_]+)/)?.[1]?.replace(/_/g, '.') ?? '';
        return 'macOS' + (v ? ' ' + v : '');
      }
      if (/Android/.test(ua)) {
        const v = ua.match(/Android ([\d.]+)/)?.[1] ?? '';
        return 'Android' + (v ? ' ' + v : '');
      }
      if (/iPhone|iPad|iPod/.test(ua)) {
        const v = ua.match(/OS ([\d_]+)/)?.[1]?.replace(/_/g, '.') ?? '';
        return 'iOS' + (v ? ' ' + v : '');
      }
      if (/Linux/.test(ua)) return 'Linux';
      if (/CrOS/.test(ua))  return 'Chrome OS';
      return 'Unknown';
    }

    function detectDevice() {
      if (/iPad/.test(ua) || (/Macintosh/.test(ua) && navigator.maxTouchPoints > 1)) return 'Tablet';
      if (/iPhone|Android.*Mobile|IEMobile|WPDesktop/.test(ua)) return 'Mobile';
      if (/Android/.test(ua)) return 'Tablet';
      return 'Desktop';
    }

    function badge(val) {
      return val
        ? '<span class="badge-ok">Yes</span>'
        : '<span class="badge-off">No</span>';
    }

    function set(id, html) {
      const el = document.getElementById(id);
      if (el) el.innerHTML = html;
    }

    // ── Populate ──
    const [bName, bVer] = detectBrowser();
    const os     = detectOS();
    const device = detectDevice();
    const conn   = navigator.connection || navigator.mozConnection || navigator.webkitConnection;

    // Summary cards
    set('scBrowser', bVer ? `${bName} ${bVer.split('.')[0]}` : bName);
    set('scOs',      os);
    set('scDevice',  device);
    set('scScreen',  `${screen.width}×${screen.height}`);

    // Browser
    set('browserName',    bName);
    set('browserVersion', bVer || 'Unknown');
    set('browserEngine',  detectEngine());
    set('cookies',   badge(navigator.cookieEnabled));
    set('dnt',       navigator.doNotTrack === '1' ? '<span class="badge-ok">Enabled</span>' : '<span class="badge-off">Disabled</span>');
    set('java',      badge(false)); // Java Plugin deprecated in all modern browsers

    // OS & Device
    set('osName',       os);
    set('deviceType',   device);
    set('cpuThreads',   navigator.hardwareConcurrency ? navigator.hardwareConcurrency + ' threads' : 'Unknown');
    set('deviceMemory', navigator.deviceMemory ? navigator.deviceMemory + ' GB (approx)' : 'Not reported');
    set('touchSupport', badge('ontouchstart' in window || navigator.maxTouchPoints > 0));
    set('maxTouch',     (navigator.maxTouchPoints ?? 0) + ' points');

    // Display
    set('screenRes',   `${screen.width} × ${screen.height} px`);
    set('availRes',    `${screen.availWidth} × ${screen.availHeight} px`);
    set('viewport',    `${window.innerWidth} × ${window.innerHeight} px`);
    set('dpr',         `${window.devicePixelRatio}×`);
    set('colorDepth',  `${screen.colorDepth}-bit`);
    set('darkMode',    window.matchMedia('(prefers-color-scheme: dark)').matches
      ? '<span class="badge-ok">Dark</span>'
      : '<span class="badge-off">Light</span>');

    // Network & Locale
    set('onlineStatus', navigator.onLine ? '<span class="badge-ok">Online</span>' : '<span class="badge-off">Offline</span>');
    set('connType',  conn?.type ?? conn?.effectiveType ?? 'Unknown');
    set('connSpeed', conn?.downlink ? conn.downlink + ' Mbps' : 'Unknown');
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const offset = -new Date().getTimezoneOffset();
    const sign   = offset >= 0 ? '+' : '-';
    const absOff = Math.abs(offset);
    set('timezone',   tz);
    set('utcOffset',  `UTC${sign}${String(Math.floor(absOff / 60)).padStart(2, '0')}:${String(absOff % 60).padStart(2, '0')}`);
    set('languages',  navigator.languages?.join(', ') || navigator.language || 'Unknown');

    // User Agent
    set('userAgent', ua);

    // Copy UA
    document.getElementById('copyUaBtn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(ua).then(() => {
        const btn = document.getElementById('copyUaBtn');
        if (btn) { btn.textContent = '✅ Copied!'; setTimeout(() => { btn.textContent = '📋 Copy User Agent'; }, 2000); }
      }).catch(() => {});
    });

    // Live viewport update on resize
    window.addEventListener('resize', () => {
      set('viewport', `${window.innerWidth} × ${window.innerHeight} px`);
      set('scScreen', `${screen.width}×${screen.height}`);
    });
  })();
  </script>
</BaseLayout>
