---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'QR Code Generator';
const description =
  'Free QR code generator. Create a QR code for any link, text, email or Wi-Fi and ' +
  'download it as a PNG. Made in your browser — fast, free and private.';
const intro =
  'Type a link or any text and your QR code appears instantly. Adjust the size and colour, then download it as a PNG.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'Do these QR codes expire?', a: 'No. The QR code encodes your text or link directly, so it works forever and never expires — there is no tracking or redirect.' },
  { q: 'Can I use it commercially?', a: 'Yes. The QR codes you generate are yours to use anywhere — posters, products, menus, business cards.' },
  { q: 'What can I put in a QR code?', a: 'Any text: a website URL, a phone number (tel:), an email (mailto:), or plain text. Keep links short for easier scanning.' },
  { q: 'Is my data uploaded?', a: 'No. The QR code is generated entirely in your browser.' },
  { q: 'What is error correction?', a: 'Error correction allows the QR code to be scanned even if part of it is damaged or obscured. Higher levels mean more redundancy — choose "High" for printed codes that may get scratched.' },
  { q: 'Can I change the QR code colours?', a: 'Yes — use the colour pickers to set both the dark modules and the background. Ensure there is enough contrast for reliable scanning.' },
  { q: 'What if my text is too long?', a: 'QR codes have a maximum data capacity. If your text is too long, the tool will show an error. Try shortening the text or using a URL shortener.' },
  { q: 'What size QR code should I generate?', a: 'For digital use, 300–500 px is sufficient. For printing, generate at least 500–1000 px to ensure scanners can read it at a distance.' },
  { q: 'Can I add a logo or image in the centre?', a: 'This tool generates standard QR codes without logos. For a logo overlay, generate the QR code here and add a logo using image-editing software.' },
  { q: 'What is the difference between error correction levels?', a: 'Low (7% recovery), Medium (15%), Quartile (25%), and High (30%). Higher levels create denser QR codes but recover from more damage or obstruction.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="DeveloperApplication">
  <div class="mt-6 grid gap-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:grid-cols-2 sm:p-6">
    <div>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Text or link</span>
        <textarea id="text" rows="4" class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">https://toolnestr.com</textarea>
      </label>

      <div class="mt-4 space-y-3">
        <label class="block text-sm font-medium text-slate-700">
          Size <span id="size-val" class="font-mono text-indigo-600">300</span> px
          <input id="size" type="range" min="120" max="1000" step="20" value="300" class="mt-1 w-full accent-indigo-600" />
        </label>
        <div class="flex gap-4">
          <label class="flex items-center gap-2 text-sm text-slate-700">Dark
            <input id="dark" type="color" value="#000000" class="h-8 w-10 rounded border border-slate-300" />
          </label>
          <label class="flex items-center gap-2 text-sm text-slate-700">Background
            <input id="light" type="color" value="#ffffff" class="h-8 w-10 rounded border border-slate-300" />
          </label>
        </div>
        <label class="block text-sm font-medium text-slate-700">Error correction
          <select id="ecl" class="mt-1 w-full rounded-md border border-slate-300 px-2 py-2 text-sm">
            <option value="L">Low</option>
            <option value="M" selected>Medium</option>
            <option value="Q">Quartile</option>
            <option value="H">High (best for logos/print)</option>
          </select>
        </label>
      </div>
    </div>

    <div class="flex flex-col items-center justify-center">
      <div class="rounded-xl border border-slate-200 p-3">
        <canvas id="canvas" class="h-auto w-full max-w-[260px]"></canvas>
      </div>
      <button id="download-btn" class="mt-4 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">Download PNG</button>
      <p id="err" class="mt-2 hidden text-sm text-red-600"></p>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How QR codes work</h2>
    <p class="mt-2 text-slate-600">QR codes encode data using black and white modules arranged in a square grid. The data is encoded using Reed-Solomon error correction, which adds redundancy so the code can still be scanned even if partially damaged or obscured.</p>
    <p class="mt-3 text-slate-600">The generator takes your text or URL, encodes it into binary, applies the selected error correction level, and arranges the modules into the standard QR pattern including finder patterns, timing patterns, and alignment markers.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Encoding the ToolNestr homepage URL into a QR code.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Input:</span> <span class="text-slate-600 font-mono text-xs">https://toolnestr.com</span></div>
        <div><span class="font-medium text-slate-700">QR size:</span> <span class="text-slate-600">~25×25 modules with Medium error correction</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About QR codes</h2>
    <p class="mt-2 text-slate-600">
      A QR code is a scannable square barcode that instantly opens a link or shows text when
      someone points their phone camera at it. They're great for menus, posters, packaging,
      business cards and events. This generator creates crisp, high-resolution QR codes right in
      your browser, with no expiry and no tracking, and lets you download them as PNG images.
      Encode data from the <a href="/tools/base64" class="font-medium text-indigo-600 hover:underline">Base64 Encoder</a>
      into a QR code, or generate a secure link with the <a href="/tools/password-generator" class="font-medium text-indigo-600 hover:underline">Password Generator</a>
      and encode it for sharing.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Type or paste your link or text.</li>
      <li>Adjust the size and colours if you like.</li>
      <li>For printing on products, choose a higher error-correction level.</li>
      <li>Click "Download PNG".</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      QR codes bridge the gap between physical and digital spaces. Restaurants use them for contactless menus. Marketers put them on posters and billboards to drive traffic to landing pages. Event organisers include QR codes on tickets for quick check-ins. Business owners add them to product packaging for easy access to manuals or video tutorials. Developers encode configuration data, Wi-Fi credentials, and app store links into QR codes for rapid deployment. Anyone sharing a link in print or in person benefits from a scannable code.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different error correction levels mean</h2>
    <p class="mt-2 text-slate-600">Error correction determines how much of the QR code can be damaged or obscured while still being readable.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Low (L)</span><span class="text-slate-400">7% recovery — smallest code, best for clean surfaces</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Medium (M)</span><span class="text-slate-400">15% recovery — good balance for most uses</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:85%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Quartile (Q)</span><span class="text-slate-400">25% recovery — recommended for printed materials</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:65%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">High (H)</span><span class="text-slate-400">30% recovery — best for logos, curved surfaces, or damage-prone codes</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-400" style="width:50%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f373;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Restaurant Owner</h3>
      <p class="mt-1 text-sm text-slate-600">Creates contactless digital menus and QR codes for table ordering, review links, and Wi-Fi access for customers.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f3aa;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Event Organiser</h3>
      <p class="mt-1 text-sm text-slate-600">Generates QR codes for digital tickets, event check-ins, speaker links, and feedback forms distributed on printed materials.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4e6;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Product Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Adds QR codes to product packaging linking to user manuals, video tutorials, warranty registration, and reorder pages.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f468;&#x200d;&#x1f4bb;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Developer</h3>
      <p class="mt-1 text-sm text-slate-600">Encodes Wi-Fi credentials, API endpoints, app download links, and configuration data into scannable QR codes for fast setup.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Error Correction</th><th class="p-3">Recovery Rate</th><th class="p-3">Best Use Case</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Low (L)</td><td class="p-3">7%</td><td class="p-3">Digital screens, clean labels, controlled environments</td></tr>
        <tr><td class="p-3 font-medium">Medium (M)</td><td class="p-3">15%</td><td class="p-3">General purpose, brochures, flyers</td></tr>
        <tr><td class="p-3 font-medium">Quartile (Q)</td><td class="p-3">25%</td><td class="p-3">Printed posters, product packaging</td></tr>
        <tr><td class="p-3 font-medium">High (H)</td><td class="p-3">30%</td><td class="p-3">Curved surfaces, logos in centre, harsh environments</td></tr>
        <tr><td class="p-3 font-medium">Module size</td><td class="p-3">N/A</td><td class="p-3">Minimum 2–3 mm per module for print, 1 px for digital</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the QR code generator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your content</h3>
        <p class="mt-1 text-sm text-slate-600">Type or paste a URL, text, email address, phone number, or any other data into the input field.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Customise appearance</h3>
        <p class="mt-1 text-sm text-slate-600">Adjust the size, dark colour, background colour, and error correction level to suit your use case.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Download the PNG</h3>
        <p class="mt-1 text-sm text-slate-600">Click Download PNG to save your QR code as a high-resolution image ready for digital or print use.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for effective QR codes</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Ensure sufficient contrast</h3>
        <p class="mt-1 text-sm text-slate-600">Dark modules should be significantly darker than the background. Avoid light greys or pastels for the dark colour — black on white is the most reliable combination.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use a high error correction for print</h3>
        <p class="mt-1 text-sm text-slate-600">For printed codes on posters, packaging, or curved surfaces, choose High (H) error correction to ensure scannability even if the code gets scratched or folded.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Keep links short</h3>
        <p class="mt-1 text-sm text-slate-600">Shorter data produces a simpler QR code with fewer modules, which is easier to scan and works better at smaller sizes. Use a URL shortener if your link is long.</p>
      </div>
    </div>
  </section>

  <script>
    import qrcode from 'qrcode-generator';

    const el = (id) => document.getElementById(id);
    const text = el('text'), sizeEl = el('size'), sizeVal = el('size-val');
    const darkEl = el('dark'), lightEl = el('light'), eclEl = el('ecl');
    const canvas = el('canvas'), err = el('err');

    function draw() {
      const value = text.value || ' ';
      try {
        const qr = qrcode(0, eclEl.value);
        qr.addData(value);
        qr.make();
        const count = qr.getModuleCount();
        const margin = 4; // quiet zone in modules
        const size = parseInt(sizeEl.value, 10);
        const cell = Math.floor(size / (count + margin * 2));
        const dim = cell * (count + margin * 2);
        canvas.width = dim;
        canvas.height = dim;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = lightEl.value;
        ctx.fillRect(0, 0, dim, dim);
        ctx.fillStyle = darkEl.value;
        for (let r = 0; r < count; r++) {
          for (let c = 0; c < count; c++) {
            if (qr.isDark(r, c)) {
              ctx.fillRect((c + margin) * cell, (r + margin) * cell, cell, cell);
            }
          }
        }
        err.classList.add('hidden');
      } catch (e) {
        err.textContent = 'Text is too long for a QR code — try a shorter link.';
        err.classList.remove('hidden');
      }
    }

    [text, sizeEl, darkEl, lightEl, eclEl].forEach((e) => e.addEventListener('input', () => {
      sizeVal.textContent = sizeEl.value;
      draw();
    }));

    el('download-btn').addEventListener('click', () => {
      const a = document.createElement('a');
      a.href = canvas.toDataURL('image/png');
      a.download = 'qr-code.png';
      a.click();
    });

    draw();
  </script>
</ToolLayout>
