---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'QR Code Generator';
const description =
  'Free QR code generator. Create a QR code for any link, text, email or Wi-Fi and ' +
  'download it as a PNG. Made in your browser — fast, free and private.';
const intro =
  'Type a link or any text and your QR code appears instantly. Adjust the size and colour, then download it as a PNG.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'Do these QR codes expire?', a: 'No. The QR code encodes your text or link directly, so it works forever and never expires — there is no tracking or redirect.' },
  { q: 'Can I use it commercially?', a: 'Yes. The QR codes you generate are yours to use anywhere — posters, products, menus, business cards.' },
  { q: 'What can I put in a QR code?', a: 'Any text: a website URL, a phone number (tel:), an email (mailto:), or plain text. Keep links short for easier scanning.' },
  { q: 'Is my data uploaded?', a: 'No. The QR code is generated entirely in your browser.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="DeveloperApplication">
  <div class="mt-6 grid gap-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:grid-cols-2 sm:p-6">
    <div>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Text or link</span>
        <textarea id="text" rows="4" class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">https://toolnestr.com</textarea>
      </label>

      <div class="mt-4 space-y-3">
        <label class="block text-sm font-medium text-slate-700">
          Size <span id="size-val" class="font-mono text-indigo-600">300</span> px
          <input id="size" type="range" min="120" max="1000" step="20" value="300" class="mt-1 w-full accent-indigo-600" />
        </label>
        <div class="flex gap-4">
          <label class="flex items-center gap-2 text-sm text-slate-700">Dark
            <input id="dark" type="color" value="#000000" class="h-8 w-10 rounded border border-slate-300" />
          </label>
          <label class="flex items-center gap-2 text-sm text-slate-700">Background
            <input id="light" type="color" value="#ffffff" class="h-8 w-10 rounded border border-slate-300" />
          </label>
        </div>
        <label class="block text-sm font-medium text-slate-700">Error correction
          <select id="ecl" class="mt-1 w-full rounded-md border border-slate-300 px-2 py-2 text-sm">
            <option value="L">Low</option>
            <option value="M" selected>Medium</option>
            <option value="Q">Quartile</option>
            <option value="H">High (best for logos/print)</option>
          </select>
        </label>
      </div>
    </div>

    <div class="flex flex-col items-center justify-center">
      <div class="rounded-xl border border-slate-200 p-3">
        <canvas id="canvas" class="h-auto w-full max-w-[260px]"></canvas>
      </div>
      <button id="download-btn" class="mt-4 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">Download PNG</button>
      <p id="err" class="mt-2 hidden text-sm text-red-600"></p>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About QR codes</h2>
    <p class="mt-2 text-slate-600">
      A QR code is a scannable square barcode that instantly opens a link or shows text when
      someone points their phone camera at it. They’re great for menus, posters, packaging,
      business cards and events. This generator creates crisp, high-resolution QR codes right in
      your browser, with no expiry and no tracking, and lets you download them as PNG images.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Type or paste your link or text.</li>
      <li>Adjust the size and colours if you like.</li>
      <li>For printing on products, choose a higher error-correction level.</li>
      <li>Click “Download PNG”.</li>
    </ol>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Browse more <a href="/#developers" class="font-medium text-indigo-600 hover:underline">developer tools →</a>
    </p>
  </Fragment>

  <script>
    import qrcode from 'qrcode-generator';

    const el = (id) => document.getElementById(id);
    const text = el('text'), sizeEl = el('size'), sizeVal = el('size-val');
    const darkEl = el('dark'), lightEl = el('light'), eclEl = el('ecl');
    const canvas = el('canvas'), err = el('err');

    function draw() {
      const value = text.value || ' ';
      try {
        const qr = qrcode(0, eclEl.value);
        qr.addData(value);
        qr.make();
        const count = qr.getModuleCount();
        const margin = 4; // quiet zone in modules
        const size = parseInt(sizeEl.value, 10);
        const cell = Math.floor(size / (count + margin * 2));
        const dim = cell * (count + margin * 2);
        canvas.width = dim;
        canvas.height = dim;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = lightEl.value;
        ctx.fillRect(0, 0, dim, dim);
        ctx.fillStyle = darkEl.value;
        for (let r = 0; r < count; r++) {
          for (let c = 0; c < count; c++) {
            if (qr.isDark(r, c)) {
              ctx.fillRect((c + margin) * cell, (r + margin) * cell, cell, cell);
            }
          }
        }
        err.classList.add('hidden');
      } catch (e) {
        err.textContent = 'Text is too long for a QR code — try a shorter link.';
        err.classList.remove('hidden');
      }
    }

    [text, sizeEl, darkEl, lightEl, eclEl].forEach((e) => e.addEventListener('input', () => {
      sizeVal.textContent = sizeEl.value;
      draw();
    }));

    el('download-btn').addEventListener('click', () => {
      const a = document.createElement('a');
      a.href = canvas.toDataURL('image/png');
      a.download = 'qr-code.png';
      a.click();
    });

    draw();
  </script>
</ToolLayout>
