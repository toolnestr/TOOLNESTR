---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Quarts to Liters"
  emoji="🧪"
  fromUnit="US quarts" toUnit="liters"
  fromTitle="Quarts" toTitle="Liters"
  fromSym="qt" toSym="L"
  quantity="volume"
  kind="factor" factor={0.946353}
  reverseSlug="liters-to-gallons" reverseLabel="Liters to Gallons Converter"
  hasReverse={false}
  related={[{"slug":"volume-converter","label":"Volume Converter"}]}
  useCase="Convert quarts of milk, stock or oil into liters for metric shopping and cooking."
/>
