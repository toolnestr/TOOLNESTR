---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Neutralization Reaction Calculator';
const description = "Neutralization reaction calculator: mix an acid and base by concentration and volume to find excess H+ or OH- and whether the result is acidic or basic.";
const intro = 'Mix a specific amount of acid with a specific amount of base and find out what is left over: excess acid, excess base, or an exact match. A live 3D beaker and charts show the H+ vs OH- balance as you adjust the amounts.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is a neutralization reaction?', a: 'A neutralization reaction is the reaction of an acid with a base to form a salt and water: acid + base → salt + water. In aqueous solution, this is really H⁺ (from the acid) combining with OH⁻ (from the base) to form H₂O, while the leftover ions form the salt.' },
  { q: 'What determines if the mixed solution ends up acidic, basic, or neutral?', a: 'It comes down to which species has more moles available: moles of H⁺ (M_acid × V_acid × n_acid) versus moles of OH⁻ (M_base × V_base × n_base). If H⁺ moles are greater, the leftover H⁺ makes the solution acidic. If OH⁻ moles are greater, the leftover OH⁻ makes it basic. If they are exactly equal, all the H⁺ and OH⁻ have combined into water — for a strong acid and strong base, that gives a neutral solution.' },
  { q: 'What is the salt product in a neutralization reaction?', a: 'The salt is whatever is left after the H⁺ and OH⁻ combine into water — the acid\'s anion paired with the base\'s cation. For example, HCl + NaOH → NaCl + H₂O: the salt is sodium chloride. The identity of the salt does not change based on how much of each reactant you use, only the leftover acid or base does.' },
  { q: 'Does neutralization always give exactly pH 7?', a: 'No — only when a strong acid reacts with a strong base in exactly stoichiometric amounts. If either the acid or the base is weak, the resulting salt itself reacts with water (hydrolysis) and shifts the pH away from 7. For example, acetic acid + NaOH gives sodium acetate, a salt that makes the solution slightly basic (pH > 7) because acetate is a weak base. This calculator finds the H⁺/OH⁻ mole balance; it does not compute the exact resulting pH for weak-acid or weak-base systems.' },
  { q: 'How is this different from a titration calculation?', a: 'Titration is the step-by-step process of slowly adding a solution of known concentration from a burette until an indicator signals the equivalence point — it is a lab technique for finding an unknown concentration. This calculator instead takes two solutions with amounts you already know and asks a stoichiometry question: given these exact starting quantities, is there leftover acid or leftover base once they react, and how much?' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Neutralization Reaction Calculator',
  description: 'Find moles of H+ and OH- from concentration and volume, and determine which is in excess after an acid-base reaction.',
  steps: [
    { name: 'Enter the acid', text: 'Type the acid\'s molarity, volume, and n (H+ per formula unit — 1 for HCl, 2 for H2SO4).' },
    { name: 'Enter the base', text: 'Type the base\'s molarity, volume, and n (OH- per formula unit — 1 for NaOH, 2 for Ca(OH)2).' },
    { name: 'Read the result', text: 'Moles of H+ and OH- are compared instantly, showing the excess reagent and resulting character.' },
  ],
};

const formulas = [
  { expr: 'mol H⁺ = M<sub>acid</sub> × V<sub>acid</sub> × n<sub>acid</sub>', note: 'moles of hydrogen ion available' },
  { expr: 'mol OH⁻ = M<sub>base</sub> × V<sub>base</sub> × n<sub>base</sub>', note: 'moles of hydroxide ion available' },
  { expr: 'excess = |mol H⁺ − mol OH⁻|', note: 'leftover reagent once reaction goes to completion' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — strong acid + strong base, excess acid', tone: 'slate',
    given: '50 mL of 0.20 M HCl (n = 1) is mixed with 30 mL of 0.25 M NaOH (n = 1). What is left over?',
    rows: [
      { label: 'Moles H⁺:', value: '0.050 L × 0.20 M × 1 = 0.010 mol' },
      { label: 'Moles OH⁻:', value: '0.030 L × 0.25 M × 1 = 0.0075 mol' },
      { label: 'Excess:', value: '0.010 − 0.0075 = 0.0025 mol H⁺ remains', full: true },
    ],
    note: 'H⁺ is in excess, so the resulting solution is acidic — there is unreacted HCl beyond what the NaOH could neutralize.',
  },
  {
    title: 'Worked example 2 — diprotic acid, excess base', tone: 'amber',
    given: '20 mL of 0.15 M H₂SO₄ (n = 2, diprotic) is mixed with 40 mL of 0.20 M NaOH (n = 1). What is left over?',
    rows: [
      { label: 'Moles H⁺:', value: '0.020 L × 0.15 M × 2 = 0.0060 mol' },
      { label: 'Moles OH⁻:', value: '0.040 L × 0.20 M × 1 = 0.0080 mol' },
      { label: 'Excess:', value: '0.0080 − 0.0060 = 0.0020 mol OH⁻ remains', full: true },
    ],
    note: 'Each mole of H₂SO₄ supplies two moles of H⁺, so n = 2 is essential here — using n = 1 would wrongly predict excess acid instead of excess base.',
  },
];

const comparison = {
  heading: 'Common neutralization reactions and their salts',
  note: 'The salt identity depends only on the acid and base used — not on how much of each you mix.',
  headers: [{ label: 'Reaction' }, { label: 'Salt formed' }, { label: 'Resulting pH (stoichiometric mix)' }],
  rows: [
    ['HCl + NaOH → NaCl + H₂O', 'Sodium chloride', '≈ 7 (strong + strong)'],
    ['H₂SO₄ + 2NaOH → Na₂SO₄ + 2H₂O', 'Sodium sulfate', '≈ 7 (strong + strong)'],
    ['HNO₃ + KOH → KNO₃ + H₂O', 'Potassium nitrate', '≈ 7 (strong + strong)'],
    ['CH₃COOH + NaOH → CH₃COONa + H₂O', 'Sodium acetate', '&gt; 7 (weak acid + strong base — salt hydrolyzes basic)'],
  ],
  highlightIndex: 3,
  footnote: 'Only strong acid + strong base pairs land at pH ≈ 7 when mixed in exact stoichiometric amounts. Weak-acid or weak-base pairs form salts that themselves shift the pH away from 7.',
};

const realWorld = [
  { emoji: '💊', title: 'Antacids', body: 'Antacid tablets contain a mild base (like calcium carbonate or magnesium hydroxide) that neutralizes excess stomach acid (HCl), relieving heartburn by consuming H⁺ until the excess acid is used up.' },
  { emoji: '🏭', title: 'Wastewater treatment', body: 'Industrial and municipal wastewater is often acidic or basic before discharge. Plant operators dose acid or base by the mole to bring effluent pH into a safe range, using the same H⁺/OH⁻ balance this calculator computes.' },
  { emoji: '🌱', title: 'Soil pH correction', body: 'Agricultural lime (a base) neutralizes excess acidity in soil, while sulfur-based amendments can neutralize overly alkaline soil — both are large-scale acid-base stoichiometry problems, just spread across a field instead of a beaker.' },
  { emoji: '🧯', title: 'Lab spill neutralization', body: 'Spilled acids and bases in a lab are neutralized with a counter-reagent before cleanup. Knowing the moles of acid or base spilled lets responders add just enough neutralizer without overshooting into the opposite extreme.' },
];

const misconceptions = [
  { claim: '"Neutralization always produces a solution with pH exactly 7."', truth: 'Only true for a strong acid reacting with a strong base in exact stoichiometric amounts. If either partner is weak, the salt produced hydrolyzes in water and shifts the pH above or below 7 — see the acetic acid + NaOH row in the comparison table above.' },
  { claim: '"The acid and base must be added in equal volumes to neutralize."', truth: 'What matters is equal moles of H⁺ and OH⁻ (M × V × n on each side), not equal volumes. A small volume of concentrated acid can neutralize a much larger volume of dilute base, or vice versa.' },
  { claim: '"n is always 1 for every acid and base."', truth: 'n is the number of H⁺ (for acids) or OH⁻ (for bases) each formula unit supplies. HCl and NaOH have n = 1, but H₂SO₄ and Ca(OH)₂ have n = 2, and H₃PO₄ has n = 3. Forgetting n for polyprotic acids or polybasic bases is a common source of error, as in worked example 2 above.' },
  { claim: '"Whichever reagent has the bigger volume is automatically in excess."', truth: 'Excess depends on total moles of H⁺ or OH⁻, which folds in concentration and n as well as volume. A larger volume of a dilute, low-n reagent can still be outweighed by a smaller volume of a concentrated, higher-n reagent.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — acid-base reactions and neutralization (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/4-3-acid-base-reactions" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 4, Aqueous Reactions and Solution Stoichiometry.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — acid-base neutralization and salt hydrolysis.' },
];
const sourcesNote = 'mol H⁺ = M_acid × V_acid × n_acid; mol OH⁻ = M_base × V_base × n_base. Results are rounded for display.';

const howToUse = [
  { title: 'Enter the acid side', body: 'Molarity, volume, and n (H⁺ per formula unit) for the acid.' },
  { title: 'Enter the base side', body: 'Molarity, volume, and n (OH⁻ per formula unit) for the base.' },
  { title: 'Read the excess', body: 'The larger of mol H⁺ / mol OH⁻ tells you which reagent — and how much — remains.' },
];

const related = [
  { href: '/tools/titration-calculator', emoji: '🚰', title: 'Titration Calculator', desc: 'M1V1 = M2V2 — find an unknown concentration.' },
  { href: '/tools/henderson-hasselbalch-calculator', emoji: '🧯', title: 'Henderson-Hasselbalch Calculator', desc: 'pH = pKa + log([A-]/[HA]) for buffers.' },
  { href: '/tools/ph-calculator', emoji: '🧪', title: 'pH Calculator', desc: 'pH = -log[H+] — solve for any variable.' },
  { href: '/tools/normality-calculator', emoji: '⚗️', title: 'Normality Calculator', desc: 'N = eq/L and N = M×n — solve any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="neutralization is a race between moles of H+ and moles of OH- — whichever side brings more, wins, and the leftover decides whether the mixture ends up acidic or basic."
  howIntro="Because moles depend on concentration, volume, <em>and</em> how many H⁺ or OH⁻ each formula unit supplies (n), two solutions that look similar by volume can still neutralize very differently. Once mol H⁺ and mol OH⁻ are found, whichever is larger is left over after the smaller amount is fully consumed forming water."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where neutralization actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-6 sm:grid-cols-2">
      <div class="rounded-xl border border-red-100 bg-red-50/40 p-4">
        <h3 class="text-sm font-semibold text-red-700">Acid</h3>
        <div class="mt-3 grid gap-3">
          <label class="block"><span class="text-sm font-medium text-slate-700">Molarity, M<sub>acid</sub> (mol/L)</span>
            <input id="Ma" type="number" step="any" placeholder="e.g. 0.20" value="0.20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-sm font-medium text-slate-700">Volume, V<sub>acid</sub> (L)</span>
            <input id="Va" type="number" step="any" placeholder="e.g. 0.050" value="0.050" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-sm font-medium text-slate-700">n<sub>acid</sub> (H⁺ per formula unit)</span>
            <input id="na" type="number" step="1" min="1" placeholder="1 for HCl, 2 for H2SO4" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        </div>
      </div>
      <div class="rounded-xl border border-blue-100 bg-blue-50/40 p-4">
        <h3 class="text-sm font-semibold text-blue-700">Base</h3>
        <div class="mt-3 grid gap-3">
          <label class="block"><span class="text-sm font-medium text-slate-700">Molarity, M<sub>base</sub> (mol/L)</span>
            <input id="Mb" type="number" step="any" placeholder="e.g. 0.25" value="0.25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-sm font-medium text-slate-700">Volume, V<sub>base</sub> (L)</span>
            <input id="Vb" type="number" step="any" placeholder="e.g. 0.030" value="0.030" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-sm font-medium text-slate-700">n<sub>base</sub> (OH⁻ per formula unit)</span>
            <input id="nb" type="number" step="1" min="1" placeholder="1 for NaOH, 2 for Ca(OH)2" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        </div>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-red-50 p-5 text-center"><div class="text-sm text-red-600">Moles H⁺</div><div id="r-h" class="mt-1 text-2xl font-bold text-red-700">—</div></div>
      <div class="rounded-xl bg-blue-50 p-5 text-center"><div class="text-sm text-blue-600">Moles OH⁻</div><div id="r-oh" class="mt-1 text-2xl font-bold text-blue-700">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Result</div><div id="r-result" class="mt-1 text-lg font-bold">—</div></div>
    </div>
    <p id="neu-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-mix" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Acid and base streams merge into one mixture</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-red-500">red</span> acid stream and <span class="font-semibold text-blue-500">blue</span> base stream pour into the same beaker. In this snapshot there is slightly more H⁺ than OH⁻, so the mixed liquid settles on the reddish side — leftover acid, not a 50/50 blend.</p>
        </div>
        <div>
          <div id="diag-molebar" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Whichever bar is taller is left over</h3>
          <p class="mt-1 text-sm text-slate-600">For 0.050 L of 0.20 M HCl mixed with 0.030 L of 0.25 M NaOH: mol H⁺ = 0.010, mol OH⁻ = 0.0075. The taller <span class="font-semibold text-red-500">H⁺</span> bar means 0.0025 mol of acid remains once all the OH⁻ has reacted away.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Neutralization graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Moles H⁺ vs moles OH⁻ — the bigger bar is in excess</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-bar"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Excess vs acid volume (fixed base) — crossover from excess base to excess acid</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-crossover"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('neu-err').textContent = '';
        el('r-h').textContent = '—'; el('r-oh').textContent = '—'; el('r-result').textContent = '—';
        const Ma = parseFloat(el('Ma').value), Va = parseFloat(el('Va').value), na = parseFloat(el('na').value);
        const Mb = parseFloat(el('Mb').value), Vb = parseFloat(el('Vb').value), nb = parseFloat(el('nb').value);
        if ([Ma, Va, na, Mb, Vb, nb].some((v) => isNaN(v))) return;
        if (Ma < 0 || Va < 0 || Mb < 0 || Vb < 0) { el('neu-err').textContent = 'Concentrations and volumes cannot be negative.'; return; }
        if (na < 1 || nb < 1) { el('neu-err').textContent = 'n must be at least 1.'; return; }
        const molH = Ma * Va * na;
        const molOH = Mb * Vb * nb;
        el('r-h').textContent = fmt(molH) + ' mol';
        el('r-oh').textContent = fmt(molOH) + ' mol';
        const diff = molH - molOH;
        const tol = Math.max(molH, molOH) * 1e-6;
        if (Math.abs(diff) <= tol) {
          el('r-result').textContent = 'Exact neutralization';
        } else if (diff > 0) {
          el('r-result').textContent = fmt(diff) + ' mol H⁺ excess (acidic)';
        } else {
          el('r-result').textContent = fmt(-diff) + ' mol OH⁻ excess (basic)';
        }
      }
      ['Ma', 'Va', 'na', 'Mb', 'Vb', 'nb'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.bar = new Chart(el('chart-bar'), {
          type: 'bar',
          data: { labels: ['H⁺ (acid)', 'OH⁻ (base)'], datasets: [{ label: 'Moles', data: [0.010, 0.0075], backgroundColor: ['#ef4444', '#3b82f6'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Moles' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.crossover = new Chart(el('chart-crossover'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Excess (mol, + = acid, − = base)', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.2, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Acid volume (L)' } }, y: { title: { display: true, text: 'Excess H⁺ (mol)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts({ h: 0.010, oh: 0.0075 });
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        charts.bar.data.datasets[0].data = [s.h, s.oh]; charts.bar.update();
        // Crossover: sweep acid volume 0..0.1 L at a fixed acid molarity,
        // holding moles OH- fixed at the reference base amount, n=1 assumed for the sweep illustration.
        const Ma = 0.20; // reference molarity used purely to sweep volume for the illustrative crossover curve
        const L = [], D = [];
        for (let v = 0; v <= 0.1 + 1e-9; v += 0.005) {
          const molHAtV = Ma * v;
          L.push(v.toFixed(3));
          D.push(+(molHAtV - s.oh).toFixed(5));
        }
        charts.crossover.data.labels = L; charts.crossover.data.datasets[0].data = D; charts.crossover.update();
      }

      // ---- standalone 3D diagrams (static geometry, auto-rotating only) ----
      let diagMix = null, diagBar = null;

      function glassBeaker(THREE, radius) {
        const g = new THREE.Group();
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        g.add(new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, 5, 40, 1, true), glassMat));
        const bottom = new THREE.Mesh(new THREE.CircleGeometry(radius, 40), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
        return g;
      }

      // ---- diagram 1: two streams merging into a mixture (static snapshot, excess H+) ----
      function initDiagMix() {
        const c = el('diag-mix'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        s.scene.add(glassBeaker(THREE, 2.0));
        // mixed liquid, slightly reddish (excess H+ snapshot: 0.010 mol H+ vs 0.0075 mol OH-)
        const liquidMat = new THREE.MeshStandardMaterial({ color: 0xef8b8b, transparent: true, opacity: 0.5, roughness: 0.3 });
        const liquid = new THREE.Mesh(new THREE.CylinderGeometry(1.9, 1.9, 3.2, 40), liquidMat);
        liquid.position.y = -2.4 + 3.2 / 2; s.scene.add(liquid);
        // acid stream (red) pouring from upper-left
        const acidMat = new THREE.MeshStandardMaterial({ color: 0xef4444 });
        const acidStream = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 2.4, 12), acidMat);
        acidStream.position.set(-1.1, 1.6, 0); acidStream.rotation.z = 0.15; s.scene.add(acidStream);
        // base stream (blue) pouring from upper-right
        const baseMat = new THREE.MeshStandardMaterial({ color: 0x3b82f6 });
        const baseStream = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 2.4, 12), baseMat);
        baseStream.position.set(1.1, 1.6, 0); baseStream.rotation.z = -0.15; s.scene.add(baseStream);
        // a few static particles suspended in the mixture: more red than blue (excess H+)
        const pGeo = new THREE.SphereGeometry(0.11, 10, 10);
        for (let i = 0; i < 10; i++) { const p = new THREE.Mesh(pGeo, acidMat); const r = Math.sqrt(Math.random()) * 1.7, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -2.4 + Math.random() * 3.2, Math.sin(a) * r); s.scene.add(p); }
        for (let i = 0; i < 7; i++) { const p = new THREE.Mesh(pGeo, baseMat); const r = Math.sqrt(Math.random()) * 1.7, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -2.4 + Math.random() * 3.2, Math.sin(a) * r); s.scene.add(p); }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0035); s.renderer.render(s.scene, s.camera); }
        frame();
        diagMix = { resize: s.resize };
      }

      // ---- diagram 2: static bar comparison of mol H+ vs mol OH- for one fixed example ----
      function initDiagMoleBar() {
        const c = el('diag-molebar'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 1, 0), MOL_OPTS);
        const grid = new THREE.GridHelper(8, 8, 0xe2e8f0, 0xeef2f7); s.scene.add(grid);
        const molH = 0.010, molOH = 0.0075, scale = 250; // visual scale factor
        const hBar = new THREE.Mesh(new THREE.BoxGeometry(1.2, molH * scale, 1.2), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
        hBar.position.set(-1.6, (molH * scale) / 2 - 2, 0); s.scene.add(hBar);
        const ohBar = new THREE.Mesh(new THREE.BoxGeometry(1.2, molOH * scale, 1.2), new THREE.MeshStandardMaterial({ color: 0x3b82f6 }));
        ohBar.position.set(1.6, (molOH * scale) / 2 - 2, 0); s.scene.add(ohBar);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagBar = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[neutralization] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[neutralization] charts failed', e); }
        if (window.THREE) {
          try { initDiagMix(); } catch (e) { console.error('[neutralization] mix diagram failed', e); }
          try { initDiagMoleBar(); } catch (e) { console.error('[neutralization] mole bar diagram failed', e); }
        }
        mountResize([diagMix, diagBar]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
