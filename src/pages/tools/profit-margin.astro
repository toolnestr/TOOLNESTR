---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Profit Margin Calculator';
const description =
  'Free profit margin calculator. Enter your cost and selling price to instantly get profit, ' +
  'profit margin and markup percentage. Works in any currency.';
const intro =
  'Enter your cost and selling price to see your profit, profit margin and markup — essential numbers for any business.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'What\'s the difference between margin and markup?', a: 'Margin is profit as a percentage of the selling price; markup is profit as a percentage of the cost. A 50% markup is only a 33% margin, which is why the distinction matters.' },
  { q: 'How is profit margin calculated?', a: 'Profit margin = (selling price − cost) ÷ selling price × 100.' },
  { q: 'Can I use it for any product?', a: 'Yes — it works for any product or service in any currency.' },
  { q: 'What is a healthy profit margin?', a: 'It varies by industry. Grocery stores often operate on razor-thin margins of 1–3%, while software companies can have margins above 80%. A "good" margin is one that covers your costs, supports growth and is competitive in your market.' },
  { q: 'How do I price a product to achieve a target margin?', a: 'If you want a 40% margin and your cost is $30, divide the cost by (1 − 0.40) = 0.60, giving a selling price of $50. Use this calculator in reverse by adjusting the selling price until you hit your target margin.' },
  { q: 'Should I use margin or markup for my pricing strategy?', a: 'Margin is more commonly used for financial reporting and profitability analysis, while markup is often used for initial pricing. Understanding both helps you avoid common pricing mistakes — many businesses that think they\'re earning a 50% margin via a 50% markup are actually earning only a 33% margin.' },
  { q: 'What is a good markup percentage?', a: 'Markup varies by industry. Retail clothing often uses 50–100% markup (keystone pricing), grocery stores operate on 10–30% markup, while luxury goods can have 200–500% markup. A "good" markup covers all your costs and leaves room for profit at a competitive price.' },
  { q: 'Can I calculate margin for services too?', a: 'Absolutely. For services, your cost includes the time and materials required to deliver the service. Calculate your effective hourly cost (wages, overhead, tools) and compare it to the service fee you charge clients.' },
  { q: 'What is the difference between gross and net profit margin?', a: 'Gross profit margin accounts only for the direct cost of goods sold (COGS). Net profit margin subtracts all operating expenses including rent, salaries, marketing, and taxes. This calculator shows gross margin; your net margin will always be lower.' },
  { q: 'How do discounts affect my margin?', a: 'Discounts come straight off your profit. A 10% discount on a product with a 30% margin reduces your margin by about one-third. Use this calculator to enter the discounted selling price and see exactly how much margin you give up with any promotion.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Currency</span>
        <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option>$</option><option>€</option><option>£</option><option>₹</option><option>₨</option><option>¥</option><option>₦</option><option>A$</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Cost</span>
        <input id="cost" type="number" step="any" placeholder="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Selling price</span>
        <input id="price" type="number" step="any" placeholder="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Profit</div><div id="r-profit" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Profit margin</div><div id="r-margin" class="mt-1 text-2xl font-bold text-emerald-600">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Markup</div><div id="r-markup" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About profit margin</h2>
    <p class="mt-2 text-slate-600">
      Knowing your profit margin and markup is essential for pricing products, comparing suppliers
      and running a healthy business. This calculator instantly turns a cost and selling price into
      your profit, margin and markup — handy for shops, freelancers, dropshippers and online
      sellers. Once you know your margin, use the <a href="/tools/break-even" class="font-medium text-indigo-600 hover:underline">Break-even Calculator</a> to determine how many units you need to sell to turn a profit.
    </p>
      <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
      <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
        <li>Enter how much it costs you to produce or buy the product (cost).</li>
        <li>Enter the price you are selling it for (selling price).</li>
        <li>See your profit in currency, the profit margin percentage, and the markup percentage.</li>
        <li>Adjust either number to experiment with different pricing strategies.</li>
      </ol>

      <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
      <p class="mt-2 text-slate-600">
        This calculator is essential when you're setting prices for a new product line, evaluating whether a supplier's quote leaves enough room for profit, or running a promotion to see how much discount you can offer without eroding your margin. Online sellers use it daily to compare margins across different products and identify their most profitable items.
      </p>

      <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
        <li>Include all costs in your cost figure — materials, labor, shipping, payment processing fees and any overhead allocated per unit.</li>
        <li>Check your margins regularly; if your supplier raises prices, you'll need to decide between raising your price or accepting a lower margin.</li>
        <li>Compare profit margins across your entire product range to identify which items deserve more marketing spend.</li>
      </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different profit margins mean</h2>
    <p class="mt-2 text-slate-600">Profit margins vary dramatically by industry and business model. Here is how different margin ranges stack up across common sectors.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">1–5%</span><span class="text-slate-400">Low margin (grocery, commodity retail)</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:10%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">10–20%</span><span class="text-slate-400">Moderate margin (general retail)</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">25–40%</span><span class="text-slate-400">Good margin (specialty products)</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">45–60%</span><span class="text-slate-400">High margin (software, services)</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:70%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">65–80%</span><span class="text-slate-400">Very high margin (digital products)</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:85%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">80%+</span><span class="text-slate-400">Ultra-high margin (SaaS, info products)</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-purple-500" style="width:100%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Small Business Owner</h3>
      <p class="mt-1 text-sm text-slate-600">Set profitable prices for your products and services by understanding exactly how cost and price translate into margin and markup.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🛒</span>
      <h3 class="mt-2 font-semibold text-slate-900">E-commerce Seller</h3>
      <p class="mt-1 text-sm text-slate-600">Factor in product cost, shipping, fees, and advertising to calculate your true margin per item and identify your best-performing products.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏭</span>
      <h3 class="mt-2 font-semibold text-slate-900">Manufacturer</h3>
      <p class="mt-1 text-sm text-slate-600">Evaluate production costs against wholesale or retail pricing to ensure your manufacturing operation is running at a sustainable margin.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📊</span>
      <h3 class="mt-2 font-semibold text-slate-900">Financial Analyst</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly compute margin and markup for financial reports, supplier negotiations, or pricing strategy presentations to stakeholders.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Markup</th><th class="p-3">Equivalent margin</th><th class="p-3">Cost $50 → sell at</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">10%</td><td class="p-3">9.1%</td><td class="p-3">$55.00</td></tr>
        <tr><td class="p-3 font-medium">25%</td><td class="p-3">20.0%</td><td class="p-3">$62.50</td></tr>
        <tr><td class="p-3 font-medium">50%</td><td class="p-3">33.3%</td><td class="p-3">$75.00</td></tr>
        <tr><td class="p-3 font-medium">75%</td><td class="p-3">42.9%</td><td class="p-3">$87.50</td></tr>
        <tr><td class="p-3 font-medium">100%</td><td class="p-3">50.0%</td><td class="p-3">$100.00</td></tr>
        <tr><td class="p-3 font-medium">150%</td><td class="p-3">60.0%</td><td class="p-3">$125.00</td></tr>
        <tr><td class="p-3 font-medium">200%</td><td class="p-3">66.7%</td><td class="p-3">$150.00</td></tr>
        <tr><td class="p-3 font-medium">300%</td><td class="p-3">75.0%</td><td class="p-3">$200.00</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the profit margin calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your cost</h3>
        <p class="mt-1 text-sm text-slate-600">Type the total cost to produce or acquire one unit of your product, including materials, labor, shipping, and fees.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the selling price</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the price you charge your customer. The calculator instantly shows your profit, margin percentage, and markup percentage.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Optimize your pricing</h3>
        <p class="mt-1 text-sm text-slate-600">Adjust cost or price to experiment with different scenarios and find the pricing strategy that balances competitiveness with profitability.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for healthy profit margins</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Know your true costs</h3>
        <p class="mt-1 text-sm text-slate-600">Many businesses underestimate their costs by forgetting overhead allocation, payment processing fees, packaging, or the value of their own labor. Include every expense to get a real margin picture.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Monitor margins regularly</h3>
        <p class="mt-1 text-sm text-slate-600">Supplier price changes, shipping cost fluctuations, and currency shifts all affect your margin. Review your key products monthly and adjust pricing before margins shrink too far.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Focus on high-margin items</h3>
        <p class="mt-1 text-sm text-slate-600">Not all products are equal. Identify your highest-margin items and invest more marketing budget in them. A product with 60% margin needs far fewer sales to generate the same profit as one with 20% margin.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const cur = el('cur');
    const fmt = (n) => cur.value + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    function update() {
      const cost = parseFloat(el('cost').value);
      const price = parseFloat(el('price').value);
      if (isNaN(cost) || isNaN(price) || price <= 0) { ['r-profit', 'r-margin', 'r-markup'].forEach((id) => (el(id).textContent = '—')); return; }
      const profit = price - cost;
      el('r-profit').textContent = fmt(profit);
      el('r-margin').textContent = (Math.round(profit / price * 10000) / 100) + '%';
      el('r-markup').textContent = cost > 0 ? (Math.round(profit / cost * 10000) / 100) + '%' : '—';
    }
    ['cur', 'cost', 'price'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
