---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Electron Configuration Calculator';
const description = "Electron configuration calculator: find the full Aufbau-order configuration, noble-gas shorthand and valence electron count for any element.";
const intro = 'Find the full electron configuration for any element (Z = 1–118), following the Aufbau filling order, plus its noble-gas shorthand notation and valence electron count. Two 3D diagrams show electron shells filling up and compare the Aufbau exception where 4s fills before 3d, with charts showing subshell capacities and filling order.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is the Aufbau principle?', a: 'The Aufbau principle states that electrons fill the lowest-energy orbitals available first, following the order 1s, 2s, 2p, 3s, 3p, 4s, 3d, 4p, 5s, 4d, 5p, 6s, 4f, 5d, 6p, 7s, 5f, 6d, 7p — not simply shell-by-shell in numerical order.' },
  { q: 'Why does 4s fill before 3d?', a: 'Even though shell 3 is "lower" than shell 4, the 4s orbital happens to sit at a slightly lower energy level than 3d for the elements where this matters, so electrons occupy 4s first. This is one of several well-known Aufbau ordering exceptions.' },
  { q: 'How many electrons fit in each subshell?', a: 's subshells hold up to 2 electrons, p subshells hold up to 6, d subshells hold up to 10, and f subshells hold up to 14 — these capacities come directly from the number of orbitals available in each subshell type (1, 3, 5, and 7 orbitals respectively, times 2 electrons each).' },
  { q: 'What is noble-gas shorthand notation?', a: 'Instead of writing out every filled subshell, noble-gas shorthand replaces the electron configuration of the nearest preceding noble gas with its symbol in brackets — for example, Sodium (Z=11) is written [Ne]3s¹ instead of 1s²2s²2p⁶3s¹.' },
  { q: 'What are valence electrons?', a: 'Valence electrons are the electrons in an atom\'s outermost occupied shell, which largely determine its chemical bonding behavior. For main-group elements, this is simply the electrons in the highest-numbered s and p subshells; transition metals have some added nuance because their (n−1)d electrons can also participate in bonding.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Electron Configuration Calculator',
  description: 'Find the full electron configuration, noble-gas shorthand, and valence electron count for any element.',
  steps: [
    { name: 'Enter the atomic number', text: 'Type a value from 1 to 118 (or pick a common element preset).' },
    { name: 'Read the configuration', text: 'The full Aufbau-order configuration and noble-gas shorthand appear instantly.' },
    { name: 'Check the valence count', text: 'The valence electron count (from the highest principal shell) is shown alongside the configuration.' },
  ],
};

const formulas = [
  { expr: '1s 2s 2p 3s 3p 4s 3d 4p 5s 4d 5p 6s 4f 5d 6p 7s 5f 6d 7p', note: 'the Aufbau filling order — not simple shell-by-shell order' },
  { expr: 's = 2, p = 6, d = 10, f = 14', note: 'maximum electrons per subshell type' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — oxygen (Z = 8)', tone: 'slate',
    given: 'Oxygen has atomic number Z = 8. Find its full electron configuration and valence electron count.',
    rows: [
      { label: 'Fill order:', value: '1s² (2 total) → 2s² (4 total) → 2p⁴ (8 total, done)' },
      { label: 'Full configuration:', value: '1s²2s²2p⁴' },
      { label: 'Valence electrons:', value: '2s²2p⁴ = 6 valence electrons (shell n=2)', full: true },
    ],
    note: 'Oxygen needs 2 more electrons to fill its outer shell to a stable 8 — exactly why it so readily forms 2⁻ ions or two covalent bonds.',
  },
  {
    title: 'Worked example 2 — iron (Z = 26, an Aufbau-order example)', tone: 'amber',
    given: 'Iron has atomic number Z = 26. Find its full electron configuration, noting the 4s-before-3d filling order.',
    rows: [
      { label: 'Fill order:', value: '1s²(2) 2s²(4) 2p⁶(10) 3s²(12) 3p⁶(18) 4s²(20) 3d⁶(26, done)' },
      { label: 'Full configuration:', value: '1s²2s²2p⁶3s²3p⁶4s²3d⁶ (often reordered by shell as 1s²2s²2p⁶3s²3p⁶3d⁶4s²)' },
      { label: 'Noble-gas shorthand:', value: '[Ar]4s²3d⁶' },
      { label: 'Valence electrons:', value: '4s² = 2 (the outermost shell, n=4) — the 3d⁶ electrons are inner but chemically relevant for bonding', full: true },
    ],
    note: 'This is the classic Aufbau exception: 4s fills before 3d during buildup, even though 3d is conventionally written first when listing the final configuration by shell number.',
  },
];

const comparison = {
  heading: 'Subshell capacities and filling order',
  note: 'Each subshell type holds a fixed maximum number of electrons, based on how many orbitals it contains.',
  headers: [{ label: 'Subshell' }, { label: 'Orbitals' }, { label: 'Max electrons' }],
  rows: [
    ['s', '1', '2'],
    ['p', '3', '6'],
    ['d ★', '5', '10'],
    ['f', '7', '14'],
  ],
  highlightIndex: 2,
  footnote: '★ Each orbital holds a maximum of 2 electrons (opposite spins), so capacity = orbitals × 2 — this is where every subshell\'s maximum electron count comes from.',
};

const realWorld = [
  { emoji: '📊', title: 'Predicting chemical reactivity', body: 'An element\'s valence electron configuration predicts how many bonds it tends to form and how reactive it is — elements with nearly full or nearly empty outer shells (like halogens and alkali metals) are typically the most reactive.' },
  { emoji: '🧲', title: 'Magnetic properties of materials', body: 'Unpaired electrons in partially filled d or f subshells (common in transition metals and lanthanides) give materials like iron and neodymium their magnetic properties — a direct consequence of their electron configuration.' },
  { emoji: '🔬', title: 'Spectroscopy and atomic emission', body: 'When electrons absorb energy and jump between subshells, then fall back down, they emit light at specific wavelengths — the basis of atomic emission spectroscopy, flame tests, and neon signage.' },
  { emoji: '📐', title: 'Understanding periodic table blocks', body: "The periodic table's s-block, p-block, d-block, and f-block regions directly correspond to which subshell type is being filled last for elements in that region — electron configuration is the reason the table has the shape it does." },
];

const misconceptions = [
  { claim: '"Electrons fill shell 3 completely before any electrons enter shell 4."', truth: 'This is one of the most common electron-configuration misconceptions — the 4s subshell actually fills before 3d, due to its slightly lower energy. Filling follows the Aufbau order (1s,2s,2p,3s,3p,4s,3d,4p,...), not strict numerical shell order.' },
  { claim: '"Valence electrons always equal the total electron count."', truth: 'Only the electrons in the outermost occupied shell count as valence electrons — inner, already-filled shells (called the core) do not participate in ordinary bonding, even though they are still part of the atom\'s total electron count.' },
  { claim: '"Every element\'s configuration follows the Aufbau order exactly, with no exceptions."', truth: 'A handful of elements (notably Chromium and Copper) deviate from the predicted Aufbau order because a half-filled or fully-filled d subshell provides extra stability — Chromium is [Ar]4s¹3d⁵ rather than the naively predicted [Ar]4s²3d⁴.' },
  { claim: '"Noble-gas shorthand changes an element\'s actual electron count."', truth: "Shorthand notation is purely a writing convenience — [Ne]3s¹ for sodium represents exactly the same 11 electrons as the full 1s²2s²2p⁶3s¹, just with the noble-gas core abbreviated." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 6, "Electronic Structure and Periodic Properties of Elements" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/6-4-electronic-structure-of-atoms-electron-configurations" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 6, Electronic Structure of Atoms.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Electron configurations and the Aufbau principle.' },
];
const sourcesNote = 'Configurations follow the standard Aufbau filling order. A small number of known exceptions (e.g. Cr, Cu, and some heavier elements) are not special-cased in this calculator\'s default output — check a reference table for those specific elements.';

const howToUse = [
  { title: 'Enter the atomic number', body: 'Type Z from 1 to 118, or pick a preset element.' },
  { title: 'Read the configuration', body: 'The full configuration, shorthand, and valence count appear instantly.' },
  { title: 'Compare on the chart', body: 'See subshell capacities and how the filling order departs from simple shell order.' },
];

const related = [
  { href: '/tools/atom-calculator', emoji: '🔘', title: 'Atom Calculator', desc: 'Protons, neutrons, and electrons from atomic number and charge.' },
  { href: '/tools/isotope-calculator', emoji: '☢️', title: 'Isotope Calculator', desc: 'Protons, neutrons, electrons — plus weighted average atomic mass.' },
  { href: '/tools/atomic-mass-calculator', emoji: '🔬', title: 'Molar Mass Calculator', desc: 'Molar mass from chemical formula.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="electrons fill available orbitals from lowest energy to highest, and because orbital energies don't line up neatly with shell number, the real filling order (1s,2s,2p,3s,3p,4s,3d,...) zig-zags in a way that surprises students expecting strict numerical order."
  howIntro="Each subshell type holds a fixed number of electrons based on its orbital count (s:1, p:3, d:5, f:7 orbitals, each holding 2 electrons), giving maximum capacities of 2, 6, 10, and 14 respectively. Filling proceeds strictly by increasing energy level along the Aufbau order, adding electrons subshell by subshell until the atom's full electron count is reached. Noble-gas shorthand simply replaces everything up through the most recent completed noble-gas configuration with that gas's symbol in brackets, since that inner 'core' never participates in ordinary bonding."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where electron configuration actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Pick a preset, or enter an atomic number directly.</p>
    <div class="mb-4 flex flex-wrap gap-2">
      <button type="button" class="ec-preset rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white" data-z="8">Oxygen (8)</button>
      <button type="button" class="ec-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-z="11">Sodium (11)</button>
      <button type="button" class="ec-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-z="17">Chlorine (17)</button>
      <button type="button" class="ec-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-z="26">Iron (26)</button>
      <button type="button" class="ec-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-z="47">Silver (47)</button>
    </div>
    <label class="block"><span class="text-sm font-medium text-slate-700">Atomic number Z (1–118)</span>
      <input id="Z" type="number" step="1" min="1" max="118" value="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 grid grid-cols-1 gap-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Full electron configuration</div><div id="r-full" class="mt-1 break-words font-mono text-lg font-bold">—</div></div>
    </div>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Noble-gas shorthand</div><div id="r-short" class="mt-1 font-mono text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Valence electrons</div><div id="r-val" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="ec-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Filling order in 3D</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-shells" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Electron shells filling outward</h3>
          <p class="mt-1 text-sm text-slate-600">Nested shells around a central nucleus, each holding progressively more electrons as atomic number increases.</p>
        </div>
        <div>
          <div id="diag-exception" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. The 4s-before-3d exception</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-amber-500">4s subshell</span> (outer, amber) sits at slightly lower energy than the <span class="font-semibold text-indigo-600">3d subshell</span> (inner, indigo) — so it fills first.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Electron configuration graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Subshell capacity by type</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-capacity"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Cumulative electron count along the Aufbau order</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-cumulative"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const ORDER = [
        [1, 's', 2], [2, 's', 2], [2, 'p', 6], [3, 's', 2], [3, 'p', 6], [4, 's', 2], [3, 'd', 10],
        [4, 'p', 6], [5, 's', 2], [4, 'd', 10], [5, 'p', 6], [6, 's', 2], [4, 'f', 14], [5, 'd', 10],
        [6, 'p', 6], [7, 's', 2], [5, 'f', 14], [6, 'd', 10], [7, 'p', 6],
      ];
      const NOBLE = { 2: 'He', 10: 'Ne', 18: 'Ar', 36: 'Kr', 54: 'Xe', 86: 'Rn', 118: 'Og' };
      const SUP = { 0: '⁰', 1: '¹', 2: '²', 3: '³', 4: '⁴', 5: '⁵', 6: '⁶', 7: '⁷', 8: '⁸', 9: '⁹' };
      function sup(n) { return String(n).split('').map((d) => SUP[d]).join(''); }

      function buildConfig(Z) {
        let remaining = Z;
        const subs = [];
        for (const [n, l, cap] of ORDER) {
          if (remaining <= 0) break;
          const fill = Math.min(cap, remaining);
          subs.push({ n, l, fill, cap });
          remaining -= fill;
        }
        return subs;
      }
      function configString(subs) {
        return subs.map((s) => s.n + s.l + sup(s.fill)).join('');
      }
      function shorthand(subs, Z) {
        let cumulative = 0, splitIdx = -1, nobleZ = 0;
        for (let i = 0; i < subs.length; i++) {
          cumulative += subs[i].fill;
          if (NOBLE[cumulative] && cumulative < Z) { splitIdx = i; nobleZ = cumulative; }
        }
        if (splitIdx === -1) return configString(subs);
        const rest = subs.slice(splitIdx + 1);
        return '[' + NOBLE[nobleZ] + ']' + configString(rest);
      }
      function valenceCount(subs) {
        const maxN = Math.max(...subs.map((s) => s.n));
        return subs.filter((s) => s.n === maxN).reduce((a, s) => a + s.fill, 0);
      }

      function update() {
        el('ec-err').textContent = '';
        el('r-full').textContent = '—'; el('r-short').textContent = '—'; el('r-val').textContent = '—';
        const Z = parseInt(el('Z').value, 10);
        if (isNaN(Z)) return;
        if (Z < 1 || Z > 118) { el('ec-err').textContent = 'Atomic number must be between 1 and 118.'; return; }
        const subs = buildConfig(Z);
        el('r-full').textContent = configString(subs);
        el('r-short').textContent = shorthand(subs, Z);
        el('r-val').textContent = valenceCount(subs);
      }
      document.querySelectorAll('.ec-preset').forEach((b) => b.addEventListener('click', () => {
        document.querySelectorAll('.ec-preset').forEach((x) => (x.className = 'ec-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600'));
        b.className = 'ec-preset rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white';
        el('Z').value = b.getAttribute('data-z');
        update();
      }));
      el('Z').addEventListener('input', update);

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.capacity = new Chart(el('chart-capacity'), {
          type: 'bar',
          data: { labels: ['s', 'p', 'd', 'f'], datasets: [{ label: 'Max electrons', data: [2, 6, 10, 14], backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Maximum electrons' } } }, plugins: { legend: { display: false } } }),
        });
        const labels = [], data = [];
        let cum = 0;
        ORDER.forEach(([n, l, cap]) => { cum += cap; labels.push(n + l); data.push(cum); });
        charts.cumulative = new Chart(el('chart-cumulative'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'Cumulative electrons', data, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.15, pointRadius: 2 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Subshell (Aufbau order)' } }, y: { title: { display: true, text: 'Cumulative electron count' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: nested shells ----
      let diagShells = null;
      function initDiagShells() {
        const c = el('diag-shells'); if (!c) throw new Error('no container');
        const s = makeScene(c, 11, new THREE.Vector3(0, 0, 0), OPTS);
        s.scene.add(new THREE.Mesh(new THREE.SphereGeometry(0.5, 16, 14), new THREE.MeshStandardMaterial({ color: 0xef4444 })));
        const radii = [1.4, 2.4, 3.4, 4.2];
        const colors = [0x6366f1, 0xf59e0b, 0x10b981, 0x94a3b8];
        radii.forEach((r, i) => {
          const ring = new THREE.Mesh(new THREE.TorusGeometry(r, 0.03, 8, 48), new THREE.MeshBasicMaterial({ color: colors[i] }));
          ring.rotation.x = Math.PI / 2.4 + i * 0.15;
          s.scene.add(ring);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagShells = { resize: s.resize };
      }

      // ---- Diagram 2: 4s vs 3d energy exception ----
      let diagException = null;
      function initDiagException() {
        const c = el('diag-exception'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 1, 0), OPTS);
        const d3 = new THREE.Mesh(new THREE.TorusGeometry(1.6, 0.25, 12, 32), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.5 }));
        d3.position.y = 0.6; d3.rotation.x = Math.PI / 2;
        s.scene.add(d3);
        const s4 = new THREE.Mesh(new THREE.TorusGeometry(2.6, 0.2, 12, 32), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5 }));
        s4.position.y = 0.2; s4.rotation.x = Math.PI / 2;
        s.scene.add(s4);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagException = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[electron-config] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[electron-config] charts failed', e); }
        if (window.THREE) {
          try { initDiagShells(); } catch (e) { console.error('[electron-config] shells diagram failed', e); }
          try { initDiagException(); } catch (e) { console.error('[electron-config] exception diagram failed', e); }
        }
        mountResize([diagShells, diagException]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
