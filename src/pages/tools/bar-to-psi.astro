---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Bar to Psi"
  emoji="🔧"
  fromUnit="bar" toUnit="pounds per square inch"
  fromTitle="Bar" toTitle="PSI"
  fromSym="bar" toSym="psi"
  quantity="pressure"
  kind="factor" factor={14.5038}
  reverseSlug="psi-to-bar" reverseLabel="Psi to Bar Converter"
  hasReverse={false}
  related={[{"slug":"pressure-converter","label":"Pressure Converter"}]}
  useCase="Convert a metric pressure in bar into the psi used by many gauges, pumps and US manuals."
/>
