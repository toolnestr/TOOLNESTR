---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Sunglasses Size Calculator';
const description = 'Find the right sunglasses frame width and lens size from your face width measurement.';
const intro = 'Convert a face width measurement into a recommended sunglasses frame size.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I measure my face width for sunglasses?', a: 'Measure straight across your face from the outer edge of one temple (the flat area behind your eye, at the hairline) to the other, in millimeters. A soft tape measure or a ruler held against a mirror both work.' },
  { q: 'What do the three numbers inside a glasses temple mean?', a: 'They are lens width, bridge width, and temple (arm) length in millimeters, in that order — for example "52-18-140" means a 52mm lens, an 18mm bridge, and a 140mm temple arm, and together roughly determine the total frame width.' },
  { q: 'Why doesn\'t sunglasses sizing use S/M/L like clothing?', a: 'Frame fit depends on several independent measurements (lens width, bridge width, temple length) rather than one overall body size, so the optical industry standardized on the three-number millimeter system instead of a single letter size.' },
  { q: 'What if I am between two frame size categories?', a: 'Lean toward the smaller recommended range if you prefer a snugger fit, or the larger range for a more relaxed fit — frame width tolerance is more forgiving than clothing sizing since adjustable nose pads and flexible temples absorb small differences.' },
];
const howTo = {
  name: 'How to find your sunglasses size',
  steps: [
    { name: 'Measure your face width', text: 'Measure straight across your face, temple to temple, in millimeters.' },
    { name: 'Enter the measurement', text: 'Type your face width into the calculator.' },
    { name: 'Read your frame size', text: 'A recommended total frame width and lens width range appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Face width (mm, temple to temple)</span>
      <input id="face" type="number" step="any" placeholder="e.g. 135" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Frame size category</div>
        <div id="r-cat" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Total frame width</div><div id="r-frame" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Suggested lens width</div><div id="r-lens" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sgc-title sgc-desc">
      <title id="sgc-title">Sunglasses frame with lens width, bridge, and temple labeled</title>
      <desc id="sgc-desc">A pair of sunglasses viewed from above showing lens width, bridge width, and temple length as the three sizing numbers</desc>
      <ellipse cx="300" cy="110" rx="70" ry="45" fill="none" stroke="#e11d48" stroke-width="4" />
      <ellipse cx="500" cy="110" rx="70" ry="45" fill="none" stroke="#e11d48" stroke-width="4" />
      <line x1="370" y1="110" x2="430" y2="110" stroke="#e11d48" stroke-width="4" />
      <line x1="230" y1="90" x2="120" y2="60" stroke="#e11d48" stroke-width="4" />
      <line x1="570" y1="90" x2="680" y2="60" stroke="#e11d48" stroke-width="4" />
      <text x="300" y="170" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Lens width</text>
      <text x="400" y="150" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Bridge</text>
      <text x="150" y="45" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Temple</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Frame size is defined by lens width, bridge width, and temple length in millimeters</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How sunglasses sizing works</h2>
    <p class="mt-2 text-slate-600">
      Unlike clothing, sunglasses sizing is not one number but three, printed inside the temple arm as a sequence like "52-18-140": lens width, bridge width, and temple length, all in millimeters. Together, lens width times two plus bridge width gives a close approximation of the total frame width — the measurement that should roughly match the width of your face for a comfortable, well-proportioned fit.
    </p>
    <p class="mt-3 text-slate-600">
      This calculator works backward from your face width to suggest a frame-width range and a matching lens-width starting point, using general optical-retail sizing guidance: narrower faces pair best with smaller lens widths (roughly 48-52mm), medium faces with 52-56mm, and wider faces with 56-60mm or larger.
    </p>
    <p class="mt-3 text-xs text-slate-400">Sizing bands follow common optical-industry face-width guidance; the printed three-number code on any specific frame is the authoritative measurement for that model.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A face width measures 137mm temple to temple.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Face width:</span> <span class="text-slate-600">137 mm</span></div>
        <div><span class="font-medium text-slate-700">Category:</span> <span class="text-slate-600"><strong>Medium</strong></span></div>
        <div><span class="font-medium text-slate-700">Frame width target:</span> <span class="text-slate-600">~134-143 mm</span></div>
        <div><span class="font-medium text-slate-700">Lens width:</span> <span class="text-slate-600">~52-56 mm</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Buying sunglasses online without trying them on is the main reason this kind of sizing matters — frames that are too narrow pinch at the temples after an hour of wear, while frames that are too wide slide down the nose constantly, and neither problem is obvious from a product photo alone.
    </p>
    <p class="mt-3 text-slate-600">
      Prescription sunglasses raise the stakes further, since an ill-fitting frame with prescription lenses can throw off the optical center and cause eye strain, not just discomfort — which is why opticians measure face width directly before ordering rather than relying on a general size guess.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Bigger sunglasses always fit better since they cover more of the face." <strong class="text-slate-900">Not for fit.</strong> Oversized frames on a narrower face tend to sit unevenly and slide, since the temple hinges land past where the head actually curves inward — coverage and correct fit are separate things.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"The lens width number tells you the whole frame's width." <strong class="text-slate-900">Only part of it.</strong> Total frame width also depends on the bridge width and how far the lenses angle outward, so two frames with the same lens-width number can still fit differently.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/hat-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Hat Size Calculator</a>
      <a href="/tools/body-shape-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Body Shape Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Clothing Size Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const v = parseFloat(el('face').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      let cat, frameLo, frameHi, lensLo, lensHi;
      if (v < 130) { cat = 'Narrow'; frameLo = 124; frameHi = 133; lensLo = 48; lensHi = 52; }
      else if (v < 140) { cat = 'Medium'; frameLo = 134; frameHi = 143; lensLo = 52; lensHi = 56; }
      else { cat = 'Wide'; frameLo = 144; frameHi = 154; lensLo = 56; lensHi = 60; }
      el('r-cat').textContent = cat;
      el('r-frame').textContent = frameLo + '-' + frameHi + ' mm';
      el('r-lens').textContent = lensLo + '-' + lensHi + ' mm';
      el('results').classList.remove('hidden');
    }

    el('face').addEventListener('input', update);
  </script>
</ToolLayout>
