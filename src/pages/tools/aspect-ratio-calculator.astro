---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Aspect Ratio Calculator';
const description = 'Calculate aspect ratios and resize dimensions without distortion. Find the ratio of any width &times; height and scale to 16:9, 4:3, 1:1, 9:16 and more.';
const intro = 'Resize width or height while keeping the same aspect ratio — and find the ratio of any dimensions.';
const category = { id: 'images', name: 'Image Tools' };
const faqs = [
  { q: 'What does 16:9 mean?', a: 'For every 16 units of width there are 9 of height — the standard widescreen video shape.' },
  { q: 'How do I keep an image from stretching?', a: 'Scale width and height by the same ratio — this tool does that automatically.' },
  { q: 'What ratio is 1920×1080?', a: '16:9.' },
  { q: 'What is best for Instagram Reels/TikTok?', a: '9:16 (vertical).' },
  { q: 'What is 4:3 used for?', a: 'Older TVs and monitors, iPads, and many presentations.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">Original width &times; height</label>
        <div class="mt-1 flex items-center gap-2">
          <input id="origW" type="number" step="1" min="1" placeholder="Width" class="w-full rounded-lg border border-slate-300 p-2.5 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <span class="text-slate-400">&times;</span>
          <input id="origH" type="number" step="1" min="1" placeholder="Height" class="w-full rounded-lg border border-slate-300 p-2.5 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">New width &times; height</label>
        <div class="mt-1 flex items-center gap-2">
          <input id="newW" type="number" step="1" min="1" placeholder="Width" class="w-full rounded-lg border border-slate-300 p-2.5 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <span class="text-slate-400">&times;</span>
          <input id="newH" type="number" step="1" min="1" placeholder="Height" class="w-full rounded-lg border border-slate-300 p-2.5 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
    </div>

    <div class="mt-5 text-center">
      <span class="text-sm text-slate-500">Simplified ratio</span>
      <p id="ratioDisplay" class="mt-1 text-2xl font-bold text-indigo-700">&mdash;</p>
    </div>

    <div class="mt-5 flex flex-wrap justify-center gap-2">
      <button data-preset="16:9" class="rounded-lg border border-slate-300 bg-slate-50 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:border-indigo-300 hover:text-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-300">16:9</button>
      <button data-preset="4:3" class="rounded-lg border border-slate-300 bg-slate-50 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:border-indigo-300 hover:text-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-300">4:3</button>
      <button data-preset="1:1" class="rounded-lg border border-slate-300 bg-slate-50 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:border-indigo-300 hover:text-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-300">1:1</button>
      <button data-preset="21:9" class="rounded-lg border border-slate-300 bg-slate-50 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:border-indigo-300 hover:text-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-300">21:9</button>
      <button data-preset="9:16" class="rounded-lg border border-slate-300 bg-slate-50 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:border-indigo-300 hover:text-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-300">9:16</button>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How aspect ratio works</h2>
    <p class="mt-2 text-slate-600">Aspect ratio describes the proportional relationship between the width and height of an image, video, or screen. It is expressed as two numbers separated by a colon — for example, 16:9. This means that for every 16 units of width, there are 9 units of height. A 16:9 image could be 1920&times;1080, 1280&times;720, or 640&times;360 — the actual pixel count changes but the relationship between width and height does not.</p>
    <p class="mt-3 text-slate-600">When you change only one dimension of an image or video without adjusting the other proportionally, the content becomes distorted. This calculator ensures your new dimensions maintain the correct ratio automatically.</p>
    <div class="mt-6 flex justify-center">
      <svg viewBox="0 0 320 200" class="w-full max-w-sm">
        <rect x="10" y="10" width="160" height="90" fill="none" stroke="#6366f1" stroke-width="2" rx="4" />
        <rect x="180" y="10" width="130" height="73.125" fill="none" stroke="#6366f1" stroke-width="2" stroke-dasharray="4,3" rx="4" />
        <text x="90" y="140" text-anchor="middle" class="text-xs" fill="#6366f1" font-size="12">1920 &times; 1080</text>
        <text x="245" y="140" text-anchor="middle" class="text-xs" fill="#6366f1" font-size="12">1280 &times; 720</text>
        <text x="160" y="170" text-anchor="middle" class="text-xs" fill="#94a3b8" font-size="11">Same 16:9 ratio — matching proportion</text>
      </svg>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula</h2>
    <div class="mt-4 space-y-3 rounded-xl border border-slate-200 bg-slate-50 p-5 font-mono text-sm text-slate-700">
      <div><span class="font-semibold text-slate-900">Ratio</span> = width &#x2236; height <span class="text-slate-400">(simplified by dividing both by their GCD)</span></div>
      <div><span class="font-semibold text-slate-900">New height</span> = newWidth &times; (originalHeight / originalWidth)</div>
      <div><span class="font-semibold text-slate-900">New width</span> = newHeight &times; (originalWidth / originalHeight)</div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="mt-4 rounded-xl border border-slate-200 bg-white p-5">
      <p class="text-sm text-slate-600">Start with a Full HD frame at <span class="font-medium text-slate-900">1920 &times; 1080</span>. You want the new width to be <span class="font-medium text-slate-900">1280</span> pixels. What height keeps the picture from stretching?</p>
      <div class="mt-3 rounded-lg bg-slate-50 p-4 font-mono text-sm text-slate-700">
        newHeight = 1280 &times; (1080 / 1920)<br />
        newHeight = 1280 &times; 0.5625<br />
        <span class="font-semibold text-indigo-700">newHeight = 720</span>
      </div>
      <p class="mt-3 text-sm text-slate-600">Result: <span class="font-medium text-slate-900">1280 &times; 720</span> — still 16:9, perfectly proportioned with no distortion.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common use cases</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Resizing images without distortion</h3>
        <p class="mt-1 text-sm text-slate-600">When you resize an image for a blog, social media post, or thumbnail, keeping the aspect ratio prevents the subject from looking squished or stretched. Most image editors have a chain-link button that locks width and height together — this tool shows you exactly what the paired dimension should be.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Finding a screen&rsquo;s ratio</h3>
        <p class="mt-1 text-sm text-slate-600">Enter your monitor or phone display resolution (e.g. 3440&times;1440 for ultrawide) and the calculator instantly tells you its ratio. This is useful when choosing wallpapers or designing assets for a specific display.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Designing for social media</h3>
        <p class="mt-1 text-sm text-slate-600">Each platform has preferred aspect ratios: Instagram feed favours 1:1 and 4:5, YouTube thumbnails are 16:9, and TikTok/Reels use 9:16. This calculator helps you scale any source material to fit these formats without guesswork.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Video editing &amp; production</h3>
        <p class="mt-1 text-sm text-slate-600">Maintaining a consistent aspect ratio across a video project is critical. If you need to scale from 4K (3840&times;2160) to HD (1920&times;1080), the calculator confirms the dimensions stay proportional. It also helps when cropping timelines or fitting footage into different frame sizes.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common aspect ratios</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Ratio</th><th class="p-3">Example resolution</th><th class="p-3">Used for</th></tr></thead>
        <tbody class="divide-y divide-slate-100 text-slate-700">
          <tr><td class="p-3 font-medium">16:9</td><td class="p-3 font-mono text-xs">1920 &times; 1080</td><td class="p-3">HD video, YouTube, widescreen monitors</td></tr>
          <tr><td class="p-3 font-medium">4:3</td><td class="p-3 font-mono text-xs">1024 &times; 768</td><td class="p-3">Older TVs, iPads, presentations</td></tr>
          <tr><td class="p-3 font-medium">1:1</td><td class="p-3 font-mono text-xs">1080 &times; 1080</td><td class="p-3">Instagram feed squares, profile photos</td></tr>
          <tr><td class="p-3 font-medium">21:9</td><td class="p-3 font-mono text-xs">3440 &times; 1440</td><td class="p-3">Ultrawide monitors, cinematic video</td></tr>
          <tr><td class="p-3 font-medium">9:16</td><td class="p-3 font-mono text-xs">1080 &times; 1920</td><td class="p-3">TikTok, Instagram Reels, Stories</td></tr>
          <tr><td class="p-3 font-medium">3:2</td><td class="p-3 font-mono text-xs">1200 &times; 800</td><td class="p-3">DSLR photos, some laptops</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for resizing with aspect ratios</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Keep one dimension fixed</h3>
        <p class="mt-1 text-sm text-slate-600">When resizing, it helps to decide which dimension is more important. If width is fixed (e.g. a blog image that must span the full column), calculate the matching height. If height is the constraint (e.g. a banner), work from that value instead.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Non-integer results round to nearest pixel</h3>
        <p class="mt-1 text-sm text-slate-600">The math sometimes produces fractional pixels (e.g. 720.5). This calculator always rounds to the nearest whole pixel because screens display only full pixels. The slight adjustment is imperceptible at normal viewing sizes.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Know the ratio before you start</h3>
        <p class="mt-1 text-sm text-slate-600">Enter your original dimensions first and note the simplified ratio. Then decide whether you need to fit a width or height target. The ratio stays the same regardless of which dimension you change, so you can freely experiment with different sizes.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 flex flex-wrap gap-3">
      <a href="/tools/image-resizer" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-700">Image Resizer</a>
      <a href="/tools/image-cropper" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-700">Image Cropper</a>
      <a href="/tools/image-rotator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-700">Image Rotator</a>
    </div>
  </section>

  <script is:inline>
    const origW = document.getElementById('origW');
    const origH = document.getElementById('origH');
    const newW = document.getElementById('newW');
    const newH = document.getElementById('newH');
    const ratioDisplay = document.getElementById('ratioDisplay');
    const presetBtns = document.querySelectorAll('[data-preset]');

    function gcd(a, b) {
      a = Math.abs(a);
      b = Math.abs(b);
      while (b) { [a, b] = [b, a % b]; }
      return a;
    }

    function compute() {
      const ow = parseFloat(origW.value);
      const oh = parseFloat(origH.value);
      const nw = parseFloat(newW.value);
      const nh = parseFloat(newH.value);

      const filled = [ow, oh, nw, nh].filter(v => !isNaN(v)).length;

      if (filled < 3) {
        if (ow && oh) {
          const g = gcd(Math.round(ow), Math.round(oh));
          ratioDisplay.textContent = `${ow / g}:${oh / g}`;
        } else {
          ratioDisplay.textContent = '\u2014';
        }
        return;
      }

      if (isNaN(ow) && oh && nw && nh) {
        const val = Math.round(nw * (oh / nh));
        origW.value = val;
      } else if (isNaN(oh) && ow && nw && nh) {
        const val = Math.round(nh * (ow / nw));
        origH.value = val;
      } else if (isNaN(nw) && ow && oh && nh) {
        const val = Math.round(nh * (ow / oh));
        newW.value = val;
      } else if (isNaN(nh) && ow && oh && nw) {
        const val = Math.round(nw * (oh / ow));
        newH.value = val;
      }

      const wow = parseFloat(origW.value);
      const woh = parseFloat(origH.value);
      if (wow && woh) {
        const g = gcd(Math.round(wow), Math.round(woh));
        ratioDisplay.textContent = `${wow / g}:${woh / g}`;
      } else {
        ratioDisplay.textContent = '\u2014';
      }
    }

    function handlePreset(e) {
      const ratio = e.currentTarget.dataset.preset.split(':').map(Number);
      const ow = parseFloat(origW.value);
      const oh = parseFloat(origH.value);
      const nw = parseFloat(newW.value);
      const nh = parseFloat(newH.value);

      const filled = [ow, oh, nw, nh].filter(v => !isNaN(v)).length;

      if (ow && oh) {
        origW.value = ratio[0];
        origH.value = ratio[1];
        if (!isNaN(nw)) {
          newH.value = Math.round(nw * (ratio[1] / ratio[0]));
        } else if (!isNaN(nh)) {
          newW.value = Math.round(nh * (ratio[0] / ratio[1]));
        }
      } else if (nw && nh) {
        newW.value = ratio[0];
        newH.value = ratio[1];
      } else {
        origW.value = ratio[0];
        origH.value = ratio[1];
      }
      compute();
    }

    origW.addEventListener('input', compute);
    origH.addEventListener('input', compute);
    newW.addEventListener('input', compute);
    newH.addEventListener('input', compute);

    presetBtns.forEach(btn => btn.addEventListener('click', handlePreset));
  </script>
</ToolLayout>
