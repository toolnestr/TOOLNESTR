---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Inches to Cm"
  emoji="📏"
  fromUnit="inches" toUnit="centimeters"
  fromTitle="Inches" toTitle="Centimeters"
  fromSym="in" toSym="cm"
  quantity="length"
  kind="factor" factor={2.54}
  reverseSlug="cm-to-inches" reverseLabel="Cm to Inches Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Convert inches from US products and TV sizes into the centimeters used on most rulers and spec sheets."
/>
