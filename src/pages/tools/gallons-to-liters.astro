---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Gallons (US) to Liters"
  emoji="🧪"
  fromUnit="US gallons" toUnit="liters"
  fromTitle="Gallons" toTitle="Liters"
  fromSym="gal" toSym="L"
  quantity="volume"
  kind="factor" factor={3.785411784}
  reverseSlug="liters-to-gallons" reverseLabel="Liters to Gallons Converter"
  hasReverse={true}
  related={[{"slug":"volume-converter","label":"Volume Converter"}]}
  useCase="Convert US gallons of fuel, water or paint into the liters used on most labels and pumps."
/>
