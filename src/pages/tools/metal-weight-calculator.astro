---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Metal Weight Calculator';
const description = 'Calculate the weight of steel, stainless, aluminum, copper and brass bars, tubes, sheets and plates from their shape and dimensions.';
const intro = 'Find the weight of a metal bar, tube, sheet, or plate from its shape, size, and material — for steel, stainless, aluminum, copper, or brass.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate the weight of a metal bar?', a: 'Find the cross-section area, multiply by the length to get the volume, then multiply by the metal density. For a round steel bar, weight in pounds equals pi/4 times the diameter squared, times the length, times 0.2836 pounds per cubic inch, with all dimensions in inches.' },
  { q: 'What is the density of steel versus aluminum?', a: 'Steel is about 0.2836 pounds per cubic inch (490 lb/ft³), while aluminum is only about 0.0975 pounds per cubic inch (169 lb/ft³). That is why an aluminum part weighs roughly a third of the same part in steel.' },
  { q: 'Does this work for tube and pipe?', a: 'Yes. For round tube it subtracts the hollow inside area from the outside area before multiplying by length and density. For threaded pipe sized by nominal bore, use the dedicated pipe weight calculator, which works from the actual outside diameter and wall thickness.' },
  { q: 'Why does my supplier quote a slightly different weight?', a: 'Mills use nominal densities and rounded dimensions, and real bar has tolerances, mill scale, and coatings. Treat this as an accurate planning figure; exact shipping weight comes from the mill certificate.' },
];
const howTo = {
  name: 'How to calculate metal weight',
  steps: [
    { name: 'Pick shape and metal', text: 'Choose the profile and the alloy; the density is applied automatically.' },
    { name: 'Enter dimensions', text: 'Give the size in inches; the labels change to match the shape you chose.' },
    { name: 'Read the weight', text: 'See total weight, weight per foot, and the cross-section area.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Shape</span>
        <select id="shape" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="round">Round bar</option>
          <option value="square">Square bar</option>
          <option value="flat">Flat / rectangular bar</option>
          <option value="tube">Round tube</option>
          <option value="hex">Hexagon bar</option>
          <option value="sheet">Sheet / plate</option>
        </select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Metal</span>
        <select id="metal" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="0.2836">Carbon steel</option>
          <option value="0.2890">Stainless steel</option>
          <option value="0.0975">Aluminum</option>
          <option value="0.3230">Copper</option>
          <option value="0.3070">Brass</option>
        </select></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <label class="block"><span id="lbl-a" class="text-sm font-medium text-slate-700">Diameter (in)</span>
        <input id="dimA" type="number" step="any" placeholder="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="wrap-b" class="hidden block"><span id="lbl-b" class="text-sm font-medium text-slate-700">Width (in)</span>
        <input id="dimB" type="number" step="any" placeholder="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span id="lbl-len" class="text-sm font-medium text-slate-700">Length (in)</span>
        <input id="len" type="number" step="any" placeholder="36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <p id="hint" class="mt-3 text-xs text-slate-500"></p>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total weight</div>
        <div id="r-lb" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-kg" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Weight per foot</div><div id="r-perft" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cross-section area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="mw-title mw-desc">
      <title id="mw-title">Metal weight from area, length, and density</title>
      <desc id="mw-desc">A metal bar with its cross-section, showing weight equals area times length times density</desc>
      <circle cx="150" cy="150" r="55" fill="#c7d2fe" stroke="#6366f1" stroke-width="2" />
      <text x="150" y="230" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">cross-section area</text>
      <rect x="240" y="120" width="180" height="60" fill="#a5b4fc" stroke="#6366f1" stroke-width="2" />
      <text x="330" y="205" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">length</text>
      <rect x="470" y="95" width="260" height="120" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="490" y="123" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Weight formula</text>
      <text x="490" y="149" font-size="12" fill="#475569" font-family="system-ui,sans-serif">W = area &times; length &times; density</text>
      <text x="490" y="171" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Steel &rho; = 0.2836 lb/in&sup3;</text>
      <text x="490" y="193" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Aluminum &rho; = 0.0975 lb/in&sup3;</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Weight is the cross-section area times the length times the metal's density.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the metal weight calculator works</h2>
    <p class="mt-2 text-slate-600">
      Every solid piece of metal weighs its volume times its density. The calculator finds the cross-section area from the shape you pick, multiplies by the length to get the volume in cubic inches, and multiplies by the metal's density in pounds per cubic inch. Because the density is what changes between metals, the same bar in aluminum weighs about a third of what it does in steel.
    </p>
    <p class="mt-3 text-slate-600">
      Each shape has its own area formula. A round bar is pi divided by four times the diameter squared; a square bar is the side squared; a flat bar is width times thickness; a hexagon is about 0.866 times the width across the flats squared; and a round tube is the outside circle area minus the inside hole. Sheet and plate use width times thickness, with the length being the third dimension.
    </p>
    <p class="mt-3 text-slate-600">
      The densities come from standard ASTM material values: carbon steel 0.2836, stainless 0.289, aluminum 0.0975, copper 0.323, and brass 0.307 pounds per cubic inch. These are nominal figures used across the industry for estimating; the exact shipping weight of a specific heat of metal comes from the mill certificate.
    </p>
    <p class="mt-3 text-xs text-slate-400">Density values follow ASTM A29 and ASTM B209 reference tables for standard mill materials.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick shape and metal</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the profile and the alloy; the density is applied automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter dimensions</h3>
        <p class="mt-1 text-sm text-slate-600">Give the size in inches; the labels change to match the shape you chose.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the weight</h3>
        <p class="mt-1 text-sm text-slate-600">See total weight, weight per foot, and the cross-section area.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Round bar area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">A = &pi;&frasl;4 &times; D&sup2;</span>. A 1-inch bar: &pi;&frasl;4 &times; 1&sup2; = <strong>0.785 in&sup2;</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Volume and weight</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">W = A &times; L &times; &rho;</span>. A 36-inch steel bar: 0.785 &times; 36 &times; 0.2836 = <strong>8.02 lb</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Same bar in aluminum</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">0.785 &times; 36 &times; 0.0975</span> = <strong>2.76 lb</strong> — about 34% of the steel weight.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A stainless flat bar 2&Prime; wide, 0.25&Prime; thick, 48&Prime; long.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Area:</span> <span class="text-slate-600">2 &times; 0.25 = 0.5 in&sup2;</span></div>
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">0.5 &times; 48 = 24 in&sup3;</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">24 &times; 0.289 = <strong>6.94 lb</strong></span></div>
        <div><span class="font-medium text-slate-700">Per foot:</span> <span class="text-slate-600">6.94 &divide; 4 = 1.73 lb/ft</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why metal weight matters</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚚</span>
        <h3 class="mt-2 font-semibold text-slate-900">Ordering and freight</h3>
        <p class="mt-1 text-sm text-slate-600">Metal is priced and shipped by weight. Knowing the weight up front lets you compare quotes, check delivery tickets, and avoid overloading a trailer or hoist.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Structural loads</h3>
        <p class="mt-1 text-sm text-slate-600">The self-weight of steel members feeds directly into beam, hanger, and foundation design, so an accurate per-foot figure is a first step in any load takeoff.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🔧</span>
        <h3 class="mt-2 font-semibold text-slate-900">Fabrication and lifting</h3>
        <p class="mt-1 text-sm text-slate-600">Shops size cranes, jigs, and welds around part weight. Choosing aluminum over steel can cut a lifted assembly to a third of the weight for the same shape.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">♻️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Scrap value</h3>
        <p class="mt-1 text-sm text-slate-600">Scrap yards pay by weight and metal type. Estimating the weight of offcuts and old material tells you what a load of scrap is worth before you haul it in.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Railing and fence fabricators lean on this calculator constantly for stock ordering. A 20-foot length of 1-inch round steel bar — a common size for handrail pickets — comes out to 0.7854 × 240 × 0.2836 = about <strong>53.5 lb</strong>. Knowing that before the order goes in means the shop can plan how many bars fit on a pallet and whether a single worker can safely lift and carry one length.
    </p>
    <p class="mt-3 text-slate-600">
      Material selection often comes down to a direct weight comparison. A full 4×8 sheet of 1/8-inch steel plate weighs 576 × 0.2836 = <strong>163.4 lb</strong>, while the same sheet in aluminum is 576 × 0.0975 = <strong>56.2 lb</strong> — under a third of the weight. That difference is why aluminum shows up on ladders, trailer panels, and anything that gets lifted by hand, even though it costs more per pound than steel.
    </p>
    <p class="mt-3 text-slate-600">
      Scrap hauling is the other end of the use case. A 10-foot offcut of 1.5-inch OD steel tube with a 0.065-inch wall works out to a cross-section of 0.293 in², giving 0.293 × 120 × 0.2836 = about <strong>10 lb</strong> — enough for a shop to estimate a scrap load's value at the yard's per-pound rate before hauling it in.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Stainless steel and carbon steel weigh about the same, since they're both 'steel.'" <strong class="text-slate-900">Close, but not exact.</strong> Stainless (0.289 lb/in³) is roughly 2% denser than carbon steel (0.2836 lb/in³) because of its nickel and chromium content — a small difference on a single part, but it adds up on a large order.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A tube's weight is basically the same as a solid bar of the same outside diameter." <strong class="text-slate-900">Not even close.</strong> A 1.5-inch OD tube with a thin wall removes most of the interior material — the tube example above weighs about 10 lb over 10 feet, while a solid 1.5-inch round bar the same length weighs roughly 60 lb. The hollow center is most of the volume.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/rebar-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Rebar Calculator</a>
      <a href="/tools/pipe-weight-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Pipe Weight Calculator</a>
      <a href="/tools/board-foot-lumber-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Board Foot Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const shapes = {
      round:  { a: 'Diameter (in)', b: null, area: (A) => Math.PI / 4 * A.a * A.a, hint: 'Solid round bar.' },
      square: { a: 'Side (in)', b: null, area: (A) => A.a * A.a, hint: 'Solid square bar.' },
      flat:   { a: 'Thickness (in)', b: 'Width (in)', area: (A) => A.a * A.b, hint: 'Flat or rectangular bar: thickness × width.' },
      tube:   { a: 'Outside dia (in)', b: 'Wall thickness (in)', area: (A) => Math.PI / 4 * (A.a * A.a - Math.pow(A.a - 2 * A.b, 2)), hint: 'Round tube: outside diameter and wall thickness.' },
      hex:    { a: 'Across flats (in)', b: null, area: (A) => 0.86603 * A.a * A.a, hint: 'Hexagon bar measured across the flats.' },
      sheet:  { a: 'Thickness (in)', b: 'Width (in)', area: (A) => A.a * A.b, hint: 'Sheet or plate: thickness × width, with length as the third side.' },
    };

    function syncLabels() {
      const s = shapes[el('shape').value];
      el('lbl-a').textContent = s.a;
      if (s.b) { el('lbl-b').textContent = s.b; el('wrap-b').classList.remove('hidden'); }
      else { el('wrap-b').classList.add('hidden'); }
      el('lbl-len').textContent = el('shape').value === 'sheet' ? 'Length (in)' : 'Length (in)';
      el('hint').textContent = s.hint;
    }

    function update() {
      const s = shapes[el('shape').value];
      const A = { a: parseFloat(el('dimA').value), b: parseFloat(el('dimB').value) };
      const L = parseFloat(el('len').value);
      const density = parseFloat(el('metal').value);
      const needB = !!s.b;
      if (!A.a || A.a <= 0 || !L || L <= 0 || (needB && (!A.b || A.b <= 0))) {
        el('results').classList.add('hidden');
        return;
      }
      const area = s.area(A);
      if (!(area > 0)) { el('results').classList.add('hidden'); return; }
      const weight = area * L * density;
      const perFt = weight / (L / 12);
      const kg = weight * 0.453592;

      el('r-lb').textContent = weight.toFixed(2) + ' lb';
      el('r-kg').textContent = kg.toFixed(2) + ' kg';
      el('r-perft').textContent = perFt.toFixed(2) + ' lb/ft';
      el('r-area').textContent = area.toFixed(3) + ' in²';
      el('results').classList.remove('hidden');
    }

    el('shape').addEventListener('change', () => { syncLabels(); update(); });
    ['metal', 'dimA', 'dimB', 'len'].forEach((id) => {
      el(id).addEventListener('input', update);
      el(id).addEventListener('change', update);
    });
    syncLabels();
  </script>
</ToolLayout>
