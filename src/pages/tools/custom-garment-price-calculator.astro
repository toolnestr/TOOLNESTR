---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Custom Garment/Order Price Calculator';
const description = 'Price a custom, made-to-order, or small-batch garment from materials cost, labor hours and rate, and target profit margin.';
const intro = 'Calculate a fair price for a custom or made-to-order garment from materials, labor, and margin.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How is pricing a custom garment different from mass production?', a: 'Custom and small-batch garments don\'t benefit from bulk fabric discounts or spread-out overhead the way factory production does, so labor is usually costed directly by hours × hourly rate rather than SMV × cost-per-minute, and materials are priced individually rather than in bulk.' },
  { q: 'What hourly rate should I charge for sewing labor?', a: 'This varies enormously by skill level, region, and market — from an entry-level maker\'s rate to an experienced tailor\'s or couture rate. Research comparable makers in your market and skill tier rather than guessing; this calculator accepts whatever rate you enter.' },
  { q: 'Should I charge for pattern-making time separately?', a: 'If a custom pattern needs to be drafted from scratch (not reused from an existing block), that time is real labor and should be included in your total hours, either as a separate line or folded into the total sewing time entered here.' },
  { q: 'How much profit margin should I add?', a: 'There\'s no universal number — many independent makers target 20-40% margin after materials and labor are covered, but it depends on your market position, how in-demand your work is, and what similar makers charge.' },
];
const howTo = {
  name: 'How to price a custom garment',
  steps: [
    { name: 'Enter materials cost', text: 'Total cost of fabric, trims, and any notions for this specific piece.' },
    { name: 'Enter labor hours and rate', text: 'How many hours the piece takes to make, and your hourly labor rate.' },
    { name: 'Set profit margin', text: 'The percentage you want to add on top of materials + labor.' },
    { name: 'Read the final price', text: 'The suggested price to charge the customer appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Materials cost ($)</span>
        <input id="materials" type="number" step="any" placeholder="e.g. 45" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Labor hours</span>
        <input id="hours" type="number" step="any" placeholder="e.g. 6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Hourly rate ($)</span>
        <input id="rate" type="number" step="any" placeholder="e.g. 25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Profit margin (%)</span>
        <input id="margin" type="number" step="any" placeholder="e.g. 25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Suggested price</div>
        <div id="r-price" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Labor cost</div><div id="r-labor" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Subtotal</div><div id="r-sub" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Profit</div><div id="r-profit" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How custom garment pricing works</h2>
    <p class="mt-2 text-slate-600">
      Custom and made-to-order pieces are priced bottom-up: materials cost plus labor cost (hours worked × hourly rate) gives the subtotal, and profit margin is applied on top of that subtotal to reach the final customer price. This mirrors the layered logic of factory garment costing, but with hourly labor replacing SMV-based CM cost, since custom work rarely runs at industrial-line efficiency.
    </p>
    <p class="mt-3 text-slate-600">
      The most common pricing mistake independent makers report is underestimating actual hours spent — fitting, pattern adjustments, and finishing details all add real time that's easy to forget when quoting from memory rather than tracking hours as the work happens. Underpricing labor is the single biggest reason custom sewing businesses struggle to be sustainable, even when demand for their work is strong.
    </p>
    <p class="mt-3 text-xs text-slate-400">Materials + labor (hours × rate) + margin follows standard small-batch/bespoke apparel pricing methodology.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A custom bridesmaid dress: $45 materials, 6 hours at $25/hr, 25% margin.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Labor cost:</span> <span class="text-slate-600">6 × 25 = $150</span></div>
        <div><span class="font-medium text-slate-700">Subtotal:</span> <span class="text-slate-600">45 + 150 = $195</span></div>
        <div><span class="font-medium text-slate-700">+ 25% margin:</span> <span class="text-slate-600">195 × 1.25 = <strong>$243.75</strong></span></div>
        <div><span class="font-medium text-slate-700">Final price:</span> <span class="text-slate-600"><strong>$243.75</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Independent bridal and formalwear makers are a classic example where this calculation matters: a $45-in-materials dress that takes 6 hours to construct properly (fitting included) is genuinely worth well over $200 once labor is fairly valued — pricing it at "cost of materials plus a little extra" is a common early-career mistake that leads directly to burnout.
    </p>
    <p class="mt-3 text-slate-600">
      Custom tailoring and alteration shops in high cost-of-living cities generally charge noticeably higher hourly rates than the same skill level in lower cost-of-living areas, since the rate has to cover the maker's real local cost of doing business, not just reflect the garment's complexity.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Custom work should just cost materials plus a bit extra." <strong class="text-slate-900">Labor is usually the larger cost.</strong> Skilled sewing time is real, valuable labor — pricing that ignores it or undervalues it isn't sustainable for a maker's business.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"I should charge what a similar-looking mass-produced garment costs." <strong class="text-slate-900">Not a fair comparison.</strong> Mass production spreads labor and overhead across thousands of identical units; a one-off custom piece carries its full labor cost alone, so it's expected to cost significantly more.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/alteration-cost-estimator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Alteration Cost Estimator</a>
      <a href="/tools/garment-cost-sheet-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Quick Cost Sheet Calculator</a>
      <a href="/tools/cost-per-wear-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Cost-Per-Wear Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const materials = parseFloat(el('materials').value) || 0;
      const hours = parseFloat(el('hours').value) || 0;
      const rate = parseFloat(el('rate').value) || 0;
      const margin = parseFloat(el('margin').value);
      if (!((materials + hours * rate) > 0 && margin >= 0)) { el('results').classList.add('hidden'); return; }

      const labor = hours * rate;
      const sub = materials + labor;
      const price = sub * (1 + margin / 100);
      const profit = price - sub;

      el('r-labor').textContent = '$' + labor.toFixed(2);
      el('r-sub').textContent = '$' + sub.toFixed(2);
      el('r-profit').textContent = '$' + profit.toFixed(2);
      el('r-price').textContent = '$' + price.toFixed(2);
      el('results').classList.remove('hidden');
    }

    ['materials', 'hours', 'rate', 'margin'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
