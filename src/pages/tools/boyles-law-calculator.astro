---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Boyle's Law Calculator";
const description = "Boyle's Law calculator with a live 3D piston and charts. Solve P1V1 = P2V2 for any variable, with worked examples on compression, scuba diving and syringes.";
const intro = "Solve P₁V₁ = P₂V₂ for any of the four variables. A live 3D piston shows particle density rising as volume shrinks, with charts of the classic inverse P–V curve.";
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is Boyle's law?", a: "Boyle's law states that at constant temperature and a fixed amount of gas, pressure and volume are inversely proportional: P₁V₁ = P₂V₂. Compress a gas to half its volume and its pressure doubles." },
  { q: "What has to stay constant for Boyle's law to apply?", a: "Temperature and the amount of gas (moles) must both stay constant. Boyle's law only isolates the pressure–volume relationship when those two are fixed — if temperature changes too, you need the combined gas law instead." },
  { q: 'Why does compressing a gas increase its pressure at the particle level?', a: 'Pressure comes from gas molecules colliding with the container walls. Squeezing the same number of molecules into a smaller volume packs them closer together, so they hit the walls more often per second — more collisions per second means higher pressure, even though nothing about the molecules themselves changed.' },
  { q: 'Does Boyle\'s law apply to liquids or solids?', a: "No. Boyle's law describes ideal (or near-ideal) gas behaviour only. Liquids and solids are essentially incompressible — their volume barely changes under pressure — so the inverse P-V relationship simply doesn't apply to them." },
  { q: 'How is Boyle\'s law different from Charles\'s law?', a: "Boyle's law holds temperature constant and relates pressure to volume (inverse relationship). Charles's law holds pressure constant and relates volume to temperature (direct relationship). They are two different slices through the same ideal gas law, PV = nRT." },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: "How to use the Boyle's Law Calculator",
  description: 'Calculate the missing pressure or volume value using P1V1 = P2V2.',
  steps: [
    { name: 'Enter three values', text: 'Type any three of P₁, V₁, P₂, V₂. Leave the unknown one blank.' },
    { name: 'Read the result', text: 'The fourth value solves instantly.' },
    { name: 'Explore the piston', text: 'Drag the volume slider to see particle density and pressure respond live.' },
  ],
};

const formulas = [
  { expr: 'P₁V₁ = P₂V₂', note: 'pressure × volume is constant at fixed T and n' },
  { expr: 'P₂ = P₁V₁ / V₂', note: 'solve for the new pressure' },
  { expr: 'V₂ = P₁V₁ / P₂', note: 'solve for the new volume' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — compressing a gas cylinder', tone: 'slate',
    given: 'A gas occupies 4.00 L at 2.00 atm. It is compressed at constant temperature until its volume is 1.00 L. Find the new pressure.',
    rows: [
      { label: 'Rearrange:', value: 'P₂ = P₁V₁ ÷ V₂' },
      { label: 'Substitute:', value: 'P₂ = (2.00 × 4.00) ÷ 1.00' },
      { label: 'New pressure:', value: 'P₂ = 8.00 atm', full: true },
    ],
    note: 'Volume dropped to a quarter of its original size, so pressure quadrupled — exactly as the inverse relationship predicts.',
  },
  {
    title: 'Worked example 2 — a diver\'s lungs on ascent', tone: 'amber',
    given: "A scuba diver at 10 m depth (ambient pressure ≈ 2.00 atm) takes a breath filling their lungs to 3.00 L, then holds it while ascending to the surface (1.00 atm). Find the lung volume at the surface.",
    rows: [
      { label: 'Rearrange:', value: 'V₂ = P₁V₁ ÷ P₂' },
      { label: 'Substitute:', value: 'V₂ = (2.00 × 3.00) ÷ 1.00' },
      { label: 'New volume:', value: 'V₂ = 6.00 L', full: true },
    ],
    note: 'The trapped air would double in volume — this is exactly why divers are trained to exhale continuously while ascending, never to hold their breath.',
  },
];

const comparison = {
  heading: "Boyle's law vs Charles's law vs Gay-Lussac's law",
  note: 'Each law holds one variable fixed and relates the other two — easy to mix up unless you track what stays constant.',
  headers: [{ label: 'Law' }, { label: 'Held constant' }, { label: 'Relationship' }],
  rows: [
    ["Boyle's law", 'Temperature, moles', 'P and V — inversely proportional (P₁V₁ = P₂V₂)'],
    ["Charles's law", 'Pressure, moles', 'V and T — directly proportional (V₁/T₁ = V₂/T₂)'],
    ["Gay-Lussac's law", 'Volume, moles', 'P and T — directly proportional (P₁/T₁ = P₂/T₂)'],
  ],
  highlightIndex: 0,
  footnote: 'All three are special cases of the combined/ideal gas law PV = nRT, each freezing one variable to isolate the other two.',
};

const realWorld = [
  { emoji: '🤿', title: 'Scuba diving', body: "As a diver ascends, ambient pressure drops, so trapped air in the lungs and BCD expands. Divers ascend slowly and exhale continuously to avoid dangerous over-expansion injuries — a direct, high-stakes application of Boyle's law." },
  { emoji: '💉', title: 'Syringes and medical devices', body: 'Pulling back a syringe plunger increases the internal volume, which drops the pressure below atmospheric and draws fluid in. Pushing the plunger does the reverse, forcing fluid out under higher pressure.' },
  { emoji: '🎈', title: 'Weather balloons', body: 'As a weather balloon rises into the low-pressure upper atmosphere, the gas inside expands — the balloon visibly grows larger the higher it climbs, until it eventually bursts.' },
  { emoji: '🧴', title: 'Aerosol cans', body: 'Aerosol cans hold gas at high pressure in a small volume. Puncturing or overheating the can lets that compressed gas rapidly expand, which is why they carry pressure and heat warnings.' },
];

const misconceptions = [
  { claim: '"Boyle\'s law works even if temperature changes too."', truth: "False — temperature (and the amount of gas) must be held constant. That constraint is the entire premise of the law. If temperature changes, you need the combined gas law, P₁V₁/T₁ = P₂V₂/T₂, instead." },
  { claim: '"Pressure and volume are directly proportional."', truth: "False — they are inversely proportional. As one goes up, the other goes down by the same factor, so their product PV stays constant. That inverse relationship is the whole point of Boyle's law." },
  { claim: '"Boyle\'s law applies to any substance, not just gases."', truth: 'False — it describes ideal (or near-ideal) gas behaviour specifically. Liquids and solids are nearly incompressible, so squeezing them barely changes their volume at all.' },
  { claim: '"Doubling the pressure always doubles something else."', truth: 'Doubling the pressure halves the volume, not doubles it — because the relationship is inverse. It is easy to default to "proportional means bigger with bigger," which is backwards here.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — gas laws and Boyle\'s law (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/9-2-relating-pressure-volume-amount-and-temperature-the-ideal-gas-law" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 10, Gases.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — the gas laws and kinetic molecular theory.' },
];
const sourcesNote = 'Boyle\'s law assumes constant temperature and a fixed amount of gas (n). Results are rounded for display.';

const howToUse = [
  { title: 'Enter three values', body: 'Fill any three of P₁, V₁, P₂, V₂; the fourth solves live.' },
  { title: 'Check units', body: 'Pressure and volume just need matching units on both sides — atm, kPa, L or mL all work.' },
  { title: 'See it in the piston', body: 'Drag the volume slider and watch particle density and pressure respond instantly.' },
];

const related = [
  { href: '/tools/ideal-gas-law-calculator', emoji: '🧮', title: 'Ideal Gas Law Calculator', desc: 'PV = nRT — solve for any variable.' },
  { href: '/tools/gas-laws-calculator', emoji: '🌡️', title: "Boyle's & Charles's Law Calculator", desc: 'Switch between multiple gas laws in one tool.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'M = mol/L — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="squeeze a gas into a smaller volume at constant temperature and its pressure rises by exactly the same factor — pressure and volume trade places, but their product never changes."
  howIntro="Rearranged, P₁V₁ = P₂V₂ solves any of the four variables: P₂ = P₁V₁/V₂ and V₂ = P₁V₁/P₂. It only holds when temperature and the amount of gas (moles) stay fixed — that constraint is what makes it Boyle's law rather than the more general combined gas law."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Boyle's law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Pressure P₁</span>
        <input id="P1" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume V₁</span>
        <input id="V1" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pressure P₂</span>
        <input id="P2" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume V₂</span>
        <input id="V2" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P₁</div><div id="r-P1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">V₁</div><div id="r-V1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P₂</div><div id="r-P2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">V₂</div><div id="r-V2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="bl-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D piston + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-piston" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Same gas, packed tighter</h3>
          <p class="mt-1 text-sm text-slate-600">Two snapshots of the <em>same amount</em> of gas: compressed into a small volume (dense particles, high pressure) vs. expanded into a large volume (sparse particles, low pressure). Nothing was added or removed — only the space changed.</p>
        </div>
        <div>
          <div id="diag-pv-curves" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. A family of inverse curves</h3>
          <p class="mt-1 text-sm text-slate-600">Each curve traces P × V = constant for a different fixed value. Every gas sample sits on exactly one such curve — moving along it is what Boyle's law describes.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Boyle's law graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pressure vs volume — the classic inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pv"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">PV product vs volume — constant, by Boyle's law</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pvconst"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('bl-err').textContent = '';
        ['r-P1', 'r-V1', 'r-P2', 'r-V2'].forEach((id) => (el(id).textContent = '—'));
        const P1 = parseFloat(el('P1').value), V1 = parseFloat(el('V1').value);
        const P2 = parseFloat(el('P2').value), V2 = parseFloat(el('V2').value);
        const vals = { P1, V1, P2, V2 };
        const filled = Object.keys(vals).filter((k) => !isNaN(vals[k]));
        if (filled.length < 3) return;
        const missing = Object.keys(vals).filter((k) => isNaN(vals[k]));
        if (missing.length !== 1) {
          // all four given — just display them
          el('r-P1').textContent = fmt(P1) + ' atm';
          el('r-V1').textContent = fmt(V1) + ' L';
          el('r-P2').textContent = fmt(P2) + ' atm';
          el('r-V2').textContent = fmt(V2) + ' L';
          return;
        }
        const m = missing[0];
        let out = { P1, V1, P2, V2 };
        try {
          if (m === 'P1') { if (V1 === 0) throw new Error('V1 cannot be zero.'); out.P1 = (P2 * V2) / V1; }
          else if (m === 'V1') { if (P1 === 0) throw new Error('P1 cannot be zero.'); out.V1 = (P2 * V2) / P1; }
          else if (m === 'P2') { if (V2 === 0) throw new Error('V2 cannot be zero.'); out.P2 = (P1 * V1) / V2; }
          else if (m === 'V2') { if (P2 === 0) throw new Error('P2 cannot be zero.'); out.V2 = (P1 * V1) / P2; }
        } catch (e) { el('bl-err').textContent = e.message; return; }
        el('r-P1').textContent = fmt(out.P1) + ' atm';
        el('r-V1').textContent = fmt(out.V1) + ' L';
        el('r-P2').textContent = fmt(out.P2) + ' atm';
        el('r-V2').textContent = fmt(out.V2) + ' L';
      }
      ['P1', 'V1', 'P2', 'V2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const K = 6; // fixed P1*V1 = 2.00 atm * 3.00 L for chart reference
      const charts = {};
      function pState() { return { v: 3, p: K / 3 }; }

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.pv = new Chart(el('chart-pv'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'P', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Volume (L)' } }, y: { title: { display: true, text: 'Pressure (atm)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.pvconst = new Chart(el('chart-pvconst'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'PV', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Volume (L)' } }, y: { title: { display: true, text: 'P × V (atm·L)' }, suggestedMin: 0, suggestedMax: K * 2 } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(pState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L = [], D = [], C = [];
        for (let vv = 0.5; vv <= 5.001; vv += 0.1) { L.push(vv.toFixed(1)); D.push(+(K / vv).toFixed(4)); C.push(+K.toFixed(4)); }
        charts.pv.data.labels = L; charts.pv.data.datasets[0].data = D; charts.pv.update();
        charts.pvconst.data.labels = L; charts.pvconst.data.datasets[0].data = C; charts.pvconst.update();
      }

      // ---- standalone diagram: piston at two static volumes ----
      function glassCylinder(THREE, radius) {
        const g = new THREE.Group();
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        g.add(new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, 5, 32, 1, true), glassMat));
        const bottom = new THREE.Mesh(new THREE.CircleGeometry(radius, 32), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
        return g;
      }
      function initDiagPiston() {
        const c = el('diag-piston'); if (!c) throw new Error('no container');
        const s = makeScene(c, 15, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        const pMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
        function pistonAt(x, radius, hGas, nParticles) {
          const grp = new THREE.Group(); grp.position.x = x;
          grp.add(glassCylinder(THREE, radius));
          const pistonMat = new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.4, metalness: 0.3 });
          const head = new THREE.Mesh(new THREE.CylinderGeometry(radius * 0.95, radius * 0.95, 0.3, 32), pistonMat);
          head.position.y = -2.4 + hGas + 0.15; grp.add(head);
          for (let i = 0; i < nParticles; i++) {
            const p = new THREE.Mesh(new THREE.SphereGeometry(0.11, 10, 10), pMat);
            const r = Math.sqrt(Math.random()) * radius * 0.85, a = Math.random() * Math.PI * 2;
            p.position.set(Math.cos(a) * r, -2.4 + Math.random() * hGas, Math.sin(a) * r);
            grp.add(p);
          }
          return grp;
        }
        s.scene.add(pistonAt(-3.2, 1.6, 1.4, 24));  // compressed: small volume, dense particles
        s.scene.add(pistonAt(3.2, 2.1, 4.2, 24));   // expanded: large volume, sparse particles
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }

      // ---- standalone diagram: family of PV = const hyperbola curves ----
      function initDiagPVCurves() {
        const c = el('diag-pv-curves'); if (!c) throw new Error('no container');
        const s = makeScene(c, 15, new THREE.Vector3(5, 3, 0), MOL_OPTS);
        const grid = new THREE.GridHelper(12, 12, 0xe2e8f0, 0xeef2f7); grid.position.set(6, 0, 6); s.scene.add(grid);
        const consts = [3, 6, 10];
        consts.forEach((kk) => {
          const pts = [];
          for (let vv = 0.4; vv <= 10; vv += 0.2) pts.push(new THREE.Vector3(vv, Math.min(10, kk / vv), 0));
          const col = kk === 6 ? 0x6366f1 : 0x94a3b8;
          const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: col, transparent: kk !== 6, opacity: kk === 6 ? 1 : 0.6 }));
          s.scene.add(line);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0035); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }

      let diagPiston = null, diagCurves = null;

      function boot() {
        try { update(); } catch (e) { console.error('[boyles] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[boyles] charts failed', e); }
        if (window.THREE) {
          try { diagPiston = initDiagPiston(); } catch (e) { console.error('[boyles] piston diagram failed', e); }
          try { diagCurves = initDiagPVCurves(); } catch (e) { console.error('[boyles] curves diagram failed', e); }
        }
        mountResize([diagPiston, diagCurves]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
