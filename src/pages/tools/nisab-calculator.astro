---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Nisab Calculator';
const description = 'Calculate the gold and silver nisab thresholds for Zakat from current metal prices, and see the recommended (lower, silver) threshold.';
const intro = 'Enter the current gold and silver price per gram to find both nisab thresholds and the recommended one to use.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'What is the nisab?', a: 'The nisab is the minimum amount of wealth a Muslim must own, above basic needs, before Zakat becomes obligatory. It is fixed in physical terms as 87.48 grams of gold or 612.36 grams of silver, and converted to money using current prices.' },
  { q: 'Which nisab should I use?', a: 'You may use either, but many scholars recommend the silver nisab because it is lower in money terms, so more people pay Zakat and more of the needy benefit. The gold nisab is also valid, especially if you hold mainly gold.' },
  { q: 'Why 87.48 g and 612.36 g?', a: 'These weights come from the classical measures of 20 mithqal of gold and 200 dirhams of silver reported in the Sunnah. Converted to modern units they are approximately 87.48 grams of gold and 612.36 grams of silver.' },
  { q: 'Does the nisab change daily?', a: 'The physical weights never change, but the monetary value does, because gold and silver prices move daily. That is why you enter live prices — your nisab in currency is recalculated each time prices update.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="mb-4 block"><span class="text-sm font-medium text-slate-700">Currency</span>
      <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="USD">USD $ — US Dollar</option><option value="PKR">PKR ₨ — Pakistani Rupee</option><option value="INR">INR ₹ — Indian Rupee</option><option value="BDT">BDT ৳ — Bangladeshi Taka</option><option value="IDR">IDR Rp — Indonesian Rupiah</option><option value="MYR">MYR RM — Malaysian Ringgit</option><option value="SAR">SAR — Saudi Riyal</option><option value="AED">AED — UAE Dirham</option><option value="QAR">QAR — Qatari Riyal</option><option value="KWD">KWD — Kuwaiti Dinar</option><option value="EGP">EGP — Egyptian Pound</option><option value="TRY">TRY ₺ — Turkish Lira</option><option value="NGN">NGN ₦ — Nigerian Naira</option><option value="ZAR">ZAR — South African Rand</option><option value="MAD">MAD — Moroccan Dirham</option><option value="GBP">GBP £ — British Pound</option><option value="EUR">EUR € — Euro</option><option value="CAD">CAD $ — Canadian Dollar</option><option value="AUD">AUD $ — Australian Dollar</option>
      </select></label>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Gold price per gram (24k)</span>
        <input id="gold" type="number" step="any" placeholder="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Silver price per gram</span>
        <input id="silver" type="number" step="any" placeholder="0.85" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl border border-amber-300 bg-amber-50 p-5 text-center"><div class="text-sm text-amber-800">Gold nisab (87.48 g)</div><div id="r-gold" class="mt-1 text-2xl font-bold tabular-nums text-amber-900">—</div></div>
        <div class="rounded-xl border border-slate-300 bg-slate-100 p-5 text-center"><div class="text-sm text-slate-600">Silver nisab (612.36 g)</div><div id="r-silver" class="mt-1 text-2xl font-bold tabular-nums text-slate-800">—</div></div>
      </div>
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Recommended threshold (lower = more cautious)</div>
        <div id="r-rec" class="mt-1 text-2xl font-bold tabular-nums">—</div>
        <div id="r-rec-basis" class="mt-1 text-sm opacity-90"></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="240" viewBox="0 0 800 240" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ns-title ns-desc">
      <title id="ns-title">Gold and silver nisab threshold bars</title>
      <desc id="ns-desc">Two horizontal bars showing the gold nisab and the lower silver nisab; the lower silver threshold is the cautious choice.</desc>
      <text x="60" y="70" font-size="14" fill="#92400e" font-family="system-ui,sans-serif" font-weight="bold">Gold 87.48 g</text>
      <rect x="60" y="80" width="660" height="34" rx="6" fill="#fde68a" stroke="#f59e0b" />
      <rect x="60" y="80" width="660" height="34" rx="6" fill="#fbbf24" opacity="0.4" />
      <text x="60" y="160" font-size="14" fill="#475569" font-family="system-ui,sans-serif" font-weight="bold">Silver 612.36 g</text>
      <rect x="60" y="170" width="240" height="34" rx="6" fill="#e2e8f0" stroke="#94a3b8" />
      <line x1="300" y1="160" x2="300" y2="214" stroke="#e11d48" stroke-width="2" stroke-dasharray="5 3" />
      <text x="312" y="196" font-size="12" fill="#e11d48" font-family="system-ui,sans-serif">Lower = recommended</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">In money terms the silver nisab is usually lower, so it is the more cautious threshold to use.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the nisab calculator works</h2>
    <p class="mt-2 text-slate-600">Before you can know whether Zakat is due, you need the nisab — the wealth threshold that separates those who must pay from those who are exempt. The nisab is defined in fixed weights of precious metal, so its value in money depends on the current price of gold and silver. This calculator converts both standards into your currency the moment you enter today's prices, and highlights the lower one as the cautious choice.</p>
    <p class="mt-3 text-slate-600">The gold nisab is the value of 87.48 grams of pure gold; the silver nisab is the value of 612.36 grams of silver. Because silver is far cheaper per gram, its monetary nisab is normally much lower than gold's. A lower threshold means more people qualify to pay Zakat, which is why many scholars and charities encourage using the silver standard.</p>
    <p class="mt-3 text-slate-600">Once you know your nisab, compare it with your total zakatable wealth — cash, gold, silver, business stock and recoverable debts, minus immediate liabilities. If your wealth reaches the threshold and stays there for a lunar year, Zakat of 2.5% becomes due. Use this figure together with the main Zakat calculator to finish the calculation.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4"><p class="font-semibold text-slate-900">Gold nisab</p><p class="mt-1 text-slate-600"><span class="font-mono">87.48 &times; gold price per gram</span>.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-4"><p class="font-semibold text-slate-900">Silver nisab</p><p class="mt-1 text-slate-600"><span class="font-mono">612.36 &times; silver price per gram</span>.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-4"><p class="font-semibold text-slate-900">Recommended</p><p class="mt-1 text-slate-600">The lower of the two values — usually silver.</p></div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Gold at 60/g, silver at 0.85/g.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Gold nisab:</span> <span class="text-slate-600">87.48 &times; 60 = 5,248.80</span></div>
        <div><span class="font-medium text-slate-700">Silver nisab:</span> <span class="text-slate-600">612.36 &times; 0.85 = 520.51</span></div>
        <div class="sm:col-span-2"><span class="font-medium text-slate-700">Recommended:</span> <span class="text-slate-600"><strong>520.51</strong> (silver — the lower threshold)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why the nisab matters</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">⚖️</span><h3 class="mt-2 font-semibold text-slate-900">It defines who pays</h3><p class="mt-1 text-sm text-slate-600">Zakat is an obligation only on those whose surplus wealth reaches the nisab. Below it, a Muslim may give voluntary charity (sadaqah) but owes no Zakat.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🌙</span><h3 class="mt-2 font-semibold text-slate-900">Paired with the hawl</h3><p class="mt-1 text-sm text-slate-600">Reaching the nisab is only half the test. Your wealth must remain at or above it for a complete lunar year before Zakat is due on the amount you then hold.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🤝</span><h3 class="mt-2 font-semibold text-slate-900">Choosing silver helps more</h3><p class="mt-1 text-sm text-slate-600">Because the silver nisab is lower, using it brings more savers into Zakat and increases what reaches the poor — a cautious and generous choice.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">📊</span><h3 class="mt-2 font-semibold text-slate-900">Re-check each year</h3><p class="mt-1 text-sm text-slate-600">Metal prices move, so the monetary nisab shifts. Recalculate it on your Zakat anniversary using fresh prices before assessing your wealth.</p></div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/zakat-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat Calculator</a>
      <a href="/tools/zakat-on-gold-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat on Gold Calculator</a>
      <a href="/tools/zakat-on-silver-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat on Silver Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const REGION_CUR = { PK: 'PKR', IN: 'INR', BD: 'BDT', ID: 'IDR', MY: 'MYR', SA: 'SAR', AE: 'AED', QA: 'QAR', KW: 'KWD', EG: 'EGP', TR: 'TRY', NG: 'NGN', ZA: 'ZAR', MA: 'MAD', GB: 'GBP', US: 'USD', CA: 'CAD', AU: 'AUD', FR: 'EUR', DE: 'EUR', IT: 'EUR', ES: 'EUR' };
    function defaultCurrency() { try { var s = localStorage.getItem('tn_currency'); if (s) return s; } catch (e) {} try { var p = (navigator.language || '').split('-')[1]; if (p && REGION_CUR[p.toUpperCase()]) return REGION_CUR[p.toUpperCase()]; } catch (e) {} return 'USD'; }
    let CUR = defaultCurrency();
    function fmtMoney(n) { try { return new Intl.NumberFormat(undefined, { style: 'currency', currency: CUR, maximumFractionDigits: 2 }).format(n); } catch (e) { return n.toLocaleString(undefined, { maximumFractionDigits: 2 }); } }
    const num = (id) => { const v = parseFloat(el(id).value); return isFinite(v) ? v : 0; };
    function update() {
      const g = num('gold'), s = num('silver');
      if (g <= 0 && s <= 0) { el('results').classList.add('hidden'); return; }
      const fmt = (n) => n.toLocaleString(undefined, { maximumFractionDigits: 2 });
      const goldN = 87.48 * g, silverN = 612.36 * s;
      el('r-gold').textContent = g > 0 ? fmtMoney(goldN) : '—';
      el('r-silver').textContent = s > 0 ? fmtMoney(silverN) : '—';
      let rec, basis;
      if (g > 0 && s > 0) { rec = Math.min(goldN, silverN); basis = rec === silverN ? 'Based on silver' : 'Based on gold'; }
      else if (s > 0) { rec = silverN; basis = 'Based on silver'; }
      else { rec = goldN; basis = 'Based on gold'; }
      el('r-rec').textContent = fmtMoney(rec);
      el('r-rec-basis').textContent = basis;
      el('results').classList.remove('hidden');
    }
    ['gold', 'silver'].forEach((id) => el(id).addEventListener('input', update));
    (function () { const c = document.getElementById('cur'); if (!c) return; c.value = CUR; c.addEventListener('change', function () { CUR = c.value; try { localStorage.setItem('tn_currency', CUR); } catch (e) {} update(); }); })();
  </script>
</ToolLayout>
