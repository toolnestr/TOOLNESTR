---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'ROI Calculator';
const description =
  'Free ROI calculator. Calculate return on investment as a percentage from your cost and total gain, with annualized ROI for multi-year investments.';
const intro =
  'Enter your initial investment cost and the total gain (or final value) to calculate your ROI percentage. If you provide a time period, you\'ll also get the annualized ROI.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'What is ROI?', a: 'ROI (Return on Investment) measures how much profit or loss an investment generates relative to its cost. It is expressed as a percentage and helps compare the efficiency of different investments.' },
  { q: 'How is ROI calculated?', a: 'ROI = ((Gain - Cost) / Cost) × 100. Gain is the total amount received from the investment. If the result is positive, you made a profit; if negative, you took a loss.' },
  { q: 'What is annualized ROI?', a: 'Annualized ROI adjusts the total ROI to show the average return per year, accounting for compounding. The formula is (1 + ROI)^(1/years) - 1. This allows fair comparison between investments held for different time periods.' },
  { q: 'What is a good ROI?', a: 'A good ROI depends on the asset class and risk. Stock market averages 7-10% annualized (historically). Real estate typically returns 8-12%. High-risk investments should offer higher potential ROI to compensate for increased risk.' },
  { q: 'How is ROI different from profit?', a: 'Profit is the absolute dollar amount earned (Gain - Cost). ROI is the percentage return relative to the cost. Profit tells you how much you made; ROI tells you how efficiently you used your capital.' },
  { q: 'Can ROI be negative?', a: 'Yes. If your total gain is less than your initial cost, ROI will be negative, meaning you lost money. The calculator handles this automatically and shows the negative percentage.' },
  { q: 'Why use annualized ROI instead of total ROI?', a: 'Total ROI can be misleading when comparing investments held for different lengths. A 50% return over 5 years is roughly 8.4% per year (annualized), while 50% over 1 year is actually 50% annualized. Annualized ROI gives you an apples-to-apples comparison.' },
  { q: 'Does ROI account for risk?', a: 'No, ROI is a pure return metric and does not factor in risk, volatility, or opportunity cost. Use ROI alongside other metrics like Sharpe ratio, risk assessment, and qualitative factors when making investment decisions.' },
  { q: 'Should I include taxes and fees in ROI?', a: 'For the most accurate picture, yes. Include brokerage fees, transaction costs, taxes paid on gains, and any maintenance costs in the "cost" field. This gives you the net ROI after all expenses.' },
  { q: 'What is the difference between ROI and ROE?', a: 'ROI measures return on any type of investment, while ROE (Return on Equity) specifically measures return on shareholders\' equity in a company. ROI is broader and applicable to any investment scenario.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial investment ($)</span>
        <input id="cost" type="number" step="any" placeholder="10000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Total gain / final value ($)</span>
        <input id="gain" type="number" step="any" placeholder="15000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time period (years, optional)</span>
        <input id="years" type="number" step="any" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Total ROI</div><div id="r-roi" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Annualized ROI</div><div id="r-annual" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Net Profit</div><div id="r-profit" class="mt-1 text-2xl font-bold text-emerald-600">—</div></div>
    </div>
    <p id="err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How ROI is calculated</h2>
    <p class="mt-2 text-slate-600">
      Return on Investment (ROI) measures the efficiency of an investment by comparing the net profit
      to the initial cost. The basic formula is:
      <span class="font-mono">ROI (%) = ((Gain - Cost) / Cost) × 100</span>.
      For multi-year investments, the annualized ROI adjusts for time using:
      <span class="font-mono">Annualized ROI = (1 + ROI)^(1 / Years) - 1</span>.
    </p>
    <p class="mt-3 text-slate-600">
      ROI is one of the most widely used financial metrics because it is simple to calculate and easy
      to interpret. A positive ROI means the investment generated more value than it cost, while a
      negative ROI indicates a loss. The annualized version is essential when comparing investments
      held for different periods — it normalizes returns to a per-year basis, accounting for the
      compounding effect over time.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">You invest $10,000 in a small business, and after 3 years you sell your stake for $15,000.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Initial investment:</span> <span class="text-slate-600">$10,000</span></div>
        <div><span class="font-medium text-slate-700">Final value:</span> <span class="text-slate-600">$15,000</span></div>
        <div><span class="font-medium text-slate-700">Net profit:</span> <span class="text-slate-600">$5,000</span></div>
        <div><span class="font-medium text-slate-700">Total ROI:</span> <span class="text-slate-600">50%</span></div>
        <div><span class="font-medium text-slate-700">Annualized ROI:</span> <span class="text-slate-600">14.47%</span></div>
      </div>
    </div>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Investment flow arrow diagram showing ROI formula">
      <title>ROI Investment Flow</title>
      <desc>An arrow diagram showing money flowing from initial investment through the investment period to a larger return, with the ROI formula overlaid.</desc>
      <rect x="60" y="60" width="160" height="70" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2"/>
      <text x="140" y="102" text-anchor="middle" fill="#6366f1" font-size="14" font-weight="bold">Investment</text>
      <text x="140" y="120" text-anchor="middle" fill="#6366f1" font-size="12">$10,000</text>
      <path d="M 220 95 L 280 95" stroke="#94a3b8" stroke-width="2" marker-end="url(#arrow)"/>
      <text x="250" y="85" text-anchor="middle" fill="#94a3b8" font-size="11">3 yrs</text>
      <rect x="280" y="60" width="160" height="70" rx="10" fill="#f0fdf4" stroke="#22c55e" stroke-width="2"/>
      <text x="360" y="102" text-anchor="middle" fill="#22c55e" font-size="14" font-weight="bold">Return</text>
      <text x="360" y="120" text-anchor="middle" fill="#22c55e" font-size="12">$15,000</text>
      <rect x="500" y="55" width="200" height="80" rx="10" fill="#fef2f2" stroke="#ef4444" stroke-width="2"/>
      <text x="600" y="88" text-anchor="middle" fill="#ef4444" font-size="14" font-weight="bold">ROI = 50%</text>
      <text x="600" y="108" text-anchor="middle" fill="#ef4444" font-size="12">Annualized = 14.5%</text>
      <path d="M 440 95 L 500 95" stroke="#6366f1" stroke-width="2" marker-end="url(#arrow2)"/>
      <defs><marker id="arrow" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M 0 0 L 10 5 L 0 10 Z" fill="#94a3b8"/></marker><marker id="arrow2" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M 0 0 L 10 5 L 0 10 Z" fill="#6366f1"/></marker></defs>
    </svg>
    <figcaption class="mt-3 text-center text-sm text-slate-500">Investment flow from initial capital through growth period to final return, showing total and annualized ROI</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About return on investment</h2>
    <p class="mt-2 text-slate-600">
      ROI is the cornerstone metric for evaluating any investment decision. Whether you are assessing
      a stock purchase, a real estate deal, a marketing campaign, or a capital equipment purchase,
      ROI tells you how much value you generated for every dollar invested. It enables you to compare
      opportunities across different asset classes and time horizons on a level playing field. Use the
      <a href="/tools/npv-calculator" class="font-medium text-indigo-600 hover:underline">NPV Calculator</a>
      to account for the time value of money, and the
      <a href="/tools/irr-calculator" class="font-medium text-indigo-600 hover:underline">IRR Calculator</a>
      for the discount rate that makes net present value zero.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter the total amount you invested or paid for the asset.</li>
      <li>Enter the total amount you received (or the current value of the investment).</li>
      <li>Optionally enter the number of years held to see annualized ROI.</li>
      <li>Review your total ROI percentage, annualized ROI, and net profit in dollars.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use ROI</h2>
    <p class="mt-2 text-slate-600">
      ROI is useful in virtually any financial decision. Business owners use it to evaluate marketing
      campaigns and capital projects. Individual investors use it to track portfolio performance.
      Real estate investors use it to compare rental properties. The key is to be consistent about
      what you include as "cost" — the more comprehensive your cost figure, the more accurate your ROI.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Include all costs — purchase price, fees, taxes, maintenance, and transaction costs — to get a true net ROI.</li>
      <li>Use annualized ROI when comparing investments held for different lengths of time.</li>
      <li>Remember that past ROI does not guarantee future returns; always consider risk alongside return.</li>
    </ul>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📈</span>
      <h3 class="mt-2 font-semibold text-slate-900">Stock Investor</h3>
      <p class="mt-1 text-sm text-slate-600">Track the return on stock purchases including dividends received. Compare performance across your portfolio to identify your best and worst investments.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏠</span>
      <h3 class="mt-2 font-semibold text-slate-900">Real Estate Investor</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate ROI on rental properties considering purchase price, renovation costs, rental income, and sale proceeds to evaluate property performance.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📢</span>
      <h3 class="mt-2 font-semibold text-slate-900">Marketing Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Measure campaign ROI by comparing total campaign spend against attributed revenue. Justify budgets by showing positive return on marketing investment.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💼</span>
      <h3 class="mt-2 font-semibold text-slate-900">Business Owner</h3>
      <p class="mt-1 text-sm text-slate-600">Evaluate capital expenditures like equipment purchases or renovations. Compare ROI across different projects to prioritize the highest-return opportunities.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the ROI calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your investment cost</h3>
        <p class="mt-1 text-sm text-slate-600">Type the total amount you put into the investment — the purchase price plus any associated fees, commissions, or expenses.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the final value</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the total amount you received from the investment (or its current market value). For ongoing investments, use the most recent valuation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Add time period (optional)</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the number of years you held the investment to see the annualized ROI, which shows your average return per year on a compounded basis.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate ROI calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Count every cost</h3>
        <p class="mt-1 text-sm text-slate-600">The accuracy of your ROI depends entirely on capturing all costs. Include transaction fees, taxes, maintenance, repairs, and any other expenses directly tied to the investment. Missing costs inflates your ROI and leads to overestimating performance.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use annualized for comparisons</h3>
        <p class="mt-1 text-sm text-slate-600">Always use annualized ROI when comparing investments with different holding periods. A 30% total return over 6 months is actually a 69% annualized return, which is dramatically different from a 30% return over 3 years (9.1% annualized).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Consider opportunity cost</h3>
        <p class="mt-1 text-sm text-slate-600">Your ROI should be compared against alternative investments. If you earned a 5% annualized ROI on a bond, but the stock market returned 10% over the same period, you incurred an opportunity cost. Always ask: could this capital have been deployed better elsewhere?</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li><a href="/tools/npv-calculator" class="font-medium text-indigo-600 hover:underline">NPV Calculator</a> — Net Present Value accounts for the time value of money by discounting future cash flows back to today's dollars.</li>
      <li><a href="/tools/irr-calculator" class="font-medium text-indigo-600 hover:underline">IRR Calculator</a> — Internal Rate of Return finds the discount rate that makes NPV zero, useful for comparing project profitability.</li>
      <li><a href="/tools/wacc-calculator" class="font-medium text-indigo-600 hover:underline">WACC Calculator</a> — Weighted Average Cost of Capital helps determine the minimum return required to satisfy all capital providers.</li>
      <li><a href="/tools/investment-calculator" class="font-medium text-indigo-600 hover:underline">Investment Calculator</a> — Project the future value of periodic investments with compound interest over time.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (n) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    function update() {
      const cost = parseFloat(el('cost').value);
      const gain = parseFloat(el('gain').value);
      const years = parseFloat(el('years').value);
      el('err').textContent = '';
      if (isNaN(cost) || isNaN(gain)) { ['r-roi', 'r-annual', 'r-profit'].forEach((id) => (el(id).textContent = '—')); return; }
      if (cost <= 0) { ['r-roi', 'r-annual', 'r-profit'].forEach((id) => (el(id).textContent = '—')); el('err').textContent = 'Initial investment must be greater than zero.'; return; }
      const profit = gain - cost;
      const roi = profit / cost;
      el('r-roi').textContent = (roi * 100).toFixed(2) + '%';
      el('r-profit').textContent = fmt(profit);
      if (!isNaN(years) && years > 0) {
        const annual = Math.pow(1 + roi, 1 / years) - 1;
        el('r-annual').textContent = (annual * 100).toFixed(2) + '%';
      } else {
        el('r-annual').textContent = '—';
      }
    }
    ['cost', 'gain', 'years'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
