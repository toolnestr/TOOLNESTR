---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Psi to Bar"
  emoji="🔧"
  fromUnit="pounds per square inch" toUnit="bar"
  fromTitle="PSI" toTitle="Bar"
  fromSym="psi" toSym="bar"
  quantity="pressure"
  kind="factor" factor={0.0689476}
  reverseSlug="bar-to-psi" reverseLabel="Bar to Psi Converter"
  hasReverse={true}
  related={[{"slug":"pressure-converter","label":"Pressure Converter"}]}
  useCase="Handy for tyre and equipment pressures when a US spec in psi needs to be read in bar."
/>
