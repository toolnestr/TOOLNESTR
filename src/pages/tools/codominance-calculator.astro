---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Codominance Calculator';
const description = "Codominance calculator. Build a Punnett square for codominant alleles (like roan cattle or AB blood type), where both alleles show fully, with worked examples.";
const intro = 'Cross two parents for a codominant gene, where heterozygotes show both alleles fully rather than one masking the other, to see the genotype and phenotype ratios. Two 3D diagrams compare a homozygous roan-cattle-style cross to a heterozygous one, and charts break down the resulting phenotype distribution.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is codominance?', a: 'Codominance is an inheritance pattern where both alleles in a heterozygote are fully and separately expressed, rather than one dominant allele masking the other. A classic example is roan cattle coat color, where a heterozygote shows both red and white hairs distinctly (not blended pink).' },
  { q: 'How is codominance different from incomplete dominance?', a: 'In codominance, both alleles show up fully and separately (like red AND white hairs in a roan). In incomplete dominance, the two alleles blend into an intermediate phenotype (like pink flowers from red and white parents). Codominance keeps both traits distinct; incomplete dominance mixes them.' },
  { q: 'What is the classic human example of codominance?', a: 'ABO blood type is the textbook example — the IA and IB alleles are codominant with each other, so a person with genotype IAIB has type AB blood, showing both A and B antigens on their red blood cells simultaneously.' },
  { q: 'Does codominance change the genotype ratio from a normal cross?', a: 'No — the underlying genotype ratio from a cross (like 1:2:1 for Aa × Aa) is identical to any other inheritance pattern. Only the phenotype interpretation changes, since codominant heterozygotes get their own distinct, unmasked phenotype category instead of matching one of the homozygotes.' },
  { q: 'Why does codominance produce a 1:2:1 phenotype ratio instead of 3:1?', a: 'Because the heterozygote has its own unique, fully visible phenotype (unlike simple dominance, where it\'s hidden behind the dominant trait) — so all three genotypes (homozygous type 1, heterozygous, homozygous type 2) show up as three distinct phenotypes, matching the 1:2:1 genotype ratio exactly.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Codominance Calculator',
  description: 'Build a Punnett square for a codominant gene and see the resulting genotype and phenotype ratios.',
  steps: [
    { name: 'Enter both parent genotypes', text: 'Use two different allele labels for the codominant gene, e.g. R1 and R2.' },
    { name: 'View the grid', text: 'The full cross grid fills in with every possible offspring genotype.' },
    { name: 'Read the phenotype ratio', text: 'Unlike simple dominance, each genotype gets its own distinct phenotype.' },
  ],
};

const formulas = [
  { expr: 'R¹R² × R¹R² → 1 R¹R¹ : 2 R¹R² : 1 R²R²', note: 'genotype ratio — identical math to any monohybrid cross' },
  { expr: '1:2:1 genotype → 1:2:1 phenotype', note: 'for codominance, each genotype is its own distinct, fully visible phenotype' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — roan cattle coat color', tone: 'slate',
    given: 'Cross two roan cattle (R¹R², heterozygous for coat color, where R¹=red hair allele and R²=white hair allele, both codominant).',
    rows: [
      { label: 'Gametes:', value: 'R¹ or R² from each parent' },
      { label: 'Genotype ratio:', value: '1 R¹R¹ : 2 R¹R² : 1 R²R²' },
      { label: 'Phenotype ratio:', value: '1 red : 2 roan : 1 white', full: true },
    ],
    note: 'Unlike simple dominance, the roan phenotype is not "hidden" — it\'s a fully distinct, visibly mixed-hair-color phenotype that only heterozygotes show.',
  },
  {
    title: 'Worked example 2 — human ABO blood type (IA vs IB)', tone: 'amber',
    given: 'A parent with genotype IAIB (blood type AB) crosses with another IAIB parent.',
    rows: [
      { label: 'Gametes:', value: 'IA or IB from each parent' },
      { label: 'Genotype ratio:', value: '1 IAIA : 2 IAIB : 1 IBIB' },
      { label: 'Phenotype ratio:', value: '1 type A : 2 type AB : 1 type B', full: true },
    ],
    note: 'IAIB individuals show type AB blood — both A and B antigens present simultaneously on red blood cells — a textbook demonstration of codominance in humans.',
  },
];

const comparison = {
  heading: 'Codominance vs simple dominance vs incomplete dominance',
  note: 'The same 1:2:1 genotype ratio from Aa × Aa produces very different phenotype outcomes depending on the inheritance pattern.',
  headers: [{ label: 'Pattern' }, { label: 'Heterozygote phenotype' }, { label: 'Phenotype ratio' }],
  rows: [
    ['Simple dominance', 'Same as dominant homozygote', '3 : 1'],
    ['Codominance ★', 'Both traits shown fully, separately', '1 : 2 : 1'],
    ['Incomplete dominance', 'Blended intermediate trait', '1 : 2 : 1'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row. Codominance and incomplete dominance share the same 1:2:1 ratio numerically, but the heterozygote phenotype looks completely different — distinct-and-separate versus blended.',
};

const realWorld = [
  { emoji: '🩸', title: 'Blood typing and transfusion medicine', body: 'Understanding the codominant relationship between IA and IB alleles (producing type AB blood) is essential for blood banks and transfusion compatibility testing.' },
  { emoji: '🐄', title: 'Cattle breeding for coat color', body: 'Cattle breeders use codominance predictions to anticipate roan, red, or white coat outcomes when planning breeding pairs.' },
  { emoji: '🧬', title: 'Immunogenetics research', body: 'Many immune system genes (like HLA genes) show codominant expression, where an individual expresses proteins from both inherited alleles simultaneously — important in organ transplant matching.' },
  { emoji: '🎓', title: 'Teaching non-Mendelian inheritance', body: 'Codominance is one of the clearest ways to teach students that not all inheritance follows simple dominant/recessive rules, broadening their understanding beyond basic Punnett squares.' },
];

const misconceptions = [
  { claim: '"Codominance and incomplete dominance are the same thing."', truth: 'They produce the same 1:2:1 ratio numerically but look completely different — codominant heterozygotes show BOTH traits fully and distinctly (like red and white hairs both visible), while incomplete-dominance heterozygotes show a single BLENDED intermediate trait (like pink).' },
  { claim: '"In codominance, one allele is still slightly stronger than the other."', truth: "By definition, codominant alleles are expressed completely equally — neither one is stronger or weaker; both are fully and independently visible in the heterozygote's phenotype." },
  { claim: '"AB blood type means a mix or dilution of A and B blood types."', truth: 'AB blood type means a person has BOTH the A antigen AND the B antigen fully present on their red blood cells simultaneously — it is not a diluted, weakened, or blended version of either.' },
  { claim: '"Codominance changes how many genotypes are possible from a cross."', truth: 'The genotype possibilities and their ratios are determined purely by Mendelian segregation, exactly the same as any other cross — codominance only changes how those genotypes map onto observable phenotypes.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 12, "Mendel\'s Experiments and Heredity" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/12-3-laws-of-inheritance" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 4, Extensions of Mendelian Genetics.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 14, Mendel and the Gene Idea (Extending Mendelian Genetics).' },
];
const sourcesNote = 'Underlying genotype math is identical to standard Mendelian segregation — only phenotype interpretation differs for codominant alleles. Results are exact probability ratios.';

const howToUse = [
  { title: 'Enter both parent genotypes', body: 'Use two distinct allele labels for the codominant gene (e.g. R1/R2 or A/B).' },
  { title: 'View the cross grid', body: 'The full grid shows every possible offspring genotype combination.' },
  { title: 'Read the phenotype ratio', body: 'Each genotype maps to its own distinct, fully-visible phenotype.' },
];

const related = [
  { href: '/tools/incomplete-dominance-calculator', emoji: '🌸', title: 'Incomplete Dominance Calculator', desc: 'Blended phenotypes — a different inheritance pattern.' },
  { href: '/tools/punnett-square-calculator', emoji: '🧬', title: 'Punnett Square Calculator', desc: 'Monohybrid cross — the classic 3:1 phenotype ratio.' },
  { href: '/tools/dihybrid-cross-calculator', emoji: '🧬', title: 'Dihybrid Cross Calculator', desc: 'Two-gene cross — the classic 9:3:3:1 phenotype ratio.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="codominance means a heterozygote doesn't hide either allele behind the other — both gene products get made and both show up fully and separately in the phenotype, so the underlying 1:2:1 genotype ratio translates directly into a matching 1:2:1 phenotype ratio."
  howIntro="The Punnett square mechanics for a codominant gene are identical to any other monohybrid cross — gametes combine according to the law of segregation, producing the same 1:2:1 genotype ratio as Aa × Aa. The only difference is interpretation: instead of one allele's product masking the other's, both alleles' gene products (like both red and white hair pigments, or both blood-type antigens) are produced and visible simultaneously in the heterozygote, giving it its own unique, fully distinct phenotype rather than resembling either homozygous parent."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where codominance actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Parent 1 genotype (e.g. R1R2)</span>
        <input id="p1" type="text" value="R1R2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Parent 2 genotype (e.g. R1R2)</span>
        <input id="p2" type="text" value="R1R2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 overflow-hidden rounded-xl border border-slate-200">
      <table id="grid" class="w-full table-fixed text-center"></table>
    </div>
    <div class="mt-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Phenotype ratio (all distinct)</div><div id="r-pheno" class="mt-1 text-lg font-bold">—</div></div>
    </div>
    <p id="cod-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Roan cattle coat color example</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-homo" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Homozygous red (R¹R¹)</h3>
          <p class="mt-1 text-sm text-slate-600">All hair-color spheres are red — only one allele type present, only one pigment produced.</p>
        </div>
        <div>
          <div id="diag-het" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Heterozygous roan (R¹R²)</h3>
          <p class="mt-1 text-sm text-slate-600">Red AND white spheres both present and distinct — both alleles' pigments show up fully, side by side, not blended.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Codominance charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Phenotype ratio — 1:2:1, all distinct</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pheno"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Codominance vs simple dominance phenotype outcomes</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-compare"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function parseGenotype(s) {
        s = (s || '').trim();
        const m = s.match(/^([A-Za-z]+\d*)\1?$/);
        // split into 2 alleles: assume equal length halves matching known alleles
        return s.length % 2 === 0 ? [s.slice(0, s.length / 2), s.slice(s.length / 2)] : null;
      }
      function update() {
        el('cod-err').textContent = '';
        el('r-pheno').textContent = '—';
        el('grid').innerHTML = '';
        const g1 = parseGenotype(el('p1').value), g2 = parseGenotype(el('p2').value);
        if (!g1 || !g2) { el('cod-err').textContent = 'Enter genotypes as two equal-length allele codes, e.g. R1R2.'; return; }
        const combos = [];
        for (const a of g1) for (const b of g2) combos.push([a, b].sort().join('+'));
        let html = '<tr><td class="bg-slate-50 p-2"></td>';
        g2.forEach((b) => (html += '<td class="bg-slate-50 p-2 font-mono font-bold text-slate-700">' + b + '</td>'));
        html += '</tr>';
        let idx = 0;
        g1.forEach((a) => {
          html += '<tr><td class="bg-slate-50 p-2 font-mono font-bold text-slate-700">' + a + '</td>';
          g2.forEach(() => { html += '<td class="border border-slate-100 p-3 font-mono font-semibold text-indigo-700">' + combos[idx].replace('+', '') + '</td>'; idx++; });
          html += '</tr>';
        });
        el('grid').innerHTML = html;
        const counts = {};
        combos.forEach((c) => (counts[c] = (counts[c] || 0) + 1));
        el('r-pheno').textContent = Object.entries(counts).map(([k, v]) => v + ' ' + k.replace('+', '/')).join(' : ');
      }
      ['p1', 'p2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.pheno = new Chart(el('chart-pheno'), {
          type: 'pie',
          data: { labels: ['Red (R1R1)', 'Roan (R1R2)', 'White (R2R2)'], datasets: [{ data: [1, 2, 1], backgroundColor: ['#ef4444', '#f59e0b', '#e2e8f0'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.compare = new Chart(el('chart-compare'), {
          type: 'bar',
          data: { labels: ['Simple dominance', 'Codominance'], datasets: [
            { label: 'Dominant phenotype', data: [3, 1], backgroundColor: '#6366f1' },
            { label: 'Heterozygote-distinct phenotype', data: [0, 2], backgroundColor: '#f59e0b' },
            { label: 'Recessive phenotype', data: [1, 1], backgroundColor: '#94a3b8' },
          ] },
          options: Object.assign({}, base, { scales: { x: { stacked: true }, y: { stacked: true, title: { display: true, text: 'Count (out of 4)' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function coatScene(container, redCount, whiteCount) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const total = redCount + whiteCount;
        for (let i = 0; i < total; i++) {
          const phi = Math.acos(1 - (2 * (i + 0.5)) / total);
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const r = 2;
          const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
          const color = i < redCount ? 0xef4444 : 0xe2e8f0;
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.24, 12, 10), new THREE.MeshStandardMaterial({ color, roughness: 0.5 }));
          sph.position.set(x, y, z);
          s.scene.add(sph);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagHomo = null, diagHet = null;
      function initDiagHomo() { const c = el('diag-homo'); if (!c) throw new Error('no container'); diagHomo = coatScene(c, 30, 0); }
      function initDiagHet() { const c = el('diag-het'); if (!c) throw new Error('no container'); diagHet = coatScene(c, 15, 15); }

      function boot() {
        try { update(); } catch (e) { console.error('[codominance] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[codominance] charts failed', e); }
        if (window.THREE) {
          try { initDiagHomo(); } catch (e) { console.error('[codominance] homo diagram failed', e); }
          try { initDiagHet(); } catch (e) { console.error('[codominance] het diagram failed', e); }
        }
        mountResize([diagHomo, diagHet]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
