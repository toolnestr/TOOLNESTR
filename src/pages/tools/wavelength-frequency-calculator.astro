---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Wavelength Calculator';
const description = 'Free online wavelength calculator. Solve for wavelength, frequency, or wave velocity using v = fλ. Works for sound, light, and radio waves.';
const intro = 'Enter any two values — wave velocity, frequency, or wavelength — to solve for the third.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is the wave equation?', a: 'The wave equation is v = fλ, where v is wave velocity (m/s), f is frequency (Hz), and λ is wavelength (m). It relates all three properties of any wave.' },
  { q: 'What is the speed of light?', a: 'The speed of light in a vacuum is exactly 299,792,458 m/s (≈ 3.0 × 10⁸ m/s). In air, it is slightly slower, and in glass or water, significantly slower.' },
  { q: 'What is the speed of sound?', a: 'The speed of sound in air at 20°C is about 343 m/s. It varies with temperature, humidity, and the medium. In water, sound travels at about 1480 m/s.' },
  { q: 'How is frequency related to wavelength?', a: 'Frequency and wavelength are inversely proportional at a constant wave speed. Higher frequency means shorter wavelength, and vice versa. This is why blue light has a shorter wavelength than red light.' },
  { q: 'What are common wave types?', a: 'Mechanical waves (sound, seismic) need a medium. Electromagnetic waves (light, radio, X-rays) can travel through a vacuum. All obey the same wave equation.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values, leave the third blank</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Wave velocity (v)</span>
        <input id="vel" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Frequency (f)</span>
        <input id="freq" type="number" step="any" placeholder="Hz" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Wavelength (λ)</span>
        <input id="wl" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mb-4 mt-4 flex gap-2">
      <button id="preset-light" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Speed of light (3×10⁸ m/s)</button>
      <button id="preset-sound" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Speed of sound (343 m/s)</button>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Wave velocity</div><div id="r-vel" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Frequency</div><div id="r-freq" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Wavelength</div><div id="r-wl" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="wl-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="wl-title wl-desc">
      <title id="wl-title">Sine wave diagram with wavelength labelled</title>
      <desc id="wl-desc">A sinusoidal wave showing wavelength λ as the distance between two consecutive peaks, with velocity and frequency annotations</desc>
      <g transform="translate(20,30)">
        <path d="M 40 120 Q 80 20 120 120 Q 160 220 200 120 Q 240 20 280 120 Q 320 220 360 120 Q 400 20 440 120 Q 480 220 520 120 Q 560 20 600 120 Q 640 220 680 120 Q 720 20 740 120" stroke="#6366f1" stroke-width="3" fill="none" stroke-linecap="round"/>
        <line x1="120" y1="120" x2="280" y2="120" stroke="#ef4444" stroke-width="2.5" stroke-dasharray="6 3"/>
        <polygon points="120,120 130,115 130,125" fill="#ef4444" transform="rotate(180 120 120)"/>
        <polygon points="280,120 270,115 270,125" fill="#ef4444"/>
        <text x="200" y="143" text-anchor="middle" fill="#ef4444" font-size="20" font-weight="bold">λ</text>
        <text x="200" y="162" text-anchor="middle" fill="#64748b" font-size="12">Wavelength</text>
        <line x1="40" y1="120" x2="40" y2="40" stroke="#10b981" stroke-width="2"/>
        <polygon points="40,40 35,50 45,50" fill="#10b981"/>
        <text x="55" y="48" fill="#10b981" font-size="13" font-weight="bold">A</text>
        <text x="70" y="48" fill="#64748b" font-size="12">Amplitude</text>
        <text x="200" y="230" text-anchor="middle" fill="#4338ca" font-size="20" font-weight="bold">v = f × λ</text>
        <text x="200" y="255" text-anchor="middle" fill="#64748b" font-size="13">Wave velocity = Frequency × Wavelength</text>
        <text x="530" y="60" fill="#f59e0b" font-size="14">Crest</text>
        <text x="530" y="185" fill="#a855f7" font-size="14">Trough</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">A sine wave showing wavelength λ, amplitude A, crests, and troughs. The wave equation v = fλ connects all wave properties.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the wave equation works</h2>
    <p class="mt-2 text-slate-600">The wave equation <span class="font-mono">v = f × λ</span> is one of the most fundamental relationships in physics. The velocity of a wave equals its frequency multiplied by its wavelength. Frequency (measured in hertz) tells you how many wave cycles pass a point per second. Wavelength (in metres) is the distance between two consecutive identical points on the wave, such as crest-to-crest. The product always equals the wave speed, which depends on the medium.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A radio station broadcasts at 98.5 MHz (98.5 × 10⁶ Hz). What is the wavelength of its signal?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Wave speed:</span> <span class="text-slate-600">3.0 × 10⁸ m/s (speed of light)</span></div>
        <div><span class="font-medium text-slate-700">Frequency:</span> <span class="text-slate-600">98.5 × 10⁶ Hz</span></div>
        <div><span class="font-medium text-slate-700">Wavelength:</span> <span class="text-slate-600">λ = 3.0×10⁸ / 98.5×10⁶ = 3.05 m</span></div>
        <div><span class="font-medium text-slate-700">Band:</span> <span class="text-slate-600">FM radio (about 3 m wavelength)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4E1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">RF Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate antenna lengths, which are typically λ/2 or λ/4. Determine the correct frequency bands for communication systems and analyse signal propagation characteristics.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4F7;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Optical Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Design optical systems using the wavelengths of different colours of light. Determine which wavelengths pass through filters and how diffraction gratings separate colours.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3A4;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Audio Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the wavelengths of sound at different frequencies for speaker placement, room acoustics, and noise cancellation system design. Low bass notes have wavelengths of several metres.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F52D;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Physics Student</h3>
      <p class="mt-1 text-sm text-slate-600">Solve wave problems from introductory physics. Understand the inverse relationship between frequency and wavelength and how wave speed depends on the medium.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the wavelength calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose a preset or enter value</h3>
        <p class="mt-1 text-sm text-slate-600">Click "Speed of light" for electromagnetic waves or "Speed of sound" for acoustic waves. Alternatively, type any wave velocity manually.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter frequency or wavelength</h3>
        <p class="mt-1 text-sm text-slate-600">Type either the frequency in hertz or the wavelength in metres. The third value is calculated and displayed automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Real-time update</h3>
        <p class="mt-1 text-sm text-slate-600">All three boxes update instantly as you type. Try different frequencies to see how wavelength changes — higher frequency means shorter wavelength.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for wave calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use correct units</h3>
        <p class="mt-1 text-sm text-slate-600">Wave velocity in m/s, frequency in Hz (cycles per second), and wavelength in metres give consistent results. For radio frequencies in MHz, convert to Hz (1 MHz = 10⁶ Hz) before using the formula.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Wave speed depends on the medium</h3>
        <p class="mt-1 text-sm text-slate-600">Light travels slower in glass, water, and other materials. Sound speed varies with temperature and air pressure. Always use the correct speed for your specific medium.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">The electromagnetic spectrum</h3>
        <p class="mt-1 text-sm text-slate-600">From radio waves (km wavelengths) to gamma rays (pm wavelengths), the electromagnetic spectrum spans an enormous range. The wave equation applies identically across all of it.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/frequency-converter" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x3030;&#xFE0F;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Frequency Converter</h3>
        <p class="mt-0.5 text-xs text-slate-500">Convert between frequency and period.</p>
      </a>
      <a href="/tools/lc-resonant-frequency-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4E1;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">LC Resonant Frequency</h3>
        <p class="mt-0.5 text-xs text-slate-500">Resonant frequency of LC tank circuits.</p>
      </a>
      <a href="/tools/ideal-gas-law-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1FAEB;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Ideal Gas Law Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">PV=nRT — solve for any variable.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });
    function update() {
      const v = parseFloat(el('vel').value);
      const f = parseFloat(el('freq').value);
      const w = parseFloat(el('wl').value);
      const filled = [!isNaN(v), !isNaN(f), !isNaN(w)];
      const count = filled.filter(Boolean).length;
      el('wl-err').textContent = '';
      ['r-vel', 'r-freq', 'r-wl'].forEach(id => el(id).textContent = '—');
      if (count < 2) return;
      let rv = NaN, rf = NaN, rw = NaN;
      if (filled[0] && filled[1]) { rw = v / f; rv = v; rf = f; }
      else if (filled[0] && filled[2]) { if (w === 0) { el('wl-err').textContent = 'Wavelength cannot be zero.'; return; } rf = v / w; rv = v; rw = w; }
      else if (filled[1] && filled[2]) { rv = f * w; rf = f; rw = w; }
      if (!isNaN(rv)) el('r-vel').textContent = fmt(rv);
      if (!isNaN(rf)) el('r-freq').textContent = fmt(rf);
      if (!isNaN(rw)) el('r-wl').textContent = fmt(rw);
    }
    el('preset-light').addEventListener('click', () => { el('vel').value = '299792458'; update(); });
    el('preset-sound').addEventListener('click', () => { el('vel').value = '343'; update(); });
    ['vel', 'freq', 'wl'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
