---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Wavelength Calculator';
const description = 'Wavelength calculator with a live 3D diagram and charts. Solve v = fλ for wave velocity, frequency, or wavelength — works for sound, light, and radio waves — with worked examples.';
const intro = 'Solve v = fλ for any wave — enter two of wave velocity, frequency, or wavelength to find the third. Two 3D diagrams compare a long-wavelength wave to a short-wavelength wave, and charts show how wavelength scales with frequency for light and for sound.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the wave equation?', a: 'The wave equation is v = fλ, where v is wave velocity (m/s), f is frequency (Hz), and λ is wavelength (m). It relates all three properties of any wave, mechanical or electromagnetic.' },
  { q: 'What is the speed of light?', a: 'The speed of light in a vacuum is exactly 299,792,458 m/s (≈3.0×10⁸ m/s). It is slightly slower in air and significantly slower in glass or water.' },
  { q: 'What is the speed of sound?', a: 'The speed of sound in air at 20°C is about 343 m/s. It varies with temperature, humidity, and the medium — in water it travels at about 1480 m/s.' },
  { q: 'How is frequency related to wavelength?', a: 'At a fixed wave speed, frequency and wavelength are inversely proportional — higher frequency means shorter wavelength. This is why blue light (higher frequency) has a shorter wavelength than red light.' },
  { q: 'Do all waves obey the same wave equation?', a: 'Yes. Mechanical waves (sound, water, seismic) and electromagnetic waves (light, radio, X-rays) all obey v = fλ — only the wave speed itself differs depending on the medium and wave type.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Wavelength Calculator',
  description: 'Solve v = fλ for wave velocity, frequency, or wavelength from any two known values.',
  steps: [
    { name: 'Choose a preset or enter velocity', text: 'Use the speed-of-light or speed-of-sound preset, or type any custom wave velocity.' },
    { name: 'Enter frequency or wavelength', text: 'Type either the frequency in hertz or the wavelength in metres — the third value solves automatically.' },
  ],
};

const formulas = [
  { expr: 'v = f × λ', note: 'wave velocity = frequency × wavelength' },
  { expr: 'f = v / λ', note: 'solve for frequency' },
  { expr: 'λ = v / f', note: 'solve for wavelength' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — an FM radio signal', tone: 'slate',
    given: 'A radio station broadcasts at f = 98.5 MHz (98.5×10⁶ Hz). Radio waves travel at the speed of light, v = 3.0×10⁸ m/s.',
    rows: [
      { label: 'Formula:', value: 'λ = v / f' },
      { label: 'Substitute:', value: 'λ = 3.0×10⁸ / 98.5×10⁶' },
      { label: 'Result:', value: 'λ ≈ 3.05 m — a typical FM broadcast wavelength', full: true },
    ],
    note: 'FM antennas are commonly built at λ/4 (≈0.76 m) for efficient reception at this wavelength.',
  },
  {
    title: 'Worked example 2 — a sound wave', tone: 'amber',
    given: 'A tuba plays a low note at f = 65.4 Hz (note C2). Sound travels at v = 343 m/s in air at 20°C.',
    rows: [
      { label: 'Formula:', value: 'λ = v / f' },
      { label: 'Substitute:', value: 'λ = 343 / 65.4' },
      { label: 'Result:', value: 'λ ≈ 5.24 m — over 5 metres long', full: true },
    ],
    note: 'Low-pitched sounds have surprisingly long wavelengths, which is why bass frequencies bend around obstacles and corners far more easily than higher-pitched sounds.',
  },
];

const comparison = {
  heading: 'Wavelength across the electromagnetic and acoustic spectrum',
  note: 'Same wave equation, wildly different scales depending on frequency and medium.',
  headers: [{ label: 'Wave' }, { label: 'Frequency' }, { label: 'Wavelength' }],
  rows: [
    ['AM radio', '~1 MHz', '~300 m'],
    ['FM radio ★', '98.5 MHz', '3.05 m'],
    ['Wi-Fi (2.4 GHz)', '2.4 GHz', '12.5 cm'],
    ['Visible red light', '~4.3×10¹⁴ Hz', '~700 nm'],
    ['Visible violet light', '~7.5×10¹⁴ Hz', '~400 nm'],
    ['Human speech (sound)', '~300 Hz', '~1.14 m'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Electromagnetic waves all travel at c, so their wavelength is set entirely by frequency; sound wavelength instead depends on the (much slower) speed of sound in the medium.',
};

const realWorld = [
  { emoji: '📡', title: 'Antenna design', body: 'Antenna length is chosen relative to the wavelength being transmitted — commonly λ/2 or λ/4 — so calculating wavelength from a broadcast frequency is a routine first step for RF engineers.' },
  { emoji: '🎨', title: 'Optics and color', body: 'Every visible color corresponds to a specific wavelength range, from about 400 nm (violet) to 700 nm (red). Filters, coatings, and diffraction gratings are all designed around specific wavelengths of light.' },
  { emoji: '🔊', title: 'Acoustics and speaker design', body: 'Speaker and room dimensions interact with sound wavelengths to create standing waves and resonances. Bass wavelengths of several metres explain why low frequencies are much harder to absorb or direct than treble.' },
  { emoji: '🩻', title: 'Medical and industrial imaging', body: 'X-rays, ultrasound, and MRI all rely on wave properties tied to specific frequency/wavelength combinations, chosen for how they interact with (or pass through) different types of tissue or material.' },
];

const misconceptions = [
  { claim: '"Wavelength depends only on frequency, no matter what kind of wave it is."', truth: 'Wavelength depends on both frequency and the wave\'s speed in that medium: λ = v/f. Two waves at the identical frequency can have very different wavelengths if their propagation speeds differ — light and sound at the same frequency have vastly different wavelengths.' },
  { claim: '"Higher frequency waves always travel faster."', truth: "In a given medium, all electromagnetic waves travel at the same speed (c) regardless of frequency — only the wavelength changes. Frequency and wave speed are independent quantities; only frequency and wavelength trade off against each other at fixed speed." },
  { claim: '"The speed of sound is a universal constant like the speed of light."', truth: 'The speed of sound depends heavily on the medium and its temperature — about 343 m/s in air at 20°C, but roughly 1480 m/s in water and even faster in solids. It is not a fixed constant of nature.' },
  { claim: '"You need calculus to work with wave equations."', truth: 'The basic relationship v = fλ is simple algebra — multiply frequency by wavelength to get speed, or divide to solve for either one. Calculus becomes relevant only for more advanced topics like wave interference patterns over time.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 16, "Waves" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/16-2-mathematics-of-waves" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 16, Waves I.' },
  { html: '<strong>Hecht, <em>Optics</em></strong> — Electromagnetic wave fundamentals.' },
];
const sourcesNote = 'v = fλ. Speed of light = 299,792,458 m/s exactly; speed of sound in air at 20°C ≈ 343 m/s. Results are rounded for display.';

const howToUse = [
  { title: 'Pick a preset or type a speed', body: 'Use the speed-of-light or speed-of-sound buttons, or enter any custom wave velocity.' },
  { title: 'Enter frequency or wavelength', body: 'Fill in one of the two remaining fields — the third solves instantly as you type.' },
  { title: 'Compare to real waves', body: 'Check the comparison table to see how your result stacks up against radio, light, and sound examples.' },
];

const related = [
  { href: '/tools/frequency-calculator', emoji: '📻', title: 'Frequency Calculator', desc: 'f = 1/T — period, frequency, and angular frequency.' },
  { href: '/tools/sound-intensity-calculator', emoji: '🔊', title: 'Sound Intensity Calculator', desc: 'β = 10log₁₀(I/I₀) — intensity and decibels.' },
  { href: '/tools/simple-harmonic-motion-calculator', emoji: '🎻', title: 'Simple Harmonic Motion Calculator', desc: 'x(t), v(t), a(t) for a mass-spring oscillator.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a wave's speed is fixed by its medium, so frequency and wavelength must always trade off against each other to keep that product constant — pack more cycles into each second (higher f) and each cycle necessarily takes up less space (shorter λ)."
  howIntro="Every travelling wave repeats itself in both time and space: frequency counts how many cycles pass a fixed point per second, and wavelength measures the physical distance between two identical points on the wave (crest to crest, for example). Multiplying frequency by wavelength always returns the wave's propagation speed, because that speed is simply how fast one wavelength's worth of distance is covered per cycle. Electromagnetic waves (light, radio) all move at the same speed in a vacuum, so their wavelength is set entirely by frequency; sound waves instead depend on the much slower and more variable speed of sound in whatever medium they're travelling through."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where wavelength actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values, leave the third blank</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Wave velocity (v)</span>
        <input id="vel" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Frequency (f)</span>
        <input id="freq" type="number" step="any" placeholder="Hz" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Wavelength (λ)</span>
        <input id="wl" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mb-2 mt-4 flex flex-wrap gap-2">
      <button id="preset-light" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Speed of light (3×10⁸ m/s)</button>
      <button id="preset-sound" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Speed of sound (343 m/s)</button>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Wave velocity</div><div id="r-vel" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Frequency</div><div id="r-freq" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Wavelength</div><div id="r-wl" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="wl-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Long vs. short wavelength</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-long" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Long wavelength (low frequency)</h3>
          <p class="mt-1 text-sm text-slate-600">Fewer, wider crests — like a bass note or an AM radio wave.</p>
        </div>
        <div>
          <div id="diag-short" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Short wavelength (high frequency)</h3>
          <p class="mt-1 text-sm text-slate-600">Many tightly-packed crests — like a treble note or visible light.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Wavelength graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">λ vs. frequency (light, v=3×10⁸ m/s)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-light"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">λ vs. frequency (sound, v=343 m/s)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-sound"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        const v = parseFloat(el('vel').value);
        const f = parseFloat(el('freq').value);
        const w = parseFloat(el('wl').value);
        const filled = [!isNaN(v), !isNaN(f), !isNaN(w)];
        const count = filled.filter(Boolean).length;
        el('wl-err').textContent = '';
        ['r-vel', 'r-freq', 'r-wl'].forEach((id) => el(id).textContent = '—');
        if (count < 2) return;
        let rv = NaN, rf = NaN, rw = NaN;
        if (filled[0] && filled[1]) { rw = v / f; rv = v; rf = f; }
        else if (filled[0] && filled[2]) { if (w === 0) { el('wl-err').textContent = 'Wavelength cannot be zero.'; return; } rf = v / w; rv = v; rw = w; }
        else if (filled[1] && filled[2]) { rv = f * w; rf = f; rw = w; }
        if (!isNaN(rv)) el('r-vel').textContent = fmt(rv) + ' m/s';
        if (!isNaN(rf)) el('r-freq').textContent = fmt(rf) + ' Hz';
        if (!isNaN(rw)) el('r-wl').textContent = fmt(rw) + ' m';
      }
      el('preset-light').addEventListener('click', () => { el('vel').value = '299792458'; update(); });
      el('preset-sound').addEventListener('click', () => { el('vel').value = '343'; update(); });
      ['vel', 'freq', 'wl'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        function buildDataset(v, fMin, fMax, steps) {
          const labels = [], data = [];
          for (let i = 0; i <= steps; i++) {
            const f = fMin + (fMax - fMin) * (i / steps);
            labels.push(f >= 1e6 ? (f / 1e6).toFixed(0) + 'M' : f.toFixed(0));
            data.push(+(v / f).toPrecision(4));
          }
          return { labels, data };
        }
        const light = buildDataset(3e8, 5e13, 5e14, 12);
        new Chart(el('chart-light'), {
          type: 'line',
          data: { labels: light.labels, datasets: [{ label: 'λ (m)', data: light.data, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Frequency (Hz)' } }, y: { type: 'logarithmic', title: { display: true, text: 'Wavelength (m)' } } }, plugins: { legend: { display: false } } }),
        });
        const sound = buildDataset(343, 50, 5000, 12);
        new Chart(el('chart-sound'), {
          type: 'line',
          data: { labels: sound.labels, datasets: [{ label: 'λ (m)', data: sound.data, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Frequency (Hz)' } }, y: { title: { display: true, text: 'Wavelength (m)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function waveScene(container, cycles) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const points = [];
        const width = 6, amp = 1;
        for (let i = 0; i <= 100; i++) {
          const x = -width / 2 + (width * i) / 100;
          const y = amp * Math.sin((i / 100) * cycles * Math.PI * 2);
          points.push(new THREE.Vector3(x, y, 0));
        }
        const geo = new THREE.BufferGeometry().setFromPoints(points);
        const line = new THREE.Line(geo, new THREE.LineBasicMaterial({ color: 0x6366f1, linewidth: 2 }));
        s.scene.add(line);
        const axis = new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-width / 2, 0, 0), new THREE.Vector3(width / 2, 0, 0)]),
          new THREE.LineBasicMaterial({ color: 0x94a3b8 })
        );
        s.scene.add(axis);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.002); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLong = null, diagShort = null;
      function initDiagLong() { const c = el('diag-long'); if (!c) throw new Error('no container'); diagLong = waveScene(c, 2); }
      function initDiagShort() { const c = el('diag-short'); if (!c) throw new Error('no container'); diagShort = waveScene(c, 8); }

      function boot() {
        try { update(); } catch (e) { console.error('[wavelength] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[wavelength] charts failed', e); }
        if (window.THREE) {
          try { initDiagLong(); } catch (e) { console.error('[wavelength] long diagram failed', e); }
          try { initDiagShort(); } catch (e) { console.error('[wavelength] short diagram failed', e); }
        }
        mountResize([diagLong, diagShort]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
