---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Liters Per Minute Calculator';
const description = 'Convert water flow rate between liters per minute, gallons per minute, and liters per hour, or measure LPM directly from a timed container fill.';
const intro = 'Convert flow rate to liters per minute, or measure it directly from a timed fill.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I convert GPM to liters per minute?', a: 'Multiply gallons per minute by 3.78541 to get liters per minute, since one US gallon equals 3.78541 liters. A flow of 10 GPM equals 10 × 3.78541 = 37.85 liters per minute.' },
  { q: 'How do I measure liters per minute directly?', a: 'Time how long it takes to fill a container of known volume (in liters), then divide the volume by the time in seconds and multiply by 60. A 10-liter container filling in 25 seconds: (10 ÷ 25) × 60 = 24 liters per minute.' },
  { q: 'What is a typical LPM for a shower head?', a: 'Modern water-efficient shower heads are often rated around 6 to 9.5 liters per minute (about 1.6 to 2.5 GPM), while older or unrestricted shower heads can flow considerably more, sometimes over 15 liters per minute.' },
  { q: 'Why convert between GPM and LPM?', a: 'Plumbing fixtures, pumps, and irrigation equipment are rated in GPM in the US and LPM in most other countries, so converting lets you compare a product spec sheet in one unit against a requirement given in the other.' },
];
const howTo = {
  name: 'How to calculate liters per minute',
  steps: [
    { name: 'Choose a method', text: 'Convert a known GPM figure, or time a real container fill to measure flow directly.' },
    { name: 'Enter the numbers', text: 'Enter the GPM value, or the container size in liters and the fill time in seconds.' },
    { name: 'Read the results', text: 'Check liters per minute, plus GPM and liters per hour for reference.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Method</span>
      <select id="mode" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="convert" selected>Convert from GPM</option>
        <option value="measure">Measure (timed fill)</option>
      </select></label>
    <div id="g-convert" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Flow rate (GPM)</span>
        <input id="gpm" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="g-measure" class="mt-4 hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Container size (liters)</span>
        <input id="liters" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fill time (seconds)</span>
        <input id="secs" type="number" step="any" placeholder="25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Flow rate</div>
        <div id="r-lpm" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Gallons per minute</div><div id="r-gpm-out" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Liters per hour</div><div id="r-lph" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="lpm-title lpm-desc">
      <title id="lpm-title">GPM to LPM flow rate conversion</title>
      <desc id="lpm-desc">Two containers, US gallons and liters, with the conversion formula</desc>
      <path d="M100 70 L150 70 L145 160 L105 160 Z" fill="#93c5fd" stroke="#2563eb" stroke-width="1.5" />
      <text x="125" y="180" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">gallon</text>
      <path d="M240 90 L280 90 L276 160 L244 160 Z" fill="#86efac" stroke="#16a34a" stroke-width="1.5" />
      <text x="260" y="180" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">liter</text>
      <rect x="420" y="55" width="330" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Flow conversion</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">LPM = GPM &times; 3.78541</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">or LPM = (liters &divide; seconds) &times; 60</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">One US gallon equals 3.78541 liters — the fixed constant behind the conversion.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the liters per minute calculator works</h2>
    <p class="mt-2 text-slate-600">
      Flow rate is stated in gallons per minute in the US and liters per minute in most other countries, so converting between them comes down to one fixed constant: one US gallon equals 3.78541 liters. Multiplying a GPM figure by that constant gives liters per minute directly, letting you compare a fixture, pump, or irrigation emitter rated in one unit against a spec or requirement given in the other.
    </p>
    <p class="mt-3 text-slate-600">
      When you don't have a GPM number to convert — say, checking an actual tap or shower's real-world flow — you can measure liters per minute directly the same way as the bucket method for GPM: time how long a container of known volume takes to fill, then divide the volume in liters by the fill time in seconds and multiply by 60 to scale up to a full minute.
    </p>
    <p class="mt-3 text-slate-600">
      This conversion is useful for comparing fixture efficiency across regions and standards. Modern water-efficient shower heads are commonly rated around 6 to 9.5 liters per minute, equivalent to about 1.6 to 2.5 GPM, while older, unrestricted fixtures can flow considerably more in either unit system.
    </p>
    <p class="mt-3 text-xs text-slate-400">The US gallon-to-liter conversion factor (3.78541) is the NIST-defined exact value; fixture flow-rate ranges reference EPA WaterSense specifications for water-efficient plumbing fixtures.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose a method</h3>
        <p class="mt-1 text-sm text-slate-600">Convert a known GPM, or time a real fill.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the numbers</h3>
        <p class="mt-1 text-sm text-slate-600">GPM, or container size and seconds.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read LPM</h3>
        <p class="mt-1 text-sm text-slate-600">Plus GPM and liters per hour for reference.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">GPM to LPM</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">LPM = GPM &times; 3.78541</span>. 10 GPM: 10 × 3.78541 = <strong>37.85 LPM</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Measured method</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">LPM = (liters &divide; seconds) &times; 60</span>. A 10 L container in 25 s: (10÷25)×60 = <strong>24 LPM</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Liters per hour</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= LPM &times; 60</span>. At 24 LPM: 24 × 60 = <strong>1,440 L/hr</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A pump rated at 25 GPM, converted to metric.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">GPM:</span> <span class="text-slate-600">25</span></div>
        <div><span class="font-medium text-slate-700">LPM:</span> <span class="text-slate-600">25 × 3.78541 = <strong>94.6 LPM</strong></span></div>
        <div><span class="font-medium text-slate-700">Liters/hour:</span> <span class="text-slate-600">94.64 × 60 = 5,678 L/hr</span></div>
        <div><span class="font-medium text-slate-700">Use:</span> <span class="text-slate-600">comparing to a metric-rated pump spec</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the LPM calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚿</span>
        <h3 class="mt-2 font-semibold text-slate-900">Checking shower and faucet efficiency</h3>
        <p class="mt-1 text-sm text-slate-600">Time a bucket fill from your shower head and compare the result to water-efficient benchmarks to see whether an aerator or low-flow fixture would meaningfully cut water use.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌱</span>
        <h3 class="mt-2 font-semibold text-slate-900">Sizing irrigation and drip systems</h3>
        <p class="mt-1 text-sm text-slate-600">Drip emitters and sprinkler heads are frequently rated in liters per hour or LPM outside the US, so converting a GPM pump spec to metric helps you match components correctly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🔧</span>
        <h3 class="mt-2 font-semibold text-slate-900">Comparing pump and pool equipment specs</h3>
        <p class="mt-1 text-sm text-slate-600">Pool pumps, sump pumps, and well pumps are often rated in GPM in the US but LPM elsewhere, so converting lets you compare products from different markets on equal footing.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧪</span>
        <h3 class="mt-2 font-semibold text-slate-900">Lab and process flow verification</h3>
        <p class="mt-1 text-sm text-slate-600">The timed-fill method gives a quick, low-tech way to verify an actual measured flow rate against a rated or expected specification without needing a flow meter.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A water-efficient shower head rated at 1.6 GPM is a common EPA WaterSense benchmark. Converting to metric: 1.6 × 3.78541 = 6.06 liters per minute, or 363.4 liters per hour if run continuously. This is the kind of number a homeowner comparing a US-rated fixture against a European or Australian metric flow-rate requirement would need, since plumbing codes and fixture ratings outside the US are almost always expressed in LPM rather than GPM.
    </p>
    <p class="mt-3 text-slate-600">
      A standard kitchen faucet rated at 5 GPM converts to 5 × 3.78541 = 18.93 liters per minute, or about 1,136 liters per hour. That is roughly three times the flow of the water-efficient shower head above, which illustrates why kitchen faucets are a bigger target for flow restrictors than shower heads when a household is trying to cut water use — the baseline flow rate is already several times higher.
    </p>
    <p class="mt-3 text-slate-600">
      The timed-fill method is useful when you don't trust a fixture's printed rating. Filling a 4-liter container from a hose bib in 20 seconds gives (4 ÷ 20) × 60 = 12 liters per minute, equivalent to about 3.17 GPM. Measuring directly like this is especially useful for older fixtures with no visible rating, or for verifying that a newly installed low-flow fixture is actually performing at its rated spec rather than running higher due to water pressure.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A gallon is a gallon everywhere, so the conversion factor never changes." <strong class="text-slate-900">Not quite — there are different gallons.</strong> This calculator uses the US liquid gallon (3.78541 liters). The UK imperial gallon is larger, at about 4.54609 liters, so using the wrong gallon definition when converting a spec sheet from a British or Commonwealth source will introduce a meaningful error.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Flow rate and water pressure are basically the same thing." <strong class="text-slate-900">They measure different quantities.</strong> Flow rate (LPM or GPM) is the volume moving past a point per unit time, while pressure (measured in PSI or bar) is the force pushing the water. A fixture can have high pressure but low flow if it's restricted, or high flow at relatively low pressure through a wide-open pipe.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/gpm-flow-rate-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">GPM Flow Rate Calculator</a>
      <a href="/tools/pipe-volume-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Pipe Volume Calculator</a>
      <a href="/tools/fire-flow-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fire Flow Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function sync() {
      const measure = el('mode').value === 'measure';
      el('g-convert').classList.toggle('hidden', measure);
      el('g-measure').classList.toggle('hidden', !measure);
      update();
    }

    function update() {
      let lpm;
      if (el('mode').value === 'measure') {
        const liters = parseFloat(el('liters').value);
        const secs = parseFloat(el('secs').value);
        if (!(liters > 0 && secs > 0)) return hide();
        lpm = (liters / secs) * 60;
      } else {
        const gpm = parseFloat(el('gpm').value);
        if (!(gpm > 0)) return hide();
        lpm = gpm * 3.78541;
      }
      const gpmOut = lpm / 3.78541;
      const lph = lpm * 60;

      el('r-lpm').textContent = lpm.toFixed(2) + ' L/min';
      el('r-note').textContent = 'liters per minute';
      el('r-gpm-out').textContent = gpmOut.toFixed(2) + ' GPM';
      el('r-lph').textContent = lph.toFixed(0) + ' L/hr';
      el('results').classList.remove('hidden');
    }
    function hide() { el('results').classList.add('hidden'); }

    el('mode').addEventListener('change', sync);
    ['gpm', 'liters', 'secs'].forEach((id) => el(id).addEventListener('input', update));
    sync();
  </script>
</ToolLayout>
