---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Grams to Pounds"
  emoji="⚖️"
  fromUnit="grams" toUnit="pounds"
  fromTitle="Grams" toTitle="Pounds"
  fromSym="g" toSym="lb"
  quantity="weight"
  kind="factor" factor={0.00220462}
  reverseSlug="pounds-to-grams" reverseLabel="Pounds to Grams Converter"
  hasReverse={true}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Useful for parcels, food portions and produce when a metric weight needs to be read in pounds."
/>
