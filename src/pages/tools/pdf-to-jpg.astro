---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'PDF to JPG';
const description =
  'Free PDF to JPG converter. Turn each page of a PDF into a high-quality image (JPG or PNG). ' +
  'Private and fast — your PDF is rendered in your browser and never uploaded.';
const intro =
  'Upload a PDF and each page is turned into an image you can preview and download. Everything runs in your browser, so your file stays private.';
const category = { id: 'pdf', name: 'PDF Tools' };
const faqs = [
  { q: 'Are my files uploaded?', a: 'No. Your PDF is rendered to images entirely in your browser. Nothing is sent to a server.' },
  { q: 'What image quality do I get?', a: 'Pages are rendered at 2x scale for sharp, high-resolution images suitable for sharing or printing.' },
  { q: 'Can I get PNG instead of JPG?', a: 'Yes — switch the format to PNG if you prefer a lossless image or need transparency.' },
  { q: 'Can I download all pages at once?', a: 'Use "Download all" to save every page. Each page is saved as its own image file.' },
  { q: 'What types of PDFs work with this tool?', a: 'Most standard PDFs work, including scanned documents and digital PDFs. Password-protected or corrupted files may not render.' },
  { q: 'Are the images editable?', a: 'The output is a standard image file (JPG or PNG) that you can edit in any photo software, insert into slideshows, or share on social media.' },
  { q: 'Can I convert only specific pages?', a: 'Currently all pages are rendered. Use the Split PDF tool first to extract only the pages you need.' },
  { q: 'Will text be readable in the images?', a: 'Yes. Pages are rendered at 2x resolution so text, diagrams and fine details are crisp and readable.' },
  { q: 'Can I use the images for printing?', a: 'Yes. The 2x rendering produces images with sufficient resolution for high-quality prints up to A4 size.' },
  { q: 'Does it work with scanned PDFs?', a: 'Yes. Scanned PDF pages are rendered to images the same way, making it easy to save individual scan pages as standalone images.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label for="file-input" class="flex cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 p-8 text-center transition hover:border-indigo-400 hover:bg-indigo-50/40">
      <span class="text-3xl">🏞️</span>
      <span class="mt-2 font-medium text-slate-700">Click to add a PDF</span>
      <span class="mt-1 text-sm text-slate-400">Each page becomes a downloadable image</span>
      <input id="file-input" type="file" accept="application/pdf" class="hidden" />
    </label>

    <div class="mt-4 flex flex-wrap items-center gap-4">
      <label class="flex items-center gap-2 text-sm text-slate-700">
        Format
        <select id="format" class="rounded-md border border-slate-300 px-2 py-1 text-sm">
          <option value="image/jpeg">JPG</option>
          <option value="image/png">PNG</option>
        </select>
      </label>
      <button id="download-all" class="hidden rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Download all</button>
      <span id="status" class="text-sm text-slate-500"></span>
    </div>

    <div id="pages" class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3"></div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How PDF-to-image conversion works</h2>
    <p class="mt-2 text-slate-600">PDF-to-image conversion renders each page of a PDF onto a canvas element using the <span class="font-mono text-indigo-600">pdfjs-dist</span> library. The PDF is parsed page by page, and each page is drawn to a canvas at 2x scale for sharp output.</p>
    <p class="mt-3 text-slate-600">The canvas is then exported as a JPG or PNG image using the <span class="font-mono text-indigo-600">toDataURL()</span> method. Each page produces a separate image file that preserves the original layout, text, and graphics from the PDF page.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Converting a 4-page PDF document to individual images.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Input:</span> <span class="text-slate-600">1 PDF with 4 pages</span></div>
        <div><span class="font-medium text-slate-700">Output:</span> <span class="text-slate-600">4 separate JPG files at 150 DPI</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different use cases mean for quality</h2>
    <p class="mt-2 text-slate-600">Choose the right output format and resolution based on how you plan to use the images.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Social media</span><span class="text-slate-400">JPG at 72 DPI, small file for quick sharing</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Email attachment</span><span class="text-slate-400">JPG at 150 DPI, balanced quality and size</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:35%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Presentation slide</span><span class="text-slate-400">PNG at 150 DPI, crisp text and diagrams</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Document archive</span><span class="text-slate-400">PNG at 300 DPI, lossless archival quality</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:70%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Professional print</span><span class="text-slate-400">PNG at 300+ DPI, maximum detail</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:90%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📱</span>
      <h3 class="mt-2 font-semibold text-slate-900">Social media manager</h3>
      <p class="mt-1 text-sm text-slate-600">Turns brochure PDFs into individual images for Instagram, LinkedIn and Facebook posts.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Extracts textbook pages as images to include in slide presentations or online learning materials.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏡</span>
      <h3 class="mt-2 font-semibold text-slate-900">Real estate agent</h3>
      <p class="mt-1 text-sm text-slate-600">Converts property listing flyers into images for social ads and MLS listings.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">✍️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content creator</h3>
      <p class="mt-1 text-sm text-slate-600">Saves single pages of notes or scripts as images for quick reference on their phone.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Output format</th><th class="p-3">Best for</th><th class="p-3">File size</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">JPG (JPEG)</td><td class="p-3">Photos, colourful pages, social media</td><td class="p-3">Small — good compression</td></tr>
        <tr><td class="p-3 font-medium">PNG</td><td class="p-3">Text, diagrams, screenshots, logos</td><td class="p-3">Larger — lossless quality</td></tr>
        <tr><td class="p-3 font-medium">JPG at 2x scale</td><td class="p-3">Sharp prints, presentations</td><td class="p-3">Medium — 2x resolution</td></tr>
        <tr><td class="p-3 font-medium">PNG at 2x scale</td><td class="p-3">Archival copies, professional printing</td><td class="p-3">Large — maximum fidelity</td></tr>
        <tr><td class="p-3 font-medium">Single page JPG</td><td class="p-3">Emailing one page, quick preview</td><td class="p-3">Small — 100-500 KB</td></tr>
        <tr><td class="p-3 font-medium">All pages PNG</td><td class="p-3">Full document archive</td><td class="p-3">Varies — 1-10 MB per page</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the PDF to image converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Upload your PDF</h3>
        <p class="mt-1 text-sm text-slate-600">Click the upload area and select the PDF you want to convert to images.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose format</h3>
        <p class="mt-1 text-sm text-slate-600">Pick JPG for smaller files or PNG for lossless quality. Pages render at 2x resolution.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Preview and download</h3>
        <p class="mt-1 text-sm text-slate-600">Preview each page image, download individually, or use "Download all" to save every page at once.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for the best image quality</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">JPG for sharing, PNG for quality</h3>
        <p class="mt-1 text-sm text-slate-600">Choose JPG when you need smaller file sizes for social media or email. Choose PNG when you need lossless quality for text, diagrams or archival storage.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Download all at once</h3>
        <p class="mt-1 text-sm text-slate-600">The "Download all" button saves every rendered page as a separate image file. Each file is named with its page number for easy identification.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Convert only what you need</h3>
        <p class="mt-1 text-sm text-slate-600">If you only need a few pages, use the Split PDF tool first to extract them, then convert just those pages to images.</p>
      </div>
    </div>
  </section>

  <script>
    import * as pdfjsLib from 'pdfjs-dist';
    import workerUrl from 'pdfjs-dist/build/pdf.worker.min.mjs?url';
    pdfjsLib.GlobalWorkerOptions.workerSrc = workerUrl;

    const input = document.getElementById('file-input');
    const pagesEl = document.getElementById('pages');
    const status = document.getElementById('status');
    const formatSel = document.getElementById('format');
    const downloadAll = document.getElementById('download-all');

    let rendered = [];

    function ext() { return formatSel.value === 'image/png' ? 'png' : 'jpg'; }

    input.addEventListener('change', async () => {
      const file = input.files[0];
      if (!file) return;
      pagesEl.innerHTML = '';
      rendered = [];
      downloadAll.classList.add('hidden');
      status.textContent = 'Rendering…';
      try {
        const data = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data }).promise;
        for (let n = 1; n <= pdf.numPages; n++) {
          const page = await pdf.getPage(n);
          const viewport = page.getViewport({ scale: 2 });
          const canvas = document.createElement('canvas');
          canvas.width = viewport.width;
          canvas.height = viewport.height;
          await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
          const dataUrl = canvas.toDataURL(formatSel.value, 0.92);
          rendered.push({ dataUrl, n });

          const card = document.createElement('div');
          card.className = 'overflow-hidden rounded-xl border border-slate-200 bg-slate-50';
          card.innerHTML =
            `<img src="${dataUrl}" class="w-full" alt="Page ${n}">` +
            `<a href="${dataUrl}" download="page-${n}.${ext()}" class="block bg-indigo-600 py-1.5 text-center text-sm font-medium text-white transition hover:bg-indigo-700">Download page ${n}</a>`;
          pagesEl.appendChild(card);
          status.textContent = `Rendered ${n} of ${pdf.numPages}…`;
        }
        status.textContent = `✓ ${pdf.numPages} page${pdf.numPages === 1 ? '' : 's'} ready.`;
        downloadAll.classList.remove('hidden');
      } catch (err) {
        status.textContent = '⚠️ Could not read this PDF — it may be corrupted or password-protected.';
      }
    });

    downloadAll.addEventListener('click', () => {
      rendered.forEach((p, i) => {
        setTimeout(() => {
          const a = document.createElement('a');
          a.href = p.dataUrl;
          a.download = `page-${p.n}.${ext()}`;
          a.click();
        }, i * 300);
      });
    });
  </script>
</ToolLayout>
