---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Oven Temperature Converter';
const description =
  'Free oven temperature converter. Instantly convert between Fahrenheit, Celsius, gas mark, and fan-assisted (convection) oven settings for any recipe.';
const intro =
  'Enter a temperature in any oven scale to see the equivalent in Fahrenheit, Celsius, gas mark and fan-assisted (convection) settings.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'Why do ovens use different temperature scales?', a: 'Different regions standardised on different systems historically. The US uses Fahrenheit for all cooking, most of Europe and Asia use Celsius, the UK and Ireland use gas marks for gas ovens (a numbered scale from 1 to 9), and fan-assisted settings reflect the fact that convection ovens cook faster and at a lower temperature than conventional ovens.' },
  { q: 'What is the difference between conventional and fan ovens?', a: 'A conventional (static) oven heats from the top and bottom elements, creating hot and cool spots. A fan (convection) oven circulates hot air with a fan, distributing heat evenly and cooking food about 20–25% faster. For fan ovens, you typically reduce the conventional temperature by 20°C (or about 25–30°F).' },
  { q: 'How do I convert Fahrenheit to Celsius?', a: 'The formula is: (°F − 32) × 5/9 = °C. For example, 350°F = (350 − 32) × 5/9 = 318 × 5/9 = 177°C, which is typically rounded to 175°C or 180°C in recipes.' },
  { q: 'What gas mark is 180°C?', a: '180°C (350°F) is Gas Mark 4 in the UK and Ireland gas oven scale. Gas mark numbers increase by about 14°C (25°F) per step: Mark 1 = 140°C, Mark 2 = 150°C, Mark 3 = 160°C, Mark 4 = 180°C, Mark 5 = 190°C, Mark 6 = 200°C, Mark 7 = 220°C, Mark 8 = 230°C and Mark 9 = 240°C.' },
  { q: 'Should I reduce temperature for a fan oven?', a: 'Yes — reduce the conventional oven temperature by 20°C (or approximately 25–30°F) when using a fan-assisted oven. For example, if a recipe says 200°C conventional, set your fan oven to 180°C. The cooking time may also reduce slightly.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature</span>
        <input id="temp" type="number" step="any" placeholder="180" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">From scale</span>
        <select id="scale" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="C">Celsius (°C)</option>
          <option value="F">Fahrenheit (°F)</option>
          <option value="gas">Gas mark</option>
          <option value="fan">Fan (°C)</option>
        </select></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Conventional oven</div>
        <div id="r-c" class="mt-1 text-3xl font-bold">—</div>
        <div id="r-f" class="mt-1 text-sm opacity-80">—</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Gas mark</div><div id="r-gas" class="mt-1 text-xl font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Fan oven (°C)</div><div id="r-fan" class="mt-1 text-xl font-bold text-slate-700">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter a temperature and select its scale to see all conversions.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The Oven Temperature Converter handles all four common oven temperature scales — Fahrenheit, Celsius, gas mark and fan-assisted Celsius — using a two-step process. Your input is first converted to Celsius as the base reference, and then converted outward to every other scale. The fan oven temperature is calculated by subtracting 20°C from the conventional Celsius value, which is the standard adjustment recommended by most oven manufacturers and cookbook authors.
    </p>
    <p class="mt-3 text-slate-600">
      Gas marks are a numbered scale (1 through 9) used primarily in the UK and Ireland for gas ovens. Each gas mark corresponds to a specific temperature range. The conversion is not perfectly linear — gas mark 4 is 180°C, gas mark 6 is 200°C and gas mark 9 is 240°C — but the steps are well established and consistent across modern gas ovens. Electric fan ovens have their own dedicated temperature guides because the circulating air transfers heat more efficiently than static heat.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="ot-title ot-desc">
      <title id="ot-title">Oven temperature scales comparison</title>
      <desc id="ot-desc">Four parallel horizontal bars showing equivalent temperatures across Fahrenheit, Celsius, gas mark and fan-assisted Celsius scales.</desc>
      <!-- Fahrenheit bar -->
      <rect x="60" y="20" width="680" height="28" rx="6" fill="#f1f5f9" />
      <rect x="60" y="20" width="340" height="28" rx="6" fill="#ef4444" />
      <text x="50" y="39" text-anchor="end" font-size="12" font-weight="bold" fill="#475569">°F</text>
      <text x="230" y="39" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">250</text>
      <text x="400" y="39" text-anchor="middle" font-size="11" fill="#ef4444">350</text>
      <text x="570" y="39" text-anchor="middle" font-size="11" fill="#64748b">450</text>
      <!-- Celsius bar -->
      <rect x="60" y="58" width="680" height="28" rx="6" fill="#f1f5f9" />
      <rect x="60" y="58" width="270" height="28" rx="6" fill="#f97316" />
      <text x="50" y="77" text-anchor="end" font-size="12" font-weight="bold" fill="#475569">°C</text>
      <text x="195" y="77" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">120</text>
      <text x="400" y="77" text-anchor="middle" font-size="11" fill="#f97316">180</text>
      <text x="600" y="77" text-anchor="middle" font-size="11" fill="#64748b">230</text>
      <!-- Gas mark bar -->
      <rect x="60" y="96" width="680" height="28" rx="6" fill="#f1f5f9" />
      <rect x="60" y="96" width="200" height="28" rx="6" fill="#eab308" />
      <text x="50" y="115" text-anchor="end" font-size="12" font-weight="bold" fill="#475569">Gas</text>
      <text x="160" y="115" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">1</text>
      <text x="400" y="115" text-anchor="middle" font-size="11" fill="#ca8a04">4</text>
      <text x="620" y="115" text-anchor="middle" font-size="11" fill="#64748b">8</text>
      <!-- Fan bar -->
      <rect x="60" y="134" width="680" height="28" rx="6" fill="#f1f5f9" />
      <rect x="60" y="134" width="240" height="28" rx="6" fill="#6366f1" />
      <text x="50" y="153" text-anchor="end" font-size="12" font-weight="bold" fill="#475569">Fan</text>
      <text x="180" y="153" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">100</text>
      <text x="400" y="153" text-anchor="middle" font-size="11" fill="#6366f1">160</text>
      <text x="600" y="153" text-anchor="middle" font-size="11" fill="#64748b">210</text>
      <!-- Labels -->
      <text x="400" y="190" text-anchor="middle" font-size="11" fill="#94a3b8">Low heat → Medium → High heat → Very hot</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Parallel temperature scales: Fahrenheit, Celsius, gas mark and fan-assisted oven</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the conversion works</h2>
    <p class="mt-2 text-slate-600">
      All conversions go through Celsius. The formula for Fahrenheit to Celsius is (°F − 32) × 5/9. For gas marks, we use the standard conversion table derived from British gas oven standards. The fan temperature is simply conventional Celsius minus 20°C.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">An American recipe calls for a 375°F oven, but your oven is marked in Celsius with a fan setting. What are the equivalents?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Input:</span> <span class="text-slate-600">375°F</span></div>
        <div><span class="font-medium text-slate-700">To Celsius:</span> <span class="text-slate-600">(375 − 32) × 5/9 = 343 × 5/9 = <strong>191°C</strong></span></div>
        <div><span class="font-medium text-slate-700">Rounded Celsius:</span> <span class="text-slate-600"><strong>190°C</strong> (common recipe rounding)</span></div>
        <div><span class="font-medium text-slate-700">Gas mark:</span> <span class="text-slate-600">190°C matches <strong>Gas Mark 5</strong></span></div>
        <div><span class="font-medium text-slate-700">Fan oven:</span> <span class="text-slate-600">190 − 20 = <strong>170°C fan</strong></span></div>
        <div><span class="font-medium text-slate-700">Check:</span> <span class="text-slate-600">375°F = 190°C = Gas 5 = 170°C fan</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌍</span>
      <h3 class="mt-2 font-semibold text-slate-900">International home cook</h3>
      <p class="mt-1 text-sm text-slate-600">Following a recipe from a different country and need to convert the oven temperature to match your local oven's markings and settings.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍞</span>
      <h3 class="mt-2 font-semibold text-slate-900">Bread enthusiast</h3>
      <p class="mt-1 text-sm text-slate-600">Bread recipes are sensitive to temperature. Converting between oven types accurately ensures your crust and crumb develop as the recipe intends.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📖</span>
      <h3 class="mt-2 font-semibold text-slate-900">Cookbook author</h3>
      <p class="mt-1 text-sm text-slate-600">Publishing recipes for an international audience requires providing oven temperatures in multiple scales so readers worldwide can follow along.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏠</span>
      <h3 class="mt-2 font-semibold text-slate-900">New oven owner</h3>
      <p class="mt-1 text-sm text-slate-600">Just bought a new fan oven and need to adapt your collection of conventional-temperature recipes to the new appliance.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Oven Temperature Converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the temperature</h3>
        <p class="mt-1 text-sm text-slate-600">Type the temperature number from your recipe. This can be a Celsius value, Fahrenheit value or gas mark number.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select the input scale</h3>
        <p class="mt-1 text-sm text-slate-600">Choose whether your entered value is in Celsius, Fahrenheit, gas mark or fan-assisted oven temperature from the dropdown.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read all equivalents</h3>
        <p class="mt-1 text-sm text-slate-600">See the temperature in all four scales instantly, including the fan oven setting so you can set your oven correctly the first time.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Know your oven's actual temperature</h3>
        <p class="mt-1 text-sm text-slate-600">Ovens often run hotter or colder than the dial says (by 10–30°C in some cases). An oven thermometer costs very little and lets you calibrate your understanding of your specific oven's behaviour.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Reduce cooking time for fan ovens</h3>
        <p class="mt-1 text-sm text-slate-600">In addition to lowering the temperature by 20°C, fan ovens often cook slightly faster. Start checking for doneness 5–10 minutes before the recipe's recommended time when using fan mode.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Gas marks are approximate</h3>
        <p class="mt-1 text-sm text-slate-600">Gas marks are a guide, not an exact temperature. The actual temperature in a gas oven can vary between models and even between the top and bottom of the oven. Use an oven thermometer to verify.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/baking-conversion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">⚖️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Conversion Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Volume to weight for baking ingredients</p>
      </a>
      <a href="/tools/cooking-measurement-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🥄</span>
        <h3 class="mt-2 font-semibold text-slate-900">Cooking Measurement Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert cups, tbsp, tsp, ml and fl oz</p>
      </a>
      <a href="/tools/meat-roasting-time-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🍖</span>
        <h3 class="mt-2 font-semibold text-slate-900">Meat Roasting Time Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Roasting times by meat type and weight</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function gasMark(c) {
      if (c < 135) return '\u2014';
      if (c < 145) return '\u00BC';
      if (c < 155) return '\u00BD';
      if (c < 165) return '1';
      if (c < 175) return '2';
      if (c < 185) return '3';
      if (c < 195) return '4';
      if (c < 205) return '5';
      if (c < 215) return '6';
      if (c < 225) return '7';
      if (c < 235) return '8';
      return '9';
    }

    function update() {
      const val = parseFloat(el('temp').value);
      const scale = el('scale').value;
      if (!val) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      let c;
      if (scale === 'C') c = val;
      else if (scale === 'F') c = (val - 32) * 5 / 9;
      else if (scale === 'gas') c = 140 + (val - 1) * 14;
      else c = val + 20;

      if (c < 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      const f = c * 9 / 5 + 32;
      const fan = c - 20;
      const gas = gasMark(c);

      el('r-c').innerHTML = Math.round(c).toLocaleString() + ' <span class="text-lg opacity-80">\u00B0C</span>';
      el('r-f').textContent = Math.round(f).toLocaleString() + '\u00B0F';
      el('r-gas').textContent = gas;
      el('r-fan').textContent = Math.round(fan) >= 0 ? Math.round(fan).toLocaleString() + '\u00B0C fan' : '\u2014';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('temp').addEventListener('input', update);
    el('scale').addEventListener('input', update);
  </script>
</ToolLayout>
