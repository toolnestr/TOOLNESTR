---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Age in Hijri Years Calculator';
const description = 'Calculate your age in Hijri (lunar) years, months and days from your Gregorian birth date, and see why it is higher than your Gregorian age.';
const intro = 'Enter your birth date to see your age counted in Hijri (Islamic) lunar years.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'Why is my Hijri age higher than my Gregorian age?', a: 'The Hijri year is about 354 days, while the Gregorian year is about 365 days. Because lunar years are shorter, more of them fit into the same span of time, so your age in Hijri years is slightly higher.' },
  { q: 'How big is the difference?', a: 'The lunar and solar years differ by roughly 11 days each year. Over a lifetime this adds up: about one extra Hijri year for every 33 Gregorian years.' },
  { q: 'How is the Hijri age calculated?', a: 'The tool converts both your birth date and today’s date to the Umm al-Qura Hijri calendar, then takes the difference in Hijri years, months and days.' },
  { q: 'Is this exact to the day?', a: 'Hijri months vary between 29 and 30 days, so the month-and-day breakdown is a close approximation. The Hijri year count itself is accurate.' },
];
const sources = [
  { html: "<strong>The Qur’an</strong> — e.g. Surah an-Nisa (4:11–12, 4:176) for the fixed inheritance shares (fara’id)." },
  { html: "<strong>Sahih al-Bukhari &amp; Sahih Muslim</strong> — hadith on inheritance, zakat and nisab thresholds." },
  { html: "<strong>AAOIFI and recognized fiqh councils</strong> (e.g. Islamic Fiqh Academy) for contemporary rulings. <a href=\"https://aaoifi.com/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">aaoifi.com</a>" },
];
const sourcesNote = "Rulings differ between scholars and schools (madhahib), and calculated astronomical times/dates may differ from local sighting. Confirm with a qualified scholar before acting.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Your birth date (Gregorian)</span>
      <input id="bdate" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div id="result" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Your age in Hijri years</div>
        <div id="r-age" class="mt-1 text-3xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Gregorian age</div><div id="r-greg" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Extra Hijri years</div><div id="r-diff" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ah-title ah-desc">
      <title id="ah-title">Hijri versus Gregorian age comparison bars</title>
      <desc id="ah-desc">Two bars showing that the same lifespan contains slightly more Hijri years than Gregorian years.</desc>
      <text x="60" y="70" font-size="14" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">Hijri years</text>
      <rect x="60" y="80" width="680" height="30" rx="6" fill="#6366f1" />
      <text x="60" y="150" font-size="14" fill="#475569" font-family="system-ui,sans-serif" font-weight="bold">Gregorian years</text>
      <rect x="60" y="160" width="660" height="30" rx="6" fill="#cbd5e1" />
      <text x="755" y="100" text-anchor="end" font-size="12" fill="#fff" font-family="system-ui,sans-serif">more</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The shorter lunar year means a higher count of Hijri years over the same lifespan.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How your Hijri age is calculated</h2>
    <p class="mt-2 text-slate-600">Your age is usually counted in Gregorian (solar) years, but the Islamic tradition counts time in Hijri (lunar) years. Because a lunar year of about 354 days is roughly 11 days shorter than a solar year, a person’s Hijri age is always a little higher than their Gregorian age. This calculator converts both your birth date and today’s date to the Hijri calendar and measures the gap between them in Islamic years, months and days.</p>
    <p class="mt-3 text-slate-600">The conversion uses the Umm al-Qura calendar built into your browser, so the result is consistent and computed entirely on your device. The headline figure is your full Hijri age, and the breakdown shows the months and days on top. For comparison, the tool also shows your ordinary Gregorian age and the extra years that the lunar count adds.</p>
    <p class="mt-3 text-slate-600">This is useful for understanding your age the way it would be recorded historically in Islamic documents, for marking lunar birthdays, or simply out of curiosity. Since Hijri months alternate between 29 and 30 days, treat the month-and-day portion as a close estimate while the year count remains reliable.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">Someone born on 1 January 1990 is about 35 Gregorian years old today. Converted to lunar years, that same span is roughly 36 Hijri years — about one extra year gained over 33 years of life.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/age-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Age Calculator</a>
      <a href="/tools/hijri-date-today/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Today’s Hijri Date</a>
      <a href="/tools/gregorian-to-hijri-converter/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gregorian to Hijri Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const hfmt = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', { day: 'numeric', month: 'numeric', year: 'numeric', timeZone: 'UTC' });
    function hijriOf(d) { const o = {}; hfmt.formatToParts(d).forEach((p) => { if (p.type !== 'literal') o[p.type] = parseInt(p.value, 10); }); return o; }
    function update() {
      const v = el('bdate').value;
      if (!v) { el('result').classList.add('hidden'); return; }
      const p = v.split('-');
      const birth = new Date(Date.UTC(+p[0], +p[1] - 1, +p[2]));
      const now = new Date();
      const today = new Date(Date.UTC(now.getFullYear(), now.getMonth(), now.getDate()));
      if (birth > today) { el('result').classList.add('hidden'); return; }
      const b = hijriOf(birth), t = hijriOf(today);
      let y = t.year - b.year, m = t.month - b.month, d = t.day - b.day;
      if (d < 0) { m -= 1; d += 30; }
      if (m < 0) { y -= 1; m += 12; }
      let gy = today.getUTCFullYear() - birth.getUTCFullYear();
      const anniv = new Date(Date.UTC(birth.getUTCFullYear() + gy, birth.getUTCMonth(), birth.getUTCDate()));
      if (anniv > today) gy -= 1;
      el('r-age').textContent = y + ' yr ' + m + ' mo ' + d + ' d';
      el('r-greg').textContent = gy + ' years';
      el('r-diff').textContent = (y - gy >= 0 ? '+' : '') + (y - gy) + ' years';
      el('result').classList.remove('hidden');
    }
    el('bdate').addEventListener('input', update);
  </script>
</ToolLayout>
