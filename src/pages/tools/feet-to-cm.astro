---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Feet to Cm"
  emoji="📏"
  fromUnit="feet" toUnit="centimeters"
  fromTitle="Feet" toTitle="Centimeters"
  fromSym="ft" toSym="cm"
  quantity="length"
  kind="factor" factor={30.48}
  reverseSlug="cm-to-feet" reverseLabel="Cm to Feet Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Turn a height or distance in feet into centimeters for passports, furniture and international forms."
/>
