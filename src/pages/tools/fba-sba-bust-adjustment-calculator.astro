---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'FBA/SBA Bust Adjustment Calculator';
const description = 'Calculate the full bust adjustment (FBA) or small bust adjustment (SBA) amount needed from your high bust and full bust measurements.';
const intro = 'Calculate a full bust or small bust adjustment amount from your high bust and full bust measurements.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is high bust versus full bust?', a: 'High bust is measured across the chest, above the bust and under the arms, close to the underarm crease. Full bust is measured around the fullest part of the bust. The difference between the two is what pattern sizing is typically based on.' },
  { q: 'Why do pattern companies assume a 1-inch difference?', a: 'Most commercial patterns are drafted assuming a "B cup" proportion, which corresponds to roughly a 1-inch difference between high bust and full bust — if your actual difference is larger or smaller than that, the pattern\'s bust area will not match your shape without adjustment.' },
  { q: 'What do I do with the calculated adjustment amount?', a: 'For an FBA, that amount is typically added by pivoting and slashing the front bodice pattern piece to add width and length at the bust point, split between the two pattern halves. For an SBA, fabric is instead removed using a similar pivot method. Follow a dedicated FBA/SBA tutorial for the exact pattern-alteration technique.' },
  { q: 'Should I size my pattern using high bust or full bust?', a: 'Many fitting guides recommend choosing your pattern size based on high bust measurement, then adding an FBA if needed, rather than sizing up based on full bust — sizing up by full bust alone can result in an oversized fit everywhere except the bust.' },
];
const howTo = {
  name: 'How to calculate an FBA or SBA amount',
  steps: [
    { name: 'Measure high bust and full bust', text: 'Measure both, in inches, with a well-fitting non-padded bra.' },
    { name: 'Enter both measurements', text: 'Enter your high bust and full bust into the calculator.' },
    { name: 'Read the adjustment amount', text: 'The FBA or SBA amount needed, and the per-side adjustment, appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">High bust (in)</span>
        <input id="highBust" type="number" step="any" placeholder="e.g. 34" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Full bust (in)</span>
        <input id="fullBust" type="number" step="any" placeholder="e.g. 38" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Adjustment needed</div>
        <div id="r-adjustment" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Amount to add/remove per side</div><div id="r-perside" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fba-title fba-desc">
      <title id="fba-title">Torso outline with high bust and full bust lines</title>
      <desc id="fba-desc">A torso silhouette with two dashed horizontal lines marking the high bust and full bust measurement points</desc>
      <path d="M370 20 Q345 20 342 45 Q340 65 355 75 Q330 85 328 120 Q326 150 350 165 L450 165 Q474 150 472 120 Q470 85 445 75 Q460 65 458 45 Q455 20 430 20Z" fill="#fecdd3" stroke="#e11d48" stroke-width="2" />
      <line x1="300" y1="55" x2="500" y2="55" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="560" y="60" font-size="13" fill="#475569" font-family="system-ui,sans-serif">High bust</text>
      <line x1="290" y1="100" x2="510" y2="100" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="560" y="105" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Full bust</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The difference between high bust and full bust determines the adjustment amount</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the FBA/SBA amount is calculated</h2>
    <p class="mt-2 text-slate-600">
      Most commercial patterns are drafted assuming roughly a 1-inch difference between high bust and full bust, corresponding to a "B cup" proportion. This calculator subtracts high bust from full bust to find your actual difference, then subtracts that standard 1-inch assumption — if the result is positive, that's your full bust adjustment (FBA) amount; if negative, that's your small bust adjustment (SBA) amount (as a positive number to remove).
    </p>
    <p class="mt-3 text-slate-600">
      Because a bodice front is typically cut as two mirrored halves (left and right), the total adjustment amount is generally split evenly between both sides, so the per-side adjustment applied to each pattern half via the standard pivot-and-slide method is roughly half the total calculated amount.
    </p>
    <p class="mt-3 text-xs text-slate-400">The 1-inch "B cup" assumption reflects the standard convention referenced across pattern-fitting and dressmaking adjustment guides; this calculator estimates the adjustment amount, not the full pattern-alteration technique itself.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A high bust of 34 inches and a full bust of 38 inches.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Difference:</span> <span class="text-slate-600">38 − 34 = 4 in</span></div>
        <div><span class="font-medium text-slate-700">FBA amount:</span> <span class="text-slate-600">4 − 1 = <strong>3 in FBA</strong></span></div>
        <div><span class="font-medium text-slate-700">Per side:</span> <span class="text-slate-600">3 ÷ 2 = <strong>1.5 in per pattern half</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Sewists whose full bust and high bust measurements point to two different pattern sizes run into this constantly — sizing to the full bust measurement alone often results in a bodice that fits well at the bust but is oversized at the shoulders and neckline, which is exactly the mismatch an FBA is designed to fix without sizing up the whole garment.
    </p>
    <p class="mt-3 text-slate-600">
      A well-executed FBA or SBA is one of the most commonly cited "fit game changer" adjustments in home sewing, since it directly addresses a mismatch between commercial pattern assumptions and individual variation that off-the-rack clothing sizing simply doesn't accommodate at all.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"An FBA amount should be added entirely to one side of the pattern." <strong class="text-slate-900">It's typically split.</strong> Since the bodice front is symmetric, the total adjustment is usually divided between the two mirrored pattern halves, not applied entirely to a single piece.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Every pattern assumes the same bust size relationship." <strong class="text-slate-900">Mostly consistent, but check.</strong> The 1-inch B-cup assumption is a common commercial-pattern default, but some pattern companies, especially those drafting for a wider size range, may assume a different base cup size — check the pattern's own fitting notes when available.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pattern-grading-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Pattern Grading Calculator</a>
      <a href="/tools/bra-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Bra Size Calculator</a>
      <a href="/tools/ease-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Ease Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const BASE_DIFF = 1;

    function update() {
      const highBust = parseFloat(el('highBust').value);
      const fullBust = parseFloat(el('fullBust').value);
      if (!highBust || !fullBust || highBust <= 0 || fullBust <= 0) { el('results').classList.add('hidden'); return; }
      const diff = fullBust - highBust;
      const adjustment = diff - BASE_DIFF;
      const absAdj = Math.abs(adjustment);
      const perSide = absAdj / 2;

      if (adjustment > 0.1) {
        el('r-adjustment').textContent = absAdj.toFixed(2) + ' in FBA (add)';
      } else if (adjustment < -0.1) {
        el('r-adjustment').textContent = absAdj.toFixed(2) + ' in SBA (remove)';
      } else {
        el('r-adjustment').textContent = 'No adjustment needed';
      }
      el('r-perside').textContent = perSide.toFixed(2) + ' in per pattern half';
      el('results').classList.remove('hidden');
    }

    el('highBust').addEventListener('input', update);
    el('fullBust').addEventListener('input', update);
  </script>
</ToolLayout>
