---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Shiplap Calculator';
const description = 'Find how many shiplap boards you need to cover a wall or ceiling, accounting for the overlap between boards, from the surface area and board dimensions.';
const intro = 'Find how many shiplap boards you need for a wall, accounting for the overlap.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate how many shiplap boards I need?', a: 'Because shiplap boards overlap at their edges, each board only adds its exposed width to the wall, not its full width. Divide the wall height by the exposed coverage width per board (board width minus overlap) to get rows, then multiply by how many boards fit across the wall length.' },
  { q: 'What is a typical shiplap overlap?', a: 'A common overlap is about 1/2 inch, though it varies by profile — some shiplap boards have a deeper rabbet joint that overlaps more. Check your specific board\'s milled profile for its actual overlap before ordering.' },
  { q: 'How much waste allowance should I add for shiplap?', a: 'A common allowance is 10% for end cuts and matching board ends at wall corners or the ceiling line. Rooms with more corners, windows, or doors typically need a higher allowance since each opening creates more cut pieces.' },
  { q: 'Does shiplap run horizontally or vertically?', a: 'Both orientations are common — horizontal is the traditional farmhouse look, while vertical shiplap is popular for a more modern feel. The calculator math is the same either way: just decide which dimension is the "coverage" direction (rows) and which is the board run length.' },
];
const howTo = {
  name: 'How to calculate shiplap boards needed',
  steps: [
    { name: 'Measure the wall', text: 'Width and height in feet.' },
    { name: 'Check the board profile', text: 'Its width and how much it overlaps.' },
    { name: 'Order by linear footage', text: 'Total board length, plus waste.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall width (ft)</span>
        <input id="width" type="number" step="any" placeholder="14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall height (ft)</span>
        <input id="height" type="number" step="any" placeholder="9" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Board width (in)</span>
        <input id="boardw" type="number" step="any" placeholder="7.25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Overlap (in)</span>
        <input id="overlap" type="number" step="any" placeholder="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Rows of boards needed</div>
        <div id="r-rows" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Exposed coverage/board</div><div id="r-exposed" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Total board length</div><div id="r-linft" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">With 10% waste</div><div id="r-waste" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sl-title sl-desc">
      <title id="sl-title">Overlapping shiplap boards on a wall</title>
      <desc id="sl-desc">Horizontal shiplap boards overlapping at their edges, with the coverage formula</desc>
      <g stroke="#78350f" stroke-width="1">
        <rect x="80" y="60" width="220" height="24" fill="#fde68a" /><rect x="80" y="80" width="220" height="24" fill="#fbbf24" /><rect x="80" y="100" width="220" height="24" fill="#fde68a" /><rect x="80" y="120" width="220" height="24" fill="#fbbf24" /><rect x="80" y="140" width="220" height="24" fill="#fde68a" />
      </g>
      <text x="190" y="175" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">boards overlap at each seam</text>
      <rect x="420" y="55" width="330" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Shiplap coverage</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">exposed width = board width &minus; overlap</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">rows = wall height &divide; exposed width</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Only the exposed portion of each board — not its full width — covers new wall area.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the shiplap calculator works</h2>
    <p class="mt-2 text-slate-600">
      Shiplap boards are milled with a rabbeted edge so each board overlaps the one before it, creating the recognizable stepped-seam look. That overlap means a board's full width doesn't all become new wall coverage — some of it is hidden behind the overlap with the next board. The coverage that actually counts is the board's exposed width: its full width minus the overlap.
    </p>
    <p class="mt-3 text-slate-600">
      To find how many rows of boards a wall needs, divide the wall height (or width, if running the boards vertically) by that exposed coverage width, rounding up since a partial board still needs a full board cut down to fit. Multiplying the number of rows by the wall's length in the other direction gives the total linear footage of board material to buy.
    </p>
    <p class="mt-3 text-slate-600">
      Direction matters for both look and layout math. Horizontal shiplap, the traditional farmhouse style, uses the wall height as the "coverage" dimension and the wall width as the run length for each row. Vertical shiplap flips that: the wall width becomes the coverage dimension (divided into rows of boards run top to bottom) and the wall height becomes the run length. The underlying arithmetic is identical either way — only which measurement plays which role changes.
    </p>
    <p class="mt-3 text-slate-600">
      A typical overlap for common shiplap profiles is about 1/2 inch, though this varies by the specific milled profile — check your board's actual overlap rather than assuming. A 10% waste allowance covers end cuts at corners, doors, and windows, with rooms that have more openings or corners typically needing a bit more.
    </p>
    <p class="mt-3 text-xs text-slate-400">Nominal shiplap board widths and rabbet-joint profiles follow typical dimensions published by softwood lumber millers and trade associations such as the Southern Pine Inspection Bureau.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the wall</h3>
        <p class="mt-1 text-sm text-slate-600">Width and height in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check the board profile</h3>
        <p class="mt-1 text-sm text-slate-600">Its width and how much it overlaps.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Order by linear footage</h3>
        <p class="mt-1 text-sm text-slate-600">Total board length, plus waste.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Exposed coverage per board</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= board width &minus; overlap</span>. A 7.25 in board, 0.5 in overlap: 7.25 − 0.5 = <strong>6.75 in</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Rows needed</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= ceil(height(in) &divide; exposed)</span>. A 9 ft (108 in) wall: ceil(108÷6.75) = <strong>16 rows</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Total linear footage</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= rows &times; wall width</span> = 16 × 14 = <strong>224 linear ft</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 20 ft × 8 ft wall, 5.5 in boards, 0.75 in overlap.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Exposed:</span> <span class="text-slate-600">5.5 − 0.75 = 4.75 in</span></div>
        <div><span class="font-medium text-slate-700">Rows:</span> <span class="text-slate-600">ceil(96÷4.75) = <strong>21 rows</strong></span></div>
        <div><span class="font-medium text-slate-700">Linear feet:</span> <span class="text-slate-600">21 × 20 = 420 ft</span></div>
        <div><span class="font-medium text-slate-700">With 10% waste:</span> <span class="text-slate-600"><strong>462 ft</strong></span></div>
      </div>
    </div>
    <p class="mt-5 text-slate-600">
      Real shiplap and MDF or engineered "faux shiplap" panels use the same coverage math but different overlap depths, so always confirm your specific product's exposed reveal before ordering. Real wood shiplap also needs an acclimation period — typically 48 to 72 hours in the room where it will be installed — to adjust to local humidity, since boards installed too dry can develop visible gaps as they later absorb moisture and expand.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A single accent wall is the most common shiplap project. A 10 ft by 8 ft wall using standard 7.25-inch boards with a 0.5-inch overlap has an exposed coverage of 6.75 inches per board, needing ceil(96÷6.75) = 15 rows and 15 × 10 = 150 linear feet of board, or 165 linear feet once the standard 10% waste allowance is added for end cuts.
    </p>
    <p class="mt-3 text-slate-600">
      Vertical shiplap in a bathroom, a popular treatment behind a vanity or tub, works the same math with the wall's dimensions swapped. A 6 ft wide, 4 ft tall accent using narrower 5.5-inch boards with a deeper 0.75-inch overlap gives 4.75 inches of exposed coverage, needing ceil(48÷4.75) = 11 rows and 11 × 6 = 66 linear feet, or 73 feet with waste — a small enough job that a single box of boards usually covers it.
    </p>
    <p class="mt-3 text-slate-600">
      A full living room feature wall scales up quickly. At 16 ft by 9 ft with the same 7.25-inch, 0.5-inch overlap boards, the wall needs ceil(108÷6.75) = 16 rows and 16 × 16 = 256 linear feet, or 282 feet with waste — at that quantity, buying boards by the bundle rather than individually usually works out cheaper per linear foot.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A board's labeled width is exactly how much new wall it covers." <strong class="text-slate-900">Not with shiplap.</strong> Because each board overlaps the one below or beside it at the rabbet joint, only the exposed portion — the full width minus the overlap — actually adds new coverage. Ignoring the overlap when estimating boards leads to running short partway through the wall.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Shiplap and tongue-and-groove board profiles are the same thing." <strong class="text-slate-900">They're milled differently.</strong> Shiplap uses a rabbet cut on each edge, leaving a visible reveal or shadow line at the seam that gives it its signature stepped look. Tongue-and-groove boards interlock with a protruding tongue fitting into a groove, producing a flush, seamless surface with no visible gap between boards.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/board-and-batten-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Board and Batten Calculator</a>
      <a href="/tools/wainscoting-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Wainscoting Calculator</a>
      <a href="/tools/vinyl-siding-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Vinyl Siding Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const W = parseFloat(el('width').value);
      const H = parseFloat(el('height').value);
      const boardW = parseFloat(el('boardw').value);
      const overlap = parseFloat(el('overlap').value);
      if (!(W > 0 && H > 0 && boardW > 0 && overlap >= 0 && overlap < boardW)) { el('results').classList.add('hidden'); return; }
      const exposed = boardW - overlap;
      const heightIn = H * 12;
      const rows = Math.ceil(heightIn / exposed);
      const linft = rows * W;
      const withWaste = linft * 1.10;

      el('r-rows').textContent = rows;
      el('r-note').textContent = exposed.toFixed(2) + ' in exposed per board, over a ' + H + ' ft wall';
      el('r-exposed').textContent = exposed.toFixed(2) + ' in';
      el('r-linft').textContent = linft.toFixed(0) + ' ft';
      el('r-waste').textContent = withWaste.toFixed(0) + ' ft';
      el('results').classList.remove('hidden');
    }

    ['width', 'height', 'boardw', 'overlap'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
