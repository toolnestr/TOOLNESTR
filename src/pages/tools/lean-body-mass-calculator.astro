---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Lean Body Mass Calculator';
const description =
  'Free lean body mass calculator. Estimate your fat-free mass using the Boer and James formulas from your height, weight, and sex instantly.';
const intro =
  'Enter your height, weight and sex to estimate your lean body mass (LBM) — the total weight of your body minus fat mass.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is lean body mass?', a: 'Lean body mass is everything in your body that is not fat — muscles, bones, organs, skin, blood and water. It is sometimes called fat-free mass and is a key metric for assessing body composition.' },
  { q: 'Which formula do you use?', a: 'We use the Boer formula (the most validated for general populations) and also show the James formula for comparison. Both use height, weight and sex to estimate fat-free mass.' },
  { q: 'Why does LBM matter?', a: 'LBM is more informative than total weight because it tells you how much metabolically active tissue you carry. A higher LBM means a higher BMR, better glucose regulation and greater physical strength.' },
  { q: 'How is LBM different from muscle mass?', a: 'Muscle mass is a component of LBM, but LBM also includes bones, organs, connective tissue and water. Muscle makes up roughly 40–50% of LBM in most people.' },
  { q: 'How accurate are these estimates?', a: 'The Boer formula gives estimates within ±3–4% of DEXA scan results for most adults. Accuracy drops for very muscular or very obese individuals. The James formula is a useful alternative comparison.' },
];
const sources = [
  { html: "<strong>NIH / National Institutes of Health</strong> and <strong>CDC</strong> reference values and formulas. <a href=\"https://www.nih.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nih.gov</a>" },
  { html: "<strong>Peer-reviewed equations</strong> (e.g. Mifflin-St Jeor, Harris-Benedict) as originally published." },
  { html: "<strong>ACOG</strong> for pregnancy, ovulation and due-date methodology. <a href=\"https://www.acog.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">acog.org</a>" },
];
const sourcesNote = "Not medical advice. Estimates only — consult a qualified healthcare professional for any personal health decision.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
      <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>

    <div id="metric" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-3" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Lean body mass</div>
        <div id="r-lbm" class="mt-1 text-3xl font-bold">—</div>
        <div class="mt-1 text-sm opacity-80">fat-free mass</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Body fat (estimated)</div><div id="r-fat" class="mt-1 text-xl font-bold text-emerald-600">—</div><div class="text-xs text-slate-400">of total weight</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Formula</div><div id="r-formula" class="mt-1 text-sm font-bold text-indigo-600">—</div><div class="text-xs text-slate-400">Boer method</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your height and weight to estimate lean body mass.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About lean body mass</h2>
    <p class="mt-2 text-slate-600">
      Lean body mass (LBM) is one of the most informative metrics in body composition analysis. Unlike total body weight, which lumps fat and lean tissue together, LBM tells you how much of your weight is metabolically active. Your LBM is the primary driver of your Basal Metabolic Rate (BMR) — more lean mass means more calories burned at rest. It also correlates strongly with strength, bone density and longevity. Tracking LBM over time helps you see whether your weight changes are coming from fat loss (good) or muscle loss (bad). Pair this with <a href="/tools/body-fat/" class="font-medium text-indigo-600 hover:underline">Body Fat Calculator</a> and <a href="/tools/bmi-calculator/" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a> for a fuller picture.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical advice.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="lbm-title lbm-desc">
      <title id="lbm-title">Body composition split: fat vs lean</title>
      <desc id="lbm-desc">A body silhouette split vertically with labels showing the proportion of fat mass versus lean body mass.</desc>
      <!-- Simple body outline -->
      <ellipse cx="400" cy="100" rx="60" ry="90" fill="#e2e8f0" />
      <ellipse cx="400" cy="100" rx="60" ry="90" fill="url(#leanGrad)" />
      <defs>
        <linearGradient id="leanGrad">
          <stop offset="0%" stop-color="#6366f1" stop-opacity="0.7" />
          <stop offset="50%" stop-color="#6366f1" stop-opacity="0.7" />
          <stop offset="50%" stop-color="#f59e0b" stop-opacity="0.7" />
          <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.7" />
        </linearGradient>
      </defs>
      <text x="340" y="60" text-anchor="middle" font-size="13" fill="#6366f1" font-weight="bold">Lean mass</text>
      <text x="340" y="80" text-anchor="middle" font-size="11" fill="#64748b">Muscles, bones, organs</text>
      <text x="460" y="60" text-anchor="middle" font-size="13" fill="#d97706" font-weight="bold">Fat mass</text>
      <text x="460" y="80" text-anchor="middle" font-size="11" fill="#64748b">Adipose tissue</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Body composition is split into fat mass and lean body mass (muscle, bone, organs, water)</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      Lean body mass is calculated using anthropometric formulas that estimate fat-free mass from height, weight and sex. The Boer formula (published in 1984) is one of the most widely validated and is the primary method used here. We also display the James formula result so you can compare. These formulas assume a standard body composition distribution and are calibrated for the general adult population. They work best for people within a normal to moderately overweight BMI range and are less accurate for extremely muscular individuals or those with very high body fat.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Boer formula:</strong><br>
      Men: LBM = 0.407 × weight (kg) + 0.267 × height (cm) − 19.2<br>
      Women: LBM = 0.252 × weight (kg) + 0.473 × height (cm) − 48.3
    </p>
    <p class="mt-3 text-slate-600">
      <strong>James formula (for comparison):</strong><br>
      Men: LBM = 1.10 × weight − 128 × (weight/height)²<br>
      Women: LBM = 1.07 × weight − 148 × (weight/height)²<br>
      (weight in kg, height in cm)
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 35-year-old man, 175 cm tall, weighing 78 kg, wants to know his lean body mass.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Boer formula:</span> <span class="text-slate-600">0.407 × 78 + 0.267 × 175 − 19.2</span></div>
        <div><span class="font-medium text-slate-700">Calculation:</span> <span class="text-slate-600">31.75 + 46.73 − 19.2 = <strong>59.3 kg</strong></span></div>
        <div><span class="font-medium text-slate-700">Estimated body fat:</span> <span class="text-slate-600">78 − 59.3 = <strong>18.7 kg</strong> (24% body fat)</span></div>
        <div><span class="font-medium text-slate-700">James formula:</span> <span class="text-slate-600">1.10 × 78 − 128 × (78/175)² ≈ <strong>58.5 kg</strong></span></div>
        <div><span class="font-medium text-slate-700">Range:</span> <span class="text-slate-600">Both formulas agree closely (59.3 vs 58.5 kg), giving confidence in the estimate.</span></div>
        <div><span class="font-medium text-slate-700">LBM %:</span> <span class="text-slate-600">59.3 ÷ 78 × 100 = <strong>76%</strong> of total weight is lean mass.</span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Strength athlete</h3>
      <p class="mt-1 text-sm text-slate-600">Monitor lean mass gains during a bulk to ensure you are adding quality tissue, not just fat. Compare LBM changes month to month.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎯</span>
      <h3 class="mt-2 font-semibold text-slate-900">Weight-loss seeker</h3>
      <p class="mt-1 text-sm text-slate-600">Track whether the weight you are losing is fat or muscle. If LBM drops too fast, increase protein and add resistance training to preserve it.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Older adult</h3>
      <p class="mt-1 text-sm text-slate-600">Sarcopenia (age-related muscle loss) is a major health risk. Tracking LBM helps you catch muscle loss early and take action with strength training and protein.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍⚕️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Healthcare practitioner</h3>
      <p class="mt-1 text-sm text-slate-600">Use LBM estimates to calculate medication dosages, assess nutritional status and monitor patients for muscle wasting conditions.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your stats</h3>
        <p class="mt-1 text-sm text-slate-600">Provide your sex, height and weight in either metric or imperial units. Accurate height measurement is important for the formula.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your LBM</h3>
        <p class="mt-1 text-sm text-slate-600">See your fat-free mass in kilograms (or pounds). The estimated body fat is calculated by subtracting LBM from total weight.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Track over time</h3>
        <p class="mt-1 text-sm text-slate-600">Recalculate every 2–4 weeks during a training or diet programme. A rising LBM means you are building muscle while losing fat is the ideal scenario.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for maintaining lean mass</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Eat enough protein</h3>
        <p class="mt-1 text-sm text-slate-600">Aim for at least 1.6 g of protein per kg of body weight daily when you are active. This provides the amino acids needed to repair and build lean tissue.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Lift weights</h3>
        <p class="mt-1 text-sm text-slate-600">Resistance training is the single most effective stimulus for building and preserving lean mass. Without it, any calorie deficit will include some muscle loss.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Don't cut calories too aggressively</h3>
        <p class="mt-1 text-sm text-slate-600">Large calorie deficits (more than 500–750 below maintenance) accelerate muscle loss. A moderate deficit with high protein and strength training preserves LBM during weight loss.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/body-fat/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Body Fat Calculator</a>
      <a href="/tools/bmr-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">BMR Calculator</a>
      <a href="/tools/protein-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Protein Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      let cm, kg;
      if (metric) { cm = parseFloat(el('m-h').value); kg = parseFloat(el('m-w').value); }
      else {
        const ft = parseFloat(el('i-ft').value) || 0, inch = parseFloat(el('i-in').value) || 0;
        cm = (ft * 12 + inch) * 2.54; kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      if (!cm || !kg || cm <= 0 || kg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const male = el('sex').value === 'male';
      let lbm;
      if (male) lbm = 0.407 * kg + 0.267 * cm - 19.2;
      else lbm = 0.252 * kg + 0.473 * cm - 48.3;
      lbm = Math.max(lbm, kg * 0.4);
      const fat = kg - lbm;
      const fatPct = (fat / kg * 100);
      const lbmKg = lbm.toFixed(1);
      const lbmLb = (lbm * 2.20462).toFixed(1);
      el('r-lbm').textContent = `${lbmKg} kg (${lbmLb} lb)`;
      el('r-fat').textContent = `${fat.toFixed(1)} kg (${fatPct.toFixed(1)}%)`;
      el('r-formula').textContent = 'Boer';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'm-h', 'm-w', 'i-ft', 'i-in', 'i-w'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
