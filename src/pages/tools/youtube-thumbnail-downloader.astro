---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'YouTube Thumbnail Downloader';
const description = 'Download YouTube video thumbnails in multiple resolutions from any video URL or ID. Get high-quality thumbnail images instantly, free and online.';
const intro = 'Download YouTube video thumbnails in multiple resolutions.';
const category = { id: 'creators', name: 'Creators' };
const faqs = [
  { q: 'What thumbnail resolutions are available?', a: 'Default (120x90), MQ (320x180), HQ (480x360), SD (640x480), and MaxRes (1280x720).' },
  { q: 'Does this work for all YouTube videos?', a: 'MaxRes may not be available for older videos. The other sizes are always available.' },
  { q: 'Is this allowed by YouTube?', a: 'Viewing and downloading thumbnails for personal use is generally accepted. Respect copyright.' },
  { q: 'Do I need an API key?', a: 'No — thumbnails are publicly accessible via YouTube\'s img.youtube.com CDN.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <label for="url-input" class="block text-sm font-medium text-slate-700">YouTube Video URL or ID</label>
      <div class="mt-1 flex gap-2">
        <input id="url-input" type="text" placeholder="e.g. https://youtube.com/watch?v=dQw4w9WgXcQ" class="flex-1 rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <button id="fetch-btn" class="rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700">Get Thumbnails</button>
      </div>

      <div id="results" class="mt-6 hidden">
        <div class="grid gap-4 sm:grid-cols-2" id="thumbnails-grid"></div>
      </div>
      <div id="error-msg" class="mt-3 hidden rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"></div>
    </div>

    <figure class="mt-10">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 160" width="800" height="160" role="img" aria-labelledby="yt-svg-title yt-svg-desc" class="w-full max-w-2xl mx-auto">
        <title id="yt-svg-title">YouTube thumbnail sizes progression</title>
        <desc id="yt-svg-desc">Five thumbnail sizes from small to large: default, MQ, HQ, SD, and MaxRes</desc>
        <rect x="60" y="30" width="120" height="90" rx="4" fill="#e2e8f0" stroke="#94a3b8" stroke-width="1" />
        <text x="120" y="78" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="10">120x90</text>
        <rect x="210" y="20" width="160" height="90" rx="4" fill="#e2e8f0" stroke="#94a3b8" stroke-width="1" />
        <text x="290" y="68" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="10">320x180</text>
        <rect x="400" y="10" width="240" height="135" rx="4" fill="#e2e8f0" stroke="#94a3b8" stroke-width="1" />
        <text x="520" y="80" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="10">480x360</text>
      </svg>
      <figcaption class="mt-2 text-center text-sm text-slate-500">YouTube generates thumbnails at multiple resolutions from each uploaded video</figcaption>
    </figure>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">How YouTube thumbnails work</h2>
      <p class="mt-2 text-slate-600">YouTube automatically generates thumbnails from uploaded videos by sampling frames at specific timestamps. Creators can also upload custom thumbnails. These images are hosted on YouTube's CDN at <code class="font-mono text-xs">img.youtube.com</code> and are publicly accessible via a predictable URL pattern using the video ID.</p>
      <p class="mt-3 text-slate-600">The thumbnail URL format is <code class="font-mono text-xs">https://img.youtube.com/vi/VIDEO_ID/RESOLUTION.jpg</code> where resolution can be: <code class="font-mono text-xs">default</code> (120x90), <code class="font-mono text-xs">mqdefault</code> (320x180), <code class="font-mono text-xs">hqdefault</code> (480x360), <code class="font-mono text-xs">sddefault</code> (640x480), or <code class="font-mono text-xs">maxresdefault</code> (1280x720). The <code class="font-mono text-xs">hqdefault</code> resolution is the most commonly used size and offers a good balance of quality and file size.</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">Use cases</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4"><span class="font-semibold text-slate-900">Blog posts & articles</span><p class="mt-1 text-sm text-slate-600">Use YouTube thumbnails as featured images when embedding videos in blog posts or news articles.</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4"><span class="font-semibold text-slate-900">Video promotion</span><p class="mt-1 text-sm text-slate-600">Share custom-sized thumbnails across social media platforms to promote your video content.</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4"><span class="font-semibold text-slate-900">Custom overlays</span><p class="mt-1 text-sm text-slate-600">Download thumbnails to add text overlays, arrows, or branding for more clickable custom thumbnails.</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4"><span class="font-semibold text-slate-900">Archival & backup</span><p class="mt-1 text-sm text-slate-600">Save thumbnails for portfolio archives, analytics, or reference before videos are removed or changed.</p></div>
      </div>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="text-lg font-bold text-slate-900">Tips</h2>
      <ul class="mt-3 list-inside list-disc space-y-2 text-sm text-slate-600">
        <li>The maxresdefault thumbnail may not exist for older videos — always check before relying on it.</li>
        <li>HD thumbnails (SD and MaxRes) may not be available for videos uploaded before 2009.</li>
        <li>YouTube video IDs are exactly 11 characters and contain letters, numbers, hyphens, and underscores.</li>
        <li>Respect thumbnail copyright — do not repurpose thumbnails as your own without permission.</li>
      </ul>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="text-lg font-bold text-slate-900">Related tools</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        <a href="/tools/social-media-image-size-cheat-sheet/" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Social Media Image Sizes</a>
        <a href="/tools/favicon-generator/" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Favicon Generator</a>
        <a href="/tools/color-palette-generator/" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Color Palette Generator</a>
      </div>
    </section>
  </div>
</ToolLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var urlInput = document.getElementById('url-input');
    var fetchBtn = document.getElementById('fetch-btn');
    var results = document.getElementById('results');
    var grid = document.getElementById('thumbnails-grid');
    var errorMsg = document.getElementById('error-msg');

    function extractId(url) {
      url = url.trim();
      if (/^[a-zA-Z0-9_-]{11}$/.test(url)) return url;
      var match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/v\/)([a-zA-Z0-9_-]{11})/);
      return match ? match[1] : null;
    }

    function buildThumbnail(id) {
      var resolutions = [
        { label: 'Default (120x90)', key: 'default', dim: '120x90' },
        { label: 'MQ (320x180)', key: 'mqdefault', dim: '320x180' },
        { label: 'HQ (480x360)', key: 'hqdefault', dim: '480x360' },
        { label: 'SD (640x480)', key: 'sddefault', dim: '640x480' },
        { label: 'MaxRes (1280x720)', key: 'maxresdefault', dim: '1280x720' }
      ];
      grid.innerHTML = '';
      resolutions.forEach(function(r) {
        var url = 'https://img.youtube.com/vi/' + id + '/' + r.key + '.jpg';
        var div = document.createElement('div');
        div.className = 'rounded-xl border border-slate-200 bg-slate-50 p-3';
        div.innerHTML = '<img src="' + url + '" alt="' + r.label + '" class="w-full rounded-lg" loading="lazy" onerror="this.parentElement.style.display=\'none\'" />' +
          '<div class="mt-2 flex items-center justify-between"><span class="text-xs font-medium text-slate-600">' + r.label + '</span>' +
          '<a href="' + url + '" download class="rounded-lg bg-indigo-100 px-3 py-1 text-xs font-medium text-indigo-700 hover:bg-indigo-200">Download</a></div>';
        grid.appendChild(div);
      });
      results.classList.remove('hidden');
      errorMsg.classList.add('hidden');
    }

    fetchBtn.addEventListener('click', function() {
      var id = extractId(urlInput.value);
      if (!id) {
        errorMsg.textContent = 'Could not extract a valid YouTube video ID from that input.';
        errorMsg.classList.remove('hidden');
        results.classList.add('hidden');
        return;
      }
      buildThumbnail(id);
    });

    urlInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') fetchBtn.click(); });
  });
</script>