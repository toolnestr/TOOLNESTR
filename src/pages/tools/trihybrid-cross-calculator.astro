---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Trihybrid Cross Calculator';
const description = "Trihybrid cross calculator. Build the full 8×8 AaBbCc × AaBbCc grid and the classic 27:9:9:9:3:3:3:1 phenotype ratio, with worked examples.";
const intro = 'Explore the classic trihybrid cross AaBbCc × AaBbCc — three independently assorting genes combine into 8 possible gametes per parent, producing a full 8×8 grid and the famous 27:9:9:9:3:3:3:1 phenotype ratio. Two 3D diagrams compare a single gamete\'s allele combination to the full set of 8, and charts show the genotype and phenotype breakdowns.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a trihybrid cross?', a: 'A trihybrid cross tracks inheritance of three genes at once, each with two alleles. Crossing two triple-heterozygotes (AaBbCc × AaBbCc) produces 8 possible gametes per parent and 64 total combinations in the full grid.' },
  { q: 'Why is the ratio 27:9:9:9:3:3:3:1?', a: 'This ratio comes directly from multiplying three independent 3:1 monohybrid ratios together: (3:1) × (3:1) × (3:1) expands to 27:9:9:9:3:3:3:1 across the eight possible phenotype combinations.' },
  { q: 'How many gametes does a triple heterozygote produce?', a: "A triple heterozygote (AaBbCc) produces 2³ = 8 genetically distinct gametes, since each of the three genes independently contributes one of its two alleles." },
  { q: 'Does a trihybrid cross assume anything special about the three genes?', a: "Yes — it assumes independent assortment, meaning the three genes are located on different chromosomes (or far enough apart on the same chromosome) so that inheriting one allele doesn't affect which allele is inherited for the other genes." },
  { q: 'Is a trihybrid cross ever done with real data instead of theory?', a: 'Yes — plant and animal breeders track three-trait crosses for real traits (like plant height, flower color, and seed shape) and compare the observed offspring counts to the theoretical 27:9:9:9:3:3:3:1 ratio using a chi-square test to confirm the genes assort independently.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Trihybrid Cross Calculator',
  description: 'View the full trihybrid cross grid for AaBbCc × AaBbCc and its resulting genotype and phenotype ratios.',
  steps: [
    { name: 'Review the 8 gametes', text: 'Each parent produces 8 gamete types from independent assortment of three genes.' },
    { name: 'Read the 8×8 grid', text: 'All 64 possible offspring combinations are shown, grouped by phenotype.' },
    { name: 'Check the 27:9:9:9:3:3:3:1 ratio', text: 'The classic trihybrid phenotype ratio tallies automatically from the grid.' },
  ],
};

const formulas = [
  { expr: '2³ = 8 gamete types per parent', note: 'independent assortment of three genes' },
  { expr: '(3:1) × (3:1) × (3:1) = 27:9:9:9:3:3:3:1', note: 'phenotype ratio — product of three independent monohybrid ratios' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — the classic AaBbCc × AaBbCc cross', tone: 'slate',
    given: 'Both parents are heterozygous for three independently assorting genes (seed shape, seed color, pod color).',
    rows: [
      { label: 'Gametes per parent:', value: '2³ = 8 (ABC, ABc, AbC, Abc, aBC, aBc, abC, abc)' },
      { label: 'Total grid cells:', value: '8 × 8 = 64' },
      { label: 'Phenotype ratio:', value: '27 : 9 : 9 : 9 : 3 : 3 : 3 : 1 (A_B_C_ : A_B_cc : A_bbC_ : aaB_C_ : A_bbcc : aaB_cc : aabbC_ : aabbcc)', full: true },
    ],
    note: 'This exact ratio is the three-gene extension of Mendel\'s original 3:1 monohybrid ratio — multiplying three independent 3:1 ratios together gives 27:9:9:9:3:3:3:1.',
  },
  {
    title: 'Worked example 2 — probability of the rarest genotype (aabbcc)', tone: 'amber',
    given: 'What fraction of offspring from AaBbCc × AaBbCc will be fully recessive (aabbcc) at all three genes?',
    rows: [
      { label: 'Per-gene probability:', value: 'P(aa) = 1/4, P(bb) = 1/4, P(cc) = 1/4' },
      { label: 'Combine (independent events):', value: 'P(aabbcc) = 1/4 × 1/4 × 1/4' },
      { label: 'Result:', value: 'P(aabbcc) = 1/64, matching the "1" in the 27:9:9:9:3:3:3:1 ratio', full: true },
    ],
    note: "This is exactly why the rarest phenotype combination in any trihybrid cross is always the fully-recessive one — it requires every single gene to independently land on its 1-in-4 recessive outcome.",
  },
];

const comparison = {
  heading: 'The 8 phenotype classes of a trihybrid cross',
  note: 'Out of 64 total offspring, each phenotype class has a fixed, predictable count.',
  headers: [{ label: 'Phenotype (A_ = dominant, aa = recessive, etc.)' }, { label: 'Count (of 64)' }],
  rows: [
    ['A_B_C_ (all three dominant) ★', '27'],
    ['A_B_cc / A_bbC_ / aaB_C_ (two dominant, one recessive)', '9 each'],
    ['A_bbcc / aaB_cc / aabbC_ (one dominant, two recessive)', '3 each'],
    ['aabbcc (all three recessive)', '1'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 1). Notice the ratio is symmetric: the three "two dominant" classes are all 9, and the three "one dominant" classes are all 3 — a direct consequence of the three genes being equivalent 3:1 crosses multiplied together.',
};

const realWorld = [
  { emoji: '🌾', title: 'Multi-trait crop breeding', body: 'Agricultural breeders track inheritance of multiple traits at once — like disease resistance, yield, and drought tolerance — using trihybrid (and higher) cross logic to predict how often all desired traits appear together.' },
  { emoji: '🐁', title: 'Laboratory genetics research', body: 'Model organism research (mice, fruit flies) often tracks three or more genetic markers simultaneously when studying gene interactions, relying on the same independent-assortment math as a trihybrid cross.' },
  { emoji: '🧬', title: 'Confirming independent assortment', body: 'Observing a real cross\'s offspring ratios and comparing them to the predicted 27:9:9:9:3:3:3:1 (via a chi-square test) is a standard way geneticists confirm that three genes truly assort independently rather than being linked.' },
  { emoji: '🐄', title: 'Livestock breeding decisions', body: 'Breeders predicting the likelihood of offspring inheriting a specific combination of three desirable traits (coat color, size, disease resistance) rely on exactly this multiplicative probability logic.' },
];

const misconceptions = [
  { claim: '"A trihybrid cross is just three separate monohybrid crosses run side by side."', truth: "It's mathematically equivalent to combining three independent monohybrid ratios, but the actual cross produces a single set of 64 offspring where all three genes are inherited together in the same individual — it's not three separate populations, just one population with three traits tracked at once." },
  { claim: '"More genes always means a less predictable outcome."', truth: 'The outcome remains exactly as predictable as a monohybrid cross — it just has more possible combinations. As long as the genes assort independently, the ratio is exactly as reliable as a simple 3:1 cross, just spread across more phenotype categories.' },
  { claim: '"The rarest phenotype class is always the double-recessive, not the triple-recessive."', truth: "The fully triple-recessive class (aabbcc) is always the single rarest outcome (1/64) in an unlinked trihybrid cross — rarer than any of the double-recessive classes (3/64 each), because it requires all three low-probability recessive outcomes to occur together." },
  { claim: '"This math works no matter where the three genes are located on the chromosomes."', truth: "The 27:9:9:9:3:3:3:1 ratio specifically requires independent assortment — if two of the three genes are close together on the same chromosome (genetically linked), they won't assort independently, and the observed ratio will deviate from this prediction." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 12, "Mendel\'s Experiments and Heredity" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/12-2-laws-of-inheritance" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 3, Independent Assortment.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 14, Mendel and the Gene Idea.' },
];
const sourcesNote = 'Assumes complete dominance for each gene and independent assortment (unlinked genes). Results are exact probability ratios, not guaranteed outcomes.';

const howToUse = [
  { title: 'Review the gamete list', body: 'Each triple-heterozygous parent produces 8 distinct gamete combinations.' },
  { title: 'Scan the 8×8 grid', body: 'All 64 possible offspring genotypes are laid out, color-coded by phenotype class.' },
  { title: 'Check the ratio breakdown', body: 'The 27:9:9:9:3:3:3:1 phenotype ratio is tallied automatically beneath the grid.' },
];

const related = [
  { href: '/tools/dihybrid-cross-calculator', emoji: '✖️', title: 'Dihybrid Cross Calculator', desc: 'Two-gene cross — the classic 9:3:3:1 phenotype ratio.' },
  { href: '/tools/punnett-square-calculator', emoji: '🔳', title: 'Punnett Square Calculator', desc: 'Build a monohybrid cross grid — genotype and phenotype ratios.' },
  { href: '/tools/chi-square-genetics-calculator', emoji: '📊', title: 'Chi-Square Goodness of Fit Calculator', desc: 'Test whether observed ratios match the expected genetic ratio.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="when three genes assort completely independently, their combined inheritance pattern is nothing more than three separate 3:1 ratios multiplied together — more genes means more possible combinations, not less predictability."
  howIntro="A triple heterozygote (AaBbCc) forms gametes by independently choosing one allele from each of its three genes, producing 2³ = 8 distinct gamete types with equal probability. Crossing two such individuals creates an 8×8 grid of 64 equally likely offspring combinations. Because the three genes assort independently, the overall phenotype ratio is exactly what you get by multiplying three separate 3:1 monohybrid ratios together — (3:1)×(3:1)×(3:1) expands algebraically into 27:9:9:9:3:3:3:1 across the eight possible phenotype combinations."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where trihybrid crosses actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">The classic trihybrid cross: AaBbCc × AaBbCc (three independently assorting genes)</p>
    <div class="overflow-x-auto rounded-xl border border-slate-200">
      <table id="grid" class="w-full table-fixed text-center text-[10px] sm:text-xs" style="min-width: 640px;"></table>
    </div>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Phenotype ratio</div><div id="r-pheno" class="mt-1 text-sm font-bold sm:text-lg">27:9:9:9:3:3:3:1</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Total offspring combinations</div><div id="r-total" class="mt-1 text-lg font-bold text-slate-800">64</div></div>
    </div>
    <p id="tri-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">One gamete vs. all eight gametes</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-one" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. One gamete (ABC)</h3>
          <p class="mt-1 text-sm text-slate-600">A single gamete carrying one dominant allele from each of the three genes.</p>
        </div>
        <div>
          <div id="diag-all" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. All eight gametes</h3>
          <p class="mt-1 text-sm text-slate-600">Every possible allele combination a triple-heterozygous parent can produce.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Trihybrid ratio charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Phenotype class counts (out of 64)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-counts"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Phenotype proportions</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pie"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const gametes = ['ABC', 'ABc', 'AbC', 'Abc', 'aBC', 'aBc', 'abC', 'abc'];
      const colorFor = { 27: '#6366f1', 9: '#f59e0b', 3: '#10b981', 1: '#94a3b8' };

      function combine(g1, g2) {
        let out = '';
        for (let i = 0; i < 3; i++) {
          const pair = [g1[i], g2[i]].sort((a, b) => (a === a.toUpperCase() ? -1 : 1) - (b === b.toUpperCase() ? -1 : 1));
          out += pair.join('');
        }
        return out;
      }
      function phenoClassCount(geno) {
        let dominantGenes = 0;
        for (let i = 0; i < 6; i += 2) if (geno[i] === geno[i].toUpperCase()) dominantGenes++;
        return dominantGenes === 3 ? 27 : dominantGenes === 2 ? 9 : dominantGenes === 1 ? 3 : 1;
      }
      function buildGrid() {
        let html = '<tr><td class="bg-slate-50 p-1"></td>';
        gametes.forEach((g) => (html += '<td class="bg-slate-50 p-1 font-mono font-bold text-slate-700">' + g + '</td>'));
        html += '</tr>';
        gametes.forEach((row) => {
          html += '<tr><td class="bg-slate-50 p-1 font-mono font-bold text-slate-700">' + row + '</td>';
          gametes.forEach((col) => {
            const geno = combine(row, col);
            const cls = phenoClassCount(geno);
            html += '<td class="border border-slate-100 p-1 font-mono font-semibold" style="color:' + colorFor[cls] + '">' + geno + '</td>';
          });
          html += '</tr>';
        });
        el('grid').innerHTML = html;
      }

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labels = ['A_B_C_', 'A_B_cc', 'A_bbC_', 'aaB_C_', 'A_bbcc', 'aaB_cc', 'aabbC_', 'aabbcc'];
        const data = [27, 9, 9, 9, 3, 3, 3, 1];
        const colors = ['#6366f1', '#f59e0b', '#f59e0b', '#f59e0b', '#10b981', '#10b981', '#10b981', '#94a3b8'];
        new Chart(el('chart-counts'), {
          type: 'bar',
          data: { labels, datasets: [{ label: 'Count (of 64)', data, backgroundColor: colors }] },
          options: Object.assign({}, base, { scales: { x: { ticks: { maxRotation: 60, minRotation: 60 } }, y: { title: { display: true, text: 'Count (out of 64)' } } }, plugins: { legend: { display: false } } }),
        });
        new Chart(el('chart-pie'), {
          type: 'pie',
          data: { labels: ['3 dominant (27/64)', '2 dominant (9×3=27/64)', '1 dominant (3×3=9/64)', '0 dominant (1/64)'], datasets: [{ data: [27, 27, 9, 1], backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#94a3b8'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }

      function gameteScene(container, alleleColors) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        alleleColors.forEach((c, i) => {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.35, 16, 14), new THREE.MeshStandardMaterial({ color: c }));
          sph.position.set((i - 1) * 0.9, 0, 0);
          s.scene.add(sph);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function allEightScene(container) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const positions = [
          [-2.4, 1.2], [-0.8, 1.2], [0.8, 1.2], [2.4, 1.2],
          [-2.4, -1.2], [-0.8, -1.2], [0.8, -1.2], [2.4, -1.2],
        ];
        gametes.forEach((g, gi) => {
          const group = new THREE.Group();
          for (let i = 0; i < 3; i++) {
            const dominant = g[i] === g[i].toUpperCase();
            const sph = new THREE.Mesh(new THREE.SphereGeometry(0.18, 12, 10), new THREE.MeshStandardMaterial({ color: dominant ? 0x6366f1 : 0xf59e0b }));
            sph.position.set((i - 1) * 0.42, 0, 0);
            group.add(sph);
          }
          group.position.set(positions[gi][0], positions[gi][1], 0);
          s.scene.add(group);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.002); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagOne = null, diagAll = null;
      function initDiagOne() { const c = el('diag-one'); if (!c) throw new Error('no container'); diagOne = gameteScene(c, [0x6366f1, 0x6366f1, 0x6366f1]); }
      function initDiagAll() { const c = el('diag-all'); if (!c) throw new Error('no container'); diagAll = allEightScene(c); }

      function boot() {
        try { buildGrid(); } catch (e) { console.error('[trihybrid-cross] grid build failed', e); }
        try { initCharts(); } catch (e) { console.error('[trihybrid-cross] charts failed', e); }
        if (window.THREE) {
          try { initDiagOne(); } catch (e) { console.error('[trihybrid-cross] one-gamete diagram failed', e); }
          try { initDiagAll(); } catch (e) { console.error('[trihybrid-cross] all-gametes diagram failed', e); }
        }
        mountResize([diagOne, diagAll]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
