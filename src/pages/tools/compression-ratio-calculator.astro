---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Compression Ratio Calculator';
const description =
  'Calculate engine compression ratio from cylinder volume at BDC and TDC. Includes swept volume, clearance volume, and CR.';
const intro =
  'Calculate engine compression ratio from volumes at bottom dead centre (BDC) and top dead centre (TDC).';
const category = { id: 'automotive', name: 'Automotive' };
const faqs = [
  { q: 'What is compression ratio?', a: 'Compression ratio (CR) is the ratio of cylinder volume when the piston is at bottom dead centre (BDC) to the volume at top dead centre (TDC). Higher ratios generally mean more power but require higher octane fuel.' },
  { q: 'How do I measure the volumes?', a: "Swept volume comes from bore and stroke. Clearance volume is measured by filling the combustion chamber with fluid from a burette (cc'ing the heads)." },
  { q: 'What is a good compression ratio?', a: 'Street petrol engines: 8:1 to 10:1. Performance builds: 10:1 to 12:1. Race engines: 12:1 to 15:1. Diesel: 14:1 to 22:1.' },
  { q: 'What happens if CR is too high?', a: 'Excessive compression causes detonation (knocking), which can destroy pistons and rings. Higher octane fuel resists detonation.' },
  { q: 'Can I calculate CR from displacement alone?', a: 'No. You need the clearance volume (combustion chamber + head gasket + piston top volume) in addition to the swept volume.' },
];
const sources = [
  { html: "<strong>SAE International</strong> standards (e.g. J1349 engine power, J1634 EV range). <a href=\"https://www.sae.org/standards/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">sae.org</a>" },
  { html: "<strong>U.S. DOE / EPA — fueleconomy.gov</strong>, official efficiency, MPGe and charging figures. <a href=\"https://www.fueleconomy.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">fueleconomy.gov</a>" },
  { html: "<strong>Vehicle manufacturer service specifications</strong> — always defer to the OEM figures for your specific vehicle." },
];
const sourcesNote = "General estimates. Follow your manufacturer’s published specifications and a qualified mechanic for safety-critical work.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Bore (mm)</span>
        <input id="bore" type="number" step="any" min="0" value="86"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Stroke (mm)</span>
        <input id="stroke" type="number" step="any" min="0" value="86"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Clearance volume (cc)</span>
        <input id="clearance" type="number" step="any" min="0" value="50"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Number of cylinders</span>
        <select id="cylinders"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="1">1</option><option value="2">2</option><option value="3">3</option>
          <option value="4" selected>4</option><option value="5">5</option><option value="6">6</option>
          <option value="8">8</option><option value="10">10</option><option value="12">12</option>
        </select>
      </label>
    </div>
    <div class="mt-6 grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-4 text-center">
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Swept vol (cc)</div>
        <div id="r-swept" class="mt-1 text-xl font-bold text-slate-800">—</div>
      </div>
      <div class="rounded-xl bg-indigo-50 p-4 text-center">
        <div class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Clearance vol (cc)</div>
        <div id="r-clear" class="mt-1 text-xl font-bold text-indigo-700">—</div>
      </div>
      <div class="rounded-xl bg-emerald-50 p-4 text-center">
        <div class="text-xs font-semibold uppercase tracking-wide text-emerald-600">Compression Ratio</div>
        <div id="r-cr" class="mt-1 text-3xl font-bold text-emerald-700">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="260" viewBox="0 0 800 260" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="piston-title piston-desc">
      <title id="piston-title">Piston at BDC and TDC positions</title>
      <desc id="piston-desc">Two cylinder cross-sections showing the piston at bottom dead centre (BDC) and top dead centre (TDC) with volume labels</desc>
      <rect x="60" y="30" width="160" height="200" rx="6" fill="#f8fafc" stroke="#cbd5e1" stroke-width="2" />
      <rect x="80" y="140" width="120" height="30" rx="4" fill="#64748b" />
      <text x="140" y="218" text-anchor="middle" fill="#475569" font-size="13" font-weight="bold">BDC</text>
      <text x="140" y="235" text-anchor="middle" fill="#94a3b8" font-size="11">Bottom Dead Centre</text>
      <line x1="180" y1="80" x2="210" y2="80" stroke="#6366f1" stroke-width="2" />
      <line x1="180" y1="140" x2="210" y2="140" stroke="#6366f1" stroke-width="2" />
      <line x1="210" y1="80" x2="210" y2="140" stroke="#6366f1" stroke-width="2" marker-end="url(#ar)" />
      <line x1="210" y1="140" x2="210" y2="80" stroke="#6366f1" stroke-width="2" marker-end="url(#ar)" />
      <text x="225" y="115" fill="#6366f1" font-size="11">Swept</text>
      <text x="225" y="128" fill="#6366f1" font-size="11">Volume</text>
      <text x="140" y="75" text-anchor="middle" fill="#ef4444" font-size="11">Clearance</text>
      <text x="140" y="88" text-anchor="middle" fill="#ef4444" font-size="11">Volume</text>
      <text x="310" y="140" fill="#64748b" font-size="32" font-weight="bold">→</text>
      <rect x="360" y="30" width="160" height="200" rx="6" fill="#f8fafc" stroke="#cbd5e1" stroke-width="2" />
      <rect x="380" y="140" width="120" height="30" rx="4" fill="#64748b" />
      <path d="M380 55 Q440 45 500 55" stroke="#6366f1" stroke-width="2" fill="none" />
      <text x="440" y="218" text-anchor="middle" fill="#475569" font-size="13" font-weight="bold">TDC</text>
      <text x="440" y="235" text-anchor="middle" fill="#94a3b8" font-size="11">Top Dead Centre</text>
      <rect x="380" y="40" width="120" height="25" rx="4" fill="#ef4444" opacity="0.3" />
      <text x="440" y="57" text-anchor="middle" fill="#dc2626" font-size="10">Clearance Vol</text>
      <text x="600" y="140" fill="#64748b" font-size="32" font-weight="bold">=</text>
      <rect x="650" y="40" width="120" height="180" rx="12" fill="#eef2ff" stroke="#c7d2fe" stroke-width="2" />
      <text x="710" y="90" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">CR</text>
      <text x="710" y="115" text-anchor="middle" fill="#6366f1" font-size="12">V<tspan baseline-shift="sub" font-size="0.7em">BDC</tspan></text>
      <text x="710" y="135" text-anchor="middle" fill="#64748b" font-size="12">÷</text>
      <text x="710" y="155" text-anchor="middle" fill="#6366f1" font-size="12">V<tspan baseline-shift="sub" font-size="0.7em">TDC</tspan></text>
      <text x="710" y="195" text-anchor="middle" fill="#4f46e5" font-size="24" font-weight="bold">10:1</text>
      <defs><marker id="ar" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="5" markerHeight="5" orient="auto"><path d="M0 0 L10 5 L0 10" fill="#6366f1" /></marker></defs>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">CR = (Swept Volume + Clearance Volume) ÷ Clearance Volume</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How compression ratio is calculated</h2>
    <p class="mt-2 text-slate-600">
      Compression ratio is one of the most important specifications of an internal combustion engine. It describes how much the air-fuel mixture is compressed before ignition. The ratio is calculated by dividing the total cylinder volume when the piston is at bottom dead centre (BDC) by the volume when the piston is at top dead centre (TDC). The TDC volume is known as the clearance volume.
    </p>
    <p class="mt-3 text-slate-600">
      The swept volume (the volume displaced by the piston) is calculated from bore and stroke using the same cylinder volume formula as engine displacement. The clearance volume is the sum of the combustion chamber volume in the cylinder head, the head gasket volume, the piston deck height volume, and any piston crown volume (dome adds volume, dish subtracts). This calculator takes bore, stroke, and clearance volume as inputs and computes the ratio.
    </p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-1 rounded-xl bg-white p-4 font-mono text-sm text-slate-700">
      <div><span class="font-semibold">Swept volume</span> = &pi; × (bore/2)² × stroke ÷ 1000 (cc)</div>
      <div><span class="font-semibold">CR</span> = (swept volume + clearance volume) ÷ clearance volume</div>
    </div>
    <h3 class="mt-4 font-semibold text-slate-900">Worked example</h3>
    <p class="mt-1 text-sm text-slate-600"><strong>Bore:</strong> 86 mm &middot; <strong>Stroke:</strong> 86 mm &middot; <strong>Clearance:</strong> 50 cc</p>
    <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
      <div><span class="font-medium text-slate-700">Swept vol:</span> <span class="text-slate-600">&pi; × 43² × 86 ÷ 1000 = 499.6 cc</span></div>
      <div><span class="font-medium text-slate-700">Clearance vol:</span> <span class="text-slate-600">50 cc</span></div>
      <div><span class="font-medium text-slate-700">CR:</span> <span class="text-slate-600">(499.6 + 50) ÷ 50 = 10.99:1</span></div>
      <div><span class="font-medium text-slate-700">Rounded:</span> <span class="text-slate-600">≈ 11.0:1</span></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔧</span>
      <h3 class="mt-2 font-semibold text-slate-900">Engine Building</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the compression ratio of your build before assembly. Adjust head gasket thickness, piston dome height, or cylinder head volume to target a specific CR.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏎️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Performance Tuning</h3>
      <p class="mt-1 text-sm text-slate-600">Increasing compression ratio is one of the most effective ways to gain power. Calculate the CR change when milling cylinder heads or using thinner head gaskets.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">⛽</span>
      <h3 class="mt-2 font-semibold text-slate-900">Fuel Selection</h3>
      <p class="mt-1 text-sm text-slate-600">Higher compression requires higher octane fuel. Use the calculator to determine your engine's CR and select the minimum octane rating needed to prevent detonation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔍</span>
      <h3 class="mt-2 font-semibold text-slate-900">Engine Diagnostics</h3>
      <p class="mt-1 text-sm text-slate-600">A compression test measures cylinder pressure, not ratio. But knowing your calculated CR helps interpret compression test results when diagnosing engine wear.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the compression ratio calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter bore and stroke</h3>
        <p class="mt-1 text-sm text-slate-600">The swept volume is calculated automatically from the cylinder bore diameter and piston stroke length.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter clearance volume</h3>
        <p class="mt-1 text-sm text-slate-600">This is the volume above the piston at TDC: chamber + gasket + deck height + piston crown volume.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the ratio</h3>
        <p class="mt-1 text-sm text-slate-600">The compression ratio is displayed along with swept volume and clearance volume for reference.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for compression ratio</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Measure clearance volume accurately</h3>
        <p class="mt-1 text-sm text-slate-600">The most common source of error is the clearance volume. Use a burette (cc kit) to measure the actual combustion chamber volume with the cylinder head installed and valves seated.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Include all volume components</h3>
        <p class="mt-1 text-sm text-slate-600">Clearance volume = chamber volume + gasket volume + deck height volume + piston crown volume (or − dish volume). Missing any component gives an incorrect CR.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Higher CR requires better fuel</h3>
        <p class="mt-1 text-sm text-slate-600">As a rule of thumb: CR 8–10:1 uses regular (87 octane), 10–11:1 uses mid-grade (89), 11–12:1 uses premium (91–93), above 12:1 usually needs race fuel or E85.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Dynamic vs static CR</h3>
        <p class="mt-1 text-sm text-slate-600">This calculator gives the static compression ratio. Dynamic CR depends on valve timing and is lower than static. Forced induction engines need lower static CR to avoid detonation under boost.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/engine-displacement-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">🔩</span>
        <h3 class="mt-1 font-semibold text-slate-900">Engine Displacement Calculator</h3>
        <p class="text-sm text-slate-600">Calculate cc and litres from bore and stroke.</p>
      </a>
      <a href="/tools/air-fuel-ratio-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">🔥</span>
        <h3 class="mt-1 font-semibold text-slate-900">Air-Fuel Ratio Calculator</h3>
        <p class="text-sm text-slate-600">Calculate AFR with lambda and stoichiometric reference.</p>
      </a>
      <a href="/tools/mpg-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📏</span>
        <h3 class="mt-1 font-semibold text-slate-900">MPG Calculator</h3>
        <p class="text-sm text-slate-600">Track fuel economy from odometer and fill data.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    function fmt(n) { return n.toLocaleString(undefined, { maximumFractionDigits: 1 }); }
    function fmtCr(n) { return n.toLocaleString(undefined, { maximumFractionDigits: 2 }); }
    function update() {
      const bore = parseFloat(document.getElementById('bore').value) || 0;
      const stroke = parseFloat(document.getElementById('stroke').value) || 0;
      const clear = parseFloat(document.getElementById('clearance').value) || 0;
      if (bore <= 0 || stroke <= 0 || clear <= 0) {
        ['r-swept','r-clear','r-cr'].forEach(id => document.getElementById(id).textContent = '—');
        return;
      }
      const radius = bore / 20;
      const swept = Math.PI * radius * radius * (stroke / 10);
      document.getElementById('r-swept').textContent = fmt(swept) + ' cc';
      document.getElementById('r-clear').textContent = fmt(clear) + ' cc';
      const cr = (swept + clear) / clear;
      document.getElementById('r-cr').textContent = fmtCr(cr) + ':1';
    }
    ['bore','stroke','clearance'].forEach(id => {
      document.getElementById(id).addEventListener('input', update);
      document.getElementById(id).addEventListener('change', update);
    });
    update();
  </script>
</ToolLayout>
