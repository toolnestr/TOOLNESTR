---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Dress Size Calculator';
const description = 'Find your US dress size from bust, waist, and hip measurements.';
const intro = 'Convert bust, waist, and hip measurements into a US dress size.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Which measurement matters most if my sizes don\'t match?', a: 'Most fitters recommend sizing to the largest of the three measurements (bust, waist, or hip), since it is much easier to take in a garment at the smaller areas during alteration than to let out fabric that isn\'t there at the largest area.' },
  { q: 'How do I measure bust, waist, and hip correctly?', a: 'Measure bust around the fullest part of your chest, waist around the narrowest point of your torso (usually just above the belly button), and hip around the widest part of your hips and buttocks. Keep the tape level and snug but not tight, in inches.' },
  { q: 'Why do dress sizes vary so much between brands?', a: 'There is no legally enforced sizing standard in most countries, so brands set their own charts based on their target customer and cut philosophy — a size 8 at one retailer can be a size 4 or size 12 at another, a practice sometimes called vanity sizing.' },
  { q: 'Is this the same as the Clothing Size Converter tool?', a: 'No — the Clothing Size Converter translates an already-known size between country systems, while this calculator derives a US size directly from your body measurements, which is more useful when you don\'t already know your size in any system.' },
];
const howTo = {
  name: 'How to find your dress size',
  steps: [
    { name: 'Measure bust, waist, and hip', text: 'Measure each in inches, keeping the tape level and snug.' },
    { name: 'Enter all three measurements', text: 'Type your bust, waist, and hip measurements into the calculator.' },
    { name: 'Read your recommended size', text: 'The calculator matches your measurements to the closest standard US dress size.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Bust (in)</span>
        <input id="bust" type="number" step="any" placeholder="e.g. 36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waist (in)</span>
        <input id="waist" type="number" step="any" placeholder="e.g. 29" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Hip (in)</span>
        <input id="hip" type="number" step="any" placeholder="e.g. 39" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Recommended US dress size</div>
        <div id="r-size" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Bust match</div><div id="r-bust" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Waist match</div><div id="r-waist" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Hip match</div><div id="r-hip" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dsc-title dsc-desc">
      <title id="dsc-title">Body silhouette with bust, waist, and hip lines</title>
      <desc id="dsc-desc">A simplified body outline with three horizontal dashed lines marking bust, waist, and hip measurement points</desc>
      <path d="M400 20 Q360 20 355 55 Q350 80 370 95 Q340 110 335 150 Q330 180 355 195 Q380 210 400 210 Q420 210 445 195 Q470 180 465 150 Q460 110 430 95 Q450 80 445 55 Q440 20 400 20Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <line x1="280" y1="90" x2="520" y2="90" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="560" y="95" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Bust</text>
      <line x1="290" y1="140" x2="510" y2="140" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="560" y="145" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Waist</text>
      <line x1="270" y1="190" x2="530" y2="190" stroke="#1e293b" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="560" y="195" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Hip</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Dress size is matched against standard bust, waist, and hip measurement charts</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How dress sizing works</h2>
    <p class="mt-2 text-slate-600">
      Dress size charts assign a standard bust, waist, and hip measurement to each numbered size, based on the general body-measurement progression used across the US misses sizing convention. This calculator compares each of your three measurements against that chart independently, then shows which size each one matches, since real bodies rarely line up perfectly across all three at once.
    </p>
    <p class="mt-3 text-slate-600">
      When the three matches disagree, the safer recommendation is generally the largest of the three sizes, because a garment that's slightly loose at the waist or bust can be taken in by a tailor, while a garment too small at any point often can't be let out enough to fit comfortably, especially in wovens with no stretch.
    </p>
    <p class="mt-3 text-xs text-slate-400">Bust/waist/hip progression follows the general US misses body-measurement convention referenced in ASTM D5585; brand-specific charts vary and should be checked when available.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A shopper measures 36 in bust, 29 in waist, 39 in hip.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Bust 36:</span> <span class="text-slate-600">matches size 8</span></div>
        <div><span class="font-medium text-slate-700">Waist 29:</span> <span class="text-slate-600">matches size 8</span></div>
        <div><span class="font-medium text-slate-700">Hip 39:</span> <span class="text-slate-600">matches size 8</span></div>
        <div><span class="font-medium text-slate-700">Recommended size:</span> <span class="text-slate-600"><strong>US 8</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Special-occasion dress shopping — bridesmaid dresses, formalwear, wedding gowns — is where a measurement-based size calculation matters most, since these garments are frequently ordered from a chart months in advance rather than tried on, and being between sizes on a structured formal gown is a common, stressful, and expensive fitting problem.
    </p>
    <p class="mt-3 text-slate-600">
      Online-only retailers without a full size run in every local store rely on shoppers self-measuring accurately, and a mismatch between self-reported "usual size" and actual current measurements (after weight or body changes) is one of the most common causes of returns in online apparel.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"My dress size should match my everyday pants size." <strong class="text-slate-900">Not reliably.</strong> Dresses are sized off bust/waist/hip together, while pants sizing focuses on waist and hip alone, so the two numbers frequently differ even for the same body.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"If my measurements land between two sizes, I should always size down to look smaller." <strong class="text-slate-900">This backfires.</strong> A too-small size strains seams and fits poorly in photos and in person; sizing up and having a tailor take it in gives a far better result.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
      <a href="/tools/body-shape-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Body Shape Calculator</a>
      <a href="/tools/bra-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Bra Size Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    // [size, bust, waist, hip]
    const table = [
      [0, 32.5, 25, 35.5], [2, 33.5, 26, 36.5], [4, 34.5, 27, 37.5], [6, 35.5, 28, 38.5],
      [8, 36.5, 29, 39.5], [10, 37.5, 30.5, 40.5], [12, 39, 32, 42], [14, 40.5, 33.5, 43.5],
      [16, 42, 35, 45], [18, 44, 37, 47], [20, 46, 39, 49],
    ];

    function nearestSize(value, colIdx) {
      let best = table[0];
      let bestDiff = Math.abs(value - table[0][colIdx]);
      table.forEach((row) => {
        const diff = Math.abs(value - row[colIdx]);
        if (diff < bestDiff) { best = row; bestDiff = diff; }
      });
      return best[0];
    }

    function update() {
      const bust = parseFloat(el('bust').value);
      const waist = parseFloat(el('waist').value);
      const hip = parseFloat(el('hip').value);
      if (!bust || !waist || !hip || bust <= 0 || waist <= 0 || hip <= 0) { el('results').classList.add('hidden'); return; }
      const bustSize = nearestSize(bust, 1);
      const waistSize = nearestSize(waist, 2);
      const hipSize = nearestSize(hip, 3);
      const recommended = Math.max(bustSize, waistSize, hipSize);
      el('r-bust').textContent = 'Size ' + bustSize;
      el('r-waist').textContent = 'Size ' + waistSize;
      el('r-hip').textContent = 'Size ' + hipSize;
      el('r-size').textContent = 'US ' + recommended;
      el('results').classList.remove('hidden');
    }

    ['bust', 'waist', 'hip'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
