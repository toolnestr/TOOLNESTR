---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Cubic Yardage Calculator';
const description = 'Convert length, width, and depth measurements to cubic yards for any material.';
const intro = 'Convert any volume measurement to cubic yards for ordering concrete, gravel, soil, and more.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'What is a cubic yard?', a: 'A cubic yard is a volume measurement equal to 3 feet x 3 feet x 3 feet, or 27 cubic feet. It is the standard unit for ordering bulk materials like concrete, gravel, topsoil, and mulch.' },
  { q: 'How many cubic feet are in a cubic yard?', a: 'There are 27 cubic feet in one cubic yard (3 x 3 x 3). To convert cubic feet to cubic yards, divide by 27. To convert cubic yards to cubic feet, multiply by 27.' },
  { q: 'How much does a cubic yard of topsoil weigh?', a: 'A cubic yard of dry topsoil weighs approximately 2,000-2,200 lbs (1-1.1 tons). Wet topsoil can weigh up to 3,000 lbs per cubic yard.' },
  { q: 'What size is a cubic yard visually?', a: 'A cubic yard is roughly the size of a washing machine or a small pickup truck bed. A standard wheelbarrow holds about 3-6 cubic feet, so one cubic yard fills 5-9 wheelbarrow loads.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="length" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="width" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Depth (in)</span>
        <input id="depth" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Material density (lbs/cu ft)</span>
        <input id="density" type="number" step="any" placeholder="100" value="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Volume in cubic yards</div>
        <div id="r-cy" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-ton" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic feet</div><div id="r-cf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic meters</div><div id="r-cm" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Weight (tons)</div><div id="r-tons" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="cy-title cy-desc">
      <title id="cy-title">Cubic yard 3D box diagram</title>
      <desc id="cy-desc">A 3D box showing length, width, and height dimensions with the formula for cubic yards</desc>
      <polygon points="200,180 500,180 550,120 250,120" fill="#e0e7ff" stroke="#6366f1" stroke-width="2" />
      <polygon points="200,180 500,180 500,260 200,260" fill="#c7d2fe" stroke="#6366f1" stroke-width="2" />
      <polygon points="200,260 500,260 550,200 250,200" fill="#a5b4fc" stroke="#6366f1" stroke-width="2" />
      <polygon points="500,180 550,120 550,200 500,260" fill="#e0e7ff" stroke="#6366f1" stroke-width="2" />
      <polygon points="250,120 500,180 500,260 250,200" fill="#c7d2fe" stroke="#6366f1" stroke-width="2" />
      <polygon points="250,120 550,120 550,200 250,200" fill="#a5b4fc" stroke="#6366f1" stroke-width="2" />
      <line x1="200" y1="140" x2="200" y2="180" stroke="#94a3b8" stroke-width="1.5" />
      <line x1="190" y1="140" x2="210" y2="140" stroke="#94a3b8" stroke-width="1.5" />
      <line x1="190" y1="180" x2="210" y2="180" stroke="#94a3b8" stroke-width="1.5" />
      <text x="180" y="165" text-anchor="end" font-size="12" fill="#475569" font-family="system-ui,sans-serif">1 yd</text>
      <line x1="500" y1="180" x2="550" y2="120" stroke="#94a3b8" stroke-width="1.5" />
      <line x1="500" y1="175" x2="545" y2="115" stroke="#94a3b8" stroke-width="1" />
      <line x1="505" y1="185" x2="550" y2="125" stroke="#94a3b8" stroke-width="1" />
      <text x="555" y="145" font-size="12" fill="#475569" font-family="system-ui,sans-serif">1 yd</text>
      <line x1="500" y1="180" x2="500" y2="260" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="3 3" />
      <line x1="495" y1="180" x2="495" y2="260" stroke="#94a3b8" stroke-width="1" />
      <line x1="505" y1="180" x2="505" y2="260" stroke="#94a3b8" stroke-width="1" />
      <text x="510" y="225" font-size="12" fill="#475569" font-family="system-ui,sans-serif">1 yd</text>
      <text x="370" y="150" text-anchor="middle" font-size="16" fill="#4338ca" font-family="system-ui,sans-serif" font-weight="bold">1 cubic yard</text>
      <text x="370" y="168" text-anchor="middle" font-size="12" fill="#6366f1" font-family="system-ui,sans-serif">= 27 cubic feet</text>
      <rect x="50" y="20" width="180" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="65" y="42" font-size="12" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Conversions</text>
      <text x="65" y="60" font-size="11" fill="#475569" font-family="system-ui,sans-serif">1 cu yd = 27 cu ft</text>
      <text x="65" y="78" font-size="11" fill="#475569" font-family="system-ui,sans-serif">1 cu yd = 0.765 cu m</text>
      <text x="65" y="96" font-size="11" fill="#475569" font-family="system-ui,sans-serif">1 cu ft = 7.48 gal</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A cubic yard is a 3D cube measuring 3 feet on each side, containing 27 cubic feet</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the cubic yardage calculator works</h2>
    <p class="mt-2 text-slate-600">
      The cubic yardage calculator converts any rectangular volume from length, width, and depth into cubic yards. It first calculates the volume in cubic feet, then divides by 27 to get cubic yards. You can also enter a material density to estimate the weight in tons.
    </p>
    <p class="mt-3 text-slate-600">
      Cubic yards are the standard unit for ordering bulk construction materials. Whether you are ordering concrete for a foundation, gravel for a driveway, topsoil for a garden, or mulch for flower beds, suppliers quote by the cubic yard. This calculator works for any material and any project size.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the area</h3>
        <p class="mt-1 text-sm text-slate-600">Measure length and width in feet, depth in inches. Use consistent units for accuracy.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Add density (optional)</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the material density to estimate weight. Leave at 100 for a generic volume-only calculation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Get your order size</h3>
        <p class="mt-1 text-sm text-slate-600">Read cubic yards, cubic feet, cubic meters, and estimated tons for your supplier.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Cubic feet</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">CF = L &times; W &times; (D/12)</span>. For a 10&prime; &times; 10&prime; area at 12 inches deep: 10 &times; 10 &times; (12/12) = <strong>100 cu ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Cubic yards</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">CY = CF / 27</span>. 100 / 27 = <strong>3.70 cu yd</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Weight</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Tons = (CF &times; density) / 2000</span>. At 100 lbs/cu ft: (100 &times; 100) / 2000 = <strong>5 tons</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 20&prime; &times; 15&prime; garden area needs 6 inches of topsoil. Topsoil density is about 90 lbs/cu ft.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Cubic feet:</span> <span class="text-slate-600">20 &times; 15 &times; (6/12) = 150 cu ft</span></div>
        <div><span class="font-medium text-slate-700">Cubic yards:</span> <span class="text-slate-600">150 / 27 = 5.56 cu yd</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">(150 &times; 90) / 2000 = <strong>6.75 tons</strong></span></div>
        <div><span class="font-medium text-slate-700">Order:</span> <span class="text-slate-600"><strong>6 cu yd</strong> (or 7 with compaction extra)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the cubic yardage calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Concrete ordering</h3>
        <p class="mt-1 text-sm text-slate-600">Ready-mix concrete is ordered by the cubic yard. Calculate your slab, footing, or wall volume and call the supplier with the exact yardage. Add 10% for waste and spillage.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌿</span>
        <h3 class="mt-2 font-semibold text-slate-900">Soil and compost</h3>
        <p class="mt-1 text-sm text-slate-600">Raised garden beds, landscaping, and yard leveling all need bulk soil measured in cubic yards. Calculate the bed volume or fill area and order from a local landscape supply company.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚧</span>
        <h3 class="mt-2 font-semibold text-slate-900">Gravel and aggregate</h3>
        <p class="mt-1 text-sm text-slate-600">Driveways, paths, and base layers use gravel sold by the cubic yard. The calculator handles any depth — from a 2-inch path to a 12-inch base course for heavy traffic areas.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🗑️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Dumpster sizing</h3>
        <p class="mt-1 text-sm text-slate-600">Construction dumpsters are measured in cubic yards. Estimate the volume of debris from a renovation project to select the right dumpster size and avoid overage fees.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for cubic yard measurements</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always convert depth to feet first</h3>
        <p class="mt-1 text-sm text-slate-600">The most common mistake is entering depth in inches without converting. Since cubic yards use feet, divide the inch depth by 12 before multiplying. This calculator does the conversion automatically, but it helps to understand the relationship.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Compactible materials need extra</h3>
        <p class="mt-1 text-sm text-slate-600">Soil, gravel, and sand compact by 10-20% when tamped or rolled. If you need 5 cubic yards of compacted fill, order 5.5-6 cubic yards of loose material. The compaction factor varies by material — contact your supplier for their specific recommendation.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Check supplier minimums and delivery fees</h3>
        <p class="mt-1 text-sm text-slate-600">Most bulk material suppliers have a minimum delivery of 2-5 cubic yards. Small orders under the minimum incur a short-load fee. Compare the cost per cubic yard plus delivery against bagged material from home centers for small projects.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/concrete-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Calculator</a>
      <a href="/tools/gravel-sand-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gravel & Sand Calculator</a>
      <a href="/tools/mulch-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Mulch Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      const D = parseFloat(el('depth').value);
      const dens = parseFloat(el('density').value);
      if (!L || !W || !D || L <= 0 || W <= 0 || D <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const cf = L * W * (D / 12);
      const cy = cf / 27;
      const cm = cf * 0.0283;
      const tons = dens > 0 ? (cf * dens) / 2000 : 0;
      el('r-cy').textContent = cy.toFixed(2) + ' cu yd';
      el('r-ton').textContent = tons > 0 ? '(' + tons.toFixed(2) + ' tons)' : '(no density)';
      el('r-cf').textContent = cf.toFixed(1) + ' cu ft';
      el('r-cm').textContent = cm.toFixed(2) + ' cu m';
      el('r-tons').textContent = tons > 0 ? tons.toFixed(2) + ' tons' : '—';
      el('results').classList.remove('hidden');
    }

    ['length', 'width', 'depth', 'density'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
  </script>
</ToolLayout>
