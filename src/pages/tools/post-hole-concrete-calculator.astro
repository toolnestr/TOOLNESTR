---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Post Hole Concrete Calculator';
const description = 'Find how many bags of concrete you need to set a fence or deck post, from the hole diameter, depth and post size — accounting for the volume the post displaces.';
const intro = 'Find how many bags of concrete you need to set a post, from the hole size and post size.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much concrete do I need per fence post?', a: 'Find the hole volume (π × radius² × depth for a round hole), subtract the volume the post itself displaces, then convert the remaining volume to bags. A 10-inch diameter, 2-foot-deep hole with a 4×4 post needs about 0.65 cubic feet of concrete, roughly one 50 lb bag.' },
  { q: 'Do I need to subtract the post from the hole volume?', a: 'Yes. The post occupies real space inside the hole, so ignoring it overestimates the concrete needed. For a square post, subtract width × depth of post in the hole; for a round post, subtract π × radius² × that depth.' },
  { q: 'How deep should a post hole be?', a: 'A common rule is one-third to one-half of the post\'s above-ground height, and always below your local frost line for a post that must resist frost heave. Deck and fence post depths are set by local code — verify with your building department.' },
  { q: 'What size hole should I dig for a 4×4 post?', a: 'A widely used rule is a hole diameter three times the post width, so a 4×4 post (actually 3.5×3.5 in) typically gets a 10 to 12-inch diameter hole, giving enough room for concrete to fully surround the post.' },
];
const howTo = {
  name: 'How to calculate concrete for setting a post',
  steps: [
    { name: 'Size the hole', text: 'Diameter and depth, below the frost line.' },
    { name: 'Enter the post', text: 'Its width, so its volume is subtracted.' },
    { name: 'Buy the bags', text: 'Rounded up per post, times the post count.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Hole diameter (in)</span>
        <input id="holedia" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Hole depth (ft)</span>
        <input id="depth" type="number" step="any" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Post width (in)</span>
        <input id="postw" type="number" step="any" placeholder="3.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of posts</span>
        <input id="count" type="number" step="1" placeholder="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Concrete bags to buy</div>
        <div id="r-bags" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Hole volume</div><div id="r-holevol" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Post displaces</div><div id="r-postvol" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Concrete needed</div><div id="r-netvol" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ph-title ph-desc">
      <title id="ph-title">Post hole cross-section showing displaced concrete</title>
      <desc id="ph-desc">A fence post set in a round hole, with concrete filling the space around it</desc>
      <ellipse cx="160" cy="70" rx="60" ry="16" fill="#e2e8f0" stroke="#64748b" stroke-width="1.5" />
      <rect x="100" y="70" width="120" height="120" fill="#e2e8f0" stroke="#64748b" stroke-width="1.5" />
      <rect x="140" y="55" width="40" height="150" fill="#a16207" stroke="#78350f" stroke-width="1.5" />
      <text x="160" y="205" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">concrete fills the gap around the post</text>
      <rect x="420" y="55" width="330" height="120" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Net concrete volume</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">hole volume &minus; post volume</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">= concrete needed</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The post takes up real space, so it must be subtracted from the hole volume.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the post hole concrete calculator works</h2>
    <p class="mt-2 text-slate-600">
      Setting a post starts with the volume of the hole itself: for a round, auger-dug hole, that's π times the radius squared times the depth. But the post sitting in that hole takes up real space too, and skipping that subtraction overestimates how much concrete you actually need. For a square post, subtract width times width times the depth it occupies; the calculator does that automatically once you enter the post's width.
    </p>
    <p class="mt-3 text-slate-600">
      A widely used rule of thumb sizes the hole diameter at roughly three times the post's width — a 4×4 post, whose actual dimension is 3.5×3.5 inches, typically gets a 10 to 12-inch hole, leaving enough space for concrete to fully surround and lock the post in place. Hole depth generally runs one-third to one-half of the post's above-ground height, and must reach below the local frost line wherever frost heave could push a shallow post out of the ground over winter.
    </p>
    <p class="mt-3 text-slate-600">
      Once the net concrete volume is known, converting it to bags is straightforward: a standard 50-pound bag of fast-setting post concrete yields about 0.375 cubic feet once mixed, so dividing the net volume by that figure and rounding up gives a safe bag count. Always check your local code for the required hole depth and diameter for fence, deck, and structural posts in your area — frost depth and post-hole requirements vary significantly by region.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Size the hole</h3>
        <p class="mt-1 text-sm text-slate-600">Diameter and depth, below the frost line.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the post</h3>
        <p class="mt-1 text-sm text-slate-600">Its width, so its volume is subtracted.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Buy the bags</h3>
        <p class="mt-1 text-sm text-slate-600">Rounded up per post, times the post count.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Hole volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= &pi; &times; (dia&frasl;24)&sup2; &times; depth</span>. A 10 in hole, 2 ft deep: π × 0.417² × 2 = <strong>1.09 ft³</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Post volume (subtract)</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= (width&frasl;12)&sup2; &times; depth</span>. A 3.5 in post, 2 ft deep: 0.292² × 2 = <strong>0.17 ft³</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Net concrete &amp; bags</p>
        <p class="mt-1 text-slate-600">
          1.09 − 0.17 = <strong>0.92 ft³</strong> ÷ 0.375 ft³/bag ≈ <strong>3 bags</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Six fence posts, 10 in holes, 2.5 ft deep, 3.5 in posts.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Hole vol (each):</span> <span class="text-slate-600">π × 0.417² × 2.5 = 1.36 ft³</span></div>
        <div><span class="font-medium text-slate-700">Post vol (each):</span> <span class="text-slate-600">0.292² × 2.5 = 0.21 ft³</span></div>
        <div><span class="font-medium text-slate-700">Net (each):</span> <span class="text-slate-600">1.15 ft³ → 4 bags</span></div>
        <div><span class="font-medium text-slate-700">Six posts:</span> <span class="text-slate-600"><strong>24 bags total</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Where post-set concrete is used</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚧</span>
        <h3 class="mt-2 font-semibold text-slate-900">Fence posts</h3>
        <p class="mt-1 text-sm text-slate-600">The most common use — setting posts for privacy, picket, or split-rail fencing along a property line or yard boundary.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏡</span>
        <h3 class="mt-2 font-semibold text-slate-900">Deck and pergola posts</h3>
        <p class="mt-1 text-sm text-slate-600">Structural posts supporting a deck or pergola generally need a deeper hole and a wider post, following local code for footing depth.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📬</span>
        <h3 class="mt-2 font-semibold text-slate-900">Mailbox and sign posts</h3>
        <p class="mt-1 text-sm text-slate-600">Small single-post jobs that rarely need more than a bag or two, though breakaway mailbox post rules apply near roadways in some areas.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🐎</span>
        <h3 class="mt-2 font-semibold text-slate-900">Round pen and corral posts</h3>
        <p class="mt-1 text-sm text-slate-600">Larger agricultural posts set in a ring or straight run, where the same per-post math scales up across many identical holes.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A single mailbox post is the smallest common case: an 8-inch hole, 2 ft deep, around a standard 3.5-inch (4×4) post nets 0.70 − 0.17 = 0.53 cubic feet — just 2 bags of 50 lb fast-setting mix, small enough to mix by hand in a bucket with no equipment beyond a shovel and a post level.
    </p>
    <p class="mt-3 text-slate-600">
      A structural deck post footing shows a bigger, deeper case: a 12-inch hole, 3.5 ft deep (to clear a colder-climate frost line), around a 5.5-inch (6×6) post nets about 2.01 cubic feet — 6 bags per post, which adds up fast across a deck with 6 or 8 footings and is often the point where a homeowner starts comparing bagged mix against a bulk delivery of pre-mixed concrete.
    </p>
    <p class="mt-3 text-slate-600">
      A full fence run multiplies a single-post calculation across many posts: 12 fence posts at 10-inch holes, 2 ft deep, 3.5-inch posts each need 3 bags, for 36 bags total — a case where a small per-post rounding error (say, forgetting to subtract the post volume) compounds into a meaningfully wrong total order across the whole run.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"The post takes up so little space in the hole that it's not worth subtracting." <strong class="text-slate-900">It adds up more than it looks.</strong> For a typical 4×4 post in a 10-inch hole, the post itself displaces around 15% of the hole's volume — skip that subtraction across a dozen posts and you'll overbuy a meaningful number of bags.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Deeper is always safer for a fence or deck post." <strong class="text-slate-900">Depth should match the frost line, not exceed it arbitrarily.</strong> The point of digging below frost depth is to reach soil that doesn't freeze and heave — digging much deeper than that adds cost and labor without adding meaningful holding power, since the post's resistance to movement comes mostly from the surrounding soil and concrete collar, not sheer depth.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fence-post-spacing-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fence Post Spacing Calculator</a>
      <a href="/tools/fence-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fence Calculator</a>
      <a href="/tools/deck-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Deck Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const dia = parseFloat(el('holedia').value);
      const depth = parseFloat(el('depth').value);
      const postW = parseFloat(el('postw').value);
      let count = parseFloat(el('count').value); if (!(count > 0)) count = 1;
      if (!(dia > 0 && depth > 0 && postW >= 0)) { el('results').classList.add('hidden'); return; }
      const holeVol = Math.PI * Math.pow(dia / 24, 2) * depth;
      const postVol = Math.pow(postW / 12, 2) * depth;
      const netVol = Math.max(holeVol - postVol, 0);
      const bagsPerPost = Math.ceil(netVol / 0.375);
      const totalBags = bagsPerPost * count;

      el('r-bags').textContent = totalBags + ' bags (50 lb)';
      el('r-note').textContent = count + ' post' + (count > 1 ? 's' : '') + ', ' + bagsPerPost + ' bags each';
      el('r-holevol').textContent = holeVol.toFixed(2) + ' ft³';
      el('r-postvol').textContent = postVol.toFixed(2) + ' ft³';
      el('r-netvol').textContent = netVol.toFixed(2) + ' ft³';
      el('results').classList.remove('hidden');
    }

    ['holedia', 'depth', 'postw', 'count'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
