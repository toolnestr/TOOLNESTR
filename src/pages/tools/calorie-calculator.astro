---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Calorie Calculator';
const description =
  'Free calorie calculator. Estimate the daily calories you need to maintain, lose, or gain weight based on your age, activity level, and goals.';
const intro =
  'Enter your details and activity level to estimate your daily calorie needs for maintaining, losing or gaining weight.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How are my calorie needs calculated?', a: 'We calculate your BMR with the Mifflin-St Jeor equation, then multiply by an activity factor to estimate your maintenance calories. Losing or gaining uses a 500-calorie daily change (about 0.45 kg / 1 lb per week).' },
  { q: 'How many calories should I cut to lose weight?', a: 'A common target is 500 calories below maintenance for roughly 0.45 kg (1 lb) of loss per week. Avoid going too low \u2014 it\u2019s often unsustainable and unhealthy.' },
  { q: 'Are these numbers exact?', a: 'They\u2019re solid estimates. Real needs vary with genetics, muscle mass and other factors, so adjust based on real-world results.' },
  { q: 'What happens if I eat too few calories?', a: 'Dropping below about 1,200 calories per day for women or 1,500 for men can slow your metabolism, cause muscle loss and lead to nutrient deficiencies. A moderate deficit is safer and more sustainable.' },
  { q: 'Do men and women need different calories?', a: 'Yes \u2014 men generally have more muscle mass and a higher BMR, so they need more calories at the same activity level. This calculator accounts for sex in the BMR equation.' },
  { q: 'Should I eat back the calories I burn through exercise?', a: 'Only if your goal is weight maintenance. If you\u2019re trying to lose weight, your activity level setting already accounts for exercise \u2014 eating back extra calories may cancel the deficit.' },
  { q: 'How do macronutrients affect my calorie needs?', a: 'Your calorie target is about quantity, but macronutrient balance (protein, carbs, fat) affects body composition. Higher protein supports muscle retention during weight loss, while fats and carbs fuel energy needs.' },
  { q: 'Should I eat the same calories every day?', a: 'Consistency helps, but daily variation of 100\u2013200 calories is normal and fine. What matters most is the weekly average, not hitting the exact number every single day.' },
  { q: 'How does sleep affect calorie needs?', a: 'Poor sleep can lower your BMR and increase appetite hormones, making weight management harder. Prioritising 7\u20138 hours of quality sleep supports your calorie goals.' },
  { q: 'Do I need more calories when I\u2019m sick or injured?', a: 'Yes \u2014 your body burns extra energy healing itself. Eating at or slightly above maintenance during illness or recovery helps support your immune system and tissue repair.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
        <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Age</span>
        <input id="age" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="metric" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-3" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Activity level</span>
      <select id="activity" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="1.2">Sedentary (little or no exercise)</option>
        <option value="1.375">Lightly active (1–3 days/week)</option>
        <option value="1.55" selected>Moderately active (3–5 days/week)</option>
        <option value="1.725">Very active (6–7 days/week)</option>
        <option value="1.9">Extra active (hard daily exercise/physical job)</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Maintain weight</div>
        <div id="r-maintain" class="mt-1 text-3xl font-bold">—</div>
        <div class="text-sm opacity-80">calories/day</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Lose weight</div><div id="r-lose" class="mt-1 text-xl font-bold text-emerald-600">—</div><div class="text-xs text-slate-400">−0.45 kg/week</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Gain weight</div><div id="r-gain" class="mt-1 text-xl font-bold text-indigo-600">—</div><div class="text-xs text-slate-400">+0.45 kg/week</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Fill in your details to see your daily calories.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this calorie calculator</h2>
    <p class="mt-2 text-slate-600">
      Knowing roughly <a href="https://www.niddk.nih.gov/health-information/weight-management" rel="noopener">how many calories you need</a> each day is the starting point for any nutrition
      or weight goal. This calculator estimates your maintenance calories from your body details
      and activity level, then shows targets for losing or gaining weight at a steady, sustainable
      pace. Use it alongside our <a href="/tools/bmr-calculator/" class="font-medium text-indigo-600 hover:underline">BMR Calculator</a> and <a href="/tools/bmi-calculator/" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical or dietary advice. Consult a professional before major diet changes.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="cal-title cal-desc">
      <title id="cal-title">Calorie balance zones</title>
      <desc id="cal-desc">Horizontal bar divided into three colour-coded sections showing calorie deficit, maintenance, and surplus zones relative to total daily energy expenditure.</desc>
      <rect x="60" y="80" width="680" height="40" rx="6" fill="#e2e8f0" />
      <rect x="60" y="80" width="200" height="40" rx="6" fill="#ef4444" />
      <rect x="260" y="80" width="280" height="40" fill="#22c55e" />
      <rect x="540" y="80" width="200" height="40" rx="6" fill="#6366f1" />
      <text x="160" y="68" text-anchor="middle" font-size="13" fill="#dc2626" font-weight="bold">Deficit</text>
      <text x="160" y="145" text-anchor="middle" font-size="11" fill="#64748b">Below TDEE</text>
      <text x="400" y="68" text-anchor="middle" font-size="13" fill="#16a34a" font-weight="bold">Maintenance</text>
      <text x="400" y="145" text-anchor="middle" font-size="11" fill="#64748b">TDEE level</text>
      <text x="640" y="68" text-anchor="middle" font-size="13" fill="#6366f1" font-weight="bold">Surplus</text>
      <text x="640" y="145" text-anchor="middle" font-size="11" fill="#64748b">Above TDEE</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Calorie balance zones: deficit, maintenance, and surplus relative to total daily energy expenditure</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the Calorie Calculator whenever you’re starting a new nutrition plan or adjusting an existing one. It’s especially helpful before beginning a weight-loss or muscle-gain phase, so you know your target intake from day one. Athletes use it to fuel training sessions, and anyone transitioning to a more (or less) active lifestyle can reset their daily targets to match their new routine.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Be honest about your activity level — overestimating it leads to calorie targets that are too high for weight loss.</li>
      <li>Track your actual intake for a week with a food diary and compare it to the calculator’s target; adjust by 100–200 calories if your weight isn’t moving as expected.</li>
      <li>Re-calculate every 5–10 kg (10–20 lb) of weight change, since your BMR shifts as your body weight changes.</li>
    </ul>
  </section>

  <!-- Calorie ranges bar chart -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different calorie ranges mean</h2>
    <p class="mt-2 text-slate-600">Your total daily energy needs depend on how active you are. The bars below show approximate daily calorie ranges for a moderately active 30-year-old at different activity levels.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Sedentary</span><span class="text-slate-400">Little or no exercise</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Lightly active</span><span class="text-slate-400">1–3 days/week</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:60%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Moderately active</span><span class="text-slate-400">3–5 days/week</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:70%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Very active</span><span class="text-slate-400">6–7 days/week</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:80%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Extra active</span><span class="text-slate-400">Hard daily / physical job</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:90%"></div></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">⚖️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Weight-loss planner</h3>
      <p class="mt-1 text-sm text-slate-600">Set a safe, sustainable calorie deficit based on your real maintenance needs instead of guessing or following generic diet templates.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Muscle builder</h3>
      <p class="mt-1 text-sm text-slate-600">Know exactly how many calories above maintenance you need to fuel muscle growth without gaining excessive fat during a bulk.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚴</span>
      <h3 class="mt-2 font-semibold text-slate-900">Endurance athlete</h3>
      <p class="mt-1 text-sm text-slate-600">Match your high daily calorie burn with adequate fuel to maintain performance, recover properly and avoid energy deficiency.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍👩‍👧</span>
      <h3 class="mt-2 font-semibold text-slate-900">Health-focused parent</h3>
      <p class="mt-1 text-sm text-slate-600">Understand your family's broad energy needs to plan balanced meals, manage portions and model healthy eating habits at home.</p>
    </div>
  </section>

  <!-- Calorie needs reference table -->
  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Activity level</th><th class="p-3">Male (70 kg, 30 yrs)</th><th class="p-3">Female (60 kg, 30 yrs)</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Sedentary</td><td class="p-3">~2,100 cal/day</td><td class="p-3">~1,700 cal/day</td></tr>
        <tr><td class="p-3 font-medium">Lightly active</td><td class="p-3">~2,400 cal/day</td><td class="p-3">~1,950 cal/day</td></tr>
        <tr><td class="p-3 font-medium">Moderately active</td><td class="p-3">~2,700 cal/day</td><td class="p-3">~2,200 cal/day</td></tr>
        <tr><td class="p-3 font-medium">Very active</td><td class="p-3">~3,000 cal/day</td><td class="p-3">~2,450 cal/day</td></tr>
        <tr><td class="p-3 font-medium">Extra active</td><td class="p-3">~3,300 cal/day</td><td class="p-3">~2,700 cal/day</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How calorie needs are calculated</h2>
    <p class="mt-2 text-slate-600">
      Your daily calorie needs are estimated in two steps. First, your <strong>Basal Metabolic Rate (BMR)</strong> is calculated using the <a href="https://pubmed.ncbi.nlm.nih.gov/2305711/" rel="noopener">Mifflin-St Jeor equation</a>. Second, your BMR is multiplied by an <strong>activity factor</strong> (1.2–1.9) that reflects your typical exercise level to give your <strong>Total Daily Energy Expenditure (TDEE)</strong>.
    </p>
    <p class="mt-3 text-slate-600">
      <strong>TDEE</strong> = BMR × activity multiplier<br>
      For weight loss: TDEE − 500 calories (≈0.45 kg / week)<br>
      For weight gain: TDEE + 500 calories (≈0.45 kg / week)
    </p>
    <p class="mt-3 text-slate-600">
      The 500-calorie adjustment is based on the well-established rule that roughly 3,500 calories equals 0.45 kg (1 lb) of body fat. Individual results vary with metabolism, adherence and body composition changes.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 28-year-old man who is 180 cm tall, weighs 82 kg, and exercises 4 days per week (moderately active) wants to know his calorie targets.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">BMR (Mifflin-St Jeor):</span> <span class="text-slate-600">10 × 82 + 6.25 × 180 − 5 × 28 + 5 = <strong>1,790 cal/day</strong></span></div>
        <div><span class="font-medium text-slate-700">Activity multiplier:</span> <span class="text-slate-600">1.55 (moderately active)</span></div>
        <div><span class="font-medium text-slate-700">TDEE (maintenance):</span> <span class="text-slate-600">1,790 × 1.55 ≈ <strong>2,775 cal/day</strong></span></div>
        <div><span class="font-medium text-slate-700">Weight loss target:</span> <span class="text-slate-600">2,775 − 500 = <strong>2,275 cal/day</strong></span></div>
        <div><span class="font-medium text-slate-700">Weight gain target:</span> <span class="text-slate-600">2,775 + 500 = <strong>3,275 cal/day</strong></span></div>
        <div><span class="font-medium text-slate-700">Estimated change:</span> <span class="text-slate-600">∼0.45 kg (1 lb) per week of loss or gain, depending on which target he follows.</span></div>
      </div>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Calorie Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your body details</h3>
        <p class="mt-1 text-sm text-slate-600">Provide your age, sex, height and weight in either metric or imperial units. These are used to calculate your BMR as the baseline.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select your activity level</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the option that best matches your typical weekly exercise routine. Be honest — overestimating leads to targets that are too high.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your calorie targets</h3>
        <p class="mt-1 text-sm text-slate-600">See your maintenance, weight loss and weight gain targets. Use the loss or gain figure as your daily guide for steady progress.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate calorie tracking</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Track your actual intake</h3>
        <p class="mt-1 text-sm text-slate-600">Use a food diary or app for a week. Compare your real intake to the calculator's target and adjust by 100–200 calories if your weight isn't moving as expected.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Recalculate after weight changes</h3>
        <p class="mt-1 text-sm text-slate-600">Every 5–10 kg (10–20 lb) of weight change shifts your BMR and therefore your maintenance calories. Re-run the calculator to keep your targets accurate.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Don't cut too aggressively</h3>
        <p class="mt-1 text-sm text-slate-600">Dropping too far below maintenance (more than 500–750 calories) can trigger metabolic slowdown, muscle loss and nutrient deficiencies. Slow and steady wins the race.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const age = parseFloat(el('age').value);
      let cm, kg;
      if (metric) { cm = parseFloat(el('m-h').value); kg = parseFloat(el('m-w').value); }
      else {
        const ft = parseFloat(el('i-ft').value) || 0, inch = parseFloat(el('i-in').value) || 0;
        cm = (ft * 12 + inch) * 2.54; kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      if (!age || !cm || !kg || age <= 0 || cm <= 0 || kg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const bmr = 10 * kg + 6.25 * cm - 5 * age + (el('sex').value === 'male' ? 5 : -161);
      const maintain = bmr * parseFloat(el('activity').value);
      el('r-maintain').textContent = Math.round(maintain).toLocaleString();
      el('r-lose').textContent = Math.round(maintain - 500).toLocaleString();
      el('r-gain').textContent = Math.round(maintain + 500).toLocaleString();
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'age', 'm-h', 'm-w', 'i-ft', 'i-in', 'i-w', 'activity'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
