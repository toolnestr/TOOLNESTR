---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'EV Charging Cost Calculator';
const description =
  'Free EV charging cost calculator. Compare the cost to charge your EV at home vs public AC vs ' +
  'DC fast charging in any currency.';
const intro =
  'Enter your battery size, efficiency, electricity rate and charging method to calculate cost ' +
  'per charge, per mile and per month.';
const category = { id: 'automotive', name: 'Automotive' };
const faqs = [
  { q: 'How much does it cost to charge an EV at home?', a: 'At the US average of $0.14/kWh, charging a 75 kWh battery from empty to full costs about $10.50. Costs vary by region — Hawaii can be $0.33/kWh while Texas averages $0.12/kWh. Time-of-use plans can lower overnight rates to $0.08–0.10/kWh.' },
  { q: 'Is DC fast charging more expensive than home charging?', a: 'Yes. DC fast charging typically costs 2–4 times more than home charging. Rates range from $0.25–0.60/kWh depending on the network and location. Some networks charge by the minute instead of by kWh. Electrify America charges about $0.48/kWh for non-members.' },
  { q: 'How much does a full charge cost compared to a tank of gas?', a: 'A full charge for a typical EV costs $10–18 at home, while filling a gas car with 15 gallons at $3.50/gal costs $52.50. Even at DC fast charging rates ($25–35 for a full charge), the EV is significantly cheaper per mile than gasoline.' },
  { q: 'What is the cost per mile to drive an EV?', a: 'An EV achieving 3.5 mi/kWh at $0.14/kWh costs about $0.04/mile to charge at home. At $0.48/kWh (DC fast), the cost rises to about $0.14/mile. A gas car at 30 MPG and $3.50/gal costs about $0.12/mile.' },
  { q: 'Does charging efficiency affect cost?', a: 'Yes. AC charging has losses of 10–15% from the wall to the battery due to heat from the onboard charger. DC fast charging has lower conversion losses (5–8%). If you pay for 100 kWh at the meter, you may only store 85–90 kWh in the battery.' },
  { q: 'What are time-of-use electricity plans?', a: 'Time-of-use (TOU) plans charge different rates depending on the time of day. Overnight rates (when EV charging typically happens) are often 30–50% cheaper than peak daytime rates. Many utilities offer special EV-specific TOU plans with rates as low as $0.06–0.08/kWh overnight.' },
  { q: 'How does public AC charging pricing work?', a: 'Public Level 2 chargers typically charge by kWh ($0.15–0.30/kWh) or by time ($1–3/hour). Some are free at shopping centers or workplaces. Many networks require a membership card or app, and some charge connection fees in addition to per-kWh rates.' },
  { q: 'Can solar panels eliminate charging costs?', a: 'If you have rooftop solar, you can charge your EV for essentially the cost of the solar installation (about $0.03–0.08/kWh amortized over panel life). Excess solar production during the day can offset EV charging at night through net metering.' },
  { q: 'What is the monthly cost to charge an EV?', a: 'Driving 1,200 miles per month at 3.5 mi/kWh and $0.14/kWh costs about $48/month at home. The same miles at DC fast charging rates would be about $168/month. Compare to a gas car at 30 MPG: $140/month at $3.50/gal.' },
  { q: 'Do subscription plans from charging networks save money?', a: 'Networks like Electrify America, EVgo, and ChargePoint offer monthly subscription plans ($4–13/month) that reduce per-kWh rates by 10–25%. They are worth it if you DC fast charge more than 2–3 times per month.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Battery (kWh)</span>
        <input id="bat" type="number" step="0.1" placeholder="75" value="75" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Efficiency (mi/kWh)</span>
        <input id="eff" type="number" step="0.1" placeholder="3.5" value="3.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Home rate ($/kWh)</span>
        <input id="hrate" type="number" step="0.001" placeholder="0.14" value="0.14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Public AC rate ($/kWh)</span>
        <input id="prate" type="number" step="0.001" placeholder="0.25" value="0.25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">DC fast rate ($/kWh)</span>
        <input id="drate" type="number" step="0.001" placeholder="0.48" value="0.48" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Monthly miles</span>
        <input id="miles" type="number" step="1" placeholder="1200" value="1200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Home cost/charge</div><div id="r-home-c" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Public AC/charge</div><div id="r-pub-c" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">DC fast/charge</div><div id="r-dc-c" class="mt-1 text-xl font-bold text-amber-600">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Home $/mi</div><div id="r-pm" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Monthly home cost</div><div id="r-month" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Monthly public AC</div><div id="r-month-pub" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Monthly DC fast</div><div id="r-month-dc" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Cost per mile by charging method</h2>
    <p class="mt-2 text-slate-600">The bars below compare the typical cost per mile for different charging methods vs a gas car, based on average US rates.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Home charging ($0.14/kWh)</span><span class="text-slate-400">~$0.04/mi</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:28%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Public AC ($0.25/kWh)</span><span class="text-slate-400">~$0.07/mi</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">DC fast ($0.48/kWh)</span><span class="text-slate-400">~$0.14/mi</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:92%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Gas car (30 MPG, $3.50/gal)</span><span class="text-slate-400">~$0.12/mi</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:78%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💰</span>
      <h3 class="mt-2 font-semibold text-slate-900">Budget-Conscious Owner</h3>
      <p class="mt-1 text-sm text-slate-600">Track your charging costs across home, work, and public chargers so you can optimize your charging habits and minimize your monthly spend.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Fleet Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Model the operating cost per mile for your EV fleet across different charging strategies to determine the most economical approach for your routes.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Business Owner</h3>
      <p class="mt-1 text-sm text-slate-600">Evaluate whether installing workplace chargers for employees or customers makes financial sense compared to the cost of DC fast charging alternatives.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏠</span>
      <h3 class="mt-2 font-semibold text-slate-900">Renter</h3>
      <p class="mt-1 text-sm text-slate-600">Compare the cost of charging at public Level 2 and DC fast chargers vs what you would pay at home so you can budget accordingly without home charging access.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Region</th><th class="p-3">Avg home rate ($/kWh)</th><th class="p-3">Public AC ($/kWh)</th><th class="p-3">DC fast ($/kWh)</th><th class="p-3">Gas ($/gal)</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">United States (avg)</td><td class="p-3">$0.14</td><td class="p-3">$0.25</td><td class="p-3">$0.48</td><td class="p-3">$3.50</td></tr>
        <tr><td class="p-3 font-medium">United Kingdom</td><td class="p-3">$0.33 (26p)</td><td class="p-3">$0.50 (40p)</td><td class="p-3">$0.88 (70p)</td><td class="p-3">$6.50</td></tr>
        <tr><td class="p-3 font-medium">European Union</td><td class="p-3">$0.25 (€0.23)</td><td class="p-3">$0.45 (€0.41)</td><td class="p-3">$0.72 (€0.65)</td><td class="p-3">$6.80</td></tr>
        <tr><td class="p-3 font-medium">Australia</td><td class="p-3">$0.18 (A$0.27)</td><td class="p-3">$0.30 (A$0.45)</td><td class="p-3">$0.56 (A$0.85)</td><td class="p-3">$4.30</td></tr>
        <tr><td class="p-3 font-medium">India</td><td class="p-3">$0.08 (₹6.5)</td><td class="p-3">$0.14 (₹12)</td><td class="p-3">$0.20 (₹17)</td><td class="p-3">$5.00</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the EV Charging Cost Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter battery + rates</h3>
        <p class="mt-1 text-sm text-slate-600">Input your battery size, vehicle efficiency, and the electricity rates for home, public AC, and DC fast charging in your area.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Compare methods</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator instantly shows the cost per full charge and cost per mile for each method, along with projected monthly costs.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">See savings</h3>
        <p class="mt-1 text-sm text-slate-600">Compare the cost difference between home and public charging to decide if installing a home charger is worth the investment.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for minimizing charging costs</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Charge at home overnight</h3>
        <p class="mt-1 text-sm text-slate-600">Home charging is typically 50–80% cheaper than DC fast charging. Installing a Level 2 charger at home is the single biggest money-saving move for EV owners.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use time-of-use plans</h3>
        <p class="mt-1 text-sm text-slate-600">Many utilities offer EV-specific rate plans with low overnight rates ($0.06–0.10/kWh). Set your car to start charging at midnight to take full advantage.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Pair with solar</h3>
        <p class="mt-1 text-sm text-slate-600">If you have solar panels, charging during peak solar production hours can drive effective costs down to $0.03–0.05/kWh. Some utilities offer net metering that offsets charging costs entirely.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Home vs public vs DC pricing</h2>
    <p class="mt-2 text-slate-600">
      Home charging is always the cheapest option at $0.08–0.33/kWh depending on your location and
      rate plan. Public Level 2 charging typically costs $0.15–0.30/kWh — about double home rates.
      DC fast charging is the most expensive at $0.30–0.60/kWh, often 3–4 times the home rate. For
      maximum savings, do 90%+ of your charging at home or work.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Time-of-use rates explained</h2>
    <p class="mt-2 text-slate-600">
      Time-of-use (TOU) electricity plans charge different rates based on grid demand. Off-peak
      hours (typically 11 PM to 7 AM) have the lowest rates because demand is minimal. Many
      utilities offer EV-specific TOU plans with overnight rates as low as $0.06–0.08/kWh —
      roughly half the standard residential rate. Even without a special EV plan, most standard
      TOU plans reduce charging costs by 30–50% compared to flat rates.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Charging efficiency losses</h2>
    <p class="mt-2 text-slate-600">
      When you pay for electricity at the meter, not all of it reaches your battery. AC charging
      (Level 1 and 2) has 10–15% losses due to the onboard charger converting AC to DC. DC fast
      charging has lower losses at 5–8% since conversion happens in the station. This means if you
      pay for 100 kWh at a DC fast charger, you store about 93–95 kWh in the battery, while Level 2
      charging stores about 85–90 kWh for the same 100 kWh purchased.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (n) => '$' + n.toFixed(2);
    function update() {
      const bat = parseFloat(el('bat').value);
      const eff = parseFloat(el('eff').value);
      const hr = parseFloat(el('hrate').value);
      const pr = parseFloat(el('prate').value);
      const dr = parseFloat(el('drate').value);
      const miles = parseFloat(el('miles').value);
      if (isNaN(bat) || isNaN(eff) || isNaN(hr) || isNaN(pr) || isNaN(dr) || isNaN(miles) || bat <= 0 || eff <= 0) {
        ['r-home-c','r-pub-c','r-dc-c','r-pm','r-month','r-month-pub','r-month-dc'].forEach(id => el(id).textContent = '—'); return;
      }
      const fullChargeKwh = bat;
      const homeFull = fullChargeKwh * hr;
      const pubFull = fullChargeKwh * pr;
      const dcFull = fullChargeKwh * dr;
      const kwhPerMi = 1 / eff;
      const homePm = kwhPerMi * hr;
      const pubPm = kwhPerMi * pr;
      const dcPm = kwhPerMi * dr;
      const monthHome = miles * homePm;
      const monthPub = miles * pubPm;
      const monthDc = miles * dcPm;
      el('r-home-c').textContent = fmt(homeFull);
      el('r-pub-c').textContent = fmt(pubFull);
      el('r-dc-c').textContent = fmt(dcFull);
      el('r-pm').textContent = fmt(homePm);
      el('r-month').textContent = fmt(monthHome);
      el('r-month-pub').textContent = fmt(monthPub);
      el('r-month-dc').textContent = fmt(monthDc);
    }
    document.querySelectorAll('input').forEach(e => e.addEventListener('input', update));
  </script>
</ToolLayout>
