---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Mark-Recapture Population Estimator';
const description = 'Mark-recapture population estimator with a live 3D wildlife sampling diagram and charts. Solve the Lincoln-Petersen index N = (M×C)/R for total population size, plus the small-sample Chapman correction, with worked examples.';
const intro = 'Solve the Lincoln-Petersen index N = (M×C)/R to estimate a wildlife population\'s total size from a mark-release-recapture study, plus the Chapman correction for small sample sizes. Two 3D diagrams compare a low-recapture-rate study (suggesting a large population) to a high-recapture-rate study (suggesting a small population), and charts show how the recapture count drives the population estimate.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is mark-recapture?', a: 'Mark-recapture is a method for estimating a wildlife population\'s size: capture and mark a sample of individuals, release them, then take a second sample later and count how many are marked (recaptured) — the proportion marked in the second sample estimates the proportion marked in the whole population.' },
  { q: 'What is the Lincoln-Petersen index?', a: 'The Lincoln-Petersen index estimates total population size as N = (M×C)/R, where M is the number marked in the first sample, C is the total captured in the second sample, and R is the number of marked (recaptured) individuals found in that second sample.' },
  { q: 'Why does a low recapture rate suggest a large population?', a: 'If very few of the second sample turn out to be marked individuals, that implies the marked animals make up only a small fraction of a much larger overall population — the recapture rate directly reflects what proportion of the total population was originally marked.' },
  { q: 'What is the Chapman correction, and when is it needed?', a: "The Chapman correction, N = ((M+1)(C+1)/(R+1)) − 1, adjusts for a known bias in the basic Lincoln-Petersen formula that becomes significant when the recapture count (R) is small — it's recommended whenever R is less than about 10." },
  { q: 'What assumptions does mark-recapture rely on?', a: 'It assumes the population is closed (no births, deaths, immigration, or emigration between samples), marked individuals mix randomly back into the population, marking doesn\'t affect survival or recapture likelihood, and every individual has an equal chance of being captured.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Mark-Recapture Population Estimator',
  description: 'Solve the Lincoln-Petersen index (and Chapman correction) for total population size from a mark-recapture study.',
  steps: [
    { name: 'Enter the number marked (M)', text: 'How many individuals were captured, marked, and released in the first sample.' },
    { name: 'Enter the second sample size and recaptures', text: 'Total captured in the second sample (C), and how many were already marked (R).' },
    { name: 'Read the population estimate', text: 'Both the simple Lincoln-Petersen estimate and the small-sample Chapman correction are shown.' },
  ],
};

const formulas = [
  { expr: 'N = (M × C) / R', note: 'Lincoln-Petersen index — M=marked and released, C=second sample size, R=recaptured (marked) in second sample' },
  { expr: 'N ≈ ((M+1)(C+1)/(R+1)) − 1', note: "Chapman's correction — reduces bias when R is small" },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a standard mark-recapture study', tone: 'slate',
    given: '50 fish are captured, marked, and released. A second sample later catches 60 fish, of which 12 are marked.',
    rows: [
      { label: 'Formula:', value: 'N = (M × C) / R' },
      { label: 'Substitute:', value: 'N = (50 × 60) / 12' },
      { label: 'Result:', value: 'N ≈ 250 total fish estimated in the population', full: true },
    ],
    note: 'A recapture rate of 12/60 = 20% in the second sample implies the originally marked 50 fish represent about 20% of the total population.',
  },
  {
    title: 'Worked example 2 — a small sample needing the Chapman correction', tone: 'amber',
    given: '10 individuals are marked and released. A second sample of 12 individuals includes 3 marked ones (a small recapture count).',
    rows: [
      { label: 'Simple Lincoln-Petersen:', value: 'N = (10 × 12) / 3 = 40' },
      { label: 'Chapman correction:', value: 'N = ((11 × 13) / 4) − 1 = 35.75 − 1 ≈ 34.75' },
      { label: 'Interpretation:', value: 'The correction pulls the estimate down from 40 to about 35, correcting for the small-sample bias', full: true },
    ],
    note: 'The Chapman correction matters most when R (the recapture count) is small — with a recapture count of only 3, the simple formula noticeably overestimates the true population.',
  },
];

const comparison = {
  heading: 'How recapture rate drives the population estimate',
  note: 'Fixed M=50 marked, C=60 second sample — only R (recaptures) changes.',
  headers: [{ label: 'Recaptures (R)' }, { label: 'Recapture rate' }, { label: 'Population estimate' }],
  rows: [
    ['6', '10%', '500'],
    ['12 ★', '20%', '250'],
    ['24', '40%', '125'],
    ['48', '80%', '62.5'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). A higher recapture rate always implies a smaller total population — the marked individuals are turning up more often because they make up a larger share of a smaller pool.',
};

const realWorld = [
  { emoji: '🐟', title: 'Fisheries population assessment', body: 'Fisheries biologists use mark-recapture studies to estimate fish stock sizes, directly informing sustainable catch limits and conservation quotas.' },
  { emoji: '🦋', title: 'Insect and butterfly population monitoring', body: "Conservationists studying at-risk butterfly or insect populations use mark-recapture (often with small paint marks or tags) to track population trends over time." },
  { emoji: '🐻', title: 'Large mammal conservation', body: "Wildlife biologists studying bears, big cats, or other elusive mammals often use camera-trap 'recapture' (identifying individuals from photos) as a non-invasive form of the same mark-recapture logic." },
  { emoji: '🦟', title: 'Disease vector and pest population studies', body: 'Public health researchers estimate mosquito or other disease-vector population sizes using mark-recapture to model disease transmission risk and evaluate control program effectiveness.' },
];

const misconceptions = [
  { claim: '"Mark-recapture gives an exact population count, not an estimate."', truth: "It produces a statistical estimate based on proportions, not an exact count — the true population size could reasonably differ from the calculated N, especially with small sample sizes, which is exactly why confidence intervals are typically reported alongside the point estimate in real studies." },
  { claim: '"The method works equally well no matter how small the recapture count is."', truth: 'The basic Lincoln-Petersen formula becomes measurably biased when the recapture count (R) is small — this is precisely why the Chapman correction exists, and it\'s recommended whenever R falls below about 10.' },
  { claim: '"Mark-recapture assumes the population never changes between samples."', truth: 'The classic Lincoln-Petersen method does assume a "closed" population (no significant births, deaths, immigration, or emigration between the two sampling events) — more advanced multi-sample mark-recapture models exist specifically to handle populations that change over time.' },
  { claim: '"Marking animals has no effect on the study\'s accuracy as long as you count carefully."', truth: "The method assumes marking doesn't change an animal's survival or likelihood of being recaptured — if marked individuals become more visible to predators, or become mark-shy or mark-prone during recapture, the estimate can be systematically biased regardless of how carefully the counting itself is done." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 45, "Population and Community Ecology" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/45-1-population-demography" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Chapman (1951)</strong> — original small-sample bias correction paper, <em>University of California Publications in Statistics</em>.' },
  { html: '<strong>Krebs, <em>Ecological Methodology</em></strong> — Population estimation techniques chapter.' },
];
const sourcesNote = 'N = (M×C)/R (Lincoln-Petersen); N ≈ ((M+1)(C+1)/(R+1))−1 (Chapman correction). Assumes a closed population with equal capture probability. Results are rounded for display.';

const howToUse = [
  { title: 'Enter marked count (M)', body: 'Individuals captured, marked, and released in the first sample.' },
  { title: 'Enter second sample and recaptures', body: 'Total second-sample size (C) and how many were already marked (R).' },
  { title: 'Compare both estimates', body: 'The simple Lincoln-Petersen result and the Chapman-corrected result display side by side.' },
];

const related = [
  { href: '/tools/population-density-calculator', emoji: '🌍', title: 'Population Density Calculator', desc: 'D = N/A — individuals per unit area.' },
  { href: '/tools/exponential-population-growth-calculator', emoji: '📈', title: 'Exponential Population Growth Calculator', desc: 'N(t) = N₀e^(rt) — unconstrained population growth.' },
  { href: '/tools/shannon-diversity-index-calculator', emoji: '🦋', title: 'Shannon Diversity Index Calculator', desc: "H' = −Σ(pᵢ ln pᵢ) — measure community biodiversity." },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="if a known number of marked individuals are released back into a population, the fraction of marked animals that turn up again in a later sample reveals what fraction of the entire population those marked individuals actually represent — and that fraction is all you need to scale up to a total population estimate."
  howIntro="Mark-recapture works by assuming marked individuals mix back into the population randomly, so a second sample's proportion of marked-to-total individuals should mirror the whole population's proportion of marked-to-total individuals. Setting those two proportions equal (R/C = M/N) and solving for N gives the Lincoln-Petersen index, N = MC/R. Because this simple formula is known to overestimate population size when the recapture count is small, the Chapman correction adjusts each term slightly to remove that small-sample bias, giving a more reliable estimate whenever few marked individuals turn up in the second sample."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where mark-recapture actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Marked & released (M)</span>
        <input id="m" type="number" step="any" value="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Second sample size (C)</span>
        <input id="c" type="number" step="any" value="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Recaptured (marked) in 2nd sample (R)</span>
        <input id="r" type="number" step="any" value="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Lincoln-Petersen estimate</div><div id="r-lp" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Chapman-corrected estimate</div><div id="r-chapman" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="mr-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Low vs. high recapture rate</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-low" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low recapture rate</h3>
          <p class="mt-1 text-sm text-slate-600">Few marked individuals turn up — implying a large total population.</p>
        </div>
        <div>
          <div id="diag-high" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High recapture rate</h3>
          <p class="mt-1 text-sm text-slate-600">Many marked individuals turn up — implying a small total population.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Mark-recapture charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Population estimate vs. recaptures (M=50, C=60)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-recap"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Lincoln-Petersen vs. Chapman (small samples)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-correction"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('mr-err').textContent = '';
        el('r-lp').textContent = '—'; el('r-chapman').textContent = '—';
        const m = parseFloat(el('m').value), c = parseFloat(el('c').value), r = parseFloat(el('r').value);
        if (isNaN(m) || isNaN(c) || isNaN(r)) return;
        if (m <= 0 || c <= 0 || r <= 0) { el('mr-err').textContent = 'All values must be positive.'; return; }
        if (r > c) { el('mr-err').textContent = 'Recaptured count cannot exceed second sample size.'; return; }
        const lp = (m * c) / r;
        const chapman = ((m + 1) * (c + 1)) / (r + 1) - 1;
        el('r-lp').textContent = fmt(lp);
        el('r-chapman').textContent = fmt(chapman);
      }
      ['m', 'c', 'r'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const rLabels = [], nData = [];
        for (let r = 3; r <= 30; r += 3) { rLabels.push(r); nData.push(+((50 * 60) / r).toFixed(1)); }
        new Chart(el('chart-recap'), {
          type: 'line',
          data: { labels: rLabels, datasets: [{ label: 'Population estimate', data: nData, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 3 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Recaptures (R)' } }, y: { title: { display: true, text: 'Population estimate' } } }, plugins: { legend: { display: false } } }),
        });
        const smallR = [1, 2, 3, 5, 8];
        const lpData = smallR.map((r) => +((10 * 12) / r).toFixed(1));
        const chapData = smallR.map((r) => +(((11 * 13) / (r + 1) - 1)).toFixed(1));
        new Chart(el('chart-correction'), {
          type: 'bar',
          data: {
            labels: smallR,
            datasets: [
              { label: 'Lincoln-Petersen', data: lpData, backgroundColor: '#f59e0b' },
              { label: 'Chapman-corrected', data: chapData, backgroundColor: '#6366f1' },
            ],
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Recaptures (R), M=10 C=12' } }, y: { title: { display: true, text: 'Population estimate' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }

      function recaptureScene(container, unmarkedCount, markedCount) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < unmarkedCount; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.16, 10, 8), new THREE.MeshStandardMaterial({ color: 0x94a3b8 }));
          m.position.set((Math.random() - 0.5) * 4.5, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 2.5);
          s.scene.add(m);
        }
        for (let i = 0; i < markedCount; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.2, 10, 8), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
          m.position.set((Math.random() - 0.5) * 4.5, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 2.5);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() { const c = el('diag-low'); if (!c) throw new Error('no container'); diagLow = recaptureScene(c, 35, 2); }
      function initDiagHigh() { const c = el('diag-high'); if (!c) throw new Error('no container'); diagHigh = recaptureScene(c, 5, 8); }

      function boot() {
        try { update(); } catch (e) { console.error('[mark-recapture] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[mark-recapture] charts failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[mark-recapture] low diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[mark-recapture] high diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
