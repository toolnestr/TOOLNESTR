---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Keyboard Tester';
const description =
  'Free online keyboard tester — press any key to see it light up instantly. Detect stuck, broken or unregistered keys. Full QWERTY layout with key code display. No download needed.';

// Keyboard layout definition — each key: { code, label, w (flex-grow unit) }
const ROWS = [
  // Function row
  [
    { code: 'Escape',    label: 'Esc',   w: 1.2 },
    { code: 'F1',  label: 'F1',  w: 1 }, { code: 'F2',  label: 'F2',  w: 1 },
    { code: 'F3',  label: 'F3',  w: 1 }, { code: 'F4',  label: 'F4',  w: 1 },
    { code: 'F5',  label: 'F5',  w: 1 }, { code: 'F6',  label: 'F6',  w: 1 },
    { code: 'F7',  label: 'F7',  w: 1 }, { code: 'F8',  label: 'F8',  w: 1 },
    { code: 'F9',  label: 'F9',  w: 1 }, { code: 'F10', label: 'F10', w: 1 },
    { code: 'F11', label: 'F11', w: 1 }, { code: 'F12', label: 'F12', w: 1 },
  ],
  // Number row
  [
    { code: 'Backquote',    label: '` ~',      w: 1 },
    { code: 'Digit1',       label: '1 !',      w: 1 },
    { code: 'Digit2',       label: '2 @',      w: 1 },
    { code: 'Digit3',       label: '3 #',      w: 1 },
    { code: 'Digit4',       label: '4 $',      w: 1 },
    { code: 'Digit5',       label: '5 %',      w: 1 },
    { code: 'Digit6',       label: '6 ^',      w: 1 },
    { code: 'Digit7',       label: '7 &',      w: 1 },
    { code: 'Digit8',       label: '8 *',      w: 1 },
    { code: 'Digit9',       label: '9 (',      w: 1 },
    { code: 'Digit0',       label: '0 )',      w: 1 },
    { code: 'Minus',        label: '- _',      w: 1 },
    { code: 'Equal',        label: '= +',      w: 1 },
    { code: 'Backspace',    label: '⌫ Back',   w: 2 },
  ],
  // QWERTY row
  [
    { code: 'Tab',          label: 'Tab',      w: 1.5 },
    { code: 'KeyQ', label: 'Q', w: 1 }, { code: 'KeyW', label: 'W', w: 1 },
    { code: 'KeyE', label: 'E', w: 1 }, { code: 'KeyR', label: 'R', w: 1 },
    { code: 'KeyT', label: 'T', w: 1 }, { code: 'KeyY', label: 'Y', w: 1 },
    { code: 'KeyU', label: 'U', w: 1 }, { code: 'KeyI', label: 'I', w: 1 },
    { code: 'KeyO', label: 'O', w: 1 }, { code: 'KeyP', label: 'P', w: 1 },
    { code: 'BracketLeft',  label: '[ {',      w: 1 },
    { code: 'BracketRight', label: '] }',      w: 1 },
    { code: 'Backslash',    label: '\\ |',     w: 1.5 },
  ],
  // Home row
  [
    { code: 'CapsLock',     label: 'Caps',     w: 1.8 },
    { code: 'KeyA', label: 'A', w: 1 }, { code: 'KeyS', label: 'S', w: 1 },
    { code: 'KeyD', label: 'D', w: 1 }, { code: 'KeyF', label: 'F', w: 1 },
    { code: 'KeyG', label: 'G', w: 1 }, { code: 'KeyH', label: 'H', w: 1 },
    { code: 'KeyJ', label: 'J', w: 1 }, { code: 'KeyK', label: 'K', w: 1 },
    { code: 'KeyL', label: 'L', w: 1 },
    { code: 'Semicolon',    label: '; :',      w: 1 },
    { code: 'Quote',        label: "\' \"",    w: 1 },
    { code: 'Enter',        label: 'Enter ↵',  w: 2.2 },
  ],
  // Shift row
  [
    { code: 'ShiftLeft',    label: 'Shift',    w: 2.3 },
    { code: 'KeyZ', label: 'Z', w: 1 }, { code: 'KeyX', label: 'X', w: 1 },
    { code: 'KeyC', label: 'C', w: 1 }, { code: 'KeyV', label: 'V', w: 1 },
    { code: 'KeyB', label: 'B', w: 1 }, { code: 'KeyN', label: 'N', w: 1 },
    { code: 'KeyM', label: 'M', w: 1 },
    { code: 'Comma',        label: ', <',      w: 1 },
    { code: 'Period',       label: '. >',      w: 1 },
    { code: 'Slash',        label: '/ ?',      w: 1 },
    { code: 'ShiftRight',   label: 'Shift',    w: 2.7 },
  ],
  // Bottom row
  [
    { code: 'ControlLeft',  label: 'Ctrl',     w: 1.5 },
    { code: 'MetaLeft',     label: '⊞ Win',    w: 1.3 },
    { code: 'AltLeft',      label: 'Alt',      w: 1.3 },
    { code: 'Space',        label: 'Space',    w: 6 },
    { code: 'AltRight',     label: 'Alt',      w: 1.3 },
    { code: 'MetaRight',    label: '⊞ Win',    w: 1.3 },
    { code: 'ContextMenu',  label: '☰ Menu',   w: 1.3 },
    { code: 'ControlRight', label: 'Ctrl',     w: 1.5 },
  ],
];

// Arrow cluster
const ARROWS = [
  [{ code: 'ArrowUp',    label: '↑', w: 1 }],
  [{ code: 'ArrowLeft',  label: '←', w: 1 }, { code: 'ArrowDown', label: '↓', w: 1 }, { code: 'ArrowRight', label: '→', w: 1 }],
];

// Nav cluster
const NAV = [
  [{ code: 'Insert', label: 'Ins', w: 1 }, { code: 'Home', label: 'Home', w: 1 }, { code: 'PageUp', label: 'PgUp', w: 1 }],
  [{ code: 'Delete', label: 'Del', w: 1 }, { code: 'End',  label: 'End',  w: 1 }, { code: 'PageDown', label: 'PgDn', w: 1 }],
];

// Total testable key count
const ALL_CODES = [...ROWS.flat(), ...ARROWS.flat(), ...NAV.flat()].map(k => k.code);
const TOTAL = ALL_CODES.length;

const faqs = [
  { q: 'How do I use the keyboard tester?', a: 'Simply press any key on your physical keyboard. The corresponding key on the on-screen layout will instantly highlight in green. Modifier keys like Shift, Ctrl, and Alt are fully supported. Use the Reset button to clear all highlights and start fresh.' },
  { q: 'What can this tool detect?', a: 'It detects non-registering keys (keys that produce no response when pressed), stuck keys (keys that appear lit even after release — indicating a hardware issue), and key code mismatches (when a key triggers an unexpected code, common on non-standard layouts).' },
  { q: 'Why are some keys not showing up?', a: 'Some system-reserved keys like the Windows key, Alt+F4, or browser shortcuts (Ctrl+T, Ctrl+W) are intercepted by the OS or browser before reaching the web page. These cannot be tested in a browser-based tool. Full key detection requires a native application.' },
  { q: 'Does this work on Mac keyboards?', a: 'Yes. Mac keyboards use the same key codes for most keys. The ⌘ Command key maps to MetaLeft/MetaRight, and Option maps to AltLeft/AltRight. Some Mac-specific keys like Fn may not fire detectable events in the browser.' },
  { q: 'Can I test a gaming keyboard with macros?', a: 'Yes, standard key presses from gaming keyboards are detected normally. Macro keys assigned to custom functions outside the standard key code set may not appear on the layout, but their key codes will still be shown in the info panel when pressed.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Keyboard Tester',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  browserRequirements: 'Requires JavaScript and a physical keyboard',
  description: 'Free online keyboard tester — detect stuck, broken or unregistered keys in real time.',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to test your keyboard',
  description: 'Check every key on your keyboard for stuck, broken or unregistered keys.',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Open the tester', text: 'Open the Keyboard Tester — the on-screen keyboard is ready immediately.' },
    { '@type': 'HowToStep', position: 2, name: 'Press keys', text: 'Press any key; the matching key lights up on screen when it is detected.' },
    { '@type': 'HowToStep', position: 3, name: 'Test every key', text: 'Work across the whole keyboard to find any key that fails to light up.' },
    { '@type': 'HowToStep', position: 4, name: 'Check the log', text: 'Review the key log for the exact key names and codes registered.' },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={[faqSchema, toolSchema, howToSchema]}>
  <style is:inline>
    :root {
      --primary: #6366f1; --success: #10b981; --warn: #f59e0b;
      --bg: #f8fafc; --card: #ffffff; --text: #1e293b; --muted: #64748b; --border: #e2e8f0;
      --key-bg: #ffffff; --key-border: #cbd5e1; --key-text: #334155;
      --key-tested: #dcfce7; --key-tested-border: #86efac; --key-tested-text: #166534;
      --key-active: #6366f1; --key-active-text: #ffffff;
    }
    .dark body {
      --bg: #0f172a; --card: #1e293b; --text: #f1f5f9; --muted: #94a3b8; --border: #334155;
      --key-bg: #1e293b; --key-border: #334155; --key-text: #e2e8f0;
      --key-tested: #14532d; --key-tested-border: #166534; --key-tested-text: #bbf7d0;
      --key-active: #818cf8; --key-active-text: #ffffff;
    }

    /* ── Flagship Hero ── */
    .kt-hero {
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 30%, #4c1d95 65%, #2e1065 100%);
      position: relative; overflow: hidden; padding: 44px 20px 56px; text-align: center;
    }
    .kt-hero::before {
      content: ''; position: absolute; top: -80px; right: -80px; width: 320px; height: 320px;
      background: radial-gradient(circle, rgba(167,139,250,0.22) 0%, transparent 70%); pointer-events: none;
    }
    .kt-hero::after {
      content: ''; position: absolute; bottom: -60px; left: -60px; width: 240px; height: 240px;
      background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%); pointer-events: none;
    }
    .kt-badge {
      display: inline-flex; align-items: center; gap: 5px; margin-bottom: 14px;
      background: rgba(255,255,255,0.12); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.22); color: #e0e7ff;
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
      padding: 4px 14px; border-radius: 20px; position: relative; z-index: 1;
    }
    .kt-hero h1 {
      font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; color: #fff;
      margin-bottom: 8px; letter-spacing: -0.02em; position: relative; z-index: 1;
    }
    .kt-hero p { font-size: 1rem; color: #c4b5fd; position: relative; z-index: 1; }

    /* ── Wrap ── */
    .kt-wrap { max-width: 900px; margin: 0 auto; padding: 28px 16px 0; }

    /* ── Mobile notice ── */
    .mobile-notice {
      display: none; background: #fef3c7; border: 1.5px solid #f59e0b; border-radius: 12px;
      padding: 14px 18px; margin-bottom: 20px; font-size: 0.9rem; color: #92400e; text-align: center;
    }
    .dark body .mobile-notice { background: #451a03; color: #fde68a; border-color: #d97706; }
    @media (pointer: coarse) { .mobile-notice { display: block; } }

    /* ── Stats bar ── */
    .kt-stats {
      display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
      justify-content: space-between; margin-bottom: 16px;
    }
    .kt-stat { display: flex; align-items: center; gap: 6px; font-size: 0.88rem; }
    .kt-stat .sv { font-weight: 800; font-size: 1.1rem; color: var(--primary); }
    .kt-stat .sl { color: var(--muted); }
    .kt-progress-bar { flex: 1; min-width: 120px; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
    .kt-progress-fill { height: 100%; background: var(--success); border-radius: 3px; width: 0%; transition: width 0.2s; }
    .kt-reset-btn {
      padding: 7px 16px; border-radius: 8px; background: transparent;
      border: 1.5px solid var(--border); color: var(--muted); font-size: 0.85rem;
      font-weight: 600; cursor: pointer; transition: all 0.15s;
    }
    .kt-reset-btn:hover { border-color: var(--primary); color: var(--primary); }

    /* ── Key Info Panel ── */
    .kt-info {
      background: var(--card); border: 1.5px solid var(--border); border-radius: 12px;
      padding: 12px 16px; margin-bottom: 16px; display: flex; align-items: center; gap: 16px;
      min-height: 52px; flex-wrap: wrap;
    }
    .kt-info .ki-label { font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .kt-info .ki-val { font-size: 0.95rem; font-weight: 700; color: var(--text); margin-top: 1px; }
    .kt-info .ki-divider { width: 1px; height: 32px; background: var(--border); flex-shrink: 0; }
    .kt-info .ki-empty { font-size: 0.88rem; color: var(--muted); }

    /* ── Keyboard ── */
    .kt-board {
      background: var(--card); border: 1.5px solid var(--border);
      border-radius: 16px; padding: 14px 12px; overflow-x: auto;
    }
    .kb-row { display: flex; gap: 5px; margin-bottom: 5px; }
    .kb-row:last-child { margin-bottom: 0; }

    /* individual key */
    .k {
      flex: 1; min-height: 42px; border-radius: 7px; display: flex; align-items: center;
      justify-content: center; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.01em;
      background: var(--key-bg); border: 1.5px solid var(--key-border); color: var(--key-text);
      transition: background 0.12s, border-color 0.12s, color 0.12s, transform 0.06s;
      cursor: default; user-select: none; text-align: center; line-height: 1.2;
      box-shadow: 0 2px 0 var(--key-border);
      white-space: nowrap; padding: 0 4px;
    }
    .k.tested {
      background: var(--key-tested); border-color: var(--key-tested-border);
      color: var(--key-tested-text); box-shadow: 0 2px 0 var(--key-tested-border);
    }
    .k.active {
      background: var(--key-active); border-color: var(--key-active); color: var(--key-active-text);
      transform: translateY(2px); box-shadow: none;
    }

    /* ── Arrow + Nav clusters ── */
    .kt-clusters { display: flex; gap: 20px; justify-content: flex-end; margin-top: 5px; flex-wrap: wrap; }
    .cluster-title { font-size: 0.68rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
    .cluster-grid { display: grid; gap: 4px; }
    .cluster-grid.arrows { grid-template-columns: repeat(3, 38px); }
    .cluster-grid.nav    { grid-template-columns: repeat(3, 48px); }
    .cluster-grid .k { min-height: 38px; flex: none; }
    .cluster-grid.arrows .k { width: 38px; }
    .cluster-grid.nav    .k { width: 48px; }
    .cluster-grid .k-placeholder { width: 38px; height: 38px; }

    /* ── Legend ── */
    .kt-legend { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 14px; font-size: 0.8rem; color: var(--muted); }
    .legend-dot { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; }
    .legend-item { display: flex; align-items: center; gap: 5px; }

    /* ── About ── */
    .about-section { max-width: 900px; margin: 28px auto 0; padding: 0 16px; }
    .about-card { background: var(--card); border: 1.5px solid var(--border); border-radius: 16px; padding: 28px; }
    .about-card h2 { font-size: 1.3rem; font-weight: 800; margin-bottom: 16px; }
    .about-card p  { font-size: .92rem; line-height: 1.8; color: var(--muted); margin-bottom: 14px; }
    .about-card p:last-child { margin-bottom: 0; }
    .about-card h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 20px 0 8px; }

    /* ── FAQ ── */
    .faq-section { max-width: 900px; margin: 28px auto 40px; padding: 0 16px; }
    .faq-title { font-size: 1.2rem; font-weight: 800; margin-bottom: 16px; }
    .faq-item { background: var(--card); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 10px; }
    .faq-q { padding: 14px 16px; font-weight: 600; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-size: 0.93rem; }
    .faq-q:hover { color: var(--primary); }
    .faq-a { padding: 0 16px 14px; font-size: 0.88rem; color: var(--muted); line-height: 1.65; display: none; }
    .faq-item.open .faq-a { display: block; }
    .faq-item.open .faq-arrow { transform: rotate(180deg); }
    .faq-arrow { transition: transform 0.2s; font-size: 0.75rem; color: var(--muted); }
  </style>

  <!-- Hero -->
  <div class="kt-hero">
    <div class="kt-badge">★ FLAGSHIP TOOL</div>
    <h1>⌨️ Keyboard Tester</h1>
    <p>Press any key to see it light up — detect stuck or broken keys instantly</p>
  </div>

  <div class="kt-wrap">
    <!-- Mobile notice -->
    <div class="mobile-notice">
      ⚠️ A physical keyboard is required to use this tool. Connect a keyboard and press any key to begin.
    </div>

    <!-- Stats bar -->
    <div class="kt-stats">
      <div class="kt-stat">
        <span class="sv" id="testedCount">0</span>
        <span class="sl">/ {TOTAL} keys tested</span>
      </div>
      <div class="kt-progress-bar"><div class="kt-progress-fill" id="progressFill"></div></div>
      <button class="kt-reset-btn" id="resetBtn">↺ Reset</button>
    </div>

    <!-- Key Info Panel -->
    <div class="kt-info" id="keyInfo">
      <span class="ki-empty">Press any key to see its details here…</span>
    </div>

    <!-- Keyboard -->
    <div class="kt-board">
      {ROWS.map((row) => (
        <div class="kb-row">
          {row.map((key) => (
            <div
              class="k"
              data-code={key.code}
              style={`flex: ${key.w}`}
            >
              {key.label}
            </div>
          ))}
        </div>
      ))}

      <!-- Arrow + Nav clusters -->
      <div class="kt-clusters">
        <div>
          <div class="cluster-title">Navigation</div>
          <div class="cluster-grid nav">
            {NAV[0].map(k => <div class="k" data-code={k.code}>{k.label}</div>)}
            {NAV[1].map(k => <div class="k" data-code={k.code}>{k.label}</div>)}
          </div>
        </div>
        <div>
          <div class="cluster-title">Arrows</div>
          <div class="cluster-grid arrows">
            <div class="k-placeholder"></div>
            <div class="k" data-code="ArrowUp">↑</div>
            <div class="k-placeholder"></div>
            <div class="k" data-code="ArrowLeft">←</div>
            <div class="k" data-code="ArrowDown">↓</div>
            <div class="k" data-code="ArrowRight">→</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Legend -->
    <div class="kt-legend">
      <div class="legend-item"><div class="legend-dot" style="background:var(--key-bg);border:1.5px solid var(--key-border);"></div> Untested</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--key-tested);border:1.5px solid var(--key-tested-border);"></div> Tested</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--key-active);"></div> Currently Pressed</div>
    </div>
  </div>

  <!-- About -->
  <section class="about-section">
    <div class="about-card">
      <h2>About the Keyboard Tester</h2>
      <p>The ToolNestr Keyboard Tester is a free, browser-based tool that helps you test every key on your keyboard to verify it registers correctly. Whether you have just purchased a new keyboard, are troubleshooting a key that seems unresponsive, or want to confirm that your existing keyboard is working properly before an important task, this tool provides instant visual feedback with no software to install and no sign-up required.</p>
      <p>The tester renders a complete keyboard layout directly in the browser, including the main QWERTY alpha keys, the number row, all function keys (F1–F12), the navigation cluster (Insert, Home, Page Up, Delete, End, Page Down), arrow keys, and the numeric keypad. When you press a key, the corresponding key in the virtual layout highlights in indigo to show it is active, and turns green once released to mark it as successfully tested. A progress counter shows how many unique keys you have tested so far.</p>

      <h3>Why test your keyboard?</h3>
      <p>Keyboards can develop problems for several reasons. Mechanical key switches eventually wear out after millions of keystrokes, causing them to register inconsistently or stop registering entirely. Liquid spills can cause keys to stick or short-circuit. Wireless keyboards can drop keystrokes if the battery is low or the receiver is too far away. Gaming keyboards sometimes experience ghosting — the failure to register simultaneous key presses — when the hardware does not support enough simultaneous inputs (referred to as N-key rollover or NKRO).</p>
      <p>After cleaning a keyboard or replacing key caps, it is good practice to run a full test to confirm every key works before putting the keyboard back into service. The Keyboard Tester makes this quick and methodical: press every key in order, and any key that does not turn green is one you need to investigate.</p>

      <h3>Key information panel</h3>
      <p>When you press a key, the information panel on the right shows the key's display name, its event.key value (the character or action it produces), its event.code value (the physical key identifier that is layout-independent), and its keyCode number (the numeric code used by older JavaScript applications). It also shows which modifier keys — Shift, Ctrl, Alt, and Meta — were held when the key was pressed. This information is useful for developers debugging keyboard shortcut handlers, for understanding the difference between key and code values, and for identifying keys that produce unexpected values on non-standard keyboard layouts.</p>

      <h3>Mobile and touch devices</h3>
      <p>On touch devices without a physical keyboard, a notice is displayed explaining that the tester requires a hardware keyboard to function. Mobile on-screen keyboards do not fire the same keyboard events as physical keyboards, and therefore cannot be tested with this tool. If you need to test a keyboard connected to a mobile device via USB or Bluetooth, many such connections do fire the standard keyboard events and should work correctly with this tester.</p>

      <h3>Browser compatibility and key limitations</h3>
      <p>The tester works in all modern browsers including Chrome, Firefox, Safari, and Edge. A small number of keys may be captured by the browser or operating system before reaching the page — for example, pressing F5 will reload the page in most browsers, and certain keyboard shortcuts like Ctrl+T or Cmd+Q are handled by the browser. The tester attempts to intercept as many keys as possible, but system-level shortcuts cannot be captured by any web application. If you need to test these keys, consider using a dedicated desktop keyboard testing application instead.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <h2 class="faq-title">Frequently Asked Questions</h2>
    {faqs.map((f) => (
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
          {f.q}
          <span class="faq-arrow">▼</span>
        </div>
        <div class="faq-a">{f.a}</div>
      </div>
    ))}
  </section>

  <script is:inline>
  (function () {
    const TOTAL = document.querySelectorAll('.k[data-code]').length;
    const testedSet = new Set();
    const activeSet = new Set();

    const testedCount = document.getElementById('testedCount');
    const progressFill = document.getElementById('progressFill');
    const keyInfo = document.getElementById('keyInfo');

    function getKeyEl(code) {
      return document.querySelector(`.k[data-code="${CSS.escape(code)}"]`);
    }

    function updateStats() {
      const n = testedSet.size;
      testedCount.textContent = n;
      progressFill.style.width = ((n / TOTAL) * 100) + '%';
    }

    function showInfo(e) {
      keyInfo.innerHTML = `
        <div><div class="ki-label">Key</div><div class="ki-val">${e.key === ' ' ? 'Space' : (e.key.length > 6 ? e.key.slice(0,12) : e.key)}</div></div>
        <div class="ki-divider"></div>
        <div><div class="ki-label">Code</div><div class="ki-val">${e.code}</div></div>
        <div class="ki-divider"></div>
        <div><div class="ki-label">KeyCode</div><div class="ki-val">${e.keyCode}</div></div>
        <div class="ki-divider"></div>
        <div><div class="ki-label">Modifiers</div><div class="ki-val">${[e.shiftKey&&'Shift',e.ctrlKey&&'Ctrl',e.altKey&&'Alt',e.metaKey&&'Meta'].filter(Boolean).join('+') || '–'}</div></div>
      `;
    }

    document.addEventListener('keydown', (e) => {
      // Prevent browser shortcuts from navigating away, but don't suppress F5
      if (['Tab', 'Space', 'ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
        e.preventDefault();
      }

      const el = getKeyEl(e.code);
      if (el && !activeSet.has(e.code)) {
        activeSet.add(e.code);
        el.classList.remove('tested');
        el.classList.add('active');
      }
      testedSet.add(e.code);
      showInfo(e);
      updateStats();
    });

    document.addEventListener('keyup', (e) => {
      const el = getKeyEl(e.code);
      if (el) {
        activeSet.delete(e.code);
        el.classList.remove('active');
        if (testedSet.has(e.code)) el.classList.add('tested');
      }
    });

    document.getElementById('resetBtn').addEventListener('click', () => {
      testedSet.clear();
      activeSet.clear();
      document.querySelectorAll('.k[data-code]').forEach(el => {
        el.classList.remove('active', 'tested');
      });
      keyInfo.innerHTML = '<span class="ki-empty">Press any key to see its details here…</span>';
      testedCount.textContent = '0';
      progressFill.style.width = '0%';
    });
  })();
  </script>
</BaseLayout>
