---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Combination & Permutation Calculator';
const description = 'Calculate nCr (combinations) and nPr (permutations) with a step-by-step factorial breakdown. Free online tool for statistics and probability problems.';
const intro = 'Calculate nCr and nPr with step-by-step factorial breakdown.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is the difference between combinations and permutations?', a: 'Permutations consider order (ABC ≠ CBA), combinations do not (ABC = CBA).' },
  { q: 'What is nCr?', a: 'nCr = n! / (r! × (n−r)!). The number of ways to choose r items from n without regard to order.' },
  { q: 'What is nPr?', a: 'nPr = n! / (n−r)!. The number of ways to arrange r items from n where order matters.' },
  { q: 'When should I use combinations vs permutations?', a: 'Use combinations when order doesn\'t matter (lottery, committee selection) and permutations when it does (passwords, race rankings).' },
];
---

<ToolLayout
  title={title}
  description={description}
  intro={intro}
  category={category}
  faqs={faqs}
  appCategory="UtilitiesApplication"
>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">n (total items)</span>
        <input id="in-n" type="number" min="0" max="170" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-center text-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">r (selected items)</span>
        <input id="in-r" type="number" min="0" max="170" value="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-center text-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>

    <button id="calc-btn" class="mt-4 w-full rounded-xl bg-indigo-600 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700">Calculate</button>

    <div id="warning" class="mt-3 hidden rounded-lg bg-amber-50 p-3 text-center text-sm text-amber-700"></div>

    <div id="result" class="mt-6 hidden space-y-5">
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl bg-indigo-50 p-4 text-center">
          <span class="text-xs font-semibold uppercase tracking-wide text-indigo-500">nCr (Combinations)</span>
          <div id="ncr-display" class="mt-1 text-3xl font-bold text-indigo-700">—</div>
          <div id="ncr-label" class="mt-1 text-xs text-indigo-400">C( , ) = </div>
        </div>
        <div class="rounded-xl bg-emerald-50 p-4 text-center">
          <span class="text-xs font-semibold uppercase tracking-wide text-emerald-500">nPr (Permutations)</span>
          <div id="npr-display" class="mt-1 text-3xl font-bold text-emerald-700">—</div>
          <div id="npr-label" class="mt-1 text-xs text-emerald-400">P( , ) = </div>
        </div>
      </div>

      <div class="rounded-xl bg-slate-50 p-4">
        <h3 class="text-sm font-semibold text-slate-700">Comparison</h3>
        <div class="mt-2 flex items-center gap-3">
          <span class="text-xs font-medium text-slate-500">nCr</span>
          <div class="flex-1 overflow-hidden rounded-full bg-slate-200">
            <div id="ncr-bar" class="h-3 rounded-full bg-indigo-500 transition-all" style="width:0%"></div>
          </div>
          <span class="text-xs font-medium text-slate-500">nPr</span>
          <div class="flex-1 overflow-hidden rounded-full bg-slate-200">
            <div id="npr-bar" class="h-3 rounded-full bg-emerald-500 transition-all" style="width:0%"></div>
          </div>
        </div>
        <p id="relation-note" class="mt-2 text-xs text-slate-400">nCr ≤ nPr always — order restrictions reduce the count.</p>
      </div>

      <div id="steps" class="space-y-2 rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-600"></div>
    </div>

    <p id="error-msg" class="mt-4 hidden text-center text-sm font-semibold text-red-500"></p>
  </div>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 300" width="800" height="300" role="img" aria-labelledby="cp-title cp-desc">
      <title id="cp-title">Combinations vs Permutations diagram</title>
      <desc id="cp-desc">A set of n items shown as circles with r highlighted. Branching arrows illustrate permutations (ordered arrangements) versus combinations (unordered selections).</desc>
      <rect width="800" height="300" fill="#f8fafc" rx="8" />

      <!-- Set of n items as circles -->
      <g transform="translate(30,30)">
        <text x="100" y="20" text-anchor="middle" font-size="16" font-weight="700" fill="#1e293b" font-family="system-ui">Set of n items</text>
        <circle cx="30" cy="50" r="14" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="30" y="55" text-anchor="middle" font-size="11" fill="#4338ca" font-family="system-ui">1</text>
        <circle cx="70" cy="50" r="14" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="70" y="55" text-anchor="middle" font-size="11" fill="#4338ca" font-family="system-ui">2</text>
        <circle cx="110" cy="50" r="14" fill="#fef3c7" stroke="#f59e0b" stroke-width="2" />
        <text x="110" y="55" text-anchor="middle" font-size="11" fill="#d97706" font-family="system-ui">3</text>
        <circle cx="150" cy="50" r="14" fill="#fef3c7" stroke="#f59e0b" stroke-width="2" />
        <text x="150" y="55" text-anchor="middle" font-size="11" fill="#d97706" font-family="system-ui">4</text>
        <circle cx="190" cy="50" r="14" fill="#d1fae5" stroke="#10b981" stroke-width="2" />
        <text x="190" y="55" text-anchor="middle" font-size="11" fill="#059669" font-family="system-ui">5</text>
        <circle cx="230" cy="50" r="14" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="230" y="55" text-anchor="middle" font-size="11" fill="#4338ca" font-family="system-ui">6</text>
        <circle cx="270" cy="50" r="14" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="270" y="55" text-anchor="middle" font-size="11" fill="#4338ca" font-family="system-ui">7</text>

        <!-- Ellipsis -->
        <text x="310" y="55" font-size="16" fill="#94a3b8" font-family="system-ui">…</text>
        <circle cx="350" cy="50" r="14" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="350" y="55" text-anchor="middle" font-size="11" fill="#4338ca" font-family="system-ui">n</text>

        <!-- r highlighted label -->
        <text x="110" y="82" text-anchor="middle" font-size="11" fill="#d97706" font-family="system-ui" font-weight="600">r selected</text>
        <line x1="30" y1="67" x2="30" y2="100" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="3,3" />
        <line x1="190" y1="67" x2="190" y2="100" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="3,3" />
        <line x1="110" y1="67" x2="110" y2="82" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="3,3" />

        <!-- Branch for Permutations -->
        <text x="50" y="115" font-size="13" font-weight="700" fill="#059669" font-family="system-ui">Permutations (order matters)</text>
        <path d="M 30 60 L 30 130" stroke="#10b981" stroke-width="1.5" stroke-dasharray="4,3" />
        <path d="M 30 130 L 50 150" stroke="#10b981" stroke-width="1.5" />
        <path d="M 30 130 L 80 150" stroke="#10b981" stroke-width="1.5" />
        <path d="M 30 130 L 110 150" stroke="#10b981" stroke-width="1.5" />
        <text x="10" y="145" font-size="11" fill="#6ee7b7" font-family="system-ui">n choices</text>
        <text x="45" y="170" font-size="11" fill="#6ee7b7" font-family="system-ui">(n−1) choices</text>
        <text x="85" y="170" font-size="11" fill="#6ee7b7" font-family="system-ui">(n−2) choices</text>
        <text x="10" y="195" font-size="11" fill="#10b981" font-family="system-ui">… r factors</text>
        <text x="10" y="220" font-size="13" fill="#059669" font-family="system-ui" font-weight="600">nPr = n·(n−1)·…·(n−r+1)</text>

        <!-- Branch for Combinations -->
        <text x="200" y="115" font-size="13" font-weight="700" fill="#6366f1" font-family="system-ui">Combinations (order irrelevant)</text>
        <path d="M 190 60 L 190 130" stroke="#6366f1" stroke-width="1.5" stroke-dasharray="4,3" />
        <path d="M 190 130 L 210 150" stroke="#6366f1" stroke-width="1.5" />
        <path d="M 190 130 L 240 150" stroke="#6366f1" stroke-width="1.5" />
        <path d="M 190 130 L 270 150" stroke="#6366f1" stroke-width="1.5" />
        <text x="170" y="145" font-size="11" fill="#a5b4fc" font-family="system-ui">r! same selections</text>
        <text x="200" y="170" font-size="11" fill="#a5b4fc" font-family="system-ui">collapsed into 1</text>
        <text x="200" y="220" font-size="13" fill="#6366f1" font-family="system-ui" font-weight="600">nCr = nPr / r!</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Visualising permutations as a branching tree of ordered selections and combinations as groupings that ignore order</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What are combinations and permutations?</h2>
    <p class="mt-2 text-slate-600">
      Combinations and permutations are two fundamental ways of counting selections from a set. The key difference is whether the <em>order</em> of selection matters.
      If order matters, we are dealing with <strong>permutations</strong>. If order does not matter, we are dealing with <strong>combinations</strong>.
    </p>
    <p class="mt-3 text-slate-600">
      Both concepts rely on the <strong>factorial</strong> function, written as <em>n!</em> and defined as the product of all positive integers from 1 up to n. For example,
      5! = 5 × 4 × 3 × 2 × 1 = 120. By convention, 0! = 1.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Formulas</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-center">
        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Permutations</h3>
        <p class="mt-3 text-2xl font-bold text-emerald-700">nPr = n! / (n − r)!</p>
        <p class="mt-2 text-sm text-slate-500">Number of ways to arrange r items from n where the order of selection matters.</p>
        <div class="mt-3 rounded-lg bg-emerald-50 p-3 text-sm text-emerald-700">
          <span class="font-semibold">Example:</span> 5P3 = 5! / 2! = 120 / 2 = <strong>60</strong>
        </div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-center">
        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wide">Combinations</h3>
        <p class="mt-3 text-2xl font-bold text-indigo-700">nCr = n! / (r! × (n − r)!)</p>
        <p class="mt-2 text-sm text-slate-500">Number of ways to choose r items from n without regard to order.</p>
        <div class="mt-3 rounded-lg bg-indigo-50 p-3 text-sm text-indigo-700">
          <span class="font-semibold">Example:</span> 5C3 = 5! / (3! × 2!) = 120 / (6 × 2) = <strong>10</strong>
        </div>
      </div>
    </div>
    <p class="mt-4 text-slate-600">
      Notice that permutations always produce a larger (or equal) value than combinations for the same n and r. This is because
      each combination of r items can be rearranged in r! different orders to produce distinct permutations. The relationship is:
      <strong>nPr = nCr × r!</strong>.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example: n = 5, r = 3</h2>
    <p class="mt-2 text-slate-600">
      Suppose you have 5 distinct items labelled A, B, C, D, and E, and you want to select 3 of them.
    </p>
    <div class="mt-4 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Permutations: 5P3 = 60</p>
        <p class="mt-1 text-sm text-slate-600">
          For the first position you have 5 choices. After picking one, 4 remain for the second position, then 3 for the third.
          Total arrangements = 5 × 4 × 3 = 60. The formula gives 5! / 2! = 120 / 2 = 60.
          Example arrangements: ABC, ABD, ABE, ACB, ACD, ACE, ADB, ADC, ADE, AEB, AEC, AED … (60 total).
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Combinations: 5C3 = 10</p>
        <p class="mt-1 text-sm text-slate-600">
          From the 60 permutations, every set of 3 items appears in 3! = 6 different orders (e.g. ABC, ACB, BAC, BCA, CAB, CBA are all the same combination).
          Dividing 60 by 6 gives 10 distinct combinations: ABC, ABD, ABE, ACD, ACE, ADE, BCD, BCE, BDE, CDE.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world use cases</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🎲</span>
        <h3 class="mt-2 font-semibold text-slate-900">Probability &amp; Lottery Odds</h3>
        <p class="mt-1 text-sm text-slate-600">
          The probability of winning a lottery is 1 divided by the number of possible combinations. If a lottery requires picking 6 numbers from 49,
          the total combinations are 49C6 = 13,983,816. Your chance of winning with one ticket is about 1 in 14 million. Combinations tell you
          how many possible outcomes exist when order does not matter — exactly the scenario for most lottery, bingo, and raffle games.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🔐</span>
        <h3 class="mt-2 font-semibold text-slate-900">Password Cracking</h3>
        <p class="mt-1 text-sm text-slate-600">
          A 4-digit PIN uses permutations because the order of digits matters: 1234 is different from 4321.
          With 10 digits (0–9) and 4 positions, the total permutations are 10P4 = 10 × 9 × 8 × 7 = 5,040.
          If digits could repeat, it would be 10⁴ = 10,000. Password security relies on these permutation counts —
          the more possible arrangements, the harder to crack.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏆</span>
        <h3 class="mt-2 font-semibold text-slate-900">Sports Brackets &amp; Rankings</h3>
        <p class="mt-1 text-sm text-slate-600">
          In a race with 8 runners, the number of ways to award gold, silver, and bronze medals is 8P3 = 336 —
          the order of the top three finishers matters. For selecting a 3-person committee from 8 candidates,
          order does not matter, so you use 8C3 = 56. Sports tournaments, chess rankings, and podium finishes
          all involve permutations.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧬</span>
        <h3 class="mt-2 font-semibold text-slate-900">Genetics &amp; Bioinformatics</h3>
        <p class="mt-1 text-sm text-slate-600">
          DNA sequences are permutations of four bases (A, T, G, C). A sequence of length 10 has 4¹⁰ = 1,048,576 possible permutations.
          When analysing gene combinations without regard to order — such as which genes are expressed — researchers use combinations.
          Combinatorial mathematics is the backbone of population genetics, protein folding analysis, and phylogenetic tree construction.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Important tips</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">r must be ≤ n</h3>
        <p class="mt-1 text-sm text-slate-600">
          You cannot select more items than are available. If r &gt; n, both nCr and nPr are undefined (zero). The calculator enforces this rule and will display an error.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">nPr is always ≥ nCr</h3>
        <p class="mt-1 text-sm text-slate-600">
          For the same n and r, permutations count every ordering separately, while combinations treat order as irrelevant.
          The ratio is exactly r! — each combination corresponds to r! distinct permutations.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Large values cause overflow</h3>
        <p class="mt-1 text-sm text-slate-600">
          Factorials grow extremely fast. 170! is approximately 7.26 × 10³⁰⁶, which exceeds the maximum safe
          double-precision float (≈1.79 × 10³⁰⁸). The calculator checks for this and shows a warning when
          intermediate values approach the overflow threshold. For n &gt; 170, you would need specialised
          arbitrary-precision libraries. This calculator handles n and r up to 170 with overflow protection.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">When r = 0 or r = n</h3>
        <p class="mt-1 text-sm text-slate-600">
          There is exactly one way to choose nothing (r = 0) or everything (r = n): nC0 = nCn = 1 and nP0 = nPn = 1.
          Choosing all items in a specific order gives n! permutations.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Symmetry of combinations</h3>
        <p class="mt-1 text-sm text-slate-600">
          Combinations have a useful symmetry: nCr = nC(n−r). Choosing which 3 items to include from 5 is the same as
          choosing which 2 items to exclude. This property can simplify calculations when r is close to n.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why factorial understanding matters</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Foundation for probability theory</h3>
        <p class="mt-1 text-sm text-slate-600">
          Every probability calculation involving equally likely outcomes reduces to counting favourable outcomes divided by
          total outcomes. Whether you are calculating the odds of a poker hand (52C5 = 2,598,960 possible hands),
          the chance of flipping exactly 3 heads in 5 coin tosses (5C3 / 2⁵ = 10/32), or the probability of a specific
          committee being formed, combinations and permutations are the essential counting tools. Mastering these
          concepts unlocks the entire field of discrete probability.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Computational considerations</h3>
        <p class="mt-1 text-sm text-slate-600">
          Computing nCr directly via the formula n! / (r! × (n−r)!) can cause unnecessary overflow because n! may be
          enormous even when the final result is small (e.g., 100C1 = 100, but 100! is huge). For efficiency and accuracy,
          many implementations use the multiplicative formula: nCr = Πᵢ₌₁ʳ (n − i + 1) / i. This calculator uses the
          multiplicative approach to stay within safe numerical ranges and only computes factorials explicitly for
          the step-by-step breakdown display.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li><a href="/tools/quadratic-equation-solver/" class="font-medium text-indigo-600 hover:underline">Quadratic Equation Solver</a> — solve ax² + bx + c = 0 step by step.</li>
      <li><a href="/tools/logarithm-calculator/" class="font-medium text-indigo-600 hover:underline">Logarithm Calculator</a> — compute logarithms with any base.</li>
    </ul>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);

    function factorialStr(n) {
      if (n <= 1) return '1';
      const parts = [];
      for (let i = n; i >= 1; i--) parts.push(i);
      return parts.join(' × ');
    }

    function factorial(n) {
      if (n <= 1) return 1;
      let r = 1;
      for (let i = 2; i <= n; i++) {
        r *= i;
        if (!isFinite(r)) return Infinity;
      }
      return r;
    }

    function compute() {
      const n = parseInt($('in-n').value, 10);
      const r = parseInt($('in-r').value, 10);
      const err = $('error-msg');
      const result = $('result');
      const warn = $('warning');

      err.classList.add('hidden');
      result.classList.add('hidden');
      warn.classList.add('hidden');

      if (isNaN(n) || isNaN(r)) {
        err.textContent = 'Please enter valid integers for n and r.';
        err.classList.remove('hidden');
        return;
      }
      if (n < 0 || r < 0) {
        err.textContent = 'n and r must be non-negative.';
        err.classList.remove('hidden');
        return;
      }
      if (r > n) {
        err.textContent = 'r cannot be greater than n.';
        err.classList.remove('hidden');
        return;
      }
      if (n > 170) {
        err.textContent = 'n cannot exceed 170 (factorial overflow limit).';
        err.classList.remove('hidden');
        return;
      }

      // Compute nCr using multiplicative method to avoid huge intermediates
      function nCrVal(n, r) {
        if (r === 0 || r === n) return 1;
        const k = Math.min(r, n - r);
        let result = 1;
        for (let i = 1; i <= k; i++) {
          result = result * (n - k + i) / i;
          if (!isFinite(result)) return Infinity;
        }
        return result;
      }

      // Compute nPr via multiplication
      function nPrVal(n, r) {
        if (r === 0) return 1;
        let result = 1;
        for (let i = 0; i < r; i++) {
          result *= (n - i);
          if (!isFinite(result)) return Infinity;
        }
        return result;
      }

      const ncr = nCrVal(n, r);
      const npr = nPrVal(n, r);

      let overflow = false;
      if (!isFinite(ncr) || !isFinite(npr) || ncr > 1e308 || npr > 1e308) {
        overflow = true;
        warn.textContent = 'Warning: Result exceeds safe number range (≈1.79 × 10³⁰⁸). Values shown may be approximate.';
        warn.classList.remove('hidden');
      }

      // Format large numbers
      function fmt(v) {
        if (!isFinite(v) || v > 1e15) return v.toExponential(4);
        return Number.isInteger(v) ? v.toLocaleString() : v.toFixed(4);
      }

      $('ncr-display').textContent = fmt(ncr);
      $('npr-display').textContent = fmt(npr);
      $('ncr-label').textContent = `C(${n}, ${r}) = ${fmt(ncr)}`;
      $('npr-label').textContent = `P(${n}, ${r}) = ${fmt(npr)}`;

      // Comparison bars (clamped)
      const maxVal = Math.max(ncr, npr, 1);
      $('ncr-bar').style.width = Math.min((ncr / maxVal) * 100, 100) + '%';
      $('npr-bar').style.width = Math.min((npr / maxVal) * 100, 100) + '%';

      if (ncr === npr) {
        $('relation-note').textContent = 'nCr = nPr when r = 0, r = 1, or r = n.';
      } else {
        $('relation-note').textContent = `nPr is ${(npr / ncr).toFixed(1)}× larger than nCr (ratio = r! = ${fmt(factorial(r))}).`;
      }

      // Step-by-step factorial breakdown
      const steps = $('steps');
      const nFact = factorial(n);
      const nrFact = factorial(n - r);
      const rFact = factorial(r);

      steps.innerHTML = `
        <div class="font-semibold text-slate-700">Step-by-step breakdown</div>
        <div><span class="font-medium">n!</span> = ${factorialStr(n)} = <span class="font-mono">${fmt(nFact)}</span></div>
        ${r > 0 ? `<div><span class="font-medium">r!</span> = ${factorialStr(r)} = <span class="font-mono">${fmt(rFact)}</span></div>` : '<div><span class="font-medium">r!</span> = 0! = <span class="font-mono">1</span></div>'}
        <div><span class="font-medium">(n−r)!</span> = ${n - r <= 1 ? '1' : factorialStr(n - r)} = <span class="font-mono">${fmt(nrFact)}</span></div>
        <hr class="border-slate-200" />
        <div><span class="font-medium">nPr</span> = n! / (n−r)! = ${fmt(nFact)} / ${fmt(nrFact)} = <span class="font-mono font-bold text-emerald-700">${fmt(npr)}</span></div>
        <div><span class="font-medium">nCr</span> = n! / (r! × (n−r)!) = ${fmt(nFact)} / (${fmt(rFact)} × ${fmt(nrFact)}) = <span class="font-mono font-bold text-indigo-700">${fmt(ncr)}</span></div>
      `;

      result.classList.remove('hidden');
    }

    $('calc-btn').addEventListener('click', compute);
    ['in-n', 'in-r'].forEach((id) => $(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') compute(); }));
    compute();
  </script>
</ToolLayout>
