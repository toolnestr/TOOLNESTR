---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Lbs to Kg"
  emoji="⚖️"
  fromUnit="pounds" toUnit="kilograms"
  fromTitle="Pounds" toTitle="Kilograms"
  fromSym="lb" toSym="kg"
  quantity="weight"
  kind="factor" factor={0.45359237}
  reverseSlug="kg-to-lbs" reverseLabel="Kg to Lbs Converter"
  hasReverse={true}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Use it to read American or British weights in the metric units used by most of the world and in science."
/>
