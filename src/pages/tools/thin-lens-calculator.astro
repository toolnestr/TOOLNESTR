---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Thin Lens Equation Calculator';
const description = 'Thin lens equation calculator with a live solver for focal length, object distance, or image distance, plus magnification. Includes static 3D ray diagrams and charts for 1/f = 1/do + 1/di.';
const intro = 'Solve 1/f = 1/do + 1/di for focal length, object distance, or image distance, and get the magnification m = -di/do with real/virtual and upright/inverted classification. Two static 3D ray diagrams show a converging lens forming a real image and a magnifying-glass case forming a virtual image, plus charts of image distance and magnification vs object distance.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the thin lens equation?', a: '1/f = 1/do + 1/di, where f is the focal length of the lens, do is the distance from the lens to the object, and di is the distance from the lens to the image. It assumes a thin lens (negligible thickness) and paraxial rays (close to the optical axis).' },
  { q: "What is the sign convention used here?", a: 'f is positive for a converging (convex) lens and negative for a diverging (concave) lens. do is positive for a real object in front of the lens. di is positive when the image forms on the opposite side from the object (a real image) and negative when it forms on the same side as the object (a virtual image).' },
  { q: 'What does a negative image distance mean?', a: 'A negative di means the image is virtual: light rays do not actually converge there, but appear to diverge from that point when traced backward. Virtual images form on the same side of the lens as the object and cannot be projected onto a screen — you can only view them by looking through the lens, like with a magnifying glass.' },
  { q: 'What is the difference between a real and a virtual image?', a: 'A real image forms where light rays actually cross and converge; it can be projected onto a screen and is inverted relative to the object. A virtual image forms where rays only appear to diverge from, cannot be projected on a screen, and is upright relative to the object.' },
  { q: 'What does the magnification value tell you?', a: 'Magnification m = -di/do. The sign of m tells you orientation: negative means inverted, positive means upright. The magnitude of m tells you size: |m| > 1 means the image is larger than the object, |m| < 1 means smaller, and |m| = 1 means the same size.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Thin Lens Equation Calculator',
  description: 'Solve 1/f = 1/do + 1/di for focal length, object distance, or image distance, and compute magnification.',
  steps: [
    { name: 'Choose what to solve for', text: 'Pick f, do, or di as the unknown.' },
    { name: 'Enter the other two values', text: 'Use consistent units (cm or m) and remember the sign convention for f and di.' },
    { name: 'Read the result', text: 'The unknown distance solves instantly, along with magnification and whether the image is real/virtual and upright/inverted.' },
  ],
};

const formulas = [
  { expr: '1/f = 1/do + 1/di', note: 'thin lens equation — f, do, di in the same length units' },
  { expr: 'm = −di / do', note: 'magnification — sign shows orientation, magnitude shows size' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — converging lens, object beyond f', tone: 'slate',
    given: 'An object sits 30 cm from a converging lens with focal length f = 10 cm. Find the image distance and magnification.',
    rows: [
      { label: 'Formula:', value: '1/di = 1/f − 1/do' },
      { label: 'Substitute:', value: '1/di = 1/10 − 1/30 = 3/30 − 1/30 = 2/30' },
      { label: 'Image distance:', value: 'di = 30/2 = 15 cm (real image, opposite side)' },
      { label: 'Magnification:', value: 'm = −di/do = −15/30 = −0.5', full: true },
    ],
    note: 'di is positive (real image) and m is negative with magnitude below 1: the image is real, inverted, and reduced to half size.',
  },
  {
    title: 'Worked example 2 — object inside the focal length (magnifying glass)', tone: 'amber',
    given: 'The same lens (f = 10 cm) now has an object placed just 5 cm away — inside the focal length. Find the image distance and magnification.',
    rows: [
      { label: 'Formula:', value: '1/di = 1/f − 1/do' },
      { label: 'Substitute:', value: '1/di = 1/10 − 1/5 = 1/10 − 2/10 = −1/10' },
      { label: 'Image distance:', value: 'di = −10 cm (virtual image, same side as object)' },
      { label: 'Magnification:', value: 'm = −di/do = −(−10)/5 = 2', full: true },
    ],
    note: 'di is negative (virtual image) and m is positive with magnitude above 1: the image is virtual, upright, and magnified 2×  — exactly how a magnifying glass works.',
  },
];

const comparison = {
  heading: 'Typical focal lengths of common lenses',
  note: 'Approximate values — actual focal length depends on the specific lens design and material.',
  headers: [{ label: 'Application' }, { label: 'Typical focal length' }],
  rows: [
    ['Reading glasses (mild)', '+100 cm to +200 cm (weak converging)'],
    ['Magnifying glass', '+5 cm to +10 cm (strong converging)'],
    ['Camera lens (standard)', '+35 mm to +50 mm'],
    ['Nearsightedness (myopia) correction', '−30 cm to −200 cm (diverging)'],
    ['Projector lens', '+5 cm to +15 cm'],
  ],
  highlightIndex: 1,
  footnote: 'Eyeglass prescriptions are usually quoted in diopters (D = 1/f in meters), not directly in focal length.',
};

const realWorld = [
  { emoji: '👓', title: 'Eyeglass and contact lens prescriptions', body: 'An optometrist measures the focal length needed to correctly focus light onto the retina and prescribes lens power in diopters (D = 1/f, with f in meters). Converging (positive) lenses correct farsightedness; diverging (negative) lenses correct nearsightedness.' },
  { emoji: '📷', title: 'Camera and telescope optics', body: 'A camera lens forms a real, inverted image on the sensor using the thin lens equation, with di essentially fixed at the sensor distance while the lens moves to bring different do into focus. Telescopes use similar principles with much longer focal lengths to gather and focus light from distant objects.' },
  { emoji: '🔍', title: 'Magnifying glasses', body: 'Holding an object inside the focal length of a converging lens produces a virtual, upright, magnified image — exactly the case in worked example 2. This is why a magnifying glass has to be held close to what you are inspecting.' },
  { emoji: '🎥', title: 'Projector image formation', body: 'A projector places the film or digital panel just beyond the focal length so the lens forms a large, real, inverted image on a distant screen; the projector flips the source image upside down internally so the projected picture appears right-side up.' },
];

const misconceptions = [
  { claim: '"A converging lens always makes a real image."', truth: 'Only when the object is farther from the lens than the focal length. If the object is placed inside the focal length (do < f), a converging lens produces a virtual, upright, magnified image instead — this is exactly how a magnifying glass is used.' },
  { claim: '"Negative magnification means the image is smaller."', truth: 'The sign of m indicates orientation only: negative means inverted, positive means upright. Whether the image is bigger or smaller than the object depends on the magnitude |m|, not the sign — m = −2 is inverted AND twice as large.' },
  { claim: '"A diverging lens can form a real image."', truth: 'A diverging (concave) lens with f < 0 always produces a virtual, upright, reduced image no matter where the object is placed, because 1/di = 1/f − 1/do is always negative when f is negative and do is positive.' },
  { claim: '"The image distance di is just a formality — only the focal length matters."', truth: 'di tells you where the image actually forms and its sign tells you whether it is real (can be projected on a screen) or virtual (only visible by looking through the lens) — both are needed together with do to know the magnification and image type.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 3</em></strong> — §2.3 "Images Formed by Thin Lenses" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-3/pages/2-3-images-formed-by-thin-lenses" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 34, Images (thin lens equation and sign conventions).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 36, Image Formation.' },
];
const sourcesNote = '1/f = 1/do + 1/di and m = −di/do, using the standard sign convention: f > 0 converging, f < 0 diverging, di > 0 real image, di < 0 virtual image. Results are rounded for display.';

const howToUse = [
  { title: 'Choose the unknown', body: 'The calculator solves for f, do, or di from the other two.' },
  { title: 'Watch your signs', body: 'Enter f as negative for a diverging lens; the calculator reports whether di comes out real or virtual.' },
  { title: 'Check the magnification', body: 'The sign shows orientation (upright/inverted) and the magnitude shows size relative to the object.' },
];

const related = [
  { href: '/tools/snells-law-calculator', emoji: '🔦', title: "Snell's Law (Refraction) Calculator", desc: 'n1 sinθ1 = n2 sinθ2 — solve for any variable.' },
  { href: '/tools/wavelength-frequency-calculator', emoji: '〰️', title: 'Wavelength Calculator', desc: 'v = fλ — solve for wavelength or frequency.' },
  { href: '/tools/coulombs-law-calculator', emoji: '⚡', title: "Coulomb's Law Calculator", desc: 'F = k|q1q2|/r² — electrostatic force.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="The thin lens equation, 1/f = 1/do + 1/di, links a lens's focal length to how far the object and its image sit from the lens — and where the object lands relative to the focal length decides whether the image is real and inverted, or virtual, upright, and magnified."
  howIntro="Rearranged, 1/f = 1/do + 1/di solves any variable: 1/di = 1/f − 1/do, 1/do = 1/f − 1/di, and 1/f = 1/do + 1/di directly gives f. Magnification follows as m = −di/do — its sign shows whether the image is upright (positive) or inverted (negative), and its magnitude shows whether the image is enlarged (|m| > 1) or reduced (|m| < 1) relative to the object."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the thin lens equation actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-f" type="button" data-solve="f" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">f</button>
      <button id="mode-do" type="button" data-solve="do" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">do</button>
      <button id="mode-di" type="button" data-solve="di" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">di</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <label id="field-f" class="block"><span class="text-sm font-medium text-slate-700">f — focal length (cm)</span>
        <input id="f" type="number" step="any" placeholder="e.g. 10" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-do" class="block"><span class="text-sm font-medium text-slate-700">do — object distance (cm)</span>
        <input id="do" type="number" step="any" placeholder="e.g. 30" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-di" class="block"><span class="text-sm font-medium text-slate-700">di — image distance (cm)</span>
        <input id="di" type="number" step="any" placeholder="solved" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div id="box-f" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">f</div><div id="r-f" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-do" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">do</div><div id="r-do" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-di" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">di</div><div id="r-di" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Magnification (m)</div><div id="r-m" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Image type</div><div id="r-type" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="tl-hint" class="mt-3 text-center text-sm text-slate-500"></p>
    <p id="tl-err" class="mt-1 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Two ideas that trip students up</h2>
      <p class="mt-1 text-sm text-slate-500">Two static, auto-rotating ray diagrams: a converging lens forming a real image, and the same lens acting as a magnifying glass when the object is inside the focal length.</p>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-converging" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Object beyond f — real, inverted image</h3>
          <p class="mt-1 text-sm text-slate-600">A converging lens (f = 10 cm) with an object arrow 30 cm away. Rays from the object tip bend through the lens and converge on the far side, forming a real, inverted image at di = 15 cm — matching worked example 1.</p>
        </div>
        <div>
          <div id="diag-diverging" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Object inside f — virtual, upright image (magnifying glass)</h3>
          <p class="mt-1 text-sm text-slate-600">The same lens with the object moved to 5 cm — inside the focal length. The rays diverge after the lens and never actually cross; traced backward (dashed), they appear to meet on the SAME side as the object, forming a virtual, upright, magnified image at di = −10 cm — matching worked example 2.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Lens equation graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Image distance (di) vs object distance (do), f = 10 cm</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-di"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Magnification (m) vs object distance (do), f = 10 cm</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-m"></canvas></div>
        </figure>
      </div>
      <p class="mt-2 text-xs text-slate-400">Both curves have a discontinuity (asymptote) at do = f = 10 cm, where 1/di would require dividing by zero — the image distance and magnification both shoot toward infinity as the object approaches the focal point.</p>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;

      // ---- calculator ----
      let solveFor = 'di';
      const modeBtns = { f: 'mode-f', do: 'mode-do', di: 'mode-di' };
      const fieldEls = { f: 'field-f', do: 'field-do', di: 'field-di' };
      const boxEls = { f: 'box-f', do: 'box-do', di: 'box-di' };

      function switchSolve(s) {
        solveFor = s;
        Object.keys(modeBtns).forEach((k) => {
          el(modeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(fieldEls).forEach((k) => {
          el(fieldEls[k]).style.opacity = k === s ? '0.45' : '1';
        });
        Object.keys(boxEls).forEach((k) => {
          el(boxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        update();
      }

      function classify(di, do_) {
        const type = di > 0 ? 'Real' : (di < 0 ? 'Virtual' : '—');
        const m = -di / do_;
        const orient = m < 0 ? 'inverted' : (m > 0 ? 'upright' : '—');
        const size = Math.abs(m) > 1 ? 'magnified' : (Math.abs(m) < 1 ? 'reduced' : 'same size');
        return { m, label: `${type}, ${orient}, ${size}` };
      }

      function update() {
        el('tl-err').textContent = '';
        el('tl-hint').textContent = '';
        ['r-f', 'r-do', 'r-di', 'r-m', 'r-type'].forEach((id) => (el(id).textContent = '—'));
        const f = parseFloat(el('f').value);
        const do_ = parseFloat(el('do').value);
        const di = parseFloat(el('di').value);

        if (solveFor === 'di') {
          if (isNaN(f) || isNaN(do_)) return;
          if (f === 0) { el('tl-err').textContent = 'Focal length cannot be zero.'; return; }
          if (do_ === 0) { el('tl-err').textContent = 'Object distance cannot be zero.'; return; }
          const inv = 1 / f - 1 / do_;
          if (inv === 0) { el('tl-err').textContent = 'The object is exactly at the focal point — rays emerge parallel and never converge; di is undefined (infinite).'; el('r-f').textContent = fmt(f); el('r-do').textContent = fmt(do_); return; }
          const ddi = 1 / inv;
          const { m, label } = classify(ddi, do_);
          el('r-f').textContent = fmt(f); el('r-do').textContent = fmt(do_); el('r-di').textContent = fmt(ddi);
          el('r-m').textContent = fmt(m); el('r-type').textContent = label;
        } else if (solveFor === 'do') {
          if (isNaN(f) || isNaN(di)) return;
          if (f === 0) { el('tl-err').textContent = 'Focal length cannot be zero.'; return; }
          if (di === 0) { el('tl-err').textContent = 'Image distance cannot be zero.'; return; }
          const inv = 1 / f - 1 / di;
          if (inv === 0) { el('tl-err').textContent = 'These values imply an object at infinity (parallel incoming rays) — do is undefined.'; return; }
          const ddo = 1 / inv;
          if (ddo <= 0) { el('tl-err').textContent = 'These f and di values do not correspond to a real object in front of the lens.'; return; }
          const { m, label } = classify(di, ddo);
          el('r-f').textContent = fmt(f); el('r-do').textContent = fmt(ddo); el('r-di').textContent = fmt(di);
          el('r-m').textContent = fmt(m); el('r-type').textContent = label;
        } else if (solveFor === 'f') {
          if (isNaN(do_) || isNaN(di)) return;
          if (do_ === 0 || di === 0) { el('tl-err').textContent = 'Object and image distances cannot be zero.'; return; }
          const inv = 1 / do_ + 1 / di;
          if (inv === 0) { el('tl-err').textContent = 'These distances imply an infinite focal length (no lens power).'; return; }
          const ff = 1 / inv;
          const { m, label } = classify(di, do_);
          el('r-f').textContent = fmt(ff); el('r-do').textContent = fmt(do_); el('r-di').textContent = fmt(di);
          el('r-m').textContent = fmt(m); el('r-type').textContent = label;
          el('tl-hint').textContent = ff > 0 ? 'Positive f: converging (convex) lens.' : 'Negative f: diverging (concave) lens.';
        }
      }
      el('mode-f').addEventListener('click', () => switchSolve('f'));
      el('mode-do').addEventListener('click', () => switchSolve('do'));
      el('mode-di').addEventListener('click', () => switchSolve('di'));
      ['f', 'do', 'di'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const F = 10;
        const L = [], DI = [], M = [];
        for (let d = 2; d <= 40; d += 1) {
          L.push(d.toString());
          const inv = 1 / F - 1 / d;
          if (Math.abs(inv) < 1e-6) { DI.push(null); M.push(null); continue; }
          const di = 1 / inv;
          DI.push(Math.abs(di) > 100 ? null : +di.toFixed(2));
          M.push(Math.abs(-di / d) > 10 ? null : +(-di / d).toFixed(3));
        }
        charts.di = new Chart(el('chart-di'), {
          type: 'line',
          data: { labels: L, datasets: [{ label: 'di (cm)', data: DI, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0, spanGaps: false }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'do (cm)' } }, y: { title: { display: true, text: 'di (cm)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.m = new Chart(el('chart-m'), {
          type: 'line',
          data: { labels: L, datasets: [{ label: 'm', data: M, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0, spanGaps: false }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'do (cm)' } }, y: { title: { display: true, text: 'magnification (m)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- static diagram helpers ----
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      function addLensPlane(s) {
        s.scene.add(new THREE.GridHelper(8, 8, 0xcbd5e1, 0xe2e8f0));
        const lensGeo = new THREE.CylinderGeometry(0.12, 0.12, 2.6, 16);
        const lensMat = new THREE.MeshStandardMaterial({ color: 0x93c5fd, transparent: true, opacity: 0.55 });
        const lens = new THREE.Mesh(lensGeo, lensMat);
        lens.rotation.z = Math.PI / 2;
        lens.position.set(0, 0, 0);
        s.scene.add(lens);
        const axisGeo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-4, 0, 0), new THREE.Vector3(4, 0, 0)]);
        const axisMat = new THREE.LineDashedMaterial({ color: 0x94a3b8, dashSize: 0.15, gapSize: 0.1 });
        const axisLine = new THREE.Line(axisGeo, axisMat);
        axisLine.computeLineDistances();
        s.scene.add(axisLine);
      }

      function addArrowObject(s, x, height, color) {
        s.scene.add(arrow(new THREE.Vector3(x, 0, 0), new THREE.Vector3(x, height, 0), color));
      }

      // ---- Diagram 1: converging lens, real inverted image ----
      let diagConverging = null;
      function initDiagConverging() {
        const c = el('diag-converging'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        addLensPlane(s);
        // object at do=-3 (scaled), height 1; image at di=1.5 (scaled), height -0.5 (inverted, reduced)
        const objX = -3, objH = 1.0;
        const imgX = 1.5, imgH = -0.5;
        addArrowObject(s, objX, objH, 0x334155);
        addArrowObject(s, imgX, imgH, 0x6366f1);
        // rays from object tip through lens to image tip
        const tip = new THREE.Vector3(objX, objH, 0);
        const centerHit = new THREE.Vector3(0, objH, 0);
        const imgTip = new THREE.Vector3(imgX, imgH, 0);
        s.scene.add(arrow(tip, centerHit, 0x94a3b8));
        s.scene.add(arrow(centerHit, imgTip, 0x94a3b8));
        const centerHit2 = new THREE.Vector3(0, 0, 0);
        s.scene.add(arrow(tip, centerHit2, 0xf59e0b));
        s.scene.add(arrow(centerHit2, imgTip, 0xf59e0b));

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagConverging = { resize: s.resize };
      }

      // ---- Diagram 2: object inside f, virtual upright image (magnifying glass) ----
      let diagDiverging = null;
      function initDiagDiverging() {
        const c = el('diag-diverging'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        addLensPlane(s);
        // object at do=-0.7 (inside f, scaled), height 0.6; virtual image at di=-1.4 (same side), height 1.2 (upright, magnified)
        const objX = -0.7, objH = 0.6;
        const imgX = -1.4, imgH = 1.2;
        addArrowObject(s, objX, objH, 0x334155);
        addArrowObject(s, imgX, imgH, 0xf59e0b);

        const tip = new THREE.Vector3(objX, objH, 0);
        const centerHit = new THREE.Vector3(0, objH, 0);
        const rayOutEnd = new THREE.Vector3(3, objH + (objH) * 1.6, 0);
        s.scene.add(arrow(tip, centerHit, 0x94a3b8));
        s.scene.add(arrow(centerHit, rayOutEnd, 0x94a3b8));
        // dashed backward projection to the virtual image
        const backGeo = new THREE.BufferGeometry().setFromPoints([centerHit, new THREE.Vector3(imgX, imgH, 0)]);
        const backMat = new THREE.LineDashedMaterial({ color: 0x6366f1, dashSize: 0.1, gapSize: 0.08 });
        const backLine = new THREE.Line(backGeo, backMat);
        backLine.computeLineDistances();
        s.scene.add(backLine);

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagDiverging = { resize: s.resize };
      }

      function boot() {
        try { switchSolve('di'); update(); } catch (e) { console.error('[thin-lens] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[thin-lens] charts failed', e); }
        if (window.THREE) {
          try { initDiagConverging(); } catch (e) { console.error('[thin-lens] converging diagram failed', e); }
          try { initDiagDiverging(); } catch (e) { console.error('[thin-lens] diverging diagram failed', e); }
        }
        mountResize([diagConverging, diagDiverging]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
