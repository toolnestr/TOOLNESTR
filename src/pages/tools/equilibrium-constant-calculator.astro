---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Equilibrium Constant (Keq) Calculator';
const description = 'Calculate the equilibrium constant Kc = [C]^c[D]^d / [A]^a[B]^b with a live 3D visualization and charts. Up to 2 reactants and 2 products, with worked examples.';
const intro = 'Enter coefficients and equilibrium concentrations for up to two reactants and two products to compute Kc, and see which side of the reaction is favored.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is the equilibrium constant Keq?', a: 'Keq (often written Kc when concentrations are used) is the ratio of product concentrations to reactant concentrations, each raised to its stoichiometric coefficient, once a reversible reaction has reached equilibrium: Kc = [C]^c[D]^d / [A]^a[B]^b. It is a fixed number for a given reaction at a given temperature.' },
  { q: 'What does a large or small Keq mean?', a: 'Kc >> 1 means the numerator dominates — at equilibrium, products are strongly favored (the reaction proceeds nearly to completion). Kc << 1 means reactants are favored — very little product forms. Kc ≈ 1 means comparable amounts of reactants and products are present at equilibrium.' },
  { q: 'Does Keq change if I add more reactant or product?', a: 'No. Keq is constant at a given temperature. Adding more reactant or product shifts the position of equilibrium (Le Chatelier\'s principle) — the system reacts to partially offset the change — but once it re-settles, the same Kc expression is satisfied again with new concentrations.' },
  { q: 'What is the difference between Kc and Kp?', a: 'Kc uses molar concentrations (mol/L); Kp uses partial pressures, typically for gas-phase reactions. They are related by Kp = Kc(RT)^Δn, where Δn is the change in moles of gas (products − reactants) and R, T are the gas constant and absolute temperature. This calculator computes Kc from concentrations.' },
  { q: 'What happens if I only have one reactant or one product?', a: 'Leave the second reactant or second product field blank. This calculator treats a blank species as absent — its concentration and exponent are excluded from the expression (equivalent to a factor of 1), so the formula automatically collapses to match reactions with just one species on that side.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Equilibrium Constant Calculator',
  description: 'Compute Kc from equilibrium concentrations and stoichiometric coefficients.',
  steps: [
    { name: 'Enter reactants', text: 'Type the coefficient and equilibrium concentration for reactant A, and optionally reactant B.' },
    { name: 'Enter products', text: 'Type the coefficient and equilibrium concentration for product C, and optionally product D.' },
    { name: 'Read Kc', text: 'The calculator computes Kc live and tells you whether products or reactants are favored.' },
  ],
};

const formulas = [
  { expr: 'K<sub>c</sub> = [C]<sup>c</sup>[D]<sup>d</sup> / [A]<sup>a</sup>[B]<sup>b</sup>', note: 'products over reactants, each raised to its coefficient' },
  { expr: 'K<sub>c</sub> ≫ 1 → products favored', note: 'K<sub>c</sub> ≪ 1 → reactants favored' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — ammonia synthesis', tone: 'slate',
    given: 'N₂ + 3 H₂ ⇌ 2 NH₃. At equilibrium: [N₂] = 0.50 M, [H₂] = 0.30 M, [NH₃] = 0.20 M.',
    rows: [
      { label: 'Numerator:', value: '[NH₃]² = (0.20)² = 0.0400' },
      { label: 'Denominator:', value: '[N₂]¹[H₂]³ = 0.50 × (0.30)³ = 0.50 × 0.0270 = 0.0135' },
      { label: 'Kc:', value: '0.0400 ÷ 0.0135 ≈ 2.963', full: true },
    ],
    note: 'Kc ≈ 2.96 is close to 1, so at this particular set of concentrations neither side is overwhelmingly favored.',
  },
  {
    title: 'Worked example 2 — simple 1:1 reaction', tone: 'amber',
    given: 'A ⇌ B. At equilibrium: [A] = 0.10 M, [B] = 0.40 M. Both coefficients are 1, and there is no second reactant or product.',
    rows: [
      { label: 'Kc:', value: 'Kc = [B]¹ ÷ [A]¹ = 0.40 ÷ 0.10 = 4' },
    ],
    note: 'Kc = 4 > 1 means product B is somewhat favored at equilibrium.',
  },
];

const comparison = {
  heading: 'Reading the size of Kc',
  note: 'The value of Kc tells you the position of equilibrium, not how fast it gets there.',
  headers: [{ label: 'Kc value' }, { label: 'Interpretation' }, { label: 'Illustrative example' }],
  rows: [
    ['Kc ≫ 1 (e.g. &gt; 10³)', 'Products strongly favored — reaction runs nearly to completion', 'Many combustion reactions'],
    ['Kc ≈ 1', 'Comparable amounts of reactants and products at equilibrium', 'Some gas-phase equilibria, e.g. certain isomerizations'],
    ['Kc ≪ 1 (e.g. &lt; 10⁻³)', 'Reactants strongly favored — very little product forms', 'Dissociation of weak acids in water'],
  ],
  highlightIndex: 1,
  footnote: 'These are conceptual bands, not fixed cutoffs — "large" and "small" are relative to the precision needed for the problem at hand.',
};

const realWorld = [
  { emoji: '🏭', title: 'Haber process (ammonia synthesis)', body: 'Industrial ammonia production (N₂ + 3H₂ ⇌ 2NH₃) is run at conditions chosen using Kc and Le Chatelier\'s principle to push the equilibrium toward more product while keeping the reaction rate practical.' },
  { emoji: '🧬', title: 'Biochemical equilibria', body: 'Enzyme-catalyzed reactions, oxygen binding to hemoglobin, and metabolic pathways all involve equilibrium constants that determine how far a reaction proceeds inside cells under physiological concentrations.' },
  { emoji: '🌫️', title: 'Environmental chemistry', body: 'Equilibrium constants describe how pollutants partition between air, water and soil, and how dissolved carbon dioxide equilibrates with carbonate species in oceans — central to modeling ocean acidification.' },
];

const misconceptions = [
  { claim: '"Adding more reactant changes Keq."', truth: 'Keq is constant at a fixed temperature. Adding reactant shifts the position of equilibrium — the system produces more product to partially counteract the change (Le Chatelier\'s principle) — but the same Kc expression is satisfied again with the new concentrations.' },
  { claim: '"A large Keq means the reaction is fast."', truth: 'Keq describes the equilibrium position (how far the reaction goes), not the rate at which it gets there. A reaction can have a huge Keq and still be extremely slow without a catalyst.' },
  { claim: '"Keq is the same as Kp."', truth: 'Kc uses concentrations and Kp uses partial pressures; they are numerically equal only when Δn = 0, and are otherwise related by Kp = Kc(RT)^Δn.' },
  { claim: '"If Kc = 1 the reaction hasn\'t started."', truth: 'Kc = 1 simply means products and reactants happen to be present in comparable amounts at equilibrium — the reaction has fully reached equilibrium, it just is not lopsided toward either side.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 13, Fundamental Equilibrium Concepts (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/13-1-chemical-equilibria" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 15, Chemical Equilibrium.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Chapter 13, Chemical Equilibrium.' },
];
const sourcesNote = 'A blank reactant or product field is treated as absent (excluded from the expression). Results are rounded for display.';

const howToUse = [
  { title: 'Enter reactants', body: 'Coefficient and equilibrium concentration for A, optionally B.' },
  { title: 'Enter products', body: 'Coefficient and equilibrium concentration for C, optionally D.' },
  { title: 'Read Kc', body: 'See the computed Kc and whether products or reactants are favored.' },
];

const related = [
  { href: '/tools/chemical-equation-balancer', emoji: '🧮', title: 'Chemical Equation Balancer', desc: 'Balance equations up to 4 species instantly.' },
  { href: '/tools/limiting-reagent-calculator', emoji: '⚖️', title: 'Limiting Reagent Calculator', desc: 'Find which reactant runs out first, plus excess.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'M = mol/L — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="at equilibrium, the ratio of product concentrations to reactant concentrations — each raised to its stoichiometric coefficient — settles at a fixed number, Kc, for a given reaction at a given temperature."
  howIntro="Kc &gt;&gt; 1 means the numerator (products) dominates the ratio, so the reaction proceeds nearly to completion. Kc &lt;&lt; 1 means the denominator (reactants) dominates, so very little product forms. A blank species field is treated as absent, so the expression naturally collapses for reactions with only one reactant or one product."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where equilibrium constants actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-xs text-slate-500">Leave a species' concentration blank to exclude it from the expression (useful for single-reactant or single-product reactions).</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 p-4">
        <h3 class="text-sm font-bold text-indigo-700">Reactants (denominator)</h3>
        <div class="mt-2 grid grid-cols-2 gap-2">
          <label class="block"><span class="text-xs font-medium text-slate-700">Coeff. a (A)</span>
            <input id="a-coeff" type="number" step="1" min="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">[A] mol/L</span>
            <input id="a-conc" type="number" step="any" min="0" placeholder="mol/L" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">Coeff. b (B)</span>
            <input id="b-coeff" type="number" step="1" min="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">[B] mol/L (optional)</span>
            <input id="b-conc" type="number" step="any" min="0" placeholder="blank = absent" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        </div>
      </div>
      <div class="rounded-xl border border-slate-200 p-4">
        <h3 class="text-sm font-bold text-green-700">Products (numerator)</h3>
        <div class="mt-2 grid grid-cols-2 gap-2">
          <label class="block"><span class="text-xs font-medium text-slate-700">Coeff. c (C)</span>
            <input id="c-coeff" type="number" step="1" min="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">[C] mol/L</span>
            <input id="c-conc" type="number" step="any" min="0" placeholder="mol/L" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">Coeff. d (D)</span>
            <input id="d-coeff" type="number" step="1" min="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">[D] mol/L (optional)</span>
            <input id="d-conc" type="number" step="any" min="0" placeholder="blank = absent" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        </div>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Equilibrium constant Kc</div><div id="r-kc" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Interpretation</div><div id="r-interp" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="keq-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: 3D sphere groups + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D reactants vs products</h2>
      <p class="mt-1 text-sm text-slate-500">Each group's size illustrates the relative equilibrium concentration on that side (illustrative, not a literal particle count). As Kc grows, the product group swells and the reactant group shrinks. Drag to orbit.</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Reactant concentration <span id="out-vreact" class="font-mono text-green-600">0.50 M</span></span>
          <input id="v-react" type="range" min="0.05" max="2" step="0.05" value="0.5" class="mt-2 w-full accent-green-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Product concentration <span id="out-vprod" class="font-mono text-green-600">0.50 M</span></span>
          <input id="v-prod" type="range" min="0.05" max="2" step="0.05" value="0.5" class="mt-2 w-full accent-green-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-green-50 p-3 text-center text-sm text-green-700">Live Kc (1:1) = <span id="out-vkc" class="font-mono font-bold">1.00</span></div>
      <div id="keq3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:320px;"></div>
      <p id="keq3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Equilibrium graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Reactant-side vs product-side magnitude</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-sides"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Kc vs [C] (fixed [A], [B], [D] and coefficients)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-kc"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function readSpecies(coeffId, concId) {
        const coeff = parseFloat(el(coeffId).value);
        const raw = el(concId).value;
        if (raw === '' || raw === null) return null; // absent species
        const conc = parseFloat(raw);
        if (isNaN(conc) || isNaN(coeff)) return null;
        return { coeff, conc };
      }
      function sideValue(species) {
        // species: array of {coeff, conc} or null; absent ones contribute factor 1
        let val = 1;
        for (const s of species) {
          if (!s) continue;
          val *= Math.pow(s.conc, s.coeff);
        }
        return val;
      }
      function updateCalc() {
        el('keq-err').textContent = '';
        el('r-kc').textContent = '—'; el('r-interp').textContent = '—';
        const A = readSpecies('a-coeff', 'a-conc');
        const B = readSpecies('b-coeff', 'b-conc');
        const C = readSpecies('c-coeff', 'c-conc');
        const D = readSpecies('d-coeff', 'd-conc');
        if (!A && !B) { return; } // need at least one reactant defined
        if (!C && !D) { return; } // need at least one product defined
        // validate negatives
        for (const s of [A, B, C, D]) { if (s && s.conc < 0) { el('keq-err').textContent = 'Concentrations cannot be negative.'; return; } }
        for (const s of [A, B, C, D]) { if (s && s.coeff <= 0) { el('keq-err').textContent = 'Coefficients must be positive.'; return; } }
        const num = sideValue([C, D]);
        const den = sideValue([A, B]);
        if (den === 0) { el('keq-err').textContent = 'Reactant concentration cannot be zero.'; return; }
        const kc = num / den;
        el('r-kc').textContent = fmt(kc);
        let interp = 'Comparable amounts (Kc ≈ 1)';
        if (kc > 10) interp = 'Products favored';
        else if (kc < 0.1) interp = 'Reactants favored';
        el('r-interp').textContent = interp;
        updateCharts();
      }
      ['a-coeff', 'a-conc', 'b-coeff', 'b-conc', 'c-coeff', 'c-conc', 'd-coeff', 'd-conc'].forEach((id) => el(id).addEventListener('input', updateCalc));

      // ---- 3D + charts state (independent live sliders, simple 1:1 illustration) ----
      function vState() {
        const react = parseFloat(el('v-react').value);
        const prod = parseFloat(el('v-prod').value);
        return { react, prod, kc: react > 0 ? prod / react : 0 };
      }
      let scene3d = null;
      const charts = {};
      function onSlider() {
        const s = vState();
        el('out-vreact').textContent = s.react.toFixed(2) + ' M';
        el('out-vprod').textContent = s.prod.toFixed(2) + ' M';
        el('out-vkc').textContent = fmt(s.kc);
        try { if (scene3d) scene3d.update(s); } catch (e) {}
        try { if (charts.ready) updateSideChart(s); } catch (e) {}
      }
      el('v-react').addEventListener('input', onSlider);
      el('v-prod').addEventListener('input', onSlider);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.sides = new Chart(el('chart-sides'), {
          type: 'bar',
          data: { labels: ['Reactant side', 'Product side'], datasets: [{ label: 'Concentration (M)', data: [0.5, 0.5], backgroundColor: ['#6366f1', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Concentration (M)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.kc = new Chart(el('chart-kc'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Kc', data: [], borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.25, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: '[C] (mol/L)' } }, y: { title: { display: true, text: 'Kc' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateSideChart(vState());
        updateKcChart();
      }
      function updateSideChart(s) {
        if (!charts.ready) return;
        charts.sides.data.datasets[0].data = [s.react, s.prod];
        charts.sides.update();
      }
      function updateKcChart() {
        if (!charts.ready) return;
        const A = readSpecies('a-coeff', 'a-conc') || { coeff: 1, conc: 0.5 };
        const B = readSpecies('b-coeff', 'b-conc');
        const cCoeff = parseFloat(el('c-coeff').value) || 1;
        const D = readSpecies('d-coeff', 'd-conc');
        const den = sideValue([A, B]);
        const L = [], Dd = [];
        for (let cc = 0.05; cc <= 2.001; cc += 0.05) {
          const num = Math.pow(cc, cCoeff) * (D ? Math.pow(D.conc, D.coeff) : 1);
          L.push(cc.toFixed(2)); Dd.push(den > 0 ? +(num / den).toFixed(4) : 0);
        }
        charts.kc.data.labels = L; charts.kc.data.datasets[0].data = Dd; charts.kc.update();
      }

      // ---- 3D sphere groups ----
      function initScene() {
        const c = el('keq3d'); if (!c) throw new Error('no keq3d container');
        const s = makeScene(c, 14, new THREE.Vector3(0, 0, 0), SCENE_OPTS);
        const matReact = new THREE.MeshStandardMaterial({ color: 0x6366f1 });
        const matProd = new THREE.MeshStandardMaterial({ color: 0x10b981 });
        const MAX_P = 60;
        const geo = new THREE.SphereGeometry(0.35, 12, 12);
        const pilesR = [], pilesP = [];
        for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(geo, matReact); p.visible = false; s.scene.add(p); pilesR.push(p); }
        for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(geo, matProd); p.visible = false; s.scene.add(p); pilesP.push(p); }

        function layout(pile, count, cx) {
          const perRow = 6;
          for (let i = 0; i < pile.length; i++) {
            const p = pile[i];
            if (i < count) {
              const row = Math.floor(i / perRow), col = i % perRow;
              p.position.set(cx + (col - (perRow - 1) / 2) * 0.85, row * 0.85 - 2, 0);
              p.visible = true;
            } else p.visible = false;
          }
        }
        function update(state) {
          const nR = Math.max(1, Math.min(MAX_P, Math.round(state.react * 40)));
          const nP = Math.max(1, Math.min(MAX_P, Math.round(state.prod * 40)));
          layout(pilesR, nR, -3.2);
          layout(pilesP, nP, 3.2);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0014); s.renderer.render(s.scene, s.camera); }
        frame();
        scene3d = { update, resize: s.resize };
        update(vState());
      }

      function boot() {
        try { el('a-conc').value = '0.50'; el('b-conc').value = ''; el('c-conc').value = '0.50'; el('d-conc').value = ''; updateCalc(); } catch (e) { console.error('[equilibrium-constant] calc init failed', e); }
        try { onSlider(); } catch (e) { console.error('[equilibrium-constant] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[equilibrium-constant] charts failed', e); }
        if (window.THREE) {
          try { initScene(); } catch (e) { console.error('[equilibrium-constant] scene failed', e); el('keq3d-fallback').classList.remove('hidden'); }
        } else { el('keq3d-fallback').classList.remove('hidden'); }
        mountResize([scene3d]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
