---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Drywall Calculator';
const description = 'Calculate the number of drywall sheets needed for walls and ceilings from room dimensions. Estimate material costs for your next renovation or build project.';
const intro = 'Estimate how many drywall sheets you need for walls and ceilings in any room.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'What size drywall sheet should I use?', a: '4x8 ft sheets are standard for most rooms. 4x10 ft sheets reduce horizontal joints on 9-ft ceilings. 4x12 ft sheets work best for long walls. Thickness is typically 1/2 inch for walls and 5/8 inch for fire-rated ceilings.' },
  { q: 'How much does a sheet of drywall weigh?', a: 'A 4x8 ft sheet of 1/2-inch drywall weighs about 54 lbs. A 5/8-inch sheet weighs about 70 lbs. 4x12 ft sheets weigh significantly more and require two people to install safely.' },
  { q: 'How many screws do I need per sheet?', a: 'For walls, use about 28-32 screws per 4x8 sheet (screws every 12 inches along studs). For ceilings, use 32-36 screws per sheet (every 12 inches along joists, 6 inches on edges).' },
  { q: 'Do I need tapered edge or square edge?', a: 'Tapered edge (most common) has recessed edges for joint tape and compound, creating a smooth finished surface. Square edge is used for double-layer applications or as a base layer where the taper is not needed.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4">
      <span class="text-sm font-medium text-slate-700">Include</span>
      <div class="mt-1 flex flex-wrap gap-2">
        {['Walls only', 'Ceiling only', 'Walls & ceiling'].map((opt) => (
          <button data-opt={opt} class="opt-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{opt}</button>
        ))}
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Room length (ft)</span>
        <input id="length" type="number" step="any" placeholder="14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Room width (ft)</span>
        <input id="width" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall height (ft)</span>
        <input id="height" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Sheet size</span>
        <select id="sheet" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 text-sm">
          <option value="32">4x8 ft (32 sq ft)</option>
          <option value="40">4x10 ft (40 sq ft)</option>
          <option value="48">4x12 ft (48 sq ft)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Drywall sheets needed</div>
        <div id="r-sheets" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-waste" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Total area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Wall area</div><div id="r-walls" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Ceiling area</div><div id="r-ceil" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="drywall-title drywall-desc">
      <title id="drywall-title">Drywall wall layout diagram</title>
      <desc id="drywall-desc">A wall elevation showing drywall sheet outlines with studs behind them</desc>
      <rect x="80" y="60" width="600" height="240" fill="#f8fafc" stroke="#cbd5e1" stroke-width="2" rx="4" />
      <g stroke="#e2e8f0" stroke-width="1.5">
        <line x1="80" y1="180" x2="680" y2="180" />
        <line x1="240" y1="60" x2="240" y2="180" />
        <line x1="400" y1="60" x2="400" y2="180" />
        <line x1="560" y1="60" x2="560" y2="180" />
        <line x1="160" y1="180" x2="160" y2="300" />
        <line x1="320" y1="180" x2="320" y2="300" />
        <line x1="480" y1="180" x2="480" y2="300" />
        <line x1="640" y1="180" x2="640" y2="300" />
      </g>
      <g fill="#6366f1" opacity="0.08">
        <rect x="80" y="60" width="160" height="120" rx="2" />
        <rect x="240" y="60" width="160" height="120" rx="2" />
        <rect x="400" y="60" width="160" height="120" rx="2" />
        <rect x="560" y="60" width="120" height="120" rx="2" />
        <rect x="80" y="180" width="160" height="120" rx="2" />
        <rect x="240" y="180" width="160" height="120" rx="2" />
        <rect x="400" y="180" width="160" height="120" rx="2" />
        <rect x="560" y="180" width="120" height="120" rx="2" />
      </g>
      <g stroke="#6366f1" stroke-width="0.5" opacity="0.3">
        <line x1="80" y1="120" x2="680" y2="120" />
        <line x1="120" y1="60" x2="120" y2="300" />
        <line x1="200" y1="60" x2="200" y2="300" />
        <line x1="280" y1="60" x2="280" y2="300" />
        <line x1="360" y1="60" x2="360" y2="300" />
        <line x1="440" y1="60" x2="440" y2="300" />
        <line x1="520" y1="60" x2="520" y2="300" />
        <line x1="600" y1="60" x2="600" y2="300" />
      </g>
      <text x="380" y="340" text-anchor="middle" font-size="13" fill="#64748b" font-family="system-ui,sans-serif">Drywall sheets are installed horizontally with staggered joints for strength</text>
      <text x="380" y="250" text-anchor="middle" font-size="11" fill="#94a3b8" font-family="system-ui,sans-serif">4 ft sheet</text>
      <text x="160" y="155" text-anchor="middle" font-size="11" fill="#94a3b8" font-family="system-ui,sans-serif">8 ft sheet</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Drywall sheet layout on a wall — 4x8 ft sheets installed horizontally over studs</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the drywall calculator works</h2>
    <p class="mt-2 text-slate-600">
      The drywall calculator estimates the number of drywall sheets needed for a room based on its length, width, wall height, and the sheet size. You can choose to calculate for walls only, ceiling only, or both. The tool calculates the total surface area and divides by the sheet area, adding 10% for waste.
    </p>
    <p class="mt-3 text-slate-600">
      Standard drywall sheets are 4 feet wide and come in lengths of 8, 10, or 12 feet. The 4x8 sheet is the most common and covers 32 square feet. Taller walls benefit from 10 or 12-ft sheets to reduce horizontal joints and the amount of taping and mudding needed. The calculator works with any sheet size.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the room</h3>
        <p class="mt-1 text-sm text-slate-600">Get the length, width, and ceiling height. Include closets and alcoves in your measurements.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose surfaces</h3>
        <p class="mt-1 text-sm text-slate-600">Select walls, ceiling, or both. Choose a sheet size that matches your wall height.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Order materials</h3>
        <p class="mt-1 text-sm text-slate-600">Use the sheet count plus 10% for waste. Add joint compound, tape, screws, and corner bead.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Wall area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Walls = 2 &times; (L + W) &times; H</span>. For a 14&prime; &times; 12&prime; room with 8&prime; walls: 2 &times; (14 + 12) &times; 8 = <strong>416 sq ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Ceiling area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Ceiling = L &times; W</span>. 14 &times; 12 = <strong>168 sq ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Sheets needed</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Sheets = ceil(total area / sheet area &times; 1.1)</span>. With walls and ceiling: (416 + 168) = 584 sq ft. Using 4x8 (32 sq ft) sheets: 584 / 32 = 18.25. With 10% waste: 18.25 &times; 1.1 = 20.08, round to <strong>21 sheets</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 16&prime; &times; 14&prime; bedroom with 9-ft ceilings, using 4x10 ft sheets. Walls and ceiling included.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Wall area:</span> <span class="text-slate-600">2 &times; (16 + 14) &times; 9 = 540 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Ceiling:</span> <span class="text-slate-600">16 &times; 14 = 224 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Total:</span> <span class="text-slate-600">540 + 224 = 764 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Sheets (4x10):</span> <span class="text-slate-600">764 / 40 = 19.1 &times; 1.1 = <strong>21 sheets</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the drywall calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Room renovation</h3>
        <p class="mt-1 text-sm text-slate-600">Replace old damaged drywall or finish a basement room. Calculate each room separately to build a complete material list for the entire renovation project, including waste and supplies.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">New construction</h3>
        <p class="mt-1 text-sm text-slate-600">Builders order drywall by the truckload for new homes. Calculate all rooms and common areas, then add 10% for waste. Order full pallets (40-50 sheets each) to minimize per-sheet cost.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏪</span>
        <h3 class="mt-2 font-semibold text-slate-900">Commercial spaces</h3>
        <p class="mt-1 text-sm text-slate-600">Offices, retail stores, and commercial buildings often use 5/8-inch fire-rated drywall. The calculator works for any sheet size and room dimensions, supporting large open floor plans.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🛠️</span>
        <h3 class="mt-2 font-semibold text-slate-900">DIY project</h3>
        <p class="mt-1 text-sm text-slate-600">Homeowners finishing a garage, attic, or shed can use the calculator to estimate materials accurately. Small rooms may only need 4-8 sheets, making this an ideal DIY project with manageable material costs.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for drywall installation</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Hang horizontally for strength</h3>
        <p class="mt-1 text-sm text-slate-600">In most regions, drywall is hung horizontally (perpendicular to studs) for stronger walls with fewer vertical joints. Horizontal hanging also makes the taper joints run horizontally, which are easier to finish smoothly. Vertical hanging is used in vaulted ceilings or narrow spaces.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Stagger joints between rows</h3>
        <p class="mt-1 text-sm text-slate-600">When installing multiple rows of drywall, stagger the vertical joints so they do not line up. Joints that align create a weak line in the wall that can crack. Staggering by at least one stud bay distributes the structural stress and hides joint lines better.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use the right screw length</h3>
        <p class="mt-1 text-sm text-slate-600">Use 1-1/4 inch screws for 1/2-inch drywall on wood studs. Use 1-5/8 inch screws for 5/8-inch drywall or when attaching to metal studs. Drive screws slightly below the paper surface without breaking the paper — a dimple about 1/16 inch deep is ideal for mud coverage.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/insulation-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Insulation Calculator</a>
      <a href="/tools/square-footage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
      <a href="/tools/paint-coverage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Paint Coverage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'both';

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      const H = parseFloat(el('height').value);
      const sheetSf = parseFloat(el('sheet').value);
      if (!L || !W || !H || L <= 0 || W <= 0 || H <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const walls = 2 * (L + W) * H;
      const ceil = L * W;
      let total = 0;
      if (mode === 'walls') total = walls;
      else if (mode === 'ceiling') total = ceil;
      else total = walls + ceil;
      const sheets = Math.ceil((total / sheetSf) * 1.1);
      el('r-sheets').textContent = sheets.toLocaleString() + ' sheets';
      el('r-waste').textContent = '(incl. 10% waste)';
      el('r-area').textContent = total.toFixed(0) + ' sq ft';
      el('r-walls').textContent = walls.toFixed(0) + ' sq ft';
      el('r-ceil').textContent = ceil.toFixed(0) + ' sq ft';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.opt-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.opt-btn').forEach((b) => {
          b.className = 'opt-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50';
        });
        btn.className = 'opt-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
        mode = btn.dataset.opt === 'Walls only' ? 'walls' : btn.dataset.opt === 'Ceiling only' ? 'ceiling' : 'both';
        update();
      });
    });

    ['length', 'width', 'height', 'sheet'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
    el('sheet').addEventListener('change', update);
    document.querySelector('.opt-btn').click();
  </script>
</ToolLayout>
