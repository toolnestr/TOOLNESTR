---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Carton CBM & Container Loading Estimator';
const description = 'Calculate a shipping carton\'s CBM (cubic meters) from its dimensions, and estimate how many cartons fit a standard shipping container.';
const intro = 'Calculate carton CBM and how many cartons your shipment fits in a standard container.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is CBM in shipping?', a: 'CBM (Cubic Meters) is a carton\'s volume — length × width × height in meters — used to calculate ocean and air freight charges, since freight is priced by volume (or weight, whichever is greater) rather than just item count.' },
  { q: 'How many CBM fit in a standard shipping container?', a: 'A 20-foot container holds roughly 28-30 CBM of usable space (about 33 CBM total, reduced for real-world stacking/access), and a 40-foot container roughly 58-60 usable CBM — this calculator uses the standard usable-capacity figures for both.' },
  { q: 'Why don\'t cartons ever fill 100% of a container\'s CBM?', a: 'Cartons are rectangular boxes packed into a rectangular container, but pallets, load bars, and irregular final-row stacking always leave some unused space — real-world loading efficiency is typically 85-92% of the container\'s theoretical maximum, which this calculator accounts for.' },
  { q: 'Should I calculate CBM using outer or inner carton dimensions?', a: 'Always use outer carton dimensions (as the box is packed for shipping) since that\'s the space it actually occupies in the container, not the smaller inner packed-goods dimensions.' },
];
const howTo = {
  name: 'How to calculate CBM and container loading',
  steps: [
    { name: 'Enter carton dimensions', text: 'Length, width, and height in centimeters, using outer carton measurements.' },
    { name: 'Enter number of cartons', text: 'The total cartons in your shipment.' },
    { name: 'Choose a container size', text: '20ft or 40ft standard container.' },
    { name: 'Read total CBM and fit', text: 'Total shipment volume and whether it fits the chosen container.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Carton length (cm)</span>
        <input id="l" type="number" step="any" placeholder="e.g. 60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Carton width (cm)</span>
        <input id="w" type="number" step="any" placeholder="e.g. 40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Carton height (cm)</span>
        <input id="h" type="number" step="any" placeholder="e.g. 40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Number of cartons</span>
      <input id="qty" type="number" step="1" placeholder="e.g. 200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    <div class="mt-4 flex gap-2">
      {['20ft (~28 CBM)', '40ft (~58 CBM)'].map((d) => (
        <button data-mode={d} class="mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">{d}</button>
      ))}
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total shipment CBM</div>
        <div id="r-cbm" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">CBM per carton</div><div id="r-carton" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div id="r-fit-box" class="rounded-xl p-3 text-center"><div class="text-sm text-slate-500">Container fit</div><div id="r-fit" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How CBM and container loading are calculated</h2>
    <p class="mt-2 text-slate-600">
      Each carton's CBM is its outer length × width × height, converted to meters: <span class="font-mono">CBM = (L × W × H in cm) ÷ 1,000,000</span>. Total shipment CBM is that figure multiplied by the number of cartons. This total is then compared against a standard container's usable capacity — roughly 28 CBM for a 20-foot container and 58 CBM for a 40-foot container, accounting for the real-world loading efficiency loss from pallets and stacking gaps, not the container's raw theoretical volume.
    </p>
    <p class="mt-3 text-slate-600">
      Freight forwarders quote ocean freight largely by CBM (or by weight for very dense cargo, whichever produces the higher "chargeable" figure), so an accurate CBM calculation directly determines shipping cost — underestimating carton size when planning a shipment risks a shipment that doesn't actually fit the booked container, forcing an expensive last-minute upgrade to a larger one or a second container.
    </p>
    <p class="mt-3 text-xs text-slate-400">CBM formula (L×W×H/1,000,000 per carton) and standard container usable-capacity figures follow standard freight-industry practice.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">200 cartons at 60 × 40 × 40 cm each, checking against a 20ft container.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">CBM per carton:</span> <span class="text-slate-600">(60×40×40) ÷ 1,000,000 = 0.096 CBM</span></div>
        <div><span class="font-medium text-slate-700">Total CBM:</span> <span class="text-slate-600">0.096 × 200 = <strong>19.2 CBM</strong></span></div>
        <div><span class="font-medium text-slate-700">20ft capacity:</span> <span class="text-slate-600">~28 CBM</span></div>
        <div><span class="font-medium text-slate-700">Fit:</span> <span class="text-slate-600"><strong>Fits, with room to spare</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Apparel is notoriously "volume-heavy but weight-light" cargo — bulky but not dense — which usually means it's CBM-limited rather than weight-limited when loading a container, unlike heavier goods that hit the container's weight limit long before filling its volume. This is why apparel shippers focus heavily on carton-size optimization and compression packing to fit more units per CBM.
    </p>
    <p class="mt-3 text-slate-600">
      Consolidating multiple smaller brands' shipments into a single shared container (LCL — Less-than-Container-Load) is a common strategy specifically when an individual shipment's CBM doesn't come close to filling a full container, since paying for an entire container's worth of space to ship a fraction of its capacity wastes money that shared LCL shipping avoids.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A 40ft container holds exactly twice the volume of a 20ft container." <strong class="text-slate-900">Slightly more than double.</strong> A 40ft container's usable CBM (~58) is a bit more than double a 20ft's (~28), since fixed loading-inefficiency losses are proportionally smaller in the larger box.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Container capacity is the container's raw dimensional volume." <strong class="text-slate-900">Real usable capacity is lower.</strong> Pallets, load bars, and imperfect stacking always leave some space unused — that's why usable-capacity figures, not raw container volume, are used for planning.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/apparel-shipping-cost-estimator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Packaging & Shipping Cost Estimator</a>
      <a href="/tools/aql-sampling-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">AQL Sampling & Lead Time Estimator</a>
      <a href="/tools/garment-cost-sheet-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Quick Cost Sheet Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let capacity = 28;

    function update() {
      const l = parseFloat(el('l').value);
      const w = parseFloat(el('w').value);
      const h = parseFloat(el('h').value);
      const qty = parseFloat(el('qty').value);
      if (!(l > 0 && w > 0 && h > 0 && qty > 0)) { el('results').classList.add('hidden'); return; }

      const cbmCarton = (l * w * h) / 1000000;
      const totalCbm = cbmCarton * qty;
      const fits = totalCbm <= capacity;

      el('r-carton').textContent = cbmCarton.toFixed(4) + ' CBM';
      el('r-cbm').textContent = totalCbm.toFixed(2) + ' CBM';
      el('r-fit').textContent = fits ? 'Fits (' + ((totalCbm / capacity) * 100).toFixed(0) + '% full)' : 'Exceeds capacity by ' + (totalCbm - capacity).toFixed(2) + ' CBM';
      el('r-fit-box').className = 'rounded-xl p-3 text-center ' + (fits ? 'bg-emerald-50' : 'bg-amber-50');
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach((b) => {
          b.className = 'mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50';
        });
        btn.className = 'mode-btn rounded-lg border border-rose-300 bg-rose-100 px-4 py-1.5 text-sm font-medium text-rose-700 transition';
        capacity = btn.dataset.mode.startsWith('20ft') ? 28 : 58;
        update();
      });
    });

    ['l', 'w', 'h', 'qty'].forEach((id) => el(id).addEventListener('input', update));
    document.querySelector('.mode-btn').click();
  </script>
</ToolLayout>
