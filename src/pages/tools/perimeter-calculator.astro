---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Perimeter Calculator';
const description = 'Calculate the perimeter of rectangles, squares, circles, and triangles.';
const intro = 'Find the perimeter of rectangles, squares, circles, and triangles from your measurements.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'What is the difference between perimeter and area?', a: 'Perimeter measures the distance around the outside of a shape. Area measures the space inside the shape. They use different units — perimeter in linear feet, area in square feet.' },
  { q: 'Why do I need to know the perimeter?', a: 'Perimeter is essential for buying fencing, baseboards, crown molding, edging, and any material that goes around the boundary of a space.' },
  { q: 'How do I measure perimeter for an irregular shape?', a: 'Measure each side individually and add them together. For curves, approximate with a piece of string and then measure the string length.' },
  { q: 'Does the calculator account for corners in baseboards?', a: 'Baseboard calculations should add about 10% extra for miter cut waste and corners. The perimeter gives you the linear footage needed before the waste factor.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex gap-2">
      {['Rectangle', 'Square', 'Circle', 'Triangle'].map((s) => (
        <button data-shape={s.toLowerCase()} class="shape-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{s}</button>
      ))}
    </div>
    <div id="rect-inputs" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="r-length" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="r-width" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="square-inputs" class="hidden grid gap-4 sm:grid-cols-1">
      <label class="block"><span class="text-sm font-medium text-slate-700">Side (ft)</span>
        <input id="s-side" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="circle-inputs" class="hidden grid gap-4 sm:grid-cols-1">
      <label class="block"><span class="text-sm font-medium text-slate-700">Radius (ft)</span>
        <input id="c-radius" type="number" step="any" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="triangle-inputs" class="hidden grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Side A (ft)</span>
        <input id="t-a" type="number" step="any" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Side B (ft)</span>
        <input id="t-b" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Side C (ft)</span>
        <input id="t-c" type="number" step="any" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Perimeter</div>
        <div id="r-perim" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Shape</div><div id="r-shape" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Inches</div><div id="r-inches" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="perim-title perim-desc">
      <title id="perim-title">Perimeter of a rectangle diagram</title>
      <desc id="perim-desc">A four-sided shape with sides labelled showing the perimeter formula as the sum of all sides</desc>
      <rect x="180" y="90" width="340" height="160" fill="#e0e7ff" stroke="#6366f1" stroke-width="3" rx="4" />
      <text x="350" y="180" text-anchor="middle" font-size="18" fill="#4338ca" font-family="system-ui,sans-serif" font-weight="bold">P = 2(L + W)</text>
      <line x1="180" y1="70" x2="520" y2="70" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="350" y="60" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Length (L)</text>
      <line x1="155" y1="90" x2="155" y2="250" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="142" y="175" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif" transform="rotate(-90 142 175)">Width (W)</text>
      <text x="525" y="130" font-size="13" fill="#6366f1" font-family="system-ui,sans-serif">Side</text>
      <text x="525" y="145" font-size="13" fill="#6366f1" font-family="system-ui,sans-serif">L</text>
      <text x="525" y="215" font-size="13" fill="#6366f1" font-family="system-ui,sans-serif">Side</text>
      <text x="525" y="230" font-size="13" fill="#6366f1" font-family="system-ui,sans-serif">L</text>
      <line x1="520" y1="110" x2="530" y2="110" stroke="#6366f1" stroke-width="1.5" />
      <line x1="520" y1="230" x2="530" y2="230" stroke="#6366f1" stroke-width="1.5" />
      <rect x="600" y="70" width="170" height="140" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="615" y="95" font-size="12" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Perimeter formulas</text>
      <text x="615" y="115" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Rectangle: 2(L+W)</text>
      <text x="615" y="133" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Square: 4s</text>
      <text x="615" y="151" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Circle: 2&pi;r</text>
      <text x="615" y="169" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Triangle: a+b+c</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The perimeter of a rectangle equals twice the sum of length and width</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the perimeter calculator works</h2>
    <p class="mt-2 text-slate-600">
      The perimeter calculator measures the total distance around any shape. For rectangles and squares, it adds up all four sides. For circles, it calculates the circumference using 2&pi;r. For triangles, it sums the three side lengths. The result is shown in feet and inches for practical construction use.
    </p>
    <p class="mt-3 text-slate-600">
      Perimeter is one of the most fundamental measurements in construction. It determines how much material you need for borders, edges, and boundaries. Whether you are installing baseboard trim around a room or building a fence around a property, the perimeter tells you the linear footage required.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose shape</h3>
        <p class="mt-1 text-sm text-slate-600">Select the shape that matches your space — rectangle, square, circle, or triangle.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter dimensions</h3>
        <p class="mt-1 text-sm text-slate-600">Type the side lengths or radius in feet. The calculator handles decimal values for precise measurements.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Get the perimeter</h3>
        <p class="mt-1 text-sm text-slate-600">Read the total perimeter in feet and inches. Use the linear footage to order trim, fencing, or edging.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Rectangle perimeter</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">P = 2(L + W)</span>. A room 14&prime; &times; 12&prime; has perimeter 2 &times; (14 + 12) = <strong>52 ft</strong>. This is the most used formula for baseboard, crown molding, and wall trim calculations.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Square perimeter</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">P = 4s</span>. A square patio with 10&prime; sides has perimeter 4 &times; 10 = <strong>40 ft</strong>. Squares are common in modern design and tile patterns.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Circle circumference</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">C = 2&pi;r</span>. A circular fountain with a 4&prime; radius has circumference 2 &times; &pi; &times; 4 ≈ <strong>25.13 ft</strong>. This measurement tells you the edging material needed.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Triangle perimeter</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">P = a + b + c</span>. A triangular garden with sides 6&prime;, 8&prime;, and 10&prime; has perimeter 6 + 8 + 10 = <strong>24 ft</strong>. The 3-4-5 triangle is common in construction for squaring corners.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A rectangular deck measuring 16&prime; &times; 12&prime; needs a border trim for a fascia board around the entire edge.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Perimeter:</span> <span class="text-slate-600">2 &times; (16 + 12) = 56 ft</span></div>
        <div><span class="font-medium text-slate-700">In inches:</span> <span class="text-slate-600">56 &times; 12 = 672 inches</span></div>
        <div><span class="font-medium text-slate-700">With 10% waste:</span> <span class="text-slate-600">56 &times; 1.1 = 61.6 ft</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the perimeter calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🪚</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baseboard and trim</h3>
        <p class="mt-1 text-sm text-slate-600">Calculate linear footage of baseboard, crown molding, chair rail, or shoe molding. Add 10% for miter cuts and waste. The perimeter of each room gives you the exact material length needed.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚧</span>
        <h3 class="mt-2 font-semibold text-slate-900">Fencing</h3>
        <p class="mt-1 text-sm text-slate-600">The perimeter of a property determines how much fencing material to buy. Measure along the property line, accounting for gates and corners. Enter the total in the rectangular mode for a quick estimate.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌿</span>
        <h3 class="mt-2 font-semibold text-slate-900">Garden edging</h3>
        <p class="mt-1 text-sm text-slate-600">Borders around flower beds and vegetable gardens need edging materials. Use the circle mode for circular beds and the rectangle mode for raised beds to get the exact linear footage.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Formwork and framing</h3>
        <p class="mt-1 text-sm text-slate-600">Concrete forms, foundation footings, and wall framing all require perimeter measurements to estimate lumber and forming material quantities accurately.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for measuring and using perimeter</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Account for waste in linear materials</h3>
        <p class="mt-1 text-sm text-slate-600">Baseboard, crown molding, and other trim materials come in standard lengths (typically 8-16 ft). Each joint creates waste from angled cuts. Add 10-15% to the raw perimeter to account for miter cut waste, damaged pieces, and future repairs.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Measure with a partner for accuracy</h3>
        <p class="mt-1 text-sm text-slate-600">For large rooms or outdoor perimeters, have one person hold the tape end while the other reads the measurement. A 100 ft tape measure is ideal for most rooms. For property lines, use a measuring wheel for greater efficiency.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Deduct openings for material estimates</h3>
        <p class="mt-1 text-sm text-slate-600">For baseboard and trim, subtract the width of door openings from the perimeter. A standard 36-inch door means 3 ft less baseboard. Window trim is measured separately as it goes around each window, not along the wall.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/square-footage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
      <a href="/tools/fence-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fence Calculator</a>
      <a href="/tools/deck-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Deck Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let currentShape = 'rectangle';

    function update() {
      let p = 0, shape = '—';
      if (currentShape === 'rectangle') {
        const L = parseFloat(el('r-length').value);
        const W = parseFloat(el('r-width').value);
        if (L > 0 && W > 0) { p = 2 * (L + W); shape = 'Rectangle'; }
      } else if (currentShape === 'square') {
        const s = parseFloat(el('s-side').value);
        if (s > 0) { p = 4 * s; shape = 'Square'; }
      } else if (currentShape === 'circle') {
        const r = parseFloat(el('c-radius').value);
        if (r > 0) { p = 2 * Math.PI * r; shape = 'Circle'; }
      } else if (currentShape === 'triangle') {
        const a = parseFloat(el('t-a').value);
        const b = parseFloat(el('t-b').value);
        const c = parseFloat(el('t-c').value);
        if (a > 0 && b > 0 && c > 0) { p = a + b + c; shape = 'Triangle'; }
      }
      if (p > 0) {
        el('r-perim').textContent = p.toFixed(2) + ' ft';
        el('r-shape').textContent = shape;
        el('r-inches').textContent = (p * 12).toFixed(1) + ' in';
        el('results').classList.remove('hidden');
      } else {
        el('results').classList.add('hidden');
      }
    }

    document.querySelectorAll('.shape-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.shape-btn').forEach((b) => {
          b.className = 'shape-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50';
        });
        btn.className = 'shape-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
        currentShape = btn.dataset.shape;
        ['rect', 'square', 'circle', 'triangle'].forEach((s) => {
          el(s + '-inputs').classList.toggle('hidden', s !== currentShape);
        });
        update();
      });
    });
    document.querySelector('.shape-btn').click();
  </script>
</ToolLayout>
