---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Work Calculator (Physics)';
const description = "Work calculator. Solve W = Fd cos(θ) for work done by a force at any angle, with worked examples and an angle-efficiency comparison table.";
const intro = 'Enter force, displacement, and the angle between them to find the work done using W = Fd cos(θ). Two 3D diagrams compare pulling at a shallow angle versus straight along the direction of motion, and charts show how work falls off as the angle increases.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is work in physics?', a: 'Work is done when a force moves an object over a distance. Only the component of force parallel to the displacement does work. The formula is W = F × d × cos(θ).' },
  { q: 'What units does work use?', a: 'Work is measured in joules (J) in the SI system, where 1 J = 1 N·m. In imperial units, work is measured in foot-pounds (ft·lb).' },
  { q: 'What happens when the force is perpendicular to displacement?', a: 'When θ = 90°, cos(90°) = 0, so no work is done at all. This is why carrying a heavy box horizontally does no work on the box — the supporting force is upward, but the displacement is horizontal.' },
  { q: 'Can work be negative?', a: 'Yes. When the force opposes the motion (θ between 90° and 270°), cos(θ) is negative, resulting in negative work. Friction and air resistance do negative work, removing energy from a system.' },
  { q: 'What is the difference between work and power?', a: 'Work is energy transferred, measured in joules. Power is the rate at which that work is done, measured in watts (1 W = 1 J/s) — a more powerful machine does the same work in less time.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Work Calculator',
  description: 'Solve W = Fd cos(θ) for the work done by a force applied at any angle to the direction of motion.',
  steps: [
    { name: 'Enter force and displacement', text: 'Provide the force magnitude and the distance moved.' },
    { name: 'Enter the angle', text: 'Provide the angle θ between the force direction and the direction of motion.' },
    { name: 'Read the result', text: 'Work done and the parallel force component solve instantly.' },
  ],
};

const formulas = [
  { expr: 'W = F·d·cos(θ)', note: 'work done — F = force (N), d = displacement (m), θ = angle between them' },
  { expr: 'F∥ = F·cos(θ)', note: 'the component of force parallel to the displacement — the only part that does work' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — pulling a sled at an angle', tone: 'slate',
    given: 'A person pulls a sled with a force of 50 N at 30° above the horizontal, over a distance of 20 m.',
    rows: [
      { label: 'Parallel component:', value: 'F∥ = F·cos(θ) = 50 × cos(30°) = 50 × 0.866 = 43.30 N' },
      { label: 'Formula:', value: 'W = F∥ × d' },
      { label: 'Result:', value: 'W = 43.30 × 20 = 866.0 J', full: true },
    ],
    note: 'Only the horizontal component of the pulling force (43.30 N) actually moves the sled forward — the rest of the 50 N is spent uselessly lifting.',
  },
  {
    title: 'Worked example 2 — the same force at 90° (no work at all)', tone: 'amber',
    given: 'The same 50 N force is now applied straight upward (θ = 90°) while the sled still moves 20 m horizontally.',
    rows: [
      { label: 'Parallel component:', value: 'F∥ = F·cos(90°) = 50 × 0 = 0 N' },
      { label: 'Formula:', value: 'W = F∥ × d' },
      { label: 'Result:', value: 'W = 0 × 20 = 0 J', full: true },
    ],
    note: 'A force purely perpendicular to the motion does zero work no matter how large it is — this is exactly why carrying a heavy box horizontally does no physics "work" on the box.',
  },
];

const comparison = {
  heading: 'How the angle affects work done (fixed F=50N, d=20m)',
  note: 'Work falls off following cos(θ), reaching exactly zero at 90° and going negative beyond that as the force starts opposing the motion.',
  headers: [{ label: 'Angle θ' }, { label: 'cos(θ)' }, { label: 'Work done' }],
  rows: [
    ['0° (fully aligned)', '1.000', '1000.0 J'],
    ['30° ★', '0.866', '866.0 J'],
    ['60°', '0.500', '500.0 J'],
    ['90° (perpendicular)', '0.000', '0.0 J'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Beyond 90°, cos(θ) turns negative and the force actively removes energy from the motion (negative work).',
};

const realWorld = [
  { emoji: '🏗️', title: 'Construction and material handling', body: 'Engineers calculate the work required to lift materials, push loads up ramps, or pull equipment — optimizing the pulling angle can meaningfully reduce the effective force needed for the job.' },
  { emoji: '⚙️', title: 'Mechanical linkage design', body: 'Levers, pulleys, and inclined planes are all analyzed through work principles to determine mechanical efficiency and the trade-off between force and distance.' },
  { emoji: '⚽', title: 'Sports biomechanics', body: 'Analyzing the work done by muscles during athletic movements helps optimize technique, since the angle of applied force strongly affects how much of that force translates into useful motion.' },
  { emoji: '📋', title: 'Physics education', body: "Demonstrating how the angle of applied force changes work output is one of the clearest ways to show that only the force component parallel to motion actually contributes energy." },
];

const misconceptions = [
  { claim: '"Applying more force always means more work is done."', truth: 'Only the component of force parallel to the direction of motion contributes to work — a very large force applied perpendicular to the motion does exactly zero work, no matter how strong it is.' },
  { claim: '"Holding a heavy object still requires doing work on it."', truth: 'Physics work requires displacement — holding a weight motionless involves zero displacement, so zero work is done on the object in the physics sense, even though it feels tiring (a biological, not physical, energy cost).' },
  { claim: '"Work is always positive."', truth: 'Work can be negative when the force opposes the direction of motion (angle greater than 90°) — friction is the classic example, always doing negative work on a moving object and removing energy from it.' },
  { claim: '"The angle is measured from the ground, not from the direction of motion."', truth: "The angle θ in W = Fd cos(θ) is always measured between the force vector and the displacement vector specifically — if an object moves at an angle itself, θ must account for that, not just the angle from a horizontal ground reference." },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 7, "Work and Kinetic Energy" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/7-1-work" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 7, Kinetic Energy and Work.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 7, Energy of a System.' },
];
const sourcesNote = 'W = F·d·cos(θ), F in newtons, d in metres, θ in degrees, W in joules. Results are rounded for display.';

const howToUse = [
  { title: 'Enter force and displacement', body: 'Provide the force magnitude in newtons and the distance moved in metres.' },
  { title: 'Enter the angle', body: 'Provide the angle between the force and the direction of motion, in degrees.' },
  { title: 'Read the result', body: 'Work done and the parallel force component solve live.' },
];

const related = [
  { href: '/tools/force-calculator', emoji: '💥', title: "Newton's Second Law (F=ma) Calculator", desc: 'Solve for force, mass, or acceleration.' },
  { href: '/tools/kinetic-energy-calculator', emoji: '⚡', title: 'Kinetic Energy Calculator', desc: 'KE=½mv² — solve for any variable.' },
  { href: '/tools/mechanical-efficiency-calculator', emoji: '⚙️', title: 'Mechanical Efficiency Calculator', desc: 'η = output/input × 100% — from work or power.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="only the part of a force that actually points along the direction of motion contributes any work — a force at an angle wastes part of its strength on a direction that never moves the object."
  howIntro="Work is defined as the dot product of the force and displacement vectors, W = F·d·cos(θ), which isolates exactly the component of force running parallel to the motion (F cos θ) and multiplies it by the distance traveled. At θ=0°, cos(θ)=1 and the full force contributes; at θ=90°, cos(θ)=0 and none of it does; beyond 90°, cos(θ) turns negative and the force actively opposes the motion, doing negative work that removes energy from the system."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where work-at-an-angle actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="force" type="number" step="any" placeholder="N" value="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Displacement (d)</span>
        <input id="dist" type="number" step="any" placeholder="m" value="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Angle (θ)</span>
        <input id="angle" type="number" step="any" placeholder="degrees" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Work done</div><div id="r-work" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Force component (F·cosθ)</div><div id="r-fcomp" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="work-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Angle changes how much force actually helps</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-angle" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Force applied at 30°</h3>
          <p class="mt-1 text-sm text-slate-600">Part of the force (amber arrow) is "wasted" lifting rather than pulling forward — only the parallel component (indigo) contributes to work.</p>
        </div>
        <div>
          <div id="diag-aligned" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Force fully aligned (0°)</h3>
          <p class="mt-1 text-sm text-slate-600">With the force pointed directly along the motion, its entire magnitude contributes — the most efficient possible angle.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Work graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Work vs angle (fixed F=50N, d=20m) — the cos(θ) falloff</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-angle"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Work vs displacement (fixed F=50N, θ=30°) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dist"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator (preserves original logic) ----
      function update() {
        const f = parseFloat(el('force').value);
        const d = parseFloat(el('dist').value);
        const a = parseFloat(el('angle').value);
        el('work-err').textContent = '';
        if (isNaN(f) || isNaN(d) || isNaN(a)) { el('r-work').textContent = '—'; el('r-fcomp').textContent = '—'; return; }
        const rad = (a * Math.PI) / 180;
        const fComp = f * Math.cos(rad);
        const work = fComp * d;
        el('r-fcomp').textContent = fmt(fComp) + ' N';
        el('r-work').textContent = fmt(work) + ' J';
      }
      ['force', 'dist', 'angle'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsA = [], dataA = [];
        for (let a = 0; a <= 120; a += 10) { labelsA.push(a); dataA.push(+(50 * Math.cos((a * Math.PI) / 180) * 20).toFixed(1)); }
        charts.angle = new Chart(el('chart-angle'), {
          type: 'line',
          data: { labels: labelsA, datasets: [{ label: 'W (J)', data: dataA, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Angle θ (degrees)' } }, y: { title: { display: true, text: 'Work (J)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsD = [], dataD = [];
        for (let d = 0; d <= 40; d += 4) { labelsD.push(d); dataD.push(+(50 * Math.cos((30 * Math.PI) / 180) * d).toFixed(1)); }
        charts.dist = new Chart(el('chart-dist'), {
          type: 'line',
          data: { labels: labelsD, datasets: [{ label: 'W (J)', data: dataD, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Displacement (m)' } }, y: { title: { display: true, text: 'Work (J)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function forceScene(container, angleDeg) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const block = new THREE.Mesh(new THREE.BoxGeometry(1.2, 1, 1), new THREE.MeshStandardMaterial({ color: 0x334155, roughness: 0.5 }));
        s.scene.add(block);
        const rad = (angleDeg * Math.PI) / 180;
        const fLen = 3;
        const tip = new THREE.Vector3(0.6 + fLen * Math.cos(rad), fLen * Math.sin(rad), 0);
        s.scene.add(arrow(new THREE.Vector3(0.6, 0, 0), tip, 0xf59e0b));
        if (angleDeg > 0) {
          s.scene.add(arrow(new THREE.Vector3(0.6, 0, 0), new THREE.Vector3(0.6 + fLen * Math.cos(rad), 0, 0), 0x6366f1));
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagAngle = null, diagAligned = null;
      function initDiagAngle() { const c = el('diag-angle'); if (!c) throw new Error('no container'); diagAngle = forceScene(c, 30); }
      function initDiagAligned() { const c = el('diag-aligned'); if (!c) throw new Error('no container'); diagAligned = forceScene(c, 0); }

      function boot() {
        try { update(); } catch (e) { console.error('[work] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[work] charts failed', e); }
        if (window.THREE) {
          try { initDiagAngle(); } catch (e) { console.error('[work] angle diagram failed', e); }
          try { initDiagAligned(); } catch (e) { console.error('[work] aligned diagram failed', e); }
        }
        mountResize([diagAngle, diagAligned]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
