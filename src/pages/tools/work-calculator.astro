---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Work Calculator (Physics)';
const description = 'Free online work calculator. Calculate work done by a force at any angle using W = F × d × cos(θ). SI and imperial units supported.';
const intro = 'Enter force, displacement, and the angle between them to find the work done.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is work in physics?', a: 'Work is done when a force moves an object over a distance. Only the component of force parallel to the displacement does work. The formula is W = F × d × cos(θ).' },
  { q: 'What units does work use?', a: 'Work is measured in joules (J) in the SI system. 1 J = 1 N·m. In imperial units, work is measured in foot-pounds (ft·lb).' },
  { q: 'What happens when the force is perpendicular to displacement?', a: 'When θ = 90°, cos(90°) = 0, so no work is done. This is why carrying a heavy box horizontally does no work on the box — the force is upward, but displacement is horizontal.' },
  { q: 'Can work be negative?', a: 'Yes. When the force opposes the motion (θ between 90° and 270°), cos(θ) is negative, resulting in negative work. Friction and air resistance do negative work, removing energy from the system.' },
  { q: 'What is the difference between work and power?', a: 'Work is energy transferred, measured in joules. Power is the rate at which work is done, measured in watts (W = J/s). A powerful machine does the same work in less time.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter three values to calculate the work done</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="force" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Displacement (d)</span>
        <input id="dist" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Angle (θ)</span>
        <input id="angle" type="number" step="any" placeholder="degrees" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="work-result" class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Work done</div><div id="r-work" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Force component (F·cosθ)</div><div id="r-fcomp" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="work-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="work-title work-desc">
      <title id="work-title">Block pushed at an angle with force vector diagram</title>
      <desc id="work-desc">A block on a horizontal surface with a force vector F applied at angle θ above the horizontal, showing the parallel component F cos θ doing the work</desc>
      <g transform="translate(40,30)">
        <rect x="200" y="100" width="180" height="120" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2.5"/>
        <text x="290" y="165" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">Block</text>
        <line x1="100" y1="220" x2="500" y2="220" stroke="#94a3b8" stroke-width="3"/>
        <text x="300" y="260" text-anchor="middle" fill="#64748b" font-size="13">Displacement →</text>
        <line x1="200" y1="220" x2="480" y2="220" stroke="#cbd5e1" stroke-width="2" stroke-dasharray="6 3"/>
        <line x1="380" y1="100" x2="200" y2="50" stroke="#ef4444" stroke-width="3" stroke-linecap="round"/>
        <polygon points="200,40 185,60 200,50" fill="#ef4444" transform="rotate(-25 200 45)"/>
        <text x="170" y="40" fill="#ef4444" font-size="18" font-weight="bold">F</text>
        <path d="M 380 90 Q 360 70 330 80" stroke="#f59e0b" stroke-width="1.5" fill="none" stroke-dasharray="4 2"/>
        <text x="340" y="70" fill="#f59e0b" font-size="14" font-weight="bold">θ</text>
        <line x1="380" y1="100" x2="490" y2="100" stroke="#10b981" stroke-width="2" stroke-linecap="round"/>
        <text x="500" y="105" fill="#10b981" font-size="14" font-weight="bold">F·cos θ</text>
        <text x="550" y="105" fill="#64748b" font-size="12">(parallel component)</text>
        <text x="300" y="20" text-anchor="middle" fill="#4338ca" font-size="22" font-weight="bold">W = F × d × cos(θ)</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">A force F applied at angle θ to the horizontal displaces the block. Only the parallel component F·cos(θ) does work.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How work is calculated</h2>
    <p class="mt-2 text-slate-600">The work done by a constant force is the product of the force magnitude, the distance moved, and the cosine of the angle between the force and displacement vectors: <span class="font-mono">W = F × d × cos(θ)</span>. Work is a scalar quantity measured in joules. When the force is in the same direction as the motion (θ = 0°), cos(0) = 1 and W = F × d, which is the maximum work possible for a given force and distance.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A person pulls a sled with a force of 50 N at an angle of 30° above the horizontal for 20 metres. How much work is done?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Force:</span> <span class="text-slate-600">50 N</span></div>
        <div><span class="font-medium text-slate-700">Displacement:</span> <span class="text-slate-600">20 m</span></div>
        <div><span class="font-medium text-slate-700">Angle:</span> <span class="text-slate-600">30°</span></div>
        <div><span class="font-medium text-slate-700">Parallel component:</span> <span class="text-slate-600">50 × cos(30°) = 43.30 N</span></div>
        <div><span class="font-medium text-slate-700">Work done:</span> <span class="text-slate-600">W = 43.30 × 20 = 866 J</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3D7;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Construction Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the work required to lift materials, push loads up ramps, or pull equipment. Optimise lifting angles to reduce the effective force needed for the job.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F6B2;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Mechanical Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Design mechanical linkages and actuators by calculating the work input and output. Use work principles to determine the efficiency of levers, pulleys, and inclined planes.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x26BD;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sports Biomechanist</h3>
      <p class="mt-1 text-sm text-slate-600">Analyse the work done by muscles during athletic movements. Optimise technique by finding the angle that maximizes effective force and minimises wasted energy.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4CB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Physics Educator</h3>
      <p class="mt-1 text-sm text-slate-600">Demonstrate how the angle of applied force affects work output. Show that only the parallel force component contributes to work, explaining why pulling at an angle is less efficient.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the work calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the force</h3>
        <p class="mt-1 text-sm text-slate-600">Type the magnitude of the applied force in newtons. This is the total force being applied, regardless of its direction.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter distance and angle</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the displacement in metres and the angle in degrees between the force direction and the direction of motion.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">See the work done</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator shows the total work done in joules and the effective force component parallel to displacement. Adjust the angle to see how it affects the result.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for work calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Angle is measured from the displacement direction</h3>
        <p class="mt-1 text-sm text-slate-600">The angle θ is always measured from the displacement vector toward the force vector. If the force is pushing downward while the object moves horizontally, the angle is measured from the horizontal.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Work is energy transfer</h3>
        <p class="mt-1 text-sm text-slate-600">Positive work adds energy to the system, negative work removes it. The net work done on an object equals its change in kinetic energy (work-energy theorem). This is a powerful concept for analysing motion.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use the calculator for efficiency analysis</h3>
        <p class="mt-1 text-sm text-slate-900">Compare the work done at different angles to find the most efficient direction for applying force. A small change in angle can significantly reduce the useful work output.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/force-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4A5;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Force Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">F = ma — solve for any variable.</p>
      </a>
      <a href="/tools/kinetic-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x26A1;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Kinetic Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">KE = ½mv² — solve for any variable.</p>
      </a>
      <a href="/tools/projectile-motion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F3AF;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Projectile Motion Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Range, height, and time from launch speed.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });
    function update() {
      const f = parseFloat(el('force').value);
      const d = parseFloat(el('dist').value);
      const a = parseFloat(el('angle').value);
      el('work-err').textContent = '';
      if (isNaN(f) || isNaN(d) || isNaN(a)) { el('r-work').textContent = '—'; el('r-fcomp').textContent = '—'; return; }
      const rad = a * Math.PI / 180;
      const fComp = f * Math.cos(rad);
      const work = fComp * d;
      el('r-fcomp').textContent = fmt(fComp);
      el('r-work').textContent = fmt(work);
    }
    ['force', 'dist', 'angle'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
