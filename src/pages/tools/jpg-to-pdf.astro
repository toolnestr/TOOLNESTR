---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'JPG to PDF';
const description =
  'Free JPG to PDF converter. Turn JPG, PNG and WebP images into a single PDF, in the ' +
  'order you choose. Private and fast — images are converted in your browser, never uploaded.';
const intro =
  'Add your images, set the order and page size, then create a PDF. Everything runs in your browser, so your photos never leave your device.';
const category = { id: 'pdf', name: 'PDF Tools' };
const faqs = [
  { q: 'Which image formats are supported?', a: 'JPG and PNG are embedded directly. Other formats like WebP are converted automatically, so you can mix image types in one PDF.' },
  { q: 'Are my images uploaded?', a: 'No. The conversion happens entirely in your browser — your images stay on your device.' },
  { q: 'Can I choose the page size?', a: 'Yes. Pick "Fit to image" for a borderless page that matches each image, or "A4" to place each image on a standard page.' },
  { q: 'Can I put several images in one PDF?', a: 'Yes — add as many as you like and arrange their order. Each image becomes one page.' },
  { q: 'Can I mix JPG and PNG in the same PDF?', a: 'Yes. The tool handles both formats and will automatically embed them correctly on each page.' },
  { q: 'What if my image is very large?', a: 'Large images are scaled to fit the page. Use "Fit to image" mode to keep the original dimensions.' },
  { q: 'Can I reorder images after adding them?', a: 'Yes — use the up/down arrows on each image thumbnail to rearrange them before creating the PDF.' },
  { q: 'Will the image quality be reduced?', a: 'No. Images are embedded at full resolution in the PDF. The quality you see is the quality you get.' },
  { q: 'Can I add images one at a time?', a: 'Yes. Click the upload area again to add more images. They are appended to the existing list.' },
  { q: 'Does the tool support HEIC or BMP?', a: 'HEIC and BMP files are not directly supported. Convert them to JPG or PNG first, then add them to the tool.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="UtilitiesApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label for="file-input" class="flex cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 p-8 text-center transition hover:border-indigo-400 hover:bg-indigo-50/40">
      <span class="text-3xl">🖼️</span>
      <span class="mt-2 font-medium text-slate-700">Click to add images</span>
      <span class="mt-1 text-sm text-slate-400">JPG, PNG, WebP — each image becomes one page</span>
      <input id="file-input" type="file" accept="image/*" multiple class="hidden" />
    </label>

    <div class="mt-4 flex flex-wrap items-center gap-4">
      <label class="flex items-center gap-2 text-sm text-slate-700">
        Page size
        <select id="page-size" class="rounded-md border border-slate-300 px-2 py-1 text-sm">
          <option value="fit">Fit to image</option>
          <option value="a4">A4</option>
        </select>
      </label>
    </div>

    <ul id="file-list" class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3"></ul>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <button id="make-btn" disabled class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700 disabled:cursor-not-allowed disabled:opacity-40">Create PDF</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear all</button>
      <span id="status" class="text-sm text-slate-500"></span>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different image sizes mean</h2>
    <p class="mt-2 text-slate-600">Larger images produce higher quality PDF pages but use more memory during conversion.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Small</span><span class="text-slate-400">Up to 1 MP, loads and converts instantly</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Medium</span><span class="text-slate-400">1-5 MP, great for documents and forms</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:35%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Large</span><span class="text-slate-400">5-12 MP, suitable for high-quality prints</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:55%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Very large</span><span class="text-slate-400">12-24 MP, uses moderate memory</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:75%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Ultra high resolution</span><span class="text-slate-400">24+ MP, may slow down conversion</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:95%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📷</span>
      <h3 class="mt-2 font-semibold text-slate-900">Photographer</h3>
      <p class="mt-1 text-sm text-slate-600">Creates portfolio PDFs from their best shots to share with clients in a professional format.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Compiles scanned worksheets and handouts into a single PDF for classroom distribution.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💼</span>
      <h3 class="mt-2 font-semibold text-slate-900">Business professional</h3>
      <p class="mt-1 text-sm text-slate-600">Turns photos of receipts and business cards into an organised PDF archive for expense reporting.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎨</span>
      <h3 class="mt-2 font-semibold text-slate-900">Artist</h3>
      <p class="mt-1 text-sm text-slate-600">Combines high-resolution artwork images into a single PDF portfolio for gallery submissions.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Format</th><th class="p-3">Best for</th><th class="p-3">Embedding method</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">JPG / JPEG</td><td class="p-3">Photos, scans, colourful images</td><td class="p-3">Embedded directly as JPEG</td></tr>
        <tr><td class="p-3 font-medium">PNG</td><td class="p-3">Diagrams, screenshots, text, logos</td><td class="p-3">Embedded directly as PNG</td></tr>
        <tr><td class="p-3 font-medium">WebP</td><td class="p-3">Modern web-optimised images</td><td class="p-3">Converted to PNG first</td></tr>
        <tr><td class="p-3 font-medium">GIF</td><td class="p-3">Simple animations, low-colour images</td><td class="p-3">Converted to PNG first</td></tr>
        <tr><td class="p-3 font-medium">BMP</td><td class="p-3">Uncompressed legacy images</td><td class="p-3">Not supported, convert first</td></tr>
        <tr><td class="p-3 font-medium">TIFF</td><td class="p-3">High-quality print, scanned archives</td><td class="p-3">Not supported, convert first</td></tr>
        <tr><td class="p-3 font-medium">HEIC</td><td class="p-3">iPhone / Apple device photos</td><td class="p-3">Not supported, convert first</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the JPG to PDF converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Add your images</h3>
        <p class="mt-1 text-sm text-slate-600">Click the upload area and select one or more images from your device.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose page size and order</h3>
        <p class="mt-1 text-sm text-slate-600">Select "Fit to image" or "A4" and use arrows to rearrange your images.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Create and download</h3>
        <p class="mt-1 text-sm text-slate-600">Click "Create PDF" and your document downloads automatically.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for the best PDF output</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Choose the right page size</h3>
        <p class="mt-1 text-sm text-slate-600">Use "Fit to image" for borderless pages that match each image's original dimensions. Use "A4" when preparing for standard office printing.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Order images before creating</h3>
        <p class="mt-1 text-sm text-slate-600">Use the up/down arrows on each thumbnail to arrange images in the correct sequence before clicking "Create PDF". The order shown is the order in the PDF.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Mix formats freely</h3>
        <p class="mt-1 text-sm text-slate-600">JPG, PNG and WebP images can all be added together. The tool handles each format correctly and combines them into one seamless PDF.</p>
      </div>
    </div>
  </section>

  <script>
    import { PDFDocument } from 'pdf-lib';

    const input = document.getElementById('file-input');
    const list = document.getElementById('file-list');
    const makeBtn = document.getElementById('make-btn');
    const clearBtn = document.getElementById('clear-btn');
    const status = document.getElementById('status');
    const pageSizeSel = document.getElementById('page-size');

    let files = [];

    function render() {
      list.innerHTML = '';
      files.forEach((file, i) => {
        const li = document.createElement('li');
        li.className = 'relative overflow-hidden rounded-xl border border-slate-200 bg-slate-50';
        const url = URL.createObjectURL(file);
        li.innerHTML =
          `<img src="${url}" class="h-24 w-full object-cover" alt="">` +
          `<div class="flex items-center justify-between px-2 py-1">` +
          `<button data-up="${i}" class="rounded p-0.5 text-slate-500 hover:bg-slate-200" ${i === 0 ? 'disabled style=opacity:.3' : ''}>▲</button>` +
          `<span class="truncate px-1 text-[11px] text-slate-500">${i + 1}</span>` +
          `<button data-down="${i}" class="rounded p-0.5 text-slate-500 hover:bg-slate-200" ${i === files.length - 1 ? 'disabled style=opacity:.3' : ''}>▼</button>` +
          `<button data-del="${i}" class="rounded p-0.5 text-red-500 hover:bg-red-50">✕</button></div>`;
        list.appendChild(li);
      });
      makeBtn.disabled = files.length < 1;
      status.textContent = files.length ? `${files.length} image${files.length === 1 ? '' : 's'} ready` : '';
    }

    list.addEventListener('click', (e) => {
      const t = e.target.closest('button');
      if (!t) return;
      if (t.dataset.del !== undefined) files.splice(+t.dataset.del, 1);
      else if (t.dataset.up !== undefined) { const i = +t.dataset.up; [files[i - 1], files[i]] = [files[i], files[i - 1]]; }
      else if (t.dataset.down !== undefined) { const i = +t.dataset.down; [files[i + 1], files[i]] = [files[i], files[i + 1]]; }
      render();
    });

    input.addEventListener('change', () => {
      files = files.concat(Array.from(input.files));
      input.value = '';
      render();
    });
    clearBtn.addEventListener('click', () => { files = []; render(); });

    function toPngBytes(file) {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          canvas.getContext('2d').drawImage(img, 0, 0);
          canvas.toBlob((blob) => blob.arrayBuffer().then(resolve), 'image/png');
        };
        img.onerror = reject;
        img.src = URL.createObjectURL(file);
      });
    }

    makeBtn.addEventListener('click', async () => {
      if (!files.length) return;
      makeBtn.disabled = true;
      status.textContent = 'Creating PDF…';
      try {
        const pdf = await PDFDocument.create();
        const A4 = [595.28, 841.89];
        for (const file of files) {
          let image;
          if (file.type === 'image/jpeg') image = await pdf.embedJpg(await file.arrayBuffer());
          else if (file.type === 'image/png') image = await pdf.embedPng(await file.arrayBuffer());
          else image = await pdf.embedPng(await toPngBytes(file));

          if (pageSizeSel.value === 'a4') {
            const page = pdf.addPage(A4);
            const margin = 28;
            const maxW = A4[0] - margin * 2;
            const maxH = A4[1] - margin * 2;
            const scale = Math.min(maxW / image.width, maxH / image.height, 1);
            const w = image.width * scale;
            const h = image.height * scale;
            page.drawImage(image, { x: (A4[0] - w) / 2, y: (A4[1] - h) / 2, width: w, height: h });
          } else {
            const page = pdf.addPage([image.width, image.height]);
            page.drawImage(image, { x: 0, y: 0, width: image.width, height: image.height });
          }
        }
        const out = await pdf.save();
        const blob = new Blob([out], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'images.pdf';
        a.click();
        setTimeout(() => URL.revokeObjectURL(url), 5000);
        status.textContent = '✓ Done! Your PDF was downloaded.';
      } catch (err) {
        status.textContent = '⚠️ Could not create the PDF — one image may be unsupported or corrupted.';
      } finally {
        makeBtn.disabled = files.length < 1;
      }
    });

    render();
  </script>
</ToolLayout>
