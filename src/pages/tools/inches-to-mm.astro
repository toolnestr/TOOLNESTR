---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Inches to Mm"
  emoji="📏"
  fromUnit="inches" toUnit="millimeters"
  fromTitle="Inches" toTitle="Millimeters"
  fromSym="in" toSym="mm"
  quantity="length"
  kind="factor" factor={25.4}
  reverseSlug="mm-to-inches" reverseLabel="Mm to Inches Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Convert imperial drawings and hardware sizes into the millimeters used in metric workshops."
/>
