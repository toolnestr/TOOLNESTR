---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Gravitational Potential Energy Calculator';
const description = "Gravitational potential energy calculator. Solve PE = mgh for potential energy, mass, height, or gravity, with worked examples across different planets.";
const intro = 'Enter any three of potential energy, mass, height, or gravity to solve for the fourth using PE = mgh. Two 3D diagrams compare an object at low and high elevation, and charts show how potential energy scales with height and how it varies across different planets.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is gravitational potential energy?', a: 'Gravitational potential energy (PE) is the energy stored in an object due to its height above a reference point. The formula is PE = m × g × h, where g is the acceleration due to gravity.' },
  { q: 'What is "g" in the formula?', a: 'g is the acceleration due to gravity. On Earth, g ≈ 9.81 m/s². On the Moon, g ≈ 1.62 m/s². The value varies slightly with latitude and altitude on Earth, and dramatically across other planets and moons.' },
  { q: 'Where is the reference point for height measured from?', a: 'The reference point is arbitrary — typically ground level, sea level, or the floor. Only the difference in potential energy between two points matters physically, not the absolute value chosen.' },
  { q: 'Can potential energy be negative?', a: 'Yes, depending on the reference point chosen. If an object sits below the reference level, h is negative and PE becomes negative — only changes in PE carry physical significance.' },
  { q: 'What happens to PE when an object falls?', a: 'As an object falls, its potential energy converts into kinetic energy. Ignoring air resistance, total mechanical energy (PE + KE) stays constant: mgh₁ + ½mv₁² = mgh₂ + ½mv₂².' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Gravitational Potential Energy Calculator',
  description: 'Solve PE = mgh for potential energy, mass, height, or gravity from any three known values.',
  steps: [
    { name: 'Enter any three values', text: 'Provide potential energy, mass, height, or gravity — leave the unknown field blank.' },
    { name: 'Read the result', text: 'The missing value solves instantly using PE = mgh.' },
    { name: 'Try different planets', text: 'Change gravity to 1.62 for the Moon, 3.71 for Mars, or 24.79 for Jupiter to compare.' },
  ],
};

const formulas = [
  { expr: 'PE = mgh', note: 'gravitational potential energy — m in kg, g in m/s², h in metres' },
  { expr: 'h = PE / (mg)', note: 'rearranged to solve for height' },
  { expr: 'g = PE / (mh)', note: 'rearranged to solve for gravity' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a book on a shelf (Earth)', tone: 'slate',
    given: 'A 5 kg book sits on a shelf 2 m above the floor, on Earth (g = 9.81 m/s²).',
    rows: [
      { label: 'Formula:', value: 'PE = mgh' },
      { label: 'Substitute:', value: 'PE = 5 × 9.81 × 2' },
      { label: 'Result:', value: 'PE = 98.1 J', full: true },
    ],
    note: 'If the book fell, essentially all of this 98.1 J would convert into kinetic energy just before it hit the floor.',
  },
  {
    title: 'Worked example 2 — the same book on the Moon', tone: 'amber',
    given: 'The same 5 kg book at the same 2 m height, but now on the Moon (g = 1.62 m/s²).',
    rows: [
      { label: 'Formula:', value: 'PE = mgh' },
      { label: 'Substitute:', value: 'PE = 5 × 1.62 × 2' },
      { label: 'Result:', value: 'PE = 16.2 J — only about 16.5% of the Earth value', full: true },
    ],
    note: 'Identical mass and height, but the Moon\'s much weaker gravity (about 1/6th of Earth\'s) means far less stored potential energy — this is also why falls on the Moon feel so much gentler.',
  },
];

const comparison = {
  heading: 'The same object and height, across the solar system',
  note: 'A fixed 5 kg mass at 2 m height — only gravity changes, showing how strongly PE depends on the local gravitational field.',
  headers: [{ label: 'Body' }, { label: 'g (m/s²)' }, { label: 'PE (5 kg, 2 m)' }],
  rows: [
    ['Moon', '1.62', '16.2 J'],
    ['Mars', '3.71', '37.1 J'],
    ['Earth ★', '9.81', '98.1 J'],
    ['Jupiter', '24.79', '247.9 J'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). The same book stores over 15× more potential energy on Jupiter than on the Moon, purely from the difference in gravity.',
};

const realWorld = [
  { emoji: '🏗️', title: 'Civil and structural engineering', body: 'Engineers calculate the potential energy of elevated structures, dams, and retaining walls to assess stability, foundation loads, and the energy that would be released in a structural failure.' },
  { emoji: '⚡', title: 'Hydroelectric power generation', body: 'The potential energy of water stored at height in a reservoir is exactly what hydroelectric plants convert into electrical energy as the water falls through turbines.' },
  { emoji: '🎢', title: 'Roller coaster design', body: 'The potential energy at the top of a roller coaster\'s first drop directly determines the maximum speed reachable at the bottom, letting engineers design both a thrilling and a safe ride.' },
  { emoji: '🎓', title: 'Teaching energy conservation', body: 'The PE-to-KE conversion during a fall is one of the clearest, most intuitive demonstrations of the conservation of mechanical energy in introductory physics.' },
];

const misconceptions = [
  { claim: '"Potential energy is always positive."', truth: 'PE can be negative depending on where the reference height is set — an object below the chosen reference point has negative PE. Only differences in PE between two states are physically meaningful.' },
  { claim: '"Gravity (g) is the same everywhere in the universe."', truth: "g depends entirely on the mass and radius of the nearby body — it's about 9.81 m/s² on Earth, but only 1.62 m/s² on the Moon and roughly 24.79 m/s² on Jupiter." },
  { claim: '"An object always has more potential energy than kinetic energy."', truth: 'PE and KE trade off during motion — as an object falls, PE converts into KE, and at the instant just before impact, nearly all the original PE has become KE.' },
  { claim: '"Height must be measured from sea level."', truth: 'The reference point for height is arbitrary and can be chosen for convenience (floor, table, ground) — as long as it stays consistent throughout a single problem, the physics works out the same.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 8, "Potential Energy and Conservation of Energy" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/8-1-potential-energy-of-a-system" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 8, Potential Energy and Conservation of Energy.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 8, Conservation of Energy.' },
];
const sourcesNote = 'PE = mgh, m in kg, g in m/s², h in metres, PE in joules. Standard Earth gravity g=9.81 m/s² used by default. Results are rounded for display.';

const howToUse = [
  { title: 'Enter any three values', body: 'Provide PE, mass, height, or gravity — leave the unknown field blank.' },
  { title: 'Read the result', body: 'The missing value solves instantly using PE = mgh.' },
  { title: 'Try other planets', body: 'Swap in different gravity values to compare potential energy across the solar system.' },
];

const related = [
  { href: '/tools/kinetic-energy-calculator', emoji: '⚡', title: 'Kinetic Energy Calculator', desc: 'KE=½mv² — solve for any variable.' },
  { href: '/tools/free-fall-calculator', emoji: '⬇️', title: 'Free Fall Calculator', desc: 'Time and velocity under gravity.' },
  { href: '/tools/weight-on-other-planets-calculator', emoji: '🪐', title: 'Weight on Other Planets Calculator', desc: 'W = mg — compare your weight across the solar system.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="gravitational potential energy is stored energy tied directly to how far an object sits above a chosen reference height, in a gravitational field of a given strength — change any one of mass, gravity, or height, and the stored energy changes proportionally."
  howIntro="PE = mgh comes directly from the work needed to lift an object of mass m against gravity g through a height h: W = F×d = (mg)×h. Because that lifting work gets stored as potential energy, PE = mgh follows immediately. Since PE depends linearly on all three of mass, gravity, and height, doubling any one of them exactly doubles the stored potential energy — no quadratic relationships here, unlike kinetic energy's dependence on velocity."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where gravitational potential energy actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Enter any three values, leave one blank.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Potential energy (PE)</span>
        <input id="pe" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mass" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (h)</span>
        <input id="height" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gravity (g)</span>
        <input id="grav" type="number" step="any" placeholder="9.81 m/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">PE</div><div id="r-pe" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-mass" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Height</div><div id="r-height" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Gravity</div><div id="r-grav" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="pe-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Low vs high elevation</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-low" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Object at low elevation</h3>
          <p class="mt-1 text-sm text-slate-600">Sitting close to the reference ground level, this object stores very little gravitational potential energy.</p>
        </div>
        <div>
          <div id="diag-high" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Object at high elevation</h3>
          <p class="mt-1 text-sm text-slate-600">The same mass, lifted much higher, stores proportionally more potential energy — ready to convert into motion if released.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Potential energy graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">PE vs height (fixed 5 kg, Earth gravity) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-height"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">PE across the solar system (fixed 5 kg, 2 m height)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-planets"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator (preserves original three-of-four solve logic) ----
      function update() {
        const pe = parseFloat(el('pe').value);
        const m = parseFloat(el('mass').value);
        const h = parseFloat(el('height').value);
        const g = parseFloat(el('grav').value);
        const filled = [!isNaN(pe), !isNaN(m), !isNaN(h), !isNaN(g)];
        const count = filled.filter(Boolean).length;
        el('pe-err').textContent = '';
        ['r-pe', 'r-mass', 'r-height', 'r-grav'].forEach((id) => (el(id).textContent = '—'));
        if (count < 3) return;
        let rpe = NaN, rm = NaN, rh = NaN, rg = NaN;
        if (!filled[0]) { rpe = m * g * h; rm = m; rh = h; rg = g; }
        else if (!filled[1]) { rm = pe / (g * h); rpe = pe; rh = h; rg = g; }
        else if (!filled[2]) { if (g === 0) { el('pe-err').textContent = 'Gravity cannot be zero.'; return; } rh = pe / (m * g); rpe = pe; rm = m; rg = g; }
        else if (!filled[3]) { if (h === 0) { el('pe-err').textContent = 'Height cannot be zero when solving for g.'; return; } rg = pe / (m * h); rpe = pe; rm = m; rh = h; }
        if (!isNaN(rpe)) el('r-pe').textContent = fmt(rpe) + ' J';
        if (!isNaN(rm)) el('r-mass').textContent = fmt(rm) + ' kg';
        if (!isNaN(rh)) el('r-height').textContent = fmt(rh) + ' m';
        if (!isNaN(rg)) el('r-grav').textContent = fmt(rg) + ' m/s²';
      }
      ['pe', 'mass', 'height', 'grav'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsH = [], dataH = [];
        for (let h = 0; h <= 10; h += 1) { labelsH.push(h); dataH.push(+(5 * 9.81 * h).toFixed(1)); }
        charts.height = new Chart(el('chart-height'), {
          type: 'line',
          data: { labels: labelsH, datasets: [{ label: 'PE (J)', data: dataH, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Height (m)' } }, y: { title: { display: true, text: 'Potential energy (J)' } } }, plugins: { legend: { display: false } } }),
        });
        const bodies = [{ n: 'Moon', g: 1.62 }, { n: 'Mars', g: 3.71 }, { n: 'Earth', g: 9.81 }, { n: 'Jupiter', g: 24.79 }];
        charts.planets = new Chart(el('chart-planets'), {
          type: 'bar',
          data: { labels: bodies.map((b) => b.n), datasets: [{ label: 'PE (J)', data: bodies.map((b) => +(5 * b.g * 2).toFixed(1)), backgroundColor: ['#94a3b8', '#f59e0b', '#6366f1', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Potential energy (J)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function heightScene(container, boxY) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 1, 0), OPTS);
        const ground = new THREE.Mesh(new THREE.BoxGeometry(4, 0.2, 2), new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.6 }));
        ground.position.set(0, -0.1, 0); s.scene.add(ground);
        const obj = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.8, 0.8), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.4 }));
        obj.position.set(0, boxY, 0); s.scene.add(obj);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() { const c = el('diag-low'); if (!c) throw new Error('no container'); diagLow = heightScene(c, 0.5); }
      function initDiagHigh() { const c = el('diag-high'); if (!c) throw new Error('no container'); diagHigh = heightScene(c, 2.8); }

      function boot() {
        try { update(); } catch (e) { console.error('[potential-energy] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[potential-energy] charts failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[potential-energy] low diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[potential-energy] high diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
