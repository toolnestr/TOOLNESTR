---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Potential Energy Calculator';
const description = 'Free online gravitational potential energy calculator. Solve for PE, mass, height, or gravity using PE = mgh.';
const intro = 'Enter any three values — potential energy, mass, height, or gravity — to solve for the fourth.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is gravitational potential energy?', a: 'Gravitational potential energy (PE) is the energy stored in an object due to its height above a reference point. The formula is PE = m × g × h, where g is the acceleration due to gravity.' },
  { q: 'What is "g" in the formula?', a: 'g is the acceleration due to gravity. On Earth, g ≈ 9.81 m/s². On the Moon, g ≈ 1.62 m/s². The value varies slightly with latitude and altitude on Earth.' },
  { q: 'Where is the reference point for height?', a: 'The reference point is arbitrary — typically ground level, sea level, or the floor. Only the difference in potential energy matters in physics problems, not the absolute value.' },
  { q: 'Can potential energy be negative?', a: 'Yes, depending on the reference point. If an object is below the reference level, h is negative and PE becomes negative. Only changes in PE have physical significance.' },
  { q: 'What happens to PE when an object falls?', a: 'As an object falls, PE is converted into kinetic energy. At any point, total mechanical energy (PE + KE) is conserved if air resistance is ignored: mgh₁ + ½mv₁² = mgh₂ + ½mv₂².' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any three values, leave one blank</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Potential Energy (PE)</span>
        <input id="pe" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mass" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (h)</span>
        <input id="height" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gravity (g)</span>
        <input id="grav" type="number" step="any" placeholder="9.81 m/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="pe-result" class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Potential Energy</div><div id="r-pe" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-mass" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Height</div><div id="r-height" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Gravity</div><div id="r-grav" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="pe-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="pe-title pe-desc">
      <title id="pe-title">Object at height with gravitational potential energy</title>
      <desc id="pe-desc">An object of mass m at height h above ground level, with gravitational acceleration g downward and PE formula shown</desc>
      <g transform="translate(40,10)">
        <rect x="260" y="40" width="160" height="100" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2.5"/>
        <text x="340" y="95" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">m</text>
        <text x="340" y="115" text-anchor="middle" fill="#64748b" font-size="14">Mass</text>
        <line x1="340" y1="140" x2="340" y2="240" stroke="#f59e0b" stroke-width="2" stroke-dasharray="6 3"/>
        <polygon points="340,240 335,230 345,230" fill="#f59e0b"/>
        <text x="360" y="195" fill="#f59e0b" font-size="16" font-weight="bold">h</text>
        <text x="390" y="195" fill="#64748b" font-size="13">Height</text>
        <line x1="100" y1="240" x2="580" y2="240" stroke="#94a3b8" stroke-width="4"/>
        <text x="580" y="245" fill="#64748b" font-size="13">Ground (reference)</text>
        <path d="M 130 240 L 130 180" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round"/>
        <polygon points="130,175 125,185 135,185" fill="#ef4444"/>
        <text x="110" y="205" fill="#ef4444" font-size="14" font-weight="bold">g</text>
        <text x="160" y="205" fill="#64748b" font-size="12">Gravity</text>
        <text x="340" y="290" text-anchor="middle" fill="#4338ca" font-size="20" font-weight="bold">PE = m × g × h</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">An object of mass m at height h above ground stores gravitational potential energy PE = mgh</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How potential energy is calculated</h2>
    <p class="mt-2 text-slate-600">Gravitational potential energy is the energy stored in an object due to its position in a gravitational field. The formula <span class="font-mono">PE = m × g × h</span> multiplies mass, gravitational acceleration, and height above a reference level. The standard gravity on Earth is 9.81 m/s², though this varies slightly by location. The formula assumes g is constant — valid near the Earth's surface but not for large heights where g decreases significantly.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 5 kg book is on a shelf 2 metres above the floor. What is its gravitational potential energy?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Mass:</span> <span class="text-slate-600">5 kg</span></div>
        <div><span class="font-medium text-slate-700">Height:</span> <span class="text-slate-600">2 m</span></div>
        <div><span class="font-medium text-slate-700">Gravity:</span> <span class="text-slate-600">9.81 m/s²</span></div>
        <div><span class="font-medium text-slate-700">PE:</span> <span class="text-slate-600">5 × 9.81 × 2 = 98.1 J</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3D7;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Civil Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the potential energy of elevated structures, dams, and retaining walls. This is critical for assessing stability, foundation loads, and the energy released in a structural failure.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x26A1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Hydroelectric Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Determine the energy available from water stored at height in a reservoir. The potential energy of water is converted to electrical energy in hydroelectric power plants.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3B3;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Amusement Park Designer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the potential energy at the top of a roller coaster drop to determine the maximum speed at the bottom. This ensures the ride is both thrilling and safe.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Physics Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Demonstrate the conservation of mechanical energy. Show how PE converts to KE as objects fall, and use the calculator to compare different heights, masses, and gravity values.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the potential energy calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter three known values</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in any three of the four fields. Gravity defaults to 9.81 m/s² on Earth, but you can adjust it for other planets or moons.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Auto-calculated result</h3>
        <p class="mt-1 text-sm text-slate-600">The missing value is solved instantly. All four boxes display the complete set of values for easy comparison and verification.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Try different planets</h3>
        <p class="mt-1 text-sm text-slate-600">Change g to 1.62 for the Moon, 3.71 for Mars, or 24.79 for Jupiter. See how gravity affects potential energy across the solar system.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for potential energy calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Choose a consistent reference level</h3>
        <p class="mt-1 text-sm text-slate-600">In any problem, use the same reference level for all potential energy calculations. Only differences in PE matter, so the reference can be anywhere as long as it is consistent across the solution.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">g is not exactly 9.81 everywhere</h3>
        <p class="mt-1 text-sm text-slate-600">Standard gravity is 9.80665 m/s² at sea level at 45° latitude. At high altitudes or extreme latitudes, g can differ by up to 0.5%. For most engineering calculations, 9.81 is sufficiently accurate.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Combine with kinetic energy</h3>
        <p class="mt-1 text-sm text-slate-600">Use the kinetic energy calculator alongside this tool to track energy transformations. At the bottom of a fall, all PE (minus losses) becomes KE: v = √(2gh).</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/kinetic-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x26A1;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Kinetic Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">KE = ½mv² — solve for any variable.</p>
      </a>
      <a href="/tools/free-fall-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2B07;&#xFE0F;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Free Fall Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Time and velocity under gravity.</p>
      </a>
      <a href="/tools/gravitational-force-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F30D;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Gravitational Force Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Newton's law of universal gravitation.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });
    function update() {
      const pe = parseFloat(el('pe').value);
      const m = parseFloat(el('mass').value);
      const h = parseFloat(el('height').value);
      const g = parseFloat(el('grav').value);
      const filled = [!isNaN(pe), !isNaN(m), !isNaN(h), !isNaN(g)];
      const count = filled.filter(Boolean).length;
      el('pe-err').textContent = '';
      ['r-pe', 'r-mass', 'r-height', 'r-grav'].forEach(id => el(id).textContent = '—');
      if (count < 3) return;
      let rpe = NaN, rm = NaN, rh = NaN, rg = NaN;
      if (!filled[0]) { rpe = m * g * h; rm = m; rh = h; rg = g; }
      else if (!filled[1]) { rm = pe / (g * h); rpe = pe; rh = h; rg = g; }
      else if (!filled[2]) { if (g === 0) { el('pe-err').textContent = 'Gravity cannot be zero.'; return; } rh = pe / (m * g); rpe = pe; rm = m; rg = g; }
      else if (!filled[3]) { if (h === 0) { el('pe-err').textContent = 'Height cannot be zero when solving for g.'; return; } rg = pe / (m * h); rpe = pe; rm = m; rh = h; }
      if (!isNaN(rpe)) el('r-pe').textContent = fmt(rpe);
      if (!isNaN(rm)) el('r-mass').textContent = fmt(rm);
      if (!isNaN(rh)) el('r-height').textContent = fmt(rh);
      if (!isNaN(rg)) el('r-grav').textContent = fmt(rg);
    }
    ['pe', 'mass', 'height', 'grav'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
