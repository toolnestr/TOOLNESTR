---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Ovulation Calculator';
const description =
  'Estimate your ovulation day and fertile window from your last period and cycle length. Get a personalized fertility calendar for family planning.';
const intro =
  'Estimate your fertile window and ovulation day from your cycle.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  {
    q: 'When am I most fertile?',
    a: 'The few days before and on ovulation — roughly the 6-day fertile window this tool shows.',
  },
  {
    q: 'How accurate is this?',
    a: 'It is an estimate based on average timing; ovulation tests and tracking improve accuracy.',
  },
  {
    q: 'Can I use it as birth control?',
    a: 'No — it is not reliable for preventing pregnancy.',
  },
  {
    q: 'What if my cycle is irregular?',
    a: 'The estimate is less accurate for irregular cycles. Track multiple cycles for better predictions.',
  },
];
const sources = [
  { html: "<strong>NIH / National Institutes of Health</strong> and <strong>CDC</strong> reference values and formulas. <a href=\"https://www.nih.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nih.gov</a>" },
  { html: "<strong>Peer-reviewed equations</strong> (e.g. Mifflin-St Jeor, Harris-Benedict) as originally published." },
  { html: "<strong>ACOG</strong> for pregnancy, ovulation and due-date methodology. <a href=\"https://www.acog.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">acog.org</a>" },
];
const sourcesNote = "Not medical advice. Estimates only — consult a qualified healthcare professional for any personal health decision.";

---

<ToolLayout
  title={title}
  description={description}
  intro={intro}
  category={category}
  faqs={faqs}
 sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">First day of last period</span>
      <input id="lmp" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </label>
    <label class="mt-4 block">
      <span class="text-sm font-medium text-slate-700">Average cycle length (days)</span>
      <input id="cycle" type="number" min="21" max="35" value="28" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </label>
    <button id="calc" class="mt-4 w-full rounded-xl bg-indigo-600 py-3 font-medium text-white transition hover:bg-indigo-700">Calculate</button>

    <div id="result" class="mt-6 hidden space-y-3 rounded-xl bg-indigo-50 p-5">
      <p><span class="font-medium text-slate-700">Ovulation date:</span> <span id="ovulation" class="text-slate-900"></span></p>
      <p><span class="font-medium text-slate-700">Fertile window:</span> <span id="fertile" class="text-slate-900"></span></p>
      <p><span class="font-medium text-slate-700">Next period date:</span> <span id="next-period" class="text-slate-900"></span></p>
    </div>

    <p id="warning" class="mt-4 hidden rounded-xl bg-amber-50 p-3 text-sm text-amber-800"></p>

    <p class="mt-4 text-xs text-slate-400">Dates are not stored — everything runs in your browser.</p>
  </div>

  <p class="mt-4 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">
    For general information only — not medical or contraceptive advice.
  </p>

  <!-- Cycle timeline SVG -->
  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" role="img" aria-labelledby="ov-title ov-desc">
      <title id="ov-title">Ovulation cycle timeline</title>
      <desc id="ov-desc">Horizontal timeline showing the menstrual cycle phases: period, follicular phase, fertile window, ovulation, and luteal phase leading to the next period.</desc>
      <rect x="60" y="90" width="680" height="40" rx="6" fill="#e2e8f0" />
      <rect x="60" y="90" width="136" height="40" rx="6" fill="#f87171" />
      <rect x="196" y="90" width="136" height="40" fill="#fbbf24" />
      <rect x="332" y="90" width="136" height="40" fill="#34d399" />
      <rect x="468" y="90" width="68" height="40" fill="#6366f1" />
      <rect x="536" y="90" width="204" height="40" rx="6" fill="#a5b4fc" />
      <text x="128" y="80" text-anchor="middle" font-size="12" fill="#dc2626" font-weight="bold">Period</text>
      <text x="128" y="155" text-anchor="middle" font-size="11" fill="#64748b">Days 1–5</text>
      <text x="264" y="80" text-anchor="middle" font-size="12" fill="#ca8a04" font-weight="bold">Follicular</text>
      <text x="264" y="155" text-anchor="middle" font-size="11" fill="#64748b">Days 6–12</text>
      <text x="400" y="80" text-anchor="middle" font-size="12" fill="#16a34a" font-weight="bold">Fertile</text>
      <text x="400" y="155" text-anchor="middle" font-size="11" fill="#64748b">Days 13–18</text>
      <text x="502" y="80" text-anchor="middle" font-size="12" fill="#6366f1" font-weight="bold">Ovulation</text>
      <text x="502" y="155" text-anchor="middle" font-size="11" fill="#64748b">Day 14</text>
      <text x="638" y="80" text-anchor="middle" font-size="12" fill="#818cf8" font-weight="bold">Luteal phase</text>
      <text x="638" y="155" text-anchor="middle" font-size="11" fill="#64748b">Days 15–28</text>
      <rect x="60" y="180" width="12" height="12" rx="2" fill="#f87171" />
      <text x="78" y="191" font-size="11" fill="#64748b">Period</text>
      <rect x="140" y="180" width="12" height="12" rx="2" fill="#fbbf24" />
      <text x="158" y="191" font-size="11" fill="#64748b">Follicular</text>
      <rect x="230" y="180" width="12" height="12" rx="2" fill="#34d399" />
      <text x="248" y="191" font-size="11" fill="#64748b">Fertile window</text>
      <rect x="350" y="180" width="12" height="12" rx="2" fill="#6366f1" />
      <text x="368" y="191" font-size="11" fill="#64748b">Ovulation</text>
      <rect x="440" y="180" width="12" height="12" rx="2" fill="#a5b4fc" />
      <text x="458" y="191" font-size="11" fill="#64748b">Luteal</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">
      Typical 28-day menstrual cycle timeline showing each phase
    </figcaption>
  </figure>

  <!-- Formula section -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How ovulation is calculated</h2>
    <p class="mt-2 text-slate-600">
      The calculation is based on the standard 14-day luteal phase that most women experience. The luteal
      phase (the time between ovulation and the next period) is relatively fixed at about 14 days, regardless
      of total cycle length. Using this known constant, we can work backwards and forwards:
    </p>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Next period date</p>
        <p class="mt-1 text-slate-600">nextPeriod = lastPeriod + cycleLength</p>
        <p class="mt-1 text-sm text-slate-500">
          Simply add the number of days in your average cycle to the first day of your last period.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Ovulation date</p>
        <p class="mt-1 text-slate-600">ovulation = nextPeriod − 14</p>
        <p class="mt-1 text-sm text-slate-500">
          Subtract 14 days (the typical luteal phase length) from your predicted next period date.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Fertile window</p>
        <p class="mt-1 text-slate-600">fertile = ovulation − 5 to ovulation + 1</p>
        <p class="mt-1 text-sm text-slate-500">
          Sperm can survive up to 5 days in the reproductive tract, and the egg is viable for about 24 hours
          after ovulation. This gives you a 6-day fertile window.
        </p>
      </div>
    </div>
  </section>

  <!-- Worked example -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">
        Last period started June 1, with a 28-day cycle:
      </p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Last period start:</span> <span class="text-slate-600">June 1</span></div>
        <div><span class="font-medium text-slate-700">Cycle length:</span> <span class="text-slate-600">28 days</span></div>
        <div><span class="font-medium text-slate-700">Next period:</span> <span class="text-slate-600">June 1 + 28 days = <strong>June 29</strong></span></div>
        <div><span class="font-medium text-slate-700">Ovulation:</span> <span class="text-slate-600">June 29 − 14 days = <strong>June 15</strong></span></div>
        <div><span class="font-medium text-slate-700">Fertile window:</span> <span class="text-slate-600">June 15 − 5 to June 15 + 1 = <strong>June 10–16</strong></span></div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      The Ovulation Calculator is a quick way to estimate your fertile window. Whether you are planning
      a pregnancy or simply want to understand your cycle better, knowing when ovulation is likely to
      occur helps you make informed decisions.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">👶</span>
        <h3 class="mt-2 font-semibold text-slate-900">Planning conception</h3>
        <p class="mt-1 text-sm text-slate-600">
          Identify your fertile window so you can time intercourse for the days when pregnancy is most
          likely. The fertile window is the six days ending on ovulation day.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Tracking cycle phases</h3>
        <p class="mt-1 text-sm text-slate-600">
          Understand where you are in your cycle at any point. Knowing which phase you are in helps
          explain energy levels, mood changes, and physical symptoms.
        </p>
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accuracy</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Track multiple cycles</h3>
        <p class="mt-1 text-sm text-slate-600">
          Your cycle length may vary from month to month. Track at least three cycles to find your
          average before relying on the estimates. The more data you have, the more accurate the
          prediction becomes.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use ovulation test kits</h3>
        <p class="mt-1 text-sm text-slate-600">
          Ovulation predictor kits (OPKs) detect the surge in luteinising hormone (LH) that happens
          24–36 hours before ovulation. Combine this tool with OPKs around your estimated fertile
          window for much greater accuracy.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Cycles vary — this is an estimate</h3>
        <p class="mt-1 text-sm text-slate-600">
          The standard 14-day luteal phase is an average. Many women have luteal phases between 12
          and 16 days. If you already know your luteal phase length, you can adjust the ovulation
          formula accordingly for a more personalised result.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Not reliable as birth control</h3>
        <p class="mt-1 text-sm text-slate-600">
          This calculator is intended for conception planning and cycle education only. It should
          never be used as a method of contraception. Sperm can survive up to 5 days, so even
          intercourse outside the estimated fertile window can result in pregnancy.
        </p>
      </div>
    </div>
  </section>

  <!-- Related tools -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 grid gap-3 sm:grid-cols-3">
      <a href="/tools/ivf-due-date-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-indigo-600 transition hover:bg-indigo-50 hover:shadow-sm">IVF Due Date Calculator</a>
      <a href="/tools/water-intake-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-indigo-600 transition hover:bg-indigo-50 hover:shadow-sm">Water Intake Calculator</a>
      <a href="/tools/ideal-weight" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-indigo-600 transition hover:bg-indigo-50 hover:shadow-sm">Ideal Weight Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function fmt(d) {
      const opts = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
      return d.toLocaleDateString('en-US', opts);
    }

    function update() {
      const lmpVal = el('lmp').value;
      const cycleVal = parseInt(el('cycle').value, 10);
      const warning = el('warning');
      const result = el('result');

      if (!lmpVal || !cycleVal) {
        result.classList.add('hidden');
        warning.classList.add('hidden');
        return;
      }

      if (cycleVal < 21 || cycleVal > 35) {
        warning.textContent =
          'Cycle length ' + cycleVal + ' days is outside the typical 21–35 day range. Results may be less accurate.';
        warning.classList.remove('hidden');
      } else {
        warning.classList.add('hidden');
      }

      const lmp = new Date(lmpVal + 'T12:00:00');
      const nextPeriod = new Date(lmp);
      nextPeriod.setDate(nextPeriod.getDate() + cycleVal);
      const ovulation = new Date(nextPeriod);
      ovulation.setDate(ovulation.getDate() - 14);
      const fertileStart = new Date(ovulation);
      fertileStart.setDate(fertileStart.getDate() - 5);
      const fertileEnd = new Date(ovulation);
      fertileEnd.setDate(fertileEnd.getDate() + 1);

      el('ovulation').textContent = fmt(ovulation);
      el('fertile').textContent = fmt(fertileStart) + ' – ' + fmt(fertileEnd);
      el('next-period').textContent = fmt(nextPeriod);
      result.classList.remove('hidden');
    }

    el('calc').addEventListener('click', update);
    el('lmp').addEventListener('change', update);
    el('cycle').addEventListener('input', update);
  </script>
</ToolLayout>
