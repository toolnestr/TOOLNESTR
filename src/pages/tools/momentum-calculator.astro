---
import ToolLayout from '../../layouts/ToolLayout.astro';
import SubjectToolLibs from '../../components/SubjectToolLibs.astro';

const title = 'Momentum & Impulse Calculator';
const description = 'Momentum calculator with a live 3D momentum arrow and charts. Solve p = mv and the impulse–momentum theorem Δp = FΔt, with worked examples and collision physics.';
const intro = 'Solve p = mv, or switch to impulse mode for Δp = FΔt. A live 3D block carries a momentum arrow that grows with mass and speed, and charts show how impulse and collision time trade off.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };
const faqs = [
  { q: 'What is momentum?', a: 'Momentum (p) is mass times velocity: p = mv. It is a vector with units kg·m/s (equivalently N·s). The heavier or faster an object, the more momentum it carries, and the harder it is to stop.' },
  { q: 'What is impulse?', a: 'Impulse is the change in momentum produced by a force acting over a time interval: J = FΔt = Δp. It equals the area under a force–time graph, and shares momentum’s units (N·s = kg·m/s).' },
  { q: 'Why is momentum conserved in collisions?', a: "By Newton's third law the force each object exerts on the other is equal and opposite, and they act for the same time, so the impulses are equal and opposite. The total momentum of the system therefore does not change." },
  { q: 'What is the difference between elastic and inelastic collisions?', a: 'Momentum is conserved in both. In an elastic collision kinetic energy is also conserved; in an inelastic collision some kinetic energy is converted to heat, sound or permanent deformation.' },
  { q: 'How do airbags use the impulse–momentum theorem?', a: 'The change in momentum in a crash is fixed. Airbags and crumple zones stretch out the stopping time Δt, and since F = Δp/Δt, a longer time means a much smaller average force on the occupant — that is what reduces injury.' },
  { q: 'Is momentum the same as kinetic energy?', a: 'No. Momentum p = mv is linear in velocity and is a vector; kinetic energy KE = ½mv² is quadratic in velocity and is a scalar. Doubling speed doubles momentum but quadruples kinetic energy.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to use the Momentum & Impulse Calculator',
    description: 'Calculate momentum with p = mv, or impulse with the impulse–momentum theorem Δp = FΔt.',
    step: [
      { '@type': 'HowToStep', name: 'Pick a mode', text: 'Choose Momentum (p = mv) or Impulse (Δp = FΔt).' },
      { '@type': 'HowToStep', name: 'Enter two values', text: 'Type any two of the three quantities; the third solves instantly.' },
      { '@type': 'HowToStep', name: 'See it in 3D', text: 'Drag the mass and velocity sliders to watch the momentum arrow grow, and read the impulse–time trade-off in the charts.' },
    ],
  })} />

  <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
    <span class="h-2 w-2 rounded-full bg-blue-500"></span> Physics
  </span>

  <style is:global>
    @media print {
      .no-print { display: none !important; }
      a[href]::after { content: none !important; }
      section { break-inside: avoid; }
    }
  </style>

  <!-- ============ CALCULATOR ============ -->
  <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-momentum" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Momentum (p = mv)</button>
      <button id="mode-impulse" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Impulse (Δp = FΔt)</button>
    </div>
    <div id="momentum-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Momentum (p)</span>
        <input id="p" type="number" step="any" placeholder="kg·m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="m" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Velocity (v)</span>
        <input id="v" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="impulse-fields" class="hidden gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Impulse (Δp)</span>
        <input id="imp" type="number" step="any" placeholder="N·s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="f" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time (Δt)</span>
        <input id="t" type="number" step="any" placeholder="s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Momentum</div><div id="r-p" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Mass</div><div id="r-m" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Velocity</div><div id="r-v" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="mom-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ INTERACTIVE 3D MOMENTUM ============ -->
  <section class="mt-8 no-print">
    <h2 class="text-lg font-bold text-slate-900">Live 3D momentum</h2>
    <p class="mt-1 text-sm text-slate-500">Bigger mass = bigger block; faster velocity = faster motion. The green arrow length is the momentum p = mv. Drag to orbit (touch works too).</p>
    <div class="mt-3 grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Mass <span id="out-bmass" class="font-mono text-indigo-600">2.0 kg</span></span>
        <input id="b-mass" type="range" min="0.2" max="10" step="0.1" value="2" class="mt-2 w-full accent-indigo-600" />
      </label>
      <label class="block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Velocity <span id="out-bvel" class="font-mono text-indigo-600">3.0 m/s</span></span>
        <input id="b-vel" type="range" min="0" max="10" step="0.1" value="3" class="mt-2 w-full accent-indigo-600" />
      </label>
    </div>
    <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">Momentum p = <span id="out-bp" class="font-mono font-bold">6.00 kg·m/s</span></div>
    <div id="scene3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
    <p id="scene3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
  </section>

  <!-- ============ LIVE CHARTS ============ -->
  <section class="mt-10 no-print">
    <h2 class="text-lg font-bold text-slate-900">Momentum &amp; impulse graphs</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Momentum vs velocity (at your current mass) — a straight line</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pv"></canvas></div>
      </figure>
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Same stop, longer time = smaller force (F = Δp/Δt)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ft"></canvas></div>
      </figure>
      <figure class="sm:col-span-2">
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">How your object compares (approx. momentum, log scale)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:260px;"><canvas id="chart-compare"></canvas></div>
      </figure>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How momentum and impulse are calculated</h2>
    <p class="mt-2 text-slate-600"><strong>The core idea in one line:</strong> momentum measures "how hard something is to stop," and impulse is how you change it — a force applied for a length of time.</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <p class="font-mono text-sm text-slate-800">p = m · v</p>
        <p class="mt-1 text-sm text-slate-600"><strong>Momentum</strong> — mass times velocity. A vector: it points the way the object moves. Units kg·m/s.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <p class="font-mono text-sm text-slate-800">J = F · Δt = Δp</p>
        <p class="mt-1 text-sm text-slate-600"><strong>Impulse</strong> — average force times the time it acts, which equals the change in momentum. Units N·s (same as kg·m/s).</p>
      </div>
    </div>
    <p class="mt-4 text-slate-600">Rearranging the impulse–momentum theorem gives the result behind every piece of crash safety: <span class="font-mono text-slate-800">F = Δp / Δt</span>. Because Δp is fixed by how fast and heavy the object is, the only way to cut the force in a collision is to <strong>increase the stopping time</strong> — exactly what airbags, crumple zones, crash mats and bent knees all do.</p>

    <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 1 — kicking a football</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> a 0.45 kg ball is kicked from rest to 20 m/s, with the boot in contact for 0.05 s. Find the impulse and the average force.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Change in momentum:</span> <span class="text-slate-600">Δp = 0.45 · 20 = 9.00 kg·m/s</span></div>
        <div><span class="font-medium text-slate-700">Impulse:</span> <span class="text-slate-600">J = Δp = 9.00 N·s</span></div>
        <div class="sm:col-span-2"><span class="font-medium text-slate-700">Average force:</span> <span class="text-slate-600">F = Δp / Δt = 9 / 0.05 = 180 N</span></div>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 2 — why the airbag helps</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> a 70 kg driver moving at 14 m/s (~50 km/h) is brought to rest. Compare a hard stop against a dashboard (0.02 s) with an airbag stop (0.20 s).</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Change in momentum:</span> <span class="text-slate-600">Δp = 70 · 14 = 980 kg·m/s (both cases)</span></div>
        <div><span class="font-medium text-slate-700">Dashboard (0.02 s):</span> <span class="text-slate-600">F = 980 / 0.02 = 49,000 N</span></div>
        <div><span class="font-medium text-slate-700">Airbag (0.20 s):</span> <span class="text-slate-600">F = 980 / 0.20 = 4,900 N</span></div>
        <div class="sm:col-span-2 text-slate-600">Same momentum change, but a 10× longer stop means a 10× smaller force — the difference between a fatal and a survivable impact.</div>
      </div>
    </div>
  </section>

  <!-- ============ STANDALONE 3D DIAGRAMS ============ -->
  <section class="mt-12 no-print">
    <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <div>
        <div id="diag-collide" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">1. Total momentum is conserved</h3>
        <p class="mt-1 text-sm text-slate-600">A light fast block meets a heavy slow one. Whatever happens in the crash, the <strong>sum</strong> of their momenta afterwards equals the sum before — the momentum just gets redistributed, never lost.</p>
      </div>
      <div>
        <div id="diag-impulse" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">2. Impulse is force × time (the area)</h3>
        <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-red-500">tall thin</span> block (big force, short time) and the <span class="font-semibold text-sky-500">short wide</span> one (small force, long time) have the <strong>same area</strong> — the same impulse, so the same change in momentum.</p>
      </div>
    </div>
  </section>

  <!-- ============ COMPARISON TABLE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Momentum of some everyday things</h2>
    <p class="mt-1 text-sm text-slate-600">Approximate values, for a sense of scale of "how hard to stop."</p>
    <div class="mt-3 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full table-fixed text-center text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-2 py-2.5 text-left font-semibold sm:px-3">Object</th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Mass<span class="block text-[10px] font-normal text-slate-400">kg</span></th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Speed<span class="block text-[10px] font-normal text-slate-400">m/s</span></th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Momentum<span class="block text-[10px] font-normal text-slate-400">kg·m/s</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700 tabular-nums">
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Thrown tennis ball</td><td class="px-2 py-2.5 sm:px-3">0.06</td><td class="px-2 py-2.5 sm:px-3">25</td><td class="px-2 py-2.5 sm:px-3">1.5</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Kicked football</td><td class="px-2 py-2.5 sm:px-3">0.45</td><td class="px-2 py-2.5 sm:px-3">20</td><td class="px-2 py-2.5 sm:px-3">9</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Sprinter</td><td class="px-2 py-2.5 sm:px-3">70</td><td class="px-2 py-2.5 sm:px-3">10</td><td class="px-2 py-2.5 sm:px-3">700</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Car on the motorway</td><td class="px-2 py-2.5 sm:px-3">1500</td><td class="px-2 py-2.5 sm:px-3">30</td><td class="px-2 py-2.5 sm:px-3">45,000</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Loaded lorry</td><td class="px-2 py-2.5 sm:px-3">30,000</td><td class="px-2 py-2.5 sm:px-3">25</td><td class="px-2 py-2.5 sm:px-3">750,000</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ============ REAL-WORLD CONTEXT ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Where momentum actually matters</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🚗 Vehicle crash safety</h3>
        <p class="mt-1 text-sm text-slate-600">Crumple zones, airbags and seatbelts all exist to stretch the collision time. Since F = Δp/Δt, a longer stop turns a lethal force into a survivable one — the single most important application of the impulse–momentum theorem.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🚀 Rockets and recoil</h3>
        <p class="mt-1 text-sm text-slate-600">A rocket throws mass (exhaust) backwards and gains equal and opposite momentum forwards. The same conservation law explains gun recoil and why you drift backwards when you throw something on a skateboard.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">⚾ Sport technique</h3>
        <p class="mt-1 text-sm text-slate-600">"Follow through" is impulse in action: keeping the bat, racquet or boot in contact longer increases Δt and so delivers more momentum to the ball. Catching softly ("giving with the ball") does the reverse to protect the hands.</p>
      </div>
    </div>
  </section>

  <!-- ============ MISCONCEPTIONS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Momentum and kinetic energy are the same thing."</p>
        <p class="mt-1 text-sm text-slate-600">Momentum p = mv is linear in speed and is a vector; kinetic energy ½mv² is quadratic and a scalar. In an inelastic collision momentum is conserved but kinetic energy is not — they behave differently.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"A big force always means a big change in motion."</p>
        <p class="mt-1 text-sm text-slate-600">Only if it acts long enough. A huge force for a tiny time can deliver a small impulse; a gentle force sustained for a long time can deliver a large one. It's the product FΔt that changes momentum.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Momentum is destroyed when something stops."</p>
        <p class="mt-1 text-sm text-slate-600">It's transferred, not destroyed. A ball stopped by a wall passes its momentum to the wall and the Earth; the total momentum of the whole system is unchanged.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Direction doesn't matter for momentum."</p>
        <p class="mt-1 text-sm text-slate-600">Momentum is a vector. Two objects with equal and opposite momenta have a total of zero. When adding momenta you must include sign or direction — this calculator works with magnitudes, so track direction yourself.</p>
      </div>
    </div>
  </section>

  <!-- ============ FORMULA SOURCES ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Formula sources &amp; further reading</h2>
    <p class="mt-2 text-slate-600">Momentum and the impulse–momentum theorem are standard introductory mechanics, traceable to:</p>
    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      <li>• <strong>OpenStax, <em>University Physics Volume 1</em></strong> — §9.1–9.2 "Linear Momentum" and "Impulse and Collisions" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/9-2-impulse-and-collisions" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a></li>
      <li>• <strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 9, Center of Mass and Linear Momentum.</li>
      <li>• <strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 9, Linear Momentum and Collisions.</li>
    </ul>
    <p class="mt-3 text-xs text-slate-400">Results are rounded for display. Momentum and impulse share units: 1 N·s = 1 kg·m/s.</p>
  </section>

  <!-- ============ HOW TO USE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose the mode</h3>
        <p class="mt-1 text-sm text-slate-600">Momentum (p = mv) for standard problems, or Impulse (Δp = FΔt) for force–time work. The fields and labels switch automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter any two</h3>
        <p class="mt-1 text-sm text-slate-600">Fill two of the three fields and the third solves live.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Explore in 3D</h3>
        <p class="mt-1 text-sm text-slate-600">Use the mass and velocity sliders to feel how momentum grows, and watch the impulse–time trade-off in the charts.</p>
      </div>
    </div>
  </section>

  <!-- ============ RELATED TOOLS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/force-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">💥</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Force Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">F = ma — solve for any variable.</p>
      </a>
      <a href="/tools/kinetic-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">⚡</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Kinetic Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">KE = ½mv² — solve for any variable.</p>
      </a>
      <a href="/tools/projectile-motion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🎯</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Projectile Motion Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Range, height and time from launch speed.</p>
      </a>
    </div>
  </section>

  <!-- Libraries: Three.js + Chart.js + shared subject kit (window.STK) -->
  <SubjectToolLibs />

  <script is:inline>
  (function () {
    'use strict';
    const { el, reduceMotion, fmt2: fmt, makeScene, mountResize, chartSetup } = window.STK;
    const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

    // ================= CALCULATOR (preserves original two-mode logic) =================
    let mode = 'momentum';
    function switchMode(m) {
      mode = m;
      el('mode-momentum').className = m === 'momentum' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
      el('mode-impulse').className = m === 'impulse' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
      el('momentum-fields').className = m === 'momentum' ? 'grid gap-4 sm:grid-cols-3' : 'hidden';
      el('impulse-fields').className = m === 'impulse' ? 'grid gap-4 sm:grid-cols-3' : 'hidden gap-4 sm:grid-cols-3';
      el('lab-1').textContent = m === 'momentum' ? 'Momentum' : 'Impulse';
      el('lab-2').textContent = m === 'momentum' ? 'Mass' : 'Force';
      el('lab-3').textContent = m === 'momentum' ? 'Velocity' : 'Time';
      ['r-p', 'r-m', 'r-v'].forEach((id) => (el(id).textContent = '—'));
      el('mom-err').textContent = '';
    }
    function update() {
      el('mom-err').textContent = '';
      if (mode === 'momentum') {
        const p = parseFloat(el('p').value), m = parseFloat(el('m').value), v = parseFloat(el('v').value);
        const filled = [!isNaN(p), !isNaN(m), !isNaN(v)];
        ['r-p', 'r-m', 'r-v'].forEach((id) => (el(id).textContent = '—'));
        if (filled.filter(Boolean).length < 2) return;
        let rp = NaN, rm = NaN, rv = NaN;
        if (filled[0] && filled[1]) { if (m === 0) { el('mom-err').textContent = 'Mass cannot be zero.'; return; } rv = p / m; rp = p; rm = m; }
        else if (filled[0] && filled[2]) { if (v === 0) { el('mom-err').textContent = 'Velocity cannot be zero when solving for mass.'; return; } rm = p / v; rp = p; rv = v; }
        else if (filled[1] && filled[2]) { rp = m * v; rm = m; rv = v; }
        if (!isNaN(rp)) el('r-p').textContent = fmt(rp) + ' kg·m/s';
        if (!isNaN(rm)) el('r-m').textContent = fmt(rm) + ' kg';
        if (!isNaN(rv)) el('r-v').textContent = fmt(rv) + ' m/s';
      } else {
        const imp = parseFloat(el('imp').value), f = parseFloat(el('f').value), t = parseFloat(el('t').value);
        const filled = [!isNaN(imp), !isNaN(f), !isNaN(t)];
        ['r-p', 'r-m', 'r-v'].forEach((id) => (el(id).textContent = '—'));
        if (filled.filter(Boolean).length < 2) return;
        let ri = NaN, rf = NaN, rt = NaN;
        if (filled[0] && filled[1]) { if (f === 0) { el('mom-err').textContent = 'Force cannot be zero.'; return; } rt = imp / f; ri = imp; rf = f; }
        else if (filled[0] && filled[2]) { if (t === 0) { el('mom-err').textContent = 'Time cannot be zero.'; return; } rf = imp / t; ri = imp; rt = t; }
        else if (filled[1] && filled[2]) { ri = f * t; rf = f; rt = t; }
        if (!isNaN(ri)) el('r-p').textContent = fmt(ri) + ' N·s';
        if (!isNaN(rf)) el('r-m').textContent = fmt(rf) + ' N';
        if (!isNaN(rt)) el('r-v').textContent = fmt(rt) + ' s';
      }
    }
    el('mode-momentum').addEventListener('click', () => { switchMode('momentum'); update(); });
    el('mode-impulse').addEventListener('click', () => { switchMode('impulse'); update(); });
    ['p', 'm', 'v', 'imp', 'f', 't'].forEach((id) => el(id).addEventListener('input', update));

    // ================= 3D + charts shared state =================
    const charts = {};
    let block = null;
    function bState() {
      const mass = parseFloat(el('b-mass').value), vel = parseFloat(el('b-vel').value);
      return { mass, vel, p: mass * vel };
    }
    function onBChange() {
      const s = bState();
      el('out-bmass').textContent = s.mass.toFixed(1) + ' kg';
      el('out-bvel').textContent = s.vel.toFixed(1) + ' m/s';
      el('out-bp').textContent = fmt(s.p) + ' kg·m/s';
      try { if (block) block.update(s); } catch (e) {}
      try { if (charts.ready) updateCharts(s); } catch (e) {}
    }
    el('b-mass').addEventListener('input', onBChange);
    el('b-vel').addEventListener('input', onBChange);

    // ================= CHARTS =================
    function initCharts() {
      if (!window.Chart) return;
      const base = chartSetup();
      charts.pv = new Chart(el('chart-pv'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'p', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Velocity (m/s)' } }, y: { title: { display: true, text: 'Momentum (kg·m/s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.ft = new Chart(el('chart-ft'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'F', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Stopping time Δt (s)' } }, y: { title: { display: true, text: 'Average force (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.compare = new Chart(el('chart-compare'), {
        type: 'bar',
        data: {
          labels: ['Tennis ball', 'Football', 'Your object', 'Sprinter', 'Car', 'Lorry'],
          datasets: [{ label: 'Momentum (kg·m/s)', data: [1.5, 9, 6, 700, 45000, 750000], backgroundColor: ['#94a3b8', '#94a3b8', '#6366f1', '#94a3b8', '#94a3b8', '#94a3b8'] }],
        },
        options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Momentum (kg·m/s, log)' } } }, plugins: { legend: { display: false } } }),
      });
      charts.ready = true;
      updateCharts(bState());
    }
    function updateCharts(s) {
      if (!charts.ready) return;
      const L = [], D = [];
      for (let vv = 0; vv <= 10.001; vv += 1) { L.push(vv + ''); D.push(+(s.mass * vv).toFixed(2)); }
      charts.pv.data.labels = L; charts.pv.data.datasets[0].data = D; charts.pv.update();
      // F vs Δt to stop the current momentum
      const L2 = [], D2 = [];
      for (let tt = 0.05; tt <= 1.0001; tt += 0.05) { L2.push(tt.toFixed(2)); D2.push(+(s.p / tt).toFixed(2)); }
      charts.ft.data.labels = L2; charts.ft.data.datasets[0].data = D2; charts.ft.update();
      charts.compare.data.datasets[0].data[2] = +Math.max(s.p, 0.01).toFixed(2);
      charts.compare.update();
    }

    // ================= 3D momentum block =================
    function initScene3d() {
      const c = el('scene3d'); if (!c) throw new Error('no container');
      const s = makeScene(c, 14, new THREE.Vector3(0, 0.5, 0), OPTS);
      s.scene.add(new THREE.GridHelper(20, 20, 0xcbd5e1, 0xe2e8f0));
      let cube = null, arrowH = null, blk = { size: 1, x: -5 };
      const cubeMat = new THREE.MeshStandardMaterial({ color: 0x6366f1 });
      function build(size) {
        if (cube) { s.scene.remove(cube); cube.geometry.dispose(); }
        cube = new THREE.Mesh(new THREE.BoxGeometry(size, size, size), cubeMat);
        s.scene.add(cube);
      }
      function update(state) {
        blk.size = Math.max(0.4, Math.cbrt(state.mass) * 0.9);   // volume ∝ mass
        build(blk.size);
        blk.speed = state.vel * 0.35;
        blk.pLen = Math.min(9, state.p * 0.5);
        if (arrowH) s.scene.remove(arrowH);
        arrowH = new THREE.ArrowHelper(new THREE.Vector3(1, 0, 0), new THREE.Vector3(0, blk.size / 2 + 0.3, 0), Math.max(0.4, blk.pLen), 0x10b981, Math.min(0.7, blk.pLen * 0.25), 0.4);
        cube.add(arrowH); arrowH.position.set(0, blk.size / 2 + 0.3, 0);
      }
      function frame() {
        requestAnimationFrame(frame);
        if (!reduceMotion) s.spin(0.0016);
        if (cube) {
          cube.position.x += (blk.speed || 0) * 0.03;
          if (cube.position.x > 8) cube.position.x = -8;
          cube.position.y = blk.size / 2;
        }
        s.renderer.render(s.scene, s.camera);
      }
      frame();
      block = { update, resize: s.resize };
      update(bState());
    }

    // ---- diagram: collision (two blocks) ----
    function initDiagCollide() {
      const c = el('diag-collide'); if (!c) throw new Error('no container');
      const s = makeScene(c, 13, new THREE.Vector3(0, 0.5, 0), OPTS);
      s.scene.add(new THREE.GridHelper(14, 14, 0xe2e8f0, 0xeef2f7));
      const a = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.8, 0.8), new THREE.MeshStandardMaterial({ color: 0x0ea5e9 }));
      const b = new THREE.Mesh(new THREE.BoxGeometry(1.6, 1.6, 1.6), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
      a.position.set(-4, 0.4, 0); b.position.set(2, 0.8, 0); s.scene.add(a); s.scene.add(b);
      let t = 0;
      function frame() {
        requestAnimationFrame(frame);
        if (!reduceMotion) { s.spin(0.003); t += 0.01; const ph = (t % 2); const closing = ph < 1; const d = closing ? ph : (2 - ph); a.position.x = -4 + d * 3.5; b.position.x = 2 - d * 1.2; }
        s.renderer.render(s.scene, s.camera);
      }
      frame();
      diagCollide = { resize: s.resize };
    }

    // ---- diagram: impulse area (tall-thin vs short-wide, same area) ----
    function initDiagImpulse() {
      const c = el('diag-impulse'); if (!c) throw new Error('no container');
      const s = makeScene(c, 13, new THREE.Vector3(0, 1.5, 0), OPTS);
      s.scene.add(new THREE.GridHelper(12, 12, 0xe2e8f0, 0xeef2f7));
      // both bars have area (w*h) = 3
      const tall = new THREE.Mesh(new THREE.BoxGeometry(0.6, 5, 1.2), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
      tall.position.set(-2.2, 2.5, 0); s.scene.add(tall);
      const wide = new THREE.Mesh(new THREE.BoxGeometry(2.5, 1.2, 1.2), new THREE.MeshStandardMaterial({ color: 0x0ea5e9 }));
      wide.position.set(2, 0.6, 0); s.scene.add(wide);
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagImpulse = { resize: s.resize };
    }

    let diagCollide = null, diagImpulse = null;

    // ================= BOOT =================
    function boot() {
      try { switchMode('momentum'); update(); } catch (e) { console.error('[momentum] calc init failed', e); }
      try { onBChange(); } catch (e) { console.error('[momentum] slider init failed', e); }
      try { initCharts(); } catch (e) { console.error('[momentum] charts failed', e); }
      if (window.THREE) {
        try { initScene3d(); } catch (e) { console.error('[momentum] 3D failed', e); el('scene3d-fallback').classList.remove('hidden'); }
        try { initDiagCollide(); } catch (e) { console.error('[momentum] collide diagram failed', e); }
        try { initDiagImpulse(); } catch (e) { console.error('[momentum] impulse diagram failed', e); }
      } else {
        el('scene3d-fallback').classList.remove('hidden');
      }
      mountResize([block, diagCollide, diagImpulse]);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
  </script>
</ToolLayout>
