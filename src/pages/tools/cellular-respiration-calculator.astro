---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Cellular Respiration Equation Balancer';
const description = 'Cellular respiration equation balancer with a live 3D mitochondrion diagram and charts. Solve the balanced stoichiometry of C6H12O6 + 6O2 → 6CO2 + 6H2O for any amount of glucose, plus estimated ATP yield, with worked examples.';
const intro = 'Solve the balanced cellular respiration equation C6H12O6 + 6O2 → 6CO2 + 6H2O for any starting amount of glucose, scaling every reactant and product proportionally, plus an estimated ATP yield. Two 3D diagrams compare a small amount of glucose being respired to a much larger amount, and charts show how O2 consumed, CO2 produced, and ATP yield all scale together.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is the overall equation for cellular respiration?', a: 'C6H12O6 + 6O2 → 6CO2 + 6H2O (+ energy, released as ATP) — one molecule of glucose combines with six molecules of oxygen to produce six molecules of carbon dioxide and six molecules of water.' },
  { q: 'How much ATP does cellular respiration produce per glucose molecule?', a: "Modern estimates put the yield at roughly 30-32 ATP per glucose molecule in eukaryotic cells — lower than the traditional textbook figure of 36-38, which didn't fully account for the energy cost of shuttling molecules across the mitochondrial membrane." },
  { q: 'Why did the accepted ATP yield estimate change over time?', a: "More precise measurements revealed that the classic 36-38 ATP estimate overlooked real energy costs — moving NADH-equivalent electrons and ADP/ATP/phosphate across the mitochondrial membrane consumes some of the proton gradient's energy, reducing net usable ATP output." },
  { q: 'How does this equation relate to photosynthesis?', a: "Cellular respiration is essentially the reverse of photosynthesis's overall equation — photosynthesis builds glucose from CO2 and water using light energy, while respiration breaks glucose back down into CO2 and water, releasing that stored energy as ATP." },
  { q: 'Does this equation apply to anaerobic respiration too?', a: "No — this equation specifically describes aerobic respiration, which requires oxygen as the final electron acceptor. Anaerobic respiration and fermentation use different final products (like lactate or ethanol) and yield far less ATP per glucose molecule." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Cellular Respiration Equation Balancer',
  description: 'Solve the balanced stoichiometry of cellular respiration for any amount of glucose, plus ATP yield.',
  steps: [
    { name: 'Enter moles of glucose', text: 'The starting amount of glucose being respired.' },
    { name: 'Read the balanced stoichiometry', text: 'Moles of O2 consumed and CO2/H2O produced scale automatically.' },
    { name: 'Read estimated ATP yield', text: 'Using the modern accepted estimate of ~30 ATP per glucose molecule.' },
  ],
};

const formulas = [
  { expr: 'C6H12O6 + 6O2 → 6CO2 + 6H2O', note: 'the balanced overall equation for aerobic cellular respiration' },
  { expr: 'ATP yield ≈ 30 × moles of glucose', note: 'using the modern accepted estimate of ~30 ATP per glucose in eukaryotic cells' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — one mole of glucose', tone: 'slate',
    given: '1 mole of glucose is fully respired aerobically.',
    rows: [
      { label: 'O2 consumed:', value: '6 mol' },
      { label: 'CO2 produced:', value: '6 mol' },
      { label: 'H2O produced:', value: '6 mol' },
      { label: 'Estimated ATP yield:', value: '≈30 ATP', full: true },
    ],
    note: 'Every coefficient in the balanced equation scales directly with however many moles of glucose you start with — this is the reference 1:1 case.',
  },
  {
    title: 'Worked example 2 — half a mole of glucose', tone: 'amber',
    given: '0.5 moles of glucose (90 g, since glucose\'s molar mass is 180.16 g/mol) is fully respired.',
    rows: [
      { label: 'O2 consumed:', value: '0.5 × 6 = 3 mol' },
      { label: 'CO2 and H2O produced:', value: '0.5 × 6 = 3 mol each' },
      { label: 'Estimated ATP yield:', value: '0.5 × 30 = 15 ATP', full: true },
    ],
    note: 'Every quantity in the equation scales in direct, linear proportion to the starting amount of glucose — half the glucose means exactly half of every reactant, product, and ATP output.',
  },
];

const comparison = {
  heading: 'Scaling the balanced equation by glucose amount',
  note: 'Every coefficient scales together, in the same 1:6:6:6 ratio.',
  headers: [{ label: 'Glucose (mol)' }, { label: 'O2 needed' }, { label: 'CO2 + H2O produced (each)' }, { label: 'Est. ATP' }],
  rows: [
    ['0.5', '3', '3', '15'],
    ['1 ★', '6', '6', '30'],
    ['2', '12', '12', '60'],
    ['5', '30', '30', '150'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). The 1:6:6:6 ratio between glucose, O2, CO2, and H2O never changes — only the absolute quantities scale.',
};

const realWorld = [
  { emoji: '🏃', title: 'Exercise physiology and metabolism', body: 'Understanding cellular respiration stoichiometry underlies how exercise physiologists calculate energy expenditure and oxygen consumption (VO2) during physical activity.' },
  { emoji: '🫁', title: 'Medical respiratory and metabolic monitoring', body: 'Clinical measurement of a patient\'s oxygen consumption and CO2 production (indirect calorimetry) relies directly on this equation\'s stoichiometry to estimate metabolic rate.' },
  { emoji: '🌍', title: 'Global carbon and oxygen cycle modeling', body: "Cellular respiration's CO2 output (balanced against photosynthesis's CO2 uptake) is a core process in global carbon cycle and atmospheric oxygen models." },
  { emoji: '🔋', title: 'Bioenergetics and metabolic engineering', body: 'Researchers engineering microorganisms for biofuel or bioproduct production rely on understanding respiration stoichiometry and ATP yield to predict and optimize cellular energy budgets.' },
];

const misconceptions = [
  { claim: '"Cellular respiration produces exactly 36-38 ATP per glucose, as many older textbooks state."', truth: "More precise modern measurements put the realistic yield closer to 30-32 ATP per glucose in eukaryotic cells — the classic 36-38 figure was a theoretical maximum that didn't fully account for the energy cost of transporting molecules across the mitochondrial membrane." },
  { claim: '"This equation describes exactly what happens in a single step inside the cell."', truth: "The overall equation summarizes the net result of dozens of individual enzymatic steps across glycolysis, the citric acid cycle, and oxidative phosphorylation — it's a bookkeeping summary, not a literal single reaction." },
  { claim: '"All organisms produce the same amount of ATP per glucose."', truth: "ATP yield varies by organism and cell type — prokaryotes without the membrane-shuttle costs of eukaryotic mitochondria can reach higher yields (up to ~38 ATP), while some eukaryotic cell types achieve less than the typical ~30-32 ATP estimate." },
  { claim: '"Doubling the amount of glucose doubles the ATP yield exactly."', truth: 'Under the simplified stoichiometric model used here, yes — but real cells face practical limits like oxygen and enzyme availability, meaning actual ATP production doesn\'t necessarily scale perfectly linearly with glucose supply in a living system.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 7, "Cellular Respiration" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/7-1-energy-in-living-systems" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Rich (2003)</strong> — reassessment of cellular respiration ATP yield, <em>Biochemical Society Transactions</em>.' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Cellular respiration and oxidative phosphorylation chapter.' },
];
const sourcesNote = 'C6H12O6 + 6O2 → 6CO2 + 6H2O. ATP yield uses the modern ~30 ATP/glucose estimate for eukaryotic cells. Results are rounded for display.';

const howToUse = [
  { title: 'Enter moles of glucose', body: 'The amount of glucose being fully respired.' },
  { title: 'Read the balanced stoichiometry', body: 'O2 required and CO2/H2O produced scale automatically.' },
  { title: 'Read estimated ATP yield', body: 'Using the modern ~30 ATP per glucose estimate.' },
];

const related = [
  { href: '/tools/photosynthesis-rate-calculator', emoji: '🌿', title: 'Photosynthesis Rate Calculator', desc: 'O2 output vs. light intensity, saturation curve.' },
  { href: '/tools/chemical-equation-balancer', emoji: '🧮', title: 'Chemical Equation Balancer', desc: 'Balance equations up to 4 species instantly.' },
  { href: '/tools/michaelis-menten-calculator', emoji: '🔑', title: 'Michaelis-Menten Enzyme Kinetics Calculator', desc: 'v = Vmax[S]/(Km+[S]) — enzyme reaction velocity.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="cellular respiration's overall equation is a fixed 1:6:6:6 recipe — one glucose always needs exactly six oxygens and always yields exactly six carbon dioxides and six waters, no matter how much glucose you start with."
  howIntro="Cellular respiration's balanced equation summarizes dozens of individual enzymatic steps — glycolysis, the citric acid cycle, and the electron transport chain — into one net statement: glucose plus oxygen yields carbon dioxide, water, and usable cellular energy. Because that ratio between reactants and products is fixed by the chemistry itself, scaling up or down to any starting amount of glucose is simple proportional arithmetic — twice the glucose needs exactly twice the oxygen and produces exactly twice the CO2, water, and ATP. The exact ATP number is where nuance comes in: careful accounting for the real energy cost of shuttling molecules across the mitochondrial membrane has revised the classic textbook estimate downward, from a theoretical 36-38 ATP to a more realistic ~30-32 in eukaryotic cells."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where cellular respiration stoichiometry actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-center font-mono text-sm text-slate-700">C6H12O6 + 6O2 → 6CO2 + 6H2O</p>
    <label class="mx-auto block max-w-xs"><span class="text-sm font-medium text-slate-700">Moles of glucose</span>
      <input id="glucose" type="number" step="any" value="1" min="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">O2 needed (mol)</div><div id="r-o2" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">CO2 produced (mol)</div><div id="r-co2" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">H2O produced (mol)</div><div id="r-h2o" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-3 text-center text-white"><div class="text-xs opacity-80">Est. ATP yield</div><div id="r-atp" class="mt-1 text-lg font-bold">—</div></div>
    </div>
    <p id="cr-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Small vs. large amount of glucose respired</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-small" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A small amount of glucose</h3>
          <p class="mt-1 text-sm text-slate-600">Fewer O2, CO2, and H2O molecules involved — less ATP produced.</p>
        </div>
        <div>
          <div id="diag-large" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. A large amount of glucose</h3>
          <p class="mt-1 text-sm text-slate-600">Many more molecules involved, all in the same fixed 1:6:6:6 ratio — much more ATP produced.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Stoichiometry charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Reactants and products vs. glucose amount</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-stoich"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ATP yield estimate vs. glucose amount</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-atp"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};

      // ---- calculator ----
      function update() {
        el('cr-err').textContent = '';
        ['r-o2', 'r-co2', 'r-h2o', 'r-atp'].forEach((id) => el(id).textContent = '—');
        const glucose = parseFloat(el('glucose').value);
        if (isNaN(glucose)) return;
        if (glucose < 0) { el('cr-err').textContent = 'Moles of glucose cannot be negative.'; return; }
        el('r-o2').textContent = fmt(glucose * 6);
        el('r-co2').textContent = fmt(glucose * 6);
        el('r-h2o').textContent = fmt(glucose * 6);
        el('r-atp').textContent = fmt(glucose * 30);
        updateCharts(glucose);
      }
      el('glucose').addEventListener('input', update);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.stoich = new Chart(el('chart-stoich'), {
          type: 'bar',
          data: { labels: ['Glucose', 'O2', 'CO2', 'H2O'], datasets: [{ label: 'Moles', data: [1, 6, 6, 6], backgroundColor: ['#f59e0b', '#6366f1', '#94a3b8', '#38bdf8'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Moles' } } }, plugins: { legend: { display: false } } }),
        });
        const glucoseRange = [0.5, 1, 2, 5, 10];
        charts.atp = new Chart(el('chart-atp'), {
          type: 'bar',
          data: { labels: glucoseRange.map((g) => g + ' mol'), datasets: [{ label: 'Est. ATP', data: glucoseRange.map((g) => g * 30), backgroundColor: '#6366f1' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Estimated ATP yield' } } }, plugins: { legend: { display: false } } }),
        });
      }
      function updateCharts(glucose) {
        if (charts.stoich) { charts.stoich.data.datasets[0].data = [glucose, glucose * 6, glucose * 6, glucose * 6]; charts.stoich.update('none'); }
      }

      function moleculeScene(container, count) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const colors = [0x6366f1, 0x94a3b8, 0x38bdf8];
        for (let i = 0; i < count; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.16, 10, 8), new THREE.MeshStandardMaterial({ color: colors[i % 3] }));
          m.position.set((Math.random() - 0.5) * 4.5, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 2.5);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSmall = null, diagLarge = null;
      function initDiagSmall() { const c = el('diag-small'); if (!c) throw new Error('no container'); diagSmall = moleculeScene(c, 9); }
      function initDiagLarge() { const c = el('diag-large'); if (!c) throw new Error('no container'); diagLarge = moleculeScene(c, 45); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[cellular-respiration] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagSmall(); } catch (e) { console.error('[cellular-respiration] small diagram failed', e); }
          try { initDiagLarge(); } catch (e) { console.error('[cellular-respiration] large diagram failed', e); }
        }
        mountResize([diagSmall, diagLarge]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
