---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Actual Yield Calculator';
const description = "Actual yield calculator with a live 3D beaker showing recovered product vs the theoretical fill line and the lost portion.";
const intro = 'Find actual yield from percent yield and theoretical yield, or from raw lab data, and see exactly how much product was lost and why. A live 3D beaker separates recovered product from what was lost.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is actual yield?', a: 'Actual yield is the mass of product you actually recover and weigh after running a reaction and purifying the product — a measured, real-world quantity, not a calculated one like theoretical yield.' },
  { q: 'How do I calculate actual yield if I only know percent yield?', a: 'Rearrange the percent yield formula: actual yield = (percent yield ÷ 100) × theoretical yield. This calculator solves that instantly, and also shows how much product was lost in the process.' },
  { q: 'Why is actual yield almost always less than theoretical yield?', a: 'Real reactions lose product to side reactions that consume reactants without forming the target compound, reactions that do not go to completion, and purification losses during filtration, recrystallization, distillation or transfer between containers.' },
  { q: 'Can actual yield be higher than theoretical yield?', a: 'Not for a correctly identified, pure product — that would violate conservation of mass. An apparent actual yield above theoretical almost always means impurities, residual solvent, or measurement error inflated the recovered mass.' },
  { q: 'What does a low actual yield tell you?', a: 'A low actual yield relative to theoretical points to yield loss somewhere in the process — check for side reactions, an incomplete reaction (more time or reagent needed), or excessive losses during workup and purification.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Actual Yield Calculator',
  description: 'Calculate actual yield from percent yield and theoretical yield, and see the yield-loss breakdown.',
  steps: [
    { name: 'Enter theoretical yield', text: 'Type the calculated maximum yield in grams (or moles).' },
    { name: 'Enter percent yield', text: 'Type the reaction\'s percent yield, or the actual yield you measured directly.' },
    { name: 'Read the results', text: 'Actual yield, grams lost, and percent lost solve instantly.' },
  ],
};

const formulas = [
  { expr: 'actual = (% yield ÷ 100) × theoretical', note: 'actual yield from percent yield' },
  { expr: 'lost = theoretical − actual', note: 'mass of product lost' },
  { expr: '% lost = 100 − % yield', note: 'the flip side of percent yield' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — from percent yield', tone: 'slate',
    given: 'A synthesis has a theoretical yield of 25.0 g. The reaction runs at 78.0% yield. Find the actual yield and how much product was lost.',
    rows: [
      { label: 'Formula:', value: 'actual = (% yield ÷ 100) × theoretical' },
      { label: 'Substitute:', value: 'actual = (78.0 ÷ 100) × 25.0' },
      { label: 'Actual yield:', value: '19.5 g', full: true },
      { label: 'Lost:', value: '25.0 − 19.5 = 5.5 g (22.0% lost)', full: true },
    ],
  },
  {
    title: 'Worked example 2 — from raw lab data', tone: 'amber',
    given: 'A student calculates a theoretical yield of 12.8 g, then weighs their purified, dried product at 10.1 g. Find the percent yield and the loss breakdown.',
    rows: [
      { label: 'Percent yield:', value: '(10.1 ÷ 12.8) × 100 = 78.9%' },
      { label: 'Lost:', value: '12.8 − 10.1 = 2.7 g' },
      { label: 'Percent lost:', value: '100 − 78.9 = 21.1%', full: true },
    ],
    note: 'This is the reverse direction — actual yield is a weighed number you already have; the calculator tells you the percent yield and loss it implies.',
  },
];

const comparison = {
  heading: 'Common causes of yield loss and their typical impact',
  note: 'Illustrative ranges — actual losses depend heavily on the specific reaction and technique used.',
  headers: [{ label: 'Cause of loss' }, { label: 'Typical % impact' }, { label: 'Where it happens' }],
  rows: [
    ['Incomplete reaction', '5–20%', 'Reaction stops before full conversion (equilibrium, time, temperature)'],
    ['Side reactions', '5–25%', 'Reactants consumed forming byproducts instead of target product'],
    ['Transfer losses', '1–5%', 'Product left behind on glassware, filter paper, or during pouring'],
    ['Recrystallization / purification', '10–30%', 'Product remains dissolved in the mother liquor and is filtered away'],
    ['Measurement / drying error', '1–5%', 'Residual solvent not fully removed, or scale/weighing inaccuracy'],
  ],
  highlightIndex: 3,
  footnote: 'These causes stack — a real synthesis usually loses yield to more than one at once, which is why multi-step syntheses compound losses across steps.',
};

const realWorld = [
  { emoji: '🏭', title: 'Industrial batch reconciliation', body: 'Process engineers track actual yield against theoretical for every production batch to spot process drift — a sudden drop in actual yield signals a problem worth investigating before the next batch runs.' },
  { emoji: '💊', title: 'Pharmaceutical quality records', body: 'Regulatory batch records require the actual yield of every manufacturing step to be logged and reconciled against the theoretical value, since unexplained yield loss can indicate a manufacturing or purity issue.' },
  { emoji: '🔬', title: 'Research lab troubleshooting', body: 'When actual yield comes in far below expectations, chemists use the size of the gap to decide where to look first — an incomplete reaction, a competing side reaction, or losses during workup.' },
];

const misconceptions = [
  { claim: '"Actual yield can exceed theoretical yield if the reaction is very efficient."', truth: 'Under correct measurement of a pure product, this is essentially impossible — it would violate conservation of mass. An apparent value over 100% is a sign of impurities, residual solvent, or measurement error, not superior efficiency.' },
  { claim: '"Actual yield is calculated, like theoretical yield."', truth: 'Actual yield is measured, not calculated — you weigh the isolated, dried product on a balance. Theoretical yield is the calculated quantity derived from stoichiometry.' },
  { claim: '"All yield loss happens during the chemical reaction itself."', truth: 'A large share of yield loss often happens after the reaction, during workup and purification — filtration, recrystallization, and transfers between containers all leave product behind.' },
  { claim: '"A low actual yield means the experiment failed."', truth: 'A low actual yield can still reflect a successful, well-understood reaction — the chemistry can be entirely correct while losses accumulate in unavoidable purification steps.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 4.4, Reaction Yields (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/4-4-reaction-yields" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 3.7, Limiting Reactants and Percent Yield.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Chapter 3, Stoichiometry, section on percent yield and yield loss.' },
];
const sourcesNote = 'Actual yield = (percent yield ÷ 100) × theoretical yield. Actual and theoretical yield must use the same units (both grams or both moles). Results are rounded for display.';

const howToUse = [
  { title: 'Enter theoretical yield', body: 'The calculated maximum, in grams or moles.' },
  { title: 'Enter percent yield', body: 'From your reaction, or your own measured actual yield converted to a percentage.' },
  { title: 'Read the loss breakdown', body: 'See grams lost and percent lost alongside the actual yield.' },
];

const related = [
  { href: '/tools/percent-yield-calculator', emoji: '🎯', title: 'Percent Yield Calculator', desc: 'Actual vs theoretical yield, solve any variable.' },
  { href: '/tools/theoretical-yield-calculator', emoji: '🧫', title: 'Theoretical Yield Calculator', desc: 'Calculate theoretical yield from stoichiometry.' },
  { href: '/tools/limiting-reagent-calculator', emoji: '⚖️', title: 'Limiting Reagent Calculator', desc: 'Find which reactant runs out first.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="actual yield is what you actually weigh after the reaction and purification — always at or below theoretical yield — and the gap between them tells you where product was lost."
  howIntro="Given percent yield and theoretical yield, actual yield falls straight out: actual = (%yield/100) × theoretical. But the more useful question is often the reverse-engineering one — given what you actually recovered, what does that say about the reaction? This calculator pairs the actual-yield number with a loss breakdown (grams lost, percent lost) so you can reason about <em>why</em> actual fell short of theoretical: an incomplete reaction, a competing side reaction, or losses during purification and transfer."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where actual yield actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-frompct" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From % yield</button>
      <button id="mode-fromactual" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From measured actual</button>
    </div>
    <div id="frompct-fields" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Theoretical yield</span>
        <input id="theo" type="number" step="any" placeholder="g or mol" value="25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">% Yield</span>
        <input id="pct" type="number" step="any" placeholder="%" value="78" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="fromactual-fields" class="hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Theoretical yield</span>
        <input id="theo2" type="number" step="any" placeholder="g or mol" value="12.8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Measured actual yield</span>
        <input id="actual2" type="number" step="any" placeholder="g or mol" value="10.1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <p class="mt-2 text-xs text-slate-400">Use the same unit (g or mol) for theoretical and actual yield.</p>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Actual yield</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">% Yield</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-red-50 p-5 text-center"><div class="text-sm text-red-500">Lost (mass)</div><div id="r-3" class="mt-1 text-2xl font-bold text-red-700">—</div></div>
      <div class="rounded-xl bg-red-50 p-5 text-center"><div class="text-sm text-red-500">Lost (%)</div><div id="r-4" class="mt-1 text-2xl font-bold text-red-700">—</div></div>
    </div>
    <p id="ay-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-beaker" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. The gap between theoretical and actual is "lost" product</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-slate-500">dashed line</span> marks the theoretical yield; the <span class="font-semibold text-sky-500">solid liquid</span> is the actual yield recovered. The small <span class="font-semibold text-red-500">red puddle</span> beside the beaker represents the portion that never made it to the final product.</p>
        </div>
        <div>
          <div id="diag-bars" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Yield loss comes from several different causes</h3>
          <p class="mt-1 text-sm text-slate-600">Illustrative percentages for three common causes: <span class="font-semibold text-amber-500">side reactions</span>, <span class="font-semibold text-indigo-600">purification loss</span>, and an <span class="font-semibold text-red-500">incomplete reaction</span>. Real losses usually stack from more than one cause at once.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Yield-loss graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Illustrative yield loss by cause (typical mid-range %)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-losscause"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Actual yield vs % yield (fixed theoretical)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-actualpct"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'frompct';
      function switchMode(m) {
        mode = m;
        const active = 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white';
        const inactive = 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-frompct').className = m === 'frompct' ? active : inactive;
        el('mode-fromactual').className = m === 'fromactual' ? active : inactive;
        el('frompct-fields').className = m === 'frompct' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        el('fromactual-fields').className = m === 'fromactual' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        update();
      }
      function update() {
        el('ay-err').textContent = '';
        ['r-1', 'r-2', 'r-3', 'r-4'].forEach((id) => (el(id).textContent = '—'));
        let theo, actual, pct;
        if (mode === 'frompct') {
          theo = parseFloat(el('theo').value); pct = parseFloat(el('pct').value);
          if (isNaN(theo) || isNaN(pct)) return;
          if (theo <= 0) { el('ay-err').textContent = 'Theoretical yield must be positive.'; return; }
          if (pct < 0) { el('ay-err').textContent = '% yield cannot be negative.'; return; }
          actual = (pct / 100) * theo;
        } else {
          theo = parseFloat(el('theo2').value); actual = parseFloat(el('actual2').value);
          if (isNaN(theo) || isNaN(actual)) return;
          if (theo <= 0) { el('ay-err').textContent = 'Theoretical yield must be positive.'; return; }
          if (actual < 0) { el('ay-err').textContent = 'Actual yield cannot be negative.'; return; }
          pct = (actual / theo) * 100;
        }
        const lost = theo - actual;
        const pctLost = 100 - pct;
        el('r-1').textContent = fmt(actual);
        el('r-2').textContent = fmt(pct) + '%';
        el('r-3').textContent = fmt(lost);
        el('r-4').textContent = fmt(pctLost) + '%';
        if (lost < 0) el('ay-err').textContent = 'Actual yield exceeds theoretical — check for impurities or measurement error.';
      }
      el('mode-frompct').addEventListener('click', () => switchMode('frompct'));
      el('mode-fromactual').addEventListener('click', () => switchMode('fromactual'));
      ['theo', 'pct', 'theo2', 'actual2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.losscause = new Chart(el('chart-losscause'), {
          type: 'bar',
          data: {
            labels: ['Incomplete rxn', 'Side reactions', 'Transfer', 'Purification', 'Measurement'],
            datasets: [{ label: 'Typical % impact (mid-range)', data: [12.5, 15, 3, 20, 3], backgroundColor: ['#f59e0b', '#ef4444', '#94a3b8', '#6366f1', '#0ea5e9'] }],
          },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: '% yield impact (illustrative)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.actualpct = new Chart(el('chart-actualpct'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Actual yield', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0.2, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: '% yield' } }, y: { title: { display: true, text: 'Actual yield' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts();
      }
      function updateCharts() {
        if (!charts.ready) return;
        const theo = 25;
        const L = [], D = [];
        for (let p = 0; p <= 100.001; p += 2) { L.push(p.toFixed(0)); D.push(+((p / 100) * theo).toFixed(4)); }
        charts.actualpct.data.labels = L; charts.actualpct.data.datasets[0].data = D; charts.actualpct.update();
      }

      // ---- standalone 3D diagrams (static, auto-rotating) ----
      function glassBeaker(radius) {
        const g = new THREE.Group();
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        g.add(new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, 5, 40, 1, true), glassMat));
        const bottom = new THREE.Mesh(new THREE.CircleGeometry(radius, 40), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
        return g;
      }

      // ---- diagram 1: beaker with theoretical (dashed) vs actual (solid, lower) + lost puddle ----
      function initDiagBeaker() {
        const c = el('diag-beaker'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), SCENE_OPTS);
        const radius = 2.2;
        s.scene.add(glassBeaker(radius));
        const theo = 25, actual = 19.5, lost = theo - actual;
        const hActual = (actual / theo) * 4.6;
        const hTheo = 4.6;
        const liquid = new THREE.Mesh(new THREE.CylinderGeometry(radius - 0.12, radius - 0.12, hActual, 40), new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.5, roughness: 0.3 }));
        liquid.position.y = -2.4 + hActual / 2; s.scene.add(liquid);

        const yTheo = -2.4 + hTheo;
        const pts = [];
        const segs = 64;
        for (let i = 0; i <= segs; i++) { const a = (i / segs) * Math.PI * 2; pts.push(new THREE.Vector3(Math.cos(a) * (radius - 0.05), yTheo, Math.sin(a) * (radius - 0.05))); }
        const outline = new THREE.LineLoop(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineDashedMaterial({ color: 0x64748b, dashSize: 0.18, gapSize: 0.12 }));
        outline.computeLineDistances();
        s.scene.add(outline);

        const lostFrac = lost / theo;
        const puddleR = 0.3 + lostFrac * 1.3;
        const puddle = new THREE.Mesh(new THREE.CylinderGeometry(puddleR, puddleR, 0.08, 24), new THREE.MeshStandardMaterial({ color: 0xef4444, transparent: true, opacity: 0.55, roughness: 0.4 }));
        puddle.position.set(3.6, -2.55, 0); s.scene.add(puddle);

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0025); s.renderer.render(s.scene, s.camera); }
        frame();
        diagBeaker = { resize: s.resize };
      }

      // ---- diagram 2: bar family of typical yield-loss causes ----
      function initDiagBars() {
        const c = el('diag-bars'); if (!c) throw new Error('no container');
        const s = makeScene(c, 14, new THREE.Vector3(0, 1.2, 0), SCENE_OPTS);
        const grid = new THREE.GridHelper(10, 10, 0xe2e8f0, 0xeef2f7); s.scene.add(grid);
        const causes = [
          { label: 'side reactions', pct: 15, color: 0xf59e0b },
          { label: 'purification loss', pct: 20, color: 0x6366f1 },
          { label: 'incomplete reaction', pct: 12.5, color: 0xef4444 },
        ];
        const maxPct = 20;
        const spacing = 2.4, startX = -spacing;
        causes.forEach((c2, i) => {
          const h = (c2.pct / maxPct) * 4.5;
          const bar = new THREE.Mesh(new THREE.BoxGeometry(1.2, h, 1.2), new THREE.MeshStandardMaterial({ color: c2.color }));
          bar.position.set(startX + i * spacing, -2.25 + h / 2, 0);
          s.scene.add(bar);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagBars = { resize: s.resize };
      }
      let diagBeaker = null, diagBars = null;

      function boot() {
        try { switchMode('frompct'); } catch (e) { console.error('[actual-yield] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[actual-yield] charts failed', e); }
        if (window.THREE) {
          try { initDiagBeaker(); } catch (e) { console.error('[actual-yield] beaker diagram failed', e); }
          try { initDiagBars(); } catch (e) { console.error('[actual-yield] bars diagram failed', e); }
        }
        mountResize([diagBeaker, diagBars]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
