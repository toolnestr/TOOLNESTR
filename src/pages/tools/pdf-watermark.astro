---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'PDF Watermark';
const description = 'Add diagonal text watermarks like "CONFIDENTIAL" or "DRAFT" to every PDF page with adjustable opacity — all in your browser.';
const intro = 'Add text watermarks to every page of a PDF — all in your browser.';
const category = { id: 'pdf', name: 'PDF Tools' };
const faqs = [
  { q: 'Is my PDF uploaded to a server?', a: 'No — everything runs in your browser. Your file never leaves your device.' },
  { q: 'What text can I use?', a: 'Any text — common examples are "CONFIDENTIAL", "DRAFT", "COPY", "SAMPLE", or your company name.' },
  { q: 'Can I adjust the opacity?', a: 'Yes — a slider controls opacity from barely visible to full strength.' },
  { q: 'Is the original content preserved?', a: 'Yes — the watermark is drawn on top without modifying existing content.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label for="file-input" class="flex cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 p-8 text-center transition hover:border-indigo-400 hover:bg-indigo-50/40">
      <span class="text-3xl">💧</span>
      <span class="mt-2 font-medium text-slate-700">Click to upload a PDF</span>
      <span class="mt-1 text-sm text-slate-400">Then customize your watermark below</span>
      <input id="file-input" type="file" accept="application/pdf" class="hidden" />
    </label>

    <div id="controls" class="mt-6 hidden">
      <p id="info" class="mb-4 text-sm font-medium text-slate-600"></p>

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Watermark text</span>
          <input id="watermark-text" type="text" value="CONFIDENTIAL" placeholder="CONFIDENTIAL" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-slate-700">Font size</span>
          <input id="font-size" type="number" value="72" min="12" max="300" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-slate-700">Opacity: <span id="opacity-value">30</span>%</span>
          <input id="opacity" type="range" min="0" max="100" value="30" class="mt-1 w-full accent-indigo-600" />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-slate-700">Watermark color</span>
          <div class="mt-1 flex items-center gap-3">
            <input id="watermark-color" type="color" value="#cccccc" class="h-10 w-14 cursor-pointer rounded-lg border border-slate-300 p-0.5" />
            <span id="color-hex" class="text-sm text-slate-500">#cccccc</span>
          </div>
        </label>
      </div>

      <div class="mt-5 flex flex-wrap items-center gap-3">
        <button id="watermark-btn" class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700 disabled:cursor-not-allowed disabled:opacity-40">Add watermark → Download</button>
        <span id="status" class="text-sm text-slate-500"></span>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How PDF watermarking works</h2>
    <p class="mt-2 text-slate-600">Watermarking adds semi-transparent text diagonally across every page of a PDF. The original content stays fully readable underneath while the watermark makes the document's status immediately clear.</p>
    <p class="mt-3 text-slate-600">This tool uses the <span class="font-mono text-indigo-600">pdf-lib</span> library entirely in your browser. It loads your PDF, draws the watermark text at a 45-degree angle across each page, then saves a new PDF. Your file never touches a server.</p>

    <div class="mt-6 overflow-hidden rounded-xl border border-slate-200 bg-white p-4 sm:p-6">
      <h3 class="mb-4 text-center font-semibold text-slate-900">Opacity comparison — same watermark at three opacity levels</h3>
      <svg viewBox="0 0 720 280" class="w-full max-w-3xl mx-auto" role="img" aria-label="Three PDF pages showing CONFIDENTIAL watermark at 15%, 30%, and 60% opacity">
        <defs>
          <clipPath id="page-clip"><rect x="0" y="0" width="200" height="260" rx="6" /></clipPath>
          <filter id="shadow"><feDropShadow dx="1" dy="2" stdDeviation="3" flood-opacity=".15" /></filter>
        </defs>
        <!-- Page 1: 15% opacity -->
        <g transform="translate(10, 10)" filter="url(#shadow)">
          <rect width="200" height="260" rx="6" fill="#fff" stroke="#e2e8f0" stroke-width="1" />
          <text x="100" y="30" text-anchor="middle" font-size="12" fill="#94a3b8">15% opacity</text>
          <g transform="rotate(-45, 100, 140)">
            <text x="60" y="130" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.15)">CONFIDENTIAL</text>
            <text x="60" y="170" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.15)">CONFIDENTIAL</text>
            <text x="60" y="210" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.15)">CONFIDENTIAL</text>
            <text x="-20" y="90" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.15)">CONFIDENTIAL</text>
            <text x="140" y="170" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.15)">CONFIDENTIAL</text>
          </g>
          <line x1="170" y1="30" x2="30" y2="250" stroke="#cbd5e1" stroke-width="0.5" stroke-dasharray="3,3" />
        </g>
        <!-- Page 2: 30% opacity -->
        <g transform="translate(260, 10)" filter="url(#shadow)">
          <rect width="200" height="260" rx="6" fill="#fff" stroke="#e2e8f0" stroke-width="1" />
          <text x="100" y="30" text-anchor="middle" font-size="12" fill="#94a3b8">30% opacity</text>
          <g transform="rotate(-45, 100, 140)">
            <text x="60" y="130" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.3)">CONFIDENTIAL</text>
            <text x="60" y="170" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.3)">CONFIDENTIAL</text>
            <text x="60" y="210" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.3)">CONFIDENTIAL</text>
            <text x="-20" y="90" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.3)">CONFIDENTIAL</text>
            <text x="140" y="170" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.3)">CONFIDENTIAL</text>
          </g>
          <line x1="170" y1="30" x2="30" y2="250" stroke="#94a3b8" stroke-width="0.5" stroke-dasharray="3,3" />
        </g>
        <!-- Page 3: 60% opacity -->
        <g transform="translate(510, 10)" filter="url(#shadow)">
          <rect width="200" height="260" rx="6" fill="#fff" stroke="#e2e8f0" stroke-width="1" />
          <text x="100" y="30" text-anchor="middle" font-size="12" fill="#94a3b8">60% opacity</text>
          <g transform="rotate(-45, 100, 140)">
            <text x="60" y="130" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.6)">CONFIDENTIAL</text>
            <text x="60" y="170" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.6)">CONFIDENTIAL</text>
            <text x="60" y="210" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.6)">CONFIDENTIAL</text>
            <text x="-20" y="90" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.6)">CONFIDENTIAL</text>
            <text x="140" y="170" font-size="28" font-family="sans-serif" font-weight="bold" fill="rgba(140,140,140,.6)">CONFIDENTIAL</text>
          </g>
          <line x1="170" y1="30" x2="30" y2="250" stroke="#64748b" stroke-width="0.5" stroke-dasharray="3,3" />
        </g>
      </svg>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📄</span>
      <h3 class="mt-2 font-semibold text-slate-900">Draft documents</h3>
      <p class="mt-1 text-sm text-slate-600">Mark drafts of contracts, proposals or reports so reviewers immediately know a document is not the final version.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔒</span>
      <h3 class="mt-2 font-semibold text-slate-900">Confidential reports</h3>
      <p class="mt-1 text-sm text-slate-600">Add "CONFIDENTIAL" to internal memos, financial summaries or HR documents that should not be shared outside the organisation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">©️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Copyright protection</h3>
      <p class="mt-1 text-sm text-slate-600">Watermark portfolio pieces, sample chapters or preview PDFs with your name or copyright notice before sharing publicly.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📋</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sample files</h3>
      <p class="mt-1 text-sm text-slate-600">Distribute preview or sample versions of reports, eBooks or whitepapers with a "SAMPLE" watermark to encourage purchases of the full version.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for effective watermarks</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Keep opacity between 20-30%</h3>
        <p class="mt-1 text-sm text-slate-600">A watermark should be visible but not overpowering. At 20-30% opacity, the text is clearly readable yet the underlying content remains fully legible. Higher opacities can distract or obscure important information.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Diagonal placement covers content without obscuring it</h3>
        <p class="mt-1 text-sm text-slate-600">A 45-degree diagonal watermark spreads across the entire page evenly. Unlike horizontal or vertical placement, a diagonal line crosses both text and whitespace, making it difficult to crop out while preserving readability.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Choose the right font size</h3>
        <p class="mt-1 text-sm text-slate-600">A font size of 60-100 points works well for most documents. Larger sizes (120+) are better for one-page summaries and smaller sizes (36-48) work for dense multi-column layouts where the watermark would otherwise overlap large blocks of text.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use light gray for a professional look</h3>
        <p class="mt-1 text-sm text-slate-600">A light gray watermark around #cccccc is unobtrusive and professional. Darker colors like black or red can work for urgent designations but should be used at lower opacities (15-20%) to avoid overwhelming the page.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to watermark PDFs</h2>
    <p class="mt-2 text-slate-600">PDF watermarking is essential whenever you need to communicate a document's status or protect its content without preventing anyone from reading it. Legal professionals regularly watermark draft contracts with "DRAFT — NOT FOR FILING" to prevent premature execution of agreements that are still under negotiation. A paralegal reviewing a 50-page merger agreement can watermark every page so that even if a single page is photocopied or screenshotted, its draft status remains evident. This simple layer of protection prevents embarrassing or legally problematic situations where an unapproved version circulates internally or externally.</p>
    <p class="mt-3 text-slate-600">Corporate teams handling confidential information use watermarks as a visual reminder of document sensitivity. An HR manager distributing employee compensation summaries might stamp each page with "CONFIDENTIAL" to reinforce that the information should not be discussed outside the management team. Financial analysts preparing quarterly earnings previews before public release use watermarks to ensure recipients understand the preliminary nature of the data. The watermark becomes a constant visual cue that persists across every page, making it far more effective than a single cover-sheet disclaimer that can be easily separated from the document.</p>
    <p class="mt-3 text-slate-600">Creative professionals and content creators use watermarks to protect their work when sharing samples or previews. A photographer sending a portfolio preview to a potential client can watermark each image with "SAMPLE — FOR REVIEW ONLY" to discourage unauthorised use. An author preparing an advance reader copy of their manuscript might stamp every page with "UNCORRECTED PROOF" so that reviewers and beta readers understand the content is still being edited. Freelance designers sharing mockups and concept boards use watermarks to prevent clients from using the low-resolution previews in place of a paid final delivery, protecting both their intellectual property and their livelihood.</p>
    <p class="mt-3 text-slate-600">Educational institutions and government agencies use watermarks to mark documents for specific purposes. A university registrar issuing unofficial transcripts might watermark them as "UNOFFICIAL — NOT A VALID CERTIFICATE" to prevent misuse of the document. Government agencies processing public records requests can apply watermarks indicating the date of release or the specific request number for tracking purposes. In each case, the watermark serves as both a security measure and an audit trail, embedding contextual information directly into the document that cannot be easily removed.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the PDF watermark tool</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Upload a PDF</h3>
        <p class="mt-1 text-sm text-slate-600">Click the upload area and select the PDF you want to watermark from your device.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Customise the watermark</h3>
        <p class="mt-1 text-sm text-slate-600">Set your text, font size, opacity and colour. The preview area shows your file is ready.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Download the result</h3>
        <p class="mt-1 text-sm text-slate-600">Click "Add watermark → Download" and your watermarked PDF saves automatically.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Client-side processing with pdf-lib</h2>
    <p class="mt-2 text-slate-600">This tool processes your PDF entirely in the browser using the pdf-lib JavaScript library. When you upload a file, it is read into memory on your device and never transmitted anywhere. The library loads the PDF structure, iterates through every page, and draws the watermark text at a 45-degree angle using the embedded Helvetica font. Each page is individually processed to ensure the watermark is positioned correctly regardless of page dimensions or orientation.</p>
    <p class="mt-3 text-slate-600">The watermark opacity is controlled through the RGBA colour model's alpha channel. A value of 0.3 (30% opacity) blends the watermark text with the underlying page content at a ratio where both remain visible. The tool multiplies your slider input by 0.01 to convert the percentage into the 0-to-1 range expected by the library. The colour picker value is converted from hexadecimal to RGB floats, then combined with the alpha value to produce the final watermark colour.</p>
    <p class="mt-3 text-slate-600">Font rendering uses the built-in Helvetica font that pdf-lib ships with, so no external font files need to be downloaded. The text is drawn at the specified font size using the <span class="font-mono text-indigo-600">drawText</span> method with a rotation of 45 degrees applied via the <span class="font-mono text-indigo-600">degrees</span> helper. Each page is saved with the watermark overlaid and the complete document is exported as a new PDF file. The original PDF remains completely untouched — a new file is always created containing the watermarked content.</p>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Use case</th><th class="p-3">Recommended text</th><th class="p-3">Opacity</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Draft review</td><td class="p-3">DRAFT</td><td class="p-3">20-25%</td></tr>
        <tr><td class="p-3 font-medium">Confidential document</td><td class="p-3">CONFIDENTIAL</td><td class="p-3">25-30%</td></tr>
        <tr><td class="p-3 font-medium">Copyright notice</td><td class="p-3">© [Year] [Name]</td><td class="p-3">15-20%</td></tr>
        <tr><td class="p-3 font-medium">Sample file</td><td class="p-3">SAMPLE</td><td class="p-3">30-40%</td></tr>
        <tr><td class="p-3 font-medium">Internal use only</td><td class="p-3">INTERNAL USE ONLY</td><td class="p-3">20-25%</td></tr>
        <tr><td class="p-3 font-medium">Unapproved version</td><td class="p-3">NOT APPROVED</td><td class="p-3">25-35%</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/pdf-page-numbers" class="rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50">
        <span class="font-semibold text-slate-900">PDF Page Numbers</span>
        <span class="mt-1 block text-slate-500">Add page numbers to existing PDFs</span>
      </a>
      <a href="/tools/pdf-rotate" class="rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50">
        <span class="font-semibold text-slate-900">PDF Rotate</span>
        <span class="mt-1 block text-slate-500">Rotate pages in a PDF document</span>
      </a>
      <a href="/tools/pdf-password-protect" class="rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50">
        <span class="font-semibold text-slate-900">PDF Password Protect</span>
        <span class="mt-1 block text-slate-500">Encrypt PDFs with a password</span>
      </a>
    </div>
  </section>

  <script is:inline>
    (async () => {
      const { PDFDocument, StandardFonts, rgb, degrees } = await import('https://esm.sh/pdf-lib@1.17.1');

      const input = document.getElementById('file-input');
      const controls = document.getElementById('controls');
      const info = document.getElementById('info');
      const watermarkText = document.getElementById('watermark-text');
      const fontSize = document.getElementById('font-size');
      const opacity = document.getElementById('opacity');
      const opacityValue = document.getElementById('opacity-value');
      const watermarkColor = document.getElementById('watermark-color');
      const colorHex = document.getElementById('color-hex');
      const btn = document.getElementById('watermark-btn');
      const status = document.getElementById('status');

      let currentBytes = null;

      opacity.addEventListener('input', () => {
        opacityValue.textContent = opacity.value;
      });

      watermarkColor.addEventListener('input', () => {
        colorHex.textContent = watermarkColor.value;
      });

      input.addEventListener('change', async () => {
        const file = input.files[0];
        if (!file) return;
        status.textContent = '';
        try {
          currentBytes = await file.arrayBuffer();
          const doc = await PDFDocument.load(currentBytes, { ignoreEncryption: true });
          const pages = doc.getPageCount();
          info.textContent = `"${file.name}" — ${pages} page${pages === 1 ? '' : 's'}`;
          controls.classList.remove('hidden');
        } catch {
          controls.classList.add('hidden');
          status.textContent = '⚠️ Could not read this PDF — it may be corrupted or password-protected.';
        }
      });

      btn.addEventListener('click', async () => {
        if (!currentBytes) return;
        btn.disabled = true;
        status.textContent = 'Adding watermark…';

        try {
          const doc = await PDFDocument.load(currentBytes, { ignoreEncryption: true });
          const font = await doc.embedFont(StandardFonts.Helvetica);
          const pages = doc.getPages();

          const text = watermarkText.value || 'CONFIDENTIAL';
          const size = parseInt(fontSize.value, 10) || 72;
          const alpha = (parseInt(opacity.value, 10) || 30) / 100;
          const hex = watermarkColor.value || '#cccccc';
          const r = parseInt(hex.slice(1, 3), 16) / 255;
          const g = parseInt(hex.slice(3, 5), 16) / 255;
          const b = parseInt(hex.slice(5, 7), 16) / 255;

          const color = rgb(r, g, b);

          const approxTextWidth = text.length * size * 0.55;
          const step = size * 3.2;
          const cos45 = Math.cos(Math.PI / 4);
          const sin45 = Math.sin(Math.PI / 4);

          for (const page of pages) {
            const { width, height } = page.getSize();
            const diag = Math.sqrt(width * width + height * height);
            page.setOpacity(alpha);

            for (let perp = -diag; perp < diag; perp += step) {
              for (let along = -diag; along < diag; along += step * 2) {
                const x = width / 2 + along * cos45 - perp * sin45 - approxTextWidth / 2;
                const y = height / 2 + along * sin45 + perp * cos45 - size / 3;
                page.drawText(text, {
                  x,
                  y,
                  size,
                  color,
                  rotate: degrees(-45),
                  font,
                });
              }
            }

            page.setOpacity(1);
          }

          const bytes = await doc.save();
          const blob = new Blob([bytes], { type: 'application/pdf' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'watermarked.pdf';
          a.click();
          setTimeout(() => URL.revokeObjectURL(url), 5000);
          status.textContent = '✓ Done! Your watermarked PDF was downloaded.';
        } catch {
          status.textContent = '⚠️ Something went wrong while adding the watermark.';
        } finally {
          btn.disabled = false;
        }
      });
    })();
  </script>
</ToolLayout>
