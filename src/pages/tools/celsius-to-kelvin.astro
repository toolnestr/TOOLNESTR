---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Celsius to Kelvin"
  emoji="🌡️"
  fromUnit="degrees Celsius" toUnit="Kelvin"
  fromTitle="Celsius" toTitle="Kelvin"
  fromSym="°C" toSym="K"
  quantity="temperature"
  kind="tempCK"
  reverseSlug="kelvin-to-celsius" reverseLabel="Kelvin to Celsius Converter"
  hasReverse={true}
  related={[{"slug":"celsius-to-fahrenheit","label":"Celsius to Fahrenheit Converter"},{"slug":"fahrenheit-to-celsius","label":"Fahrenheit to Celsius Converter"}]}
  useCase="Scientists use Kelvin for absolute temperature, so this converts everyday Celsius into the SI base unit."
/>
