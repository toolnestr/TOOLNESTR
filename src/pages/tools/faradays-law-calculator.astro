---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Faraday's Law of Electrolysis Calculator";
const description = "Faraday's law of electrolysis calculator: find the mass of metal deposited or dissolved from current, time, molar mass and electrons transferred.";
const intro = "Solve m = (I×t×M)/(n×F) for the mass of metal deposited or dissolved during electrolysis, from current, time, molar mass, and the number of electrons transferred per ion. Two 3D diagrams show an electroplating cell and compare deposited mass at different plating times, with charts showing mass vs current and mass vs time.";
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is Faraday's law of electrolysis?", a: "Faraday's law states that the mass of a substance deposited or dissolved at an electrode is directly proportional to the total electric charge passed through the cell: m = (Q×M)/(n×F), where Q = I×t is the charge, M is molar mass, n is electrons per ion, and F is Faraday's constant (96,485 C/mol)." },
  { q: "What is Faraday's constant?", a: 'Faraday\'s constant, F = 96,485 coulombs per mole, is the electric charge carried by one mole of electrons. It links the macroscopic quantity of charge passed through a cell to the microscopic number of electrons actually transferred.' },
  { q: 'Why does the number of electrons transferred (n) matter?', a: 'Different ions require different numbers of electrons to be reduced or oxidized — Cu²⁺ needs 2 electrons per copper atom deposited, while Ag⁺ needs only 1 per silver atom. For the same charge passed, an ion requiring fewer electrons deposits proportionally more mass.' },
  { q: 'How is charge related to current and time?', a: 'Charge Q = I × t, where I is current in amps and t is time in seconds. This is the same relationship used in basic circuit calculations — electrolysis just uses that charge to drive a chemical reaction at each electrode.' },
  { q: 'What is electroplating and how does Faraday\'s law apply?', a: "Electroplating deposits a thin layer of metal onto a surface by passing a controlled current through a solution containing that metal's ions. Faraday's law lets engineers precisely calculate how long to run the current to achieve a target coating thickness or mass." },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: "How to use the Faraday's Law of Electrolysis Calculator",
  description: 'Find the mass of metal deposited or dissolved during electrolysis from current, time, molar mass, and electrons transferred.',
  steps: [
    { name: 'Enter current and time', text: 'Provide the current I (amps) and the duration t (seconds) the current flows.' },
    { name: 'Enter molar mass and electrons transferred', text: "Provide the metal's molar mass M and n, the number of electrons transferred per ion (e.g. n=2 for Cu²⁺, n=1 for Ag⁺)." },
    { name: 'Read the result', text: 'The mass of metal deposited or dissolved solves instantly.' },
  ],
};

const formulas = [
  { expr: 'Q = I × t', note: 'total electric charge passed — I in amps, t in seconds' },
  { expr: 'm = (Q × M) / (n × F)', note: 'mass deposited — M = molar mass, n = electrons per ion, F = 96,485 C/mol' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — copper electroplating', tone: 'slate',
    given: 'A current of I = 2 A flows for t = 3600 s (1 hour) through a copper sulfate solution. Copper\'s molar mass M = 63.55 g/mol, and Cu²⁺ requires n = 2 electrons.',
    rows: [
      { label: 'Charge:', value: 'Q = I × t = 2 × 3600 = 7200 C' },
      { label: 'Formula:', value: 'm = (Q × M) / (n × F)' },
      { label: 'Substitute:', value: 'm = (7200 × 63.55) / (2 × 96,485) = 457,560 / 192,970' },
      { label: 'Result:', value: 'm ≈ 2.371 g of copper deposited', full: true },
    ],
    note: 'Just over 2 grams of copper plates out in one hour at 2 amps — real electroplating baths run for hours to build up a usable coating thickness.',
  },
  {
    title: 'Worked example 2 — silver electroplating', tone: 'amber',
    given: 'A current of I = 0.5 A flows for t = 1800 s (30 minutes) through a silver nitrate solution. Silver\'s molar mass M = 107.87 g/mol, and Ag⁺ requires n = 1 electron.',
    rows: [
      { label: 'Charge:', value: 'Q = I × t = 0.5 × 1800 = 900 C' },
      { label: 'Formula:', value: 'm = (Q × M) / (n × F)' },
      { label: 'Substitute:', value: 'm = (900 × 107.87) / (1 × 96,485) = 97,083 / 96,485' },
      { label: 'Result:', value: 'm ≈ 1.006 g of silver deposited', full: true },
    ],
    note: 'Silver deposits more efficiently per coulomb than copper here, partly because Ag⁺ needs only 1 electron per ion instead of 2.',
  },
];

const comparison = {
  heading: 'Mass deposited by 1 coulomb of charge, by metal',
  note: 'For the same tiny amount of charge, different metals deposit different masses — driven by both molar mass and how many electrons each ion needs.',
  headers: [{ label: 'Metal ion' }, { label: 'n' }, { label: 'M (g/mol)' }, { label: 'mg per coulomb' }],
  rows: [
    ['Ag⁺ (silver)', '1', '107.87', '1.118 mg'],
    ['Cu²⁺ (copper) ★', '2', '63.55', '0.329 mg'],
    ['Ni²⁺ (nickel)', '2', '58.69', '0.304 mg'],
    ['Al³⁺ (aluminum)', '3', '26.98', '0.0932 mg'],
  ],
  highlightIndex: 1,
  footnote: '★ Computed as (M/n)/F × 1000 mg. Silver deposits the most mass per coulomb here, combining a large molar mass with needing only 1 electron per ion.',
};

const realWorld = [
  { emoji: '✨', title: 'Electroplating and jewelry finishing', body: "Jewelry, tableware, and electronics use electroplating to apply thin, controlled coatings of gold, silver, chromium, or nickel — Faraday's law lets manufacturers precisely time the process to hit a target coating mass." },
  { emoji: '🔋', title: 'Battery manufacturing and charge capacity', body: "Battery charge capacity ratings are fundamentally tied to Faraday's law, since the amount of active material that can be oxidized or reduced sets the maximum charge (and therefore energy) the battery can store." },
  { emoji: '⚙️', title: 'Aluminum production (Hall-Héroult process)', body: 'Industrial aluminum smelting uses electrolysis on a massive scale, and Faraday\'s law is the basis for calculating the electrical energy and time needed to produce a target quantity of aluminum metal from its ore.' },
  { emoji: '🧪', title: 'Electrorefining of metals', body: "Faraday's law underlies electrorefining, where impure metal is dissolved from an anode and redeposited in pure form at a cathode, used industrially to purify copper and other metals to very high purity." },
];

const misconceptions = [
  { claim: '"The same current for the same time always deposits the same mass, regardless of the metal."', truth: 'Mass deposited depends on the metal\'s molar mass and how many electrons its ion requires (n), not just on current and time — silver, copper, and aluminum all deposit different masses for the exact same charge passed.' },
  { claim: '"Faraday\'s constant is the charge of a single electron."', truth: "Faraday's constant (96,485 C/mol) is the charge carried by one full mole of electrons, not a single electron — it equals the elementary charge (1.602×10⁻¹⁹ C) multiplied by Avogadro's number." },
  { claim: '"Doubling the current doubles the deposition rate, but doubling the time has no such effect."', truth: 'Both current and time have exactly the same effect, since they only ever enter the formula multiplied together as charge (Q = I×t) — doubling either one alone doubles the mass deposited, just as doubling both would quadruple it.' },
  { claim: '"Electrolysis and a galvanic cell (battery) are the same process."', truth: 'They are opposites: a galvanic cell generates electrical energy from a spontaneous chemical reaction (positive E°cell), while electrolysis uses external electrical energy to force a non-spontaneous reaction to occur — but Faraday\'s law of mass-charge proportionality applies to both.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 17, "Electrochemistry" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/17-7-electrolysis" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 20, Electrochemistry (Electrolysis).' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Electrolysis and Faraday\'s laws.' },
];
const sourcesNote = 'm = (I×t×M)/(n×F) with F = 96,485 C/mol (Faraday\'s constant). Assumes 100% current efficiency (no side reactions). Results are rounded for display.';

const howToUse = [
  { title: 'Enter current and time', body: 'Provide current in amps and duration in seconds (or use the minutes/hours toggle).' },
  { title: 'Enter molar mass and n', body: "Provide the metal ion's molar mass and how many electrons it needs per ion." },
  { title: 'Read the result', body: 'Mass deposited or dissolved solves live in grams.' },
];

const related = [
  { href: '/tools/cell-emf-calculator', emoji: '🔌', title: 'Cell EMF Calculator', desc: 'E°cell = E°cathode − E°anode, plus Gibbs free energy and spontaneity.' },
  { href: '/tools/nernst-equation-calculator', emoji: '🔋', title: 'Nernst Equation Calculator', desc: 'E_cell = E°_cell − (0.0592/n)log(Q) at 25°C.' },
  { href: '/tools/avogadros-number-calculator', emoji: '🌌', title: "Avogadro's Number Calculator", desc: 'N = n×N_A — moles to particles, or mass to particles.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="every mole of electrons that flows through an electrolytic cell drives a fixed, predictable amount of chemical change at each electrode — so the total mass deposited or dissolved is directly proportional to the total electric charge passed."
  howIntro="Charge and current are related simply by Q = I×t. Each mole of a metal ion needs exactly n moles of electrons to be reduced to metal (n depends on the ion's charge, like 2 for Cu²⁺ or 1 for Ag⁺), and each mole of electrons carries a charge of F = 96,485 coulombs (Faraday's constant). Combining these relationships, the moles of metal deposited equal Q/(nF), and multiplying by molar mass M converts moles into the mass m = (I×t×M)/(n×F) that actually plates out."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Faraday's law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Current I (A)</span>
        <input id="I" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time t (seconds)</span>
        <input id="t" type="number" step="any" value="3600" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Molar mass M (g/mol)</span>
        <input id="M" type="number" step="any" value="63.55" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Electrons per ion (n)</span>
        <input id="n" type="number" step="1" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Mass deposited (m)</div><div id="r-m" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Charge passed (Q)</div><div id="r-q" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="fe-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Electroplating in action</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-plating" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. An electroplating cell</h3>
          <p class="mt-1 text-sm text-slate-600">A metal object (cathode) sits in a solution of metal ions — current drives those ions to deposit onto the object's surface as a thin plated layer.</p>
        </div>
        <div>
          <div id="diag-thickness" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Deposited mass over time</h3>
          <p class="mt-1 text-sm text-slate-600">A <span class="font-semibold text-slate-500">short plating time</span> (thin layer) versus a <span class="font-semibold text-amber-500">long plating time</span> (thick layer) — mass builds up linearly with time at constant current.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Faraday's law graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Mass deposited vs current (fixed t=3600s, Cu)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-current"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Mass deposited vs time (fixed I=2A, Cu)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-time"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const F = 96485;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('fe-err').textContent = '';
        el('r-m').textContent = '—'; el('r-q').textContent = '—';
        const I = parseFloat(el('I').value), t = parseFloat(el('t').value), M = parseFloat(el('M').value), n = parseFloat(el('n').value);
        if (isNaN(I) || isNaN(t) || isNaN(M) || isNaN(n)) return;
        if (n <= 0 || M <= 0 || t < 0 || I < 0) { el('fe-err').textContent = 'Molar mass and n must be positive; current and time cannot be negative.'; return; }
        const Q = I * t;
        const m = (Q * M) / (n * F);
        el('r-q').textContent = fmt(Q) + ' C';
        el('r-m').textContent = fmt(m) + ' g';
      }
      ['I', 't', 'M', 'n'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsI = [], dataI = [];
        for (let i = 0.5; i <= 5; i += 0.5) { labelsI.push(i.toFixed(1)); dataI.push(+((i * 3600 * 63.55) / (2 * F)).toFixed(3)); }
        charts.current = new Chart(el('chart-current'), {
          type: 'line',
          data: { labels: labelsI, datasets: [{ label: 'mass (g)', data: dataI, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Current (A)' } }, y: { title: { display: true, text: 'Mass deposited (g)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsT = [], dataT = [];
        for (let tt = 0; tt <= 7200; tt += 600) { labelsT.push(Math.round(tt / 60)); dataT.push(+((2 * tt * 63.55) / (2 * F)).toFixed(3)); }
        charts.time = new Chart(el('chart-time'), {
          type: 'line',
          data: { labels: labelsT, datasets: [{ label: 'mass (g)', data: dataT, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (minutes)' } }, y: { title: { display: true, text: 'Mass deposited (g)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: electroplating cell ----
      let diagPlating = null;
      function initDiagPlating() {
        const c = el('diag-plating'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 0, 0), OPTS);
        const bath = new THREE.Mesh(new THREE.CylinderGeometry(2.2, 2.2, 2.2, 32, 1, true), new THREE.MeshStandardMaterial({ color: 0x93c5fd, roughness: 0.3, transparent: true, opacity: 0.45 }));
        s.scene.add(bath);
        const object = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.6, 0.4), new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.4 }));
        object.position.set(-0.8, 0.2, 0); s.scene.add(object);
        const anodeRod = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 1.8, 16), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5 }));
        anodeRod.position.set(0.9, 0.2, 0); s.scene.add(anodeRod);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagPlating = { resize: s.resize };
      }

      // ---- Diagram 2: thin vs thick plated layer ----
      let diagThickness = null;
      function initDiagThickness() {
        const c = el('diag-thickness'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const core1 = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.6, 0.4), new THREE.MeshStandardMaterial({ color: 0x64748b, roughness: 0.5 }));
        core1.position.set(-1.6, 0, 0); s.scene.add(core1);
        const shell1 = new THREE.Mesh(new THREE.BoxGeometry(0.86, 1.66, 0.46), new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.5, transparent: true, opacity: 0.6 }));
        shell1.position.set(-1.6, 0, 0); s.scene.add(shell1);
        const core2 = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.6, 0.4), new THREE.MeshStandardMaterial({ color: 0x64748b, roughness: 0.5 }));
        core2.position.set(1.6, 0, 0); s.scene.add(core2);
        const shell2 = new THREE.Mesh(new THREE.BoxGeometry(1.1, 1.9, 0.7), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5, transparent: true, opacity: 0.7 }));
        shell2.position.set(1.6, 0, 0); s.scene.add(shell2);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagThickness = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[faradays-law] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[faradays-law] charts failed', e); }
        if (window.THREE) {
          try { initDiagPlating(); } catch (e) { console.error('[faradays-law] plating diagram failed', e); }
          try { initDiagThickness(); } catch (e) { console.error('[faradays-law] thickness diagram failed', e); }
        }
        mountResize([diagPlating, diagThickness]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
