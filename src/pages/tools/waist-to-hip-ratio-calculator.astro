---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Waist-to-Hip Ratio Calculator';
const description =
  'Free waist-to-hip ratio (WHR) calculator. Measure your body fat distribution and assess health risk using WHO categories.';
const intro =
  'Enter your waist and hip measurements to calculate your waist-to-hip ratio and see your WHO health risk category.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is waist-to-hip ratio?', a: 'Waist-to-hip ratio (WHR) is the circumference of your waist divided by the circumference of your hips. It measures where you carry your body fat — around your abdomen (apple shape) or hips and thighs (pear shape).' },
  { q: 'Why does WHR matter for health?', a: 'Abdominal fat (apple shape, high WHR) is more metabolically active and linked to higher risks of heart disease, type 2 diabetes and metabolic syndrome than fat stored around the hips and thighs.' },
  { q: 'Where should I measure?', a: 'Waist: at the narrowest point between the bottom of your ribs and the top of your hip bone, usually around your navel. Hips: at the widest point around your buttocks. Measure relaxed, with the tape level.' },
  { q: 'What is a healthy WHR?', a: 'WHO guidelines: For men, below 0.90 is low risk, 0.90–0.99 is moderate risk, 1.0+ is high risk. For women, below 0.80 is low risk, 0.80–0.89 is moderate risk, 0.90+ is high risk.' },
  { q: 'Can I improve my WHR?', a: 'Yes — reducing overall body fat through a calorie deficit, especially abdominal fat, lowers WHR. Strength training and high-intensity exercise are particularly effective for reducing visceral fat.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric (cm)</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial (in)</button>
    </div>

    <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
      <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>

    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Waist circumference (<span class="unit">cm</span>)</span>
        <input id="waist" type="number" step="any" placeholder="85" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Hip circumference (<span class="unit">cm</span>)</span>
        <input id="hip" type="number" step="any" placeholder="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Waist-to-hip ratio</div>
        <div id="r-whr" class="mt-1 text-3xl font-bold">—</div>
        <div id="r-risk" class="mt-1 text-sm font-medium">—</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Shape type</div><div id="r-shape" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Waist alone</div><div id="r-waist-alone" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your waist and hip measurements to calculate your WHR.</p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical advice. Consult a professional for full health assessment.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About waist-to-hip ratio</h2>
    <p class="mt-2 text-slate-600">
      Waist-to-hip ratio is a simple yet powerful measure of body fat distribution. While overall body fat level matters, <em>where</em> you carry that fat has a significant impact on your health risk. Fat stored around the abdomen (visceral fat) is metabolically active and releases inflammatory substances that increase the risk of cardiovascular disease, type 2 diabetes, high blood pressure and metabolic syndrome. Fat stored around the hips and thighs (subcutaneous fat) is relatively protective. The <a href="https://www.who.int" rel="noopener">World Health Organization</a> uses WHR as a standard screening tool for metabolic risk. For a fuller picture of your body composition, pair this with the <a href="/tools/bmi-calculator/" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a> and <a href="/tools/body-fat/" class="font-medium text-indigo-600 hover:underline">Body Fat Calculator</a>.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" role="img" aria-labelledby="whr-title whr-desc">
      <title id="whr-title">Body measurement lines</title>
      <desc id="whr-desc">A body silhouette with horizontal lines marking the waist and hip measurement locations.</desc>
      <ellipse cx="400" cy="100" rx="55" ry="90" fill="none" stroke="#e2e8f0" stroke-width="3" />
      <line x1="300" y1="85" x2="500" y2="85" stroke="#ef4444" stroke-width="3" />
      <text x="275" y="90" font-size="13" fill="#dc2626" font-weight="bold">Waist</text>
      <line x1="310" y1="145" x2="490" y2="145" stroke="#6366f1" stroke-width="3" />
      <text x="275" y="150" font-size="13" fill="#6366f1" font-weight="bold">Hip</text>
      <text x="400" y="205" text-anchor="middle" font-size="11" fill="#94a3b8">WHR = Waist circumference / Hip circumference</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Waist and hip measurement locations on the body — WHR is the ratio of waist to hip circumference</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      WHR is calculated by dividing your waist measurement by your hip measurement. The result is a ratio between roughly 0.65 and 1.20 for most adults. A ratio of 1.0 means your waist and hips are the same circumference. Higher values indicate more abdominal fat relative to hip fat. The WHO categories differ by sex because women naturally have wider hips and store more subcutaneous fat in that area, so a given ratio represents different risk levels for men and women. The calculator also assesses your waist circumference alone — a waist over 88 cm (35 in) for women or 102 cm (40 in) for men indicates elevated risk regardless of WHR.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>WHR</strong> = waist circumference ÷ hip circumference
    </p>
    <p class="mt-3 text-slate-600">
      <strong>WHO risk categories:</strong><br>
      Men: &lt; 0.90 low risk, 0.90–0.99 moderate risk, ≥ 1.00 high risk<br>
      Women: &lt; 0.80 low risk, 0.80–0.89 moderate risk, ≥ 0.90 high risk
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 45-year-old man has a waist measurement of 96 cm and hip measurement of 102 cm.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Waist:</span> <span class="text-slate-600">96 cm</span></div>
        <div><span class="font-medium text-slate-700">Hip:</span> <span class="text-slate-600">102 cm</span></div>
        <div><span class="font-medium text-slate-700">WHR:</span> <span class="text-slate-600">96 ÷ 102 = <strong>0.94</strong></span></div>
        <div><span class="font-medium text-slate-700">Risk category (male):</span> <span class="text-slate-600"><strong>Moderate</strong> (0.90–0.99)</span></div>
        <div><span class="font-medium text-slate-700">Waist alone:</span> <span class="text-slate-600">96 cm — below 102 cm threshold, so waist alone is <strong>not elevated</strong></span></div>
        <div><span class="font-medium text-slate-700">Shape:</span> <span class="text-slate-600"><strong>Apple shape</strong> (higher abdominal fat distribution)</span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🫀</span>
      <h3 class="mt-2 font-semibold text-slate-900">Heart health monitor</h3>
      <p class="mt-1 text-sm text-slate-600">Track your WHR over time as a simple indicator of metabolic risk. A rising WHR is a red flag even if your weight stays the same.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍎</span>
      <h3 class="mt-2 font-semibold text-slate-900">Apple-shaped individual</h3>
      <p class="mt-1 text-sm text-slate-600">If your WHR is high (apple shape), you face higher health risks. Targeted interventions — weight loss and exercise — are particularly important.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍐</span>
      <h3 class="mt-2 font-semibold text-slate-900">Pear-shaped individual</h3>
      <p class="mt-1 text-sm text-slate-600">A lower WHR (pear shape) is generally protective for metabolic health. Maintain a healthy lifestyle to preserve this favourable fat distribution.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍⚕️</span>
      <h3 class="mt-2 font-semibold text-slate-900">GP / nurse</h3>
      <p class="mt-1 text-sm text-slate-600">Use WHR alongside BMI for a more complete cardiometabolic risk assessment in routine health checks and lifestyle counselling.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to measure your WHR</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure your waist</h3>
        <p class="mt-1 text-sm text-slate-600">Find the narrowest point between your ribs and hip bone. Measure with a flexible tape, snug but not compressing the skin, after exhaling.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure your hips</h3>
        <p class="mt-1 text-sm text-slate-600">Measure at the widest point around your buttocks, keeping the tape level. Take both measurements in the same units.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your ratio</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator divides waist by hip. See your WHR, WHO risk category and whether your waist circumference alone is elevated.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for improving your WHR</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Reduce overall body fat</h3>
        <p class="mt-1 text-sm text-slate-600">You cannot spot-reduce belly fat. A calorie deficit that reduces overall body fat will shrink waist circumference. Aim for moderate, sustainable weight loss of 0.5–1 kg per week.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Exercise regularly</h3>
        <p class="mt-1 text-sm text-slate-600">Both aerobic exercise and strength training reduce visceral fat. HIIT and resistance training are particularly effective for improving body composition and lowering WHR.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Limit added sugar and alcohol</h3>
        <p class="mt-1 text-sm text-slate-600">High sugar intake and excess alcohol are strongly linked to visceral fat accumulation. Reducing both can lead to measurable decreases in waist circumference over several weeks.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/bmi-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">BMI Calculator</a>
      <a href="/tools/body-fat/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Body Fat Calculator</a>
      <a href="/tools/calorie-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Calorie Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      document.querySelectorAll('.unit').forEach((u) => (u.textContent = isMetric ? 'cm' : 'in'));
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const female = el('sex').value === 'female';
      let waist, hip;
      waist = parseFloat(el('waist').value);
      hip = parseFloat(el('hip').value);
      if (!waist || !hip || waist <= 0 || hip <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const whr = waist / hip;
      let risk, shape;
      if (female) {
        if (whr < 0.80) { risk = 'Low risk'; shape = 'Pear'; }
        else if (whr < 0.90) { risk = 'Moderate risk'; shape = 'Apple-pear'; }
        else { risk = 'High risk'; shape = 'Apple'; }
      } else {
        if (whr < 0.90) { risk = 'Low risk'; shape = 'Pear'; }
        else if (whr < 1.00) { risk = 'Moderate risk'; shape = 'Apple-pear'; }
        else { risk = 'High risk'; shape = 'Apple'; }
      }
      const k = metric ? 1 : 2.54;
      const waistCm = waist * k;
      const waistElevated = female ? (waistCm > 88) : (waistCm > 102);
      const waistStr = metric
        ? waist.toFixed(1) + ' cm' + (waistElevated ? ' (elevated)' : ' (normal)')
        : (waist * 2.54).toFixed(0) + ' cm' + (waistElevated ? ' (elevated)' : ' (normal)');
      el('r-whr').textContent = whr.toFixed(2);
      el('r-risk').textContent = risk;
      el('r-shape').textContent = shape;
      el('r-waist-alone').textContent = waistStr;
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'waist', 'hip'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
