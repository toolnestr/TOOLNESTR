---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Ml to Fluid Ounces (US)"
  emoji="🧪"
  fromUnit="milliliters" toUnit="US fluid ounces"
  fromTitle="Milliliters" toTitle="Fluid Ounces"
  fromSym="mL" toSym="fl oz"
  quantity="volume"
  kind="factor" factor={0.0338140227}
  reverseSlug="ounces-to-ml" reverseLabel="Fluid Ounces to Ml Converter"
  hasReverse={true}
  related={[{"slug":"volume-converter","label":"Volume Converter"}]}
  useCase="Handy for drinks and recipes when a metric volume needs to be read in US fluid ounces."
/>
