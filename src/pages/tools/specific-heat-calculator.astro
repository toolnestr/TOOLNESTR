---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Specific Heat Calculator';
const description = 'Specific heat calculator with 3D diagrams and charts. Solve c = Q/(mΔT) to find specific heat capacity, heat energy, mass, or temperature change, and identify unknown materials from calorimetry data.';
const intro = 'Find a material’s specific heat capacity from calorimetry data with c = Q / (m × ΔT), then compare it to known materials to identify an unknown metal. Diagrams and charts show why materials differ so widely.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is specific heat capacity?', a: 'Specific heat capacity (c) is the amount of energy, in joules, needed to raise the temperature of 1 kg of a substance by 1 K (or 1°C). It is an intrinsic property of the material — water is 4184 J/(kg·K), while metals like copper (385) and lead (128) are much lower.' },
  { q: 'Why is water’s specific heat so high compared to metals?', a: 'Water molecules form extensive hydrogen bonds with their neighbors. Raising water’s temperature requires enough energy to make molecules move faster while constantly breaking and reforming these bonds, which takes far more energy per degree than in metals, where atoms are held together by simpler, more uniform metallic bonding.' },
  { q: 'How do you identify an unknown metal using specific heat?', a: 'In a calorimetry experiment, measure the heat added (Q), the sample’s mass (m), and its temperature change (ΔT), then compute c = Q / (mΔT). Compare the result to a table of known specific heat values (aluminum 897, iron 449, copper 385, lead 128, gold 129 J/(kg·K)) — the closest match, usually within a few percent, is a strong candidate for the material.' },
  { q: 'What is the difference between specific heat and heat capacity?', a: 'Specific heat capacity (c) is per unit mass — J/(kg·K) — and depends only on the material. Heat capacity (C) is for a whole object: C = m × c, measured in J/K, and depends on both the material and how much of it you have. A large iron block has a bigger heat capacity than a small one, even though both share the same specific heat.' },
  { q: 'Why might a measured specific heat not exactly match a table value?', a: 'Real samples are rarely pure — alloys, impurities, or measurement error (heat lost to the surroundings, an inexact thermometer reading, or an imprecise mass) can shift the measured c a few percent from the textbook value. A match within about 5% is usually good enough to identify the likely material or alloy family.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Specific Heat Calculator',
  description: 'Solve c = Q / (m × ΔT) for specific heat capacity, heat energy, mass, or temperature change, and identify an unknown material.',
  steps: [
    { name: 'Enter three known values', text: 'Fill in any three of specific heat (c), heat energy (Q), mass (m), and ΔT — leave the value you want to solve for blank.' },
    { name: 'Read the result', text: 'The missing quantity solves instantly.' },
    { name: 'Check the material match', text: 'If you solved for c, the calculator compares it to known materials and reports the closest match within about 5%.' },
  ],
};

const formulas = [
  { expr: 'c = Q / (m × ΔT)', note: 'specific heat capacity from heat, mass &amp; temperature change' },
  { expr: 'Q = m × c × ΔT', note: 'rearranged for heat energy' },
  { expr: 'm = Q / (c × ΔT)', note: 'rearranged for mass, or ΔT = Q / (m × c)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — identifying an unknown metal', tone: 'slate',
    given: '500 J of heat is added to a 0.200 kg sample of an unknown metal, raising its temperature by 5.85°C. Find its specific heat and identify the material.',
    rows: [
      { label: 'Specific heat:', value: 'c = Q / (m × ΔT) = 500 / (0.200 × 5.85)' },
      { label: 'Result:', value: 'c = 500 / 1.17 = 427.35 J/(kg·K)', full: true },
      { label: 'Closest match:', value: 'Iron (c = 449 J/(kg·K)) — about 4.8% off, likely iron or an iron alloy.' },
    ],
    note: 'A perfectly pure sample would land closer to 449; small differences like this are normal for calorimetry due to heat loss to the surroundings or an alloyed sample.',
  },
  {
    title: 'Worked example 2 — confirming water’s specific heat', tone: 'amber',
    given: '2.0 kg of water absorbs 251,040 J of heat and its temperature rises from 20°C to 50°C. Confirm the specific heat capacity.',
    rows: [
      { label: 'Temperature change:', value: 'ΔT = 50 − 20 = 30 K' },
      { label: 'Specific heat:', value: 'c = Q / (m × ΔT) = 251,040 / (2.0 × 30)' },
      { label: 'Result:', value: 'c = 251,040 / 60 = 4184 J/(kg·K)', full: true },
    ],
    note: 'This matches the standard reference value for liquid water almost exactly, confirming the sample is water (or a very dilute aqueous solution).',
  },
];

const comparison = {
  heading: 'Specific heat capacity of common materials',
  note: 'Materials with a higher c absorb more heat for the same mass and temperature change — use this table to identify an unknown sample from a measured c value.',
  headers: [{ label: 'Material' }, { label: 'c — J/(kg·K)' }, { label: 'Energy for 1 kg, ΔT = 1 K' }],
  rows: [
    ['Water (liquid)', '4184', '4184 J'],
    ['Aluminum', '897', '897 J'],
    ['Iron', '449', '449 J'],
    ['Copper', '385', '385 J'],
    ['Gold', '129', '129 J'],
    ['Lead', '128', '128 J'],
  ],
  highlightIndex: 0,
  footnote: 'Values are standard reference specific heat capacities at typical conditions, rounded to 3–4 significant figures. A measured c within about 5% of one of these is a strong material match.',
};

const realWorld = [
  { emoji: '\u{1F52C}', title: 'Calorimetry in the lab', body: 'Measuring the heat absorbed by a known mass of water when a hot metal sample is dropped in lets chemists and physics students back out the metal’s specific heat and identify unknown samples — a classic introductory lab experiment.' },
  { emoji: '\u{1F697}', title: 'Engine coolant selection', body: 'Coolants are chosen partly for high specific heat capacity so they can absorb large amounts of engine heat without their own temperature rising too quickly, keeping the engine in a safe operating range.' },
  { emoji: '\u{1F373}', title: 'Cookware material choice', body: 'Cast iron pans have a lower specific heat than the water or food inside them, so they heat up quickly and hold that heat, while materials with a higher specific heat resist rapid temperature swings.' },
  { emoji: '\u{1F30A}', title: 'Climate moderation by oceans', body: 'Because water has such a high specific heat, large bodies of water absorb and release enormous amounts of heat with only small temperature changes, moderating coastal climates compared to inland regions.' },
];

const misconceptions = [
  { claim: '"All metals have roughly the same specific heat."', truth: 'False — common metals vary by more than 3x, from about 128 J/(kg·K) for lead to 897 J/(kg·K) for aluminum. This wide spread is exactly what makes specific heat useful for identifying an unknown metal.' },
  { claim: '"Specific heat and heat capacity are the same thing."', truth: 'They are related but distinct. Specific heat (c) is a per-unit-mass property of the material, in J/(kg·K). Heat capacity (C) belongs to a specific object: C = m × c, in J/K, and depends on how much material you have, not just what it is made of.' },
  { claim: '"A measured c must exactly match a table value to identify the material."', truth: 'Not necessarily — real samples, alloys, and experimental heat losses typically produce a measured c within a few percent of the pure reference value. A match within about 5% is usually good enough to identify the likely material.' },
  { claim: '"Higher specific heat means a material heats up faster."', truth: 'The opposite — a higher specific heat means a material needs more energy per kilogram to change temperature by the same amount, so for the same heat input it heats up more slowly than a low-c material.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — Chapter 1, Temperature and Heat (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/1-3-heat-capacity-and-equilibrium-temperature" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 18, Temperature, Heat, and the First Law of Thermodynamics.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — specific heat capacity and calorimetry.' },
];
const sourcesNote = 'c = Q / (mΔT) applies to sensible heat (within one phase) only. Specific heat values are standard reference figures; results and material matches are rounded for display.';

const howToUse = [
  { title: 'Enter three known values', body: 'Fill in any three of c, Q, m, and ΔT — leave one field blank to solve for it.' },
  { title: 'Read the solved value', body: 'The missing quantity — c, Q, m, or ΔT — solves automatically.' },
  { title: 'Check the material identification', body: 'When solving for c, see which known material it most closely matches, within about 5%.' },
];

const related = [
  { href: '/tools/heat-transfer-calculator', emoji: '\u{1F321}️', title: 'Heat Transfer Calculator', desc: 'Q = mcΔT — solve heat energy, mass, or ΔT.' },
  { href: '/tools/mechanical-efficiency-calculator', emoji: '⚙️', title: 'Mechanical Efficiency Calculator', desc: 'η = output/input × 100% — from work or power.' },
  { href: '/tools/calorimetry-calculator', emoji: '⚖️', title: 'Calorimetry Calculator', desc: 'Find final equilibrium temperature of mixed substances.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="rearranging Q = mcΔT to solve for c lets you measure an unknown material's specific heat capacity from a simple calorimetry experiment, then compare it against known reference values to identify the material."
  howIntro="The same equation solves any missing quantity: Q = mcΔT gives the heat needed for a known material, m = Q/(cΔT) gives the mass a known heat input can warm by a known amount, and c = Q/(mΔT) — this tool's default direction — backs out an unknown material's specific heat from a measurement, which is the basis of the classic 'identify the metal' calorimetry lab."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where specific heat identification actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Specific heat capacity (c)</span>
        <input id="c" type="number" step="any" placeholder="J/(kg·K)" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Heat energy (Q)</span>
        <input id="Q" type="number" step="any" placeholder="J" value="500" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="m" type="number" step="any" placeholder="kg" value="0.200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature change (ΔT)</span>
        <input id="dT" type="number" step="any" placeholder="K or °C" value="5.85" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Specific heat (c)</div><div id="r-c" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Heat energy (Q)</div><div id="r-Q" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass (m)</div><div id="r-m" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">ΔT</div><div id="r-dT" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <div id="material-match" class="mt-4 hidden rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-center text-sm font-medium text-emerald-800"></div>
    <p id="sh-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-metals" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Specific heat varies by metal</h3>
          <p class="mt-1 text-sm text-slate-600">Each cube is the same size (same mass), but the bar beside it shows relative specific heat — aluminum needs much more energy per degree than copper, iron, or lead.</p>
        </div>
        <div>
          <div id="diag-water-vs-metal" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Water vs. metal, same mass &amp; ΔT</h3>
          <p class="mt-1 text-sm text-slate-600">For the same mass and temperature rise, water (tall blue bar) needs roughly 5–10x more energy than a typical metal (short bar) — its high specific heat in action.</p>
        </div>
      </div>
      <p id="diag3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Specific heat graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Specific heat capacity by material</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-c"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Heat energy Q vs ΔT (fixed mass) — water vs aluminum</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-qdt"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const KNOWN = [
        { name: 'Water', c: 4184 },
        { name: 'Aluminum', c: 897 },
        { name: 'Iron', c: 449 },
        { name: 'Copper', c: 385 },
        { name: 'Gold', c: 129 },
        { name: 'Lead', c: 128 },
      ];

      // ---- calculator ----
      function findMatch(c) {
        let best = null, bestPct = Infinity;
        KNOWN.forEach((k) => {
          const pct = Math.abs(c - k.c) / k.c * 100;
          if (pct < bestPct) { bestPct = pct; best = k; }
        });
        return { best, bestPct };
      }
      function update() {
        el('sh-err').textContent = '';
        ['r-c', 'r-Q', 'r-m', 'r-dT'].forEach((id) => (el(id).textContent = '—'));
        el('material-match').classList.add('hidden');
        const c = parseFloat(el('c').value);
        const Q = parseFloat(el('Q').value);
        const m = parseFloat(el('m').value);
        const dT = parseFloat(el('dT').value);
        const filled = [!isNaN(c), !isNaN(Q), !isNaN(m), !isNaN(dT)];
        if (filled.filter(Boolean).length < 3) return;
        let rc = c, rQ = Q, rm = m, rdT = dT;
        if (!filled[0]) {
          if (m === 0 || dT === 0) { el('sh-err').textContent = 'Mass and ΔT cannot be zero when solving for specific heat.'; return; }
          rc = Q / (m * dT);
        } else if (!filled[1]) {
          rQ = m * c * dT;
        } else if (!filled[2]) {
          if (c === 0 || dT === 0) { el('sh-err').textContent = 'Specific heat and ΔT cannot be zero when solving for mass.'; return; }
          rm = Q / (c * dT);
        } else if (!filled[3]) {
          if (m === 0 || c === 0) { el('sh-err').textContent = 'Mass and specific heat cannot be zero when solving for ΔT.'; return; }
          rdT = Q / (m * c);
        }
        if (!isNaN(rc)) el('r-c').textContent = fmt(rc) + ' J/(kg·K)';
        if (!isNaN(rQ)) el('r-Q').textContent = fmt(rQ) + ' J';
        if (!isNaN(rm)) el('r-m').textContent = fmt(rm) + ' kg';
        if (!isNaN(rdT)) el('r-dT').textContent = fmt(rdT) + ' K';
        if (!filled[0] && !isNaN(rc) && rc > 0) {
          const { best, bestPct } = findMatch(rc);
          if (best && bestPct <= 5) {
            el('material-match').textContent = 'Closest match: ' + best.name + ' (' + best.c + ' J/(kg·K)) — ' + bestPct.toFixed(1) + '% difference.';
            el('material-match').classList.remove('hidden');
          } else if (best) {
            el('material-match').textContent = 'No close match (nearest is ' + best.name + ', ' + bestPct.toFixed(1) + '% off) — likely an alloy or non-standard material.';
            el('material-match').classList.remove('hidden');
          }
        }
      }
      ['c', 'Q', 'm', 'dT'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.c = new Chart(el('chart-c'), {
          type: 'bar',
          data: { labels: ['Water', 'Aluminum', 'Iron', 'Copper', 'Gold', 'Lead'], datasets: [{ label: 'c J/(kg·K)', data: [4184, 897, 449, 385, 129, 128], backgroundColor: ['#38bdf8', '#94a3b8', '#ef4444', '#f59e0b', '#eab308', '#64748b'] }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Material' } }, y: { title: { display: true, text: 'c — J/(kg·K)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.qdt = new Chart(el('chart-qdt'), {
          type: 'line',
          data: { labels: [], datasets: [
            { label: 'Water (c=4184)', data: [], borderColor: '#38bdf8', backgroundColor: 'rgba(56,189,248,0.10)', fill: false, tension: 0, pointRadius: 0 },
            { label: 'Aluminum (c=897)', data: [], borderColor: '#94a3b8', backgroundColor: 'rgba(148,163,184,0.10)', fill: false, tension: 0, pointRadius: 0 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'ΔT (K)' } }, y: { title: { display: true, text: 'Q (J)' } } }, plugins: { legend: { position: 'bottom' } } }),
        });
        charts.ready = true;
        updateQdtChart();
      }
      function updateQdtChart() {
        if (!charts.ready) return;
        const m = 1;
        const L = [], Dw = [], Da = [];
        for (let dt = 0; dt <= 100.001; dt += 10) {
          L.push(dt.toFixed(0));
          Dw.push(+(m * 4184 * dt).toFixed(2));
          Da.push(+(m * 897 * dt).toFixed(2));
        }
        charts.qdt.data.labels = L;
        charts.qdt.data.datasets[0].data = Dw;
        charts.qdt.data.datasets[1].data = Da;
        charts.qdt.update();
      }

      // ---- Diagram A: metal cubes with relative-c bars ----
      let diagMetals = null;
      function initDiagMetals() {
        const c = el('diag-metals'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(3, 2, 0), MOL_OPTS);
        const grid = new THREE.GridHelper(14, 14, 0xe2e8f0, 0xeef2f7); grid.position.set(3, 0, 0); s.scene.add(grid);
        const mats = [
          { name: 'Aluminum', c: 897, color: 0x94a3b8 },
          { name: 'Iron', c: 449, color: 0xef4444 },
          { name: 'Copper', c: 385, color: 0xf59e0b },
          { name: 'Lead', c: 128, color: 0x64748b },
        ];
        const maxC = Math.max.apply(null, mats.map((m) => m.c));
        mats.forEach((m, i) => {
          const x = i * 2.4;
          const cube = new THREE.Mesh(new THREE.BoxGeometry(1, 1, 1), new THREE.MeshStandardMaterial({ color: m.color, roughness: 0.35 }));
          cube.position.set(x, 0.5, 0);
          s.scene.add(cube);
          const h = Math.max(0.2, (m.c / maxC) * 4);
          const bar = new THREE.Mesh(new THREE.BoxGeometry(0.5, h, 0.5), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          bar.position.set(x, h / 2, 1.6);
          s.scene.add(bar);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagMetals = { resize: s.resize };
      }

      // ---- Diagram B: water container vs metal block, same mass/ΔT ----
      function liquidContainer(THREE) {
        const g = new THREE.Group();
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        g.add(new THREE.Mesh(new THREE.CylinderGeometry(1.1, 1.1, 4, 32, 1, true), glassMat));
        const liquidMat = new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.55, roughness: 0.3 });
        const liquid = new THREE.Mesh(new THREE.CylinderGeometry(1.02, 1.02, 3.6, 32), liquidMat);
        liquid.position.y = -0.2;
        g.add(liquid);
        return g;
      }
      let diagWvM = null;
      function initDiagWaterVsMetal() {
        const c = el('diag-water-vs-metal'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(1.5, 1, 0), MOL_OPTS);
        const grid = new THREE.GridHelper(10, 10, 0xe2e8f0, 0xeef2f7);
        s.scene.add(grid);
        const water = liquidContainer(THREE);
        water.position.set(-1.6, 2, 0);
        s.scene.add(water);
        const metal = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.9, 1.4), new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.35 }));
        metal.position.set(1.6, 0.45, 0);
        s.scene.add(metal);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagWvM = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[specific-heat] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[specific-heat] charts failed', e); }
        if (window.THREE) {
          try { initDiagMetals(); } catch (e) { console.error('[specific-heat] metals diagram failed', e); el('diag3d-fallback').classList.remove('hidden'); }
          try { initDiagWaterVsMetal(); } catch (e) { console.error('[specific-heat] water-vs-metal diagram failed', e); el('diag3d-fallback').classList.remove('hidden'); }
        } else { el('diag3d-fallback').classList.remove('hidden'); }
        mountResize([diagMetals, diagWvM]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
