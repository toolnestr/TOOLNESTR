---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'pOH Calculator';
const description = 'pOH calculator with a live 3D beaker and charts. Solve pOH = -log[OH-], convert between pOH and [OH-], and use pH + pOH = 14 to switch between them.';
const intro = 'Find pOH from hydroxide concentration, or convert straight from pH using pH + pOH = 14. A live 3D beaker and charts show how OH⁻ density tracks pOH.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is pOH?', a: 'pOH is a measure of the hydroxide ion concentration of a solution: pOH = −log₁₀[OH⁻]. It works exactly like pH, but for [OH⁻] instead of [H⁺]. A low pOH means a high [OH⁻] — a strongly basic solution.' },
  { q: 'How does pOH relate to pH?', a: 'At 25°C, pH + pOH = 14. This comes from the ion product of water, Kw = [H⁺][OH⁻] = 1.0 × 10⁻¹⁴, and taking −log₁₀ of both sides: −log[H⁺] + −log[OH⁻] = −log(Kw) = 14. So pOH = 14 − pH and pH = 14 − pOH.' },
  { q: 'What is Kw and why does it matter here?', a: 'Kw is the ion product (autoionization constant) of water: Kw = [H⁺][OH⁻]. At 25°C, Kw = 1.0 × 10⁻¹⁴, which is where the "14" in pH + pOH = 14 comes from. Every aqueous equilibrium at that temperature must satisfy this product.' },
  { q: 'Why is it 14 specifically at 25°C?', a: 'Kw is temperature-dependent because water\'s autoionization is an equilibrium reaction with its own enthalpy change. At 25°C, Kw happens to equal 1.0 × 10⁻¹⁴, so −log(Kw) = 14. At 0°C, Kw is smaller (about 1.14 × 10⁻¹⁵, so pH+pOH ≈ 14.94); at 60°C, Kw is larger (about 9.6 × 10⁻¹⁴, so pH+pOH ≈ 13.02).' },
  { q: 'What are some common pOH values?', a: 'Pure water at 25°C is pOH 7 (neutral). Household ammonia is around pOH 2–2.5 (strongly basic). Baking soda solution is around pOH 5 (mildly basic). Drain cleaner (strong base) can be near pOH 0.5. Battery acid (strong acid) is near pOH 13.5.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the pOH Calculator',
  description: 'Calculate pOH from hydroxide ion concentration, or convert directly between pH and pOH.',
  steps: [
    { name: 'Pick a mode', text: 'Choose "From [OH⁻]" to solve pOH ⇄ [OH⁻], or "From pH" to convert using pH + pOH = 14.' },
    { name: 'Enter a value', text: 'Type the concentration (scientific notation supported) or the pH/pOH value.' },
    { name: 'Read the result', text: 'The paired value solves instantly, and the 3D beaker updates.' },
  ],
};

const formulas = [
  { expr: 'pOH = −log₁₀[OH⁻]', note: 'pOH from hydroxide concentration' },
  { expr: '[OH⁻] = 10<sup>−pOH</sup>', note: 'hydroxide concentration from pOH' },
  { expr: 'pH + pOH = 14', note: 'at 25°C, from K<sub>w</sub> = [H⁺][OH⁻] = 1.0×10⁻¹⁴' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — from [OH⁻]', tone: 'slate',
    given: 'A solution has [OH⁻] = 1.0 × 10⁻³ mol/L. Find the pOH.',
    rows: [
      { label: 'Formula:', value: 'pOH = −log₁₀[OH⁻]' },
      { label: 'Substitute:', value: 'pOH = −log₁₀(1.0 × 10⁻³) = −(−3.00)' },
      { label: 'pOH:', value: '3.00', full: true },
    ],
    note: 'A pOH of 3.00 is well below 7, so this is a strongly basic solution.',
  },
  {
    title: 'Worked example 2 — from pH', tone: 'amber',
    given: 'A solution has pH = 9.5. Find the pOH and [OH⁻].',
    rows: [
      { label: 'Formula:', value: 'pOH = 14 − pH' },
      { label: 'Substitute:', value: 'pOH = 14 − 9.5 = 4.5' },
      { label: '[OH⁻]:', value: '[OH⁻] = 10⁻⁴·⁵ ≈ 3.16 × 10⁻⁵ mol/L', full: true },
    ],
  },
];

const comparison = {
  heading: 'pOH, pH, [OH⁻] and [H⁺] for common substances',
  note: 'Approximate values at 25°C — real samples vary with concentration, temperature and source.',
  headers: [{ label: 'Substance' }, { label: 'pH' }, { label: 'pOH' }, { label: '[OH⁻] (mol/L)' }, { label: '[H⁺] (mol/L)' }],
  rows: [
    ['Battery acid', '≈ 0.5', '≈ 13.5', '≈ 3.2 × 10⁻¹⁴', '≈ 0.32'],
    ['Lemon juice', '≈ 2', '≈ 12', '≈ 1.0 × 10⁻¹²', '≈ 1.0 × 10⁻²'],
    ['Pure water', '7', '7', '1.0 × 10⁻⁷', '1.0 × 10⁻⁷'],
    ['Baking soda solution', '≈ 9', '≈ 5', '≈ 1.0 × 10⁻⁵', '≈ 1.0 × 10⁻⁹'],
    ['Household ammonia', '≈ 11.5', '≈ 2.5', '≈ 3.2 × 10⁻³', '≈ 3.2 × 10⁻¹²'],
    ['Drain cleaner', '≈ 13.5', '≈ 0.5', '≈ 0.32', '≈ 3.2 × 10⁻¹⁴'],
  ],
  highlightIndex: 2,
  footnote: 'pOH = 14 − pH at 25°C. [OH⁻] and [H⁺] are back-calculated from pOH and pH respectively; [H⁺][OH⁻] = Kw = 1.0 × 10⁻¹⁴.',
};

const realWorld = [
  { emoji: '💧', title: 'Water treatment', body: 'Operators track both pH and pOH when dosing lime or caustic soda to raise alkalinity, since the hydroxide concentration directly drives coagulation and corrosion-control chemistry.' },
  { emoji: '🌱', title: 'Agriculture & soil chemistry', body: 'Soil scientists use pOH alongside pH to understand hydroxide availability in alkaline soils, which affects micronutrient solubility (iron, manganese, zinc) and how well crops can absorb them.' },
  { emoji: '💊', title: 'Buffer solutions in biology & medicine', body: 'Physiological buffers (like blood, pH ≈ 7.4) are described just as validly by their pOH ≈ 6.6. Pharmaceutical formulation uses both to keep drugs stable and compatible with tissue.' },
  { emoji: '🏭', title: 'Industrial process control', body: 'Manufacturing processes that use strong bases — pulp bleaching, soap making, metal etching — monitor pOH because it is the more sensitive number when a solution is deep in basic territory.' },
];

const misconceptions = [
  { claim: '"pH and pOH always sum to exactly 14."', truth: 'Only at 25°C. Kw = [H⁺][OH⁻] is temperature-dependent, so −log(Kw) is not always 14. At 0°C the sum is about 14.94; at 60°C it is about 13.02. The "14" is a room-temperature convenience, not a universal constant.' },
  { claim: '"A solution can\'t have negative pOH or a pOH above 14."', truth: 'It can — for very concentrated strong bases, [OH⁻] can exceed 1 mol/L, giving a negative pOH; for very concentrated strong acids, [OH⁻] can be smaller than 10⁻¹⁴ M, giving a pOH above 14. Values outside 0–14 are unusual but not impossible.' },
  { claim: '"Low pOH means acidic."', truth: 'The opposite — a low pOH means a high [OH⁻], which is basic (alkaline). Low pH is what signals acidic; low pOH signals basic.' },
  { claim: '"pOH is a separate, independent measurement from pH."', truth: 'At a given temperature they are two views of the same equilibrium, linked by Kw. Measuring one and knowing the temperature\'s Kw always lets you compute the other — you never need to measure both directly.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — acid-base equilibria, Kw and the pH/pOH scales (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/14-2-ph-and-poh" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 16, Acid–Base Equilibria.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — the ion product of water and the pH/pOH relationship.' },
];
const sourcesNote = 'pOH = −log₁₀[OH⁻]; pH + pOH = 14 at 25°C only, since Kw is temperature-dependent. Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"From [OH⁻]" solves pOH ⇄ [OH⁻]; "From pH" converts using pH + pOH = 14.' },
  { title: 'Enter one value', body: 'Type the concentration or the pH/pOH; the paired quantities solve live.' },
  { title: 'See it in the beaker', body: 'Use the slider to watch OH⁻ ion density track the pOH value.' },
];

const related = [
  { href: '/tools/ph-calculator', emoji: '🧪', title: 'pH Calculator', desc: 'pH = −log[H⁺] — solve for any variable.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'M = mol/L — solve for any variable.' },
  { href: '/tools/dilution-calculator', emoji: '💧', title: 'Dilution Calculator', desc: 'C₁V₁ = C₂V₂ — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="pOH measures how much hydroxide is dissolved in a solution — the mirror image of pH, linked to it by pH + pOH = 14 at 25°C."
  howIntro="Because pOH = −log₁₀[OH⁻], each one-unit drop in pOH means a tenfold increase in hydroxide concentration. And because pH + pOH = 14 at room temperature, you never need to measure both — knowing one gives you the other instantly."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where pOH actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-oh" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From [OH⁻]</button>
      <button id="mode-ph" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From pH</button>
    </div>
    <div id="oh-fields" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">[OH⁻] (hydroxide concentration)</span>
        <input id="oh" type="number" step="any" placeholder="mol/L (e.g. 0.001 or 1e-3)" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">pOH</span>
        <input id="poh-from-oh" type="number" step="any" placeholder="solved from [OH⁻]" class="mt-1 w-full rounded-xl border border-slate-300 bg-slate-50 p-3 text-slate-500 outline-none" readonly /></label>
    </div>
    <div id="ph-fields" class="hidden gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">pH</span>
        <input id="ph" type="number" step="any" placeholder="e.g. 9.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">pOH</span>
        <input id="poh-from-ph" type="number" step="any" placeholder="e.g. 4.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">pOH</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">[OH⁻] (mol/L)</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">pH</div><div id="r-3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="poh-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D beaker + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D pOH beaker</h2>
      <p class="mt-1 text-sm text-slate-500">Drag the slider to set the pOH; the liquid colour shifts along the scale and the OH⁻ ion density visually tracks the hydroxide concentration. Drag to orbit (touch works too).</p>
      <div class="mt-3">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">pOH <span id="out-bpoh" class="font-mono text-green-600">7.00</span></span>
          <input id="b-poh" type="range" min="0" max="14" step="0.1" value="7" class="mt-2 w-full accent-green-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-green-50 p-3 text-center text-sm text-green-700">[OH⁻] = <span id="out-boh" class="font-mono font-bold">1.00 × 10⁻⁷ M</span> &nbsp;·&nbsp; pH = <span id="out-bph" class="font-mono font-bold">7.00</span></div>
      <div id="beaker3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="beaker3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">pOH graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">pOH vs pH — the inverse relationship pH + pOH = 14</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-phpoh"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">[OH⁻] at common pOH values</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ohbar"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'oh';
      function switchMode(m) {
        mode = m;
        el('mode-oh').className = m === 'oh' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-ph').className = m === 'ph' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('oh-fields').className = m === 'oh' ? 'grid gap-4 sm:grid-cols-2' : 'hidden';
        el('ph-fields').className = m === 'ph' ? 'grid gap-4 sm:grid-cols-2' : 'hidden gap-4 sm:grid-cols-2';
        el('poh-err').textContent = '';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        update();
      }
      function update() {
        el('poh-err').textContent = '';
        if (mode === 'oh') {
          const oh = parseFloat(el('oh').value);
          el('poh-from-oh').value = '';
          if (isNaN(oh)) { ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—')); return; }
          if (oh <= 0) { el('poh-err').textContent = '[OH⁻] must be greater than 0.'; ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—')); return; }
          const poh = -Math.log10(oh);
          const ph = 14 - poh;
          el('poh-from-oh').value = poh.toFixed(2);
          el('r-1').textContent = poh.toFixed(2);
          el('r-2').textContent = oh.toExponential(3) + ' M';
          el('r-3').textContent = ph.toFixed(2);
          if (poh < 0 || poh > 14) el('poh-err').textContent = 'Note: pOH outside 0–14 is unusual, but valid for very concentrated solutions.';
        } else {
          const ph = parseFloat(el('ph').value);
          const pohInput = el('poh-from-ph').value.trim();
          if (pohInput !== '' && !isNaN(parseFloat(pohInput)) && isNaN(ph)) {
            const poh = parseFloat(pohInput);
            const ph2 = 14 - poh;
            const oh = Math.pow(10, -poh);
            el('r-1').textContent = poh.toFixed(2);
            el('r-2').textContent = oh.toExponential(3) + ' M';
            el('r-3').textContent = ph2.toFixed(2);
            if (poh < 0 || poh > 14) el('poh-err').textContent = 'Note: pOH outside 0–14 is unusual, but valid for very concentrated solutions.';
            return;
          }
          if (isNaN(ph)) { ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—')); return; }
          const poh = 14 - ph;
          const oh = Math.pow(10, -poh);
          el('poh-from-ph').value = poh.toFixed(2);
          el('r-1').textContent = poh.toFixed(2);
          el('r-2').textContent = oh.toExponential(3) + ' M';
          el('r-3').textContent = ph.toFixed(2);
          if (poh < 0 || poh > 14) el('poh-err').textContent = 'Note: pOH outside 0–14 is unusual, but valid for very concentrated solutions.';
        }
      }
      el('mode-oh').addEventListener('click', () => switchMode('oh'));
      el('mode-ph').addEventListener('click', () => switchMode('ph'));
      el('oh').addEventListener('input', update);
      el('ph').addEventListener('input', () => { el('poh-from-ph').value = ''; update(); });
      el('poh-from-ph').addEventListener('input', () => { el('ph').value = ''; update(); });

      // ---- 3D + charts ----
      const charts = {};
      let beaker = null;
      function bState() { const poh = parseFloat(el('b-poh').value); const oh = Math.pow(10, -poh); const ph = 14 - poh; return { poh, oh, ph }; }
      function onB() {
        const s = bState();
        el('out-bpoh').textContent = s.poh.toFixed(2);
        el('out-boh').textContent = fmtExp(s.oh) + ' M';
        el('out-bph').textContent = s.ph.toFixed(2);
        try { if (beaker) beaker.update(s); } catch (e) {}
      }
      function fmtExp(v) {
        const s = v.toExponential(2);
        const [mant, exp] = s.split('e');
        const e = parseInt(exp, 10);
        return mant + ' × 10' + toSuperscript(e);
      }
      function toSuperscript(n) {
        const map = { '-': '⁻', '0': '⁰', '1': '¹', '2': '²', '3': '³', '4': '⁴', '5': '⁵', '6': '⁶', '7': '⁷', '8': '⁸', '9': '⁹' };
        return String(n).split('').map((c) => map[c] || c).join('');
      }
      el('b-poh').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const phLabels = [], pohData = [];
        for (let p = 0; p <= 14; p += 1) { phLabels.push(String(p)); pohData.push(14 - p); }
        charts.phpoh = new Chart(el('chart-phpoh'), {
          type: 'line',
          data: { labels: phLabels, datasets: [{ label: 'pOH', data: pohData, borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 2 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'pH' } }, y: { title: { display: true, text: 'pOH' }, beginAtZero: true, max: 14 } }, plugins: { legend: { display: false } } }),
        });
        const barPoh = [2.5, 5, 7, 0.5];
        const barOh = barPoh.map((p) => Math.pow(10, -p));
        charts.ohbar = new Chart(el('chart-ohbar'), {
          type: 'bar',
          data: { labels: ['Ammonia', 'Baking soda', 'Pure water', 'Drain cleaner'], datasets: [{ label: '[OH⁻] (mol/L)', data: barOh, backgroundColor: ['#6366f1', '#10b981', '#38bdf8', '#f43f5e'] }] },
          options: Object.assign({}, base, {
            scales: { y: { type: 'logarithmic', title: { display: true, text: '[OH⁻] (mol/L, log scale)' } } },
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => '[OH⁻] ≈ ' + ctx.parsed.y.toExponential(2) + ' M' } } },
          }),
        });
        charts.ready = true;
      }

      // ---- interactive beaker ----
      function glassBeaker(THREE) {
        const g = new THREE.Group();
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        g.add(new THREE.Mesh(new THREE.CylinderGeometry(2.2, 2.2, 5, 40, 1, true), glassMat));
        const bottom = new THREE.Mesh(new THREE.CircleGeometry(2.2, 40), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
        return g;
      }
      function pohColor(poh) {
        // Low pOH (strongly basic) -> deep blue/indigo. High pOH (strongly acidic) -> red/orange.
        const t = Math.max(0, Math.min(1, poh / 14));
        // t=0 (pOH 0, very basic) -> blue (0x3b82f6-ish); t=1 (pOH 14, very acidic) -> red
        const basic = { r: 0x22, g: 0x6b, b: 0xf7 };
        const acidic = { r: 0xef, g: 0x44, b: 0x44 };
        const r = Math.round(basic.r + (acidic.r - basic.r) * t);
        const g = Math.round(basic.g + (acidic.g - basic.g) * t);
        const b = Math.round(basic.b + (acidic.b - basic.b) * t);
        return (r << 16) | (g << 8) | b;
      }
      function initBeaker() {
        const c = el('beaker3d'); if (!c) throw new Error('no beaker');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        s.scene.add(glassBeaker(THREE));
        let liquid = null;
        const hLiq = 4.2;
        const MAX_P = 140;
        const particleGeo = new THREE.SphereGeometry(0.11, 10, 10);
        const particleMat = new THREE.MeshStandardMaterial({ color: 0x6366f1 });
        const particles = [];
        for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(particleGeo, particleMat); p.visible = false; s.scene.add(p); particles.push(p); }
        function update(state) {
          const color = pohColor(state.poh);
          if (liquid) { s.scene.remove(liquid); liquid.geometry.dispose(); liquid.material.dispose(); }
          const liquidMat = new THREE.MeshStandardMaterial({ color, transparent: true, opacity: 0.45, roughness: 0.3 });
          liquid = new THREE.Mesh(new THREE.CylinderGeometry(2.08, 2.08, hLiq, 40), liquidMat);
          liquid.position.y = -2.4 + hLiq / 2; s.scene.add(liquid);
          // OH- ion density: low pOH => high [OH-] => more visible particles.
          const density = Math.max(0, Math.min(1, (14 - state.poh) / 14));
          const nShow = Math.max(0, Math.min(MAX_P, Math.round(6 + density * (MAX_P - 6))));
          for (let i = 0; i < MAX_P; i++) {
            const p = particles[i];
            if (i < nShow) { const r = Math.sqrt(Math.random()) * 1.9, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -2.4 + Math.random() * hLiq, Math.sin(a) * r); p.visible = true; }
            else p.visible = false;
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        beaker = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { switchMode('oh'); } catch (e) { console.error('[poh] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[poh] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[poh] charts failed', e); }
        if (window.THREE) {
          try { initBeaker(); } catch (e) { console.error('[poh] beaker failed', e); el('beaker3d-fallback').classList.remove('hidden'); }
        } else { el('beaker3d-fallback').classList.remove('hidden'); }
        mountResize([beaker]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
