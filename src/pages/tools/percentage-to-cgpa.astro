---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Percentage to CGPA Calculator';
const description =
  'Free percentage to CGPA calculator. Convert your percentage to CGPA using the CBSE formula ' +
  '(÷ 9.5) or a custom divisor. Instant and free.';
const intro =
  'Enter your percentage to convert it to CGPA. Uses the common CBSE formula (percentage ÷ 9.5) or your own divisor.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'How do I convert percentage to CGPA?', a: 'The common method divides your percentage by 9.5. For example, 76% ÷ 9.5 = 8.0 CGPA.' },
  { q: 'Can I use a different divisor?', a: 'Yes — choose “Custom divisor” and enter the value your university uses.' },
  { q: 'Is the result official?', a: 'It’s an accurate estimate using a widely-used formula, but always confirm your institution’s official method for formal applications.' },
  { q: 'What is the highest CGPA I can get?', a: 'That depends on your institution’s scale. On a 10-point scale with the CBSE formula (÷ 9.5), 100% converts to approximately 10.53 CGPA, but most systems cap CGPA at 10.' },
  { q: 'What if my percentage is above 100%?', a: 'The calculator will still compute a result, but double-check — percentages above 100 usually indicate extra credit or a scoring adjustment. The result may not be meaningful.' },
  { q: 'Can I convert CGPA to percentage?', a: 'Yes — use our <a href="/tools/cgpa-to-percentage" class="font-medium text-indigo-600 hover:underline">CGPA to Percentage Calculator</a> for the reverse conversion.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Your percentage</span>
        <input id="pct" type="number" step="any" placeholder="76" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Formula</span>
        <select id="div" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="9.5">CBSE (÷ 9.5)</option>
          <option value="10">÷ 10</option>
          <option value="custom">Custom divisor</option>
        </select></label>
      <label id="custom-wrap" class="block sm:max-w-[12rem]" style="display:none"><span class="text-sm font-medium text-slate-700">Custom divisor</span>
        <input id="custom" type="number" step="any" value="9.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Your CGPA</div>
      <div id="cgpa" class="mt-1 text-3xl font-bold">—</div>
      <div id="formula" class="mt-1 font-mono text-sm opacity-80"></div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your percentage to convert it to CGPA.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About percentage to CGPA conversion</h2>
    <p class="mt-2 text-slate-600">
      If your marksheet shows a percentage but an application asks for CGPA, this calculator does
      the conversion in a click. It uses the popular CBSE divisor of 9.5 by default, and lets you
      switch to any divisor your school or university uses. To convert CGPA back to percentage, use our <a href="/tools/cgpa-to-percentage" class="font-medium text-indigo-600 hover:underline">CGPA to Percentage Calculator</a>.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter your percentage score (e.g. 76%).</li>
      <li>Choose the formula — CBSE (÷ 9.5), ÷ 10, or a custom divisor.</li>
      <li>Your CGPA appears instantly with the calculation shown.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Ideal when a university application, scholarship form, or job portal asks for your CGPA but your marksheet only shows percentages. Many institutions outside India (and some within) require CGPA for their application systems, making this conversion a common step for students and graduates.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>The CBSE divisor of 9.5 is the most common standard, but some universities use 9.0, 10, or other values — check your institution's policy.</li>
      <li>Use the custom divisor option if you know your university's specific conversion factor from their official guidelines.</li>
      <li>For the reverse conversion, use our <a href="/tools/cgpa-to-percentage" class="font-medium text-indigo-600 hover:underline">CGPA to Percentage Calculator</a>.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    el('div').addEventListener('change', () => {
      el('custom-wrap').style.display = el('div').value === 'custom' ? 'block' : 'none';
      update();
    });
    function update() {
      const pct = parseFloat(el('pct').value);
      const d = el('div').value === 'custom' ? parseFloat(el('custom').value) : parseFloat(el('div').value);
      if (isNaN(pct) || isNaN(d) || d === 0) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      const cgpa = pct / d;
      el('cgpa').textContent = (Math.round(cgpa * 100) / 100).toString();
      el('formula').textContent = `${pct} ÷ ${d} = ${Math.round(cgpa * 100) / 100}`;
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }
    ['pct', 'custom'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
