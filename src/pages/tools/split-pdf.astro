---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Split PDF';
const description =
  'Free online PDF splitter. Extract a range of pages from a PDF into a new file. ' +
  'Private and fast — your PDF is processed in your browser and never uploaded.';
const intro =
  'Upload a PDF, choose the page range you want, and download it as a new PDF. Everything happens in your browser — your file never leaves your device.';
const category = { id: 'pdf', name: 'PDF Tools' };
const faqs = [
  { q: 'Are my files uploaded?', a: 'No. The PDF is split directly in your browser, so your document stays private on your device.' },
  { q: 'How do I extract just one page?', a: 'Set both “From” and “To” to the same page number — for example From 3, To 3 extracts only page 3.' },
  { q: 'Can I split a password-protected PDF?', a: 'Encrypted PDFs can’t be processed directly. Remove the password first, then split.' },
  { q: 'Does it change the original file?', a: 'No. It creates a brand-new PDF with the pages you chose; your original is untouched.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label for="file-input" class="flex cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 p-8 text-center transition hover:border-indigo-400 hover:bg-indigo-50/40">
      <span class="text-3xl">✂️</span>
      <span class="mt-2 font-medium text-slate-700">Click to add a PDF</span>
      <span class="mt-1 text-sm text-slate-400">Then choose the pages to extract</span>
      <input id="file-input" type="file" accept="application/pdf" class="hidden" />
    </label>

    <div id="controls" class="mt-4 hidden">
      <p id="info" class="text-sm font-medium text-slate-600"></p>
      <div class="mt-3 flex flex-wrap items-end gap-3">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">From page</span>
          <input id="from" type="number" min="1" value="1" class="mt-1 w-28 rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">To page</span>
          <input id="to" type="number" min="1" value="1" class="mt-1 w-28 rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
        <button id="split-btn" class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">Extract pages</button>
      </div>
      <span id="status" class="mt-3 block text-sm text-slate-500"></span>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About splitting PDFs</h2>
    <p class="mt-2 text-slate-600">
      Sometimes you only need a few pages from a large PDF — a single chapter, one form, or a
      specific section. This splitter lets you pull out any page range into a fresh PDF, instantly
      and privately in your browser, without uploading your document anywhere.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Click the box and choose a PDF.</li>
      <li>Enter the first and last page you want to keep.</li>
      <li>Click “Extract pages”.</li>
      <li>Your new PDF downloads automatically.</li>
    </ol>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try <a href="/tools/merge-pdf" class="font-medium text-indigo-600 hover:underline">Merge PDF</a>
      or <a href="/#pdf" class="font-medium text-indigo-600 hover:underline">see all PDF tools →</a>
    </p>
  </Fragment>

  <script>
    import { PDFDocument } from 'pdf-lib';

    const input = document.getElementById('file-input');
    const controls = document.getElementById('controls');
    const info = document.getElementById('info');
    const fromEl = document.getElementById('from');
    const toEl = document.getElementById('to');
    const splitBtn = document.getElementById('split-btn');
    const status = document.getElementById('status');

    let currentBytes = null;
    let totalPages = 0;

    input.addEventListener('change', async () => {
      const file = input.files[0];
      if (!file) return;
      status.textContent = '';
      try {
        currentBytes = await file.arrayBuffer();
        const doc = await PDFDocument.load(currentBytes, { ignoreEncryption: true });
        totalPages = doc.getPageCount();
        info.textContent = `“${file.name}” has ${totalPages} page${totalPages === 1 ? '' : 's'}.`;
        fromEl.max = totalPages; toEl.max = totalPages;
        fromEl.value = 1; toEl.value = totalPages;
        controls.classList.remove('hidden');
      } catch (err) {
        controls.classList.add('hidden');
        status.textContent = '⚠️ Could not read this PDF — it may be corrupted or password-protected.';
        controls.classList.remove('hidden');
      }
    });

    splitBtn.addEventListener('click', async () => {
      if (!currentBytes) return;
      let from = parseInt(fromEl.value, 10);
      let to = parseInt(toEl.value, 10);
      if (isNaN(from) || isNaN(to)) { status.textContent = 'Please enter valid page numbers.'; return; }
      from = Math.max(1, Math.min(from, totalPages));
      to = Math.max(from, Math.min(to, totalPages));

      splitBtn.disabled = true;
      status.textContent = 'Extracting…';
      try {
        const src = await PDFDocument.load(currentBytes, { ignoreEncryption: true });
        const out = await PDFDocument.create();
        const indices = [];
        for (let i = from - 1; i <= to - 1; i++) indices.push(i);
        const pages = await out.copyPages(src, indices);
        pages.forEach((p) => out.addPage(p));
        const bytes = await out.save();
        const blob = new Blob([bytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `pages-${from}-${to}.pdf`;
        a.click();
        setTimeout(() => URL.revokeObjectURL(url), 5000);
        status.textContent = `✓ Done! Extracted pages ${from}–${to}.`;
      } catch (err) {
        status.textContent = '⚠️ Something went wrong while extracting.';
      } finally {
        splitBtn.disabled = false;
      }
    });
  </script>
</ToolLayout>
