---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Split PDF';
const description =
  'Free online PDF splitter. Extract a range of pages from a PDF into a new file. ' +
  'Private and fast — your PDF is processed in your browser and never uploaded.';
const intro =
  'Upload a PDF, choose the page range you want, and download it as a new PDF. Everything happens in your browser — your file never leaves your device.';
const category = { id: 'pdf', name: 'PDF Tools' };
const faqs = [
  { q: 'Are my files uploaded?', a: 'No. The PDF is split directly in your browser, so your document stays private on your device.' },
  { q: 'How do I extract just one page?', a: 'Set both "From" and "To" to the same page number — for example From 3, To 3 extracts only page 3.' },
  { q: 'Can I split a password-protected PDF?', a: 'Encrypted PDFs can\'t be processed directly. Remove the password first, then split.' },
  { q: 'Does it change the original file?', a: 'No. It creates a brand-new PDF with the pages you chose; your original is untouched.' },
  { q: 'Can I split a PDF into multiple documents?', a: 'This tool extracts a single page range. To split into multiple documents, do one extraction at a time for different ranges.' },
  { q: 'What format is the output?', a: 'The extracted pages are saved as a new PDF file with the same quality and formatting as the original.' },
  { q: 'Can I split every page individually?', a: 'To extract each page as its own file, run the tool once per page — From 1 To 1, then From 2 To 2, and so on.' },
  { q: 'Will the extracted PDF look different?', a: 'No. The extracted pages retain all original formatting, fonts, images and layout exactly as they appeared.' },
  { q: 'Can I split a scanned PDF?', a: 'Yes. Scanned PDFs work the same way — each scanned page is treated as one page you can extract.' },
  { q: 'What is the maximum page range I can extract?', a: 'You can extract any range from page 1 to the last page. The tool automatically validates your range against the total page count.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label for="file-input" class="flex cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 p-8 text-center transition hover:border-indigo-400 hover:bg-indigo-50/40">
      <span class="text-3xl">✂️</span>
      <span class="mt-2 font-medium text-slate-700">Click to add a PDF</span>
      <span class="mt-1 text-sm text-slate-400">Then choose the pages to extract</span>
      <input id="file-input" type="file" accept="application/pdf" class="hidden" />
    </label>

    <div id="controls" class="mt-4 hidden">
      <p id="info" class="text-sm font-medium text-slate-600"></p>
      <div class="mt-3 flex flex-wrap items-end gap-3">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">From page</span>
          <input id="from" type="number" min="1" value="1" class="mt-1 w-28 rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">To page</span>
          <input id="to" type="number" min="1" value="1" class="mt-1 w-28 rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
        <button id="split-btn" class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">Extract pages</button>
      </div>
      <span id="status" class="mt-3 block text-sm text-slate-500"></span>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How PDF splitting works</h2>
    <p class="mt-2 text-slate-600">PDF splitting extracts a specified range of pages from a source PDF into a new file. The tool loads the original PDF, identifies the pages in your requested range, and copies only those pages into a brand-new PDF document.</p>
    <p class="mt-3 text-slate-600">Page extraction preserves all content including text, images, fonts, and vector graphics. The original PDF remains completely untouched — a new file is always created with only the pages you selected.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Splitting a 10-page PDF into three separate documents.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Input:</span> <span class="text-slate-600">1 PDF with 10 pages</span></div>
        <div><span class="font-medium text-slate-700">Output:</span> <span class="text-slate-600">3 PDFs: pages 1–3, 4–7, and 8–10</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different page ranges mean</h2>
    <p class="mt-2 text-slate-600">The page range you choose determines how much of your document ends up in the extracted file.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Single page</span><span class="text-slate-400">Extract one specific page from the document</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Short range</span><span class="text-slate-400">2-10 consecutive pages, quick extraction</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Chapter range</span><span class="text-slate-400">10-50 pages, ideal for book chapters</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Large section</span><span class="text-slate-400">50-100 pages, takes a few seconds</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:70%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Almost entire document</span><span class="text-slate-400">100+ pages, uses more memory</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:90%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Student</h3>
      <p class="mt-1 text-sm text-slate-600">Extracts a single chapter from a textbook PDF instead of carrying the whole 500-page file.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧾</span>
      <h3 class="mt-2 font-semibold text-slate-900">Accountant</h3>
      <p class="mt-1 text-sm text-slate-600">Separates individual monthly statements from a yearly financial report.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👔</span>
      <h3 class="mt-2 font-semibold text-slate-900">HR professional</h3>
      <p class="mt-1 text-sm text-slate-600">Pulls out a single signed form from a multi-page onboarding document for filing.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔬</span>
      <h3 class="mt-2 font-semibold text-slate-900">Researcher</h3>
      <p class="mt-1 text-sm text-slate-600">Isolates the methodology section from a long academic paper for peer review.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Use case</th><th class="p-3">Document type</th><th class="p-3">Pages extracted</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Chapter extraction</td><td class="p-3">Textbook, manual, report</td><td class="p-3">10-40</td></tr>
        <tr><td class="p-3 font-medium">Form removal</td><td class="p-3">Application, contract, waiver</td><td class="p-3">1-2</td></tr>
        <tr><td class="p-3 font-medium">Statement isolation</td><td class="p-3">Financial report, bank statement</td><td class="p-3">1-5</td></tr>
        <tr><td class="p-3 font-medium">Section sharing</td><td class="p-3">Research paper, thesis</td><td class="p-3">5-20</td></tr>
        <tr><td class="p-3 font-medium">Cover page extract</td><td class="p-3">Report, proposal, eBook</td><td class="p-3">1</td></tr>
        <tr><td class="p-3 font-medium">Appendix separation</td><td class="p-3">Business document, legal brief</td><td class="p-3">3-15</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the PDF splitter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Upload a PDF</h3>
        <p class="mt-1 text-sm text-slate-600">Click the upload area and select the PDF you want to split from your device.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the page range</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the first and last page numbers you want to keep in the new PDF.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Extract and download</h3>
        <p class="mt-1 text-sm text-slate-600">Click "Extract pages" and your new PDF downloads automatically.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate extraction</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Double-check your range</h3>
        <p class="mt-1 text-sm text-slate-600">Verify the "From" and "To" values before extracting — the tool uses the exact range you specify and cannot undo an extraction.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Single page shortcut</h3>
        <p class="mt-1 text-sm text-slate-600">To extract only one page, set both "From" and "To" to the same number. This is useful for pulling out cover pages or specific forms.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Original stays intact</h3>
        <p class="mt-1 text-sm text-slate-600">The tool never modifies your original PDF, so feel free to experiment with different ranges until you get exactly what you need.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use PDF splitting</h2>
    <p class="mt-2 text-slate-600">PDF splitting is most useful when you need to isolate specific sections of a larger document. Students frequently extract single chapters from textbooks to reduce file size on their devices, making study materials more manageable and portable. Instead of carrying a 500-page textbook PDF, a student can extract only the chapters relevant to their current coursework and study efficiently without unnecessary bulk.</p>
    <p class="mt-3 text-slate-600">Legal professionals use PDF splitting to separate individual affidavits or signed forms from multi-page case bundles. A paralegal might receive a 50-page discovery document and need to file only the signed declaration on page 12. Splitting isolates that single page into its own file without altering the original, preserving the chain of evidence and document integrity.</p>
    <p class="mt-3 text-slate-600">In accounting and finance, splitting helps separate monthly statements from a yearly report. An accountant reviewing a 12-month financial statement can extract each month into its own PDF for distribution to different departments. The same approach works for splitting quarterly reports into individual months or separating appendices from the main body of a business proposal.</p>
    <p class="mt-3 text-slate-600">Researchers and academics split papers to share only relevant sections with collaborators. A lab lead might extract the methodology section of a 30-page paper for a peer reviewer, keeping the full results confidential. Publishers use splitting to extract cover pages or specific chapters for proofreading without distributing the entire manuscript to external reviewers.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Limitations and considerations</h2>
    <p class="mt-2 text-slate-600">PDF splitting works best with standard, unencrypted PDF files. Password-protected or encrypted PDFs cannot be processed directly and require password removal first through your PDF reader software. Corrupted PDFs may fail to load entirely, and files with damaged page trees can produce unpredictable results or fail silently.</p>
    <p class="mt-3 text-slate-600">Very large PDFs with hundreds of pages or hundreds of megabytes consume significant browser memory. If your device has limited RAM, consider splitting in smaller batches or closing other browser tabs before processing. The tool loads the entire PDF into memory before extraction, so file size matters more than page count in most practical scenarios.</p>
    <p class="mt-3 text-slate-600">This tool extracts a single continuous page range per operation. To split a PDF into multiple separate documents, you must perform multiple extractions — one for each range. For example, to split a 10-page document into three files, you would extract pages 1-3, then 4-7, then 8-10 in three separate operations. There is no batch mode for extracting every page individually in one pass.</p>
    <p class="mt-3 text-slate-600">Scanned PDFs are fully supported, but the extracted pages remain as scanned images. The splitting process copies entire pages without modification, so any OCR text or embedded metadata in the original pages is preserved in the extracted output. Form fields and annotations are also carried over, though interactive elements may behave differently in the extracted document.</p>
  </section>

  <script>
    import { PDFDocument } from 'pdf-lib';

    const input = document.getElementById('file-input');
    const controls = document.getElementById('controls');
    const info = document.getElementById('info');
    const fromEl = document.getElementById('from');
    const toEl = document.getElementById('to');
    const splitBtn = document.getElementById('split-btn');
    const status = document.getElementById('status');

    let currentBytes = null;
    let totalPages = 0;

    input.addEventListener('change', async () => {
      const file = input.files[0];
      if (!file) return;
      status.textContent = '';
      try {
        currentBytes = await file.arrayBuffer();
        const doc = await PDFDocument.load(currentBytes, { ignoreEncryption: true });
        totalPages = doc.getPageCount();
        info.textContent = `"${file.name}" has ${totalPages} page${totalPages === 1 ? '' : 's'}.`;
        fromEl.max = totalPages; toEl.max = totalPages;
        fromEl.value = 1; toEl.value = totalPages;
        controls.classList.remove('hidden');
      } catch (err) {
        controls.classList.add('hidden');
        status.textContent = '⚠️ Could not read this PDF — it may be corrupted or password-protected.';
        controls.classList.remove('hidden');
      }
    });

    splitBtn.addEventListener('click', async () => {
      if (!currentBytes) return;
      let from = parseInt(fromEl.value, 10);
      let to = parseInt(toEl.value, 10);
      if (isNaN(from) || isNaN(to)) { status.textContent = 'Please enter valid page numbers.'; return; }
      from = Math.max(1, Math.min(from, totalPages));
      to = Math.max(from, Math.min(to, totalPages));

      splitBtn.disabled = true;
      status.textContent = 'Extracting…';
      try {
        const src = await PDFDocument.load(currentBytes, { ignoreEncryption: true });
        const out = await PDFDocument.create();
        const indices = [];
        for (let i = from - 1; i <= to - 1; i++) indices.push(i);
        const pages = await out.copyPages(src, indices);
        pages.forEach((p) => out.addPage(p));
        const bytes = await out.save();
        const blob = new Blob([bytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `pages-${from}-${to}.pdf`;
        a.click();
        setTimeout(() => URL.revokeObjectURL(url), 5000);
        status.textContent = `✓ Done! Extracted pages ${from}–${to}.`;
      } catch (err) {
        status.textContent = '⚠️ Something went wrong while extracting.';
      } finally {
        splitBtn.disabled = false;
      }
    });
  </script>
</ToolLayout>
