---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Cooking Measurement Converter';
const description =
  'Free cooking measurement converter. Instantly convert between cups, tablespoons, ' +
  'teaspoons, millilitres and fluid ounces. Handy for any recipe.';
const intro =
  'Enter a value in any cooking measurement unit to see conversions across cups, tablespoons, teaspoons, millilitres and fluid ounces.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'Why are US and metric cooking measurements different?', a: 'The US customary system uses cups of 236.6 ml (or 240 ml in nutrition labelling), while the metric system uses millilitres and litres. The UK imperial cup was historically 284 ml, but modern British recipes often use metric weights rather than cups. This converter uses the standard US cup (236.6 ml) as its reference.' },
  { q: 'How many tablespoons are in a cup?', a: 'There are 16 tablespoons (tbsp) in 1 US cup. This is a fixed ratio: 1 cup = 16 tbsp = 48 tsp. Memorising these three numbers makes most recipe conversions quick and easy.' },
  { q: 'Are tablespoons different in different countries?', a: 'Yes. The US tablespoon is 14.8 ml (usually rounded to 15 ml), the Australian tablespoon is 20 ml, and the UK tablespoon is 15 ml. This converter uses the standard US/UK 15 ml tablespoon. Australian users should note their tablespoon is slightly larger.' },
  { q: 'What is the difference between fluid ounces and weight ounces?', a: 'Fluid ounces (fl oz) measure volume, while ounces (oz) measure weight. One fluid ounce of water weighs approximately one ounce, but for other ingredients (like flour or honey), the volume-to-weight ratio differs. This converter handles fluid ounces for volume only.' },
  { q: 'Can I use this for dry ingredients too?', a: 'For volume-to-volume conversions, yes — a cup of flour is the same volume as a cup of water. However, a cup of flour weighs much less than a cup of water. If you need weight equivalents, use the Baking Conversion Calculator which accounts for each ingredient\'s density.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Enter a value</span>
      <input id="value" type="number" step="any" placeholder="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">From unit</span>
      <select id="fromUnit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="cups">Cups</option>
        <option value="tbsp">Tablespoons (tbsp)</option>
        <option value="tsp">Teaspoons (tsp)</option>
        <option value="ml">Millilitres (ml)</option>
        <option value="floz">Fluid ounces (fl oz)</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Converted value (all units)</div>
        <div id="r-cups" class="mt-1 text-xl font-bold">— cups</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Tablespoons</div><div id="r-tbsp" class="mt-1 text-lg font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Teaspoons</div><div id="r-tsp" class="mt-1 text-lg font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Millilitres</div><div id="r-ml" class="mt-1 text-lg font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Fluid ounces</div><div id="r-floz" class="mt-1 text-lg font-bold text-slate-700">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter a value and select a unit to see all conversions.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The Cooking Measurement Converter uses a set of fixed conversion ratios between common kitchen volume units. Every unit is first converted to millilitres as the base reference, then converted onward to every other unit. This chain method ensures consistency — whether you start with cups, tablespoons or fluid ounces, the results are mathematically coherent across all five units.
    </p>
    <p class="mt-3 text-slate-600">
      The standard conversions used are: 1 US cup = 236.588 ml, 1 tablespoon = 14.787 ml, 1 teaspoon = 4.929 ml, and 1 fluid ounce = 29.574 ml. These are the values defined by the US National Institute of Standards and Technology (NIST) and are the most widely accepted figures in modern recipe development and food science.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" role="img" aria-labelledby="cm-title cm-desc">
      <title id="cm-title">Cooking measurement conversion ladder</title>
      <desc id="cm-desc">Vertical ladder illustration showing how cups, tablespoons, teaspoons, millilitres and fluid ounces relate to each other with conversion factors shown between each rung.</desc>
      <defs>
        <linearGradient id="cupG" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#6366f1"/><stop offset="100%" stop-color="#818cf8"/></linearGradient>
        <linearGradient id="tbG" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#8b5cf6"/><stop offset="100%" stop-color="#a78bfa"/></linearGradient>
        <linearGradient id="tsG" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#ec4899"/><stop offset="100%" stop-color="#f472b6"/></linearGradient>
        <linearGradient id="mlG" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#f59e0b"/><stop offset="100%" stop-color="#fbbf24"/></linearGradient>
        <linearGradient id="flG" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#10b981"/><stop offset="100%" stop-color="#34d399"/></linearGradient>
      </defs>
      <!-- Ladder rails -->
      <rect x="390" y="20" width="6" height="320" rx="3" fill="#e2e8f0" />
      <rect x="400" y="20" width="6" height="320" rx="3" fill="#e2e8f0" />
      <!-- Cups rung -->
      <rect x="60" y="20" width="220" height="48" rx="10" fill="url(#cupG)" />
      <text x="170" y="50" text-anchor="middle" font-size="17" font-weight="bold" fill="#fff">1 Cup</text>
      <text x="310" y="46" text-anchor="middle" font-size="13" fill="#6366f1" font-weight="bold">= 16 tbsp</text>
      <!-- tbsp rung -->
      <rect x="60" y="88" width="220" height="48" rx="10" fill="url(#tbG)" />
      <text x="170" y="118" text-anchor="middle" font-size="17" font-weight="bold" fill="#fff">1 tbsp</text>
      <text x="310" y="114" text-anchor="middle" font-size="13" fill="#8b5cf6" font-weight="bold">= 3 tsp</text>
      <!-- tsp rung -->
      <rect x="60" y="156" width="220" height="48" rx="10" fill="url(#tsG)" />
      <text x="170" y="186" text-anchor="middle" font-size="17" font-weight="bold" fill="#fff">1 tsp</text>
      <text x="310" y="182" text-anchor="middle" font-size="13" fill="#ec4899" font-weight="bold">≈ 4.93 ml</text>
      <!-- ml rung -->
      <rect x="60" y="224" width="220" height="48" rx="10" fill="url(#mlG)" />
      <text x="170" y="254" text-anchor="middle" font-size="17" font-weight="bold" fill="#fff">1 ml</text>
      <text x="310" y="250" text-anchor="middle" font-size="13" fill="#d97706" font-weight="bold">≈ 0.034 fl oz</text>
      <!-- fl oz rung -->
      <rect x="60" y="292" width="220" height="48" rx="10" fill="url(#flG)" />
      <text x="170" y="322" text-anchor="middle" font-size="17" font-weight="bold" fill="#fff">1 fl oz</text>
      <text x="310" y="318" text-anchor="middle" font-size="13" fill="#059669" font-weight="bold">≈ 29.57 ml</text>
      <!-- Side labels -->
      <text x="490" y="46" font-size="13" fill="#64748b">1 cup = 236.6 ml</text>
      <text x="490" y="118" font-size="13" fill="#64748b">16 tbsp = 1 cup</text>
      <text x="490" y="186" font-size="13" fill="#64748b">48 tsp = 1 cup</text>
      <text x="490" y="254" font-size="13" fill="#64748b">237 ml ≈ 1 cup</text>
      <text x="490" y="322" font-size="13" fill="#64748b">8 fl oz ≈ 1 cup</text>

      <!-- Connecting lines between rungs -->
      <line x1="285" y1="44" x2="390" y2="44" stroke="#6366f1" stroke-width="1.5" stroke-dasharray="4,3" />
      <line x1="285" y1="112" x2="390" y2="112" stroke="#8b5cf6" stroke-width="1.5" stroke-dasharray="4,3" />
      <line x1="285" y1="180" x2="390" y2="180" stroke="#ec4899" stroke-width="1.5" stroke-dasharray="4,3" />
      <line x1="285" y1="248" x2="390" y2="248" stroke="#d97706" stroke-width="1.5" stroke-dasharray="4,3" />
      <line x1="285" y1="316" x2="390" y2="316" stroke="#059669" stroke-width="1.5" stroke-dasharray="4,3" />
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Measurement conversion ladder showing relationships between cups, tablespoons, teaspoons, millilitres and fluid ounces</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the conversion works</h2>
    <p class="mt-2 text-slate-600">
      All conversions go through millilitres as the base unit. Enter any value in any unit and the calculator converts it to every other unit using these fixed factors:
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A recipe calls for 0.5 cups of milk, but you only have a measuring jug marked in millilitres. What is 0.5 cups in ml, tbsp, tsp and fl oz?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Start:</span> <span class="text-slate-600">0.5 cups</span></div>
        <div><span class="font-medium text-slate-700">Convert to ml:</span> <span class="text-slate-600">0.5 × 236.588 = <strong>118.3 ml</strong></span></div>
        <div><span class="font-medium text-slate-700">To tablespoons:</span> <span class="text-slate-600">0.5 × 16 = <strong>8 tbsp</strong></span></div>
        <div><span class="font-medium text-slate-700">To teaspoons:</span> <span class="text-slate-600">0.5 × 48 = <strong>24 tsp</strong></span></div>
        <div><span class="font-medium text-slate-700">To fluid ounces:</span> <span class="text-slate-600">118.3 ÷ 29.574 = <strong>4 fl oz</strong></span></div>
        <div><span class="font-medium text-slate-700">Check:</span> <span class="text-slate-600">0.5 cup = 4 fl oz (the classic "half cup = 4 oz" rule)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌍</span>
      <h3 class="mt-2 font-semibold text-slate-900">International recipe follower</h3>
      <p class="mt-1 text-sm text-slate-600">Following a US recipe with European measuring tools, or a British recipe with American cups — convert between systems instantly without mental maths.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📖</span>
      <h3 class="mt-2 font-semibold text-slate-900">Cookbook collector</h3>
      <p class="mt-1 text-sm text-slate-600">Old cookbooks use pinches, dashes and gills, while modern ones use millilitres. Convert everything to your preferred unit with this tool.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Baking enthusiast</h3>
      <p class="mt-1 text-sm text-slate-600">Baking recipes from different websites use different units. Convert everything to one consistent system before you start measuring ingredients.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Culinary student</h3>
      <p class="mt-1 text-sm text-slate-600">Learning professional kitchen measurements and need to practise conversions between metric and imperial volume units for exams and recipes.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Cooking Measurement Converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the amount</h3>
        <p class="mt-1 text-sm text-slate-600">Type the numeric value you want to convert, such as 2, 0.5 or 3.75. Decimals and whole numbers are both supported.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select the unit</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the unit of your entered value from the dropdown — cups, tbsp, tsp, ml or fl oz. The results update automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read all conversions</h3>
        <p class="mt-1 text-sm text-slate-600">See the equivalent value in every unit at once. Use whichever unit matches your measuring tools in the kitchen.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use the right tool for the job</h3>
        <p class="mt-1 text-sm text-slate-600">Liquid measuring cups (with spouts) are best for fluids; dry measuring cups (flat-edged) are for solids. Scooping flour with a liquid cup compacts it and changes the volume significantly.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Level off dry ingredients</h3>
        <p class="mt-1 text-sm text-slate-600">When measuring tablespoons and teaspoons of dry ingredients, use a straight edge (like the back of a knife) to level off the top for an accurate measure.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Know your tablespoon origin</h3>
        <p class="mt-1 text-sm text-slate-600">If you are using an Australian recipe, remember their tablespoon is 20 ml (4 tsp) rather than the standard 15 ml (3 tsp). Adjust accordingly or use this converter with the standard setting.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/baking-conversion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">⚖️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Conversion Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Volume to weight for baking ingredients</p>
      </a>
      <a href="/tools/baking-ingredient-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🧈</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Ingredient Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert butter, flour and sugar amounts</p>
      </a>
      <a href="/tools/recipe-scaling-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">📝</span>
        <h3 class="mt-2 font-semibold text-slate-900">Recipe Scaling Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Scale recipes up or down by servings</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    const toMl = { cups: 236.588, tbsp: 14.787, tsp: 4.929, ml: 1, floz: 29.574 };
    const fromMl = { cups: 1 / 236.588, tbsp: 1 / 14.787, tsp: 1 / 4.929, ml: 1, floz: 1 / 29.574 };

    function update() {
      const val = parseFloat(el('value').value);
      const unit = el('fromUnit').value;
      if (!val || val <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const ml = val * toMl[unit];
      const cups = ml * fromMl.cups;
      const tbsp = ml * fromMl.tbsp;
      const tsp = ml * fromMl.tsp;
      const floz = ml * fromMl.floz;

      el('r-cups').innerHTML = cups.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' <span class="text-lg opacity-80">cups</span>';
      el('r-tbsp').textContent = tbsp.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' tbsp';
      el('r-tsp').textContent = tsp.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' tsp';
      el('r-ml').textContent = ml.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' ml';
      el('r-floz').textContent = floz.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' fl oz';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('value').addEventListener('input', update);
    el('fromUnit').addEventListener('input', update);
  </script>
</ToolLayout>
