---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Ramadan Countdown';
const description = 'Live countdown to the first day of Ramadan — see exactly how many days, hours and minutes remain until the blessed month begins.';
const intro = 'A live countdown to the first day of Ramadan, based on the Umm al-Qura calendar.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'When is Ramadan this year?', a: 'The countdown shows the estimated first day of Ramadan based on the Umm al-Qura calendar. The actual start may shift by a day depending on the local sighting of the new moon, so confirm with your local mosque.' },
  { q: 'Is the date an estimate or exact?', a: 'It is a calculated estimate. Ramadan officially begins when the crescent moon is sighted, which can be a day earlier or later than the calculated date in your region.' },
  { q: 'How long is Ramadan?', a: 'Ramadan lasts 29 or 30 days, ending when the moon for Shawwal is sighted. The following day is Eid al-Fitr.' },
  { q: 'What about Suhoor and Iftar?', a: 'Once Ramadan begins, use our Sehri & Iftar Time Calculator to get the daily Suhoor (pre-dawn) and Iftar (sunset) times for your city.' },
];
const sources = [
  { html: "<strong>The Qur’an</strong> — e.g. Surah an-Nisa (4:11–12, 4:176) for the fixed inheritance shares (fara’id)." },
  { html: "<strong>Sahih al-Bukhari &amp; Sahih Muslim</strong> — hadith on inheritance, zakat and nisab thresholds." },
  { html: "<strong>AAOIFI and recognized fiqh councils</strong> (e.g. Islamic Fiqh Academy) for contemporary rulings. <a href=\"https://aaoifi.com/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">aaoifi.com</a>" },
];
const sourcesNote = "Rulings differ between scholars and schools (madhahib), and calculated astronomical times/dates may differ from local sighting. Confirm with a qualified scholar before acting.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-gradient-to-br from-indigo-600 to-violet-700 p-6 text-center text-white shadow-sm">
    <div class="text-3xl">🌙</div>
    <div class="mt-1 text-sm opacity-80">Time until 1 Ramadan</div>
    <div id="cd" class="mt-3 grid grid-cols-4 gap-2">
      {['Days', 'Hours', 'Min', 'Sec'].map((l, i) => (
        <div class="rounded-xl bg-white/10 p-3"><div id={'cd-' + i} class="text-2xl font-bold tabular-nums sm:text-3xl">—</div><div class="mt-1 text-xs opacity-80">{l}</div></div>
      ))}
    </div>
    <div id="cd-date" class="mt-4 text-sm opacity-90">—</div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="170" viewBox="0 0 800 170" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rc-title rc-desc">
      <title id="rc-title">Crescent moon with a countdown</title>
      <desc id="rc-desc">A crescent moon and stars representing the countdown to the start of Ramadan.</desc>
      <path d="M150 85 a50 50 0 1 0 33 47 a38 38 0 1 1 -33 -47 Z" fill="#fbbf24" />
      <path d="M260 60 l6 14 15 1 -11 10 4 15 -14 -8 -14 8 4 -15 -11 -10 15 -1 Z" fill="#a5b4fc" />
      <path d="M330 100 l5 11 12 1 -9 8 3 12 -11 -6 -11 6 3 -12 -9 -8 12 -1 Z" fill="#c7d2fe" />
      <rect x="420" y="60" width="320" height="55" rx="10" fill="#eef2ff" stroke="#a5b4fc" /><text x="580" y="93" text-anchor="middle" font-size="15" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">Ramadan Mubarak</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Counting down to the start of the blessed month of fasting.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About the Ramadan countdown</h2>
    <p class="mt-2 text-slate-600">Ramadan is the ninth month of the Islamic calendar and the holiest month of the year, during which Muslims fast from dawn until sunset, increase their worship, and seek closeness to Allah. Because the Islamic calendar is lunar, Ramadan moves about 11 days earlier each Gregorian year, so its start date changes annually. This live countdown shows exactly how long remains until the first day of Ramadan, refreshing every second.</p>
    <p class="mt-3 text-slate-600">The tool works by finding the Gregorian date of the next 1 Ramadan using the Umm al-Qura calendar built into your browser. If this year’s Ramadan has already begun or passed, it automatically rolls forward to next year. All of the calculation happens on your device, so there is nothing to load and nothing is stored.</p>
    <p class="mt-3 text-slate-600">Use the countdown to prepare spiritually and practically — planning suhoor and iftar routines, arranging time for extra prayers and Qur’an, and organising charity. Remember that the displayed date is calculated; the official start of Ramadan depends on the sighting of the new crescent moon and may differ by a day in your area.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Preparing for Ramadan</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🤲</span><h3 class="mt-2 font-semibold text-slate-900">Spiritual readiness</h3><p class="mt-1 text-sm text-slate-600">Begin building good habits before Ramadan arrives — voluntary fasts in Sha’ban, daily Qur’an, and consistent prayer make the transition smoother.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🍽️</span><h3 class="mt-2 font-semibold text-slate-900">Practical planning</h3><p class="mt-1 text-sm text-slate-600">Plan balanced suhoor and iftar meals, hydration, and a realistic sleep schedule so you can sustain worship through the month.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">💝</span><h3 class="mt-2 font-semibold text-slate-900">Zakat and charity</h3><p class="mt-1 text-sm text-slate-600">Many give their annual Zakat in Ramadan. Calculate it in advance so you can give promptly during the month of multiplied reward.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">📅</span><h3 class="mt-2 font-semibold text-slate-900">Confirm locally</h3><p class="mt-1 text-sm text-slate-600">Keep an eye on your local moon-sighting announcement, since the first fast may begin a day before or after the calculated date.</p></div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/eid-countdown" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Eid Countdown</a>
      <a href="/tools/sehri-iftar-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Sehri &amp; Iftar Times</a>
      <a href="/tools/hijri-date-today" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Today’s Hijri Date</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const hfmt = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', { day: 'numeric', month: 'numeric', year: 'numeric', timeZone: 'UTC' });
    function hijriOf(d) { const o = {}; hfmt.formatToParts(d).forEach((p) => { if (p.type !== 'literal') o[p.type] = parseInt(p.value, 10); }); return o; }
    function toGregorian(hy, hm, hd) {
      let date = new Date(Date.UTC(Math.floor(hy * 0.970224 + 621), 0, 1));
      for (let i = 0; i < 8; i++) { const h = hijriOf(date); const diff = (hy - h.year) * 354 + (hm - h.month) * 29.53 + (hd - h.day); if (Math.abs(diff) < 1) break; date = new Date(date.getTime() + Math.round(diff) * 86400000); }
      let g = 0; while (g++ < 90) { const h = hijriOf(date); if (h.year === hy && h.month === hm && h.day === hd) return date; const cmp = (h.year - hy) || (h.month - hm) || (h.day - hd); date = new Date(date.getTime() + (cmp > 0 ? -1 : 1) * 86400000); }
      return date;
    }
    try {
      const now = new Date();
      const hy = hijriOf(now).year;
      let target = toGregorian(hy, 9, 1);
      if (target.getTime() <= Date.now()) target = toGregorian(hy + 1, 9, 1);
      el('cd-date').textContent = 'Estimated: ' + target.toLocaleDateString('en-US', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
      function tick() {
        let diff = Math.max(0, target.getTime() - Date.now());
        const d = Math.floor(diff / 86400000); diff -= d * 86400000;
        const h = Math.floor(diff / 3600000); diff -= h * 3600000;
        const m = Math.floor(diff / 60000); diff -= m * 60000;
        const s = Math.floor(diff / 1000);
        el('cd-0').textContent = d; el('cd-1').textContent = h; el('cd-2').textContent = m; el('cd-3').textContent = s;
      }
      tick(); setInterval(tick, 1000);
    } catch (e) { el('cd-date').textContent = 'Calendar not supported in this browser'; }
  </script>
</ToolLayout>
