---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Metric Tons to Kg"
  emoji="⚖️"
  fromUnit="metric tons" toUnit="kilograms"
  fromTitle="Metric Tons" toTitle="Kilograms"
  fromSym="t" toSym="kg"
  quantity="weight"
  kind="factor" factor={1000}
  reverseSlug="kg-to-lbs" reverseLabel="Kg to Lbs Converter"
  hasReverse={false}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Useful in freight, construction and agriculture where bulk loads are quoted in tonnes but priced per kilogram."
/>
