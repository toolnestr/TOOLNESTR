---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Unit Converter';
const description =
  'Free unit converter for length, weight, temperature, speed and volume. Convert between ' +
  'metric and imperial units instantly. Works in your browser on any device.';
const intro =
  'Choose a category, pick your units and type a value — the converted result appears instantly. Supports both metric and imperial.';
const category = { id: 'everyday', name: 'Everyday' };
const faqs = [
  { q: 'Which units can I convert?', a: 'Length, weight/mass, temperature, speed and volume — covering common metric and imperial units like meters, miles, kilograms, pounds, Celsius, Fahrenheit and more.' },
  { q: 'Does it handle temperature correctly?', a: 'Yes. Temperature uses proper formulas (not simple ratios), so Celsius, Fahrenheit and Kelvin convert accurately.' },
  { q: 'Can I quickly swap the units?', a: 'Yes — use the swap button to flip the "from" and "to" units instantly.' },
  { q: 'Is it private?', a: 'Yes, everything runs in your browser.' },
  { q: 'How accurate are the conversions?', a: 'All conversions use standard conversion factors and are accurate to six decimal places. Temperature conversions use the exact formulas.' },
  { q: 'Can I add more unit categories or custom units?', a: 'The five built-in categories cover the most common needs. For niche conversions, you may need a specialised tool.' },
  { q: 'Why does the swap button only swap the units and not the value?', a: 'The swap is designed to quickly flip the conversion direction. The value you entered stays so you can see the reverse conversion right away.' },
  { q: 'What is the difference between metric and imperial?', a: 'Metric (SI) uses base-10 units like meters and grams and is used in nearly every country. Imperial uses feet, pounds, gallons and is primarily used in the US, Liberia and Myanmar.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Category</span>
      <select id="cat" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></select>
    </label>

    <div class="mt-4 grid items-end gap-3 sm:grid-cols-[1fr_auto_1fr]">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">From</span>
        <select id="from" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></select>
        <input id="value" type="number" step="any" value="1" class="mt-2 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <button id="swap" title="Swap" class="mb-2 self-end rounded-xl border border-slate-300 px-3 py-3 text-lg transition hover:bg-slate-50">⇄</button>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">To</span>
        <select id="to" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></select>
        <input id="result" type="text" readonly class="mt-2 w-full rounded-xl border border-slate-200 bg-slate-50 p-3 font-semibold text-indigo-700 outline-none" />
      </label>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why unit conversion matters every day</h2>
    <p class="mt-2 text-slate-600">
      Unit conversion is something you do more often than you think. Following a recipe from another country, checking your weight on a foreign scale, estimating fuel consumption on a road trip, understanding weather forecasts in Celsius vs Fahrenheit — the metric and imperial systems coexist, and being able to switch between them is a practical life skill.
    </p>

    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Cooking (recipes)</span><span class="text-slate-400">Volume & Weight</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:35%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Travel (distances)</span><span class="text-slate-400">Length & Speed</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Health (weight)</span><span class="text-slate-400">Weight / Mass</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:65%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Weather (temperature)</span><span class="text-slate-400">Temperature</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:80%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Science & education</span><span class="text-slate-400">All categories</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-violet-500" style="width:100%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Home Cooks</h3>
      <p class="mt-1 text-sm text-slate-600">Convert grams to cups, liters to fluid ounces, or Celsius to Fahrenheit for recipes from different countries. No more guesswork in the kitchen.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">✈️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Travelers</h3>
      <p class="mt-1 text-sm text-slate-600">Convert miles to kilometers for road trips, pounds to kilograms for luggage limits, and Fahrenheit to Celsius for local weather forecasts abroad.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📐</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students</h3>
      <p class="mt-1 text-sm text-slate-600">Check your science and math homework. Convert between SI and imperial units for physics, chemistry and engineering problems.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏗️</span>
      <h3 class="mt-2 font-semibold text-slate-900">DIY & Construction</h3>
      <p class="mt-1 text-sm text-slate-600">Convert between meters and feet for building projects, liters and gallons for paint estimates, and Celsius to Fahrenheit for material temperature ratings.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the unit converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a category</h3>
        <p class="mt-1 text-sm text-slate-600">Choose from Length, Weight, Temperature, Speed or Volume to see the available units.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select units & value</h3>
        <p class="mt-1 text-sm text-slate-600">Pick "from" and "to" units, then type the value. Use ⇄ to swap units instantly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The converted value updates as you type. Accurate to 6 decimal places for all standard conversions.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Key conversion facts</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Metric vs Imperial: quick benchmarks</h3>
        <p class="mt-1 text-sm text-slate-600">1 inch ≈ 2.54 cm. 1 foot ≈ 30.5 cm. 1 mile ≈ 1.61 km. 1 kg ≈ 2.2 lbs. 1 liter ≈ 0.26 gallons. 0°C = 32°F (freezing), 100°C = 212°F (boiling).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Temperature formulas</h3>
        <p class="mt-1 text-sm text-slate-600">°C to °F: multiply by 9/5 and add 32. °F to °C: subtract 32 and multiply by 5/9. Kelvin adds 273.15 to Celsius for absolute temperature.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Why two systems?</h3>
        <p class="mt-1 text-sm text-slate-600">The metric system (SI) was developed in 1790s France and is used by nearly every country for its simplicity. The imperial system evolved from historical English units and remains in daily use in the United States, making cross-system conversion a practical necessity.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const data = {
      Length: { base: 'Meter', units: { Meter: 1, Kilometer: 1000, Centimeter: 0.01, Millimeter: 0.001, Mile: 1609.344, Yard: 0.9144, Foot: 0.3048, Inch: 0.0254 } },
      Weight: { base: 'Kilogram', units: { Kilogram: 1, Gram: 0.001, Milligram: 1e-6, Tonne: 1000, Pound: 0.45359237, Ounce: 0.028349523, Stone: 6.35029318 } },
      Speed: { units: { 'Meters/sec': 1, 'Km/hour': 0.277777778, 'Miles/hour': 0.44704, Knot: 0.514444444 } },
      Volume: { units: { Liter: 1, Milliliter: 0.001, 'Cubic meter': 1000, 'Gallon (US)': 3.785411784, 'Quart (US)': 0.946352946, 'Cup (US)': 0.2365882365, 'Fluid oz (US)': 0.0295735296 } },
      Temperature: { temp: true, units: { Celsius: 'C', Fahrenheit: 'F', Kelvin: 'K' } },
    };

    const catSel = el('cat'), fromSel = el('from'), toSel = el('to'), value = el('value'), result = el('result');
    Object.keys(data).forEach((c) => { const o = document.createElement('option'); o.textContent = c; catSel.appendChild(o); });

    function fillUnits() {
      const units = Object.keys(data[catSel.value].units);
      [fromSel, toSel].forEach((sel) => { sel.innerHTML = ''; units.forEach((u) => { const o = document.createElement('option'); o.textContent = u; sel.appendChild(o); }); });
      toSel.selectedIndex = Math.min(1, units.length - 1);
      convert();
    }

    function tempConvert(v, from, to) {
      let c;
      if (from === 'Celsius') c = v; else if (from === 'Fahrenheit') c = (v - 32) * 5 / 9; else c = v - 273.15;
      if (to === 'Celsius') return c; if (to === 'Fahrenheit') return c * 9 / 5 + 32; return c + 273.15;
    }

    function convert() {
      const v = parseFloat(value.value);
      if (isNaN(v)) { result.value = ''; return; }
      const cat = data[catSel.value];
      let out;
      if (cat.temp) out = tempConvert(v, fromSel.value, toSel.value);
      else out = v * cat.units[fromSel.value] / cat.units[toSel.value];
      result.value = Math.round(out * 1e6) / 1e6;
    }

    catSel.addEventListener('change', fillUnits);
    [fromSel, toSel, value].forEach((e) => e.addEventListener('input', convert));
    el('swap').addEventListener('click', () => { const i = fromSel.selectedIndex; fromSel.selectedIndex = toSel.selectedIndex; toSel.selectedIndex = i; convert(); });

    fillUnits();
  </script>
</ToolLayout>
