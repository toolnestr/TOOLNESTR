---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Wave Speed Calculator';
const description = 'Wave speed calculator with a live 3D sine-wave diagram and charts. Solve v = f×λ for wave speed, frequency, or wavelength, with worked examples for sound in air and water.';
const intro = 'Solve v = f×λ for wave speed, frequency, or wavelength. Two 3D diagrams compare a short-wavelength (high-frequency) wave to a longer-wavelength (low-frequency) wave, and charts show the inverse relationship between wavelength and frequency plus a comparison of common wave speeds.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the wave speed formula?', a: 'v = f × λ, where v is wave speed, f is frequency (in hertz, cycles per second), and λ (lambda) is wavelength (the distance between successive identical points on the wave, such as crest to crest). This applies to all periodic waves — sound, water, and light — though the numerical wave speed differs for each type and medium.' },
  { q: 'How are frequency and wavelength related?', a: 'For a fixed wave speed, frequency and wavelength are inversely proportional: f = v/λ. Doubling the frequency of a wave travelling at the same speed halves its wavelength, and vice versa — a relationship you can rearrange from v = fλ.' },
  { q: 'Does wave speed depend on frequency?', a: 'For a given medium, wave speed is usually set by the medium\'s properties (like air temperature for sound, or tension and mass density for a string), not by the wave\'s frequency. Changing frequency changes wavelength to compensate, keeping v = fλ constant for that medium.' },
  { q: 'Why does sound travel faster in water than in air?', a: 'Sound speed depends on the stiffness and density of the medium. Water is much less compressible relative to its density than air, so pressure disturbances propagate faster — roughly 1480 m/s in water versus about 343 m/s in air at room temperature.' },
  { q: 'Is the wave speed formula the same for light?', a: 'Yes, the same relationship applies as c = fλ, where c is the speed of light (about 3×10⁸ m/s in vacuum). Because light\'s speed is so much greater than sound\'s, visible-light wavelengths are extremely short (hundreds of nanometres) even at very high frequencies.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Wave Speed Calculator',
  description: 'Calculate wave speed, frequency, or wavelength from v = f×λ.',
  steps: [
    { name: 'Choose what to solve for', text: 'Pick wave speed (v), frequency (f), or wavelength (λ) as the unknown.' },
    { name: 'Enter the other two values', text: 'Use the presets for common wave speeds, such as sound in air (343 m/s) or water (1480 m/s), or enter your own.' },
    { name: 'Read the result', text: 'The unknown solves instantly, and the 3D diagrams and charts update.' },
  ],
};

const formulas = [
  { expr: 'v = f × λ', note: 'wave speed = frequency × wavelength' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — wavelength of a musical note in air', tone: 'slate',
    given: 'A tuning fork vibrates at f = 440 Hz (concert A), and sound travels at v = 343 m/s in air. Find the wavelength.',
    rows: [
      { label: 'Formula:', value: 'λ = v / f' },
      { label: 'Substitute:', value: 'λ = 343 / 440' },
      { label: 'Result:', value: 'λ ≈ 0.7795 m', full: true },
    ],
    note: 'This roughly 78 cm wavelength is why low musical instruments (longer wavelengths, lower frequencies) tend to be physically larger than high-pitched ones.',
  },
  {
    title: 'Worked example 2 — frequency of sound in water', tone: 'amber',
    given: 'A sonar pulse has a wavelength of λ = 2 m in water, where sound travels at v = 1500 m/s. Find the frequency.',
    rows: [
      { label: 'Formula:', value: 'f = v / λ' },
      { label: 'Substitute:', value: 'f = 1500 / 2' },
      { label: 'Result:', value: 'f = 750 Hz', full: true },
    ],
    note: 'The same 2 m wavelength in air (v = 343 m/s) would correspond to a much lower frequency of only about 171.5 Hz — wave speed changes the frequency-wavelength pairing entirely.',
  },
];

const comparison = {
  heading: 'Speed of sound in different media',
  note: 'Sound travels faster through stiffer, less compressible media — speed generally increases from gases to liquids to solids.',
  headers: [{ label: 'Medium' }, { label: 'Approx. speed of sound' }],
  rows: [
    ['Air (20°C) ★', '343 m/s'],
    ['Water', '~1480 m/s'],
    ['Steel', '~5960 m/s'],
  ],
  highlightIndex: 0,
  footnote: '★ Air reference value. Sound travels roughly 4× faster in water and 17× faster in steel than in air, because both are far stiffer relative to their density.',
};

const realWorld = [
  { emoji: '🎸', title: 'Musical instrument design', body: 'Instrument makers choose string length, tension, and material to set specific wavelengths for each note — combined with the wave speed on that string, v = fλ determines exactly which frequency (pitch) is produced.' },
  { emoji: '📡', title: 'Radio and telecommunications', body: 'Radio waves travel at the speed of light, so engineers use c = fλ to choose antenna sizes matched to a station\'s wavelength — antennas are often built as a simple fraction of the wavelength for efficient transmission.' },
  { emoji: '🌊', title: 'Ocean wave forecasting', body: 'Surfers and forecasters use the relationship between wave period (1/f) and wavelength to predict how fast incoming swells will travel and when they will arrive at the shore.' },
  { emoji: '🩺', title: 'Medical ultrasound imaging', body: 'Ultrasound machines choose a wave frequency based on the required image resolution, then use the known speed of sound in tissue (about 1540 m/s) via v = fλ to convert echo timing into precise depth measurements.' },
];

const misconceptions = [
  { claim: '"A higher frequency always means a faster wave."', truth: 'Frequency and wave speed are different quantities — for a fixed medium, wave speed stays constant regardless of frequency. Changing the frequency instead changes the wavelength to keep v = fλ satisfied, not the speed.' },
  { claim: '"All waves travel at the same speed."', truth: 'Wave speed depends entirely on the type of wave and the medium it travels through — sound in air, sound in water, and light in a vacuum all have vastly different speeds, even though they all obey v = fλ.' },
  { claim: '"Wavelength is a fixed property of a wave, like its frequency source."', truth: 'Wavelength depends on both frequency and the medium\'s wave speed — the same frequency source produces a different wavelength in air than in water, because λ = v/f changes whenever v changes.' },
  { claim: '"Doubling frequency doubles wave speed."', truth: 'In a single medium, wave speed is essentially fixed by the medium\'s properties. Doubling frequency instead halves the wavelength (since λ = v/f), leaving speed unchanged.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §16.2 "Mathematics of Waves" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/16-2-mathematics-of-waves" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 16, Waves I.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 16, Wave Motion.' },
];
const sourcesNote = 'v = f × λ. Speed-of-sound reference values are standard approximations at room temperature. Results are rounded for display.';

const howToUse = [
  { title: 'Choose the unknown', body: 'The calculator solves for wave speed, frequency, or wavelength from the other two.' },
  { title: 'Use a speed preset', body: 'Pick sound in air, water, or steel, or type your own wave speed.' },
  { title: 'Compare the diagrams', body: 'See how a short wavelength (high frequency) differs visually from a long wavelength (low frequency).' },
];

const related = [
  { href: '/tools/wavelength-frequency-calculator', emoji: '🌈', title: 'Wavelength–Frequency Calculator', desc: 'c = λf for electromagnetic waves.' },
  { href: '/tools/snells-law-calculator', emoji: '🔦', title: "Snell's Law Calculator", desc: 'n1 sinθ1 = n2 sinθ2 — refraction of waves.' },
  { href: '/tools/frequency-converter', emoji: '🔁', title: 'Frequency Converter', desc: 'Convert between Hz, kHz, MHz, and GHz.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="A wave's speed equals how far one full cycle spans (wavelength) times how many cycles pass a point each second (frequency) — v = fλ links the spatial and time-based descriptions of any periodic wave."
  howIntro="Rearranged, v = fλ solves any variable: f = v/λ and λ = v/f. Because wave speed is normally set by the medium the wave travels through, raising the frequency of a wave in a fixed medium shortens its wavelength to compensate — the two trade off while the speed itself stays the same."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where wave speed actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-v" type="button" data-solve="v" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Wave speed (v)</button>
      <button id="mode-f" type="button" data-solve="f" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Frequency (f)</button>
      <button id="mode-lambda" type="button" data-solve="lambda" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Wavelength (λ)</button>
    </div>
    <div class="mb-4 flex flex-wrap gap-2 text-xs">
      <span class="pt-2 font-medium text-slate-500">Presets:</span>
      <button type="button" data-preset-v="343" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">Sound in air (343 m/s)</button>
      <button type="button" data-preset-v="1480" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">Sound in water (1480 m/s)</button>
      <button type="button" data-preset-v="5960" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">Sound in steel (5960 m/s)</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <label id="field-v" class="block"><span class="text-sm font-medium text-slate-700">Wave speed (v)</span>
        <input id="v" type="number" step="any" placeholder="m/s" value="343" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-f" class="block"><span class="text-sm font-medium text-slate-700">Frequency (f)</span>
        <input id="f" type="number" step="any" placeholder="Hz" value="440" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-lambda" class="block"><span class="text-sm font-medium text-slate-700">Wavelength (λ)</span>
        <input id="lambda" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div id="box-v" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Wave speed</div><div id="r-v" class="mt-1 text-2xl font-bold">—</div></div>
      <div id="box-f" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Frequency</div><div id="r-f" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-lambda" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Wavelength</div><div id="r-lambda" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="ws-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Short vs long wavelength</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-short" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Short wavelength — high frequency</h3>
          <p class="mt-1 text-sm text-slate-600">A static sine wave with a <span class="font-semibold text-indigo-600">short wavelength</span> — many cycles packed into the same distance, corresponding to a high frequency at a given speed.</p>
        </div>
        <div>
          <div id="diag-long" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Long wavelength — low frequency</h3>
          <p class="mt-1 text-sm text-slate-600">The same span with a <span class="font-semibold text-amber-500">longer wavelength</span> — fewer, wider cycles, corresponding to a lower frequency at the same speed.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Wave speed graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Wavelength vs frequency (fixed v = 343 m/s) — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-lf"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Speed of sound — air, water, and steel</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-media"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      // ---- calculator ----
      let solveFor = 'lambda';
      const modeBtns = { v: 'mode-v', f: 'mode-f', lambda: 'mode-lambda' };
      const fieldEls = { v: 'field-v', f: 'field-f', lambda: 'field-lambda' };
      const boxEls = { v: 'box-v', f: 'box-f', lambda: 'box-lambda' };

      function switchSolve(s) {
        solveFor = s;
        Object.keys(modeBtns).forEach((k) => {
          el(modeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(fieldEls).forEach((k) => { el(fieldEls[k]).style.opacity = k === s ? '0.45' : '1'; });
        Object.keys(boxEls).forEach((k) => {
          el(boxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        update();
      }

      function update() {
        el('ws-err').textContent = '';
        ['r-v', 'r-f', 'r-lambda'].forEach((id) => (el(id).textContent = '—'));
        const v = parseFloat(el('v').value);
        const f = parseFloat(el('f').value);
        const lambda = parseFloat(el('lambda').value);
        let V, F, L;
        if (solveFor === 'v') {
          if (isNaN(f) || isNaN(lambda)) return;
          V = f * lambda; F = f; L = lambda;
        } else if (solveFor === 'f') {
          if (isNaN(v) || isNaN(lambda)) return;
          if (lambda === 0) { el('ws-err').textContent = 'Wavelength cannot be zero.'; return; }
          F = v / lambda; V = v; L = lambda;
        } else {
          if (isNaN(v) || isNaN(f)) return;
          if (f === 0) { el('ws-err').textContent = 'Frequency cannot be zero.'; return; }
          L = v / f; V = v; F = f;
        }
        el('r-v').textContent = fmt(V) + ' m/s';
        el('r-f').textContent = fmt(F) + ' Hz';
        el('r-lambda').textContent = fmt(L) + ' m';
      }
      el('mode-v').addEventListener('click', () => switchSolve('v'));
      el('mode-f').addEventListener('click', () => switchSolve('f'));
      el('mode-lambda').addEventListener('click', () => switchSolve('lambda'));
      ['v', 'f', 'lambda'].forEach((id) => el(id).addEventListener('input', update));
      document.querySelectorAll('[data-preset-v]').forEach((b) => b.addEventListener('click', () => { el('v').value = b.getAttribute('data-preset-v'); update(); }));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const L1 = [], D1 = [];
        const vFixed = 343;
        for (let ff = 20; ff <= 2000.001; ff += 40) { L1.push(ff.toFixed(0)); D1.push(+(vFixed / ff).toFixed(4)); }
        charts.lf = new Chart(el('chart-lf'), {
          type: 'line',
          data: { labels: L1, datasets: [{ label: 'λ', data: D1, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Frequency (Hz)' } }, y: { title: { display: true, text: 'Wavelength (m)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.media = new Chart(el('chart-media'), {
          type: 'bar',
          data: { labels: ['Air', 'Water', 'Steel'], datasets: [{ label: 'Speed (m/s)', data: [343, 1480, 5960], backgroundColor: ['#94a3b8', '#38bdf8', '#f59e0b'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Speed of sound (m/s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagrams: short vs long wavelength sine waves ----
      let diagShort = null, diagLong = null;
      function buildSineWave(container, wavelength, amplitude, cycleSpan) {
        const c = el(container); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const points = [];
        const numPoints = 120;
        for (let i = 0; i <= numPoints; i++) {
          const x = -cycleSpan / 2 + (i / numPoints) * cycleSpan;
          const y = amplitude * Math.sin((2 * Math.PI * x) / wavelength);
          points.push(new THREE.Vector3(x, y, 0));
        }
        const geo = new THREE.BufferGeometry().setFromPoints(points);
        const mat = new THREE.LineBasicMaterial({ color: 0x6366f1, linewidth: 2 });
        s.scene.add(new THREE.Line(geo, mat));

        // small spheres marking each crest
        const crestMat = new THREE.MeshStandardMaterial({ color: 0xf59e0b });
        for (let x = -cycleSpan / 2 + wavelength / 4; x <= cycleSpan / 2; x += wavelength) {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.12, 12, 10), crestMat);
          sph.position.set(x, amplitude, 0);
          s.scene.add(sph);
        }
        // baseline
        const baseGeo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-cycleSpan / 2, 0, 0), new THREE.Vector3(cycleSpan / 2, 0, 0)]);
        const baseMat = new THREE.LineDashedMaterial({ color: 0x94a3b8, dashSize: 0.1, gapSize: 0.08 });
        const baseLine = new THREE.Line(baseGeo, baseMat);
        baseLine.computeLineDistances();
        s.scene.add(baseLine);

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function initDiagShort() { diagShort = buildSineWave('diag-short', 1.2, 1.0, 8); }
      function initDiagLong() { diagLong = buildSineWave('diag-long', 3.0, 1.0, 8); }

      function boot() {
        try { switchSolve('lambda'); update(); } catch (e) { console.error('[wave-speed] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[wave-speed] charts failed', e); }
        if (window.THREE) {
          try { initDiagShort(); } catch (e) { console.error('[wave-speed] short diagram failed', e); }
          try { initDiagLong(); } catch (e) { console.error('[wave-speed] long diagram failed', e); }
        }
        mountResize([diagShort, diagLong]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
