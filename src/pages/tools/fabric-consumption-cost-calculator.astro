---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fabric Consumption-to-Cost Calculator';
const description = 'Convert a garment\'s fabric consumption (in meters or yards) and fabric price per unit into a per-garment fabric cost.';
const intro = 'Turn fabric consumption per garment and fabric price into a per-unit fabric cost for costing.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is fabric consumption in garment costing?', a: 'Fabric consumption is the amount of fabric — usually in meters or yards — actually used to cut one garment, including normal cutting waste. It\'s determined from the marker (cutting layout) efficiency, not just the pattern pieces\' flat area.' },
  { q: 'Should I include wastage in fabric consumption?', a: 'Yes — real-world consumption always includes some wastage from marker inefficiency, fabric flaws, and end-of-roll losses. If your consumption figure is a theoretical pattern-only number, add a wastage percentage using the Fabric Waste & Overrun Calculator before costing.' },
  { q: 'How is fabric consumption measured — per garment or per dozen?', a: 'Both conventions exist in the industry. Factories often quote consumption per dozen for production planning, but per-garment is more intuitive for individual costing — this calculator works per single garment; divide a per-dozen figure by 12 first if that\'s what you have.' },
  { q: 'Does fabric width affect consumption?', a: 'Yes significantly — a narrower fabric roll needs more running length to fit the same pattern pieces across its width, so consumption figures are always tied to a specific fabric width and aren\'t transferable to a different-width fabric without recalculating the marker.' },
];
const howTo = {
  name: 'How to calculate fabric cost per garment',
  steps: [
    { name: 'Enter fabric consumption per garment', text: 'The meters or yards of fabric used to cut one unit, including wastage.' },
    { name: 'Enter fabric price per meter/yard', text: 'The cost of the fabric per running unit at your chosen width.' },
    { name: 'Read the fabric cost per garment', text: 'The resulting cost feeds directly into your overall garment cost sheet.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Meters', 'Yards'].map((u) => (
        <button data-unit={u} class="unit-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">{u}</button>
      ))}
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Fabric consumption per garment</span>
        <input id="consumption" type="number" step="any" placeholder="e.g. 1.8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fabric price per unit ($)</span>
        <input id="price" type="number" step="any" placeholder="e.g. 4.50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Fabric cost per garment</div>
        <div id="r-cost" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fabric cost per garment is calculated</h2>
    <p class="mt-2 text-slate-600">
      Fabric cost per garment is simply consumption multiplied by price: <span class="font-mono">cost = consumption (m or yd) × price per m or yd</span>. The complexity lives entirely in getting an accurate consumption figure, since that number reflects the real cutting layout (the "marker") for the garment's pattern pieces on a roll of a specific width — not just the theoretical flat area of the pattern pieces added together.
    </p>
    <p class="mt-3 text-slate-600">
      Marker efficiency — how tightly the pattern pieces nest together on the fabric roll — typically runs 75-90% for garment cutting, meaning 10-25% of the fabric bought is unavoidable waste from the gaps between pieces, off-grain requirements, and directional-print or nap constraints. A consumption figure taken directly from a factory's actual marker already bakes this in; a theoretical pattern-area estimate does not, and needs a wastage allowance added.
    </p>
    <p class="mt-3 text-xs text-slate-400">Fabric consumption costing follows standard apparel cut-order-planning and marker-efficiency methodology.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A dress consumes 1.8 meters of fabric priced at $4.50 per meter.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Consumption:</span> <span class="text-slate-600">1.8 m</span></div>
        <div><span class="font-medium text-slate-700">Price:</span> <span class="text-slate-600">$4.50/m</span></div>
        <div><span class="font-medium text-slate-700">Fabric cost:</span> <span class="text-slate-600">1.8 × 4.50 = <strong>$8.10</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Fabric is typically the single largest line item in a garment's cost sheet, often 40-60% of the total FOB cost for simpler garments — which is exactly why marker efficiency gets so much attention on a production floor: even a few percentage points of wastage reduction, multiplied across a production run of thousands of units, adds up to a meaningful cost saving.
    </p>
    <p class="mt-3 text-slate-600">
      Directional prints, plaids that need pattern-matching across seams, and fabrics with a nap (velvet, corduroy) all force a less efficient marker than a plain solid fabric, since pattern pieces can't be flipped or rotated freely to save space — this is a major, often underestimated reason patterned or napped garments cost noticeably more to produce than an otherwise identical solid-color version.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Fabric consumption is just the pattern pieces' total area." <strong class="text-slate-900">No — it's the real marker length.</strong> The actual roll length used includes the unavoidable gaps between pattern pieces on the cutting layout, which pure pattern area ignores entirely.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A wider fabric roll always uses less total fabric." <strong class="text-slate-900">Not necessarily proportionally.</strong> Wider rolls generally improve marker efficiency, but the relationship isn't perfectly linear — it depends on how the specific pattern pieces nest at that width.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-waste-overrun-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Waste & Overrun Calculator</a>
      <a href="/tools/garment-costing-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Garment Costing Calculator</a>
      <a href="/tools/fabric-yield-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Yield Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let unit = 'Meters';

    function update() {
      const consumption = parseFloat(el('consumption').value);
      const price = parseFloat(el('price').value);
      if (!(consumption > 0 && price > 0)) { el('results').classList.add('hidden'); return; }
      const cost = consumption * price;
      el('r-cost').textContent = '$' + cost.toFixed(2);
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.unit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.unit-btn').forEach((b) => {
          b.className = 'unit-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50';
        });
        btn.className = 'unit-btn rounded-lg border border-rose-300 bg-rose-100 px-4 py-1.5 text-sm font-medium text-rose-700 transition';
        unit = btn.dataset.unit;
      });
    });

    ['consumption', 'price'].forEach((id) => el(id).addEventListener('input', update));
    document.querySelector('.unit-btn').click();
  </script>
</ToolLayout>
