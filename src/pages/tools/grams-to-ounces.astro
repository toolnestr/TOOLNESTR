---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Grams to Ounces"
  emoji="⚖️"
  fromUnit="grams" toUnit="ounces"
  fromTitle="Grams" toTitle="Ounces"
  fromSym="g" toSym="oz"
  quantity="weight"
  kind="factor" factor={0.0352739619}
  reverseSlug="ounces-to-grams" reverseLabel="Ounces to Grams Converter"
  hasReverse={true}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Handy in the kitchen and for postage when a recipe or scale gives grams but you need ounces."
/>
