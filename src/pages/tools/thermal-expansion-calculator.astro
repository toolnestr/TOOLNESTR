---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Thermal Expansion Calculator';
const description = "Thermal expansion calculator: find change in length from a material's expansion coefficient, original length and temperature change, with presets.";
const intro = 'Solve ΔL = αL₀ΔT for how much a material grows or shrinks with temperature change, using preset expansion coefficients for common materials. Two 3D diagrams show a rod at two temperatures and a railroad expansion joint closing as it heats, with charts comparing materials and showing expansion vs temperature change.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the linear thermal expansion formula?', a: 'ΔL = αL₀ΔT, where α is the material\'s linear expansion coefficient (per °C or per K), L₀ is the original length, and ΔT is the temperature change. A positive ΔT (heating) gives a positive ΔL (growth); a negative ΔT (cooling) gives contraction.' },
  { q: 'What is the coefficient of linear expansion?', a: 'It is a material property describing how much a substance\'s length changes per degree of temperature change, per unit length — typically expressed in units of 1/°C (or ppm/°C). Metals like aluminum expand more than steel, which expands more than glass.' },
  { q: 'How does area and volume expansion relate to linear expansion?', a: 'For an isotropic solid, the area expansion coefficient is approximately 2α and the volumetric expansion coefficient is approximately 3α, since area scales with length squared and volume scales with length cubed.' },
  { q: 'Why do bridges have expansion joints?', a: 'A steel bridge span can grow by several centimetres between winter and summer due to thermal expansion. Expansion joints are gaps built into the structure that let the bridge lengthen and shorten safely without buckling or cracking.' },
  { q: 'What is Invar and why does it expand so little?', a: 'Invar is a nickel-iron alloy engineered to have an unusually low expansion coefficient (about 1.2×10⁻⁶/°C, roughly a tenth of steel\'s), making it valuable for precision instruments, clock pendulums, and scientific equipment where dimensional stability matters.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Thermal Expansion Calculator',
  description: 'Find the change in length of a material from its expansion coefficient, original length, and temperature change.',
  steps: [
    { name: 'Pick a material or enter α manually', text: 'Choose a preset (steel, aluminum, copper, glass, concrete, Invar) or type a custom expansion coefficient.' },
    { name: 'Enter length and temperature change', text: 'Provide the original length L₀ and the temperature change ΔT (positive for heating, negative for cooling).' },
    { name: 'Read the result', text: 'The change in length and new length solve instantly.' },
  ],
};

const formulas = [
  { expr: 'ΔL = α L₀ ΔT', note: 'linear expansion — α = expansion coefficient (1/°C), L₀ = original length' },
  { expr: 'L = L₀ + ΔL', note: 'new length after the temperature change' },
  { expr: 'β_volume ≈ 3α', note: 'volumetric expansion coefficient — roughly 3× the linear coefficient for isotropic solids' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a steel bridge beam across a season', tone: 'slate',
    given: 'A steel bridge beam is L₀ = 30 m long. Between winter and summer, the temperature swings by ΔT = 40°C. Steel\'s α = 12×10⁻⁶/°C.',
    rows: [
      { label: 'Formula:', value: 'ΔL = α L₀ ΔT' },
      { label: 'Substitute:', value: 'ΔL = 12×10⁻⁶ × 30 × 40' },
      { label: 'Result:', value: 'ΔL = 0.0144 m = 14.4 mm', full: true },
    ],
    note: 'This roughly 14 mm swing is exactly why long steel bridges need expansion joints — without them, the beam would buckle or crack the structure trying to grow into a fixed space.',
  },
  {
    title: 'Worked example 2 — an aluminum rod cooling', tone: 'amber',
    given: 'An aluminum rod is L₀ = 2 m long at room temperature. It is cooled by ΔT = −50°C (a drop of 50 degrees). Aluminum\'s α = 23×10⁻⁶/°C.',
    rows: [
      { label: 'Formula:', value: 'ΔL = α L₀ ΔT' },
      { label: 'Substitute:', value: 'ΔL = 23×10⁻⁶ × 2 × (−50)' },
      { label: 'Result:', value: 'ΔL = −0.0023 m = −2.3 mm (the rod shrinks)', full: true },
    ],
    note: 'Negative ΔT (cooling) always produces negative ΔL (contraction) — the rod\'s new length is 2 m − 2.3 mm = 1.9977 m.',
  },
];

const comparison = {
  heading: 'Linear expansion coefficients across materials',
  note: 'Change in length for a standard 1 m rod heated by ΔT = 100°C — Invar\'s specially engineered low expansion stands out sharply against ordinary metals.',
  headers: [{ label: 'Material' }, { label: 'α', sub: '×10⁻⁶/°C' }, { label: 'ΔL for 1 m, ΔT=100°C' }],
  rows: [
    ['Aluminum', '23', '2.3 mm'],
    ['Copper', '17', '1.7 mm'],
    ['Steel ★', '12', '1.2 mm'],
    ['Concrete', '12', '1.2 mm'],
    ['Glass', '9', '0.9 mm'],
    ['Invar (Ni-Fe alloy)', '1.2', '0.12 mm'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). Invar expands about a tenth as much as steel — the entire reason it exists as an engineered alloy for precision instruments.',
};

const realWorld = [
  { emoji: '🌉', title: 'Bridge and railway expansion joints', body: 'Engineers calculate expected thermal expansion across a structure\'s full temperature range and build in expansion joints or gaps sized to absorb that exact movement, preventing buckling or structural damage.' },
  { emoji: '🕰️', title: 'Precision clock pendulums', body: 'A pendulum clock\'s timekeeping depends on a fixed length — Invar and other low-expansion alloys are used in precision pendulums so temperature swings don\'t throw off the clock\'s accuracy.' },
  { emoji: '🔧', title: 'Shrink-fitting machine parts', body: 'Engineers exploit thermal expansion deliberately: heating a metal ring lets it expand enough to slide over a shaft, then cooling locks it into an extremely tight, permanent fit as it contracts back down.' },
  { emoji: '🌡️', title: 'Bimetallic strip thermostats', body: 'Two metals with different expansion coefficients bonded together bend as temperature changes, since one side expands more than the other — a simple mechanical thermometer used in classic thermostats and circuit breakers.' },
];

const misconceptions = [
  { claim: '"All materials expand by the same amount for the same temperature change."', truth: 'Expansion coefficients vary significantly by material — aluminum expands almost twice as much as steel for the same length and temperature change, and specially engineered alloys like Invar expand roughly ten times less than ordinary steel.' },
  { claim: '"Thermal expansion only matters for extreme temperature changes."', truth: 'Even everyday temperature swings (a 30–40°C difference between winter and summer) can shift a long steel beam or bridge span by over a centimetre — enough to cause serious structural damage if no expansion joint is provided.' },
  { claim: '"Volume expansion is the same numeric coefficient as linear expansion."', truth: 'For an isotropic solid, the volumetric expansion coefficient is approximately 3α (three times the linear coefficient), because volume scales with length cubed — a small linear expansion coefficient produces a proportionally larger volume change.' },
  { claim: '"Cooling a material always makes it smaller in every material."', truth: 'This is true for the vast majority of materials, but water is a famous exception — it actually expands as it cools from 4°C down to freezing (0°C), which is why ice floats and pipes can burst when water freezes inside them.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — Chapter 1, "Temperature and Heat" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/1-3-thermal-expansion" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 18, Temperature, Heat, and the First Law of Thermodynamics.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 19, Temperature.' },
];
const sourcesNote = 'ΔL = αL₀ΔT. Standard material α values are textbook reference figures at room temperature and may vary slightly by alloy or manufacturing source. Results are rounded for display.';

const howToUse = [
  { title: 'Pick a material preset', body: 'Choose steel, aluminum, copper, glass, concrete, or Invar to auto-fill the expansion coefficient α.' },
  { title: 'Enter length and ΔT', body: 'Provide the original length L₀ and the temperature change (positive for heating, negative for cooling).' },
  { title: 'Compare materials on the chart', body: 'See how much more some materials expand than others for the exact same temperature swing.' },
];

const related = [
  { href: '/tools/heat-transfer-calculator', emoji: '🌡️', title: 'Heat Transfer Calculator', desc: 'Q = mcΔT — solve heat energy, mass, specific heat, or ΔT.' },
  { href: '/tools/specific-heat-calculator', emoji: '🧯', title: 'Specific Heat Calculator', desc: 'c = Q/(mΔT) — find specific heat and identify unknown materials.' },
  { href: '/tools/density-calculator', emoji: '⚖️', title: 'Density Calculator', desc: 'Solve density, mass, or volume from any two.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="heating a material makes its atoms vibrate more vigorously and push each other slightly farther apart on average, so nearly every solid grows a little when heated and shrinks a little when cooled, at a rate set by its own expansion coefficient."
  howIntro="The linear expansion coefficient α is defined so that the fractional change in length per degree of temperature change, ΔL/L₀, equals α times ΔT — rearranged, this gives the working formula ΔL = αL₀ΔT directly. Because α is usually a very small number (on the order of 10⁻⁵ or 10⁻⁶ per degree), the resulting length changes look tiny for small objects but become significant over the long spans found in bridges, railways, and pipelines."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where thermal expansion actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Pick a material preset, or enter a custom expansion coefficient.</p>
    <div class="mb-4 flex flex-wrap gap-2">
      <button type="button" class="mat-preset rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white" data-a="12e-6">Steel</button>
      <button type="button" class="mat-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-a="23e-6">Aluminum</button>
      <button type="button" class="mat-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-a="17e-6">Copper</button>
      <button type="button" class="mat-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-a="9e-6">Glass</button>
      <button type="button" class="mat-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-a="1.2e-6">Invar</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Expansion coefficient α (1/°C)</span>
        <input id="alpha" type="text" inputmode="decimal" value="12e-6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Original length L₀ (m)</span>
        <input id="L0" type="number" step="any" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature change ΔT (°C)</span>
        <input id="dT" type="number" step="any" value="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Change in length ΔL</div><div id="r-dl" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">New length L</div><div id="r-l" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="te-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Expansion in action</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-rod" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A rod at two temperatures</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-slate-500">cool rod</span> (shorter) versus the <span class="font-semibold text-amber-500">heated rod</span> (longer) — exaggerated here for visibility, since real expansions are a tiny fraction of the original length.</p>
        </div>
        <div>
          <div id="diag-joint" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. A railway expansion joint</h3>
          <p class="mt-1 text-sm text-slate-600">Two rail segments with a gap between them — the gap exists specifically to absorb the length increase from thermal expansion on hot days.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Thermal expansion graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ΔL vs ΔT for a 1 m steel rod</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Expansion coefficient comparison across materials</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-materials"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('te-err').textContent = '';
        el('r-dl').textContent = '—'; el('r-l').textContent = '—';
        const alpha = parseFloat(el('alpha').value), L0 = parseFloat(el('L0').value), dT = parseFloat(el('dT').value);
        if (isNaN(alpha) || isNaN(L0) || isNaN(dT)) return;
        if (L0 <= 0) { el('te-err').textContent = 'Original length must be greater than 0.'; return; }
        const dL = alpha * L0 * dT;
        el('r-dl').textContent = (dL >= 0 ? '+' : '') + fmt(dL * 1000) + ' mm';
        el('r-l').textContent = fmt(L0 + dL) + ' m';
      }
      document.querySelectorAll('.mat-preset').forEach((b) => b.addEventListener('click', () => {
        document.querySelectorAll('.mat-preset').forEach((x) => (x.className = 'mat-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600'));
        b.className = 'mat-preset rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white';
        el('alpha').value = b.getAttribute('data-a');
        update();
      }));
      ['alpha', 'L0', 'dT'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsT = [], dataT = [];
        for (let t = -50; t <= 50; t += 10) { labelsT.push(t); dataT.push(+(12e-6 * 1 * t * 1000).toFixed(4)); }
        charts.dt = new Chart(el('chart-dt'), {
          type: 'line',
          data: { labels: labelsT, datasets: [{ label: 'ΔL (mm)', data: dataT, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'ΔT (°C)' } }, y: { title: { display: true, text: 'ΔL (mm) for 1m steel rod' } } }, plugins: { legend: { display: false } } }),
        });
        const mats = [{ n: 'Glass', a: 9 }, { n: 'Steel', a: 12 }, { n: 'Copper', a: 17 }, { n: 'Aluminum', a: 23 }];
        charts.materials = new Chart(el('chart-materials'), {
          type: 'bar',
          data: { labels: mats.map((m) => m.n), datasets: [{ label: 'α (×10⁻⁶/°C)', data: mats.map((m) => m.a), backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'α (×10⁻⁶ per °C)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: rod at two temperatures ----
      let diagRod = null;
      function initDiagRod() {
        const c = el('diag-rod'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 0, 0), OPTS);
        const cool = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.25, 3, 20), new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.5 }));
        cool.rotation.z = Math.PI / 2; cool.position.set(0, 1, 0);
        s.scene.add(cool);
        const hot = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.25, 4, 20), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5 }));
        hot.rotation.z = Math.PI / 2; hot.position.set(0, -1, 0);
        s.scene.add(hot);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagRod = { resize: s.resize };
      }

      // ---- Diagram 2: railway expansion joint ----
      let diagJoint = null;
      function initDiagJoint() {
        const c = el('diag-joint'); if (!c) throw new Error('no container');
        const s = makeScene(c, 11, new THREE.Vector3(0, 0, 0), OPTS);
        const railMat = new THREE.MeshStandardMaterial({ color: 0x64748b, roughness: 0.5 });
        const rail1 = new THREE.Mesh(new THREE.BoxGeometry(3.4, 0.3, 0.5), railMat);
        rail1.position.set(-2, 0, 0); s.scene.add(rail1);
        const rail2 = new THREE.Mesh(new THREE.BoxGeometry(3.4, 0.3, 0.5), railMat);
        rail2.position.set(2, 0, 0); s.scene.add(rail2);
        const tieMat = new THREE.MeshStandardMaterial({ color: 0x92613a, roughness: 0.7 });
        for (let x = -4; x <= 4; x += 1) {
          const tie = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.15, 1.4), tieMat);
          tie.position.set(x, -0.3, 0);
          s.scene.add(tie);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagJoint = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[thermal-expansion] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[thermal-expansion] charts failed', e); }
        if (window.THREE) {
          try { initDiagRod(); } catch (e) { console.error('[thermal-expansion] rod diagram failed', e); }
          try { initDiagJoint(); } catch (e) { console.error('[thermal-expansion] joint diagram failed', e); }
        }
        mountResize([diagRod, diagJoint]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
