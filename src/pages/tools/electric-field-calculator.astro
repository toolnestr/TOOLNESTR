---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Electric Field Calculator';
const description = 'Electric field calculator with a live 3D field-line diagram and charts. Solve E = F/q or E = kQ/r² for field strength, force, charge, or distance, with worked examples.';
const intro = 'Solve E = F/q for the electric field from force and charge, or E = kQ/r² for the field created by a point charge at a distance. Two 3D diagrams show field-line density near and far from a point charge, and charts show how field strength falls off with distance and scales with charge.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is an electric field?', a: 'An electric field is the region around a charged object where another charge would feel a force. Its strength E at a point is defined as the force per unit charge a small positive test charge would feel there: E = F/q, measured in newtons per coulomb (N/C).' },
  { q: 'What is the formula for the field of a point charge?', a: 'E = kQ/r², where k ≈ 8.9875×10⁹ N·m²/C² is Coulomb\'s constant, Q is the source charge, and r is the distance from it. This is the same inverse-square shape as Coulomb\'s law itself, since F = qE = kQq/r².' },
  { q: 'How is the electric field related to Coulomb\'s law?', a: 'Coulomb\'s law gives the force between two charges, F = kq₁q₂/r². The electric field is what one charge creates at every point in space; multiplying that field by a second charge\'s magnitude gives the force on it, F = qE — so E = kQ/r² is just Coulomb\'s law divided by the test charge.' },
  { q: 'Does the electric field depend on the test charge placed in it?', a: 'No — the field E = kQ/r² is a property of the source charge Q and the distance r alone. A test charge only experiences the field; it does not change it (assuming the test charge is small enough not to disturb the source charge\'s position).' },
  { q: 'Which way does the electric field point?', a: 'By convention, field lines point away from positive charges and toward negative charges — showing the direction the force on a small positive test charge would point at that location.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Electric Field Calculator',
  description: 'Calculate electric field strength from force and charge (E = F/q), or from a point charge and distance (E = kQ/r²).',
  steps: [
    { name: 'Pick a mode', text: 'Use "From force and charge" for E = F/q, or "From point charge" for E = kQ/r².' },
    { name: 'Enter the known values', text: 'Use scientific notation for charges, e.g. 2e-6 for 2 μC.' },
    { name: 'Read the result', text: 'The field, force, or charge solves instantly, and the 3D diagrams and charts update.' },
  ],
};

const formulas = [
  { expr: 'E = F / q', note: 'electric field from force on a test charge' },
  { expr: 'E = k Q / r²', note: "field of a point charge; k ≈ 8.9875×10⁹ N·m²/C²" },
];

const workedExamples = [
  {
    title: 'Worked example 1 — field from a point charge', tone: 'slate',
    given: 'A point charge Q = 2 μC (2×10⁻⁶ C) sits at the origin. Find the electric field at r = 0.5 m.',
    rows: [
      { label: 'Formula:', value: 'E = kQ/r²' },
      { label: 'Substitute:', value: 'E = 8.9875×10⁹ × 2×10⁻⁶ / (0.5)²' },
      { label: 'Simplify:', value: 'E = 8.9875×10⁹ × 2×10⁻⁶ / 0.25' },
      { label: 'Result:', value: 'E = 71,900 N/C', full: true },
    ],
    note: 'Halving the distance to 0.25 m would quadruple this field to 287,600 N/C, since E falls off as 1/r².',
  },
  {
    title: 'Worked example 2 — force from field and charge', tone: 'amber',
    given: 'A uniform electric field of E = 500 N/C acts on a charge q = 4 μC (4×10⁻⁶ C). Find the force on the charge.',
    rows: [
      { label: 'Formula:', value: 'F = E × q' },
      { label: 'Substitute:', value: 'F = 500 × 4×10⁻⁶' },
      { label: 'Result:', value: 'F = 0.002 N = 2 mN', full: true },
    ],
    note: 'The force direction matches the field direction for a positive charge, and points opposite the field for a negative charge.',
  },
];

const comparison = {
  heading: 'Electric field vs gravitational field',
  note: 'Both are "force per unit source quantity" fields with an inverse-square dependence on distance from a point source.',
  headers: [{ label: 'Property' }, { label: 'Electric field' }, { label: 'Gravitational field' }],
  rows: [
    ['Formula (point source)', 'E = kQ/r²', 'g = GM/r²'],
    ['Source quantity', 'Charge Q', 'Mass M'],
    ['Force on a test object', 'F = qE', 'F = mg'],
    ['Can point either way', 'Yes — away from + charge, toward − charge', 'No — always toward the mass'],
  ],
  highlightIndex: 3,
  footnote: 'Both fields obey an inverse-square law, but the electric field can point toward or away from its source depending on charge sign, while gravity is always attractive.',
};

const realWorld = [
  { emoji: '🖨️', title: 'Laser printers and photocopiers', body: 'A charged drum creates an electric field that attracts oppositely charged toner particles to exactly the right spots on the page, using the same E = F/q relationship that governs any charged particle in a field.' },
  { emoji: '🌩️', title: 'Thunderstorm electric fields', body: 'Charge separation inside storm clouds builds up an electric field strong enough — often tens of thousands of volts per metre — to ionise air and trigger a lightning strike once it exceeds air\'s dielectric breakdown strength.' },
  { emoji: '🧪', title: 'Mass spectrometers and particle accelerators', body: 'Charged particles are steered and accelerated using carefully shaped electric fields, where the force F = qE determines exactly how much a particle of known charge will bend or speed up.' },
  { emoji: '📺', title: 'Old CRT televisions', body: 'Cathode ray tubes used electric fields between charged plates to deflect a beam of electrons left, right, up, and down thousands of times per second to paint an image on the phosphor screen.' },
];

const misconceptions = [
  { claim: '"The electric field is the same thing as the force."', truth: 'Field and force are related but distinct: E = F/q means the field is force per unit charge. The same field E produces different forces on different charges — a bigger charge in the same field feels a bigger force, F = qE.' },
  { claim: '"A stronger field always means a bigger charge is present."', truth: 'Field strength from a point charge, E = kQ/r², depends on both the charge and the distance. A modest charge very close by can create a stronger field than a huge charge far away — distance matters just as much as charge magnitude.' },
  { claim: '"Electric field lines are physically real, like wires."', truth: 'Field lines are a visualization tool showing the direction a test charge would be pushed or pulled at each point — there is nothing physically there. Line density is just a convenient way to represent field strength, with denser lines meaning a stronger field.' },
  { claim: '"The field only exists where there is a test charge to feel it."', truth: 'The electric field exists at every point in space around a charge, whether or not another charge is there to experience it — placing a test charge just reveals the field that was already present, it does not create it.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — §5.4 "Electric Field" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/5-4-electric-field" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 22, Electric Fields.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 23, Electric Fields.' },
];
const sourcesNote = 'E = F/q and E = kQ/r² with k ≈ 8.9875×10⁹ N·m²/C². Results are rounded for display.';

const howToUse = [
  { title: 'Pick a mode', body: 'Use "From force and charge" for E = F/q, or "From point charge" for E = kQ/r².' },
  { title: 'Enter charges in coulombs', body: 'Use scientific notation for lab-scale charges, e.g. 2e-6 for 2 μC.' },
  { title: 'See the field visually', body: 'The 3D diagrams show field-line density falling off with distance from the source charge.' },
];

const related = [
  { href: '/tools/coulombs-law-calculator', emoji: '⚡', title: "Coulomb's Law Calculator", desc: 'F = k|q1q2|/r² — electrostatic force between two charges.' },
  { href: '/tools/electric-power-calculator', emoji: '💡', title: 'Electric Power Calculator', desc: 'P = V×I plus energy and electricity cost.' },
  { href: '/tools/capacitance-calculator', emoji: '🪫', title: 'Capacitance Calculator', desc: 'C = Q/V and the parallel-plate formula.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="An electric field describes the force per unit charge that would act on a small test charge at every point around a charged object — it exists whether or not a test charge is actually there to feel it."
  howIntro="From E = F/q, force and charge solve directly: F = qE and q = F/E. For the field of a point charge, E = kQ/r² rearranges to Q = Er²/k and r = √(kQ/E). Because E falls off as 1/r², doubling the distance from a point charge cuts the field to a quarter — the same inverse-square drop-off as Coulomb's law itself, since the field is just force divided by a test charge."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where electric fields actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Mode:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-fq" type="button" data-mode="fq" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From force and charge</button>
      <button id="mode-point" type="button" data-mode="point" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From point charge</button>
    </div>

    <!-- Force/charge panel -->
    <div id="panel-fq">
      <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
      <div class="mb-4 flex flex-wrap gap-2">
        <button id="fqmode-e" type="button" data-solve="e" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Field (E)</button>
        <button id="fqmode-f" type="button" data-solve="f" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Force (F)</button>
        <button id="fqmode-q" type="button" data-solve="q" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Charge (q)</button>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <label id="field-e" class="block"><span class="text-sm font-medium text-slate-700">Field (E)</span>
          <input id="e" type="number" step="any" placeholder="N/C" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label id="field-f" class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
          <input id="f" type="number" step="any" placeholder="N" value="0.002" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label id="field-q" class="block"><span class="text-sm font-medium text-slate-700">Charge (q)</span>
          <input id="q" type="number" step="any" placeholder="C, e.g. 4e-6" value="4e-6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div id="box-e" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Field</div><div id="r-e" class="mt-1 text-2xl font-bold">—</div></div>
        <div id="box-f" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Force</div><div id="r-f" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
        <div id="box-q" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Charge</div><div id="r-q" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      </div>
      <p id="fq-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
    </div>

    <!-- Point-charge panel -->
    <div id="panel-point" class="hidden">
      <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
      <div class="mb-4 flex flex-wrap gap-2">
        <button id="ptmode-e" type="button" data-solve="e" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Field (E)</button>
        <button id="ptmode-qq" type="button" data-solve="qq" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Charge (Q)</button>
        <button id="ptmode-r" type="button" data-solve="r" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Distance (r)</button>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <label id="field-pe" class="block"><span class="text-sm font-medium text-slate-700">Field (E)</span>
          <input id="pe" type="number" step="any" placeholder="N/C" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label id="field-qq" class="block"><span class="text-sm font-medium text-slate-700">Charge (Q)</span>
          <input id="qq" type="number" step="any" placeholder="C, e.g. 2e-6" value="2e-6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label id="field-r" class="block"><span class="text-sm font-medium text-slate-700">Distance (r)</span>
          <input id="r" type="number" step="any" placeholder="m" value="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div id="box-pe" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Field</div><div id="r-pe" class="mt-1 text-2xl font-bold">—</div></div>
        <div id="box-qq" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Charge</div><div id="r-qq" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
        <div id="box-r" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Distance</div><div id="r-r" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      </div>
      <p id="pt-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
    </div>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Field-line density near and far from a charge</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-near" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Close to the charge — strong field</h3>
          <p class="mt-1 text-sm text-slate-600">Field-line arrows sampled at a <span class="font-semibold text-amber-500">near distance</span> from a positive point charge, radiating outward densely — a strong field.</p>
        </div>
        <div>
          <div id="diag-far" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Far from the charge — weak field</h3>
          <p class="mt-1 text-sm text-slate-600">The same charge sampled at a <span class="font-semibold text-slate-500">farther distance</span> — arrows are sparser and shorter, showing the field has weakened with the inverse-square drop-off.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Electric field graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">E vs distance r (fixed Q = 2 μC) — an inverse-square curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-r"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">E vs charge Q (fixed r = 0.5 m) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-q"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };
      const K = 8.9875e9;

      // ---- mode switching ----
      let mode = 'fq';
      function switchMode(m) {
        mode = m;
        el('mode-fq').className = m === 'fq' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-point').className = m === 'point' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('panel-fq').classList.toggle('hidden', m !== 'fq');
        el('panel-point').classList.toggle('hidden', m !== 'point');
      }
      el('mode-fq').addEventListener('click', () => switchMode('fq'));
      el('mode-point').addEventListener('click', () => switchMode('point'));

      // ---- force/charge panel ----
      let fqSolve = 'e';
      const fqModeBtns = { e: 'fqmode-e', f: 'fqmode-f', q: 'fqmode-q' };
      const fqFieldEls = { e: 'field-e', f: 'field-f', q: 'field-q' };
      const fqBoxEls = { e: 'box-e', f: 'box-f', q: 'box-q' };

      function switchFqSolve(s) {
        fqSolve = s;
        Object.keys(fqModeBtns).forEach((k) => {
          el(fqModeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(fqFieldEls).forEach((k) => { el(fqFieldEls[k]).style.opacity = k === s ? '0.45' : '1'; });
        Object.keys(fqBoxEls).forEach((k) => {
          el(fqBoxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        updateFq();
      }

      function updateFq() {
        el('fq-err').textContent = '';
        ['r-e', 'r-f', 'r-q'].forEach((id) => (el(id).textContent = '—'));
        const e = parseFloat(el('e').value);
        const f = parseFloat(el('f').value);
        const q = parseFloat(el('q').value);
        let E, F, Q;
        if (fqSolve === 'e') {
          if (isNaN(f) || isNaN(q)) return;
          if (q === 0) { el('fq-err').textContent = 'Charge cannot be zero when solving for field.'; return; }
          E = f / q; F = f; Q = q;
        } else if (fqSolve === 'f') {
          if (isNaN(e) || isNaN(q)) return;
          E = e; F = e * q; Q = q;
        } else {
          if (isNaN(e) || isNaN(f)) return;
          if (e === 0) { el('fq-err').textContent = 'Field cannot be zero when solving for charge.'; return; }
          E = e; F = f; Q = f / e;
        }
        el('r-e').textContent = fmt(E) + ' N/C';
        el('r-f').textContent = fmt(F) + ' N';
        el('r-q').textContent = fmt(Q) + ' C';
      }
      el('fqmode-e').addEventListener('click', () => switchFqSolve('e'));
      el('fqmode-f').addEventListener('click', () => switchFqSolve('f'));
      el('fqmode-q').addEventListener('click', () => switchFqSolve('q'));
      ['e', 'f', 'q'].forEach((id) => el(id).addEventListener('input', updateFq));

      // ---- point-charge panel ----
      let ptSolve = 'e';
      const ptModeBtns = { e: 'ptmode-e', qq: 'ptmode-qq', r: 'ptmode-r' };
      const ptFieldEls = { e: 'field-pe', qq: 'field-qq', r: 'field-r' };
      const ptBoxEls = { e: 'box-pe', qq: 'box-qq', r: 'box-r' };

      function switchPtSolve(s) {
        ptSolve = s;
        Object.keys(ptModeBtns).forEach((k) => {
          el(ptModeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(ptFieldEls).forEach((k) => { el(ptFieldEls[k]).style.opacity = k === s ? '0.45' : '1'; });
        Object.keys(ptBoxEls).forEach((k) => {
          el(ptBoxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        updatePt();
      }

      function updatePt() {
        el('pt-err').textContent = '';
        ['r-pe', 'r-qq', 'r-r'].forEach((id) => (el(id).textContent = '—'));
        const e = parseFloat(el('pe').value);
        const q = parseFloat(el('qq').value);
        const r = parseFloat(el('r').value);
        let E, Q, R;
        if (ptSolve === 'e') {
          if (isNaN(q) || isNaN(r)) return;
          if (r === 0) { el('pt-err').textContent = 'Distance cannot be zero.'; return; }
          E = K * q / (r * r); Q = q; R = r;
        } else if (ptSolve === 'qq') {
          if (isNaN(e) || isNaN(r)) return;
          Q = (e * r * r) / K; E = e; R = r;
        } else {
          if (isNaN(e) || isNaN(q)) return;
          if (e === 0) { el('pt-err').textContent = 'Field cannot be zero when solving for distance.'; return; }
          if (K * q / e < 0) { el('pt-err').textContent = 'Field and charge must have consistent signs.'; return; }
          R = Math.sqrt(K * q / e); E = e; Q = q;
        }
        el('r-pe').textContent = fmt(E) + ' N/C';
        el('r-qq').textContent = fmt(Q) + ' C';
        el('r-r').textContent = fmt(R) + ' m';
      }
      el('ptmode-e').addEventListener('click', () => switchPtSolve('e'));
      el('ptmode-qq').addEventListener('click', () => switchPtSolve('qq'));
      el('ptmode-r').addEventListener('click', () => switchPtSolve('r'));
      ['pe', 'qq', 'r'].forEach((id) => el(id).addEventListener('input', updatePt));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const L1 = [], D1 = [];
        const Qfixed = 2e-6;
        for (let rr = 0.1; rr <= 2.0001; rr += 0.05) { L1.push(rr.toFixed(2)); D1.push(+(K * Qfixed / (rr * rr)).toFixed(2)); }
        charts.r = new Chart(el('chart-r'), {
          type: 'line',
          data: { labels: L1, datasets: [{ label: 'E', data: D1, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Distance r (m)' } }, y: { title: { display: true, text: 'Field E (N/C)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        const L2 = [], D2 = [];
        const rFixed = 0.5;
        for (let qMicro = 0; qMicro <= 10.001; qMicro += 0.5) { L2.push(qMicro.toFixed(1)); D2.push(+(K * (qMicro * 1e-6) / (rFixed * rFixed)).toFixed(2)); }
        charts.q = new Chart(el('chart-q'), {
          type: 'line',
          data: { labels: L2, datasets: [{ label: 'E', data: D2, borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Charge Q (μC)' } }, y: { title: { display: true, text: 'Field E (N/C)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagrams: near vs far field-line density ----
      let diagNear = null, diagFar = null;
      function buildFieldDiagram(container, sampleRadius, arrowLen, arrowCount) {
        const c = el(container); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const chargeMat = new THREE.MeshStandardMaterial({ color: 0xef4444 });
        const charge = new THREE.Mesh(new THREE.SphereGeometry(0.4, 24, 20), chargeMat);
        s.scene.add(charge);
        for (let i = 0; i < arrowCount; i++) {
          const theta = (i / arrowCount) * Math.PI * 2;
          const phi = Math.acos(1 - 2 * ((i * 0.61803398875) % 1));
          const dir = new THREE.Vector3(Math.sin(phi) * Math.cos(theta), Math.cos(phi) * 0.6, Math.sin(phi) * Math.sin(theta)).normalize();
          const start = dir.clone().multiplyScalar(sampleRadius);
          const end = dir.clone().multiplyScalar(sampleRadius + arrowLen);
          s.scene.add(arrow(start, end, 0xf59e0b));
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function initDiagNear() { diagNear = buildFieldDiagram('diag-near', 1.2, 1.0, 14); }
      function initDiagFar() { diagFar = buildFieldDiagram('diag-far', 3.0, 0.5, 8); }

      function boot() {
        try { switchFqSolve('e'); updateFq(); } catch (e) { console.error('[electric-field] fq init failed', e); }
        try { switchPtSolve('e'); updatePt(); } catch (e) { console.error('[electric-field] pt init failed', e); }
        try { initCharts(); } catch (e) { console.error('[electric-field] charts failed', e); }
        if (window.THREE) {
          try { initDiagNear(); } catch (e) { console.error('[electric-field] near diagram failed', e); }
          try { initDiagFar(); } catch (e) { console.error('[electric-field] far diagram failed', e); }
        }
        mountResize([diagNear, diagFar]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
