---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Arch Layout Calculator';
const description = 'Find the radius and rise of a curved arch opening from its span and height, for framing a doorway, window or trim arch — plus the arc length for trim stock.';
const intro = 'Find the radius and arc length for a curved arch, from its span and rise.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate the radius of an arch from its span and rise?', a: 'Radius = (rise² + (span/2)²) ÷ (2 × rise). A 48-inch span with a 6-inch rise: (6² + 24²) ÷ (2×6) = (36+576) ÷ 12 = 51 inches.' },
  { q: 'What is the rise of an arch?', a: 'Rise is the height of the curve measured from a straight line drawn across the span (the springline) up to the highest point of the arc. A shallow segmental arch has a small rise relative to its span; a tall Roman-style arch has a rise close to half the span.' },
  { q: 'How much trim or track material do I need for an arch?', a: 'The arc length — the curved distance along the top of the opening — tells you how much flexible trim, track, or casing to buy. It\'s found from the radius and the angle the arc sweeps through, using arc length = radius × angle in radians.' },
  { q: 'How do I mark the arch curve for cutting?', a: 'Once you know the radius, you can strike the arc with a trammel (a beam compass) pivoted at a point directly below the center of the span, at a distance equal to the radius down from the springline — or minus the rise if the center falls above it, depending on the radius and rise relationship.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Span (in)</span>
        <input id="span" type="number" step="any" placeholder="48" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Rise (in)</span>
        <input id="rise" type="number" step="any" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Arch radius</div>
        <div id="r-radius" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Arc length</div><div id="r-arclen" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Sweep angle</div><div id="r-angle" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Center drop below springline</div><div id="r-center" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="al-title al-desc">
      <title id="al-title">Arch span, rise, and radius</title>
      <desc id="al-desc">A curved arch opening with span, rise, and the radius formula</desc>
      <path d="M80 140 Q220 60 360 140" stroke="#6366f1" stroke-width="4" fill="none" />
      <line x1="80" y1="140" x2="360" y2="140" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="4 3" />
      <line x1="220" y1="140" x2="220" y2="83" stroke="#ef4444" stroke-width="1.5" />
      <text x="220" y="160" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">span</text>
      <text x="235" y="110" font-size="12" fill="#ef4444" font-family="system-ui,sans-serif">rise</text>
      <rect x="420" y="55" width="330" height="120" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Arch radius</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">R = (rise&sup2; + (span&frasl;2)&sup2;) &divide; (2 &times; rise)</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">arc length = R &times; angle (radians)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The springline is the straight base of the arch; the rise is measured up from it.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the arch layout calculator works</h2>
    <p class="mt-2 text-slate-600">
      Laying out a curved arch — over a doorway, window, or piece of trim — comes down to finding the radius of the circle that the arc is a slice of. Given the span (the straight-line width of the opening at its base, called the springline) and the rise (the height of the curve above that springline), the radius is found with R = (rise² + (span/2)²) ÷ (2 × rise). This formula comes from the geometric relationship between a chord, its height above the chord, and the radius of the circle it belongs to.
    </p>
    <p class="mt-3 text-slate-600">
      Once you have the radius, you can find the arc length — the actual curved distance along the top of the opening — which tells you how much flexible trim, casing, or track material to buy. Arc length equals the radius times the sweep angle in radians; the calculator works out that angle from the span and radius and converts the result to a length automatically.
    </p>
    <p class="mt-3 text-slate-600">
      To physically mark the curve for cutting, use a trammel — essentially a large compass — pivoted at the arc's true center. That center sits directly below the midpoint of the span, at a distance equal to the radius measured down from the highest point of the arc; the calculator reports how far that center point falls below the springline, which is what you'd measure down from the base of the opening to locate the pivot point on the wall or a temporary layout batten.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set span and rise</h3>
        <p class="mt-1 text-sm text-slate-600">Width of the opening and how tall the curve is.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get the radius</h3>
        <p class="mt-1 text-sm text-slate-600">Used to strike the curve with a trammel.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Order trim by arc length</h3>
        <p class="mt-1 text-sm text-slate-600">The actual curved distance to cover.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Radius</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= (rise&sup2; + (span&frasl;2)&sup2;) &divide; (2&times;rise)</span>. A 48 in span, 6 in rise: (36+576) ÷ 12 = <strong>51 in</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Sweep angle</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= 2 &times; asin((span&frasl;2) &divide; R)</span> = 2 × asin(24÷51) = <strong>56.1°</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Arc length</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= R &times; angle(rad)</span> = 51 × 0.980 = <strong>50.0 in</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A wide 72 in doorway arch with a 12 in rise.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Radius:</span> <span class="text-slate-600">(144+1296) ÷ 24 = 60 in</span></div>
        <div><span class="font-medium text-slate-700">Angle:</span> <span class="text-slate-600">2×asin(36÷60) = 73.7°</span></div>
        <div><span class="font-medium text-slate-700">Arc length:</span> <span class="text-slate-600">60 × 1.287 = <strong>77.2 in</strong></span></div>
        <div><span class="font-medium text-slate-700">Center drop:</span> <span class="text-slate-600">60 − 12 = 48 in below springline</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/miter-angle-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Miter Angle Calculator</a>
      <a href="/tools/door-header-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Door Header Size Calculator</a>
      <a href="/tools/perimeter-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Perimeter Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const rad = (d) => d * Math.PI / 180;
    const deg = (r) => r * 180 / Math.PI;

    function update() {
      const span = parseFloat(el('span').value);
      const rise = parseFloat(el('rise').value);
      if (!(span > 0 && rise > 0)) { el('results').classList.add('hidden'); return; }
      const R = (rise * rise + Math.pow(span / 2, 2)) / (2 * rise);
      const halfAngleRad = Math.asin(Math.min((span / 2) / R, 1));
      const sweepDeg = deg(halfAngleRad) * 2;
      const arcLen = R * (halfAngleRad * 2);
      const centerDrop = R - rise;

      el('r-radius').textContent = R.toFixed(1) + ' in';
      el('r-note').textContent = span + ' in span, ' + rise + ' in rise';
      el('r-arclen').textContent = arcLen.toFixed(1) + ' in';
      el('r-angle').textContent = sweepDeg.toFixed(1) + '°';
      el('r-center').textContent = centerDrop.toFixed(1) + ' in';
      el('results').classList.remove('hidden');
    }

    ['span', 'rise'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
