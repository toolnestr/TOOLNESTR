---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Km to Miles"
  emoji="📏"
  fromUnit="kilometers" toUnit="miles"
  fromTitle="Kilometers" toTitle="Miles"
  fromSym="km" toSym="mi"
  quantity="length"
  kind="factor" factor={0.6213711922}
  reverseSlug="miles-to-km" reverseLabel="Miles to Km Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Ideal for road trips and running, translating a metric distance into the miles used on US and UK roads."
/>
