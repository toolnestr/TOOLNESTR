---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Zipper Length Calculator';
const description = 'Calculate the zipper length needed for an opening, or check it against common garment zipper lengths.';
const intro = 'Calculate zipper length from an opening measurement, with common garment length references.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Should the zipper be exactly the same length as the opening?', a: 'Usually slightly shorter — a zipper about half an inch to an inch shorter than the finished opening leaves room for the seam allowance and a clean finish at the top and bottom of the opening.' },
  { q: 'What zipper length is standard for a skirt or dress?', a: 'A side or back zipper on a skirt is commonly 7 inches, a dress back zipper commonly runs 20-22 inches (or invisible zippers in similar lengths), and a pants fly zipper is commonly 7 inches — these are standard notions-store lengths, not exact formulas.' },
  { q: 'What if I can\'t find the exact zipper length I calculated?', a: 'Zippers are typically sold in fixed length increments (often every inch or every few centimeters); buy the closest length available and adjust the opening slightly, or shorten a longer zipper yourself by stitching a new stop and trimming the excess.' },
  { q: 'Does an invisible zipper need a different length than a regular zipper?', a: 'The length calculation is the same, but invisible zippers are typically sewn slightly differently (seam allowance covers the zipper coil), so check your pattern\'s specific instructions for the exact placement relative to seam lines.' },
];
const howTo = {
  name: 'How to calculate zipper length',
  steps: [
    { name: 'Measure the finished opening', text: 'Measure the length of the opening the zipper needs to close.' },
    { name: 'Subtract the standard allowance', text: 'The calculator subtracts a small allowance for a clean top and bottom finish.' },
    { name: 'Read the zipper length to buy', text: 'Compare the result against standard notions-store zipper lengths.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Finished opening length (in)</span>
        <input id="opening" type="number" step="any" placeholder="e.g. 22" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Allowance (in)</span>
        <input id="allowance" type="number" step="any" value="0.75" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Zipper length to buy</div>
        <div id="r-length" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[400px] text-sm">
        <thead><tr class="border-b border-slate-200 text-left text-slate-500"><th class="py-2">Garment</th><th class="py-2">Typical zipper length</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <tr><td class="py-2">Pants fly</td><td class="py-2">7 in</td></tr>
          <tr><td class="py-2">Skirt (side/back)</td><td class="py-2">7 in</td></tr>
          <tr><td class="py-2">Dress (back)</td><td class="py-2">20-22 in</td></tr>
          <tr><td class="py-2">Jacket (front)</td><td class="py-2">22-26 in</td></tr>
          <tr><td class="py-2">Cushion cover</td><td class="py-2">14-18 in</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="zlc-title zlc-desc">
      <title id="zlc-title">Zipper shown slightly shorter than a garment opening</title>
      <desc id="zlc-desc">A vertical opening with a zipper strip inside it, slightly shorter than the full opening length</desc>
      <line x1="400" y1="20" x2="400" y2="160" stroke="#94a3b8" stroke-width="2" stroke-dasharray="6 3" />
      <rect x="385" y="35" width="30" height="115" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <text x="450" y="30" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Opening</text>
      <text x="450" y="90" font-size="12" fill="#c026d3" font-family="system-ui,sans-serif">Zipper</text>
      <text x="450" y="150" font-size="12" fill="#475569" font-family="system-ui,sans-serif">(slightly shorter)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Zipper length is slightly shorter than the finished opening for a clean finish</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How zipper length is calculated</h2>
    <p class="mt-2 text-slate-600">
      A zipper is generally cut or bought slightly shorter than the finished opening it fills, leaving a small allowance at the top and bottom for a clean seam finish and, at the top, room for a waistband or facing to cover the zipper's stop. This calculator subtracts a standard allowance from your measured opening length to suggest the zipper length to shop for.
    </p>
    <p class="mt-3 text-slate-600">
      Because zippers are manufactured in fixed length increments rather than any custom size, the calculated number is a target to match against available lengths — round up to the nearest available length if nothing matches exactly, since a zipper that's too short can't close the opening, while one slightly too long can be shortened.
    </p>
    <p class="mt-3 text-xs text-slate-400">The allowance and typical garment lengths reflect standard home-sewing and notions-industry conventions.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A dress has a 22-inch back opening, using a 0.75-inch allowance.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Opening:</span> <span class="text-slate-600">22 in</span></div>
        <div><span class="font-medium text-slate-700">Zipper length:</span> <span class="text-slate-600">22 − 0.75 = <strong>21.25 in</strong></span></div>
        <div><span class="font-medium text-slate-700">Buy:</span> <span class="text-slate-600">nearest standard length, typically <strong>22 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Replacing a broken zipper in an existing garment is one of the most common alteration requests, and matching the original zipper's length (rather than guessing from the garment's overall size) avoids ending up with a zipper that leaves an unfinished gap or bunches at one end.
    </p>
    <p class="mt-3 text-slate-600">
      Home-decor projects like cushion covers use zippers at the edge of a seam rather than in a shaped garment opening, so the length calculation is simpler — matching the seam length directly, minus a small allowance so the zipper doesn't run into the corners where the boxing strip or piping is sewn.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A longer zipper than needed can always just be sewn in as-is." <strong class="text-slate-900">Usually needs shortening first.</strong> An oversized zipper typically needs its excess trimmed and a new stop added so the pull doesn't run off the end, rather than being sewn in at full length.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All garment zippers of the same type use the same standard length." <strong class="text-slate-900">Only roughly.</strong> The "standard" lengths in the reference table are common defaults, not fixed rules — a fitted mermaid-style dress or an oversized jacket can call for a noticeably different zipper length than the typical range.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/seam-allowance-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Seam Allowance Calculator</a>
      <a href="/tools/pillow-box-cushion-fabric-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Pillow/Box Cushion Fabric Calculator</a>
      <a href="/tools/buttonhole-length-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Buttonhole Length Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const opening = parseFloat(el('opening').value);
      const allowance = parseFloat(el('allowance').value) || 0;
      if (!opening || opening <= 0) { el('results').classList.add('hidden'); return; }
      const zipLength = opening - allowance;
      el('r-length').textContent = zipLength.toFixed(2) + ' in';
      el('results').classList.remove('hidden');
    }

    el('opening').addEventListener('input', update);
    el('allowance').addEventListener('input', update);
  </script>
</ToolLayout>
