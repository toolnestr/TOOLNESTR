---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Serial Dilution Calculator';
const description = 'Serial dilution calculator with a live 3D dilution-series diagram and charts. Solve per-step and cumulative dilution factor across a series, plus final concentration, with worked examples.';
const intro = 'Solve the dilution factor for one step of a serial dilution — DF = (sample + diluent) / sample — then compound it across multiple steps to find the cumulative dilution factor and final concentration. Two 3D diagrams compare a mild dilution series to a steep one, and charts show how concentration drops step by step on a log scale.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a serial dilution?', a: "A serial dilution is a series of sequential dilutions, each one made from the previous step's result rather than from the original stock — this lets you reach extremely high dilution factors using only small, manageable volumes at each step." },
  { q: 'How do you calculate the dilution factor for one step?', a: 'The dilution factor for a single step equals the total final volume divided by the sample volume added: DF = (sample volume + diluent volume) / sample volume. A 1 mL sample added to 9 mL of diluent gives DF = 10/1 = 10 (often written as a 1:10 dilution).' },
  { q: 'How do you find the cumulative dilution factor across multiple steps?', a: 'Multiply the dilution factor of each individual step together — for a series of identical 1:10 dilutions repeated 5 times, the cumulative dilution factor is 10 × 10 × 10 × 10 × 10 = 10⁵ = 100,000.' },
  { q: 'Why use a serial dilution instead of one large single dilution?', a: 'Diluting directly to an extremely high factor (like 1:100,000) in a single step would require an impractically large volume of diluent. A serial dilution reaches the same final dilution using several small, easy-to-pipette steps instead.' },
  { q: 'How is serial dilution used to count bacteria?', a: 'Since colony counting on a plate only works within a countable range (too many colonies overlap and can\'t be counted), samples are serially diluted until a plate shows a countable number of colonies, then the original concentration is back-calculated using the known cumulative dilution factor.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Serial Dilution Calculator',
  description: 'Solve per-step and cumulative dilution factor, plus final concentration, across a dilution series.',
  steps: [
    { name: 'Enter sample and diluent volume per step', text: 'The same ratio is assumed to be repeated at every step in the series.' },
    { name: 'Enter the number of dilution steps', text: 'How many times the dilution is repeated in sequence.' },
    { name: 'Enter the starting concentration', text: 'The cumulative dilution factor and final concentration solve instantly.' },
  ],
};

const formulas = [
  { expr: 'DF (per step) = (sample + diluent) / sample', note: 'dilution factor for one step of the series' },
  { expr: 'Cumulative DF = (DF per step)ⁿ', note: 'n = number of identical dilution steps in the series' },
  { expr: 'Final concentration = C0 / cumulative DF', note: 'C0 = starting (undiluted) concentration' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a standard 1:10 dilution series', tone: 'slate',
    given: 'A bacterial culture at C0 = 1×10⁸ CFU/mL is serially diluted using 1 mL sample + 9 mL diluent per step (a 1:10 dilution), repeated 5 times.',
    rows: [
      { label: 'Per-step DF:', value: '(1+9)/1 = 10' },
      { label: 'Cumulative DF:', value: '10⁵ = 100,000' },
      { label: 'Final concentration:', value: '1×10⁸ / 100,000 = 1×10³ CFU/mL', full: true },
    ],
    note: 'This exact 1:10 serial dilution scheme is the standard technique for bringing a dense bacterial culture down to a plate-countable range.',
  },
  {
    title: 'Worked example 2 — a 1:5 dilution series', tone: 'amber',
    given: 'A sample at C0 = 2×10⁶ cells/mL is diluted using 1 mL sample + 4 mL diluent per step (a 1:5 dilution), repeated 3 times.',
    rows: [
      { label: 'Per-step DF:', value: '(1+4)/1 = 5' },
      { label: 'Cumulative DF:', value: '5³ = 125' },
      { label: 'Final concentration:', value: '2×10⁶ / 125 = 1.6×10⁴ cells/mL', full: true },
    ],
    note: 'A smaller per-step dilution factor (5 instead of 10) reaches a much less extreme final dilution for the same number of steps — the choice of ratio depends on how much total dilution is actually needed.',
  },
];

const comparison = {
  heading: 'Cumulative dilution factor by step (1:10 series)',
  note: 'Starting from a 1:10 dilution repeated at every step.',
  headers: [{ label: 'Step' }, { label: 'Cumulative DF' }, { label: 'Concentration remaining' }],
  rows: [
    ['1', '10', '10%'],
    ['2', '100', '1%'],
    ['3 ★', '1,000', '0.1%'],
    ['5', '100,000', '0.001%'],
  ],
  highlightIndex: 2,
  footnote: '★ Each additional step multiplies the cumulative dilution factor by 10 again — this is exactly why serial dilution reaches enormous total dilutions using only small individual steps.',
};

const realWorld = [
  { emoji: '🧫', title: 'Bacterial and viral plate counting', body: 'Serial dilution is the standard first step before plating a sample for colony counting, bringing an overly dense culture down into the countable range (typically 30-300 colonies per plate).' },
  { emoji: '🔬', title: 'Preparing standard curves', body: 'Serial dilutions of a known-concentration standard are used to build calibration curves for assays like ELISA, where a range of known concentrations is needed to interpret an unknown sample\'s signal.' },
  { emoji: '💉', title: 'Vaccine and antibody titer testing', body: 'Measuring how far a sample (like patient serum) can be diluted while still showing a positive antibody response is a classic serial-dilution-based technique for determining antibody titer.' },
  { emoji: '🧪', title: 'Pharmacology dose-response studies', body: 'Serial dilutions of a drug compound are prepared to test a range of concentrations against cells or organisms, producing the dose-response curves used to determine effective drug concentrations.' },
];

const misconceptions = [
  { claim: '"Serial dilution and a single large dilution give different final results if you do the math right."', truth: 'A correctly performed serial dilution reaches mathematically the identical final concentration as one single dilution with the same overall dilution factor — the series is simply a practical way to reach that factor without needing enormous diluent volumes.' },
  { claim: '"Doubling the number of dilution steps doubles the total dilution factor."', truth: 'Dilution factors multiply, not add, across steps — doubling the number of identical 1:10 steps from 3 to 6 doesn\'t double the cumulative factor from 1,000 to 2,000, it squares it, from 1,000 to 1,000,000.' },
  { claim: '"Any pipetting error at one step only affects that one step\'s result."', truth: "Because each dilution step feeds directly into the next, an error at any single step propagates through every subsequent step — this is exactly why careful, consistent pipetting technique matters more in serial dilution than in a single dilution." },
  { claim: '"The dilution ratio must always be 1:10."', truth: '1:10 is common because it\'s easy to calculate and covers a wide range quickly, but serial dilutions can use any consistent ratio (1:2, 1:5, 1:3, etc.) depending on how finely spaced the resulting concentration series needs to be.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Microbiology</em></strong> — Chapter 9, "Microbial Growth" (free, peer-reviewed, includes standard plate count methodology). <a href="https://openstax.org/books/microbiology/pages/9-2-measuring-microbial-growth" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Madigan et al., <em>Brock Biology of Microorganisms</em></strong> — Culturing and counting microorganisms chapter.' },
  { html: '<strong>Tortora, Funke &amp; Case, <em>Microbiology: An Introduction</em></strong> — Standard plate count and dilution technique chapter.' },
];
const sourcesNote = 'DF = (sample+diluent)/sample per step; cumulative DF = (per-step DF)ⁿ. Assumes identical dilution ratio at every step. Results are rounded for display.';

const howToUse = [
  { title: 'Enter sample and diluent volume', body: 'The volumes used at each identical step of the series.' },
  { title: 'Enter number of steps', body: 'How many times the dilution is repeated in sequence.' },
  { title: 'Enter starting concentration', body: 'Cumulative dilution factor and final concentration solve automatically.' },
];

const related = [
  { href: '/tools/cfu-per-ml-calculator', emoji: '🔬', title: 'CFU per mL Calculator', desc: 'Colony forming units from plate count and dilution.' },
  { href: '/tools/dilution-calculator', emoji: '💧', title: 'Dilution Calculator', desc: 'C1V1=C2V2 — solve for any variable.' },
  { href: '/tools/bacterial-growth-rate-calculator', emoji: '⏱️', title: 'Bacterial Growth Rate Calculator', desc: 'k = ln(Nt/N0)/t — exponential growth rate constant.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="each dilution step multiplies, rather than adds to, the total dilution achieved so far — which is exactly why a handful of small, easy-to-pipette steps can reach a total dilution that would otherwise require an impossibly large volume of diluent."
  howIntro="A single dilution step's factor is simply the ratio of total final volume to sample volume added — a 1 mL sample topped up with 9 mL of diluent makes a 10-fold (1:10) dilution. Because a serial dilution uses the result of one step as the input to the next, the dilution factors compound multiplicatively rather than adding together: repeating a 1:10 dilution five times doesn't give a 50-fold dilution, it gives 10⁵ = 100,000-fold. This multiplicative compounding is precisely what makes serial dilution so powerful — it reaches enormous total dilution factors using only a series of small, manageable, and highly reproducible individual steps."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where serial dilution actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Sample volume (mL)</span>
        <input id="sample" type="number" step="any" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Diluent volume (mL)</span>
        <input id="diluent" type="number" step="any" value="9" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of steps</span>
        <input id="steps" type="number" step="1" min="1" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Starting concentration (per mL)</span>
        <input id="c0" type="number" step="any" value="1e8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Per-step DF</div><div id="r-perstep" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Cumulative DF</div><div id="r-cumulative" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Final concentration</div><div id="r-final" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="sd-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Mild vs. steep dilution series</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-mild" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Mild dilution (1:2 per step)</h3>
          <p class="mt-1 text-sm text-slate-600">Concentration drops gradually — many particles still remain after each step.</p>
        </div>
        <div>
          <div id="diag-steep" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Steep dilution (1:10 per step)</h3>
          <p class="mt-1 text-sm text-slate-600">Concentration drops sharply — far fewer particles remain after each step.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Serial dilution graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Concentration remaining per step (1:10 series)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-steps"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Cumulative dilution factor by ratio</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ratios"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('sd-err').textContent = '';
        el('r-perstep').textContent = '—'; el('r-cumulative').textContent = '—'; el('r-final').textContent = '—';
        const sample = parseFloat(el('sample').value), diluent = parseFloat(el('diluent').value);
        const steps = parseInt(el('steps').value, 10), c0 = parseFloat(el('c0').value);
        if (isNaN(sample) || isNaN(diluent) || isNaN(steps) || isNaN(c0)) return;
        if (sample <= 0 || diluent < 0 || steps < 1 || c0 < 0) { el('sd-err').textContent = 'Sample volume and steps must be positive; diluent and concentration cannot be negative.'; return; }
        const perStep = (sample + diluent) / sample;
        const cumulative = Math.pow(perStep, steps);
        const final = c0 / cumulative;
        el('r-perstep').textContent = fmt(perStep) + '×';
        el('r-cumulative').textContent = fmt(cumulative) + '×';
        el('r-final').textContent = fmt(final) + ' /mL';
      }
      ['sample', 'diluent', 'steps', 'c0'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const stepLabels = [], stepData = [];
        for (let s = 0; s <= 6; s++) { stepLabels.push(s); stepData.push(+(100 / Math.pow(10, s)).toPrecision(4)); }
        new Chart(el('chart-steps'), {
          type: 'line',
          data: { labels: stepLabels, datasets: [{ label: '% concentration remaining', data: stepData, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.2, pointRadius: 3 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Dilution step' } }, y: { type: 'logarithmic', title: { display: true, text: '% concentration remaining' } } }, plugins: { legend: { display: false } } }),
        });
        const ratioLabels = ['1:2', '1:5', '1:10'];
        const ratioData = [Math.pow(2, 5), Math.pow(5, 5), Math.pow(10, 5)];
        new Chart(el('chart-ratios'), {
          type: 'bar',
          data: { labels: ratioLabels, datasets: [{ label: 'Cumulative DF after 5 steps', data: ratioData, backgroundColor: ['#94a3b8', '#f59e0b', '#6366f1'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Cumulative dilution factor' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function dilutionScene(container, particleCounts) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const positions = [-2.4, -0.8, 0.8, 2.4];
        particleCounts.forEach((count, i) => {
          const tube = new THREE.Mesh(new THREE.CylinderGeometry(0.45, 0.45, 2.2, 16, 1, true), new THREE.MeshBasicMaterial({ color: 0x94a3b8, wireframe: true }));
          tube.position.set(positions[i], 0, 0);
          s.scene.add(tube);
          for (let j = 0; j < count; j++) {
            const dot = new THREE.Mesh(new THREE.SphereGeometry(0.09, 8, 6), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
            dot.position.set(positions[i] + (Math.random() - 0.5) * 0.7, (Math.random() - 0.5) * 1.8, (Math.random() - 0.5) * 0.7);
            s.scene.add(dot);
          }
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagMild = null, diagSteep = null;
      function initDiagMild() { const c = el('diag-mild'); if (!c) throw new Error('no container'); diagMild = dilutionScene(c, [30, 15, 8, 4]); }
      function initDiagSteep() { const c = el('diag-steep'); if (!c) throw new Error('no container'); diagSteep = dilutionScene(c, [30, 3, 1, 0]); }

      function boot() {
        try { update(); } catch (e) { console.error('[serial-dilution] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[serial-dilution] charts failed', e); }
        if (window.THREE) {
          try { initDiagMild(); } catch (e) { console.error('[serial-dilution] mild diagram failed', e); }
          try { initDiagSteep(); } catch (e) { console.error('[serial-dilution] steep diagram failed', e); }
        }
        mountResize([diagMild, diagSteep]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
