---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fence Calculator';
const description = 'Calculate the number of posts, rails, and panels needed for a fence run from total length and spacing. Plan materials and costs for your fencing project.';
const intro = 'Plan your fence project — posts, rails, and panels from the total fence length.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'How far apart should fence posts be?', a: 'Standard post spacing is 6-8 feet apart. Closer spacing (6 ft) is better for windy areas and heavier fence materials. Wider spacing (8 ft) works for lighter fences like split rail.' },
  { q: 'How deep should fence posts be set?', a: 'Posts should be set one-third of their length into the ground. For a 6 ft fence, use 8 ft posts with 2 ft below grade. The hole should be three times the post width.' },
  { q: 'Do I need concrete for fence posts?', a: 'Yes, concrete is recommended for most fence posts to prevent leaning and frost heave. Use quick-set concrete mix and ensure the post is perfectly plumb before the concrete sets.' },
  { q: 'How many rails does a fence need?', a: 'A standard 6 ft privacy fence uses 2-3 rails between posts. Two rails (top and bottom) are sufficient for most designs. A third rail in the middle adds strength for heavy gates or windy locations.' },
];
const howTo = {
  name: 'How to calculate fence posts, rails, and panels',
  steps: [
    { name: 'Measure the line', text: 'Measure the total length of the fence line in feet. Mark post locations every 6-8 ft.' },
    { name: 'Configure fence design', text: 'Choose post spacing and number of rails. Standard privacy fences use 8 ft spacing and 2 rails.' },
    { name: 'Add gates', text: 'Include gate posts and hardware in your material list. Gates need extra support for the hinge weight.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Fence length (ft)</span>
        <input id="length" type="number" step="any" placeholder="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Post spacing (ft)</span>
        <input id="spacing" type="number" step="any" placeholder="8" value="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Rails per section</span>
        <input id="rails" type="number" min="1" step="1" placeholder="2" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gates needed</span>
        <input id="gates" type="number" min="0" step="1" placeholder="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Posts needed</div>
        <div id="r-posts" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-detail" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Sections</div><div id="r-sections" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Rails needed</div><div id="r-rails" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Gate posts</div><div id="r-gates" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fence-title fence-desc">
      <title id="fence-title">Fence line diagram</title>
      <desc id="fence-desc">A fence line showing posts spaced evenly with rails between them, including a gate section</desc>
      <rect x="60" y="120" width="680" height="160" fill="#f0fdf4" stroke="#86efac" stroke-width="1" rx="4" />
      <g fill="#a3e635" opacity="0.3">
        <rect x="60" y="120" width="680" height="160" />
      </g>
      <g>
        <rect x="70" y="80" width="8" height="200" fill="#92400e" rx="2" />
        <rect x="240" y="80" width="8" height="200" fill="#92400e" rx="2" />
        <rect x="410" y="80" width="8" height="200" fill="#92400e" rx="2" />
        <rect x="580" y="80" width="8" height="200" fill="#92400e" rx="2" />
        <rect x="742" y="80" width="8" height="200" fill="#92400e" rx="2" />
      </g>
      <g fill="#d97706" opacity="0.6">
        <rect x="78" y="100" width="162" height="6" rx="2" />
        <rect x="78" y="180" width="162" height="6" rx="2" />
        <rect x="248" y="100" width="162" height="6" rx="2" />
        <rect x="248" y="180" width="162" height="6" rx="2" />
        <rect x="418" y="100" width="162" height="6" rx="2" />
        <rect x="418" y="180" width="162" height="6" rx="2" />
        <rect x="588" y="100" width="154" height="6" rx="2" />
        <rect x="588" y="180" width="154" height="6" rx="2" />
      </g>
      <text x="350" y="310" text-anchor="middle" font-size="13" fill="#64748b" font-family="system-ui,sans-serif">Posts support horizontal rails that hold the fence panels</text>
      <line x1="60" y1="60" x2="750" y2="60" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="405" y="50" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Total fence length</text>
      <line x1="74" y1="75" x2="74" y2="55" stroke="#94a3b8" stroke-width="1" />
      <line x1="746" y1="75" x2="746" y2="55" stroke="#94a3b8" stroke-width="1" />
      <line x1="74" y1="55" x2="746" y2="55" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="2 2" />
      <text x="155" y="290" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Section</text>
      <text x="408" y="290" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Section</text>
      <text x="670" y="290" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Gate</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Fence layout with posts, section rails, and a gate opening</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the fence calculator works</h2>
    <p class="mt-2 text-slate-600">
      The fence calculator helps you plan the materials for a new fence. Enter the total fence length, post spacing, number of rails per section, and how many gates you need. The tool calculates the number of posts, sections, rails, and gate posts required.
    </p>
    <p class="mt-3 text-slate-600">
      Fence posts are the vertical supports that carry the weight of the fence. They are set in concrete below the frost line. The standard spacing of 6-8 feet ensures the fence is stable and the rails do not sag. Each section between posts needs horizontal rails — typically 2 for a 4-ft fence and 3 for a 6-ft privacy fence.
    </p>
    <p class="mt-3 text-slate-600">
      Gate openings require wider posts (typically 4x4 or 6x6) and additional hardware. A standard single gate needs a 3-4 ft opening. Double gates for driveways need 8-12 ft openings. The calculator accounts for gate posts separately since they use heavier material.
    </p>
    <p class="mt-3 text-xs text-slate-400">Post depth and spacing guidance follows American Wood Council and AWC fence-post embedment rules of thumb (roughly one-third of post length set below grade).</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the line</h3>
        <p class="mt-1 text-sm text-slate-600">Measure the total length of the fence line in feet. Mark post locations every 6-8 ft.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Configure fence design</h3>
        <p class="mt-1 text-sm text-slate-600">Choose post spacing and number of rails. Standard privacy fences use 8 ft spacing and 2 rails.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Add gates</h3>
        <p class="mt-1 text-sm text-slate-600">Include gate posts and hardware in your material list. Gates need extra support for the hinge weight.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Number of sections</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Sections = ceil(Length / spacing)</span>. A 100 ft fence with 8 ft spacing: 100 / 8 = 12.5, round up to <strong>13 sections</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Number of posts</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Posts = sections + 1</span> for a straight run. With 13 sections: <strong>14 posts</strong>. Each gate adds 2 end posts.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Rails needed</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Rails = sections &times; rails per section</span>. 13 sections with 2 rails each: 13 &times; 2 = <strong>26 rails</strong>. Each rail is typically 8-12 ft long.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 150 ft backyard fence with 8 ft post spacing, 2 rails per section, and one single gate.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Sections:</span> <span class="text-slate-600">150 / 8 = 18.75, round to 19</span></div>
        <div><span class="font-medium text-slate-700">Regular posts:</span> <span class="text-slate-600">19 + 1 = 20</span></div>
        <div><span class="font-medium text-slate-700">Gate posts:</span> <span class="text-slate-600">1 gate &times; 2 = 2</span></div>
        <div><span class="font-medium text-slate-700">Total posts:</span> <span class="text-slate-600">20 + 2 = <strong>22 posts</strong></span></div>
        <div><span class="font-medium text-slate-700">Rails:</span> <span class="text-slate-600">19 &times; 2 = <strong>38 rails</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the fence calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Privacy fence</h3>
        <p class="mt-1 text-sm text-slate-600">A 6-ft tall privacy fence uses close-spaced pickets or panels between posts. The calculator gives you the post and rail count, then you add the picket or panel material separately.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌳</span>
        <h3 class="mt-2 font-semibold text-slate-900">Property boundary</h3>
        <p class="mt-1 text-sm text-slate-600">Marking property lines with a fence requires precise post placement. Use the calculator to plan the entire run, then verify property corner markers before digging.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🐕</span>
        <h3 class="mt-2 font-semibold text-slate-900">Pet enclosure</h3>
        <p class="mt-1 text-sm text-slate-600">A dog run or yard enclosure needs shorter posts and lighter materials. Adjust the post spacing to 6 ft for a stronger, climb-resistant fence.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌺</span>
        <h3 class="mt-2 font-semibold text-slate-900">Garden fence</h3>
        <p class="mt-1 text-sm text-slate-600">Decorative garden fencing uses closer post spacing (4-5 ft) for a lighter look. Use fewer rails and lighter pickets for an ornamental rather than security-focused fence.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for building a fence</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Call before you dig</h3>
        <p class="mt-1 text-sm text-slate-600">Always call your local utility locating service before digging post holes. They will mark underground gas, electric, water, and telecom lines for free. Hitting a utility line is dangerous and expensive, so this step is essential before any digging starts.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Set corner posts first</h3>
        <p class="mt-1 text-sm text-slate-600">Install corner and end posts first, then string a line between them. Set the intermediate posts along this line. This ensures the fence is straight and the posts are properly aligned. Use a level to check plumb in both directions.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use gravel for drainage</h3>
        <p class="mt-1 text-sm text-slate-600">Add 4-6 inches of gravel at the bottom of each post hole before setting the post. This improves drainage around the post base, preventing wood rot in wooden posts and reducing frost heave in cold climates.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A full backyard perimeter fence is the calculator's most common use. A 240 ft run at 8 ft post spacing, 2 rails per section, and one single gate breaks into 30 sections, needing 31 regular posts plus 2 gate posts for 33 posts total, and 60 rails. At roughly $25-35 per treated post and $10-15 per rail before pickets, that post-and-rail total alone often lands in the $1,000-1,500 range before any panel or picket material is added.
    </p>
    <p class="mt-3 text-slate-600">
      A small dog run scales the same formula down. A 60 ft enclosure at the tighter 6 ft spacing recommended for climb-resistant fencing, 2 rails per section, one gate, breaks into 10 sections, 11 regular posts plus 2 gate posts for 13 posts total, and 20 rails. The tighter spacing versus a standard 8 ft layout adds roughly 30% more posts for the same length, which is the tradeoff for a sturdier, harder-to-breach fence.
    </p>
    <p class="mt-3 text-slate-600">
      A driveway frontage fence with double gates shows how heavier designs multiply materials fast. A 300 ft run at 8 ft spacing with 3 rails per section (typical for a taller privacy fence) and 2 gate openings breaks into 38 sections, 39 regular posts plus 4 gate posts for 43 posts total, and 114 rails — nearly double the rail count of the backyard example even though the run is only 25% longer, because the extra rail per section compounds across every one of the 38 sections.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Posts = fence length divided by spacing." <strong class="text-slate-900">That undercounts by one.</strong> A straight fence run always needs one more post than the number of sections, since a post sits at both ends of every section. A 100 ft fence at 8 ft spacing has 13 sections but 14 posts — forgetting the "+1" is one of the most common material-list errors on DIY fence projects.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any post will do as long as it's set in concrete." <strong class="text-slate-900">Gate posts need to be heavier.</strong> A regular line post only carries the weight of adjoining panels, but a gate post cantilevers the full weight of a swinging gate off one side. Builders typically upsize from a 4x4 line post to a 6x6 gate post, and set it deeper and in a larger concrete footing to resist the leverage from repeated opening and closing.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/perimeter-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Perimeter Calculator</a>
      <a href="/tools/concrete-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Calculator</a>
      <a href="/tools/deck-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Deck Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const length = parseFloat(el('length').value);
      const spacing = parseFloat(el('spacing').value);
      const railsPer = parseInt(el('rails').value, 10) || 2;
      const gates = parseInt(el('gates').value, 10) || 0;
      if (!length || !spacing || length <= 0 || spacing <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const sections = Math.ceil(length / spacing);
      const regPosts = sections + 1;
      const gatePosts = gates * 2;
      const totalPosts = regPosts + gatePosts;
      const totalRails = sections * railsPer;
      el('r-posts').textContent = totalPosts.toLocaleString() + ' posts';
      el('r-detail').textContent = regPosts + ' regular + ' + gatePosts + ' gate';
      el('r-sections').textContent = sections.toLocaleString();
      el('r-rails').textContent = totalRails.toLocaleString() + ' rails';
      el('r-gates').textContent = gates > 0 ? gatePosts + ' posts' : 'None';
      el('results').classList.remove('hidden');
    }

    ['length', 'spacing', 'rails', 'gates'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
  </script>
</ToolLayout>
