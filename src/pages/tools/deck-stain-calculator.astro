---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Deck Stain Calculator';
const description = 'Estimate how many gallons of deck stain or sealant you need from the deck square footage, railing length and number of coats.';
const intro = 'Estimate the gallons of deck stain or sealant you need, from the deck size, railing length, and number of coats.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much deck stain do I need?', a: 'Most deck stains cover 150 to 300 square feet per gallon per coat, depending on the product and how porous the wood is. Rough, weathered, or new wood soaks up more stain than smooth, previously sealed wood.' },
  { q: 'Do I need to add extra for railings and balusters?', a: 'Yes. Railings, balusters, and stair components have far more surface area per square foot of floor space than a flat deck board, so this calculator adds a percentage on top of the floor area to account for them.' },
  { q: 'How many coats does a deck need?', a: 'New or bare wood often needs two coats for full protection and color, while a routine re-coat of an already-sealed deck usually needs just one. Always follow the product label, since coverage and coat count vary by formula.' },
  { q: 'Why does wood condition change coverage?', a: 'Rough-sawn, weathered, or previously unsealed wood is more porous and drinks up more stain per square foot than smooth, dense, or already-sealed wood, so the same gallon covers less area on an older or rougher deck.' },
];
const howTo = {
  name: 'How to calculate deck stain needed',
  steps: [
    { name: 'Measure the deck', text: 'Floor area in square feet and total railing length in linear feet.' },
    { name: 'Set coats and condition', text: 'Choose the number of coats and how porous the wood is.' },
    { name: 'Read the gallons', text: 'Get the total and round up to the next full or partial can.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Deck floor area (sq ft)</span>
        <input id="area" type="number" step="any" placeholder="300" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Railing length (ft)</span>
        <input id="rail" type="number" step="any" placeholder="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Coats</span>
        <input id="coats" type="number" step="1" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Wood condition</span>
        <select id="cond" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="300">Smooth / previously sealed (300 ft²/gal)</option>
          <option value="200" selected>Typical weathered wood (200 ft²/gal)</option>
          <option value="150">Rough-sawn / very porous (150 ft²/gal)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Stain needed</div>
        <div id="r-gal" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Effective area</div><div id="r-eff" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Per coat</div><div id="r-percoat" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="280" viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ds-title ds-desc">
      <title id="ds-title">Deck with railing to be stained</title>
      <desc id="ds-desc">A deck floor with railing and balusters, showing the extra surface area railings add</desc>
      <rect x="90" y="140" width="300" height="90" fill="#fde68a" stroke="#d97706" stroke-width="2" />
      <g stroke="#92400e" stroke-width="1"><line x1="90" y1="160" x2="390" y2="160"/><line x1="90" y1="180" x2="390" y2="180"/><line x1="90" y1="200" x2="390" y2="200"/><line x1="90" y1="220" x2="390" y2="220"/></g>
      <g stroke="#d97706" stroke-width="2"><line x1="100" y1="140" x2="100" y2="90"/><line x1="140" y1="140" x2="140" y2="90"/><line x1="180" y1="140" x2="180" y2="90"/><line x1="220" y1="140" x2="220" y2="90"/><line x1="260" y1="140" x2="260" y2="90"/><line x1="300" y1="140" x2="300" y2="90"/><line x1="340" y1="140" x2="340" y2="90"/><line x1="380" y1="140" x2="380" y2="90"/></g>
      <line x1="90" y1="90" x2="390" y2="90" stroke="#d97706" stroke-width="3" />
      <text x="240" y="252" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">floor area + railing surface</text>
      <rect x="440" y="90" width="290" height="120" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="460" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Stain estimate</text>
      <text x="460" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">effective = floor + rail&times;3 ft&sup2;/ft</text>
      <text x="460" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">gallons = effective &times; coats &divide; coverage</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Railings add far more surface area per linear foot than flat decking, so they are counted separately.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the deck stain calculator works</h2>
    <p class="mt-2 text-slate-600">
      Deck stain is applied to a surface area, but a deck is more than its flat floor. Railings, balusters, and stair parts have edges, faces, and gaps that add up to far more surface area than their footprint suggests. The calculator estimates railing surface as about 3 square feet of stainable surface per linear foot of railing, a practical allowance for typical baluster spacing, and adds that to the floor area.
    </p>
    <p class="mt-3 text-slate-600">
      That combined "effective area" is then multiplied by the number of coats, since each coat uses roughly the same amount of stain. Dividing by the coverage rate for your wood's condition gives the gallons needed. Smooth or previously sealed wood covers more per gallon, around 300 square feet, while rough-sawn or very porous new wood soaks up more, down around 150 square feet per gallon.
    </p>
    <p class="mt-3 text-slate-600">
      These are typical manufacturer coverage figures; always check your specific product's label, since formulas vary. New or bare wood usually needs two coats for full protection, while a routine maintenance re-coat over an already-sealed deck often needs only one.
    </p>
    <p class="mt-3 text-xs text-slate-400">Coverage rates of roughly 150-300 ft² per gallon and the recommendation to follow the product label reflect typical manufacturer specifications published by major deck-stain brands for semi-transparent and solid-color exterior wood stains.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the deck</h3>
        <p class="mt-1 text-sm text-slate-600">Floor area in square feet and total railing length in linear feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set coats and condition</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the number of coats and how porous the wood is.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the gallons</h3>
        <p class="mt-1 text-sm text-slate-600">Get the total and round up to the next full or partial can.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Effective area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= floor + rail &times; 3</span>. 300 ft&sup2; floor, 40 ft rail: 300 + 40&times;3 = <strong>420 ft&sup2;</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Gallons per coat</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= effective &divide; coverage</span>. At 200 ft&sup2;/gal: 420&frasl;200 = <strong>2.1 gal per coat</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Total for two coats</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= 2.1 &times; 2</span> = <strong>4.2 gallons</strong> — buy five 1-gallon cans or one 5-gallon pail.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A small 150 ft&sup2; deck with 20 ft of rail, rough new lumber, 2 coats.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Effective area:</span> <span class="text-slate-600">150 + 20&times;3 = 210 ft²</span></div>
        <div><span class="font-medium text-slate-700">Per coat:</span> <span class="text-slate-600">210&frasl;150 = 1.4 gal</span></div>
        <div><span class="font-medium text-slate-700">Two coats:</span> <span class="text-slate-600">1.4 &times; 2 = <strong>2.8 gallons</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Getting a good finish</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧹</span>
        <h3 class="mt-2 font-semibold text-slate-900">Clean and let it dry</h3>
        <p class="mt-1 text-sm text-slate-600">Wash away dirt, mildew, and old finish, and let the wood dry fully before staining. Stain applied to damp wood traps moisture and fails early.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌤️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Pick the right weather</h3>
        <p class="mt-1 text-sm text-slate-600">Stain in mild, dry weather out of direct sun. Extreme heat dries the surface too fast, and moisture or freezing temperatures can ruin the cure.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🪣</span>
        <h3 class="mt-2 font-semibold text-slate-900">Buy from the same batch</h3>
        <p class="mt-1 text-sm text-slate-600">Stain color can shift slightly between production runs. Buy all your cans together and box them — mix them in one bucket for a large deck — so the color stays consistent.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🔁</span>
        <h3 class="mt-2 font-semibold text-slate-900">Plan for maintenance</h3>
        <p class="mt-1 text-sm text-slate-600">Most deck stains need reapplying every one to three years depending on sun and foot traffic. Keep a partial can on hand or note the product for an easy touch-up.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A routine annual maintenance re-coat is one of the most common uses for this calculator. A large 500 sq ft deck with 60 ft of railing, already sealed and smooth (300 ft²/gal), needs just one coat: effective area is 500 + 60&times;3 = 680 ft², so 680&frasl;300 = <strong>2.27 gallons</strong> — call it three 1-gallon cans, since a single coat on well-maintained wood goes a long way.
    </p>
    <p class="mt-3 text-slate-600">
      A brand-new, rough-sawn deck sits at the other extreme. A small 120 sq ft deck with 15 ft of rail, unfinished and porous (150 ft²/gal), needs two coats: effective area is 120 + 15&times;3 = 165 ft², so 165&frasl;150 = 1.1 gallons per coat, and 1.1 &times; 2 = <strong>2.2 gallons</strong> total — nearly the same total volume as the much larger recoated deck above, because raw wood absorbs so much more stain per square foot.
    </p>
    <p class="mt-3 text-slate-600">
      A mid-size deck getting its first refinish after a few seasons of weathering lands in between. A 350 sq ft deck with 45 ft of rail, typical weathered wood (200 ft²/gal), two coats: effective area is 350 + 45&times;3 = 485 ft², so 485&frasl;200 = 2.425 gallons per coat, and 2.425 &times; 2 = <strong>4.85 gallons</strong> — worth rounding up to a 5-gallon pail plus a little extra for touch-ups rather than buying individual cans.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"I only need to cover the floor boards I can see." <strong class="text-slate-900">Railings eat a lot of stain too.</strong> Balusters, top and bottom rails, and posts have far more combined surface area per linear foot than a flat deck board — this calculator adds roughly 3 square feet of stainable surface per linear foot of railing, and skipping that allowance is a common reason people run out mid-project.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"More coats always means better, longer-lasting protection." <strong class="text-slate-900">Not past the label's recommendation.</strong> Most stains are formulated to penetrate and cure within a specific number of coats; applying extra coats beyond what the product calls for can leave a sticky, uncured film on the surface that peels rather than weathers evenly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/deck-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Deck Calculator</a>
      <a href="/tools/paint-coverage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Paint Coverage Calculator</a>
      <a href="/tools/fence-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fence Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const area = parseFloat(el('area').value);
      let rail = parseFloat(el('rail').value); if (!rail || rail < 0) rail = 0;
      let coats = parseInt(el('coats').value, 10); if (!coats || coats < 1) coats = 1;
      const coverage = parseFloat(el('cond').value);
      if (!area || area <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const eff = area + rail * 3;
      const perCoat = eff / coverage;
      const total = perCoat * coats;

      el('r-gal').textContent = total.toFixed(1) + ' gallons';
      el('r-note').textContent = coats + ' coat' + (coats > 1 ? 's' : '') + ' over ' + eff.toFixed(0) + ' ft²';
      el('r-eff').textContent = eff.toFixed(0) + ' ft²';
      el('r-percoat').textContent = perCoat.toFixed(2) + ' gal';
      el('results').classList.remove('hidden');
    }

    ['area', 'rail', 'coats'].forEach((id) => el(id).addEventListener('input', update));
    el('cond').addEventListener('change', update);
  </script>
</ToolLayout>
