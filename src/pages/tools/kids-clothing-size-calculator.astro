---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Kids\' Clothing Size by Age Calculator';
const description = 'Find a child\'s clothing size from age, with matching height and weight ranges. Enter your child\'s age to get an accurate US size recommendation instantly.';
const intro = 'Convert a child\'s age into a general US clothing size, with typical height and weight ranges.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Is age or height a better way to size kids\' clothing?', a: 'Height is more reliable, since children grow at different rates and two kids of the same age can differ by several inches. Age-based sizing is a convenient starting point, but check the height and weight range shown against your child\'s actual measurements when possible.' },
  { q: 'What does "2T" mean versus just "2"?', a: 'The "T" stands for toddler and indicates a cut designed for a child still in diapers, with a roomier fit through the middle, while a plain size "2" (rare) or sizes from about 4 onward without a T are cut for an older child\'s proportions.' },
  { q: 'Why do sizes sometimes skip or overlap, like 18-24 months and 2T?', a: 'Growth is not perfectly linear, and different brands draw the size boundaries slightly differently, so overlapping ranges like these exist to smooth the transition between infant/toddler sizing and youth sizing.' },
  { q: 'Should I size up for a growing child?', a: 'Many parents deliberately buy one size up, especially for outerwear and pants, to extend how long an item stays wearable — this calculator shows the standard-fit range, but sizing up a step is a common practical choice.' },
];
const howTo = {
  name: 'How to find a child\'s clothing size',
  steps: [
    { name: 'Enter the child\'s age', text: 'Type the age in years (decimals allowed for months, e.g. 1.5 for 18 months).' },
    { name: 'Read the size', text: 'A general US clothing size appears based on typical growth charts for that age.' },
    { name: 'Check height and weight', text: 'Compare the shown height/weight range against the child\'s actual measurements for a more accurate fit.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Child's age (years, decimals allowed)</span>
      <input id="age" type="number" step="any" placeholder="e.g. 1.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Suggested size</div>
        <div id="r-size" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Typical height</div><div id="r-height" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Typical weight</div><div id="r-weight" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="kcs-title kcs-desc">
      <title id="kcs-title">Growth chart curve rising with age</title>
      <desc id="kcs-desc">A simple rising curve showing how clothing size increases with a child's age, flattening in later years</desc>
      <path d="M80 170 Q250 150 400 100 Q550 60 720 40" fill="none" stroke="#c026d3" stroke-width="4" stroke-linecap="round" />
      <text x="80" y="190" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Newborn</text>
      <text x="650" y="190" font-size="13" fill="#475569" font-family="system-ui,sans-serif">12 years</text>
      <text x="400" y="30" text-anchor="middle" font-size="13" fill="#94a3b8" font-family="system-ui,sans-serif">Size increases with age, but growth rate varies by child</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Clothing size generally tracks age, though height is the more precise measure</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How kids' clothing sizing works</h2>
    <p class="mt-2 text-slate-600">
      Children's clothing sizes are labeled by expected age up through about 24 months (0-3M, 3-6M, and so on), then shift to toddler sizing (2T-4T) and youth sizing (size 5 and up), roughly matching typical growth charts published by pediatric health organizations. Each size band corresponds to a general height and weight range, since manufacturers cut garments to fit a child's expected proportions at that stage, not just a single number.
    </p>
    <p class="mt-3 text-slate-600">
      Because children's growth rates vary significantly, age is only an approximation — a tall-for-their-age 2-year-old may already fit a 3T, while a smaller child of the same age might still be in 18-24 month sizing. This calculator shows the general age-based size along with the typical height and weight range it corresponds to, so you can double-check against your child's actual measurements.
    </p>
    <p class="mt-3 text-xs text-slate-400">Size, height, and weight bands follow the general US children's apparel sizing convention used across most major retailers; individual brands can run slightly larger or smaller.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A parent is shopping for a 3-year-old child.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Age:</span> <span class="text-slate-600">3 years</span></div>
        <div><span class="font-medium text-slate-700">Suggested size:</span> <span class="text-slate-600"><strong>3T</strong></span></div>
        <div><span class="font-medium text-slate-700">Typical height:</span> <span class="text-slate-600">35-38 in</span></div>
        <div><span class="font-medium text-slate-700">Typical weight:</span> <span class="text-slate-600">30-33 lb</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Buying clothes as a gift for someone else's child is the classic use case, since the giver usually only knows the child's age, not their exact height and weight — the age-to-size conversion turns that limited information into a workable starting size, with the height/weight range as a sanity check against what the parents have mentioned about how tall the child is for their age.
    </p>
    <p class="mt-3 text-slate-600">
      Seasonal buy-ahead shopping (buying next winter's coat during a summer sale) also relies heavily on this kind of projection, since parents are estimating a size for a child who will have grown several months by the time the item is actually worn — many deliberately size up a full step for this reason.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A 2-year-old should always wear size 2." <strong class="text-slate-900">Not necessarily.</strong> Toddler sizing (2T-4T) is built around expected height and weight for that age, but individual growth varies enough that many 2-year-olds fit better in 18-24 month or 3T clothing depending on their actual size.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All brands' kids' sizes match exactly." <strong class="text-slate-900">They don't.</strong> Sizing runs noticeably large or small between budget and premium children's brands, more so than in adult clothing, since there is less standardization pressure in kidswear.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/clothing-size-converter/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
      <a href="/tools/shoe-size-converter/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Shoe Size Converter</a>
      <a href="/tools/sock-size-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Sock Size Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    // [ageMonthsMax, size, height range, weight range]
    const table = [
      [3, 'NB / 0-3M', 'up to 24 in', 'up to 12.5 lb'],
      [6, '3-6M', '24-26 in', '12.5-17 lb'],
      [9, '6-9M', '26-28 in', '17-20 lb'],
      [12, '9-12M', '28-29 in', '20-22 lb'],
      [18, '12-18M', '29-32 in', '22-27 lb'],
      [24, '18-24M / 2T', '32-34 in', '27-30 lb'],
      [36, '3T', '35-38 in', '30-33 lb'],
      [48, '4T', '38-41 in', '33-36 lb'],
      [60, '5', '42-44 in', '38-42 lb'],
      [72, '6', '45-47 in', '43-48 lb'],
      [84, '7', '48-49 in', '50-54 lb'],
      [96, '8', '50-52 in', '55-60 lb'],
      [120, '10', '54-56 in', '65-75 lb'],
      [144, '12', '58-60 in', '85-95 lb'],
    ];

    function update() {
      const years = parseFloat(el('age').value);
      if (years === undefined || isNaN(years) || years < 0) { el('results').classList.add('hidden'); return; }
      const months = years * 12;
      const row = table.find((r) => months <= r[0]) || table[table.length - 1];
      el('r-size').textContent = row[1];
      el('r-height').textContent = row[2];
      el('r-weight').textContent = row[3];
      el('results').classList.remove('hidden');
    }

    el('age').addEventListener('input', update);
  </script>
</ToolLayout>
