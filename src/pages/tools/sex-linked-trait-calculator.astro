---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Sex-Linked Trait Punnett Calculator';
const description = 'Sex-linked trait calculator with a live 3D X/Y chromosome diagram and charts. Build an X-linked Punnett square from mother and father genotypes, with worked examples for carrier mothers and color blindness.';
const intro = 'Enter parent genotypes for an X-linked gene to build the full Punnett square, revealing why sex-linked traits affect sons and daughters so differently. Two 3D diagrams compare X and Y chromosomes carrying an allele, and charts break down the resulting offspring by sex and phenotype.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a sex-linked trait?', a: 'A sex-linked trait is one controlled by a gene located on a sex chromosome (usually the X chromosome), causing the trait to be inherited differently in males and females due to their different chromosome combinations (XX vs XY).' },
  { q: 'Why are X-linked recessive conditions more common in males?', a: 'Males have only one X chromosome (XY), so a single copy of a recessive X-linked allele is enough to show the trait. Females (XX) need two copies (one on each X) to show the same recessive trait, making them far more likely to be unaffected carriers instead.' },
  { q: 'Can a father pass an X-linked trait to his son?', a: 'No — a father always passes his Y chromosome to sons and his X chromosome to daughters. This means an X-linked trait from the father can only appear in his daughters (as one of their two X chromosomes), never directly in his sons.' },
  { q: 'What is a carrier mother?', a: 'A carrier mother is heterozygous for an X-linked recessive allele (one normal X, one affected X) — she does not show the trait herself, but can pass the affected X to her children, with sons who receive it being affected.' },
  { q: 'What is a classic example of an X-linked recessive trait?', a: 'Red-green color blindness is a classic human example — it is far more common in men than women because it only takes one copy of the recessive allele on a man\'s single X chromosome to cause it.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Sex-Linked Trait Punnett Calculator',
  description: 'Build an X-linked Punnett square from mother and father genotypes to predict offspring by sex and phenotype.',
  steps: [
    { name: 'Enter the mother\'s genotype', text: 'Provide her two X-chromosome alleles, e.g. X^A X^a for a carrier.' },
    { name: 'Enter the father\'s genotype', text: 'Provide his single X allele and Y, e.g. X^A Y for an unaffected father.' },
    { name: 'Read the offspring breakdown', text: 'Sons and daughters are shown separately, since their inheritance patterns differ.' },
  ],
};

const formulas = [
  { expr: 'Sons receive: X from mother, Y from father', note: 'a son\'s X-linked phenotype depends entirely on his mother\'s alleles' },
  { expr: 'Daughters receive: one X from each parent', note: 'a daughter needs the recessive allele from BOTH parents to show a recessive trait' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a carrier mother and unaffected father (color blindness)', tone: 'slate',
    given: 'Mother is a carrier (X^A X^a), father is unaffected (X^A Y), for X-linked recessive color blindness (a = colorblind allele).',
    rows: [
      { label: "Sons' genotypes:", value: 'X^A Y (unaffected) or X^a Y (colorblind) — 50% affected' },
      { label: "Daughters' genotypes:", value: 'X^A X^A (unaffected) or X^A X^a (carrier) — 0% affected, 50% carriers', full: true },
    ],
    note: 'This is exactly why X-linked recessive conditions like color blindness show up far more often in sons than daughters when the mother is a carrier — daughters need a second copy from the father to actually be affected.',
  },
  {
    title: 'Worked example 2 — an affected father and unaffected (non-carrier) mother', tone: 'amber',
    given: 'Father is affected (X^a Y), mother is homozygous unaffected (X^A X^A).',
    rows: [
      { label: "Sons' genotypes:", value: 'All X^A Y (unaffected) — sons get Y from father, not his X' },
      { label: "Daughters' genotypes:", value: 'All X^A X^a (carriers, unaffected) — every daughter gets the affected X from her father', full: true },
    ],
    note: "This shows the classic pattern where an affected father passes his X-linked allele to ALL of his daughters (making them carriers) but NONE of his sons, since sons only receive his Y chromosome.",
  },
];

const comparison = {
  heading: 'X-linked recessive inheritance patterns',
  note: 'The same allele produces very different outcomes in sons versus daughters, depending on which parent carries it.',
  headers: [{ label: 'Cross' }, { label: 'Affected sons' }, { label: 'Affected daughters' }],
  rows: [
    ['Carrier mother × unaffected father ★', '50%', '0% (50% carriers)'],
    ['Affected mother × unaffected father', '100%', '0% (100% carriers)'],
    ['Unaffected mother × affected father', '0%', '0% (100% carriers)'],
    ['Carrier mother × affected father', '50%', '50%'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 1). Notice daughters are never affected unless the father himself is affected — a hallmark signature of X-linked recessive inheritance.',
};

const realWorld = [
  { emoji: '👁️', title: 'Red-green color blindness', body: 'The most common human X-linked recessive trait, affecting roughly 8% of men but under 1% of women — a direct real-world consequence of the inheritance pattern this calculator models.' },
  { emoji: '🩸', title: 'Hemophilia', body: 'Hemophilia A and B are X-linked recessive blood clotting disorders, historically significant in European royal family pedigrees where carrier queens passed the condition to affected sons.' },
  { emoji: '🧬', title: 'Genetic counseling for X-linked conditions', body: 'Genetic counselors use exactly this cross logic to calculate the probability that a woman\'s sons or daughters will be affected or carriers for a known X-linked condition in her family.' },
  { emoji: '🔬', title: "Morgan's fruit fly experiments", body: 'Thomas Hunt Morgan\'s discovery of X-linked inheritance in fruit fly eye color was the first direct experimental evidence that genes are physically located on chromosomes.' },
];

const misconceptions = [
  { claim: '"A father can pass an X-linked trait directly to his sons."', truth: 'A father always gives his Y chromosome to sons and his X chromosome to daughters — so a father\'s X-linked trait can only ever be passed to daughters, never directly to sons.' },
  { claim: '"X-linked recessive traits affect men and women equally."', truth: 'They affect men far more often, because a single X chromosome means one recessive allele copy is enough to show the trait in men — women need two copies (one on each X), making them much more likely to be unaffected carriers instead.' },
  { claim: '"A carrier mother will show mild symptoms of the condition."', truth: 'A true carrier (heterozygous) typically shows no symptoms at all for a fully recessive X-linked trait, since her one normal X allele\'s function is usually sufficient — though some conditions can show partial expression due to X-inactivation patterns.' },
  { claim: '"If a son is unaffected, his mother cannot be a carrier."', truth: 'A carrier mother has only a 50% chance of passing the affected X to each son — an unaffected son does not rule out his mother being a carrier, since he may simply have inherited her normal X instead.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 15, "The Chromosomal Basis of Inheritance" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/15-2-sex-linkage" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 4, X-Linked Inheritance.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 15, The Chromosomal Basis of Inheritance.' },
];
const sourcesNote = 'Assumes a simple X-linked recessive gene and standard XX/XY sex determination. Results are exact probability ratios.';

const howToUse = [
  { title: "Enter the mother's genotype", body: 'Provide her two X-allele genotype, e.g. X^A X^a for a carrier.' },
  { title: "Enter the father's genotype", body: 'Provide his single X allele (he only has one X plus a Y).' },
  { title: 'Read sons and daughters separately', body: 'Their inheritance patterns differ fundamentally, so results are broken out by sex.' },
];

const related = [
  { href: '/tools/punnett-square-calculator', emoji: '🧬', title: 'Punnett Square Calculator', desc: 'Monohybrid cross — the classic 3:1 phenotype ratio.' },
  { href: '/tools/hardy-weinberg-calculator', emoji: '🧬', title: 'Hardy-Weinberg Allele Frequency Calculator', desc: 'p²+2pq+q²=1 — allele and genotype frequencies.' },
  { href: '/tools/recombination-frequency-calculator', emoji: '🔗', title: 'Recombination Frequency Calculator', desc: 'Detect gene linkage from crossover frequency.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="because males have only one X chromosome, an X-linked recessive allele has nowhere to hide in a son — he shows the trait immediately — while a daughter's second X chromosome can mask a single recessive copy, making her a symptomless carrier instead."
  howIntro="Standard XX/XY sex determination means sons always receive their single X chromosome from their mother (and a Y from their father), while daughters receive one X from each parent. For an X-linked gene, this asymmetry means a son's phenotype depends entirely on which single X allele he happened to inherit from his mother, while a daughter needs the recessive allele from BOTH parents to actually show a recessive trait — precisely why sex-linked conditions show such different inheritance patterns between sons and daughters."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where sex-linked inheritance actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mother's genotype (X alleles, e.g. Aa)</span>
        <input id="mom" type="text" maxlength="2" value="Aa" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Father's genotype (single X allele, e.g. A)</span>
        <input id="dad" type="text" maxlength="1" value="A" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Sons</div><div id="r-sons" class="mt-1 text-base font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Daughters</div><div id="r-daughters" class="mt-1 text-base font-bold text-slate-800">—</div></div>
    </div>
    <p id="sex-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">X and Y chromosomes</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-xx" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A carrier mother's XX pair</h3>
          <p class="mt-1 text-sm text-slate-600">One X carries the normal allele (indigo), the other carries the recessive allele (amber) — she is unaffected but can pass either one on.</p>
        </div>
        <div>
          <div id="diag-xy" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. A father's XY pair</h3>
          <p class="mt-1 text-sm text-slate-600">A single X chromosome and a much smaller Y — sons get the Y (and his phenotype depends only on mom's X), daughters get his X.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Sex-linked inheritance graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Affected sons vs daughters (carrier mother × unaffected father)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-affected"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Color blindness prevalence — men vs women</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-prevalence"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function update() {
        el('sex-err').textContent = '';
        el('r-sons').textContent = '—'; el('r-daughters').textContent = '—';
        const mom = (el('mom').value || '').trim();
        const dad = (el('dad').value || '').trim();
        if (mom.length !== 2 || dad.length !== 1) { el('sex-err').textContent = "Mother needs 2 alleles (e.g. Aa), father needs 1 (e.g. A)."; return; }
        const momAlleles = [mom[0], mom[1]];
        // sons: X from mom (either allele, 50/50), Y from dad
        const sonGenos = momAlleles.map((a) => a + 'Y');
        // daughters: X from mom (either), X from dad (fixed)
        const daughterGenos = momAlleles.map((a) => [a, dad].sort((x, y) => (x === x.toUpperCase() ? -1 : 1) - (y === y.toUpperCase() ? -1 : 1)).join(''));
        el('r-sons').textContent = sonGenos.join(' or ') + ' (50% each)';
        el('r-daughters').textContent = daughterGenos.join(' or ') + ' (50% each)';
      }
      ['mom', 'dad'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.affected = new Chart(el('chart-affected'), {
          type: 'bar',
          data: { labels: ['Sons', 'Daughters'], datasets: [
            { label: 'Affected', data: [50, 0], backgroundColor: '#ef4444' },
            { label: 'Unaffected/Carrier', data: [50, 100], backgroundColor: '#6366f1' },
          ] },
          options: Object.assign({}, base, { scales: { x: { stacked: true }, y: { stacked: true, title: { display: true, text: 'Percent' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.prevalence = new Chart(el('chart-prevalence'), {
          type: 'bar',
          data: { labels: ['Men', 'Women'], datasets: [{ label: 'Color blindness prevalence (%)', data: [8, 0.5], backgroundColor: ['#6366f1', '#f59e0b'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Prevalence (%)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function xxScene(container) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        function xChrom(x, color) {
          const g = new THREE.Group();
          const bar1 = new THREE.Mesh(new THREE.BoxGeometry(0.25, 2.2, 0.25), new THREE.MeshStandardMaterial({ color, roughness: 0.5 }));
          bar1.rotation.z = Math.PI / 4; g.add(bar1);
          const bar2 = new THREE.Mesh(new THREE.BoxGeometry(0.25, 2.2, 0.25), new THREE.MeshStandardMaterial({ color, roughness: 0.5 }));
          bar2.rotation.z = -Math.PI / 4; g.add(bar2);
          g.position.set(x, 0, 0);
          s.scene.add(g);
        }
        xChrom(-1.2, 0x6366f1);
        xChrom(1.2, 0xf59e0b);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function xyScene(container) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const g1 = new THREE.Group();
        const b1 = new THREE.Mesh(new THREE.BoxGeometry(0.25, 2.2, 0.25), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.5 }));
        b1.rotation.z = Math.PI / 4; g1.add(b1);
        const b2 = new THREE.Mesh(new THREE.BoxGeometry(0.25, 2.2, 0.25), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.5 }));
        b2.rotation.z = -Math.PI / 4; g1.add(b2);
        g1.position.set(-1.2, 0, 0);
        s.scene.add(g1);
        const g2 = new THREE.Group();
        const b3 = new THREE.Mesh(new THREE.BoxGeometry(0.22, 1.1, 0.22), new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.5 }));
        b3.position.set(0, 0.5, 0); g2.add(b3);
        const b4 = new THREE.Mesh(new THREE.BoxGeometry(0.22, 1.1, 0.22), new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.5 }));
        b4.rotation.z = Math.PI / 3; b4.position.set(0, -0.3, 0); g2.add(b4);
        g2.position.set(1.2, 0, 0);
        s.scene.add(g2);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagXX = null, diagXY = null;
      function initDiagXX() { const c = el('diag-xx'); if (!c) throw new Error('no container'); diagXX = xxScene(c); }
      function initDiagXY() { const c = el('diag-xy'); if (!c) throw new Error('no container'); diagXY = xyScene(c); }

      function boot() {
        try { update(); } catch (e) { console.error('[sex-linked] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[sex-linked] charts failed', e); }
        if (window.THREE) {
          try { initDiagXX(); } catch (e) { console.error('[sex-linked] xx diagram failed', e); }
          try { initDiagXY(); } catch (e) { console.error('[sex-linked] xy diagram failed', e); }
        }
        mountResize([diagXX, diagXY]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
