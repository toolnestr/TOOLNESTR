---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Speciation Rate Estimator';
const description = "Speciation rate estimator. Solve net diversification rate r = ln(N/N0)/t for a clade's species richness over geological time, with worked examples.";
const intro = "Solve r = ln(N/N0)/t for a clade's net diversification rate — how quickly a group of species has multiplied in number over millions of years. Two 3D diagrams compare a slowly-diversifying lineage to a rapidly-diversifying one, and charts show species richness building up over geological time at different diversification rates.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is speciation rate?', a: "Speciation rate describes how quickly new species form within a lineage over time. It's often summarized as the net diversification rate — the balance between how fast new species form (speciation) and how fast existing ones go extinct." },
  { q: 'How is net diversification rate calculated?', a: 'Using r = ln(N/N0)/t, where N0 is the number of species at the start of the period, N is the number now, and t is the elapsed time — mathematically identical to the population growth rate formula, just applied to species counts instead of individuals.' },
  { q: 'Why do some groups diversify much faster than others?', a: "Rapid diversification (an 'adaptive radiation') often follows access to new, unexploited ecological opportunities — like Darwin's finches colonizing the isolated Galápagos Islands, or cichlid fish rapidly filling many niches in Africa's Great Lakes." },
  { q: 'Is net diversification rate the same as speciation rate?', a: 'Not quite — net diversification rate is speciation rate minus extinction rate. A clade could have a high speciation rate but a low net diversification rate if extinction is also happening quickly, offsetting much of the new species formation.' },
  { q: 'How do scientists actually measure ancient speciation rates?', a: 'Using a combination of the fossil record (directly counting species over time) and molecular phylogenies (DNA-based family trees calibrated with a "molecular clock" to estimate how long ago lineages split).' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Speciation Rate Estimator',
  description: "Solve a clade's net diversification rate from species counts at two points in time.",
  steps: [
    { name: 'Enter starting and current species counts', text: 'The number of species in the clade at the start of the period, and now.' },
    { name: 'Enter the elapsed time', text: 'In millions of years, matching typical geological/evolutionary timescales.' },
    { name: 'Read the diversification rate', text: 'Net diversification rate and species-doubling time solve instantly.' },
  ],
};

const formulas = [
  { expr: 'r = ln(N/N0) / t', note: 'net diversification rate — N0=starting species count, N=current count, t=elapsed time (millions of years)' },
  { expr: 'Species doubling time = ln(2) / r', note: 'time for the clade\'s species count to double, at this diversification rate' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a moderately diversifying clade', tone: 'slate',
    given: 'A clade had N0 = 2 species 10 million years ago and now has N = 32 species.',
    rows: [
      { label: 'Formula:', value: 'r = ln(N/N0)/t' },
      { label: 'Substitute:', value: 'r = ln(32/2)/10 = ln(16)/10' },
      { label: 'Result:', value: 'r ≈ 0.277 new species per million years, doubling roughly every 2.5 Myr', full: true },
    ],
    note: 'This clade has doubled its species count exactly 4 times (2→4→8→16→32) over 10 million years — a doubling roughly every 2.5 million years.',
  },
  {
    title: 'Worked example 2 — comparing a slow and a rapid radiation', tone: 'amber',
    given: 'Clade A: 5 species → 10 species over 20 million years. Clade B (an adaptive radiation): 2 species → 500 species over 5 million years.',
    rows: [
      { label: 'Clade A rate:', value: 'r = ln(10/5)/20 ≈ 0.035 per Myr (slow)' },
      { label: 'Clade B rate:', value: 'r = ln(500/2)/5 ≈ 1.10 per Myr (extremely rapid)' },
      { label: 'Comparison:', value: "Clade B's diversification rate is roughly 31× faster than Clade A's", full: true },
    ],
    note: "Clade B's numbers resemble a real adaptive radiation — like cichlid fish in East African lakes, which produced hundreds of species in just a few million years after colonizing a new habitat.",
  },
];

const comparison = {
  heading: 'Diversification rate in real evolutionary radiations (order-of-magnitude estimates)',
  note: 'Diversification rate varies enormously depending on ecological opportunity and lineage.',
  headers: [{ label: 'Group' }, { label: 'Approx. diversification pattern' }],
  rows: [
    ['Slow-diversifying lineages (e.g., some deep-sea groups) ★', 'Very low r — species accumulate over tens of millions of years'],
    ['Typical vertebrate clades', 'Moderate r'],
    ['Cichlid fish (African Great Lakes)', 'Very high r — hundreds of species in a few million years'],
    ["Darwin's finches (Galápagos)", 'High r — ~15 species from one ancestor in a few million years'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row. Adaptive radiations like cichlids and Darwin\'s finches are famous precisely because their diversification rates are so unusually high compared to typical lineages.',
};

const realWorld = [
  { emoji: '🐟', title: "Adaptive radiation research", body: "Studying explosively diversifying groups like African cichlid fish or Hawaiian silverswords helps biologists understand what ecological and genetic conditions trigger rapid speciation." },
  { emoji: '🦴', title: 'Paleontology and mass extinction recovery', body: 'Measuring diversification rates before and after mass extinction events (like the one that ended the dinosaurs) reveals how quickly life rebounds and fills newly emptied ecological niches.' },
  { emoji: '🧬', title: 'Molecular phylogenetics', body: 'DNA-based family trees calibrated with fossil dates let researchers estimate diversification rates for groups with a poor fossil record, extending speciation-rate analysis across the entire tree of life.' },
  { emoji: '🌎', title: 'Conservation biology', body: 'Comparing a threatened group\'s current diversification rate to its historical rate helps conservationists identify lineages that may already be in a slow decline before population numbers make the problem obvious.' },
];

const misconceptions = [
  { claim: '"Speciation happens at the same steady rate throughout a lineage\'s entire history."', truth: "Diversification rate is rarely constant — it often spikes sharply after a lineage gains access to new ecological opportunity (an adaptive radiation) and can slow dramatically once available niches fill up." },
  { claim: '"A high net diversification rate means no extinction is happening."', truth: 'Net diversification rate is speciation rate minus extinction rate — a lineage can have substantial extinction occurring while still showing positive net diversification, as long as new species form even faster than old ones disappear.' },
  { claim: '"Modern species counts alone are enough to calculate historical diversification rate."', truth: "Extinct species that left no living descendants aren't reflected in a living-species count at all — reconstructing true historical diversification typically requires fossil evidence alongside molecular data, not species counts alone." },
  { claim: '"Faster diversification is always evolutionarily better for a lineage."', truth: "Rapid diversification doesn't guarantee long-term success — many fast-diversifying groups later suffer high extinction rates too, and some slow, steady lineages persist for far longer overall." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 21, "Speciation" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/21-1-the-nature-of-species" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Nee, Mooers &amp; Harvey (1992)</strong> — foundational diversification-rate estimation methods, <em>PNAS</em>.' },
  { html: '<strong>Futuyma &amp; Kirkpatrick, <em>Evolution</em></strong> — Speciation and macroevolution chapter.' },
];
const sourcesNote = 'r = ln(N/N0)/t. A simplified constant-rate model — real diversification rates often vary over a lineage\'s history. Results are rounded for display.';

const howToUse = [
  { title: 'Enter species counts', body: 'The clade\'s species count at the start of the period, and its current count.' },
  { title: 'Enter elapsed time', body: 'In millions of years, matching the geological timescale being studied.' },
  { title: 'Read the diversification rate', body: 'Net diversification rate and species-doubling time solve instantly.' },
];

const related = [
  { href: '/tools/exponential-population-growth-calculator', emoji: '📈', title: 'Exponential Population Growth Calculator', desc: 'N(t) = N₀e^(rt) — unconstrained population growth.' },
  { href: '/tools/hardy-weinberg-equilibrium-checker', emoji: '⚖️', title: 'Hardy-Weinberg Equilibrium Checker', desc: 'Chi-square test comparing observed vs. expected genotypes.' },
  { href: '/tools/natural-selection-calculator', emoji: '🦋', title: 'Natural Selection Simulator', desc: 'Allele frequency change over generations under selection.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a clade's species count grows (or shrinks) exactly like a population of individuals does — through repeated, compounding doublings — so the same exponential math that describes bacterial growth also describes how a handful of ancestral species can become hundreds over geological time."
  howIntro="Just as a population of individuals grows exponentially when births outpace deaths, a clade's species richness grows exponentially when speciation (the formation of new species) outpaces extinction. The net diversification rate r captures this balance in a single number, calculated exactly like a population growth rate constant but applied to species counts instead of individual organisms: r = ln(N/N0)/t. A high r means new species are accumulating quickly — often the signature of an adaptive radiation, where a lineage suddenly gains access to abundant new ecological opportunity, like an isolated island chain or a newly emptied post-extinction landscape."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where speciation rate actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Starting species count (N0)</span>
        <input id="n0" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current species count (N)</span>
        <input id="n" type="number" step="any" value="32" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Elapsed time (million years)</span>
        <input id="t" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Net diversification rate (r)</div><div id="r-rate" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Species doubling time</div><div id="r-double" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="sr-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Slow vs. rapid diversification</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-slow" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Slow diversification</h3>
          <p class="mt-1 text-sm text-slate-600">Few branching points — a small, slowly-growing family tree of species.</p>
        </div>
        <div>
          <div id="diag-fast" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Rapid diversification (adaptive radiation)</h3>
          <p class="mt-1 text-sm text-slate-600">Many branching points — a bushy, rapidly-expanding family tree of species.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Diversification rate graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Species richness over time at different rates</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-richness"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Species doubling time vs. diversification rate</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-doubling"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('sr-err').textContent = '';
        el('r-rate').textContent = '—'; el('r-double').textContent = '—';
        const n0 = parseFloat(el('n0').value), n = parseFloat(el('n').value), t = parseFloat(el('t').value);
        if (isNaN(n0) || isNaN(n) || isNaN(t)) return;
        if (n0 <= 0 || n <= 0 || t <= 0) { el('sr-err').textContent = 'Species counts and time must be positive.'; return; }
        const rate = Math.log(n / n0) / t;
        el('r-rate').textContent = fmt(rate) + ' /Myr';
        if (rate > 0) el('r-double').textContent = fmt(Math.log(2) / rate) + ' Myr';
        else el('r-double').textContent = 'N/A (no net growth)';
      }
      ['n0', 'n', 't'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labels = [];
        const slowData = [], fastData = [];
        for (let t = 0; t <= 10; t += 0.5) { labels.push(t.toFixed(1)); slowData.push(+(2 * Math.exp(0.05 * t)).toFixed(1)); fastData.push(+(2 * Math.exp(0.4 * t)).toFixed(1)); }
        new Chart(el('chart-richness'), {
          type: 'line',
          data: {
            labels,
            datasets: [
              { label: 'r=0.05/Myr (slow)', data: slowData, borderColor: '#94a3b8', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
              { label: 'r=0.4/Myr (rapid)', data: fastData, borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
            ],
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (million years)' } }, y: { type: 'logarithmic', title: { display: true, text: 'Species richness' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        const rLabels = [], dtData = [];
        for (let r = 0.05; r <= 1; r += 0.05) { rLabels.push(r.toFixed(2)); dtData.push(+(Math.log(2) / r).toFixed(2)); }
        new Chart(el('chart-doubling'), {
          type: 'line',
          data: { labels: rLabels, datasets: [{ label: 'Doubling time (Myr)', data: dtData, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Diversification rate (/Myr)' } }, y: { title: { display: true, text: 'Doubling time (Myr)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function branchScene(container, depth, branchProb) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        function addBranch(start, dir, level) {
          if (level > depth) return;
          const length = 1.2 / (level * 0.5 + 1);
          const end = start.clone().add(dir.clone().multiplyScalar(length));
          const geo = new THREE.BufferGeometry().setFromPoints([start, end]);
          s.scene.add(new THREE.Line(geo, new THREE.LineBasicMaterial({ color: 0x6366f1 })));
          if (Math.random() < branchProb || level < 2) {
            const angle1 = Math.random() * 0.6 - 0.3, angle2 = Math.random() * 0.6 - 0.3;
            const d1 = dir.clone().applyAxisAngle(new THREE.Vector3(0, 0, 1), 0.4 + angle1);
            const d2 = dir.clone().applyAxisAngle(new THREE.Vector3(0, 0, 1), -0.4 + angle2);
            addBranch(end, d1, level + 1);
            addBranch(end, d2, level + 1);
          } else {
            addBranch(end, dir, level + 1);
          }
        }
        addBranch(new THREE.Vector3(0, -2, 0), new THREE.Vector3(0, 1, 0), 0);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSlow = null, diagFast = null;
      function initDiagSlow() { const c = el('diag-slow'); if (!c) throw new Error('no container'); diagSlow = branchScene(c, 3, 0.3); }
      function initDiagFast() { const c = el('diag-fast'); if (!c) throw new Error('no container'); diagFast = branchScene(c, 5, 0.9); }

      function boot() {
        try { update(); } catch (e) { console.error('[speciation-rate] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[speciation-rate] charts failed', e); }
        if (window.THREE) {
          try { initDiagSlow(); } catch (e) { console.error('[speciation-rate] slow diagram failed', e); }
          try { initDiagFast(); } catch (e) { console.error('[speciation-rate] fast diagram failed', e); }
        }
        mountResize([diagSlow, diagFast]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
