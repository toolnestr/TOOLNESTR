---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Feet & Inches Calculator';
const description =
  'Add, subtract, and multiply measurements in feet and inches with fractional inch support.';
const intro =
  'Perform arithmetic on measurements in feet, inches, and fractional inches. Perfect for construction and woodworking.';
const category = { id: 'converters', name: 'Converters' };
const faqs = [
  { q: 'How many inches are in a foot?', a: '12 inches = 1 foot. The calculator handles this conversion automatically.' },
  { q: 'Can I use fractions of an inch?', a: 'Yes. Enter fractions as decimals (e.g., 0.5 for 1/2 inch). The result includes the decimal inch equivalent.' },
  { q: 'Does it handle negative results?', a: 'Yes. If subtraction gives a negative result, it is shown with a minus sign.' },
  { q: 'What is the maximum value?', a: 'There is no hard limit, but very large numbers may display in scientific notation.' },
  { q: 'Can I multiply feet and inches?', a: 'Yes. Select multiply to multiply the two measurements together, useful for area calculations.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <span class="text-sm font-medium text-slate-700">Measurement A</span>
        <div class="mt-1 flex gap-2">
          <input id="ft1" type="number" step="any" value="5" class="w-20 rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <span class="flex items-center text-sm text-slate-500">ft</span>
          <input id="in1" type="number" step="any" value="8" class="w-20 rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <span class="flex items-center text-sm text-slate-500">in</span>
        </div>
      </div>
      <div>
        <span class="text-sm font-medium text-slate-700">Measurement B</span>
        <div class="mt-1 flex gap-2">
          <input id="ft2" type="number" step="any" value="3" class="w-20 rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <span class="flex items-center text-sm text-slate-500">ft</span>
          <input id="in2" type="number" step="any" value="4" class="w-20 rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <span class="flex items-center text-sm text-slate-500">in</span>
        </div>
      </div>
    </div>
    <label class="block mt-4">
      <span class="text-sm font-medium text-slate-700">Operation</span>
      <select id="op"
        class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="add">Add (A + B)</option>
        <option value="sub">Subtract (A - B)</option>
        <option value="mul">Multiply (A × B)</option>
      </select>
    </label>
    <div class="mt-6 grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Total inches</div>
        <div id="r-total-in" class="mt-1 text-2xl font-bold text-slate-800">—</div>
      </div>
      <div class="rounded-xl bg-indigo-50 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Feet &amp; Inches</div>
        <div id="r-ftin" class="mt-1 text-2xl font-bold text-indigo-700">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tape-title tape-desc">
      <title id="tape-title">Tape measure stacking diagram</title>
      <desc id="tape-desc">Three tape measures stacked vertically showing feet and inches adding together</desc>
      <rect x="60" y="20" width="680" height="40" rx="6" fill="#fbbf24" />
      <rect x="60" y="20" width="680" height="8" rx="4" fill="#f59e0b" />
      <text x="70" y="46" fill="#92400e" font-size="13" font-weight="bold">Measurement A: 5 ft 8 in</text>
      <line x1="160" y1="28" x2="160" y2="60" stroke="#92400e" stroke-width="1.5" />
      <text x="160" y="70" text-anchor="middle" fill="#92400e" font-size="10">5 ft</text>
      <line x1="440" y1="28" x2="440" y2="60" stroke="#92400e" stroke-width="1.5" />
      <text x="440" y="70" text-anchor="middle" fill="#92400e" font-size="10">+8 in</text>
      <rect x="60" y="80" width="520" height="40" rx="6" fill="#a78bfa" />
      <rect x="60" y="80" width="520" height="8" rx="4" fill="#8b5cf6" />
      <text x="70" y="106" fill="#fff" font-size="13" font-weight="bold">Measurement B: 3 ft 4 in</text>
      <line x1="140" y1="88" x2="140" y2="120" stroke="#fff" stroke-width="1.5" />
      <text x="140" y="130" text-anchor="middle" fill="#7c3aed" font-size="10">3 ft</text>
      <line x1="380" y1="88" x2="380" y2="120" stroke="#fff" stroke-width="1.5" />
      <text x="380" y="130" text-anchor="middle" fill="#7c3aed" font-size="10">+4 in</text>
      <text x="600" y="108" fill="#6366f1" font-size="24" font-weight="bold">+</text>
      <rect x="60" y="140" width="680" height="40" rx="6" fill="#34d399" />
      <rect x="60" y="140" width="680" height="8" rx="4" fill="#10b981" />
      <text x="70" y="166" fill="#065f46" font-size="13" font-weight="bold">Result: 9 ft 0 in</text>
      <line x1="260" y1="148" x2="260" y2="180" stroke="#065f46" stroke-width="1.5" />
      <text x="260" y="190" text-anchor="middle" fill="#065f46" font-size="10">9 ft</text>
      <line x1="260" y1="148" x2="260" y2="180" stroke="#065f46" stroke-width="1.5" />
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Feet and inches measurements stack like physical tape measures</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How feet and inches arithmetic works</h2>
    <p class="mt-2 text-slate-600">
      The imperial measurement system, used primarily in the United States and to some extent in the UK and Canada, expresses length in feet and inches where one foot equals 12 inches. Performing arithmetic on these mixed units can be tedious by hand. This calculator converts both measurements entirely to inches, performs the operation, then converts the result back to feet and inches for display.
    </p>
    <p class="mt-3 text-slate-600">
      Each measurement is parsed as feet plus inches (with decimal inches supported). The total in inches is computed as (feet × 12) + inches. The operation runs on the inch totals, and the result is decomposed back: divide by 12 for feet, with the remainder as inches. When the remainder is exactly zero, the result shows whole feet.
    </p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-1 rounded-xl bg-white p-4 font-mono text-sm text-slate-700">
      <div><span class="font-semibold">Total inches</span> = (feet × 12) + inches</div>
      <div><span class="font-semibold">Addition:</span> Result = A<sub>in</sub> + B<sub>in</sub></div>
      <div><span class="font-semibold">Subtraction:</span> Result = A<sub>in</sub> − B<sub>in</sub></div>
      <div><span class="font-semibold">Back to ft+in:</span> ft = floor(result / 12), in = result mod 12</div>
    </div>
    <h3 class="mt-4 font-semibold text-slate-900">Worked example</h3>
    <p class="mt-1 text-sm text-slate-600"><strong>5 ft 8 in</strong> + <strong>3 ft 4 in</strong></p>
    <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
      <div><span class="font-medium text-slate-700">A in inches:</span> <span class="text-slate-600">5 × 12 + 8 = 68 in</span></div>
      <div><span class="font-medium text-slate-700">B in inches:</span> <span class="text-slate-600">3 × 12 + 4 = 40 in</span></div>
      <div><span class="font-medium text-slate-700">Total:</span> <span class="text-slate-600">68 + 40 = 108 in</span></div>
      <div><span class="font-medium text-slate-700">Convert back:</span> <span class="text-slate-600">108 ÷ 12 = 9 ft 0 in</span></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🪚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Woodworking</h3>
      <p class="mt-1 text-sm text-slate-600">Add board lengths, subtract kerf widths, and calculate total material needed for a project without mental math errors.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏠</span>
      <h3 class="mt-2 font-semibold text-slate-900">Construction Layout</h3>
      <p class="mt-1 text-sm text-slate-600">Add wall lengths, subtract window and door openings, and verify overall dimensions match the architectural plan.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📐</span>
      <h3 class="mt-2 font-semibold text-slate-900">Interior Design</h3>
      <p class="mt-1 text-sm text-slate-600">Add furniture dimensions to verify they fit in a room. Subtract clearance requirements from available space.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚧</span>
      <h3 class="mt-2 font-semibold text-slate-900">DIY Projects</h3>
      <p class="mt-1 text-sm text-slate-900">Measure twice, cut once. Use the calculator to add up all the pieces you need for fencing, decking, or shelving.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the feet and inches calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter measurements</h3>
        <p class="mt-1 text-sm text-slate-600">Type the feet and inches for each measurement. Inches can include decimals for fractional precision.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose operation</h3>
        <p class="mt-1 text-sm text-slate-600">Select add, subtract, or multiply. Each uses the internal inch representation for precise results.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">See the total in inches and the decomposed feet + inches format simultaneously.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for feet and inch calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always measure twice</h3>
        <p class="mt-1 text-sm text-slate-600">Small errors in feet and inches compound quickly. Double-check your input values against a physical tape measure.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use decimals for fractions</h3>
        <p class="mt-1 text-sm text-slate-600">A half inch is 0.5, a quarter is 0.25, an eighth is 0.125. For exact fractional inches, use the inches to fraction calculator.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Multiplication gives area</h3>
        <p class="mt-1 text-sm text-slate-600">When you multiply two length measurements, the result is in square inches. Divide by 144 to get square feet.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/inches-to-fraction-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📏</span>
        <h3 class="mt-1 font-semibold text-slate-900">Inches to Fraction Calculator</h3>
        <p class="text-sm text-slate-600">Convert decimal inches to exact fractions.</p>
      </a>
      <a href="/tools/unit-converter" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📐</span>
        <h3 class="mt-1 font-semibold text-slate-900">Unit Converter</h3>
        <p class="text-sm text-slate-600">All-purpose measurement converter.</p>
      </a>
      <a href="/tools/square-footage-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📐</span>
        <h3 class="mt-1 font-semibold text-slate-900">Square Footage Calculator</h3>
        <p class="text-sm text-slate-600">Calculate area in sq ft from length and width.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    function fmt(n) { return n.toLocaleString(undefined, { maximumFractionDigits: 4 }); }
    function update() {
      const ft1 = parseFloat(document.getElementById('ft1').value) || 0;
      const in1 = parseFloat(document.getElementById('in1').value) || 0;
      const ft2 = parseFloat(document.getElementById('ft2').value) || 0;
      const in2 = parseFloat(document.getElementById('in2').value) || 0;
      const op = document.getElementById('op').value;
      const a = ft1 * 12 + in1;
      const b = ft2 * 12 + in2;
      let r;
      if (op === 'add') r = a + b;
      else if (op === 'sub') r = a - b;
      else r = a * b;
      document.getElementById('r-total-in').textContent = fmt(r) + ' in';
      if (r < 0) {
        document.getElementById('r-ftin').textContent = '-' + fmt(Math.abs(r));
      } else {
        const ft = Math.floor(r / 12);
        const rem = r % 12;
        document.getElementById('r-ftin').textContent = ft + ' ft ' + fmt(rem) + ' in';
      }
    }
    ['ft1','in1','ft2','in2','op'].forEach(id => document.getElementById(id).addEventListener('input', update));
    document.getElementById('op').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
