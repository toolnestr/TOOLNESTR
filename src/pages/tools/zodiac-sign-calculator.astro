    ];

    function getSign(month, day) {
      for (const s of signs) {
        if (s.startM === 12) {
          if (month === 12 && day >= s.startD) return s;
          if (month === 1 && day <= s.endD) return s;
        } else {
          if (month === s.startM && day >= s.startD) return s;
          if (month === s.endM && day <= s.endD) return s;
        }
      }
      return null;
    }

    function formatDateRange(s) {
      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      return months[s.startM - 1] + ' ' + s.startD + ' - ' + months[s.endM - 1] + ' ' + s.endD;
    }

    function elementColor(el) {
      const map = { Fire: 'bg-red-100 text-red-700 border-red-200', Earth: 'bg-emerald-100 text-emerald-700 border-emerald-200', Air: 'bg-amber-100 text-amber-700 border-amber-200', Water: 'bg-blue-100 text-blue-700 border-blue-200' };
      return map[el] || 'bg-slate-100 text-slate-700';
    }

    const $ = (id) => document.getElementById(id);
    const resultDiv = $('zodiac-result');

    function calculate() {
      const val = $('zodiac-birthdate').value;
      if (!val) { resultDiv.classList.add('hidden'); return; }
      const [y, m, d] = val.split('-').map(Number);
      const sign = getSign(m, d);
      if (!sign) { resultDiv.innerHTML = '<p class="text-slate-600">Could not determine your sign. Please check the date.</p>'; resultDiv.classList.remove('hidden'); return; }

      const range = formatDateRange(sign);
      const elClass = elementColor(sign.element);

      resultDiv.innerHTML =
        '<div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-5 text-center">' +
          '<div class="text-5xl">' + sign.emoji + '</div>' +
          '<h3 class="mt-2 text-2xl font-bold text-slate-900">' + sign.name + '</h3>' +
          '<p class="text-sm text-slate-500">' + range + '</p>' +
          '<div class="mt-4 flex flex-wrap justify-center gap-2">' +
            '<span class="rounded-full border px-3 py-1 text-xs font-medium ' + elementColor(sign.element) + '">' + sign.element + '</span>' +
            '<span class="rounded-full border border-purple-200 bg-purple-100 px-3 py-1 text-xs font-medium text-purple-700">' + sign.quality + '</span>' +
            '<span class="rounded-full border border-cyan-200 bg-cyan-100 px-3 py-1 text-xs font-medium text-cyan-700">' + sign.planet + '</span>' +
          '</div>' +
          '<div class="mt-4 text-left">' +
            '<div class="mb-2 text-sm"><span class="font-semibold text-slate-700">Traits:</span> <span class="text-slate-600">' + sign.traits + '</span></div>' +
            '<div class="text-sm"><span class="font-semibold text-slate-700">Compatibility:</span> <span class="text-slate-600">' + sign.compatibility + '</span></div>' +
          '</div>' +
        '</div>';
      resultDiv.classList.remove('hidden');
    }

    $('zodiac-btn').addEventListener('click', calculate);
    $('zodiac-birthdate').addEventListener('change', calculate);
    $('zodiac-birthdate').valueAsDate = new Date();
    calculate();
  </script>
</ToolLayout>
