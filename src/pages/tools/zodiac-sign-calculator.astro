---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Zodiac Sign Calculator';
const description = 'Find your Western zodiac sign based on your birth date — Aries, Taurus, Gemini, Cancer, Leo, Virgo, Libra, Scorpio, Sagittarius, Capricorn, Aquarius, Pisces.';
const intro = 'Find your Western zodiac sign based on your birth date.';
const category = { id: 'time-date', name: 'Time & Date Tools' };
const faqs = [
  { q: 'What determines my zodiac sign?', a: 'Your birth date determines which constellation the sun was in when you were born.' },
  { q: 'Are the dates fixed?', a: 'The dates are traditional and may vary slightly year to year by a day due to precession.' },
  { q: 'What are the 12 signs?', a: 'Aries, Taurus, Gemini, Cancer, Leo, Virgo, Libra, Scorpio, Sagittarius, Capricorn, Aquarius, Pisces.' },
  { q: 'What about Ophiuchus?', a: 'The 13th constellation is not part of traditional Western astrology (tropical system).' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700" for="zodiac-birthdate">Your birth date</label>
      <input id="zodiac-birthdate" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </div>
    <button id="zodiac-btn" class="w-full rounded-xl bg-indigo-600 px-4 py-3 font-semibold text-white transition hover:bg-indigo-700 active:bg-indigo-800">Find My Sign</button>
    <div id="zodiac-result" class="mt-6 hidden"></div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The zodiac wheel</h2>
    <p class="mt-2 text-slate-600">Western astrology divides the year into 12 segments of 30 degrees each, forming a circular zodiac wheel. Each segment is associated with a constellation and its corresponding sign.</p>
    <div class="mt-4 flex justify-center">
      <svg viewBox="0 0 500 500" class="w-full max-w-lg" role="img" aria-label="Circular zodiac wheel showing all 12 astrological signs arranged in order around the wheel">
        <defs>
          <radialGradient id="zodiac-bg" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#f8fafc"/><stop offset="100%" stop-color="#e2e8f0"/></radialGradient>
        </defs>
        <circle cx="250" cy="250" r="230" fill="url(#zodiac-bg)" stroke="#cbd5e1" stroke-width="2"/>
        <circle cx="250" cy="250" r="200" fill="none" stroke="#cbd5e1" stroke-width="1"/>
        <circle cx="250" cy="250" r="155" fill="none" stroke="#cbd5e1" stroke-width="0.5" stroke-dasharray="4,4"/>
        <circle cx="250" cy="250" r="110" fill="none" stroke="#cbd5e1" stroke-width="0.5" stroke-dasharray="4,4"/>
        <line x1="250" y1="50" x2="250" y2="450" stroke="#e2e8f0" stroke-width="0.5"/>
        <line x1="50" y1="250" x2="450" y2="250" stroke="#e2e8f0" stroke-width="0.5"/>
        <line x1="107" y1="107" x2="393" y2="393" stroke="#e2e8f0" stroke-width="0.5"/>
        <line x1="107" y1="393" x2="393" y2="107" stroke="#e2e8f0" stroke-width="0.5"/>

        <g transform="translate(250,250)">
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="-185" fill="#b91c1c">&#9837; Aries</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="-170" fill="#64748b">Mar 21 - Apr 19</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="-140" transform="rotate(30)" fill="#b45309">&#9790; Taurus</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="-125" transform="rotate(30)" fill="#64748b">Apr 20 - May 20</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="-95" transform="rotate(60)" fill="#a16207">&#9808; Gemini</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="-80" transform="rotate(60)" fill="#64748b">May 21 - Jun 20</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="-50" transform="rotate(90)" fill="#15803d">&#9809; Cancer</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="-35" transform="rotate(90)" fill="#64748b">Jun 21 - Jul 22</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="-5" transform="rotate(120)" fill="#b91c1c">&#9810; Leo</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="10" transform="rotate(120)" fill="#64748b">Jul 23 - Aug 22</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="40" transform="rotate(150)" fill="#4f46e5">&#9811; Virgo</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="55" transform="rotate(150)" fill="#64748b">Aug 23 - Sep 22</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="85" transform="rotate(180)" fill="#7c3aed">&#9806; Libra</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="100" transform="rotate(180)" fill="#64748b">Sep 23 - Oct 22</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="130" transform="rotate(210)" fill="#1d4ed8">&#9807; Scorpio</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="145" transform="rotate(210)" fill="#64748b">Oct 23 - Nov 21</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="175" transform="rotate(240)" fill="#7c3aed">&#9800; Sagittarius</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="190" transform="rotate(240)" fill="#64748b">Nov 22 - Dec 21</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="220" transform="rotate(270)" fill="#15803d">&#9803; Capricorn</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="235" transform="rotate(270)" fill="#64748b">Dec 22 - Jan 19</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="-220" transform="rotate(300)" fill="#a16207">&#9812; Aquarius</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="-235" transform="rotate(300)" fill="#64748b">Jan 20 - Feb 18</text>
          <text style="text-anchor:middle;font-size:13px;font-weight:700;font-family:sans-serif" y="-250" transform="rotate(330)" fill="#4f46e5">&#9813; Pisces</text>
          <text style="text-anchor:middle;font-size:11px;font-family:sans-serif" y="-265" transform="rotate(330)" fill="#64748b">Feb 19 - Mar 20</text>
        </g>

        <text x="250" y="258" text-anchor="middle" font-size="10" fill="#94a3b8" font-family="sans-serif">ZODIAC</text>
      </svg>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the zodiac works</h2>
    <p class="mt-2 text-slate-600">Western astrology divides the year into 12 segments of 30 degrees each, known as the tropical zodiac. Each segment corresponds to one of the 12 zodiac signs, named after the constellation that occupied that region of the sky when the system was formalized over 2,000 years ago. As the Earth orbits the Sun, the Sun appears to move through each of these 12 signs over the course of a year, spending roughly 30 days in each sign. Your zodiac sign is determined by which constellation the Sun was passing through at the moment of your birth. This is why it is called your sun sign. The zodiac wheel begins with Aries at the vernal equinox (around March 21) and proceeds through Taurus, Gemini, Cancer, Leo, Virgo, Libra, Scorpio, Sagittarius, Capricorn, Aquarius, and Pisces. Each sign is associated with one of four classical elements — fire, earth, air, and water — and one of three qualities — cardinal, fixed, and mutable. These elements and qualities combine to create the unique personality traits, strengths, and weaknesses associated with each sign. While modern astronomy recognizes that the constellations no longer align perfectly with their corresponding dates due to the precession of the equinoxes, the tropical zodiac remains the standard system used in Western astrology.</p>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌟</span>
      <h3 class="mt-2 font-semibold text-slate-900">Self-discovery</h3>
      <p class="mt-1 text-sm text-slate-600">Learn about your personality traits, strengths, and weaknesses based on your zodiac sign. Many people find that their sign description resonates with their character.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎈</span>
      <h3 class="mt-2 font-semibold text-slate-900">Birthday fun</h3>
      <p class="mt-1 text-sm text-slate-600">Share your sign at parties and with friends. Compare compatibility between signs and see which elements work best together for relationships and friendships.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Learning astrology basics</h3>
      <p class="mt-1 text-sm text-slate-600">Understand the fundamentals of the tropical zodiac system, the four elements, the three qualities, and how they combine to create the unique energy of each sign.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Compatibility insights</h3>
      <p class="mt-1 text-sm text-slate-600">Discover which signs naturally complement each other based on elemental compatibility. Fire signs pair well with air, earth with water, and so on.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The 12 zodiac signs</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9837;</span> Aries — Mar 21 to Apr 19 <span class="text-xs text-slate-400">(Fire, Cardinal)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Aries is the first sign of the zodiac, symbolized by the Ram. Ruled by Mars, Aries individuals are known for their courage, determination, and competitive spirit. They are natural leaders who charge headfirst into new challenges with boundless energy and enthusiasm. Their impulsive nature can sometimes lead to recklessness, but their ability to take initiative makes them inspirational pioneers.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9790;</span> Taurus — Apr 20 to May 20 <span class="text-xs text-slate-400">(Earth, Fixed)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Taurus is the second sign, symbolized by the Bull. Ruled by Venus, Taureans value stability, comfort, and the finer things in life. They are reliable, patient, and deeply loyal, with a strong appreciation for beauty, art, and nature. Their stubbornness is legendary, but it comes from a place of deep-rooted consistency and a desire for security. They make devoted friends and partners who can be counted on through thick and thin.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9808;</span> Gemini — May 21 to Jun 20 <span class="text-xs text-slate-400">(Air, Mutable)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Gemini is the third sign, symbolized by the Twins. Ruled by Mercury, Geminis are curious, adaptable, and quick-witted communicators. They thrive on mental stimulation, social interaction, and learning new things. Their dual nature means they can see multiple sides of any situation, making them excellent mediators. However, their restless minds can lead to inconsistency and a tendency to flit between interests.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9809;</span> Cancer — Jun 21 to Jul 22 <span class="text-xs text-slate-400">(Water, Cardinal)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Cancer is the fourth sign, symbolized by the Crab. Ruled by the Moon, Cancerians are deeply emotional, intuitive, and nurturing. They are fiercely protective of their loved ones and their home environment. Their sensitivity gives them a profound understanding of others' feelings, but it also means they can be moody and retreat into their shell when hurt. Family and emotional security are paramount for this deeply caring sign.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9810;</span> Leo — Jul 23 to Aug 22 <span class="text-xs text-slate-400">(Fire, Fixed)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Leo is the fifth sign, symbolized by the Lion. Ruled by the Sun, Leos are confident, charismatic, and naturally theatrical. They have an infectious enthusiasm and a generous spirit that draws people toward them. They love being in the spotlight and have a flair for drama and creativity. Their pride can sometimes come across as arrogance, but their warmth, loyalty, and big-hearted nature make them natural leaders and beloved friends.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9811;</span> Virgo — Aug 23 to Sep 22 <span class="text-xs text-slate-400">(Earth, Mutable)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Virgo is the sixth sign, symbolized by the Maiden. Ruled by Mercury, Virgos are analytical, meticulous, and service-oriented. They have a keen eye for detail and a natural gift for organization and problem-solving. Their practical nature makes them excellent planners and critical thinkers. Their perfectionism can lead to overthinking and self-criticism, but their dedication to improvement and helping others makes them invaluable in any team.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9806;</span> Libra — Sep 23 to Oct 22 <span class="text-xs text-slate-400">(Air, Cardinal)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Libra is the seventh sign, symbolized by the Scales. Ruled by Venus, Librans are diplomatic, charming, and fairness-obsessed. They seek balance and harmony in all aspects of life and are natural peacemakers. Their refined taste and appreciation for beauty make them lovers of art, culture, and elegant living. Their desire to please everyone can lead to indecisiveness, but their social grace and ability to see all perspectives make them wonderful companions.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9807;</span> Scorpio — Oct 23 to Nov 21 <span class="text-xs text-slate-400">(Water, Fixed)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Scorpio is the eighth sign, symbolized by the Scorpion. Ruled by Pluto (traditionally Mars), Scorpios are intense, passionate, and mysterious. They possess remarkable emotional depth and an unwavering determination to uncover the truth. Their loyalty is absolute once earned, but they are fiercely private and protective of their inner world. Their transformative nature means they are constantly evolving, rising stronger from every challenge they face.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9800;</span> Sagittarius — Nov 22 to Dec 21 <span class="text-xs text-slate-400">(Fire, Mutable)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Sagittarius is the ninth sign, symbolized by the Archer. Ruled by Jupiter, Sagittarians are adventurous, optimistic, and philosophically inclined. They have an insatiable thirst for knowledge, travel, and new experiences. Their honesty is refreshing and sometimes blunt, but it comes from a place of genuine authenticity. Their free-spirited nature resists constraints, and they are always looking toward the next horizon with infectious enthusiasm.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9803;</span> Capricorn — Dec 22 to Jan 19 <span class="text-xs text-slate-400">(Earth, Cardinal)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Capricorn is the tenth sign, symbolized by the Sea-Goat. Ruled by Saturn, Capricorns are ambitious, disciplined, and practical. They have a strong sense of responsibility and an unwavering work ethic that drives them toward their goals. Their patience and strategic thinking allow them to build lasting success. Their reserved nature can be mistaken for coldness, but beneath the surface lies a dry wit and deep loyalty to those they care about.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9812;</span> Aquarius — Jan 20 to Feb 18 <span class="text-xs text-slate-400">(Air, Fixed)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Aquarius is the eleventh sign, symbolized by the Water Bearer. Ruled by Uranus (traditionally Saturn), Aquarians are innovative, independent, and humanitarian. They think outside the box and are often ahead of their time, driven by a vision for a better future. They value intellectual freedom and surround themselves with diverse ideas and people. Their detachment can seem aloof, but their commitment to social progress and collective well-being runs deep.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><span class="text-xl">&#9813;</span> Pisces — Feb 19 to Mar 20 <span class="text-xs text-slate-400">(Water, Mutable)</span></h3>
        <p class="mt-1 text-sm text-slate-600">Pisces is the twelfth and final sign, symbolized by the Fish. Ruled by Neptune (traditionally Jupiter), Pisceans are compassionate, artistic, and deeply intuitive. They have a natural gift for empathy and often absorb the emotions of those around them. Their creative imagination knows no bounds, making them exceptional artists, musicians, and healers. Their sensitivity can lead to escapism, but their ability to connect with the universal human experience is truly magical.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The four elements and three qualities</h2>
    <p class="mt-2 text-slate-600">Each zodiac sign belongs to one of four classical elements and one of three qualities, which together define its fundamental nature. Fire signs (Aries, Leo, Sagittarius) are passionate, energetic, and dynamic. Earth signs (Taurus, Virgo, Capricorn) are grounded, practical, and reliable. Air signs (Gemini, Libra, Aquarius) are intellectual, social, and communicative. Water signs (Cancer, Scorpio, Pisces) are emotional, intuitive, and empathetic. The three qualities describe how each sign expresses its energy. Cardinal signs (Aries, Cancer, Libra, Capricorn) are initiators who start new cycles. Fixed signs (Taurus, Leo, Scorpio, Aquarius) are stabilizers who provide consistency and endurance. Mutable signs (Gemini, Virgo, Sagittarius, Pisces) are adapters who facilitate change and transition. The combination of element and quality creates the unique archetype of each sign. For example, a Cardinal Fire sign (Aries) initiates with bold action, while a Cardinal Earth sign (Capricorn) initiates with strategic planning. A Fixed Water sign (Scorpio) stabilizes with emotional intensity, while a Fixed Air sign (Aquarius) stabilizes with intellectual conviction.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tropical vs sidereal astrology</h2>
    <p class="mt-2 text-slate-600">This calculator uses the tropical zodiac system, which is the standard in Western astrology. The tropical zodiac is based on the Earth's relationship to the Sun and is anchored to the vernal equinox (the first day of spring). Due to the precession of the equinoxes — a slow wobble of Earth's axis that takes approximately 26,000 years to complete — the tropical zodiac no longer aligns with the actual constellations in the sky. The sidereal zodiac, used in Vedic (Jyotish) astrology, accounts for this precession and adjusts the dates accordingly. As of 2026, the sidereal zodiac is approximately 24 days behind the tropical zodiac. This means that if you were born on a tropical sign boundary, your sidereal sign may differ. For example, someone born on April 10 is a tropical Aries but a sidereal Pisces. Neither system is more correct; they are simply different frameworks with different philosophical foundations. The tropical system focuses on the seasons and the Sun's energy relative to Earth, while the sidereal system uses the actual positions of fixed stars and constellations.</p>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for using the zodiac sign calculator</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Check the boundary dates</h3>
        <p class="mt-1 text-sm text-slate-600">If you were born on a cusp date (the first or last day of a sign's range), your sign may vary slightly depending on the year and exact time of birth. The traditional dates provided here are a reliable guide for most purposes.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Sidereal differs by ~24 days</h3>
        <p class="mt-1 text-sm text-slate-600">This tool is based on tropical astrology (tropical zodiac). Sidereal astrology, used in Vedic traditions, places the signs about 24 days earlier. If you explore both systems, you may find that different signs resonate with different aspects of your personality.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Sun sign is just the beginning</h3>
        <p class="mt-1 text-sm text-slate-600">Your sun sign represents your core identity, but a full birth chart includes your moon sign (emotions), rising sign (outer personality), and the positions of all planets. For deeper insights, consider generating a complete natal chart.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Have fun with it</h3>
        <p class="mt-1 text-sm text-slate-600">Astrology is a tool for self-reflection and entertainment. Use it as a starting point for understanding yourself and others better, but remember that every individual is unique and cannot be fully defined by their zodiac sign.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <a href="/tools/moon-phase-calculator/" class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🌙</span>
        <div><div class="font-semibold text-slate-900">Moon Phase Calculator</div><div class="text-sm text-slate-500">Find the moon phase for any date</div></div>
      </a>
      <a href="/tools/world-clock-comparator/" class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🌐</span>
        <div><div class="font-semibold text-slate-900">World Clock Comparator</div><div class="text-sm text-slate-500">Compare current times across cities</div></div>
      </a>
    </div>
  </section>

  <script is:inline>
    const signs = [
      { name: 'Aries', emoji: '&#9837;', startM: 3, startD: 21, endM: 4, endD: 19, element: 'Fire', quality: 'Cardinal', planet: 'Mars', traits: 'Courageous, determined, confident, enthusiastic, impulsive', compatibility: 'Leo, Sagittarius, Gemini, Aquarius' },
      { name: 'Taurus', emoji: '&#9790;', startM: 4, startD: 20, endM: 5, endD: 20, element: 'Earth', quality: 'Fixed', planet: 'Venus', traits: 'Reliable, patient, practical, devoted, stubborn', compatibility: 'Virgo, Capricorn, Cancer, Pisces' },
      { name: 'Gemini', emoji: '&#9808;', startM: 5, startD: 21, endM: 6, endD: 20, element: 'Air', quality: 'Mutable', planet: 'Mercury', traits: 'Curious, adaptable, witty, communicative, restless', compatibility: 'Libra, Aquarius, Aries, Leo' },
      { name: 'Cancer', emoji: '&#9809;', startM: 6, startD: 21, endM: 7, endD: 22, element: 'Water', quality: 'Cardinal', planet: 'Moon', traits: 'Nurturing, intuitive, emotional, protective, moody', compatibility: 'Scorpio, Pisces, Taurus, Virgo' },
      { name: 'Leo', emoji: '&#9810;', startM: 7, startD: 23, endM: 8, endD: 22, element: 'Fire', quality: 'Fixed', planet: 'Sun', traits: 'Confident, charismatic, generous, dramatic, proud', compatibility: 'Aries, Sagittarius, Gemini, Libra' },
      { name: 'Virgo', emoji: '&#9811;', startM: 8, startD: 23, endM: 9, endD: 22, element: 'Earth', quality: 'Mutable', planet: 'Mercury', traits: 'Analytical, meticulous, practical, modest, critical', compatibility: 'Taurus, Capricorn, Cancer, Scorpio' },
