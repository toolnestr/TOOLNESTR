---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Text Repeater';
const description =
  'Free text repeater. Repeat any word, sentence or emoji as many times as you want, with ' +
  'your choice of separator. Copy the result instantly. Free and private.';
const intro =
  'Type some text, choose how many times to repeat it and how to separate each copy, then copy the result.';
const category = { id: 'creators', name: 'Creators' };
const faqs = [
  { q: 'What can I repeat?', a: 'Anything — a word, a sentence, an emoji or a symbol. It\'s popular for memes, chats and filling text.' },
  { q: 'Can I add a space or new line between copies?', a: 'Yes. Choose "Space", "New line", "Comma" or "None" as the separator between each repetition.' },
  { q: 'Is there a limit?', a: 'You can repeat up to a large number of times, but extremely large amounts may slow your browser. It\'s designed for everyday use.' },
  { q: 'Is it free?', a: 'Yes, completely free and it runs in your browser.' },
  { q: 'What counts as "too many" repetitions?', a: 'The limit is 10,000 repetitions. Beyond that the output may slow your browser. For most uses, a few hundred is plenty.' },
  { q: 'Can I repeat text with line breaks?', a: 'Yes — choose "New line" as the separator to place each repetition on its own line.' },
  { q: 'Is there a mobile version?', a: 'Yes, the tool works on any device with a browser, including phones and tablets.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Text to repeat</span>
      <input id="text" type="text" placeholder="e.g. hello" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </label>

    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Repeat how many times</span>
        <input id="count" type="number" min="1" max="10000" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Separator</span>
        <select id="sep" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value=" ">Space</option>
          <option value="\n">New line</option>
          <option value=", ">Comma</option>
          <option value="">None</option>
        </select>
      </label>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <button id="copy-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Copy result</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
      <span id="count-info" class="ml-auto text-sm text-slate-400">0 characters</span>
    </div>

    <textarea id="output" rows="7" readonly placeholder="Repeated text appears here…" class="mt-3 w-full resize-y rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm outline-none"></textarea>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this text repeater</h2>
    <p class="mt-2 text-slate-600">
      Need the same word or emoji repeated dozens of times without typing it over and over? This
      text repeater does it instantly. It’s handy for memes, group chats, testing, or filling a
      field with placeholder text — and you choose how each copy is separated.
      Style the output with the <a href="/tools/fancy-text" class="font-medium text-indigo-600 hover:underline">Fancy Text Generator</a>
      or count the characters with the <a href="/tools/word-counter" class="font-medium text-indigo-600 hover:underline">Word Counter</a>.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Type the text you want to repeat.</li>
      <li>Set the number of repetitions.</li>
      <li>Choose a separator (space, new line, comma or none).</li>
      <li>Copy the result.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Repeating text is surprisingly useful in many everyday situations. Meme creators generate endless streams of the same word for comedic effect. Developers fill placeholder fields with repeated text when testing website layouts and form designs. Social media managers create decorative separators by repeating hyphens or stars. Students quickly generate practice sentences for typing drills. Even gamers use text repeaters to create rhythmic chants in chat channels — all without the tedium of copy-pasting manually.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Use the "New line" separator to list each repetition on its own line — great for creating vertical text patterns.</li>
      <li>Check the character count at the bottom to make sure your output isn’t too long for the platform you’re pasting into.</li>
      <li>For large numbers of repetitions, the preview updates instantly — the clear button resets everything in one click.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const text = el('text'), count = el('count'), sep = el('sep'), output = el('output'), info = el('count-info');

    function update() {
      const t = text.value;
      const n = Math.max(0, Math.min(parseInt(count.value, 10) || 0, 10000));
      const separator = sep.value === '\\n' ? '\n' : sep.value;
      output.value = t ? Array(n).fill(t).join(separator) : '';
      info.textContent = output.value.length.toLocaleString() + ' characters';
    }

    [text, count, sep].forEach((e) => e.addEventListener('input', update));
    el('clear-btn').addEventListener('click', () => { text.value = ''; update(); text.focus(); });
    el('copy-btn').addEventListener('click', async () => {
      if (!output.value) return;
      try { await navigator.clipboard.writeText(output.value); const b = el('copy-btn'); const o = b.textContent; b.textContent = 'Copied!'; setTimeout(() => (b.textContent = o), 1200); } catch (e) {}
    });

    update();
  </script>
</ToolLayout>
