---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Dropspot – Cross-Network File & Text Sharing (No Login)';
const description =
  'A shared spot to drop files, links and text across any network with a simple room code. No login, no app. Files up to 50 MB, plus text and links, sync instantly through secure storage — shared with everyone in the room and downloadable across any network. Works across Wi-Fi, mobile data and different networks.';

const faqs = [
  { q: 'Do I need an account to use Dropspot?', a: 'No. Dropspot is completely login-free. You create a room, get a 6-character code, and share that code (or the QR) with anyone. They join instantly — no sign-up, no app install, nothing to download. The room and its contents automatically expire after the time you choose.' },
  { q: 'Does it work across different networks?', a: 'Yes. Unlike local-only tools that need everyone on the same Wi-Fi, Dropspot works across any network using room codes. One person can be on home Wi-Fi and another on mobile data on the other side of the world — as long as both have the room code, they share the same room. Text, links and files all sync through secure cloud storage, so everyone in the room can grab them on any network.' },
  { q: 'How are files transferred?', a: 'Files up to 50 MB each are uploaded to fast, secure temporary storage — they appear for everyone in the room to download, work across any network, survive a page refresh, and are kept for about an hour. Each room can hold up to 100 MB of files at a time. Just drag a file onto the drop zone or click to choose one.' },
  { q: 'Is my data private?', a: 'Text, links and files are stored only for the lifetime you choose and are then permanently deleted. Uploads go to private storage that is only reachable through the room and are auto-deleted on expiry. You can also protect any room with a PIN and delete any item manually at any time.' },
  { q: 'How long does content stay available?', a: 'You choose when you create the room: from 10 minutes up to 8 hours. Every item carries its own expiry, and a background cleanup permanently removes expired text, links and files. Nothing lingers longer than you asked for.' },
  { q: 'Why does it warn me about backgrounding the tab?', a: 'Browsers pause or throttle background tabs to save battery. Dropspot sends a small heartbeat every few seconds so others can see you are online in the room. If you switch tabs or minimise, that heartbeat pauses and you will drop off the live device list — so keep the tab visible to stay shown as present.' },
  { q: 'Is there a file size limit?', a: 'Each file can be up to 50 MB, and a single room can hold up to 100 MB of files at a time. Uploads use secure temporary storage — fast, reliable, downloadable by everyone in the room, and kept for about an hour before they auto-expire.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Dropspot',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  browserRequirements: 'Requires JavaScript',
  description,
};
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to share files and text with Dropspot',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Create a room', text: 'Open Dropspot and click Create room. You get a 6-character code and a QR code.' },
    { '@type': 'HowToStep', position: 2, name: 'Share the code', text: 'Send the code, link or QR to anyone you want to share with — on any network.' },
    { '@type': 'HowToStep', position: 3, name: 'Join', text: 'The other person enters the code (or scans the QR) to join the same room instantly.' },
    { '@type': 'HowToStep', position: 4, name: 'Share', text: 'Paste text or links to sync instantly, or drop a file to share it with everyone in the room.' },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={[faqSchema, toolSchema, howToSchema]}>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style is:inline>
    /* ══════════════════════════════════════════════════════════
       Dropspot — "Refined" theme (Linear / Vercel-inspired)
       Flat near-black (dark) / near-white (light), faint grid,
       one restrained indigo accent, hairline borders, line icons.
       Light is the default; `html.dark` supplies the dark tokens.
       Scoped under .ds so nothing leaks into the site shell.
       ══════════════════════════════════════════════════════════ */
    .ds {
      /* light (default) */
      --bg: #f7f8fa;
      --panel: #ffffff;
      --panel-2: #f2f4f7;
      --border: rgba(9, 9, 11, 0.09);
      --border-2: rgba(9, 9, 11, 0.16);
      --border-grad: linear-gradient(180deg, rgba(9, 9, 11, 0.12), rgba(9, 9, 11, 0.045));
      --text: #15161a;
      --muted: #565c6a;
      --faint: #8b909d;
      --accent: #2563eb;
      --accent-hover: #1d4ed8;
      --accent-weak: rgba(37, 99, 235, 0.1);
      --accent-fg: #ffffff;
      --grad: var(--accent);
      --grad-shadow: 0 4px 12px rgba(37, 99, 235, 0.18);
      --ok: #0d9f6e;
      --danger: #dc2f45;
      --grid: rgba(9, 9, 11, 0.03);
      --shadow: 0 1px 2px rgba(9, 9, 11, 0.04), 0 8px 24px rgba(9, 9, 11, 0.06);
      --shadow-lg: 0 2px 4px rgba(9, 9, 11, 0.05), 0 16px 40px rgba(9, 9, 11, 0.09);
      --glow: radial-gradient(52% 40% at 50% -4%, rgba(37, 99, 235, 0.1), transparent 72%);

      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      color: var(--text);
      background: var(--bg);
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      -webkit-font-smoothing: antialiased;
    }
    html.dark .ds {
      --bg: #08090d;
      --panel: #101218;
      --panel-2: #171a22;
      --border: rgba(255, 255, 255, 0.08);
      --border-2: rgba(255, 255, 255, 0.16);
      --border-grad: linear-gradient(180deg, rgba(255, 255, 255, 0.17), rgba(255, 255, 255, 0.045));
      --text: #eaecf1;
      --muted: #969cab;
      --faint: #616776;
      --accent: #3b82f6;
      --accent-hover: #60a5fa;
      --accent-weak: rgba(59, 130, 246, 0.18);
      --grad: var(--accent);
      --grad-shadow: 0 4px 14px rgba(59, 130, 246, 0.28);
      --ok: #34d399;
      --danger: #f87171;
      --grid: rgba(255, 255, 255, 0.03);
      --shadow: 0 1px 2px rgba(0, 0, 0, 0.35), 0 10px 30px rgba(0, 0, 0, 0.4);
      --shadow-lg: 0 2px 6px rgba(0, 0, 0, 0.45), 0 24px 60px rgba(0, 0, 0, 0.55);
      --glow: radial-gradient(50% 38% at 50% -6%, rgba(59, 130, 246, 0.18), transparent 72%);
    }
    .ds * { box-sizing: border-box; }

    /* faint grid + soft accent glow */
    .ds::before {
      content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background-image: linear-gradient(var(--grid) 1px, transparent 1px), linear-gradient(90deg, var(--grid) 1px, transparent 1px);
      background-size: 36px 36px;
      -webkit-mask-image: radial-gradient(120% 80% at 50% 0%, #000 45%, transparent 100%);
      mask-image: radial-gradient(120% 80% at 50% 0%, #000 45%, transparent 100%);
    }
    .ds::after { content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none; background: var(--glow); }

    .ds-wrap { position: relative; z-index: 1; max-width: 860px; margin: 0 auto; padding: 44px 20px 80px; }

    /* accent icon tile */
    .ds-tile { width: 34px; height: 34px; border-radius: 9px; display: grid; place-items: center; color: #fff; background: var(--grad); box-shadow: var(--grad-shadow); flex: none; }
    .ds-tile .ico { width: 17px; height: 17px; stroke-width: 1.8; stroke: #fff; color: #fff; }

    .ds svg { display: block; }
    .ds .ico { width: 16px; height: 16px; stroke: currentColor; stroke-width: 1.6; fill: none; stroke-linecap: round; stroke-linejoin: round; flex: none; }
    .ds .ico-sm { width: 14px; height: 14px; }
    .ds .ico-lg { width: 22px; height: 22px; }

    /* ── Hero ── */
    .ds-badge {
      display: inline-flex; align-items: center; gap: 7px; padding: 4px 11px; border-radius: 7px;
      background: var(--panel-2); border: 1px solid var(--border);
      color: var(--muted); font-size: 12px; font-weight: 500; letter-spacing: 0.01em;
    }
    .ds-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
    .ds-hero { text-align: center; padding: 8px 0 30px; }
    .ds-hero h1 { font-size: clamp(2.3rem, 6vw, 3.4rem); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; margin: 22px 0 14px; color: var(--text); }
    .ds-hero h1 .g { color: var(--accent); }
    .ds-hero p { color: var(--muted); font-size: clamp(1rem, 2vw, 1.12rem); line-height: 1.6; max-width: 520px; margin: 0 auto; }

    /* feature strip */
    .ds-strip { display: grid; grid-template-columns: 1fr; gap: 10px; margin-top: 30px; text-align: left; }
    @media (min-width: 620px) { .ds-strip { grid-template-columns: repeat(3, 1fr); } }
    .ds-feat { display: flex; align-items: center; gap: 12px; padding: 14px 16px; }
    .ds-feat .ds-tile { width: 30px; height: 30px; border-radius: 8px; }
    .ds-feat .ds-tile .ico { width: 15px; height: 15px; }
    .ds-feat div b { display: block; font-size: 13px; font-weight: 500; color: var(--text); }
    .ds-feat div span { display: block; font-size: 12px; color: var(--muted); margin-top: 1px; }

    /* ── Panels (gradient-lit hairline border + elevation) ── */
    .ds-panel {
      position: relative; border: 1px solid transparent; border-radius: 14px;
      background: linear-gradient(var(--panel), var(--panel)) padding-box, var(--border-grad) border-box;
      box-shadow: var(--shadow);
    }

    /* ── Landing ── */
    .ds-landing { display: grid; gap: 16px; grid-template-columns: 1fr; }
    @media (min-width: 720px) { .ds-landing { grid-template-columns: 1fr 1fr; } }
    .ds-card { padding: 24px; }
    .ds-card h2 { font-size: 16px; font-weight: 600; margin: 0 0 4px; display: flex; align-items: center; gap: 11px; letter-spacing: -0.01em; }
    .ds-card .sub { color: var(--muted); font-size: 13px; margin: 2px 0 20px; line-height: 1.5; }

    .ds-field { margin-bottom: 16px; }
    .ds-field label { display: block; font-size: 12px; font-weight: 500; color: var(--muted); margin-bottom: 7px; }
    .ds-input, .ds-select {
      width: 100%; padding: 9px 12px; border-radius: 9px; background: var(--bg);
      border: 1px solid var(--border); color: var(--text); font-size: 14px; font-family: inherit;
      outline: none; transition: border-color .15s, box-shadow .15s;
    }
    html.dark .ds-input, html.dark .ds-select { background: var(--panel-2); }
    .ds-input::placeholder { color: var(--faint); }
    .ds-input:focus, .ds-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-weak); }
    .ds-input.code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; letter-spacing: 0.3em; text-transform: uppercase; text-align: center; font-size: 17px; font-weight: 600; }
    .ds-row { display: flex; gap: 12px; }
    .ds-row > * { flex: 1; }

    .ds-btn {
      width: 100%; padding: 10px 16px; border-radius: 9px; cursor: pointer; border: 1px solid transparent;
      font-family: inherit; font-weight: 500; font-size: 14px; color: #fff; background: var(--grad);
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      box-shadow: var(--grad-shadow); transition: transform .15s, box-shadow .15s, opacity .15s;
    }
    .ds-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(37, 99, 235, 0.32); filter: brightness(1.05); }
    .ds-btn:active { transform: translateY(0); }
    .ds-btn:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--accent-weak); }
    .ds-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }
    .ds-btn.ghost { background: var(--panel); color: var(--text); border-color: var(--border-2); box-shadow: var(--shadow); }
    .ds-btn.ghost:hover { background: var(--panel-2); transform: translateY(-1px); }
    .ds-btn.sm { width: auto; padding: 7px 13px; font-size: 13px; box-shadow: none; }
    .ds-btn.sm:not(.ghost) { box-shadow: var(--grad-shadow); }
    .ds-btn .ico { width: 15px; height: 15px; }

    /* optional PIN toggle */
    .ds-toggle { display: inline-flex; align-items: center; gap: 9px; cursor: pointer; user-select: none; color: var(--muted); font-size: 13px; margin-bottom: 16px; }
    .ds-toggle input { accent-color: var(--accent); width: 15px; height: 15px; }

    /* ── Room view ── */
    .ds-room { display: none; }
    .ds-room.active { display: block; }
    .ds-roomhead { padding: 22px; margin-bottom: 14px; display: grid; gap: 20px; grid-template-columns: 1fr; align-items: center; }
    @media (min-width: 600px) { .ds-roomhead { grid-template-columns: 1fr auto; } }
    .ds-codewrap .k { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--faint); font-weight: 600; }
    .ds-code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: clamp(1.7rem, 6vw, 2.3rem); font-weight: 600; letter-spacing: 0.18em; margin: 4px 0 12px; color: var(--text); }
    .ds-codebtns { display: flex; flex-wrap: wrap; gap: 8px; }
    .ds-qr { background: #fff; border-radius: 12px; padding: 8px; width: 108px; height: 108px; justify-self: center; border: 1px solid var(--border); }
    .ds-qr canvas, .ds-qr img { width: 100% !important; height: 100% !important; display: block; }

    .ds-meta { display: flex; flex-wrap: wrap; gap: 10px 24px; padding: 13px 20px; margin-bottom: 14px; font-size: 13px; color: var(--muted); align-items: center; }
    .ds-meta > span { display: inline-flex; align-items: center; gap: 7px; }
    .ds-meta .ico { color: var(--faint); }
    .ds-meta b { color: var(--text); font-weight: 500; }
    .ds-count { font-variant-numeric: tabular-nums; }

    .ds-warn { display: none; align-items: center; gap: 9px; padding: 10px 15px; margin-bottom: 14px; border-radius: 10px; background: var(--panel); border: 1px solid var(--border-2); color: var(--muted); font-size: 13px; }
    .ds-warn.show { display: flex; }
    .ds-warn .ico { color: var(--accent); }

    .ds-sect { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--faint); font-weight: 600; margin: 0 0 11px; }
    .ds-presence { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; min-height: 32px; }
    .ds-chip { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: 8px; background: var(--panel); border: 1px solid var(--border); font-size: 13px; color: var(--text); }
    .ds-chip .live { width: 6px; height: 6px; border-radius: 50%; background: var(--ok); }
    .ds-chip.me { border-color: var(--accent); }
    .ds-empty { color: var(--faint); font-size: 13px; padding: 2px 0; }

    /* composer */
    .ds-composer { padding: 18px; margin-bottom: 24px; }
    .ds-tabs { display: flex; gap: 4px; margin-bottom: 16px; background: var(--panel-2); padding: 4px; border-radius: 10px; width: fit-content; border: 1px solid var(--border); }
    .ds-tab { padding: 6px 13px; border-radius: 7px; background: transparent; border: none; color: var(--muted); cursor: pointer; font-size: 13px; font-weight: 500; font-family: inherit; display: inline-flex; align-items: center; gap: 7px; transition: color .15s, background .15s; }
    .ds-tab:hover { color: var(--text); }
    .ds-tab.active { color: var(--text); background: var(--panel); box-shadow: var(--shadow); }
    .ds-tab .ico { width: 15px; height: 15px; }
    .ds-composer textarea { width: 100%; min-height: 84px; resize: vertical; padding: 11px 13px; border-radius: 10px; background: var(--bg); border: 1px solid var(--border); color: var(--text); font-family: inherit; font-size: 14px; line-height: 1.5; outline: none; transition: border-color .15s, box-shadow .15s; }
    html.dark .ds-composer textarea { background: var(--panel-2); }
    .ds-composer textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-weak); }
    .ds-foot { display: flex; align-items: center; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
    .ds-foot .ds-select { flex: 0 0 auto; width: auto; padding: 7px 11px; font-size: 13px; }
    .ds-foot .ds-btn { width: auto; margin-left: auto; }

    .ds-drop { border: 1.5px dashed var(--border-2); border-radius: 12px; padding: 30px 20px; text-align: center; color: var(--muted); transition: border-color .15s, background .15s; cursor: pointer; }
    .ds-drop:hover, .ds-drop.hot { border-color: var(--accent); background: var(--accent-weak); }
    .ds-drop .ico-lg { margin: 0 auto 10px; color: var(--faint); }
    .ds-drop .hint { font-size: 12px; color: var(--faint); margin-top: 6px; }

    /* icon buttons (shared by items, files, received) */
    .ds-iconbtn { width: 30px; height: 30px; border-radius: 7px; border: 1px solid transparent; background: transparent; color: var(--muted); cursor: pointer; display: grid; place-items: center; transition: color .15s, background .15s, border-color .15s; }
    .ds-iconbtn:hover { color: var(--text); background: var(--panel-2); border-color: var(--border); }
    .ds-iconbtn.danger:hover { color: var(--danger); border-color: var(--border); }

    /* ── Shared-in-room category boxes (Files / Text / Links) ── */
    .ds-cats { display: flex; flex-direction: column; gap: 14px; }
    .ds-cat { padding: 16px 16px 18px; }
    .ds-cat-head { display: flex; align-items: center; gap: 10px; margin-bottom: 13px; }
    .ds-cat-head .ds-tile { width: 28px; height: 28px; border-radius: 8px; }
    .ds-cat-head .ds-tile .ico { width: 14px; height: 14px; }
    .ds-cat-head .lbl { font-size: 14px; font-weight: 600; letter-spacing: -0.01em; color: var(--text); }
    .ds-cat-head .cnt { margin-left: auto; font-size: 11px; font-weight: 600; color: var(--muted); background: var(--panel-2); border: 1px solid var(--border); border-radius: 999px; padding: 2px 9px; font-variant-numeric: tabular-nums; }
    /* files header: select-all + download-selected */
    .ds-catacts { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .ds-catacts .ds-btn.sm { width: auto; box-shadow: none; }
    .ds-selall { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; color: var(--muted); cursor: pointer; user-select: none; }
    .ds-check { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; margin: 0; flex: none; }
    .ds-sub.file .fh .fsel { margin-top: 1px; }
    .ds-sub.file.sel { border-color: var(--accent); background: var(--accent-weak); }
    /* files → responsive grid of small boxes; text/links → stacked boxes */
    .ds-catgrid { display: grid; gap: 10px; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); }
    .ds-catlist { display: flex; flex-direction: column; gap: 10px; }
    .ds-sub { position: relative; border: 1px solid var(--border); border-radius: 11px; background: var(--panel-2); padding: 13px; transition: border-color .15s; }
    html.dark .ds-sub { background: var(--bg); }
    .ds-sub:hover { border-color: var(--border-2); }
    /* file sub-box: icon on top, name, meta, download button */
    .ds-sub.file { display: flex; flex-direction: column; gap: 9px; }
    .ds-sub.file .fh { display: flex; align-items: flex-start; gap: 10px; }
    .ds-sub.file .fic { flex: none; width: 34px; height: 34px; border-radius: 9px; display: grid; place-items: center; background: var(--accent-weak); color: var(--accent); border: 1px solid var(--border); }
    .ds-sub.file .fmeta { flex: 1; min-width: 0; }
    .ds-sub.file .nm { font-size: 13px; font-weight: 500; color: var(--text); word-break: break-word; line-height: 1.35; }
    .ds-sub.file .sz { font-size: 11.5px; color: var(--faint); margin-top: 2px; font-variant-numeric: tabular-nums; }
    .ds-sub.file .fbtns { display: flex; gap: 8px; margin-top: 1px; }
    .ds-sub.file .fbtns .ds-btn.sm { flex: 1; box-shadow: none; }
    .ds-sub.file .fbtns .ds-iconbtn { flex: none; }
    /* text/link sub-box: content + footer row */
    .ds-sub.tl { display: flex; gap: 12px; align-items: flex-start; }
    .ds-sub.tl .tic { flex: none; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; background: var(--panel); color: var(--muted); border: 1px solid var(--border); }
    .ds-sub.tl .tbody { flex: 1; min-width: 0; }
    .ds-sub.tl .txt { font-size: 14px; word-break: break-word; white-space: pre-wrap; line-height: 1.5; color: var(--text); margin: 0; }
    .ds-sub.tl a.txt { color: var(--accent); text-decoration: none; }
    .ds-sub.tl a.txt:hover { text-decoration: underline; }
    .ds-sub.tl .sub { font-size: 11.5px; color: var(--faint); font-variant-numeric: tabular-nums; margin-top: 5px; }
    .ds-sub.tl .acts { flex: none; display: flex; gap: 4px; }
    .ds-catempty { color: var(--faint); font-size: 12.5px; padding: 2px 0 1px; }

    /* toast */
    .ds-toasts { position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%); z-index: 60; display: flex; flex-direction: column; gap: 8px; align-items: center; }
    .ds-toast { display: flex; align-items: center; gap: 8px; padding: 9px 15px; border-radius: 9px; background: var(--panel); border: 1px solid var(--border-2); color: var(--text); font-size: 13px; box-shadow: var(--shadow); animation: ds-in .18s ease; }
    .ds-toast .ico { color: var(--accent); }
    @keyframes ds-in { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

    /* FAQ */
    .ds-faq { margin-top: 44px; }
    .ds-faq h2 { font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 16px; }
    .ds-faq details { padding: 15px 18px; margin-bottom: 8px; }
    .ds-faq summary { cursor: pointer; font-weight: 500; font-size: 14px; list-style: none; display: flex; justify-content: space-between; gap: 12px; align-items: center; }
    .ds-faq summary::-webkit-details-marker { display: none; }
    .ds-faq summary .chev { color: var(--faint); transition: transform .18s; }
    .ds-faq details[open] summary .chev { transform: rotate(180deg); }
    .ds-faq details p { color: var(--muted); font-size: 13.5px; line-height: 1.65; margin: 12px 0 0; }

    /* transfers */
    .ds-transfers { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
    .ds-xfer { padding: 13px 15px; }
    .ds-xfer .top { display: flex; align-items: center; gap: 11px; }
    .ds-xfer .ic { flex: none; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; background: var(--panel-2); border: 1px solid var(--border); color: var(--muted); }
    .ds-xfer .nm { flex: 1; min-width: 0; font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ds-xfer .tag { flex: none; font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 6px; background: var(--accent-weak); color: var(--accent); }
    .ds-xfer .st { flex: none; font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; }
    .ds-xfer-cancel { flex: none; width: 26px; height: 26px; border-radius: 7px; display: grid; place-items: center; background: transparent; border: 1px solid var(--border); color: var(--muted); cursor: pointer; margin-left: 2px; transition: color .15s, border-color .15s; }
    .ds-xfer-cancel:hover { color: var(--danger); border-color: var(--danger); }
    .ds-xfer-cancel .ico { width: 13px; height: 13px; }
    .ds-bar { height: 5px; border-radius: 999px; background: var(--panel-2); overflow: hidden; margin-top: 11px; }
    .ds-bar > i { display: block; height: 100%; width: 0%; background: var(--grad); border-radius: 999px; transition: width .25s ease; }
    .ds-bar.err > i { background: var(--danger); }
    .ds-bar.ok > i { background: var(--ok); }
    /* completed rows fade out — the file then lives in the Files box below */
    .ds-xfer.gone { opacity: 0; transform: translateY(-4px); max-height: 0; padding-top: 0; padding-bottom: 0; margin: 0; overflow: hidden; transition: opacity .3s ease, transform .3s ease, max-height .35s ease, padding .35s ease; }

    /* room storage capacity bar */
    .ds-cap { margin-bottom: 20px; }
    .ds-cap-row { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 7px; }
    .ds-cap-lbl { font-size: 12.5px; font-weight: 600; color: var(--text); }
    .ds-cap-nums { font-size: 11.5px; color: var(--faint); font-variant-numeric: tabular-nums; text-align: right; }
    .ds-cap-track { height: 7px; border-radius: 999px; background: var(--panel-2); border: 1px solid var(--border); overflow: hidden; }
    .ds-cap-track > i { display: block; height: 100%; width: 0%; background: var(--accent); border-radius: 999px; transition: width .3s ease; }
    .ds-cap.full .ds-cap-track > i { background: var(--danger); }
    .ds-cap.full .ds-cap-nums { color: var(--danger); }

    /* received files (user-initiated download + multi-select zip) */
    .ds-hidden { display: none !important; }
    @media (prefers-reduced-motion: reduce) { .ds * { animation: none !important; transition: none !important; } }
  </style>

  <div class="ds">
    <div class="ds-wrap">
      <!-- Hero -->
      <header class="ds-hero">
