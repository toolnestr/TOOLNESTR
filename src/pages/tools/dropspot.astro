    function fileCategory(files) {
      const box = catBox('file', 'Files', files.length);
      const cards = []; // { f, cb, card } — for select-all to drive each card
      // ── Header actions: select-all + download-selected (zips when 2+ chosen) ──
      const acts = document.createElement('div'); acts.className = 'ds-catacts';
