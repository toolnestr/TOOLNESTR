  <script>
    // QR library is loaded lazily (only when a room opens) so a slow/blocked
    // CDN can never stop the core create/join/share flow from working.
    let _qrLib = null;
    function loadQR() {
      if (!_qrLib) _qrLib = import('https://esm.sh/qrcode@1.5.4').then((m) => m.default).catch(() => null);
      return _qrLib;
    }

    // ── Line-icon set (Lucide-style, stroke 1.6) ──
    const ICONS = {
      copy: '<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>',
      download: '<path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>',
      trash: '<path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m2 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6"/>',
      text: '<path d="M4 7V4h16v3M9 20h6M12 4v16"/>',
      link: '<path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>',
      file: '<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/>',
      check: '<path d="M20 6L9 17l-5-5"/>',
      up: '<path d="M12 19V5M5 12l7-7 7 7"/>',
      down: '<path d="M12 5v14M19 12l-7 7-7-7"/>',
    };
    function iconSvg(name, cls) {
      return '<svg class="ico ' + (cls || '') + '" viewBox="0 0 24 24">' + (ICONS[name] || '') + '</svg>';
    }

    // ── Config ──
    const isLocal = /^(localhost|127\.0\.0\.1)$/.test(location.hostname);
    const API = (isLocal ? 'http://127.0.0.1:8799' : 'https://toolnestr-dropspot.toolnestr.workers.dev') + '/api';

    function uid() { try { return crypto.randomUUID().replace(/-/g, ''); } catch { return String(Math.random()).slice(2) + Date.now(); } }
    const DEVICE_ID = (() => { let v = localStorage.getItem('dropspot_device_id'); if (!v) { v = uid(); localStorage.setItem('dropspot_device_id', v); } return v; })();
    const DEVICE_LABEL = (() => {
      let v = localStorage.getItem('dropspot_device_label');
      if (!v) { const a = ['Falcon','Otter','Lynx','Heron','Fox','Wren','Ibex','Koi']; v = a[Math.floor(Math.random()*a.length)] + '-' + Math.floor(Math.random()*900+100); localStorage.setItem('dropspot_device_label', v); }
      return v;
    })();

    const state = { code: null, pin: null, room: null, lastData: null, hbTimer: null, pollTimer: null, cdTimer: null, wasHidden: false, expiresAt: 0, presenceList: [], xfers: {}, skew: 0, deletedIds: new Set(), optimistic: {}, optimisticFiles: {}, selectedFiles: new Set(), lastFiles: [] };
    const $ = (id) => document.getElementById(id);
    const els = {
      landing: $('landing'), room: $('room'), createBtn: $('createBtn'), joinBtn: $('joinBtn'),
      pinToggle: $('pinToggle'), pinField: $('pinField'), createPin: $('createPin'),
      createTtl: $('createTtl'), createMax: $('createMax'),
      joinCode: $('joinCode'), joinPin: $('joinPin'), joinPinField: $('joinPinField'),
      roomCode: $('roomCode'), qr: $('qr'), copyCodeBtn: $('copyCodeBtn'), copyLinkBtn: $('copyLinkBtn'), leaveBtn: $('leaveBtn'),
      metaPin: $('metaPin'), metaExpiry: $('metaExpiry'), metaDevices: $('metaDevices'),
      bgWarn: $('bgWarn'), presence: $('presence'), items: $('items'),
      textInput: $('textInput'), linkInput: $('linkInput'), itemTtl: $('itemTtl'),
      shareBtn: $('shareBtn'), toasts: $('toasts'), drop: $('drop'), fileInput: $('fileInput'), dropLabel: $('dropLabel'),
    };
    let activeTab = 'text';

    function toast(msg, icon) {
      const t = document.createElement('div'); t.className = 'ds-toast';
      t.innerHTML = iconSvg(icon || 'check') + '<span></span>';
      t.querySelector('span').textContent = msg;
      els.toasts.appendChild(t);
      setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity .25s'; setTimeout(() => t.remove(), 260); }, 2600);
    }
    async function api(path, opts) {
      const headers = Object.assign({ 'Content-Type': 'application/json' }, (opts && opts.headers) || {});
      if (state.pin) headers['X-Room-Pin'] = state.pin;
      const res = await fetch(API + path, Object.assign({}, opts, { headers }));
      let data = null; try { data = await res.json(); } catch {}
      if (!res.ok) throw Object.assign(new Error((data && data.error) || 'error'), { status: res.status, data });
      return data;
    }
    function nowSec() { return Math.floor(Date.now() / 1000); }
    // Server-authoritative clock so every device shows the same countdowns
    // regardless of local clock skew.
    function serverNow() { return nowSec() + state.skew; }
    function fmtDuration(sec) {
      if (sec <= 0) return 'expired';
      const d = Math.floor(sec/86400), h = Math.floor((sec%86400)/3600), m = Math.floor((sec%3600)/60), s = sec%60;
      if (d) return d + 'd ' + h + 'h'; if (h) return h + 'h ' + m + 'm';
      if (m) return m + 'm ' + String(s).padStart(2,'0') + 's'; return s + 's';
    }
    function fmtSize(b) { if (b < 1024) return b + ' B'; if (b < 1048576) return (b/1024).toFixed(1) + ' KB'; return (b/1048576).toFixed(1) + ' MB'; }

    // ── Create / Join ──
    els.pinToggle.addEventListener('change', () => els.pinField.classList.toggle('ds-hidden', !els.pinToggle.checked));
    els.createBtn.addEventListener('click', async () => {
      els.createBtn.disabled = true; els.createBtn.textContent = 'Creating…';
      try {
        const body = { ttl_seconds: Number(els.createTtl.value), default_ttl_seconds: Number(els.createTtl.value), max_devices: Number(els.createMax.value) };
        if (els.pinToggle.checked && els.createPin.value) body.pin = els.createPin.value;
        const data = await api('/room', { method: 'POST', body: JSON.stringify(body) });
        state.pin = body.pin || null;
        // Use the create response directly — a GET here would race KV's
        // read-after-write lag and 404 on a room that definitely exists.
        await enterRoom(data.room.code, { room: data.room, items: [], files: [], presence: [], server_time: data.room.created_at });
      } catch { toast('Could not create room. Is the service reachable?', 'trash'); }
      finally { els.createBtn.disabled = false; els.createBtn.textContent = 'Create room'; }
    });
    els.joinCode.addEventListener('input', () => { els.joinCode.value = els.joinCode.value.toUpperCase().replace(/[^A-Z0-9]/g, ''); });
    els.joinBtn.addEventListener('click', () => attemptJoin());
    els.joinCode.addEventListener('keydown', (e) => { if (e.key === 'Enter') attemptJoin(); });
    els.joinPin.addEventListener('keydown', (e) => { if (e.key === 'Enter') attemptJoin(); });
    async function attemptJoin() {
      const code = els.joinCode.value.trim().toUpperCase();
      if (code.length < 6) { toast('Enter a valid 6-character code.', 'trash'); return; }
      state.pin = els.joinPin.value || null;
      els.joinBtn.disabled = true; els.joinBtn.textContent = 'Joining…';
      try { await enterRoom(code); }
      catch (e) {
        if (e.status === 401) { els.joinPinField.classList.remove('ds-hidden'); toast('This room needs a PIN.', 'file'); }
        else if (e.status === 404) toast('Room not found or expired.', 'trash');
        else if (e.status === 429) toast('Too many attempts — wait a minute.', 'trash');
        else toast('Could not join room.', 'trash');
      } finally { els.joinBtn.disabled = false; els.joinBtn.textContent = 'Join room'; }
    }
    async function enterRoom(code, initialData) {
      state.code = code;
      let data = initialData;
      if (!data) {
        // Cloudflare KV is eventually consistent: a room GET right after its
        // creation can hit a replica without the write yet (404). Retry a few
        // times before giving up so create/rejoin don't spuriously fail.
        for (let i = 0; i < 4; i++) {
          try { data = await api('/room/' + code); break; }
          catch (e) { if (e.status === 404 && i < 3) { await new Promise((r) => setTimeout(r, 600)); continue; } throw e; }
        }
      }
      state.room = data;
      els.landing.classList.add('ds-hidden');
      els.room.classList.add('active');
      els.roomCode.textContent = code;
      renderQR(code); applyState(data); startLoops();
      const url = new URL(location.href); url.searchParams.set('room', code); history.replaceState({}, '', url);
      // Persist so a refresh rejoins the same room instead of dropping to landing.
      try { sessionStorage.setItem('dropspot_room', JSON.stringify({ code, pin: state.pin || null })); } catch {}
      toast('You are in room ' + code);
    }
    function renderQR(code) {
      const url = location.origin + location.pathname + '?room=' + code;
      els.qr.innerHTML = '';
      const canvas = document.createElement('canvas'); els.qr.appendChild(canvas);
      loadQR().then((QRCode) => {
        if (!QRCode) { els.qr.innerHTML = ''; return; }
        QRCode.toCanvas(canvas, url, { width: 200, margin: 1, color: { dark: '#0a0b0f', light: '#ffffff' } }, (err) => { if (err) els.qr.innerHTML = ''; });
      });
    }

    // ── Render ──
    function applyState(data) {
      state.lastData = data; state.room = data; const room = data.room;
      // Track server↔local clock offset for skew-free countdowns.
      if (typeof data.server_time === 'number') state.skew = data.server_time - nowSec();
      els.metaPin.textContent = room.has_pin ? 'PIN protected' : 'Open';
      els.metaDevices.textContent = String((data.presence || []).length);
      renderPresence(data.presence || []);
      renderMerged();
      renderCapacity();
      state.expiresAt = room.expires_at; updateCountdown();
    }
    // Room storage budget bar — how much of the 100 MB room cap is used, and
    // how much is left for new uploads. Server sends `storage` in GET /room.
    function renderCapacity() {
      const el = $('capBar'); if (!el) return;
      const st = state.lastData && state.lastData.storage;
      if (!st || !st.max) { el.style.display = 'none'; return; }
      el.style.display = '';
      const used = Math.min(st.used, st.max);
      const pct = Math.min(100, Math.round((used / st.max) * 100));
      $('capFill').style.width = pct + '%';
      el.classList.toggle('full', pct >= 90);
      $('capNums').textContent = fmtSize(used) + ' of ' + fmtSize(st.max) + ' used · ' + fmtSize(Math.max(0, st.max - used)) + ' free';
    }
    // Merge the server snapshot with the user's optimistic add/delete ops so
    // their own actions feel instant despite KV read-after-write lag.
    function renderMerged() {
      const data = state.lastData || { items: [], files: [] };
      const serverItems = data.items || [];
      const serverFiles = data.files || [];
      const serverItemIds = new Set(serverItems.map((i) => i.id));
      const serverFileIds = new Set(serverFiles.map((f) => f.id));
      // forget delete-markers once the server has actually dropped the item OR
      // file (checking BOTH arrays — otherwise a deleted file's marker gets
      // pruned while it's still in the snapshot and the file flickers back).
      for (const id of [...state.deletedIds]) if (!serverItemIds.has(id) && !serverFileIds.has(id)) state.deletedIds.delete(id);
      const items = serverItems.filter((i) => !state.deletedIds.has(i.id));
      // keep optimistic items until the server starts returning them
      for (const id in state.optimistic) {
        if (serverItemIds.has(id) || state.deletedIds.has(id)) delete state.optimistic[id];
        else items.push(state.optimistic[id]);
      }
      const files = serverFiles.filter((f) => !state.deletedIds.has(f.id));
      // keep just-uploaded R2 files visible until the server snapshot includes them
      for (const id in state.optimisticFiles) {
        if (serverFileIds.has(id) || state.deletedIds.has(id)) delete state.optimisticFiles[id];
        else files.push(state.optimisticFiles[id]);
      }
      // drop selections for files that no longer exist (deleted / expired)
      const presentFileIds = new Set(files.map((f) => f.id));
