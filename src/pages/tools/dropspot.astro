      const grid = document.createElement('div'); grid.className = 'ds-catgrid';
      files.forEach((f) => {
        const card = document.createElement('div'); card.className = 'ds-sub file';
        const fh = document.createElement('div'); fh.className = 'fh';
        const cb = document.createElement('input'); cb.type = 'checkbox'; cb.className = 'ds-check fsel';
