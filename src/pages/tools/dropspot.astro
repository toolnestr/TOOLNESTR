    }
    function textLinkCategory(kind, label, list) {
      const box = catBox(kind, label, list.length);
      const cont = document.createElement('div'); cont.className = 'ds-catlist';
      list.forEach((i) => {
        const card = document.createElement('div'); card.className = 'ds-sub tl';
