      const syncUI = () => {
        const n = state.selectedFiles.size;
        dlBtn.querySelector('span').textContent = n >= 2 ? ('Download ' + n + ' as zip') : (n === 1 ? 'Download 1' : 'Download selected');
        dlBtn.disabled = n === 0;
