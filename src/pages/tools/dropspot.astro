        else { const p = document.createElement('div'); p.className = 'txt'; p.textContent = i.content; body.appendChild(p); }
        const sub = document.createElement('div'); sub.className = 'sub'; sub.textContent = 'expires ' + fmtDuration(i.expires_at - serverNow());
        body.appendChild(sub);
        const acts = document.createElement('div'); acts.className = 'acts';
        acts.appendChild(iconBtn('copy', 'Copy', () => { navigator.clipboard.writeText(i.content); toast('Copied'); }));
        acts.appendChild(iconBtn('trash', 'Delete', () => deleteItem('item', i.id), true));
