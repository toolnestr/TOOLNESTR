    function iconBtn(name, title, onClick, danger) {
      const b = document.createElement('button'); b.className = 'ds-iconbtn' + (danger ? ' danger' : ''); b.title = title;
      b.setAttribute('aria-label', title); b.innerHTML = iconSvg(name); b.addEventListener('click', onClick); return b;
    }
    function downloadFile(f) {
      const a = document.createElement('a');
      fetch(API + '/room/' + state.code + '/file/' + f.id, { headers: state.pin ? { 'X-Room-Pin': state.pin } : {} })
        .then((r) => r.blob())
        .then((blob) => { const u = URL.createObjectURL(blob); a.href = u; a.download = f.filename; a.click(); setTimeout(() => URL.revokeObjectURL(u), 4000); })
        .catch(() => toast('Download failed', 'trash'));
    }
    // Fetch a file's bytes while streaming the response body so we can report
    // real download progress (calling onBytes as chunks arrive) instead of only
    // jumping when each whole file finishes.
    async function fetchBlobWithProgress(f, onBytes, signal) {
      const res = await fetch(API + '/room/' + state.code + '/file/' + f.id, { headers: state.pin ? { 'X-Room-Pin': state.pin } : {}, signal });
      if (!res.ok) throw new Error('dl');
      if (!res.body || !res.body.getReader) return res.blob(); // no streaming support → still completes
      const reader = res.body.getReader(); const chunks = [];
      for (;;) {
        const { done, value } = await reader.read();
        if (done) break;
        chunks.push(value); if (value) onBytes(value.length);
      }
      return new Blob(chunks);
    }
    function triggerDownload(blob, name) {
      const a = document.createElement('a'); const u = URL.createObjectURL(blob);
      a.href = u; a.download = name; document.body.appendChild(a); a.click(); a.remove();
      setTimeout(() => URL.revokeObjectURL(u), 6000);
    }
    // fflate is loaded lazily from esm.sh only when a multi-file zip is needed
    // (CSP script-src already allows esm.sh). If it can't load, we fall back to
    // downloading each file individually so the action never silently fails.
    let _zipLib = null;
    function loadZip() { if (!_zipLib) _zipLib = import('https://esm.sh/fflate@0.8.2').then((m) => m).catch(() => null); return _zipLib; }
    // Async zip so the main thread doesn't freeze on large sets (fflate.zip runs
    // in a worker — CSP worker-src allows blob:). Falls back to sync zipSync.
    function zipEntries(fflate, entries) {
      return new Promise((res, rej) => {
        if (fflate.zip) fflate.zip(entries, { level: 0 }, (err, data) => (err ? rej(err) : res(data)));
        else res(fflate.zipSync(entries, { level: 0 }));
      });
    }
    // Building a zip means downloading every selected file, then packing them —
    // all before the browser save dialog appears. Show a progress row for that
    // whole phase so it doesn't look frozen and then "pop" fully downloaded.
    async function downloadSelectedFiles() {
      const sel = (state.lastFiles || []).filter((f) => state.selectedFiles.has(f.id));
      if (!sel.length) return;
      if (sel.length === 1) { downloadFile(sel[0]); return; }
      const id = xid();
      const ctrl = new AbortController(); let cancelled = false;
      addTransfer(id, sel.length + ' files → zip', 'down', 'Zip', () => { cancelled = true; ctrl.abort(); });
      setTransfer(id, 0, 'Downloading…');
      try {
        const total = sel.reduce((s, f) => s + (f.size || 0), 0) || 1;
        let downloaded = 0, lastPct = -1; const blobs = [];
        for (let i = 0; i < sel.length; i++) {
          blobs.push(await fetchBlobWithProgress(sel[i], (n) => {
            downloaded += n;
            const pct = Math.min(90, Math.round((downloaded / total) * 90));
            if (pct !== lastPct) { lastPct = pct; setTransfer(id, pct, 'Downloading ' + fmtSize(downloaded) + ' / ' + fmtSize(total)); }
          }, ctrl.signal));
        }
        const fflate = await loadZip();
        if (!fflate || !(fflate.zip || fflate.zipSync)) { removeTransfer(id); sel.forEach(downloadFile); return; } // esm.sh blocked → individual downloads
        setTransfer(id, 93, 'Zipping…');
        const entries = {}; const counts = {};
        for (let i = 0; i < sel.length; i++) {
          const orig = sel[i].filename; let name = orig;
          if (counts[orig]) { const dot = orig.lastIndexOf('.'); name = dot > 0 ? orig.slice(0, dot) + '-' + counts[orig] + orig.slice(dot) : orig + '-' + counts[orig]; }
          counts[orig] = (counts[orig] || 0) + 1;
          entries[name] = new Uint8Array(await blobs[i].arrayBuffer());
        }
        const zipped = await zipEntries(fflate, entries);
        setTransfer(id, 100, 'Downloaded', 'ok');
        triggerDownload(new Blob([zipped], { type: 'application/zip' }), 'dropspot-files.zip');
      } catch {
        if (cancelled) { removeTransfer(id); toast('Download cancelled', 'trash'); }
        else setTransfer(id, 100, 'Download failed', 'err');
      }
    }
    async function deleteItem(kind, id) {
      // Optimistic: hide immediately, then confirm with the server. The DELETE
      // route removes from BOTH the items and files arrays (and the R2 object),
      // so the same call works for text, links and stored files.
      state.deletedIds.add(id); delete state.optimistic[id]; delete state.optimisticFiles[id]; renderMerged();
      try {
        await api('/room/' + state.code + '/item/' + id, { method: 'DELETE' });
        toast('Deleted'); refresh();
      } catch {
        state.deletedIds.delete(id); renderMerged(); toast('Could not delete', 'trash');
      }
    }

    // ── Composer ──
    document.querySelectorAll('.ds-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        activeTab = tab.getAttribute('data-tab');
        document.querySelectorAll('.ds-tab').forEach((t) => t.classList.toggle('active', t === tab));
        document.querySelectorAll('[data-pane]').forEach((p) => p.classList.toggle('ds-hidden', p.getAttribute('data-pane') !== activeTab));
        $('composerFoot').style.display = activeTab === 'file' ? 'none' : 'flex';
      });
    });
    els.shareBtn.addEventListener('click', shareCurrent);
    els.textInput.addEventListener('keydown', (e) => { if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') shareCurrent(); });
    els.linkInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') shareCurrent(); });
    async function shareCurrent() {
      const kind = activeTab === 'link' ? 'link' : 'text';
      const content = (kind === 'link' ? els.linkInput.value : els.textInput.value).trim();
      if (!content) { toast('Nothing to share.', 'trash'); return; }
      if (kind === 'link' && !/^https?:\/\//i.test(content)) { toast('Links must start with http:// or https://', 'trash'); return; }
      const body = { kind, content, device_id: DEVICE_ID };
      if (els.itemTtl.value) body.ttl_seconds = Number(els.itemTtl.value);
      els.shareBtn.disabled = true;
      try {
        const resp = await api('/room/' + state.code + '/item', { method: 'POST', body: JSON.stringify(body) });
        els.textInput.value = ''; els.linkInput.value = '';
        if (resp && resp.item) { state.optimistic[resp.item.id] = resp.item; renderMerged(); } // instant
        toast('Shared'); refresh();
      }
      catch (e) { toast(e.data && e.data.error === 'content_too_long' ? 'That is too long.' : 'Could not share.', 'trash'); }
      finally { els.shareBtn.disabled = false; }
    }
    els.drop.addEventListener('click', () => els.fileInput.click());
    ['dragover','dragenter'].forEach((ev) => els.drop.addEventListener(ev, (e) => { e.preventDefault(); els.drop.classList.add('hot'); }));
    ['dragleave','drop'].forEach((ev) => els.drop.addEventListener(ev, (e) => { e.preventDefault(); els.drop.classList.remove('hot'); }));
    els.drop.addEventListener('drop', (e) => { for (const f of e.dataTransfer.files) onFilePicked(f); });
    els.fileInput.addEventListener('change', () => { for (const f of els.fileInput.files) onFilePicked(f); els.fileInput.value = ''; });

    // ════════════════════════════════════════════════════════════
    //  File transfer — R2 upload (secure storage, shared with everyone)
    // ════════════════════════════════════════════════════════════
    const MAX_R2 = 52428800;             // 50 MB per-file cap (must match worker MAX_FILE_BYTES)
    function xid() { return 'x' + Math.random().toString(36).slice(2, 9); }

    // R2-only file sharing: every file goes to secure storage — up to 50 MB per
    // file, 100 MB per room. One reliable path that works on any network, shows
    // for everyone in the room, and persists briefly. (No peer-to-peer.)
    function onFilePicked(file) {
      if (!state.code) return;
      if (file.size > MAX_R2) { toast('Files must be 50 MB or smaller.', 'trash'); return; }
      // Instant client-side room-capacity guard (the server enforces it too).
      const st = state.lastData && state.lastData.storage;
      if (st && st.used + file.size > st.max) {
        toast('Room is full (' + fmtSize(st.max) + '). Delete a file to free space.', 'trash'); return;
      }
      sendFileR2(file, xid());
    }

    // ── Upload progress rows (fade out once done — the file then lives in the
    //    Files box below, so rows don't stack up and bury the shared content) ──
    function addTransfer(id, name, dir, tag, onCancel) {
      if (state.xfers[id]) return state.xfers[id];
      $('xferSect').style.display = '';
      const el = document.createElement('div'); el.className = 'ds-panel ds-xfer';
      el.innerHTML =
        '<div class="top"><span class="ic">' + iconSvg(dir) + '</span>' +
        '<span class="nm"></span><span class="tag"></span><span class="st"></span></div>' +
        '<div class="ds-bar"><i></i></div>';
      el.querySelector('.nm').textContent = name;
      el.querySelector('.tag').textContent = tag;
      const rec = { el, bar: el.querySelector('.ds-bar'), fill: el.querySelector('.ds-bar > i'), st: el.querySelector('.st'), cancelBtn: null };
      if (onCancel) {
        const x = document.createElement('button'); x.className = 'ds-xfer-cancel'; x.title = 'Cancel'; x.setAttribute('aria-label', 'Cancel');
        x.innerHTML = '<svg class="ico" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>';
        x.addEventListener('click', onCancel);
        el.querySelector('.top').appendChild(x); rec.cancelBtn = x;
      }
      document.getElementById('transfers').prepend(el);
      state.xfers[id] = rec; return rec;
    }
    function setTransfer(id, pct, status, kind) {
      const r = state.xfers[id]; if (!r) return;
      if (pct != null) r.fill.style.width = pct + '%';
      if (status != null) r.st.textContent = status;
      r.bar.classList.toggle('err', kind === 'err');
      r.bar.classList.toggle('ok', kind === 'ok');
      // once finished (ok/err) it's no longer cancellable — drop the X
      if ((kind === 'ok' || kind === 'err') && r.cancelBtn) { r.cancelBtn.remove(); r.cancelBtn = null; }
      if (kind === 'ok') setTimeout(() => removeTransfer(id), 2200); // failures stay put
    }
    function removeTransfer(id) {
      const r = state.xfers[id]; if (!r) return;
      delete state.xfers[id];
      r.el.classList.add('gone');
      setTimeout(() => {
        try { r.el.remove(); } catch {}
        if (!Object.keys(state.xfers).length) $('xferSect').style.display = 'none';
      }, 380);
    }

    // ── R2 upload (streamed, with progress) ──
    function sendFileR2(file, id) {
      addTransfer(id, file.name, 'up', 'Stored');
      if (file.size > MAX_R2) { setTransfer(id, 100, 'Too large — 50 MB max', 'err'); return; }
      setTransfer(id, 0, 'Uploading…');
      const xhr = new XMLHttpRequest();
      const url = API + '/room/' + state.code + '/file?filename=' + encodeURIComponent(file.name) + '&device_id=' + DEVICE_ID;
      xhr.open('POST', url);
      xhr.setRequestHeader('Content-Type', file.type || 'application/octet-stream');
      if (state.pin) xhr.setRequestHeader('X-Room-Pin', state.pin);
      xhr.upload.onprogress = (e) => { if (e.lengthComputable) setTransfer(id, Math.round(e.loaded / e.total * 90), 'Uploading…'); };
      xhr.onload = () => {
        if (xhr.status >= 200 && xhr.status < 300) {
          setTransfer(id, 100, 'Stored', 'ok');
          // Show the file in "Shared in this room" immediately — KV can lag a
          // few seconds behind this write, so don't wait for the next poll.
          try { const r = JSON.parse(xhr.responseText); if (r && r.file) { state.optimisticFiles[r.file.id] = r.file; renderMerged(); } } catch {}
          refresh();
        }
        else if (xhr.status === 413) setTransfer(id, 100, 'Too large — 50 MB max', 'err');
        else if (xhr.status === 409) { setTransfer(id, 100, 'Room storage full', 'err'); toast('Room is full — delete a file to free space.', 'trash'); }
        else setTransfer(id, 100, 'Upload failed', 'err');
      };
      xhr.onerror = () => setTransfer(id, 100, 'Upload failed', 'err');
      xhr.send(file);
    }

    // ── Copy / leave ──
    els.copyCodeBtn.addEventListener('click', () => { navigator.clipboard.writeText(state.code); toast('Code copied'); });
    els.copyLinkBtn.addEventListener('click', () => { navigator.clipboard.writeText(location.origin + location.pathname + '?room=' + state.code); toast('Join link copied'); });
    els.leaveBtn.addEventListener('click', leaveRoom);
    function leaveRoom() {
      stopLoops(); state.code = null; state.pin = null; state.room = null; state.lastData = null;
      state.skew = 0; state.deletedIds = new Set(); state.optimistic = {}; state.optimisticFiles = {}; state.xfers = {}; state.selectedFiles = new Set(); state.lastFiles = [];
      try { sessionStorage.removeItem('dropspot_room'); } catch {}
      const tf = document.getElementById('transfers'); if (tf) tf.innerHTML = '';
      const xs = document.getElementById('xferSect'); if (xs) xs.style.display = 'none';
      els.room.classList.remove('active'); els.landing.classList.remove('ds-hidden');
      const url = new URL(location.href); url.searchParams.delete('room'); history.replaceState({}, '', url);
    }

    // ── Heartbeat + polling (Page Visibility aware) ──
    async function heartbeat() {
      if (document.hidden || !state.code) return;
      try {
        const data = await api('/room/' + state.code + '/heartbeat', { method: 'POST', body: JSON.stringify({ device_id: DEVICE_ID, label: DEVICE_LABEL, foreground: !document.hidden }) });
        if (data && data.presence) { renderPresence(data.presence); els.metaDevices.textContent = String(data.presence.length); }
      } catch (e) { if (e.status === 403) toast('Room is full.', 'trash'); }
    }
    async function refresh() {
      if (document.hidden || !state.code) return;
      try { applyState(await api('/room/' + state.code)); } catch (e) { if (e.status === 404) { toast('Room expired.', 'trash'); leaveRoom(); } }
    }
    // Intervals tuned for KV free-tier budgets (writes 1k/day, reads 100k/day):
    // heartbeat (a write) is the scarcest, so it runs least often.
    function startLoops() { stopLoops(); heartbeat(); state.hbTimer = setInterval(heartbeat, 8000); state.pollTimer = setInterval(refresh, 4000); state.cdTimer = setInterval(updateCountdown, 1000); }
    function stopLoops() { [state.hbTimer, state.pollTimer, state.cdTimer].forEach((t) => t && clearInterval(t)); state.hbTimer = state.pollTimer = state.cdTimer = null; }
    function updateCountdown() { if (!state.expiresAt) return; const left = state.expiresAt - serverNow(); els.metaExpiry.textContent = fmtDuration(left); if (left <= 0) { toast('Room expired.', 'trash'); leaveRoom(); } }

    document.addEventListener('visibilitychange', () => {
      if (!state.code) return;
      if (document.hidden) { state.wasHidden = true; els.bgWarn.classList.add('show'); }
      else { els.bgWarn.classList.remove('show'); if (state.wasHidden) { state.wasHidden = false; heartbeat(); refresh(); toast('Presence resumed'); } }
    });
    window.addEventListener('beforeunload', () => stopLoops());

    // On load, rejoin the room from the URL (?room=) or the persisted session,
    // so a refresh restores the room + its server-side content instead of
    // dropping to the landing page.
    (async function autoResume() {
      let code = new URLSearchParams(location.search).get('room');
      let pin = null;
      try { const s = JSON.parse(sessionStorage.getItem('dropspot_room') || 'null'); if (s && (!code || s.code === code)) { code = code || s.code; pin = s.pin || null; } } catch {}
      if (!code) return;
      code = code.toUpperCase();
      els.joinCode.value = code;
      state.pin = pin;
      try {
        await enterRoom(code);
      } catch (e) {
        state.pin = null;
        if (e.status === 401) { els.joinPinField.classList.remove('ds-hidden'); toast('Enter the room PIN to rejoin.'); els.joinCode.scrollIntoView({ block: 'center' }); }
        else if (e.status === 404) { try { sessionStorage.removeItem('dropspot_room'); } catch {} const url = new URL(location.href); url.searchParams.delete('room'); history.replaceState({}, '', url); toast('That room has expired.', 'trash'); }
        else { els.joinCode.scrollIntoView({ block: 'center' }); }
      }
    })();
  </script>
</BaseLayout>
