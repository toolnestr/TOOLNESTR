---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Brick Calculator';
const description = 'Calculate the number of bricks needed for a wall from dimensions and mortar joints.';
const intro = 'Estimate how many bricks you need for any wall including mortar joint allowance.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'How many bricks are in a square foot?', a: 'Standard modular bricks (3-5/8 x 2-1/4 x 7-5/8 inches) require about 7 bricks per square foot with a 3/8-inch mortar joint.' },
  { q: 'What is the difference between modular and queen brick?', a: 'Modular bricks are the most common at 7-5/8 x 2-1/4 x 3-5/8 inches. Queen bricks are slightly larger at 9-5/8 x 2-3/4 x 2-3/4 inches, giving a different aesthetic with fewer courses needed.' },
  { q: 'Do I need to add extra bricks for waste?', a: 'Yes, add 5-10% extra for breakage, cutting, and chipped bricks. Brick is fragile and breakage is common during transport and installation.' },
  { q: 'What mortar mix should I use?', a: 'Type N mortar (1 part cement, 1 part lime, 6 parts sand) is standard for most above-grade walls. Type S (stronger) is used for below-grade and load-bearing walls.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall length (ft)</span>
        <input id="length" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall height (ft)</span>
        <input id="height" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Brick length (in)</span>
        <input id="brick-l" type="number" step="any" placeholder="7.625" value="7.625" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Brick height (in)</span>
        <input id="brick-h" type="number" step="any" placeholder="2.25" value="2.25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mortar joint (in)</span>
        <input id="mortar" type="number" step="any" placeholder="0.375" value="0.375" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waste (%)</span>
        <input id="waste" type="number" min="0" step="1" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Bricks needed</div>
        <div id="r-bricks" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-waste" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Wall area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Bricks per sq ft</div><div id="r-psf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Total with waste</div><div id="r-total" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="brick-title brick-desc">
      <title id="brick-title">Brick wall elevation diagram</title>
      <desc id="brick-desc">A wall section showing a running bond brick pattern with dimensions</desc>
      <rect x="80" y="60" width="560" height="240" fill="#f8fafc" stroke="#cbd5e1" stroke-width="2" rx="4" />
      <g fill="#e53e3e" opacity="0.7">
        <rect x="82" y="62" width="100" height="28" rx="1" />
        <rect x="184" y="62" width="100" height="28" rx="1" />
        <rect x="286" y="62" width="100" height="28" rx="1" />
        <rect x="388" y="62" width="100" height="28" rx="1" />
        <rect x="490" y="62" width="100" height="28" rx="1" />
        <rect x="131" y="92" width="100" height="28" rx="1" />
        <rect x="233" y="92" width="100" height="28" rx="1" />
        <rect x="335" y="92" width="100" height="28" rx="1" />
        <rect x="437" y="92" width="100" height="28" rx="1" />
        <rect x="539" y="92" width="100" height="28" rx="1" />
        <rect x="82" y="122" width="100" height="28" rx="1" />
        <rect x="184" y="122" width="100" height="28" rx="1" />
        <rect x="286" y="122" width="100" height="28" rx="1" />
        <rect x="388" y="122" width="100" height="28" rx="1" />
        <rect x="490" y="122" width="100" height="28" rx="1" />
        <rect x="131" y="152" width="100" height="28" rx="1" />
        <rect x="233" y="152" width="100" height="28" rx="1" />
        <rect x="335" y="152" width="100" height="28" rx="1" />
        <rect x="437" y="152" width="100" height="28" rx="1" />
        <rect x="539" y="152" width="100" height="28" rx="1" />
      </g>
      <g stroke="#fef2f2" stroke-width="1">
        <line x1="82" y1="90" x2="638" y2="90" />
        <line x1="82" y1="120" x2="638" y2="120" />
        <line x1="82" y1="150" x2="638" y2="150" />
        <line x1="82" y1="180" x2="638" y2="180" />
      </g>
      <line x1="80" y1="40" x2="640" y2="40" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="360" y="30" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Wall length</text>
      <line x1="65" y1="60" x2="65" y2="300" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="52" y="185" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif" transform="rotate(-90 52 185)">Wall height</text>
      <text x="350" y="330" text-anchor="middle" font-size="13" fill="#64748b" font-family="system-ui,sans-serif">Running bond brick pattern with staggered vertical joints</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A brick wall in running bond pattern — the most common and structurally sound bricklaying pattern</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the brick calculator works</h2>
    <p class="mt-2 text-slate-600">
      The brick calculator estimates the total number of bricks required for a wall based on the length, height, brick dimensions, and mortar joint thickness. It calculates the wall area in square feet, determines how many bricks fit per square foot including the mortar joint, and multiplies to get the total brick count.
    </p>
    <p class="mt-3 text-slate-600">
      The standard modular brick measures 7-5/8 inches long by 2-1/4 inches tall by 3-5/8 inches deep. The mortar joint is typically 3/8 inch thick. With these defaults, approximately 7 bricks are needed per square foot of wall surface. The calculator allows you to adjust all these parameters for non-standard brick sizes and joint thicknesses.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the wall</h3>
        <p class="mt-1 text-sm text-slate-600">Get the length and height of the wall in feet. Include all areas that will be bricked.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set brick and mortar specs</h3>
        <p class="mt-1 text-sm text-slate-600">Enter your brick dimensions and mortar joint thickness. Standard values are pre-filled.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Order with confidence</h3>
        <p class="mt-1 text-sm text-slate-600">Get the total bricks including waste. Add the mortar mix and supplies to your order.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Brick face area with mortar</p>
        <p class="mt-1 text-slate-600">
          Each brick plus its mortar joint occupies: <span class="font-mono">(brick L + joint) &times; (brick H + joint)</span>. For a standard modular brick with 3/8&Prime; joint: (7.625 + 0.375) &times; (2.25 + 0.375) = 8 &times; 2.625 = <strong>21 sq in per brick</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Bricks per square foot</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Bricks/sq ft = 144 &divide; brick area in sq in</span>. 144 &divide; 21 = <strong>6.86 bricks per sq ft</strong>. We round this to 7 for quick estimates.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Total bricks</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Total = wall area &times; bricks/sq ft &times; (1 + waste%)</span>. A 10&prime; &times; 8&prime; wall is 80 sq ft. 80 &times; 6.86 &times; 1.1 (10% waste) = <strong>604 bricks</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A garden wall 20&prime; long and 3&prime; tall using standard modular bricks (7.625&Prime; &times; 2.25&Prime;) with 3/8&Prime; mortar joint and 10% waste.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Wall area:</span> <span class="text-slate-600">20 &times; 3 = 60 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Bricks per sq ft:</span> <span class="text-slate-600">144 / (8 &times; 2.625) = 6.86</span></div>
        <div><span class="font-medium text-slate-700">Base bricks:</span> <span class="text-slate-600">60 &times; 6.86 = 411.6</span></div>
        <div><span class="font-medium text-slate-700">With 10% waste:</span> <span class="text-slate-600">411.6 &times; 1.1 = <strong>453 bricks</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the brick calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">House facade</h3>
        <p class="mt-1 text-sm text-slate-600">Calculate bricks for a full house exterior or a partial facade accent wall. Include windows and doors by subtracting their area from the total wall area.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌿</span>
        <h3 class="mt-2 font-semibold text-slate-900">Garden wall</h3>
        <p class="mt-1 text-sm text-slate-600">Freestanding garden walls, retaining walls, and raised planter beds all require brick calculations. These small structures are ideal DIY projects where accurate brick counts save money.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Pillar and column</h3>
        <p class="mt-1 text-sm text-slate-600">Brick pillars for gates, porches, and fence posts use a different calculation since they are three-dimensional. Calculate each face separately and add them together.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🔥</span>
        <h3 class="mt-2 font-semibold text-slate-900">Fireplace and chimney</h3>
        <p class="mt-1 text-sm text-slate-600">Fireplaces need firebrick for the interior and face brick for the exterior. Firebrick is a different size and material. Calculate the two layers separately and add them together.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for bricklaying</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Soak bricks before laying</h3>
        <p class="mt-1 text-sm text-slate-600">Dry bricks absorb water from the mortar too quickly, weakening the bond. Soak bricks in water for 10-15 minutes before laying, especially in hot weather. The bricks should be damp but not dripping when laid.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use a line for level courses</h3>
        <p class="mt-1 text-sm text-slate-600">String a mason's line from corner to corner for each course of bricks. This ensures straight, level rows. Check each brick with a level as you go, tapping gently with the trowel handle to adjust.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Strike joints as you go</h3>
        <p class="mt-1 text-sm text-slate-600">Finish the mortar joints with a striking tool when the mortar is thumbprint-hard — firm enough to hold a impression but not yet hard. This creates a professional look and seals the joint against water infiltration.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/concrete-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Calculator</a>
      <a href="/tools/paver-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Paver Calculator</a>
      <a href="/tools/square-footage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('length').value);
      const H = parseFloat(el('height').value);
      const bL = parseFloat(el('brick-l').value);
      const bH = parseFloat(el('brick-h').value);
      const mortar = parseFloat(el('mortar').value);
      const waste = parseFloat(el('waste').value);
      if (!L || !H || !bL || !bH || L <= 0 || H <= 0 || bL <= 0 || bH <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const wallArea = L * H;
      const brickUnitArea = (bL + mortar) * (bH + mortar);
      const bricksPerSf = 144 / brickUnitArea;
      const baseBricks = wallArea * bricksPerSf;
      const totalBricks = Math.ceil(baseBricks * (1 + (waste || 0) / 100));

      el('r-bricks').textContent = totalBricks.toLocaleString();
      el('r-waste').textContent = '(incl. ' + (waste || 0) + '% waste)';
      el('r-area').textContent = wallArea.toFixed(1) + ' sq ft';
      el('r-psf').textContent = bricksPerSf.toFixed(2);
      el('r-total').textContent = totalBricks.toLocaleString() + ' bricks';
      el('results').classList.remove('hidden');
    }

    ['length', 'height', 'brick-l', 'brick-h', 'mortar', 'waste'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
  </script>
</ToolLayout>
