---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Celsius to Fahrenheit"
  emoji="🌡️"
  fromUnit="degrees Celsius" toUnit="degrees Fahrenheit"
  fromTitle="Celsius" toTitle="Fahrenheit"
  fromSym="°C" toSym="°F"
  quantity="temperature"
  kind="tempCF"
  reverseSlug="fahrenheit-to-celsius" reverseLabel="Fahrenheit to Celsius Converter"
  hasReverse={true}
  related={[{"slug":"celsius-to-kelvin","label":"Celsius to Kelvin Converter"},{"slug":"kelvin-to-celsius","label":"Kelvin to Celsius Converter"}]}
  useCase="The classic weather and cooking conversion between the metric and US temperature scales."
/>
