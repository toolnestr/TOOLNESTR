---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Surface Area-to-Volume Calculator';
const description = "Surface area-to-volume ratio calculator. Compute SA:V for a cube-shaped cell model and see why cells stay small, with worked examples across increasing sizes.";
const intro = 'Enter a cell\'s side length (modeled as a cube) to compute its surface area, volume, and their ratio — the key constraint that keeps cells small. Two 3D diagrams compare a small and a large cube-shaped cell, and charts show how SA:V ratio drops sharply as cell size increases.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is the surface area-to-volume ratio, and why does it matter for cells?', a: "SA:V ratio compares a cell's outer membrane area (through which nutrients and waste move) to its internal volume (which needs those nutrients). As a cell grows, volume increases faster than surface area, so the ratio drops — eventually limiting how large a cell can efficiently be." },
  { q: 'Why does volume grow faster than surface area as size increases?', a: 'Surface area scales with the square of linear size (side²) while volume scales with the cube (side³) — so doubling a cell\'s side length increases surface area 4-fold but volume 8-fold, dropping the SA:V ratio.' },
  { q: 'Why do cells stay small instead of growing larger?', a: 'A cell relies on its surface membrane to exchange nutrients, gases, and waste with its surroundings. If a cell grew too large, its shrinking SA:V ratio would leave too little membrane area to support the much larger volume of cytoplasm needing supply — starving the interior.' },
  { q: 'How do large organisms get around this size limit?', a: 'Multicellular organisms grow large by dividing into many small cells rather than one giant cell, keeping every individual cell\'s SA:V ratio favorable — this is one of the fundamental reasons cells divide instead of simply growing indefinitely.' },
  { q: 'Do all cell shapes affect SA:V ratio the same way?', a: 'No — shape matters a lot. Elongated, folded, or highly branched shapes (like microvilli in intestinal cells, or root hairs in plants) increase surface area without proportionally increasing volume, giving cells and structures a much better effective SA:V ratio for their size.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Surface Area-to-Volume Ratio Calculator',
  description: 'Compute surface area, volume, and their ratio for a cube-shaped cell model at any size.',
  steps: [
    { name: 'Enter a side length', text: 'Provide the side length of your cube-shaped cell model.' },
    { name: 'Read SA, V, and the ratio', text: 'Surface area, volume, and SA:V ratio solve instantly.' },
    { name: 'Compare across sizes', text: 'See how quickly the ratio drops as the modeled cell grows larger.' },
  ],
};

const formulas = [
  { expr: 'SA = 6s²', note: 'surface area of a cube — s = side length' },
  { expr: 'V = s³', note: 'volume of a cube' },
  { expr: 'SA:V = 6s² / s³ = 6/s', note: 'the ratio simplifies to show it decreases as s increases' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a small cube-shaped cell (s=1)', tone: 'slate',
    given: 'A cube-shaped cell model with side length s = 1 unit.',
    rows: [
      { label: 'Surface area:', value: 'SA = 6 × 1² = 6 square units' },
      { label: 'Volume:', value: 'V = 1³ = 1 cubic unit' },
      { label: 'SA:V ratio:', value: '6:1 (or 6.0)', full: true },
    ],
    note: 'At this small size, the cell has an ample 6 units of membrane surface for every 1 unit of interior volume — a favorable ratio for efficient nutrient exchange.',
  },
  {
    title: 'Worked example 2 — the same shape scaled up 3× (s=3)', tone: 'amber',
    given: 'The same cube shape, but scaled up to side length s = 3 units.',
    rows: [
      { label: 'Surface area:', value: 'SA = 6 × 3² = 54 square units (9× larger)' },
      { label: 'Volume:', value: 'V = 3³ = 27 cubic units (27× larger)' },
      { label: 'SA:V ratio:', value: '54/27 = 2:1 (or 2.0) — a 3× drop from the original 6:1', full: true },
    ],
    note: 'Even though the cell only tripled in linear size, its SA:V ratio dropped to a third of the original — illustrating exactly why cells can\'t simply keep growing larger indefinitely.',
  },
];

const comparison = {
  heading: 'How SA:V ratio drops as cube size increases',
  note: 'Volume always outpaces surface area growth — the larger the cube, the worse (lower) its ratio becomes.',
  headers: [{ label: 'Side length (s)' }, { label: 'Surface area' }, { label: 'Volume' }, { label: 'SA:V ratio' }],
  rows: [
    ['1 ★', '6', '1', '6.0'],
    ['2', '24', '8', '3.0'],
    ['3', '54', '27', '2.0'],
    ['5', '150', '125', '1.2'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 1). Notice the ratio always simplifies to 6/s — a purely geometric consequence of comparing an area (s²) to a volume (s³).',
};

const realWorld = [
  { emoji: '🦠', title: 'Why cells divide instead of growing indefinitely', body: 'The SA:V constraint is one of the fundamental reasons cells divide once they reach a certain size rather than continuing to grow — dividing resets the ratio back to a more favorable value for each daughter cell.' },
  { emoji: '🔬', title: 'Explaining specialized absorptive cell shapes', body: 'Intestinal cells, root hair cells, and many others evolve highly folded or elongated surfaces (like microvilli) specifically to maximize surface area for absorption without proportionally increasing their volume.' },
  { emoji: '🐘', title: 'Body size and heat exchange in animals', body: 'The same SA:V principle explains why larger animals (like elephants) have relatively less skin surface per unit of body mass than smaller animals, affecting how efficiently they can dissipate heat — a real evolutionary and physiological constraint.' },
  { emoji: '🎓', title: 'Teaching the biological limits on cell size', body: 'The SA:V ratio is one of the clearest, most quantitative demonstrations in introductory biology of why cells are microscopic rather than macroscopic.' },
];

const misconceptions = [
  { claim: '"Cells could grow as large as they wanted if they just had enough nutrients available."', truth: 'Even with unlimited external nutrients, a growing cell\'s SHRINKING surface-area-to-volume ratio limits how quickly nutrients can actually cross the membrane relative to how much interior volume needs supplying — availability outside the cell isn\'t the bottleneck, the geometry of exchange is.' },
  { claim: '"Doubling a cell\'s size doubles both its surface area and volume equally."', truth: 'Doubling linear size quadruples surface area (2²=4) but multiplies volume by eight (2³=8) — surface area and volume scale completely differently with size, which is the entire reason the SA:V ratio changes at all.' },
  { claim: '"All cells are roughly cube- or sphere-shaped, so shape doesn\'t matter much for this ratio."', truth: 'Cell shape matters enormously — highly folded, elongated, or branched shapes can achieve a much better SA:V ratio at the same volume than a simple cube or sphere, which is exactly why many absorptive cells evolve complex, non-spherical shapes.' },
  { claim: '"SA:V ratio only matters for single-celled organisms, not for multicellular animals."', truth: "SA:V considerations apply at every scale from individual cells to entire organisms — for instance, it directly explains real physiological patterns like why small animals lose heat faster (relatively more surface area) than large animals." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 4, "Cell Structure" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/4-1-studying-cells" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Chapter 1, Cells and Genomes.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 6, A Tour of the Cell.' },
];
const sourcesNote = 'Modeled as a cube: SA=6s², V=s³, SA:V=6/s. Real cells are rarely perfect cubes, but the same scaling principle (area∝s², volume∝s³) applies to any shape. Results are rounded for display.';

const howToUse = [
  { title: 'Enter a side length', body: 'Provide the side length of your cube-shaped cell model, in any consistent unit.' },
  { title: 'Read SA, V, and the ratio', body: 'All three values solve instantly from the cube formulas.' },
  { title: 'Compare across sizes', body: 'See how dramatically the ratio drops as the modeled cell grows.' },
];

const related = [
  { href: '/tools/cell-doubling-time-calculator', emoji: '⏱️', title: 'Cell Doubling Time Calculator', desc: 'Estimate generation time from growth data.' },
  { href: '/tools/osmosis-tonicity-calculator', emoji: '💧', title: 'Osmosis/Tonicity Predictor', desc: 'Predict water movement direction across a membrane.' },
  { href: '/tools/exponential-growth-calculator', emoji: '📈', title: 'Exponential Population Growth Calculator', desc: 'N(t) = N₀e^(rt) — model unconstrained population growth.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a cell's outer membrane (its supply line) scales with the square of its size, while its interior (its demand) scales with the cube — so simply getting bigger inevitably strains a cell's ability to feed its own volume through a shrinking relative surface area."
  howIntro="For a cube of side length s, surface area is 6s² (six faces, each s×s) while volume is s³. Dividing surface area by volume gives 6s²/s³, which simplifies to 6/s — a ratio that shrinks as s grows, since s is now in the denominator alone. This simple geometric fact — area scaling with the square of size, volume with the cube — applies to essentially any shape, not just cubes, and is the fundamental reason biological cells face a practical upper limit on how large they can efficiently grow before needing to divide."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where surface area-to-volume ratio actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Side length (s)</span>
      <input id="side" type="number" step="any" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Surface area (6s²)</div><div id="r-sa" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Volume (s³)</div><div id="r-v" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">SA:V ratio</div><div id="r-ratio" class="mt-1 text-lg font-bold">—</div></div>
    </div>
    <p id="sav-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Small cell vs large cell</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-small" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A small cube-shaped cell</h3>
          <p class="mt-1 text-sm text-slate-600">A high SA:V ratio — plenty of membrane surface relative to its small internal volume.</p>
        </div>
        <div>
          <div id="diag-large" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. A large cube-shaped cell</h3>
          <p class="mt-1 text-sm text-slate-600">A much lower SA:V ratio — the same shape, but its enormous interior volume is now poorly served by its relatively smaller surface.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">SA:V ratio graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">SA:V ratio vs side length — 6/s falls sharply</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ratio"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Surface area vs volume growth (both normalized to s=1)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-growth"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function update() {
        el('sav-err').textContent = '';
        const s = parseFloat(el('side').value);
        if (isNaN(s)) { el('r-sa').textContent = '—'; el('r-v').textContent = '—'; el('r-ratio').textContent = '—'; return; }
        if (s <= 0) { el('sav-err').textContent = 'Side length must be greater than 0.'; return; }
        const sa = 6 * s * s, v = s * s * s;
        el('r-sa').textContent = fmt(sa);
        el('r-v').textContent = fmt(v);
        el('r-ratio').textContent = fmt(sa / v) + ' : 1';
      }
      el('side').addEventListener('input', update);

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsS = [], dataRatio = [];
        for (let s = 1; s <= 10; s += 1) { labelsS.push(s); dataRatio.push(+(6 / s).toFixed(2)); }
        charts.ratio = new Chart(el('chart-ratio'), {
          type: 'line',
          data: { labels: labelsS, datasets: [{ label: 'SA:V ratio', data: dataRatio, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Side length (s)' } }, y: { title: { display: true, text: 'SA:V ratio' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsG = [], dataSA = [], dataV = [];
        for (let s = 1; s <= 5; s += 1) { labelsG.push(s); dataSA.push(6 * s * s); dataV.push(s * s * s); }
        charts.growth = new Chart(el('chart-growth'), {
          type: 'line',
          data: { labels: labelsG, datasets: [
            { label: 'Surface area (6s²)', data: dataSA, borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0.3, pointRadius: 3 },
            { label: 'Volume (s³)', data: dataV, borderColor: '#f59e0b', backgroundColor: 'transparent', tension: 0.3, pointRadius: 3 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Side length (s)' } }, y: { title: { display: true, text: 'Value' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function cubeScene(container, size, color) {
        const s = makeScene(container, Math.max(6, size * 2.2), new THREE.Vector3(0, 0, 0), OPTS);
        const cube = new THREE.Mesh(new THREE.BoxGeometry(size, size, size), new THREE.MeshStandardMaterial({ color, roughness: 0.4, transparent: true, opacity: 0.85 }));
        s.scene.add(cube);
        const edges = new THREE.LineSegments(new THREE.EdgesGeometry(cube.geometry), new THREE.LineBasicMaterial({ color: 0x1e293b }));
        cube.add(edges);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSmall = null, diagLarge = null;
      function initDiagSmall() { const c = el('diag-small'); if (!c) throw new Error('no container'); diagSmall = cubeScene(c, 1.2, 0x6366f1); }
      function initDiagLarge() { const c = el('diag-large'); if (!c) throw new Error('no container'); diagLarge = cubeScene(c, 3, 0xf59e0b); }

      function boot() {
        try { update(); } catch (e) { console.error('[surface-area-volume] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[surface-area-volume] charts failed', e); }
        if (window.THREE) {
          try { initDiagSmall(); } catch (e) { console.error('[surface-area-volume] small diagram failed', e); }
          try { initDiagLarge(); } catch (e) { console.error('[surface-area-volume] large diagram failed', e); }
        }
        mountResize([diagSmall, diagLarge]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
