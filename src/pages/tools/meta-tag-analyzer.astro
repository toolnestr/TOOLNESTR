---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Meta Tag Analyzer';
const description =
  'Free online meta tag analyzer. Paste HTML source code to extract and analyze title tag, meta description, keywords, Open Graph and Twitter cards.';
const intro =
  'Paste your webpage\'s HTML source (or the &lt;head&gt; section) to extract all meta tags and see their content with recommendations.';
const category = { id: 'seo', name: 'SEO Tools' };
const faqs = [
  { q: 'What meta tags does this tool analyze?', a: 'It extracts the title tag, meta description, meta keywords, Open Graph (og:) tags, Twitter card tags, viewport, charset, robots, canonical and author meta tags.' },
  { q: 'What is the ideal title tag length?', a: 'Title tags should be 50-60 characters. Google typically displays the first 50-60 characters in SERPs. Longer titles get truncated with an ellipsis.' },
  { q: 'What is the ideal meta description length?', a: 'Meta descriptions should be 150-160 characters. While Google sometimes displays longer snippets, descriptions within this range are most reliably shown in full.' },
  { q: 'What are Open Graph tags?', a: 'Open Graph (og:) tags control how your page appears when shared on social platforms like Facebook, LinkedIn and Pinterest. They define the title, description, image and URL for social previews.' },
  { q: 'What are Twitter Card tags?', a: 'Twitter Card tags (twitter:) control how your page appears in tweets. They support summary cards, large image cards, app cards and player cards for media content.' },
  { q: 'Does this tool check if meta tags are missing?', a: 'Yes. It highlights missing critical tags like the title, description and viewport. Missing Open Graph tags are flagged with recommendations to add them.' },
  { q: 'Can I analyze any webpage?', a: 'You need the HTML source code. Open any page in your browser, right-click and select View Page Source, then copy the &lt;head&gt; section into the tool.' },
  { q: 'Is my HTML data safe?', a: 'Yes. All analysis runs entirely in your browser. No HTML or extracted data is sent to any server.' },
  { q: 'What does "duplicate title" mean?', a: 'A page should have exactly one title tag. Multiple title tags confuse search engines and may cause the wrong title to appear in search results.' },
  { q: 'Does this tool check canonical tags?', a: 'Yes. The canonical tag is extracted and displayed. Missing canonical tags on pages with similar content are flagged to prevent duplicate content issues.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea
      id="html-input"
      rows="10"
      spellcheck="false"
      placeholder="Paste your HTML source or &lt;head&gt; section here..."
      class="w-full resize-y rounded-xl border border-slate-300 p-4 font-mono text-sm leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>

    <div class="mt-4 flex flex-wrap items-center gap-3">
      <button id="analyze-btn" class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Analyze</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
    </div>

    <div id="results" class="mt-4 hidden space-y-4"></div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How meta tag analysis works</h2>
    <p class="mt-2 text-slate-600">
      The meta tag analyzer parses HTML source code using the browser's built-in DOM parser. It extracts content from specific selectors: <code>document.querySelector('title')</code> for the title tag, <code>meta[name="description"]</code> for the description, and <code>meta[property^="og:"]</code> for all Open Graph tags. Each extracted value is then evaluated against SEO best practices.
    </p>
    <p class="mt-3 text-slate-600">
      Title tags are validated against the 50–60 character ideal range — shorter titles truncate less visibly but may miss keyword opportunity; longer titles get cut off in SERPs with an ellipsis. Meta descriptions are checked against 150–160 characters. Missing tags are flagged with red warnings. Duplicate tags (multiple titles, multiple descriptions) are detected and highlighted as critical issues.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Analyzing a typical blog page head section:</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Title (55 chars):</span> <span class="text-slate-600">"10 SEO Tips for Better Rankings in 2026" — <strong>✓ Ideal</strong></span></div>
        <div><span class="font-medium text-slate-700">Meta desc (158 chars):</span> <span class="text-slate-600">Within ideal range — <strong>✓ Good</strong></span></div>
        <div><span class="font-medium text-slate-700">OG tags found:</span> <span class="text-slate-600">3 of 4 essential (missing og:image) — <strong>⚠ Partial</strong></span></div>
        <div><span class="font-medium text-slate-700">Twitter card:</span> <span class="text-slate-600">None found — <strong>⚠ Missing</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Title and description length analysis</h2>
    <p class="mt-2 text-slate-600">How your title and meta description lengths compare to the ideal ranges.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Title tag length</span><span id="title-bar-label" class="text-slate-400">—</span></div>
        <div class="mt-1 h-4 w-full rounded-full bg-slate-100">
          <div id="title-bar" class="h-4 rounded-full bg-indigo-500" style="width:0%"></div>
        </div>
        <p class="mt-1 text-xs text-slate-400">Ideal: 50–60 characters</p>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Meta description length</span><span id="desc-bar-label" class="text-slate-400">—</span></div>
        <div class="mt-1 h-4 w-full rounded-full bg-slate-100">
          <div id="desc-bar" class="h-4 rounded-full bg-emerald-500" style="width:0%"></div>
        </div>
        <p class="mt-1 text-xs text-slate-400">Ideal: 150–160 characters</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F50D;</span>
      <h3 class="mt-2 font-semibold text-slate-900">SEO Specialist</h3>
      <p class="mt-1 text-sm text-slate-600">Audits client sites for meta tag issues. Uses the analyzer to quickly identify missing tags, length problems and optimization opportunities at scale.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F469;&#x200D;&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Web Developer</h3>
      <p class="mt-1 text-sm text-slate-600">Builds and maintains websites. Checks meta tags after deployment to ensure title, description and OG tags are correctly implemented before launch.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4C1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Reviews meta descriptions for brand consistency and CTR optimization. Ensures each page has a unique, compelling description that matches the content.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3E0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Site Owner</h3>
      <p class="mt-1 text-sm text-slate-600">Runs a small business website. Verifies that all pages have proper meta tags for better search visibility and social sharing without needing technical skills.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Meta tag character limits</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-sm">
        <thead><tr class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500"><th class="px-4 py-3">Tag</th><th class="px-4 py-3">Ideal length</th><th class="px-4 py-3">Max display</th><th class="px-4 py-3">Tip</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <tr><td class="px-4 py-3 font-medium text-slate-900">Title</td><td class="px-4 py-3 text-slate-700">50–60 chars</td><td class="px-4 py-3 text-slate-700">~600px</td><td class="px-4 py-3 text-slate-500">Front-load primary keywords</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Meta description</td><td class="px-4 py-3 text-slate-700">150–160 chars</td><td class="px-4 py-3 text-slate-700">~920px</td><td class="px-4 py-3 text-slate-500">Include call to action</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">OG title</td><td class="px-4 py-3 text-slate-700">40–60 chars</td><td class="px-4 py-3 text-slate-700">Varies</td><td class="px-4 py-3 text-slate-500">Match page title</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">OG description</td><td class="px-4 py-3 text-slate-700">80–200 chars</td><td class="px-4 py-3 text-slate-700">Varies</td><td class="px-4 py-3 text-slate-500">Summarize page content</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Twitter title</td><td class="px-4 py-3 text-slate-700">40–70 chars</td><td class="px-4 py-3 text-slate-700">Varies</td><td class="px-4 py-3 text-slate-500">Keep under 70 chars</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Twitter description</td><td class="px-4 py-3 text-slate-700">100–200 chars</td><td class="px-4 py-3 text-slate-700">Varies</td><td class="px-4 py-3 text-slate-500">Avoid truncation</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Meta Tag Analyzer</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get the HTML source</h3>
        <p class="mt-1 text-sm text-slate-600">Open any webpage, right-click and select "View Page Source". Copy the &lt;head&gt; section or the entire HTML.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste and analyze</h3>
        <p class="mt-1 text-sm text-slate-600">Paste the HTML into the text area and click Analyze. All meta tags are extracted and evaluated instantly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Review recommendations</h3>
        <p class="mt-1 text-sm text-slate-600">Check the status badges and recommendations. Missing tags, length issues or duplicates are highlighted so you can fix them.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for better meta tags</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Write unique meta data for every page</h3>
        <p class="mt-1 text-sm text-slate-600">Duplicate title tags and meta descriptions across pages confuse search engines and reduce click-through rates. Each page should have a unique, descriptive title and description.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Include target keywords naturally</h3>
        <p class="mt-1 text-sm text-slate-600">Place your primary keyword near the start of the title tag. In meta descriptions, write for humans first — compelling descriptions earn more clicks than keyword-stuffed ones.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Always add Open Graph tags</h3>
        <p class="mt-1 text-sm text-slate-600">OG tags control how your page looks when shared on social media. Without them, platforms guess the content, often picking the wrong image or description. Four OG tags (title, description, image, url) are essential.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why meta tags matter</h2>
    <p class="mt-2 text-slate-600">Meta tags are the primary way search engines understand what a page is about. The title tag is the most important on-page SEO element — it appears as the clickable headline in search results. Meta descriptions, while not a direct ranking factor, significantly impact click-through rates.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Title tag best practices</h2>
    <p class="mt-2 text-slate-600">Keep titles between 50-60 characters. Place primary keywords first, include your brand name at the end (separated by a pipe or dash), and ensure each page has a unique title. Avoid ALL CAPS, excessive punctuation and vague titles like "Home" or "Page 1".</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Meta description tips</h2>
    <p class="mt-2 text-slate-600">Write compelling, actionable descriptions between 150-160 characters. Include the target keyword, a clear value proposition and a call to action. Match the description to the page content — misleading descriptions increase bounce rates and hurt SEO.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">OG tags for social</h2>
    <p class="mt-2 text-slate-600">The four essential Open Graph tags are og:title, og:description, og:image and og:url. A properly sized OG image (1200x630 pixels at 72 DPI) ensures your links look professional when shared on Facebook, LinkedIn and other platforms that support the protocol.</p>
  </section>

  <script is:inline>
    const htmlInput = document.getElementById('html-input');
    const analyzeBtn = document.getElementById('analyze-btn');
    const clearBtn = document.getElementById('clear-btn');
    const resultsDiv = document.getElementById('results');
    const titleBar = document.getElementById('title-bar');
    const titleBarLabel = document.getElementById('title-bar-label');
    const descBar = document.getElementById('desc-bar');
    const descBarLabel = document.getElementById('desc-bar-label');

    function extractMeta(html) {
      const doc = document.createElement('div');
      doc.innerHTML = html;

      const getTag = (sel, attr) => {
        const el = doc.querySelector(sel);
        return el ? (el.getAttribute(attr) || el.textContent || '').trim() : null;
      };

      const getAll = (sel, attr) => {
        return Array.from(doc.querySelectorAll(sel))
          .map(el => (el.getAttribute(attr) || el.textContent || '').trim())
          .filter(Boolean);
      };

      const title = getTag('title', null);
      const metaDesc = getTag('meta[name="description"]', 'content');
      const metaKeywords = getTag('meta[name="keywords"]', 'content');
      const viewport = getTag('meta[name="viewport"]', 'content');
      const charset = getTag('meta[charset]', 'charset') || getTag('meta[http-equiv="Content-Type"]', 'content');
      const canonical = getTag('link[rel="canonical"]', 'href');
      const robots = getTag('meta[name="robots"]', 'content');
      const author = getTag('meta[name="author"]', 'content');

      const ogTags = {};
      doc.querySelectorAll('meta[property^="og:"]').forEach(el => {
        const prop = el.getAttribute('property');
        ogTags[prop] = el.getAttribute('content') || '';
      });

      const twitterTags = {};
      doc.querySelectorAll('meta[name^="twitter:"]').forEach(el => {
        const name = el.getAttribute('name');
        twitterTags[name] = el.getAttribute('content') || '';
      });

      const titles = getAll('title');
      const metaDescs = getAll('meta[name="description"]');
      const canonicals = getAll('link[rel="canonical"]');

      return { title, metaDesc, metaKeywords, viewport, charset, canonical, robots, author, ogTags, twitterTags, titles, metaDescs, canonicals };
    }

    function statusBadge(ok, msg) {
      const cls = ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700';
      return '<span class="inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ' + cls + '">' + msg + '</span>';
    }

    function analyze() {
      const html = htmlInput.value.trim();
      if (!html) {
        resultsDiv.classList.add('hidden');
        resultsDiv.innerHTML = '';
        titleBar.style.width = '0%';
        titleBarLabel.textContent = '—';
        descBar.style.width = '0%';
        descBarLabel.textContent = '—';
        return;
      }

      const m = extractMeta(html);
      let html_out = '';

      const fmtLen = (s, idealMin, idealMax) => {
        if (!s) return statusBadge(false, 'Missing');
        const len = s.length;
        if (len < idealMin) return statusBadge(false, len + ' chars (too short)');
        if (len > idealMax) return statusBadge(false, len + ' chars (too long)');
        return statusBadge(true, len + ' chars');
      };

      const titleLen = m.title ? m.title.length : 0;
      const descLen = m.metaDesc ? m.metaDesc.length : 0;

      if (m.title) {
        const pct = Math.min(100, (titleLen / 60) * 100);
        titleBar.style.width = Math.max(5, pct) + '%';
        titleBarLabel.textContent = titleLen + ' chars';
        titleBar.className = 'h-4 rounded-full ' + (titleLen >= 50 && titleLen <= 60 ? 'bg-indigo-500' : titleLen < 50 ? 'bg-amber-500' : 'bg-red-500');
      } else {
        titleBar.style.width = '5%';
        titleBarLabel.textContent = 'Missing';
        titleBar.className = 'h-4 rounded-full bg-slate-300';
      }

      if (m.metaDesc) {
        const pct = Math.min(100, (descLen / 160) * 100);
        descBar.style.width = Math.max(5, pct) + '%';
        descBarLabel.textContent = descLen + ' chars';
        descBar.className = 'h-4 rounded-full ' + (descLen >= 150 && descLen <= 160 ? 'bg-emerald-500' : descLen < 150 ? 'bg-amber-500' : 'bg-red-500');
      } else {
        descBar.style.width = '5%';
        descBarLabel.textContent = 'Missing';
        descBar.className = 'h-4 rounded-full bg-slate-300';
      }

      if (m.titles.length > 1) html_out += '<div class="rounded-xl border border-slate-200 p-4"><span class="font-medium text-red-600">Warning:</span> Multiple title tags found (' + m.titles.length + '). Pages should have exactly one title tag.</div>';

      html_out +=
        '<div class="rounded-xl border border-slate-200 p-4">' +
          '<table class="w-full text-sm">' +
            '<tbody class="divide-y divide-slate-100">' +
              '<tr><td class="py-2 pr-4 font-medium text-slate-900">Title</td><td class="py-2 text-slate-700">' + (m.title ? escapeHtml(m.title) : '<span class="text-red-500">Missing</span>') + '</td><td class="py-2 pl-4 text-right">' + fmtLen(m.title, 50, 60) + '</td></tr>' +
              '<tr><td class="py-2 pr-4 font-medium text-slate-900">Meta description</td><td class="py-2 text-slate-700">' + (m.metaDesc ? escapeHtml(m.metaDesc) : '<span class="text-red-500">Missing</span>') + '</td><td class="py-2 pl-4 text-right">' + fmtLen(m.metaDesc, 150, 160) + '</td></tr>' +
              (m.metaKeywords ? '<tr><td class="py-2 pr-4 font-medium text-slate-900">Keywords</td><td class="py-2 text-slate-700" colspan="2">' + escapeHtml(m.metaKeywords) + '</td></tr>' : '') +
              '<tr><td class="py-2 pr-4 font-medium text-slate-900">Charset</td><td class="py-2 text-slate-700" colspan="2">' + (m.charset || '<span class="text-amber-600">Missing (recommend UTF-8)</span>') + '</td></tr>' +
              '<tr><td class="py-2 pr-4 font-medium text-slate-900">Viewport</td><td class="py-2 text-slate-700" colspan="2">' + (m.viewport || '<span class="text-amber-600">Missing (recommend adding)</span>') + '</td></tr>' +
              (m.canonical ? '<tr><td class="py-2 pr-4 font-medium text-slate-900">Canonical</td><td class="py-2 text-slate-700" colspan="2">' + escapeHtml(m.canonical) + '</td></tr>' : '') +
              (m.robots ? '<tr><td class="py-2 pr-4 font-medium text-slate-900">Robots</td><td class="py-2 text-slate-700" colspan="2">' + escapeHtml(m.robots) + '</td></tr>' : '') +
              (m.author ? '<tr><td class="py-2 pr-4 font-medium text-slate-900">Author</td><td class="py-2 text-slate-700" colspan="2">' + escapeHtml(m.author) + '</td></tr>' : '') +
            '</tbody>' +
          '</table>' +
        '</div>';

      const ogKeys = Object.keys(m.ogTags);
      html_out +=
        '<div class="rounded-xl border border-slate-200 p-4">' +
          '<h3 class="mb-2 font-semibold text-slate-900">Open Graph tags ' + (ogKeys.length ? statusBadge(true, ogKeys.length + ' found') : statusBadge(false, 'None found')) + '</h3>';
      if (ogKeys.length) {
        html_out += '<table class="w-full text-sm"><tbody class="divide-y divide-slate-100">';
        ogKeys.forEach(k => {
          html_out += '<tr><td class="py-1 pr-4 font-mono text-xs text-slate-600">' + k + '</td><td class="py-1 text-slate-700">' + escapeHtml(m.ogTags[k]) + '</td></tr>';
        });
        html_out += '</tbody></table>';
      } else {
        html_out += '<p class="text-sm text-amber-600">No Open Graph tags found. Add og:title, og:description, og:image and og:url for better social sharing.</p>';
      }
      html_out += '</div>';

      const twKeys = Object.keys(m.twitterTags);
      html_out +=
        '<div class="rounded-xl border border-slate-200 p-4">' +
          '<h3 class="mb-2 font-semibold text-slate-900">Twitter Card tags ' + (twKeys.length ? statusBadge(true, twKeys.length + ' found') : statusBadge(false, 'None found')) + '</h3>';
      if (twKeys.length) {
        html_out += '<table class="w-full text-sm"><tbody class="divide-y divide-slate-100">';
        twKeys.forEach(k => {
          html_out += '<tr><td class="py-1 pr-4 font-mono text-xs text-slate-600">' + k + '</td><td class="py-1 text-slate-700">' + escapeHtml(m.twitterTags[k]) + '</td></tr>';
        });
        html_out += '</tbody></table>';
      } else {
        html_out += '<p class="text-sm text-amber-600">No Twitter Card tags found. Add twitter:card, twitter:title, twitter:description and twitter:image for better tweet previews.</p>';
      }
      html_out += '</div>';

      resultsDiv.innerHTML = html_out;
      resultsDiv.classList.remove('hidden');
    }

    function escapeHtml(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    analyzeBtn.addEventListener('click', analyze);

    clearBtn.addEventListener('click', () => {
      htmlInput.value = '';
      resultsDiv.classList.add('hidden');
      resultsDiv.innerHTML = '';
      titleBar.style.width = '0%';
      titleBarLabel.textContent = '—';
      descBar.style.width = '0%';
      descBarLabel.textContent = '—';
      htmlInput.focus();
    });
  </script>
</ToolLayout>
