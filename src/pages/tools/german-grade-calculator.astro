---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'German Grade Calculator';
const description =
  'Free German grade calculator. Convert your GPA, percentage, CGPA, or other grades to the German 1.0-5.0 system using the Modified Bavarian Formula.';
const intro =
  'Convert your grade to the German 1.0–5.0 system in seconds. Works with GPA, percentage, CGPA and custom scales using the Modified Bavarian Formula.';
const category = { id: 'everyday', name: 'Everyday' };
const faqs = [
  { q: 'What is the Modified Bavarian Formula?', a: 'It\'s the official formula German universities use to convert foreign grades: German grade = 1 + 3 × (Nmax − N) ÷ (Nmax − Nmin), where Nmax is the best grade, Nmin is the minimum passing grade, and N is your grade.' },
  { q: 'What do the German grades mean?', a: '1.0 is the best, 4.0 is the lowest pass, and anything above 4.0 is failing. 1.0–1.5 is "Sehr gut" (very good), 1.6–2.5 "Gut" (good), 2.6–3.5 "Befriedigend" (satisfactory), 3.6–4.0 "Ausreichend" (sufficient).' },
  { q: 'Which grading systems are supported?', a: 'US GPA (4.0 scale), CGPA (10-point), percentage (out of 100), and any custom scale — just set your maximum grade and minimum passing grade.' },
  { q: 'Is this an official conversion?', a: 'It uses the official formula, but each German university makes the final decision. Use it as an accurate estimate, not a guarantee.' },
  { q: 'What does "Sehr gut" mean for admissions?', a: 'A grade of 1.0–1.5 is considered excellent and makes you competitive for almost any program. Many top-tier master\'s programs expect at least 2.5.' },
  { q: 'Can I convert from German back to my home system?', a: 'Not directly — the Modified Bavarian Formula is designed to convert foreign grades to German grades, not the reverse. You would need your home institution\'s specific conversion.' },
  { q: 'What if my grade uses a different scale (e.g. 1–20)?', a: 'Use the "Custom scale" option and set your best possible grade (e.g. 20) and minimum passing grade (e.g. 10). The formula will convert correctly.' },
  { q: 'Do all German universities use this formula?', a: 'Most use the Modified Bavarian Formula or a close variant. Some universities may apply their own adjustment, so always check the specific requirements of the program you are applying to.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Your grading system</span>
      <select id="system" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="gpa">US GPA (4.0 scale)</option>
        <option value="cgpa">CGPA (10-point scale)</option>
        <option value="percent">Percentage (out of 100)</option>
        <option value="custom">Custom scale</option>
      </select></label>

    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Your grade</span>
        <input id="grade" type="number" step="any" placeholder="3.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Best possible grade</span>
        <input id="max" type="number" step="any" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Minimum passing grade</span>
        <input id="min" type="number" step="any" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden overflow-hidden rounded-2xl">
      <div class="bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Your German grade</div>
        <div id="g-val" class="mt-1 text-4xl font-bold">—</div>
        <div id="g-label" class="mt-1 text-sm font-medium"></div>
      </div>
      <div class="bg-slate-50 p-4 text-center">
        <div id="g-desc" class="text-sm text-slate-600"></div>
        <div id="g-formula" class="mt-2 rounded-lg bg-white p-2 font-mono text-xs text-slate-500"></div>
      </div>
    </div>
    <p id="err" class="mt-4 text-center text-sm text-red-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the Modified Bavarian Formula works</h2>
    <p class="mt-2 text-slate-600">
      The Modified Bavarian Formula is the standard method used by German universities to convert foreign grades into the German 1.0–5.0 system. The formula is: <code>German Grade = 1 + 3 × (Nmax − N) ÷ (Nmax − Nmin)</code>, where N is your grade, Nmax is the best possible grade in your system, and Nmin is the minimum passing grade.
    </p>
    <p class="mt-3 text-slate-600">
      The formula maps your grade proportionally onto the German scale. A perfect score (N = Nmax) always yields 1.0, a minimum passing score yields 4.0, and anything below the minimum pass maps to 5.0 (fail). The formula ensures that grade distributions are compared fairly across different national systems. For example, a US GPA of 3.5 (on a 4.0 scale where 1.0 is the minimum pass) converts as: 1 + 3 × (4 − 3.5) ÷ (4 − 1) = 1 + 3 × 0.5 ÷ 3 = 1.50 (Sehr gut).
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked conversions</h3>
      <div class="mt-2 grid gap-2 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">US GPA 3.8:</span> <span class="text-slate-600">1 + 3×(4−3.8)÷(4−1) = <strong>1.20 (Sehr gut)</strong></span></div>
        <div><span class="font-medium text-slate-700">CGPA 8.5/10:</span> <span class="text-slate-600">1 + 3×(10−8.5)÷(10−4) = <strong>1.75 (Gut)</strong></span></div>
        <div><span class="font-medium text-slate-700">Percentage 72%:</span> <span class="text-slate-600">1 + 3×(100−72)÷(100−50) = <strong>2.68 (Befriedigend)</strong></span></div>
        <div><span class="font-medium text-slate-700">CGPA 6.0/10:</span> <span class="text-slate-600">1 + 3×(10−6)÷(10−4) = <strong>3.00 (Befriedigend)</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What German grades mean</h2>
    <p class="mt-2 text-slate-600">The German grading system runs from 1.0 (excellent) to 5.0 (fail). Each range has a name and a corresponding level of academic achievement.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">1.0 – 1.5 (Sehr gut)</span><span class="text-slate-400">Excellent — top-tier admissions</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">1.6 – 2.5 (Gut)</span><span class="text-slate-400">Good — competitive for most programs</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">2.6 – 3.5 (Befriedigend)</span><span class="text-slate-400">Satisfactory — accepted by many</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:70%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">3.6 – 4.0 (Ausreichend)</span><span class="text-slate-400">Sufficient — passes but may be limiting</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:80%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">4.1 – 5.0 (Fail)</span><span class="text-slate-400">Below passing threshold</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:100%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🇩🇪</span>
      <h3 class="mt-2 font-semibold text-slate-900">Study Abroad Applicants</h3>
      <p class="mt-1 text-sm text-slate-600">Converting your grades to the German system is a mandatory step when applying to German universities. This calculator gives you an instant, accurate estimate.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Master's Applicants</h3>
      <p class="mt-1 text-sm text-slate-600">Many German master's programs have specific grade requirements. Use this to check if your converted grade meets the minimum before applying.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Exchange Students</h3>
      <p class="mt-1 text-sm text-slate-600">Planning a semester abroad in Germany? Convert your home grades to understand where you stand in the German system.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📄</span>
      <h3 class="mt-2 font-semibold text-slate-900">Scholarship Applicants</h3>
      <p class="mt-1 text-sm text-slate-600">German scholarship programs like DAAD often require grade conversions. Get a quick estimate before submitting your application.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">German Grade</th><th class="p-3">Label</th><th class="p-3">Description</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">1.0 – 1.5</td><td class="p-3">Sehr gut</td><td class="p-3">Very good — excellent performance</td></tr>
        <tr><td class="p-3 font-medium">1.6 – 2.5</td><td class="p-3">Gut</td><td class="p-3">Good — above average</td></tr>
        <tr><td class="p-3 font-medium">2.6 – 3.5</td><td class="p-3">Befriedigend</td><td class="p-3">Satisfactory — average performance</td></tr>
        <tr><td class="p-3 font-medium">3.6 – 4.0</td><td class="p-3">Ausreichend</td><td class="p-3">Sufficient — meets minimum pass</td></tr>
        <tr><td class="p-3 font-medium">4.1 – 5.0</td><td class="p-3">Nicht ausreichend</td><td class="p-3">Insufficient — failing grade</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the German grade calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select your system</h3>
        <p class="mt-1 text-sm text-slate-600">Choose GPA, CGPA, percentage, or custom scale. The best and minimum passing grades are pre-filled automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your grade</h3>
        <p class="mt-1 text-sm text-slate-600">Type in your grade value. The max and min fields adjust automatically for each preset system.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">Your converted German grade, its label, and the formula used appear instantly along with a description of what it means.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate conversion</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use the correct max and min values</h3>
        <p class="mt-1 text-sm text-slate-600">Preset scales (GPA, CGPA, percentage) set these automatically. For custom scales, verify your institution's best possible and minimum passing grades.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">This is an estimate</h3>
        <p class="mt-1 text-sm text-slate-600">Each German university makes the final decision on grade conversions. Always check the specific requirements of your target program.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use the custom scale for non-standard systems</h3>
        <p class="mt-1 text-sm text-slate-600">If your university uses a 4.3 scale, a 7-point CGPA, or any other non-standard system, the custom option handles it correctly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Why accurate German grade conversion matters</h2>
    <div class="mt-4 space-y-4">
      <p class="text-slate-600">
        German universities use a strict grade-based admission process, particularly for master's programs and highly competitive bachelor's courses. Your converted grade is often the single most important factor in the admissions decision. A difference of 0.1 on the German scale can determine whether you receive an offer of admission or a rejection, especially for Numerus Clausus (NC) programs where admission is based entirely on grade ranking.
      </p>
      <p class="text-slate-600">
        The Modified Bavarian Formula is the officially recognised conversion method, but its accuracy depends entirely on providing the correct input values. Entering the wrong maximum grade or minimum passing grade for your system produces an inaccurate result that could either give you false confidence or discourage you from applying to programs where you would actually be competitive. For example, a US GPA of 3.0 converts to 2.0 on the German scale using the standard parameters (max 4.0, min 1.0), but if the minimum passing grade is entered incorrectly, the result changes significantly.
      </p>
      <p class="text-slate-600">
        Different grading systems around the world have different conventions for what constitutes a passing grade. In the US system, the minimum passing grade is typically 1.0 (D grade), but some universities consider 0.0 as the minimum passing threshold. For percentage systems, the minimum passing grade varies widely from 30% to 60% depending on the country and institution. Using the correct values ensures that your conversion reflects the true standard of your academic performance.
      </p>
      <p class="text-slate-600">
        Scholarship programs such as DAAD (German Academic Exchange Service) also use the German grading scale when evaluating applications. A converted grade below 2.5 is generally considered competitive for DAAD scholarships, while grades above 3.0 may make it difficult to secure funding. Accurate conversion helps you assess your chances realistically and plan your application strategy accordingly.
      </p>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const presets = { gpa: [4, 1], cgpa: [10, 4], percent: [100, 50] };

    el('system').addEventListener('change', () => {
      const p = presets[el('system').value];
      if (p) { el('max').value = p[0]; el('min').value = p[1]; }
      update();
    });

    function label(g) {
      if (g <= 1.5) return ['Sehr gut (Very good)', 'An excellent result — opens doors to top programs.'];
      if (g <= 2.5) return ['Gut (Good)', 'A strong result that most German universities welcome.'];
      if (g <= 3.5) return ['Befriedigend (Satisfactory)', 'A solid pass accepted by many programs.'];
      if (g <= 4.0) return ['Ausreichend (Sufficient)', 'A passing grade, though competitive programs may want higher.'];
      return ['Nicht ausreichend (Fail)', 'Below the passing threshold in the German system.'];
    }

    function update() {
      const N = parseFloat(el('grade').value);
      const max = parseFloat(el('max').value);
      const min = parseFloat(el('min').value);
      el('err').textContent = '';
      if (isNaN(N) || isNaN(max) || isNaN(min)) { el('result').classList.add('hidden'); return; }
      if (max <= min) { el('err').textContent = 'Best grade must be higher than the minimum passing grade.'; el('result').classList.add('hidden'); return; }
      if (N > max || N < 0) { el('err').textContent = 'Your grade should be between 0 and the best possible grade.'; el('result').classList.add('hidden'); return; }
      let g = 1 + 3 * (max - N) / (max - min);
      g = Math.min(5, Math.max(1, g));
      const [lbl, desc] = label(g);
      el('g-val').textContent = g.toFixed(1);
      el('g-label').textContent = lbl;
      el('g-desc').textContent = desc;
      el('g-formula').textContent = `1 + 3 × (${max} − ${N}) ÷ (${max} − ${min}) = ${g.toFixed(2)}`;
      el('result').classList.remove('hidden');
    }
    ['grade', 'max', 'min'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
