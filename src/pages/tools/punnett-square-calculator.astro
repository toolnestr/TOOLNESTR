---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Punnett Square Calculator';
const description = "Punnett square calculator. Build a full monohybrid cross grid from two parent genotypes, with genotype/phenotype ratios and worked examples.";
const intro = 'Enter two parent genotypes for a single gene (e.g. Aa × Aa) to build the full 2×2 Punnett square, showing every possible offspring genotype and the resulting genotype and phenotype ratios. Two 3D diagrams compare a homozygous and heterozygous cross, and charts show the classic 1:2:1 genotype and 3:1 phenotype ratios.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a Punnett square?', a: 'A Punnett square is a grid used to predict the possible genotypes of offspring from a genetic cross. Each parent\'s alleles are placed along one edge, and the grid cells show every possible allele combination the offspring could inherit.' },
  { q: 'What is the difference between genotype and phenotype ratio?', a: 'Genotype ratio counts the actual allele combinations (like 1 AA : 2 Aa : 1 aa). Phenotype ratio groups those by observable trait — since AA and Aa both show the dominant trait, the classic 1:2:1 genotype ratio becomes a 3:1 phenotype ratio (dominant:recessive).' },
  { q: 'Why does Aa × Aa give a 3:1 phenotype ratio?', a: 'Each parent contributes one of two alleles (A or a) with equal probability. Combining two parents\' alleles independently gives four equally likely combinations: AA, Aa, aA, aa — three of which (AA, Aa, aA) show the dominant phenotype, and one (aa) shows the recessive phenotype.' },
  { q: 'What if both parents are homozygous?', a: 'A homozygous × homozygous cross (like AA × aa) produces offspring that are all identical — 100% Aa in this case — since each parent can only contribute one type of allele.' },
  { q: 'Does a Punnett square predict exact numbers or just probabilities?', a: 'A Punnett square shows probabilities/ratios, not guaranteed exact counts. A real cross with only 4 offspring might not show exactly a 3:1 split — the predicted ratio becomes more accurate as the number of offspring increases, following the law of large numbers.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Punnett Square Calculator',
  description: 'Build a monohybrid Punnett square from two parent genotypes and see the resulting genotype and phenotype ratios.',
  steps: [
    { name: 'Enter both parent genotypes', text: 'Type each parent\'s two alleles for the gene, e.g. Aa and Aa.' },
    { name: 'View the grid', text: 'The full 2×2 cross grid fills in automatically with every possible offspring genotype.' },
    { name: 'Read the ratios', text: 'Genotype and phenotype ratios are tallied automatically below the grid.' },
  ],
};

const formulas = [
  { expr: 'Aa × Aa → 1 AA : 2 Aa : 1 aa', note: 'the classic heterozygous cross — genotype ratio 1:2:1' },
  { expr: '1 AA : 2 Aa : 1 aa → 3 : 1', note: 'phenotype ratio — dominant (AA, Aa) : recessive (aa)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a classic heterozygous cross (Aa × Aa)', tone: 'slate',
    given: 'Both pea plant parents are heterozygous for seed shape (Aa), where A (round) is dominant over a (wrinkled).',
    rows: [
      { label: 'Gametes from each parent:', value: 'A or a (each with 50% probability)' },
      { label: 'Grid outcomes:', value: 'AA, Aa, aA, aa (4 equally likely combinations)' },
      { label: 'Genotype ratio:', value: '1 AA : 2 Aa : 1 aa' },
      { label: 'Phenotype ratio:', value: '3 round : 1 wrinkled', full: true },
    ],
    note: 'This exact 3:1 ratio is what Gregor Mendel observed in his original pea plant experiments, forming the foundation of classical genetics.',
  },
  {
    title: 'Worked example 2 — a testcross (Aa × aa)', tone: 'amber',
    given: 'One parent is heterozygous (Aa) and the other is homozygous recessive (aa) — a classic "testcross" used to determine an unknown genotype.',
    rows: [
      { label: 'Gametes:', value: 'Parent 1: A or a. Parent 2: a only.' },
      { label: 'Grid outcomes:', value: 'Aa, Aa, aa, aa' },
      { label: 'Genotype ratio:', value: '2 Aa : 2 aa (i.e. 1:1)' },
      { label: 'Phenotype ratio:', value: '1 dominant : 1 recessive', full: true },
    ],
    note: 'A 1:1 phenotype ratio from a testcross confirms the tested parent was heterozygous (Aa) — if it had been homozygous dominant (AA), all offspring would show the dominant trait instead.',
  },
];

const comparison = {
  heading: 'Common monohybrid cross outcomes',
  note: 'The phenotype ratio depends entirely on which genotypes are being crossed.',
  headers: [{ label: 'Cross' }, { label: 'Genotype ratio' }, { label: 'Phenotype ratio' }],
  rows: [
    ['AA × AA', '4 AA', 'All dominant'],
    ['Aa × Aa ★', '1 AA : 2 Aa : 1 aa', '3 : 1'],
    ['Aa × aa', '2 Aa : 2 aa', '1 : 1'],
    ['aa × aa', '4 aa', 'All recessive'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). This is the cross Mendel used to establish the 3:1 phenotype ratio as a hallmark of simple dominant/recessive inheritance.',
};

const realWorld = [
  { emoji: '🌱', title: "Mendel's original pea plant experiments", body: 'Gregor Mendel\'s 19th-century pea plant crosses, analyzed using exactly this logic, established the foundational laws of inheritance that underlie all of modern genetics.' },
  { emoji: '🐕', title: 'Animal breeding programs', body: 'Breeders use Punnett square logic to predict the likelihood of offspring inheriting desired (or undesired) traits before making breeding decisions.' },
  { emoji: '🧬', title: 'Genetic counseling', body: 'Genetic counselors use Punnett squares to help prospective parents understand the probability of passing on a recessive genetic condition, especially when both parents are known carriers.' },
  { emoji: '🌾', title: 'Crop breeding', body: 'Agricultural scientists predict trait inheritance in crop breeding programs — such as disease resistance or yield traits — using the same monohybrid cross logic.' },
];

const misconceptions = [
  { claim: '"A Punnett square guarantees exactly a 3:1 ratio in any 4 offspring."', truth: 'A Punnett square shows probabilities, not guarantees — with only 4 actual offspring, you might see 4:0, 2:2, or any other split by chance. The predicted ratio becomes increasingly accurate only as the number of offspring grows large.' },
  { claim: '"The dominant allele is always the more common one in a population."', truth: "An allele's dominance describes how it behaves when paired with a different allele in an individual — it has no bearing on how common that allele is in the overall population, which depends on separate population genetics factors." },
  { claim: '"Heterozygous individuals show a blend of both traits."', truth: 'For simple complete dominance, a heterozygote (Aa) shows only the dominant phenotype, not a blend — blending only occurs in incomplete dominance, a different inheritance pattern covered by a separate calculator.' },
  { claim: '"A Punnett square can predict any trait, no matter how complex."', truth: 'The basic Punnett square models simple, single-gene traits with clean dominant/recessive inheritance. Many real traits (height, skin color, many diseases) are polygenic or influenced by environment, requiring far more complex models.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 12, "Mendel\'s Experiments and Heredity" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/12-1-mendels-experiments-and-the-laws-of-probability" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 3, Mendelian Genetics.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 14, Mendel and the Gene Idea.' },
];
const sourcesNote = 'Assumes simple complete dominance and independent assortment for a single gene. Results are exact probability ratios, not guaranteed outcomes.';

const howToUse = [
  { title: 'Enter both parent genotypes', body: 'Type each parent\'s allele pair for the gene, using uppercase for dominant and lowercase for recessive.' },
  { title: 'View the cross grid', body: 'The full Punnett square fills in with every possible offspring genotype combination.' },
  { title: 'Read the ratios', body: 'Genotype and phenotype ratios are tallied and displayed automatically.' },
];

const related = [
  { href: '/tools/dihybrid-cross-calculator', emoji: '🧬', title: 'Dihybrid Cross Calculator', desc: 'Two-gene cross — the classic 9:3:3:1 phenotype ratio.' },
  { href: '/tools/incomplete-dominance-calculator', emoji: '🌸', title: 'Incomplete Dominance Calculator', desc: 'Blended phenotypes — a different inheritance pattern.' },
  { href: '/tools/sex-linked-trait-calculator', emoji: '🔬', title: 'Sex-Linked Trait Punnett Calculator', desc: 'X-linked inheritance crosses.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="each parent contributes exactly one of its two alleles to each offspring, entirely by chance, so combining both parents' possible contributions into a grid reveals every genetically possible outcome and its exact probability."
  howIntro="The law of segregation states that each parent's two alleles separate during gamete formation, so each gamete carries only one allele for the gene. Listing one parent's possible gametes across the top of a grid and the other parent's down the side, then filling in every cell with the combination of the corresponding row and column, produces every possible offspring genotype with equal probability per cell. Tallying how many cells produce each phenotype (grouping genotypes that look the same due to dominance) gives the final predicted phenotype ratio."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Punnett squares actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Parent 1 genotype</span>
        <input id="p1" type="text" maxlength="2" value="Aa" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Parent 2 genotype</span>
        <input id="p2" type="text" maxlength="2" value="Aa" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 overflow-hidden rounded-xl border border-slate-200">
      <table id="grid" class="w-full table-fixed text-center"></table>
    </div>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Genotype ratio</div><div id="r-geno" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Phenotype ratio</div><div id="r-pheno" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="pun-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Homozygous vs heterozygous parents</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-homo" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Homozygous parent (AA)</h3>
          <p class="mt-1 text-sm text-slate-600">Both allele spheres are the same color — this parent can only pass on one type of allele.</p>
        </div>
        <div>
          <div id="diag-het" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Heterozygous parent (Aa)</h3>
          <p class="mt-1 text-sm text-slate-600">One dominant allele (indigo) and one recessive allele (amber) — this parent can pass on either one.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Punnett square ratio charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Genotype ratio (Aa × Aa) — 1:2:1</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-geno"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Phenotype ratio (Aa × Aa) — 3:1</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pheno"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function parseGeno(s) {
        s = (s || '').trim();
        if (s.length !== 2) return null;
        const letter = s[0].toLowerCase();
        const a1 = s[0], a2 = s[1];
        if (a1.toLowerCase() !== letter || a2.toLowerCase() !== letter) return null;
        return [a1, a2];
      }
      function isDominant(allele) { return allele === allele.toUpperCase(); }
      function phenotypeOf(pair) { return (isDominant(pair[0]) || isDominant(pair[1])) ? 'dominant' : 'recessive'; }

      function update() {
        el('pun-err').textContent = '';
        el('r-geno').textContent = '—'; el('r-pheno').textContent = '—';
        const g1 = parseGeno(el('p1').value), g2 = parseGeno(el('p2').value);
        el('grid').innerHTML = '';
        if (!g1 || !g2) { el('pun-err').textContent = 'Enter two letters of the same gene for each parent, e.g. Aa.'; return; }
        const results = [];
        for (const a of g1) for (const b of g2) results.push([a, b].sort((x, y) => (x.toLowerCase() === x ? 1 : -1) - (y.toLowerCase() === y ? 1 : -1)).join(''));
        // build grid
        let html = '<tr><td class="bg-slate-50 p-2"></td>';
        for (const b of g2) html += '<td class="bg-slate-50 p-2 font-mono font-bold text-slate-700">' + b + '</td>';
        html += '</tr>';
        let idx = 0;
        for (const a of g1) {
          html += '<tr><td class="bg-slate-50 p-2 font-mono font-bold text-slate-700">' + a + '</td>';
          for (const b of g2) { html += '<td class="border border-slate-100 p-3 font-mono font-semibold text-indigo-700">' + results[idx] + '</td>'; idx++; }
          html += '</tr>';
        }
        el('grid').innerHTML = html;
        // tally genotype and phenotype
        const genoCounts = {};
        const phenoCounts = { dominant: 0, recessive: 0 };
        results.forEach((g) => {
          genoCounts[g] = (genoCounts[g] || 0) + 1;
          phenoCounts[phenotypeOf(g)]++;
        });
        el('r-geno').textContent = Object.entries(genoCounts).map(([k, v]) => v + ' ' + k).join(' : ');
        el('r-pheno').textContent = phenoCounts.dominant + ' dominant : ' + phenoCounts.recessive + ' recessive';
      }
      ['p1', 'p2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts (fixed illustrative Aa x Aa example) ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.geno = new Chart(el('chart-geno'), {
          type: 'pie',
          data: { labels: ['AA', 'Aa', 'aa'], datasets: [{ data: [1, 2, 1], backgroundColor: ['#6366f1', '#f59e0b', '#94a3b8'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.pheno = new Chart(el('chart-pheno'), {
          type: 'pie',
          data: { labels: ['Dominant', 'Recessive'], datasets: [{ data: [3, 1], backgroundColor: ['#6366f1', '#94a3b8'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function alleleScene(container, colors) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        colors.forEach((c, i) => {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.7, 24, 20), new THREE.MeshStandardMaterial({ color: c, roughness: 0.4 }));
          sph.position.set(i === 0 ? -1 : 1, 0, 0);
          s.scene.add(sph);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagHomo = null, diagHet = null;
      function initDiagHomo() { const c = el('diag-homo'); if (!c) throw new Error('no container'); diagHomo = alleleScene(c, [0x6366f1, 0x6366f1]); }
      function initDiagHet() { const c = el('diag-het'); if (!c) throw new Error('no container'); diagHet = alleleScene(c, [0x6366f1, 0xf59e0b]); }

      function boot() {
        try { update(); } catch (e) { console.error('[punnett-square] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[punnett-square] charts failed', e); }
        if (window.THREE) {
          try { initDiagHomo(); } catch (e) { console.error('[punnett-square] homo diagram failed', e); }
          try { initDiagHet(); } catch (e) { console.error('[punnett-square] het diagram failed', e); }
        }
        mountResize([diagHomo, diagHet]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
