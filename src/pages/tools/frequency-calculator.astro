---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Frequency Calculator';
const description = 'Frequency calculator with a live 3D diagram and charts. Solve f = 1/T for frequency or period of any repeating motion, plus angular frequency (ω = 2πf) and RPM, with worked examples.';
const intro = 'Solve f = 1/T for the frequency or period of any repeating motion — a pendulum swing, a spinning fan, an AC power cycle, a vibrating string. Two 3D diagrams compare a slow and a fast oscillation side by side, and charts show how frequency and period trade off, and how real-world frequencies compare across many orders of magnitude.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the formula for frequency?', a: 'Frequency is the reciprocal of the period: f = 1/T, where f is in hertz (Hz, cycles per second) and T is the period in seconds (time for one complete cycle).' },
  { q: 'What is the difference between frequency and period?', a: 'Period (T) is how long one full cycle takes; frequency (f) is how many cycles happen per second. They are inverses of each other — a shorter period always means a higher frequency.' },
  { q: 'What is angular frequency?', a: 'Angular frequency (ω) measures rotation in radians per second rather than cycles per second: ω = 2πf. It is used throughout rotational motion, AC circuits, and simple harmonic motion equations.' },
  { q: 'How is frequency related to RPM?', a: 'RPM (revolutions per minute) converts to frequency in hertz by dividing by 60: f (Hz) = RPM / 60. Conversely, RPM = f × 60.' },
  { q: 'Why do power grids use 50 Hz or 60 Hz?', a: 'These frequencies were standardized in the early 20th century as a practical balance — fast enough to avoid visible flicker in lighting, slow enough for generators and transformers of the era to handle efficiently. Different regions settled on different standards (50 Hz in Europe/most of the world, 60 Hz in North America) and never fully unified.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Frequency Calculator',
  description: 'Solve f = 1/T for frequency from a period, or the reverse, plus angular frequency and RPM.',
  steps: [
    { name: 'Enter the period or frequency', text: 'Type a period in seconds, or a frequency in hertz — the other one solves automatically.' },
    { name: 'Read the derived values', text: 'Angular frequency (rad/s) and RPM are computed from whichever value you entered.' },
  ],
};

const formulas = [
  { expr: 'f = 1/T', note: 'frequency (Hz) is the reciprocal of the period (s)' },
  { expr: 'ω = 2πf', note: 'angular frequency in radians per second' },
  { expr: 'RPM = f × 60', note: 'revolutions per minute, common in engineering' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a pendulum', tone: 'slate',
    given: 'A pendulum completes one full swing (out and back) every 2 seconds, so T = 2 s.',
    rows: [
      { label: 'Formula:', value: 'f = 1/T' },
      { label: 'Substitute:', value: 'f = 1/2' },
      { label: 'Result:', value: 'f = 0.5 Hz, so ω = 2π × 0.5 = 3.14 rad/s', full: true },
    ],
    note: 'A frequency below 1 Hz simply means the cycle takes longer than one second — nothing unusual, just a slow oscillation.',
  },
  {
    title: 'Worked example 2 — a spinning fan blade', tone: 'amber',
    given: 'A cooling fan spins at f = 25 Hz.',
    rows: [
      { label: 'Formula:', value: 'T = 1/f' },
      { label: 'Substitute:', value: 'T = 1/25' },
      { label: 'Result:', value: 'T = 0.04 s = 40 ms, and RPM = 25 × 60 = 1500 rpm', full: true },
    ],
    note: 'Converting to RPM is common in mechanical engineering, where rotational speed is usually specified in revolutions per minute rather than hertz.',
  },
];

const comparison = {
  heading: 'Frequencies across everyday phenomena',
  note: 'From slow biological rhythms to fast radio waves, frequency spans an enormous range.',
  headers: [{ label: 'Phenomenon' }, { label: 'Frequency' }, { label: 'Period' }],
  rows: [
    ['Resting heart rate', '≈1.2 Hz', '≈0.83 s'],
    ['AC power (Europe/Asia)', '50 Hz ★', '20 ms'],
    ['AC power (North America)', '60 Hz', '16.7 ms'],
    ['Musical note A4', '440 Hz', '2.27 ms'],
    ['FM radio station', '≈100 MHz', '≈10 ns'],
    ['Wi-Fi (2.4 GHz band)', '2.4 GHz', '≈0.417 ns'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row. Note how period shrinks dramatically as frequency climbs — the two are always inversely related.',
};

const realWorld = [
  { emoji: '🎸', title: 'Music and acoustics', body: 'Every musical pitch corresponds to a specific frequency — A4 is standardized at 440 Hz. Doubling frequency raises a note by exactly one octave, which is why frequency (not period) is the natural unit for describing pitch.' },
  { emoji: '⚡', title: 'Electrical engineering', body: 'AC power alternates direction at a fixed frequency (50 or 60 Hz depending on region). Motors, transformers, and grid synchronization all depend on this frequency staying extremely stable — even small deviations can damage equipment.' },
  { emoji: '🔧', title: 'Mechanical design', body: 'Rotating machinery — engines, turbines, fans, hard drives — is specified by rotational frequency, usually in RPM. Converting between RPM and hertz is a routine step in mechanical and automotive engineering calculations.' },
  { emoji: '📡', title: 'Radio and wireless communication', body: 'Every radio band, Wi-Fi channel, and cellular network operates at an assigned frequency. Regulatory bodies allocate frequency ranges precisely because transmissions at the same frequency interfere with each other.' },
];

const misconceptions = [
  { claim: '"A higher frequency always means a physically faster-moving object."', truth: "Frequency measures how often a cycle repeats, not speed directly. A pendulum with a longer arm can swing at a lower frequency while still moving through a larger arc at high speed at the bottom of its swing — frequency and speed are related but not the same thing." },
  { claim: '"Frequency and angular frequency are the same number."', truth: 'They differ by a factor of 2π. Frequency f counts cycles per second; angular frequency ω = 2πf counts radians per second, since one full cycle corresponds to 2π radians of rotation.' },
  { claim: '"Zero frequency just means a very slow oscillation."', truth: 'Zero frequency means no oscillation at all — an infinite period, i.e., the motion never completes a cycle. This is different from a very low but nonzero frequency, which does eventually repeat.' },
  { claim: '"RPM and Hz measure different physical quantities."', truth: 'They measure the same thing — rate of rotation — just in different units. RPM counts revolutions per minute; Hz counts cycles per second. Converting between them is just a unit conversion (÷60 or ×60), not a different formula.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 15, "Oscillations" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/15-1-simple-harmonic-motion" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 15, Oscillations.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Periodic Motion chapter.' },
];
const sourcesNote = 'f = 1/T, ω = 2πf. Results are rounded for display.';

const howToUse = [
  { title: 'Enter a period', body: 'Type any period in seconds — frequency, angular frequency, and RPM solve instantly.' },
  { title: 'Or enter a frequency', body: 'Type a frequency in hertz instead — the period and other derived values update the same way.' },
  { title: 'Compare examples', body: 'Use the comparison table below to see how your value stacks up against real-world frequencies.' },
];

const related = [
  { href: '/tools/wavelength-frequency-calculator', emoji: '〰️', title: 'Wavelength Calculator', desc: 'v = fλ — solve wave speed, frequency, or wavelength.' },
  { href: '/tools/simple-harmonic-motion-calculator', emoji: '🎻', title: 'Simple Harmonic Motion Calculator', desc: 'x(t), v(t), a(t) for a mass-spring oscillator.' },
  { href: '/tools/uniform-circular-motion-calculator', emoji: '🔄', title: 'Uniform Circular Motion Calculator', desc: 'Centripetal accel/force, period, ω from r and v.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="frequency and period are two ways of describing the same repeating motion — one counts cycles per second, the other times a single cycle — so knowing either one always tells you the other."
  howIntro="Any process that repeats at regular intervals — a swing, a rotation, a vibration, an electrical cycle — has both a period (the time for one repeat) and a frequency (how many repeats happen per second). Because they describe the same motion from opposite directions, multiplying them together always gives exactly 1: f × T = 1. Angular frequency reframes the same rate in radians instead of whole cycles, which is why it shows up throughout rotational motion and wave equations."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where frequency actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter either value — the other solves automatically</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Period, T (s)</span>
        <input id="period" type="number" step="any" placeholder="e.g. 2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Frequency, f (Hz)</span>
        <input id="freq" type="number" step="any" placeholder="e.g. 0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Frequency (f)</div><div id="r-f" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Angular frequency (ω)</div><div id="r-w" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">RPM</div><div id="r-rpm" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="freq-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Slow vs. fast oscillation</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-slow" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low frequency (long period)</h3>
          <p class="mt-1 text-sm text-slate-600">A slowly swinging pendulum — few cycles per second, so each cycle takes a relatively long time.</p>
        </div>
        <div>
          <div id="diag-fast" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High frequency (short period)</h3>
          <p class="mt-1 text-sm text-slate-600">A rapidly rotating disc — many cycles per second, so each individual cycle is very brief.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Frequency graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Frequency vs. period (f = 1/T)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ft"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Real-world frequencies (log scale)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-examples"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update(source) {
        el('freq-err').textContent = '';
        el('r-f').textContent = '—'; el('r-w').textContent = '—'; el('r-rpm').textContent = '—';
        let T = parseFloat(el('period').value), f = parseFloat(el('freq').value);
        if (source === 'period' && !isNaN(T)) { if (T <= 0) { el('freq-err').textContent = 'Period must be positive.'; return; } f = 1 / T; el('freq').value = ''; }
        else if (source === 'freq' && !isNaN(f)) { if (f <= 0) { el('freq-err').textContent = 'Frequency must be positive.'; return; } T = 1 / f; el('period').value = ''; }
        else return;
        el('r-f').textContent = fmt(f) + ' Hz';
        el('r-w').textContent = fmt(2 * Math.PI * f) + ' rad/s';
        el('r-rpm').textContent = fmt(f * 60) + ' rpm';
      }
      el('period').addEventListener('input', () => update('period'));
      el('freq').addEventListener('input', () => update('freq'));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsT = [], dataF = [];
        for (let t = 0.1; t <= 3; t += 0.1) { labelsT.push(t.toFixed(1)); dataF.push(+(1 / t).toFixed(3)); }
        new Chart(el('chart-ft'), {
          type: 'line',
          data: { labels: labelsT, datasets: [{ label: 'f (Hz)', data: dataF, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Period T (s)' } }, y: { title: { display: true, text: 'Frequency f (Hz)' } } }, plugins: { legend: { display: false } } }),
        });
        const exLabels = ['Heart rate', '50Hz power', '60Hz power', 'Note A4', 'FM radio', 'Wi-Fi'];
        const exData = [1.2, 50, 60, 440, 1e8, 2.4e9];
        new Chart(el('chart-examples'), {
          type: 'bar',
          data: { labels: exLabels, datasets: [{ label: 'Frequency (Hz)', data: exData, backgroundColor: '#f59e0b' }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Frequency (Hz, log scale)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function wheelScene(container, speed) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const disc = new THREE.Mesh(new THREE.CylinderGeometry(2, 2, 0.3, 32), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
        disc.rotation.x = Math.PI / 2;
        s.scene.add(disc);
        const marker = new THREE.Mesh(new THREE.SphereGeometry(0.22, 12, 10), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
        marker.position.set(1.8, 0.2, 0);
        disc.add(marker);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) disc.rotation.z += speed; s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSlow = null, diagFast = null;
      function initDiagSlow() { const c = el('diag-slow'); if (!c) throw new Error('no container'); diagSlow = wheelScene(c, 0.006); }
      function initDiagFast() { const c = el('diag-fast'); if (!c) throw new Error('no container'); diagFast = wheelScene(c, 0.04); }

      function boot() {
        try { update('freq') || update('period'); } catch (e) { console.error('[frequency] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[frequency] charts failed', e); }
        if (window.THREE) {
          try { initDiagSlow(); } catch (e) { console.error('[frequency] slow diagram failed', e); }
          try { initDiagFast(); } catch (e) { console.error('[frequency] fast diagram failed', e); }
        }
        mountResize([diagSlow, diagFast]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
