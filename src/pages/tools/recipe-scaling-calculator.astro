---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Recipe Scaling Calculator';
const description =
  'Free recipe scaling calculator. Scale any recipe up or down by serving count or a custom multiplier, adjusting every ingredient amount proportionally.';
const intro =
  'Enter your original servings and target servings (or a multiplier) to scale every ingredient in your recipe proportionally.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'How does recipe scaling work?', a: 'Recipe scaling uses a simple ratio: new amount = original amount × (new servings ÷ original servings). If a recipe serves 4 and you want 6, you multiply each ingredient by 6 ÷ 4 = 1.5. This keeps the proportions identical so the dish tastes the same.' },
  { q: 'Can I scale any recipe this way?', a: 'Most recipes scale well between 0.5× and 4× the original. Extreme scaling — such as turning a 2-serving recipe into 50 servings — can cause issues with pan sizes, cooking times and ingredient behaviour (especially for baked goods).' },
  { q: 'Do eggs scale easily?', a: 'Eggs can be tricky since they come in whole units. For fractional egg amounts, beat the egg first, then measure out the fraction you need (e.g. half a beaten egg ≈ 1.5 tbsp). For large batches, round to the nearest whole egg and adjust liquid slightly.' },
  { q: 'What about spices and seasoning?', a: 'Spices scale linearly for savoury dishes, but be cautious with strong spices like cayenne, cloves or asafoetida — start with slightly less and taste as you go. Salt can also be reduced slightly when scaling up.' },
  { q: 'Does scaling affect cooking time?', a: 'Yes, especially for baked goods and large roasts. A larger volume of batter in a bigger pan may bake faster or slower depending on pan shape. Always check for doneness with a skewer or thermometer rather than relying on the original cooking time.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Original servings</span>
        <input id="orig" type="number" step="any" placeholder="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">New servings</span>
        <input id="new" type="number" step="any" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Or enter a multiplier directly</span>
        <input id="mult" type="number" step="0.25" placeholder="1.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Ingredient amount (optional — see scaled result)</span>
        <input id="amount" type="number" step="any" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Scaling factor</div>
        <div id="r-factor" class="mt-1 text-3xl font-bold">1.0×</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Original amount</div><div id="r-orig" class="mt-1 text-xl font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Scaled amount</div><div id="r-scaled" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter servings or a multiplier to see the scaling factor.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The Recipe Scaling Calculator uses a simple proportional method to adjust ingredient quantities. When you change the number of servings a recipe produces, every ingredient must be adjusted by the same ratio so that the dish's flavour balance, texture and consistency remain unchanged. The calculator computes a scaling factor by dividing your target servings by the original servings, then applies that factor to any ingredient amount you enter.
    </p>
    <p class="mt-3 text-slate-600">
      This approach works for virtually any recipe — soups, stews, sauces, marinades, salad dressings, casseroles and even many baked goods. The principle is straightforward: cooking is about ratios, and as long as you keep the ratios intact, the recipe will behave the same way regardless of batch size. Professional kitchens use this exact method every day, often working with "baker's percentages" or "yield factors" to scale production up and down.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="rs-title rs-desc">
      <title id="rs-title">Recipe scaling diagram</title>
      <desc id="rs-desc">A recipe card visual showing original servings being multiplied by a scaling arrow to produce new servings with adjusted ingredient amounts.</desc>
      <rect x="80" y="40" width="220" height="140" rx="12" fill="#fff" stroke="#cbd5e1" stroke-width="2" />
      <rect x="100" y="55" width="180" height="12" rx="4" fill="#6366f1" />
      <rect x="100" y="78" width="100" height="8" rx="2" fill="#e2e8f0" />
      <rect x="100" y="94" width="140" height="8" rx="2" fill="#e2e8f0" />
      <rect x="100" y="110" width="80" height="8" rx="2" fill="#e2e8f0" />
      <rect x="100" y="126" width="120" height="8" rx="2" fill="#e2e8f0" />
      <text x="190" y="170" text-anchor="middle" font-size="13" font-weight="bold" fill="#475569">4 servings</text>

      <path d="M 320 110 Q 360 60 400 110 Q 440 160 480 110" fill="none" stroke="#6366f1" stroke-width="3" marker-end="url(#arrow)" />
      <defs><marker id="arrow" markerWidth="10" markerHeight="8" refX="9" refY="4" orient="auto"><path d="M 0 0 L 10 4 L 0 8 Z" fill="#6366f1" /></marker></defs>
      <text x="400" y="42" text-anchor="middle" font-size="15" font-weight="bold" fill="#6366f1">× 1.5</text>

      <rect x="500" y="40" width="220" height="140" rx="12" fill="#fff" stroke="#6366f1" stroke-width="2" />
      <rect x="520" y="55" width="180" height="12" rx="4" fill="#6366f1" />
      <rect x="520" y="78" width="150" height="8" rx="2" fill="#c7d2fe" />
      <rect x="520" y="94" width="180" height="8" rx="2" fill="#c7d2fe" />
      <rect x="520" y="110" width="120" height="8" rx="2" fill="#c7d2fe" />
      <rect x="520" y="126" width="160" height="8" rx="2" fill="#c7d2fe" />
      <text x="610" y="170" text-anchor="middle" font-size="13" font-weight="bold" fill="#475569">6 servings</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Scaling a 4-serving recipe up to 6 servings using a 1.5× multiplier</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the conversion works</h2>
    <p class="mt-2 text-slate-600">
      The core formula is simple: <strong>scaling factor</strong> = new servings ÷ original servings. Multiply every ingredient amount by this factor to get the scaled quantity.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A lasagne recipe serves 6 and calls for 500 g of minced beef, 2 cans of tomatoes, 3 garlic cloves, 250 g of lasagne sheets and 400 ml of béchamel sauce. You need to serve 9 people.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Original servings:</span> <span class="text-slate-600">6</span></div>
        <div><span class="font-medium text-slate-700">Target servings:</span> <span class="text-slate-600">9</span></div>
        <div><span class="font-medium text-slate-700">Scaling factor:</span> <span class="text-slate-600">9 ÷ 6 = <strong>1.5</strong></span></div>
        <div><span class="font-medium text-slate-700">Minced beef:</span> <span class="text-slate-600">500 g × 1.5 = <strong>750 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Canned tomatoes:</span> <span class="text-slate-600">2 × 1.5 = <strong>3 cans</strong></span></div>
        <div><span class="font-medium text-slate-700">Garlic cloves:</span> <span class="text-slate-600">3 × 1.5 = <strong>4.5 cloves</strong> (use 4–5)</span></div>
        <div><span class="font-medium text-slate-700">Lasagne sheets:</span> <span class="text-slate-600">250 g × 1.5 = <strong>375 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Béchamel sauce:</span> <span class="text-slate-600">400 ml × 1.5 = <strong>600 ml</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍👩‍👧‍👦</span>
      <h3 class="mt-2 font-semibold text-slate-900">Home cook feeding a crowd</h3>
      <p class="mt-1 text-sm text-slate-600">Doubling or tripling family favourites like chilli, curry or pasta bake for a gathering without having to calculate each ingredient manually.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍞</span>
      <h3 class="mt-2 font-semibold text-slate-900">Home baker</h3>
      <p class="mt-1 text-sm text-slate-600">Scaling bread or cake recipes to fit different pan sizes or to produce more loaves for a bake sale while keeping the ingredient ratios precise.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍽️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Meal prep enthusiast</h3>
      <p class="mt-1 text-sm text-slate-600">Scaling weekly meal prep recipes up or down to match exact portion counts for the week ahead, reducing food waste and saving time.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Small-scale caterer</h3>
      <p class="mt-1 text-sm text-slate-600">Taking a base recipe for 4 and adjusting it to serve 20, 40 or more for events while keeping quality and consistency across batches.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Recipe Scaling Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter original servings</h3>
        <p class="mt-1 text-sm text-slate-600">Type the number of servings your original recipe yields. This is the baseline for all calculations.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter new servings or multiplier</h3>
        <p class="mt-1 text-sm text-slate-600">Type the number of servings you want, or enter a multiplier directly (e.g. 2 for double). The scaling factor updates instantly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check scaled amounts</h3>
        <p class="mt-1 text-sm text-slate-600">Enter any ingredient amount to see its scaled value. Use the factor shown to convert every ingredient in your recipe.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Round fractional amounts sensibly</h3>
        <p class="mt-1 text-sm text-slate-600">When scaling produces awkward fractions (like 1.37 tsp of salt), round to a practical measurement — 1.5 tsp is much easier to measure. For baking, be more precise; for everyday cooking, rounding is fine.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Adjust cooking vessels and times</h3>
        <p class="mt-1 text-sm text-slate-600">A larger batch needs a bigger pot or pan. Baking times change when you scale a recipe — a larger cake in the same size tin will be thicker and need more time, while the same batter in a larger tin will be thinner and bake faster.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Taste and adjust as you go</h3>
        <p class="mt-1 text-sm text-slate-600">Scaling is an exact science for ingredients but salt, spice and acid often benefit from a final tasting. Season incrementally towards the end of cooking rather than adding the full scaled amount of salt up front.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/cooking-measurement-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🥄</span>
        <h3 class="mt-2 font-semibold text-slate-900">Cooking Measurement Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert between cups, tbsp, tsp, ml and fl oz</p>
      </a>
      <a href="/tools/baking-conversion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">⚖️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Conversion Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Volume to weight for flour, sugar, butter and more</p>
      </a>
      <a href="/tools/baking-ingredient-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🧈</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Ingredient Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert butter, flour and sugar between forms</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const orig = parseFloat(el('orig').value);
      const newS = parseFloat(el('new').value);
      const mult = parseFloat(el('mult').value);
      const amount = parseFloat(el('amount').value);

      let factor;
      if (mult && mult > 0) {
        factor = mult;
      } else if (orig && orig > 0 && newS && newS > 0) {
        factor = newS / orig;
      } else {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      if (factor <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      el('r-factor').textContent = factor.toLocaleString(undefined, { maximumFractionDigits: 3 }) + '\u00D7';
      if (amount && amount > 0) {
        el('r-orig').textContent = amount.toLocaleString(undefined, { maximumFractionDigits: 2 });
        el('r-scaled').textContent = (amount * factor).toLocaleString(undefined, { maximumFractionDigits: 2 });
      } else {
        el('r-orig').textContent = '\u2014';
        el('r-scaled').textContent = '\u2014';
      }
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    ['orig', 'new', 'mult', 'amount'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
