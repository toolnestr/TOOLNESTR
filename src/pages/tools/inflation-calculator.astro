---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Inflation Calculator';
const description =
  'Free inflation calculator. See how inflation changes the value and buying power of money ' +
  'over time at a given rate. Works in any currency.';
const intro =
  'Enter an amount, an inflation rate and a number of years to see future prices and how buying power changes.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'What does inflation do to money?', a: 'Inflation makes prices rise over time, so the same amount of money buys less in the future. A steady 3% inflation roughly halves your buying power in about 24 years.' },
  { q: 'What inflation rate should I use?', a: 'Many countries target around 2–3% per year, but it varies. Use your own estimate or your country’s recent average.' },
  { q: 'What is “buying power”?', a: 'It’s what your money will actually be worth in today’s terms after inflation — useful for understanding long-term savings and retirement.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Currency</span>
        <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option>$</option><option>€</option><option>£</option><option>₹</option><option>₨</option><option>¥</option><option>₦</option><option>A$</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Amount today</span>
        <input id="amount" type="number" step="any" placeholder="1000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Inflation rate % / year</span>
        <input id="rate" type="number" step="any" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Years</span>
        <input id="years" type="number" step="any" placeholder="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Future price (what it’ll cost)</div><div id="r-future" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Buying power (today’s value)</div><div id="r-power" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="explain" class="mt-3 text-center text-sm text-slate-500"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About inflation</h2>
    <p class="mt-2 text-slate-600">
      Inflation quietly erodes the value of money over time. Understanding it helps you plan for
      the future — whether you’re saving for retirement, budgeting long term, or just curious how
      much something will cost in 10 or 20 years. This calculator shows both the future price of
      today’s money and how much your money will really be worth.
    </p>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/compound-interest" class="font-medium text-indigo-600 hover:underline">Compound Interest Calculator</a>
      or <a href="/tools/investment-calculator" class="font-medium text-indigo-600 hover:underline">Investment Calculator</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const cur = el('cur');
    const fmt = (n) => cur.value + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    function update() {
      const amount = parseFloat(el('amount').value);
      const rate = parseFloat(el('rate').value);
      const years = parseFloat(el('years').value);
      if (isNaN(amount) || isNaN(rate) || isNaN(years) || years < 0) { el('r-future').textContent = el('r-power').textContent = '—'; el('explain').textContent = ''; return; }
      const factor = Math.pow(1 + rate / 100, years);
      el('r-future').textContent = fmt(amount * factor);
      el('r-power').textContent = fmt(amount / factor);
      el('explain').textContent = `In ${years} years at ${rate}% inflation, ${fmt(amount)} today will have the buying power of about ${fmt(amount / factor)}.`;
    }
    ['cur', 'amount', 'rate', 'years'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
