---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Hardy-Weinberg Allele Frequency Calculator';
const description = 'Hardy-Weinberg calculator with a live 3D allele-pool diagram and charts. Solve p²+2pq+q²=1 for allele and genotype frequencies in a population, with worked examples for recessive disease carrier rates.';
const intro = 'Enter an allele frequency or an observed genotype frequency to solve the Hardy-Weinberg equations p+q=1 and p²+2pq+q²=1 for the rest. Two 3D diagrams compare a population near equilibrium to one with a rare recessive allele, and charts show how genotype frequencies shift as allele frequency changes.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is the Hardy-Weinberg principle?', a: 'The Hardy-Weinberg principle describes allele and genotype frequencies in a population that is not evolving — one with no mutation, migration, genetic drift, or selection, and random mating. It provides a baseline (p²+2pq+q²=1) to detect when a population is actually evolving.' },
  { q: 'What do p and q represent?', a: 'p is the frequency of the dominant allele in the population, and q is the frequency of the recessive allele, where p+q=1 (they must add up to the whole population\'s alleles for that gene).' },
  { q: 'How do I find allele frequency from a recessive phenotype frequency?', a: 'Since only the homozygous recessive genotype (qq) shows the recessive phenotype, the observed frequency of that phenotype equals q² directly — take the square root to find q, then p=1−q.' },
  { q: 'What does 2pq represent?', a: '2pq is the frequency of heterozygous individuals (carriers) in the population — they carry one copy of each allele but show the dominant phenotype since they\'re not homozygous recessive.' },
  { q: 'Why is the Hardy-Weinberg principle useful if real populations rarely meet all its assumptions?', a: 'It serves as a null hypothesis — by comparing predicted Hardy-Weinberg frequencies to actually observed frequencies, biologists can detect and measure real evolutionary forces (like selection or drift) acting on a population.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Hardy-Weinberg Allele Frequency Calculator',
  description: 'Solve for allele and genotype frequencies using p+q=1 and p²+2pq+q²=1.',
  steps: [
    { name: 'Pick a mode', text: 'Enter a known allele frequency (p or q), or an observed recessive phenotype frequency (q²).' },
    { name: 'Read the results', text: 'All genotype frequencies (p², 2pq, q²) and both allele frequencies solve instantly.' },
    { name: 'Interpret carrier rate', text: 'The 2pq value gives the frequency of heterozygous carriers in the population.' },
  ],
};

const formulas = [
  { expr: 'p + q = 1', note: 'allele frequencies for a two-allele gene must sum to 1' },
  { expr: 'p² + 2pq + q² = 1', note: 'genotype frequencies — p²=homozygous dominant, 2pq=heterozygous, q²=homozygous recessive' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — finding carrier frequency for a recessive condition', tone: 'slate',
    given: 'A recessive genetic condition appears in 9% of a population (q² = 0.09). Find the allele frequencies and the carrier (heterozygous) frequency.',
    rows: [
      { label: 'Recessive allele frequency:', value: 'q = √0.09 = 0.3' },
      { label: 'Dominant allele frequency:', value: 'p = 1 − q = 1 − 0.3 = 0.7' },
      { label: 'Carrier frequency:', value: '2pq = 2 × 0.7 × 0.3 = 0.42, or 42%' },
      { label: 'Homozygous dominant:', value: 'p² = 0.7² = 0.49, or 49%', full: true },
    ],
    note: 'Notice that carriers (42%) far outnumber affected individuals (9%) — a common and important insight when counseling families about recessive genetic conditions.',
  },
  {
    title: 'Worked example 2 — starting from a known allele frequency', tone: 'amber',
    given: 'In a population, the recessive allele frequency is known to be q = 0.1. Find all genotype frequencies.',
    rows: [
      { label: 'Dominant allele:', value: 'p = 1 − 0.1 = 0.9' },
      { label: 'Homozygous dominant (p²):', value: '0.9² = 0.81, or 81%' },
      { label: 'Heterozygous (2pq):', value: '2 × 0.9 × 0.1 = 0.18, or 18%' },
      { label: 'Homozygous recessive (q²):', value: '0.1² = 0.01, or 1%', full: true },
    ],
    note: 'These three genotype frequencies (0.81+0.18+0.01) sum to exactly 1.00, confirming the calculation is internally consistent.',
  },
];

const comparison = {
  heading: 'How carrier frequency changes with allele rarity',
  note: 'As the recessive allele becomes rarer, the gap between carrier frequency (2pq) and affected frequency (q²) grows dramatically.',
  headers: [{ label: 'q (recessive allele)' }, { label: 'Affected (q²)' }, { label: 'Carriers (2pq)' }],
  rows: [
    ['0.5', '25%', '50%'],
    ['0.3 ★', '9%', '42%'],
    ['0.1', '1%', '18%'],
    ['0.01', '0.01%', '~2%'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). For rare recessive conditions, carriers vastly outnumber affected individuals — this is why many genetic diseases seem to "skip generations."',
};

const realWorld = [
  { emoji: '🧬', title: 'Estimating carrier rates for genetic diseases', body: 'Public health researchers use Hardy-Weinberg calculations to estimate how many people in a population carry one copy of a disease allele, informing genetic screening program design.' },
  { emoji: '🐄', title: 'Conservation genetics', body: 'Conservation biologists use deviations from Hardy-Weinberg equilibrium to detect inbreeding, genetic drift, or selection pressure in small or endangered populations.' },
  { emoji: '🔬', title: 'Detecting natural selection', body: 'When a population\'s observed genotype frequencies significantly deviate from Hardy-Weinberg predictions, it signals that real evolutionary forces — like selection against a particular genotype — are actively at work.' },
  { emoji: '📊', title: 'Population genetics research baseline', body: 'Hardy-Weinberg equilibrium serves as the fundamental null model against which every real population genetics study is compared, making it foundational to the entire field.' },
];

const misconceptions = [
  { claim: '"A population in Hardy-Weinberg equilibrium is not evolving and never will."', truth: "Hardy-Weinberg equilibrium describes a snapshot under specific idealized conditions (no mutation, migration, drift, selection, random mating) — real populations rarely meet all these conditions perfectly, which is exactly why deviations from the prediction are used to detect real evolutionary change." },
  { claim: '"If a disease affects 1% of a population, only 1% of people carry the allele."', truth: 'For a recessive condition, the affected frequency is q² (only 1% in this example), but the carrier frequency 2pq is typically much higher — for q²=0.01, carriers make up about 18% of the population, far more than the affected 1%.' },
  { claim: '"p and q refer to two different genes."', truth: 'p and q are the two allele frequencies for the SAME gene (one gene, two alternate alleles) — not two separate genes. Genes with more than two alleles require an extended version of the Hardy-Weinberg math.' },
  { claim: '"Hardy-Weinberg calculations require actually counting every individual\'s genotype."', truth: 'One of the most useful features of Hardy-Weinberg math is that you only need to observe ONE genotype frequency (usually the recessive phenotype, since it directly reveals q²) to calculate every other allele and genotype frequency in the population.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 19, "Population and Community Ecology" / Chapter 20, "Evolution" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/19-4-population-genetics" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 25, Population Genetics.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 23, The Evolution of Populations.' },
];
const sourcesNote = 'p+q=1; p²+2pq+q²=1. Assumes the five Hardy-Weinberg conditions (no mutation, migration, drift, selection; random mating). Results are rounded for display.';

const howToUse = [
  { title: 'Pick your known value', body: 'Enter either an allele frequency (p or q) or an observed recessive phenotype frequency (q²).' },
  { title: 'Read all frequencies', body: 'Both allele frequencies and all three genotype frequencies solve instantly.' },
  { title: 'Interpret carrier rate', body: 'The 2pq value shows how common heterozygous carriers are, often surprisingly higher than the affected frequency.' },
];

const related = [
  { href: '/tools/punnett-square-calculator', emoji: '🧬', title: 'Punnett Square Calculator', desc: 'Monohybrid cross — the classic 3:1 phenotype ratio.' },
  { href: '/tools/chi-square-genetics-calculator', emoji: '📊', title: 'Chi-Square Goodness of Fit Calculator', desc: 'Test whether observed offspring match a predicted ratio.' },
  { href: '/tools/population-density-calculator', emoji: '🌍', title: 'Population Density Calculator', desc: 'D = N/A — individuals per unit area.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="if a population's mating is truly random and no evolutionary forces are acting on a gene, the frequencies of its genotypes settle into a fixed, predictable relationship with the underlying allele frequencies — any real deviation from that prediction is a signal that evolution is actually happening."
  howIntro="Since every individual carries exactly two alleles for a gene, and p and q are simply the overall population-wide frequencies of each allele, p+q=1 must hold by definition. Expanding (p+q)² algebraically gives p²+2pq+q²=1 — and because random mating means any two gametes combine independently, this expansion exactly predicts the frequency of each genotype: p² for homozygous dominant, 2pq for heterozygous (the cross term counts both possible parental origins), and q² for homozygous recessive."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Hardy-Weinberg calculations actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-q" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From q (recessive allele freq.)</button>
      <button id="mode-q2" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From q² (affected phenotype freq.)</button>
    </div>
    <div id="field-q" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Recessive allele frequency (q)</span>
        <input id="qval" type="number" step="any" min="0" max="1" value="0.3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="field-q2" class="hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Affected phenotype frequency (q²)</span>
        <input id="q2val" type="number" step="any" min="0" max="1" value="0.09" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-5">
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">p</div><div id="r-p" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">q</div><div id="r-q" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-3 text-center text-white"><div class="text-xs opacity-80">p² (AA)</div><div id="r-p2" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-amber-500 p-3 text-center text-white"><div class="text-xs opacity-80">2pq (Aa)</div><div id="r-2pq" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-500 p-3 text-center text-white"><div class="text-xs opacity-80">q² (aa)</div><div id="r-q2" class="mt-1 text-lg font-bold">—</div></div>
    </div>
    <p id="hw-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Allele pools compared</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-common" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Both alleles common (p≈q≈0.5)</h3>
          <p class="mt-1 text-sm text-slate-600">Dominant (indigo) and recessive (amber) alleles are roughly balanced in the population pool.</p>
        </div>
        <div>
          <div id="diag-rare" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Recessive allele rare (q small)</h3>
          <p class="mt-1 text-sm text-slate-600">Very few recessive alleles (amber) among a majority of dominant alleles (indigo) — most copies of the recessive allele exist in heterozygous carriers.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Hardy-Weinberg graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Genotype frequencies vs allele frequency q</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-freq"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Carrier (2pq) vs affected (q²) frequency</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-carrier"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      let mode = 'q';
      function switchMode(m) {
        mode = m;
        el('mode-q').className = m === 'q' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-q2').className = m === 'q2' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('field-q').className = m === 'q' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        el('field-q2').className = m === 'q2' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        update();
      }
      function update() {
        el('hw-err').textContent = '';
        ['r-p', 'r-q', 'r-p2', 'r-2pq', 'r-q2'].forEach((id) => (el(id).textContent = '—'));
        let q;
        if (mode === 'q') {
          q = parseFloat(el('qval').value);
        } else {
          const q2 = parseFloat(el('q2val').value);
          if (isNaN(q2)) return;
          if (q2 < 0 || q2 > 1) { el('hw-err').textContent = 'q² must be between 0 and 1.'; return; }
          q = Math.sqrt(q2);
        }
        if (isNaN(q)) return;
        if (q < 0 || q > 1) { el('hw-err').textContent = 'q must be between 0 and 1.'; return; }
        const p = 1 - q;
        el('r-p').textContent = fmt(p);
        el('r-q').textContent = fmt(q);
        el('r-p2').textContent = (p * p * 100).toFixed(2) + '%';
        el('r-2pq').textContent = (2 * p * q * 100).toFixed(2) + '%';
        el('r-q2').textContent = (q * q * 100).toFixed(2) + '%';
      }
      el('mode-q').addEventListener('click', () => switchMode('q'));
      el('mode-q2').addEventListener('click', () => switchMode('q2'));
      ['qval', 'q2val'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsQ = [], dataP2 = [], data2pq = [], dataQ2 = [];
        for (let qq = 0; qq <= 1; qq += 0.1) { const pp = 1 - qq; labelsQ.push(qq.toFixed(1)); dataP2.push(+(pp * pp).toFixed(3)); data2pq.push(+(2 * pp * qq).toFixed(3)); dataQ2.push(+(qq * qq).toFixed(3)); }
        charts.freq = new Chart(el('chart-freq'), {
          type: 'line',
          data: { labels: labelsQ, datasets: [
            { label: 'p² (AA)', data: dataP2, borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
            { label: '2pq (Aa)', data: data2pq, borderColor: '#f59e0b', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
            { label: 'q² (aa)', data: dataQ2, borderColor: '#94a3b8', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'q (recessive allele frequency)' } }, y: { title: { display: true, text: 'Genotype frequency' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        const labelsQ2 = [0.5, 0.3, 0.1, 0.05, 0.01];
        charts.carrier = new Chart(el('chart-carrier'), {
          type: 'bar',
          data: { labels: labelsQ2.map((q) => 'q=' + q), datasets: [
            { label: 'Affected (q²)', data: labelsQ2.map((q) => +(q * q * 100).toFixed(2)), backgroundColor: '#94a3b8' },
            { label: 'Carriers (2pq)', data: labelsQ2.map((q) => +(2 * (1 - q) * q * 100).toFixed(2)), backgroundColor: '#f59e0b' },
          ] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Percent of population' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function poolScene(container, qFrac) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const total = 30;
        const recessiveCount = Math.round(total * qFrac);
        for (let i = 0; i < total; i++) {
          const x = (Math.random() - 0.5) * 5, y = (Math.random() - 0.5) * 3, z = (Math.random() - 0.5) * 3;
          const color = i < recessiveCount ? 0xf59e0b : 0x6366f1;
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.22, 12, 10), new THREE.MeshStandardMaterial({ color }));
          sph.position.set(x, y, z);
          s.scene.add(sph);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagCommon = null, diagRare = null;
      function initDiagCommon() { const c = el('diag-common'); if (!c) throw new Error('no container'); diagCommon = poolScene(c, 0.5); }
      function initDiagRare() { const c = el('diag-rare'); if (!c) throw new Error('no container'); diagRare = poolScene(c, 0.1); }

      function boot() {
        try { switchMode('q'); } catch (e) { console.error('[hardy-weinberg] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[hardy-weinberg] charts failed', e); }
        if (window.THREE) {
          try { initDiagCommon(); } catch (e) { console.error('[hardy-weinberg] common diagram failed', e); }
          try { initDiagRare(); } catch (e) { console.error('[hardy-weinberg] rare diagram failed', e); }
        }
        mountResize([diagCommon, diagRare]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
