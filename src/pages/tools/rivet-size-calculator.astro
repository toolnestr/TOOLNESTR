---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Rivet Size Calculator';
const description = 'Find the right rivet diameter and grip length for joining two or more sheets of material, from the total material thickness (grip range).';
const intro = 'Find the right rivet diameter and grip length for your material stack-up.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I choose a rivet diameter?', a: 'A common rule of thumb picks a rivet diameter roughly 3 times the thickness of the thinnest sheet being joined, within the rivet\'s rated shear strength for the application. This calculator suggests a diameter from your total stack thickness as a starting point — always confirm against the rivet manufacturer\'s load rating for your application.' },
  { q: 'What is rivet grip length?', a: 'Grip length is the total thickness of all the materials being joined together, which the rivet must span and clamp. Rivets are manufactured in a range of grip lengths, and choosing one within the rivet\'s rated grip range ensures the mandrel breaks off flush and the joint clamps properly, whether it\'s a solid rivet or a pop (blind) rivet.' },
  { q: 'What happens if I use a grip length that\'s too short or too long?', a: 'Too short a grip and the rivet won\'t fully engage or clamp the stack; too long and the mandrel may not set correctly, leaving a loose or improperly formed joint. Manufacturers publish a grip range for each rivet length — stay within it for a reliable joint.' },
  { q: 'Do I need a specific hole size for a rivet?', a: 'Yes — rivet holes are typically drilled slightly larger than the rivet\'s nominal diameter (often by about 1/32 inch, or per the manufacturer\'s spec) to allow for easy insertion without a hole so loose that the rivet can\'t properly clamp the joint.' },
];
const howTo = {
  name: 'How to size a rivet',
  steps: [
    { name: 'Find the thinnest sheet', text: 'Sets the suggested rivet diameter.' },
    { name: 'Total the stack', text: 'All sheets together give the required grip.' },
    { name: 'Match a rivet spec', text: 'Confirm the rated grip range and hole size.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Thinnest sheet thickness (in)</span>
        <input id="thin" type="number" step="any" placeholder="0.06" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Total stack thickness / grip (in)</span>
        <input id="grip" type="number" step="any" placeholder="0.19" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Suggested rivet diameter</div>
        <div id="r-dia" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Grip length needed</div><div id="r-grip" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Recommended hole size</div><div id="r-hole" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rv-title rv-desc">
      <title id="rv-title">Rivet joining a stack of sheets</title>
      <desc id="rv-desc">A rivet spanning the total grip length of stacked sheet material</desc>
      <rect x="100" y="70" width="140" height="16" fill="#cbd5e1" stroke="#64748b" stroke-width="1" />
      <rect x="100" y="86" width="140" height="16" fill="#94a3b8" stroke="#64748b" stroke-width="1" />
      <rect x="100" y="102" width="140" height="16" fill="#cbd5e1" stroke="#64748b" stroke-width="1" />
      <circle cx="170" cy="70" r="12" fill="#f97316" stroke="#c2410c" stroke-width="1.5" />
      <rect x="165" y="70" width="10" height="60" fill="#fb923c" stroke="#c2410c" stroke-width="1" />
      <circle cx="170" cy="130" r="9" fill="#f97316" stroke="#c2410c" stroke-width="1.5" />
      <text x="260" y="90" font-size="11" fill="#475569" font-family="system-ui,sans-serif">grip = total stack thickness</text>
      <rect x="420" y="55" width="330" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Rivet sizing</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">diameter &approx; 3 &times; thinnest sheet</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">grip length &ge; total stack thickness</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The rivet must clamp the full stack — its grip length has to match, not just its diameter.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the rivet size calculator works</h2>
    <p class="mt-2 text-slate-600">
      Sizing a rivet involves two independent decisions: diameter and grip length. Diameter is commonly set by a rule of thumb relative to the thinnest sheet in the joint — roughly three times that sheet's thickness — since a rivet too large for a thin sheet can tear through it, while one too small won't provide adequate shear strength across the joint. This is a starting-point guideline; the final diameter should also respect the rivet manufacturer's rated shear and tensile strength for your actual application load.
    </p>
    <p class="mt-3 text-slate-600">
      Grip length is entirely separate from diameter — it's simply the total thickness of every sheet stacked together that the rivet has to span and clamp. Rivets are manufactured in a range of lengths, each rated for a specific grip range; picking a rivet within that rated range for your actual stack thickness ensures a blind (pop) rivet's mandrel breaks off correctly and the joint clamps with proper tension, or that a solid rivet's tail forms correctly on the far side.
    </p>
    <p class="mt-3 text-slate-600">
      The hole the rivet passes through also matters: it's typically drilled slightly oversized relative to the rivet's nominal diameter, often by about 1/32 inch, following the specific rivet manufacturer's recommended hole size — a hole too tight makes insertion difficult and can deform the rivet, while one too loose prevents proper clamping.
    </p>
    <p class="mt-3 text-xs text-slate-400">The diameter-to-sheet-thickness ratio and grip-length practice are referenced in industrial fastener guides such as MIL-STD and the Society of Automotive Engineers (SAE) rivet standards.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Find the thinnest sheet</h3>
        <p class="mt-1 text-sm text-slate-600">Sets the suggested rivet diameter.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Total the stack</h3>
        <p class="mt-1 text-sm text-slate-600">All sheets together give the required grip.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Match a rivet spec</h3>
        <p class="mt-1 text-sm text-slate-600">Confirm the rated grip range and hole size.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Suggested diameter</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">&approx; 3 &times; thinnest sheet</span>. At 0.06 in: 3 × 0.06 = <strong>0.18 in ≈ 3/16 in rivet</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Grip length</p>
        <p class="mt-1 text-slate-600">
          Equal to the total stack thickness entered, e.g. <strong>0.19 in</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Hole size</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">&approx; diameter + 1&frasl;32 in</span> = 0.18 + 0.031 = <strong>0.21 in</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Joining three 0.04 in sheets, 0.12 in total stack.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Thinnest sheet:</span> <span class="text-slate-600">0.04 in</span></div>
        <div><span class="font-medium text-slate-700">Suggested diameter:</span> <span class="text-slate-600">3 × 0.04 = <strong>0.12 in</strong></span></div>
        <div><span class="font-medium text-slate-700">Grip needed:</span> <span class="text-slate-600">0.12 in</span></div>
        <div><span class="font-medium text-slate-700">Hole size:</span> <span class="text-slate-600">0.12 + 0.031 ≈ <strong>0.15 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Thin aircraft-grade aluminum skin, at 0.032 in, is a classic example of the 3x rule in action: suggested diameter comes out to 0.096 in — close enough to a standard 3/32 in rivet, one of the most common sizes in sheet-metal aircraft construction — with a hole size around 0.127 in. This is why aviation sheet metal work leans so heavily on that specific diameter family rather than jumping to a larger, heavier rivet that would risk tearing the thin skin.
    </p>
    <p class="mt-3 text-slate-600">
      HVAC ductwork, often 24-gauge sheet steel at about 0.025 in thick, suggests an even smaller 0.075 in diameter with a 0.106 in hole — but in practice, ductwork fabricators commonly size up to a standard 1/8 in (0.125 in) pop rivet anyway, since the rule of thumb is a floor, not a hard ceiling, and slightly oversized rivets are common where vibration resistance matters more than minimizing weight.
    </p>
    <p class="mt-3 text-slate-600">
      A heavier 0.125 in steel angle bracket, the kind used in structural shelving or equipment mounts, suggests a 0.375 in (3/8 in) diameter rivet with a 0.406 in hole — at that size, many fabricators switch from pop rivets to structural blind rivets or bolted connections instead, since standard pop rivets are typically rated for lighter sheet-metal work rather than heavy structural loads.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A bigger rivet is always a stronger, safer choice." <strong class="text-slate-900">Oversized rivets can tear through thin material.</strong> A rivet significantly larger than roughly three times the thinnest sheet's thickness concentrates enough force at the hole edge to deform or tear the sheet before the rivet itself fails — matching diameter to the thinnest sheet, not just maximizing size, is the safer approach.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Grip length and rivet diameter are set by the same rule." <strong class="text-slate-900">They're two independent decisions.</strong> Diameter is driven by the thinnest sheet in the stack to prevent tear-out, while grip length is driven by the total stack thickness to ensure the rivet clamps and forms correctly — a wide-diameter rivet on a thin stack still needs the correct grip length for that stack, not a longer one just because the diameter is bigger.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any hole size close to the rivet diameter works fine." <strong class="text-slate-900">Hole size directly affects clamping and shear strength.</strong> Too tight and the rivet can gall or deform on insertion, weakening it before it's even set; too loose and the rivet can't seat fully against the hole wall, reducing shear strength and letting the joint shift under load — the roughly 1/32 in oversize convention balances easy insertion against a snug fit.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/thread-pitch-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Thread Pitch Calculator</a>
      <a href="/tools/countersink-depth-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Countersink Depth Calculator</a>
      <a href="/tools/steel-plate-weight-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Steel Plate Weight Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const thin = parseFloat(el('thin').value);
      const grip = parseFloat(el('grip').value);
      if (!(thin > 0 && grip > 0)) { el('results').classList.add('hidden'); return; }
      const dia = thin * 3;
      const hole = dia + (1 / 32);

      el('r-dia').textContent = dia.toFixed(3) + ' in';
      el('r-note').textContent = 'based on a ' + thin + ' in thinnest sheet';
      el('r-grip').textContent = grip.toFixed(3) + ' in';
      el('r-hole').textContent = hole.toFixed(3) + ' in';
      el('results').classList.remove('hidden');
    }

    ['thin', 'grip'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
