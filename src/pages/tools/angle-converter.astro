---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Degrees", sym: "°", toBase: 1 }, { name: "Radians", sym: "rad", toBase: 57.29577951308232 }, { name: "Gradians", sym: "grad", toBase: 0.9 }, { name: "Arcminutes", sym: "′", toBase: 0.0166666667 }, { name: "Arcseconds", sym: "″", toBase: 0.0002777778 }, { name: "Turns", sym: "turn", toBase: 360 }];
---
<MultiUnitConverter
  title="Angle Converter"
  emoji="📐"
  quantity="angle"
  baseName="degree"
  units={units}
  defaultFrom={0} defaultTo={1}
  intro="Convert between angle units — degrees, radians, gradians, arcminutes, arcseconds and more."
  blurb="Angles measure rotation and direction, used in geometry, engineering and navigation."
  related={[{"slug":"length-converter","label":"Length Converter Converter"}]}
/>
