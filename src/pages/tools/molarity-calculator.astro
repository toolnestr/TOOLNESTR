---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Molarity Calculator';
const description = 'Free molarity calculator with a live 3D beaker and charts. Solve M = mol/L for molarity, moles, or volume, and handle dilutions with M₁V₁ = M₂V₂.';
const intro = 'Enter any two of molarity, moles, or volume to solve for the third — or switch to dilution mode. A live 3D beaker and charts show what the numbers mean.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is molarity?', a: 'Molarity (M) is the number of moles of solute per litre of solution: M = mol / L. It is the most common way chemists express the concentration of a solution.' },
  { q: 'How do I calculate molarity from mass?', a: 'First convert the mass of solute to moles using its molar mass (moles = mass ÷ molar mass), then divide by the solution volume in litres. For example, 58.44 g of NaCl is 1 mole; dissolved to make 1 L gives a 1 M solution.' },
  { q: 'What is the dilution formula?', a: 'M₁V₁ = M₂V₂, where M₁ and V₁ are the initial concentration and volume and M₂ and V₂ are the final ones. It works because diluting a solution adds solvent but does not change the number of moles of solute.' },
  { q: 'What units should I use?', a: 'Molarity in mol/L (M), moles in mol, and volume in litres. If your volume is in millilitres, divide by 1000 first — forgetting this is the single most common molarity mistake.' },
  { q: 'What is the difference between molarity and molality?', a: 'Molarity is moles of solute per litre of solution and changes slightly with temperature (because volume changes). Molality is moles of solute per kilogram of solvent and is temperature-independent, so it is preferred for precise or high-temperature work.' },
  { q: 'Does adding water change the number of moles of solute?', a: 'No. Dilution changes the concentration and the volume, but the amount of solute (moles) stays exactly the same. That constant-moles fact is what the dilution equation M₁V₁ = M₂V₂ is built on.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to use the Molarity Calculator',
    description: 'Calculate molarity, moles, or solution volume with M = mol/L, or dilute a solution with M₁V₁ = M₂V₂.',
    step: [
      { '@type': 'HowToStep', name: 'Pick a mode', text: 'Choose Molarity (M = mol/L) or Dilution (M₁V₁ = M₂V₂).' },
      { '@type': 'HowToStep', name: 'Enter what you know', text: 'In molarity mode enter any two of molarity, moles and volume; in dilution mode enter any three of M₁, V₁, M₂, V₂.' },
      { '@type': 'HowToStep', name: 'Read the missing value', text: 'The calculator solves for the remaining quantity instantly.' },
      { '@type': 'HowToStep', name: 'See it in the beaker', text: 'Use the moles and volume sliders to watch concentration and particle density change in the live 3D beaker.' },
    ],
  })} />

  <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">
    <span class="h-2 w-2 rounded-full bg-green-500"></span> Chemistry
  </span>

  <!-- Print-friendly worked examples (spec Section 10): hide interactive widgets when printing -->
  <style is:global>
    @media print {
      .no-print { display: none !important; }
      a[href]::after { content: none !important; }
      section { break-inside: avoid; }
    }
  </style>

  <!-- ============ CALCULATOR ============ -->
  <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-mol" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Molarity (M = mol/L)</button>
      <button id="mode-dil" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Dilution (M₁V₁ = M₂V₂)</button>
    </div>
    <div id="mol-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Molarity (M)</span>
        <input id="m" type="number" step="any" placeholder="mol/L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Moles (n)</span>
        <input id="n" type="number" step="any" placeholder="mol" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume (V)</span>
        <input id="v" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="dil-fields" class="hidden gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">M₁ (initial)</span>
        <input id="m1" type="number" step="any" placeholder="mol/L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">V₁ (initial)</span>
        <input id="v1" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">M₂ (final)</span>
        <input id="m2" type="number" step="any" placeholder="mol/L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">V₂ (final)</span>
        <input id="v2" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-3 flex flex-wrap gap-2">
      <button id="btn-example" type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 hover:bg-slate-50">Load example</button>
      <button id="btn-clear" type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 hover:bg-slate-50">Clear</button>
    </div>
    <div id="mol-result" class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Molarity</div><div id="r-m1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Moles</div><div id="r-v1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Volume</div><div id="r-v2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="mol-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ INTERACTIVE 3D BEAKER ============ -->
  <section class="mt-8 no-print">
    <h2 class="text-lg font-bold text-slate-900">Live 3D beaker</h2>
    <p class="mt-1 text-sm text-slate-500">Change the moles of solute and the volume of solution — the concentration and the density of dissolved particles update live. Drag to orbit (touch works too).</p>
    <div class="mt-3 grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Solute <span id="out-bmol" class="font-mono text-green-600">1.00 mol</span></span>
        <input id="b-mol" type="range" min="0" max="5" step="0.05" value="1" class="mt-2 w-full accent-green-600" />
      </label>
      <label class="block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Volume <span id="out-bvol" class="font-mono text-green-600">1.00 L</span></span>
        <input id="b-vol" type="range" min="0.1" max="5" step="0.05" value="1" class="mt-2 w-full accent-green-600" />
      </label>
    </div>
    <div class="mt-2 rounded-xl bg-green-50 p-3 text-center text-sm text-green-700">Concentration = <span id="out-bM" class="font-mono font-bold">1.00 M</span> &nbsp;(<span id="out-bMdesc">moderately concentrated</span>)</div>
    <div id="beaker3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
    <p id="beaker3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
  </section>

  <!-- ============ LIVE CHARTS ============ -->
  <section class="mt-10 no-print">
    <h2 class="text-lg font-bold text-slate-900">Concentration graphs</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Concentration as you add solvent (fixed moles)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dilute"></canvas></div>
      </figure>
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Moles needed vs volume (at current M)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-moles"></canvas></div>
      </figure>
      <figure class="sm:col-span-2">
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">How your solution compares to everyday ones (approx. molarity, log scale)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:260px;"><canvas id="chart-compare"></canvas></div>
      </figure>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How molarity is calculated</h2>
    <p class="mt-2 text-slate-600"><strong>The core definition in one line:</strong> molarity is the number of moles of solute divided by the volume of solution in litres — <span class="font-mono">M = n / V</span>. A 1 M solution holds one mole of dissolved substance in every litre.</p>
    <p class="mt-3 text-slate-600">The formula rearranges three ways, so knowing any two quantities gives the third:</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">M = n / V</p><p class="mt-1 text-xs text-slate-500">concentration from moles &amp; volume</p></div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">n = M × V</p><p class="mt-1 text-xs text-slate-500">moles needed for a target M</p></div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">V = n / M</p><p class="mt-1 text-xs text-slate-500">volume to reach a target M</p></div>
    </div>

    <p class="mt-5 text-slate-600">Most of the time you start from a <strong>mass</strong> on a balance, not moles. The full chain is: mass → moles (divide by molar mass) → molarity (divide by litres). Written out:</p>
    <p class="mt-2 rounded-lg bg-slate-50 p-3 text-center font-mono text-sm text-slate-800">M = (mass ÷ molar mass) ÷ volume(L)</p>

    <p class="mt-5 text-slate-600"><strong>Where the dilution equation comes from:</strong> when you add solvent, the moles of solute do not change — only the volume does. Since n = M × V, and n before equals n after, you get the compact rule</p>
    <p class="mt-2 rounded-lg bg-slate-50 p-3 text-center font-mono text-sm text-slate-800">M₁V₁ = M₂V₂</p>
    <p class="mt-2 text-slate-600">That single fact — moles are conserved on dilution — is the reason a small amount of concentrated stock can be diluted to a large, precise working solution.</p>

    <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 1 — molarity from mass</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> you dissolve 20 g of sodium hydroxide (NaOH, molar mass 40.00 g/mol) and make it up to 500 mL of solution. What is the molarity?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Moles:</span> <span class="text-slate-600">20 ÷ 40.00 = 0.50 mol</span></div>
        <div><span class="font-medium text-slate-700">Volume in litres:</span> <span class="text-slate-600">500 mL ÷ 1000 = 0.50 L</span></div>
        <div class="sm:col-span-2"><span class="font-medium text-slate-700">Molarity:</span> <span class="text-slate-600">M = 0.50 ÷ 0.50 = 1.00 M</span></div>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 2 — dilution</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> you have a 12 M stock of hydrochloric acid. How do you make 250 mL of 1 M HCl?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Rearrange:</span> <span class="text-slate-600">V₁ = M₂V₂ ÷ M₁</span></div>
        <div><span class="font-medium text-slate-700">Stock volume:</span> <span class="text-slate-600">V₁ = (1 × 0.250) ÷ 12 = 0.0208 L ≈ 20.8 mL</span></div>
        <div class="sm:col-span-2 text-slate-600">Measure 20.8 mL of the 12 M stock, then add water up to 250 mL total. (Safety: always add acid to water, never the reverse.)</div>
      </div>
    </div>
  </section>

  <!-- ============ STANDALONE 3D DIAGRAMS ============ -->
  <section class="mt-12 no-print">
    <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <div>
        <div id="diag-dilute" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">1. Dilution keeps the particles, adds the water</h3>
        <p class="mt-1 text-sm text-slate-600">Both beakers hold the <strong>same number</strong> of solute particles. The right one just has more solvent, so the particles are spread thinner — lower molarity, identical moles.</p>
      </div>
      <div>
        <div id="diag-cube" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">2. Molarity is particles per litre</h3>
        <p class="mt-1 text-sm text-slate-600">Each cube is one litre. A 2 M solution simply packs twice as many moles of solute into the same litre as a 1 M solution — concentration is a density of "stuff dissolved."</p>
      </div>
    </div>
  </section>

  <!-- ============ COMPARISON TABLE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Molarity of some everyday solutions</h2>
    <p class="mt-1 text-sm text-slate-600">Approximate values — useful for a sense of scale of what "how concentrated" actually means.</p>
    <div class="mt-3 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full table-fixed text-center text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-2 py-2.5 text-left font-semibold sm:px-3">Solution</th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Approx. molarity</th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Note</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700">
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Blood glucose</td><td class="px-2 py-2.5 sm:px-3 tabular-nums">~0.005 M</td><td class="px-2 py-2.5 sm:px-3">very dilute</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Seawater (NaCl)</td><td class="px-2 py-2.5 sm:px-3 tabular-nums">~0.6 M</td><td class="px-2 py-2.5 sm:px-3">salty</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Household vinegar</td><td class="px-2 py-2.5 sm:px-3 tabular-nums">~0.9 M</td><td class="px-2 py-2.5 sm:px-3">acetic acid</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Stomach acid</td><td class="px-2 py-2.5 sm:px-3 tabular-nums">~0.1 M</td><td class="px-2 py-2.5 sm:px-3">HCl</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Concentrated HCl (stock)</td><td class="px-2 py-2.5 sm:px-3 tabular-nums">~12 M</td><td class="px-2 py-2.5 sm:px-3">lab reagent</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">Pure water (as itself)</td><td class="px-2 py-2.5 sm:px-3 tabular-nums">~55.5 M</td><td class="px-2 py-2.5 sm:px-3">for reference</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ============ REAL-WORLD CONTEXT ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Where molarity actually matters</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🧪 The lab bench</h3>
        <p class="mt-1 text-sm text-slate-600">Almost every wet-lab procedure starts with "prepare X mL of a Y molar solution." Molarity is how chemists communicate concentration unambiguously, and the dilution equation is used dozens of times a day to turn concentrated stocks into precise working solutions.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">💊 Medicine and pharmacy</h3>
        <p class="mt-1 text-sm text-slate-600">IV fluids, drug formulations and buffers are all defined by concentration. Getting a dilution wrong is not an academic error here — it changes a dose — which is why the M₁V₁ = M₂V₂ calculation is double-checked at every step.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🌊 Environmental testing</h3>
        <p class="mt-1 text-sm text-slate-600">Measuring pollutants in water means preparing calibration standards at known molarities by serial dilution. The accuracy of the final reading is only as good as the concentration maths behind the standards.</p>
      </div>
    </div>
  </section>

  <!-- ============ MISCONCEPTIONS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Molarity is per litre of solvent (water)."</p>
        <p class="mt-1 text-sm text-slate-600">It is per litre of <em>solution</em> — solute plus solvent together, measured after mixing. You dissolve the solute and then make the total volume up to the mark, rather than adding solute to a litre of water.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Diluting a solution removes some of the solute."</p>
        <p class="mt-1 text-sm text-slate-600">Dilution only adds solvent. The moles of solute are unchanged — they are just spread through a larger volume, so the concentration drops. That conservation of moles is the whole basis of M₁V₁ = M₂V₂.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Molarity and molality are the same thing."</p>
        <p class="mt-1 text-sm text-slate-600">Molarity is moles per litre of solution and shifts with temperature as the volume changes. Molality is moles per kilogram of solvent and does not, which is why molality is used for boiling-point and freezing-point work.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Just use millilitres — the number is bigger."</p>
        <p class="mt-1 text-sm text-slate-600">The formula requires litres. Using millilitres without converting inflates your molarity by a factor of 1000. Always divide millilitres by 1000 first.</p>
      </div>
    </div>
  </section>

  <!-- ============ FORMULA SOURCES & CREDIBILITY (spec Sections 9 & 10) ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Formula sources &amp; further reading</h2>
    <p class="mt-2 text-slate-600">The molarity and dilution relationships are standard general-chemistry definitions, traceable to these widely used references:</p>
    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      <li>• <strong>OpenStax, <em>Chemistry 2e</em></strong> — §3.4 "Molarity" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/3-4-other-units-for-solution-concentrations" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a></li>
      <li>• <strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 4, Reactions in Aqueous Solution (Concentrations of Solutions).</li>
      <li>• <strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Chapter 4, Types of Chemical Reactions and Solution Stoichiometry.</li>
      <li>• <strong>IUPAC</strong> — recommended symbol for amount concentration is <em>c</em> (mol/L); "molarity" and the unit symbol M remain in common practical use.</li>
    </ul>
    <p class="mt-3 text-xs text-slate-400">Results are rounded to four significant figures; very small or very large values switch to scientific notation.</p>
  </section>

  <!-- ============ RELATED TOOLS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/dilution-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">💧</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Dilution Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">M₁V₁ = M₂V₂ — solve for any variable.</p>
      </a>
      <a href="/tools/atomic-mass-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">⚗️</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molar Mass Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Sum atomic masses from a chemical formula.</p>
      </a>
      <a href="/tools/ph-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🧫</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">pH Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">pH from hydrogen-ion concentration.</p>
      </a>
    </div>
  </section>

  <!-- Libraries: Three.js (3D) + Chart.js (graphs), per project spec Section 4 -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>

  <script is:inline>
  (function () {
    'use strict';
    const el = (id) => document.getElementById(id);
    const reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- number formatting (spec Section 16) ----
    function fmt(v) {
      if (!isFinite(v)) return '—';
      if (v !== 0 && (Math.abs(v) < 1e-3 || Math.abs(v) >= 1e5)) return v.toExponential(2);
      if (Math.abs(v) < 1e-12) v = 0;
      return parseFloat(v.toPrecision(4)).toLocaleString(undefined, { maximumFractionDigits: 4 });
    }

    // ================= CALCULATOR (works with zero dependencies) — preserves original logic =================
    let mode = 'mol';
    function switchMode(m) {
      mode = m;
      el('mode-mol').className = m === 'mol' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
      el('mode-dil').className = m === 'dil' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
      el('mol-fields').className = m === 'mol' ? 'grid gap-4 sm:grid-cols-3' : 'hidden';
      el('dil-fields').className = m === 'dil' ? 'grid gap-4 sm:grid-cols-4' : 'hidden gap-4 sm:grid-cols-4';
      el('lab-1').textContent = m === 'mol' ? 'Molarity' : 'M₁';
      el('lab-2').textContent = m === 'mol' ? 'Moles' : 'V₁';
      el('lab-3').textContent = m === 'mol' ? 'Volume' : 'M₂ / V₂';
      ['r-m1', 'r-v1', 'r-v2'].forEach((id) => (el(id).textContent = '—'));
      el('mol-err').textContent = '';
    }
    function update() {
      el('mol-err').textContent = '';
      if (mode === 'mol') {
        const M = parseFloat(el('m').value);
        const n = parseFloat(el('n').value);
        const V = parseFloat(el('v').value);
        const filled = [!isNaN(M), !isNaN(n), !isNaN(V)];
        const count = filled.filter(Boolean).length;
        ['r-m1', 'r-v1', 'r-v2'].forEach((id) => (el(id).textContent = '—'));
        if (count < 2) return;
        let rM = NaN, rn = NaN, rV = NaN;
        if (filled[0] && filled[1]) { if (M === 0) { el('mol-err').textContent = 'Molarity cannot be zero when solving for volume.'; return; } rV = n / M; rM = M; rn = n; }
        else if (filled[0] && filled[2]) { rn = M * V; rM = M; rV = V; }
        else if (filled[1] && filled[2]) { if (V === 0) { el('mol-err').textContent = 'Volume cannot be zero.'; return; } rM = n / V; rn = n; rV = V; }
        if (!isNaN(rM)) el('r-m1').textContent = fmt(rM) + ' M';
        if (!isNaN(rn)) el('r-v1').textContent = fmt(rn) + ' mol';
        if (!isNaN(rV)) el('r-v2').textContent = fmt(rV) + ' L';
      } else {
        const m1 = parseFloat(el('m1').value);
        const v1 = parseFloat(el('v1').value);
        const m2 = parseFloat(el('m2').value);
        const v2 = parseFloat(el('v2').value);
        const filled = [!isNaN(m1), !isNaN(v1), !isNaN(m2), !isNaN(v2)];
        const count = filled.filter(Boolean).length;
        ['r-m1', 'r-v1', 'r-v2'].forEach((id) => (el(id).textContent = '—'));
        if (count < 3) return;
        let rm1 = NaN, rv1 = NaN, rm2 = NaN, rv2 = NaN;
        if (!filled[0]) { if (v1 === 0) { el('mol-err').textContent = 'V₁ cannot be zero.'; return; } rm1 = (m2 * v2) / v1; rv1 = v1; rm2 = m2; rv2 = v2; }
        else if (!filled[1]) { if (m1 === 0) { el('mol-err').textContent = 'M₁ cannot be zero.'; return; } rv1 = (m2 * v2) / m1; rm1 = m1; rm2 = m2; rv2 = v2; }
        else if (!filled[2]) { if (v2 === 0) { el('mol-err').textContent = 'V₂ cannot be zero.'; return; } rm2 = (m1 * v1) / v2; rm1 = m1; rv1 = v1; rv2 = v2; }
        else if (!filled[3]) { if (m2 === 0) { el('mol-err').textContent = 'M₂ cannot be zero.'; return; } rv2 = (m1 * v1) / m2; rm1 = m1; rv1 = v1; rm2 = m2; }
        el('r-m1').textContent = isNaN(rm1) ? '—' : fmt(rm1) + ' M';
        el('r-v1').textContent = isNaN(rv1) ? '—' : fmt(rv1) + ' L';
        el('r-v2').textContent = (isNaN(rm2) ? '—' : fmt(rm2) + ' M') + ' / ' + (isNaN(rv2) ? '—' : fmt(rv2) + ' L');
      }
    }
    el('mode-mol').addEventListener('click', () => { switchMode('mol'); update(); });
    el('mode-dil').addEventListener('click', () => { switchMode('dil'); update(); });
    ['m', 'n', 'v', 'm1', 'v1', 'm2', 'v2'].forEach((id) => el(id).addEventListener('input', update));
    el('btn-example').addEventListener('click', () => {
      if (mode === 'mol') { el('n').value = 0.5; el('v').value = 0.5; el('m').value = ''; }
      else { el('m1').value = 12; el('v1').value = ''; el('m2').value = 1; el('v2').value = 0.25; }
      update();
    });
    el('btn-clear').addEventListener('click', () => {
      ['m', 'n', 'v', 'm1', 'v1', 'm2', 'v2'].forEach((id) => (el(id).value = ''));
      update();
    });

    // ================= BEAKER SLIDERS → shared state for 3D + charts =================
    const charts = {};
    let beaker = null;
    function beakerState() {
      const nMol = parseFloat(el('b-mol').value);
      const vol = parseFloat(el('b-vol').value);
      const M = vol > 0 ? nMol / vol : 0;
      return { nMol, vol, M };
    }
    function describeM(M) {
      if (M <= 0) return 'no solute';
      if (M < 0.1) return 'very dilute';
      if (M < 0.5) return 'dilute';
      if (M < 1.5) return 'moderately concentrated';
      if (M < 4) return 'concentrated';
      return 'highly concentrated';
    }
    function onBeakerChange() {
      const s = beakerState();
      el('out-bmol').textContent = s.nMol.toFixed(2) + ' mol';
      el('out-bvol').textContent = s.vol.toFixed(2) + ' L';
      el('out-bM').textContent = fmt(s.M) + ' M';
      el('out-bMdesc').textContent = describeM(s.M);
      try { if (beaker) beaker.update(s); } catch (e) {}
      try { if (charts.ready) updateCharts(s); } catch (e) {}
    }
    el('b-mol').addEventListener('input', onBeakerChange);
    el('b-vol').addEventListener('input', onBeakerChange);

    // ================= CHARTS (Chart.js) =================
    function initCharts() {
      if (!window.Chart) return;
      Chart.defaults.font.family = "'Inter', system-ui, sans-serif";
      Chart.defaults.color = '#64748b';
      const base = { responsive: true, maintainAspectRatio: false, animation: false };

      charts.dilute = new Chart(el('chart-dilute'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'M', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Volume (L)' } }, y: { title: { display: true, text: 'Molarity (M)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.moles = new Chart(el('chart-moles'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'moles', data: [], borderColor: '#6366f1', pointRadius: 0, tension: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Volume (L)' } }, y: { title: { display: true, text: 'Moles needed' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.compare = new Chart(el('chart-compare'), {
        type: 'bar',
        data: {
          labels: ['Blood glucose', 'Stomach acid', 'Seawater', 'Vinegar', 'Your solution', 'Conc. HCl', 'Pure water'],
          datasets: [{ label: 'Molarity (M)', data: [0.005, 0.1, 0.6, 0.9, 1, 12, 55.5], backgroundColor: ['#94a3b8', '#94a3b8', '#94a3b8', '#94a3b8', '#10b981', '#94a3b8', '#94a3b8'] }],
        },
        options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Molarity (M, log)' } } }, plugins: { legend: { display: false } } }),
      });
      charts.ready = true;
      updateCharts(beakerState());
    }
    function updateCharts(s) {
      if (!charts.ready) return;
      // dilution curve: fixed moles = s.nMol, sweep volume
      const L = [], D = [];
      for (let vv = 0.1; vv <= 5.001; vv += 0.1) { L.push(vv.toFixed(1)); D.push(+(s.nMol / vv).toFixed(4)); }
      charts.dilute.data.labels = L; charts.dilute.data.datasets[0].data = D; charts.dilute.update();
      // moles vs volume at current M
      const L2 = [], D2 = [];
      for (let vv = 0; vv <= 5.001; vv += 0.25) { L2.push(vv.toFixed(2)); D2.push(+(s.M * vv).toFixed(4)); }
      charts.moles.data.labels = L2; charts.moles.data.datasets[0].data = D2; charts.moles.update();
      // comparison: update "your solution" bar
      charts.compare.data.datasets[0].data[4] = +Math.max(s.M, 0.001).toFixed(4);
      charts.compare.update();
    }

    // ================= THREE.js SCENES =================
    function makeScene(container, camRadius, target) {
      const w = container.clientWidth, h = container.clientHeight || 240;
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(50, w / h, 0.1, 5000);
      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(w, h);
      container.appendChild(renderer.domElement);
      renderer.domElement.style.touchAction = 'none';
      scene.add(new THREE.AmbientLight(0xffffff, 0.9));
      const dir = new THREE.DirectionalLight(0xffffff, 0.5); dir.position.set(6, 12, 8); scene.add(dir);
      let azim = 0.7, pol = 1.2, radius = camRadius;
      const tgt = target || new THREE.Vector3(0, 0, 0);
      function place() {
        camera.position.set(tgt.x + radius * Math.sin(pol) * Math.sin(azim), tgt.y + radius * Math.cos(pol), tgt.z + radius * Math.sin(pol) * Math.cos(azim));
        camera.lookAt(tgt);
      }
      place();
      let dragging = false, px = 0, py = 0;
      function down(x, y) { dragging = true; px = x; py = y; }
      function move(x, y) { if (!dragging) return; azim -= (x - px) * 0.008; pol += (y - py) * 0.008; pol = Math.max(0.3, Math.min(Math.PI / 2 + 0.2, pol)); px = x; py = y; place(); }
      function up() { dragging = false; }
      const cvs = renderer.domElement;
      cvs.addEventListener('mousedown', (e) => down(e.clientX, e.clientY));
      window.addEventListener('mousemove', (e) => move(e.clientX, e.clientY));
      window.addEventListener('mouseup', up);
      cvs.addEventListener('touchstart', (e) => { const t = e.touches[0]; down(t.clientX, t.clientY); }, { passive: true });
      cvs.addEventListener('touchmove', (e) => { const t = e.touches[0]; move(t.clientX, t.clientY); }, { passive: true });
      cvs.addEventListener('touchend', up);
      function resize() { const w2 = container.clientWidth, h2 = container.clientHeight || 240; camera.aspect = w2 / h2; camera.updateProjectionMatrix(); renderer.setSize(w2, h2); }
      return { scene, camera, renderer, resize, place, spin: (d) => { if (!dragging) { azim += d; place(); } }, THREE };
    }

    function glassBeaker(THREE) {
      const g = new THREE.Group();
      const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1 });
      const wall = new THREE.Mesh(new THREE.CylinderGeometry(2.2, 2.2, 5, 40, 1, true), glassMat);
      wall.material.side = THREE.DoubleSide; g.add(wall);
      const bottom = new THREE.Mesh(new THREE.CircleGeometry(2.2, 40), glassMat);
      bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
      return g;
    }

    // ---- interactive beaker ----
    function initBeaker() {
      const c = el('beaker3d'); if (!c) throw new Error('no beaker');
      const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0));
      s.scene.add(glassBeaker(THREE));
      const liquidMat = new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.45, roughness: 0.3 });
      let liquid = null;
      const MAX_P = 120;
      const particleGeo = new THREE.SphereGeometry(0.11, 10, 10);
      const particleMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
      const particles = [];
      for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(particleGeo, particleMat); p.visible = false; s.scene.add(p); particles.push(p); }
      function update(state) {
        const maxVol = 5;
        const frac = Math.max(0.02, Math.min(1, state.vol / maxVol));
        const hLiq = frac * 4.6;
        if (liquid) { s.scene.remove(liquid); liquid.geometry.dispose(); }
        liquid = new THREE.Mesh(new THREE.CylinderGeometry(2.08, 2.08, hLiq, 40), liquidMat);
        liquid.position.y = -2.4 + hLiq / 2; s.scene.add(liquid);
        // particle count scales with concentration (visual, capped)
        const nShow = Math.max(0, Math.min(MAX_P, Math.round(state.M * 22)));
        for (let i = 0; i < MAX_P; i++) {
          const p = particles[i];
          if (i < nShow) {
            const r = Math.sqrt(Math.random()) * 1.9, a = Math.random() * Math.PI * 2;
            p.position.set(Math.cos(a) * r, -2.4 + Math.random() * hLiq, Math.sin(a) * r);
            p.visible = true;
          } else p.visible = false;
        }
      }
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
      frame();
      beaker = { update, resize: s.resize };
      update(beakerState());
    }

    // ---- diagram: dilution (two beakers, same particles) ----
    function initDiagDilute() {
      const c = el('diag-dilute'); if (!c) throw new Error('no diag');
      const s = makeScene(c, 15, new THREE.Vector3(0, 0, 0));
      const pGeo = new THREE.SphereGeometry(0.12, 10, 10);
      const pMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
      function beakerAt(x, liquidH, radius, particleSpread) {
        const grp = new THREE.Group(); grp.position.x = x;
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        grp.add(new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, 5, 32, 1, true), glassMat));
        const liq = new THREE.Mesh(new THREE.CylinderGeometry(radius * 0.95, radius * 0.95, liquidH, 32), new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.4 }));
        liq.position.y = -2.4 + liquidH / 2; grp.add(liq);
        for (let i = 0; i < 12; i++) { const p = new THREE.Mesh(pGeo, pMat); const r = Math.sqrt(Math.random()) * radius * 0.8, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -2.4 + Math.random() * liquidH, Math.sin(a) * r); grp.add(p); }
        return grp;
      }
      s.scene.add(beakerAt(-3.2, 2.2, 1.6, 1));   // concentrated: less liquid, same 12 particles
      s.scene.add(beakerAt(3.2, 4.4, 2.0, 1));     // diluted: more liquid, same 12 particles
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagD = { resize: s.resize };
    }

    // ---- diagram: molarity as particles per litre cube ----
    function initDiagCube() {
      const c = el('diag-cube'); if (!c) throw new Error('no diag');
      const s = makeScene(c, 15, new THREE.Vector3(0, 0, 0));
      const edge = new THREE.LineBasicMaterial({ color: 0x6366f1 });
      function cube(x, n) {
        const grp = new THREE.Group(); grp.position.x = x;
        grp.add(new THREE.LineSegments(new THREE.EdgesGeometry(new THREE.BoxGeometry(2.4, 2.4, 2.4)), edge));
        const pMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
        for (let i = 0; i < n; i++) { const p = new THREE.Mesh(new THREE.SphereGeometry(0.12, 10, 10), pMat); p.position.set((Math.random() - 0.5) * 2.1, (Math.random() - 0.5) * 2.1, (Math.random() - 0.5) * 2.1); grp.add(p); }
        return grp;
      }
      s.scene.add(cube(-2.4, 12));  // 1 M
      s.scene.add(cube(2.4, 24));   // 2 M
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagC = { resize: s.resize };
    }

    let diagD = null, diagC = null;

    // ================= BOOT (defensive: each widget isolated) =================
    function boot() {
      try { switchMode('mol'); update(); } catch (e) { console.error('[molarity] calculator init failed', e); }
      try { onBeakerChange(); } catch (e) { console.error('[molarity] beaker state init failed', e); }
      try { initCharts(); } catch (e) { console.error('[molarity] charts init failed', e); }
      if (window.THREE) {
        try { initBeaker(); } catch (e) { console.error('[molarity] beaker 3D failed', e); el('beaker3d-fallback').classList.remove('hidden'); }
        try { initDiagDilute(); } catch (e) { console.error('[molarity] dilution diagram failed', e); }
        try { initDiagCube(); } catch (e) { console.error('[molarity] cube diagram failed', e); }
      } else {
        el('beaker3d-fallback').classList.remove('hidden');
      }
      function onResize() { [beaker, diagD, diagC].forEach((x) => { try { x && x.resize(); } catch (e) {} }); }
      window.addEventListener('resize', onResize);
      window.addEventListener('orientationchange', () => setTimeout(onResize, 300));
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
  </script>
</ToolLayout>
