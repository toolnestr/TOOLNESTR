---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Hardy-Weinberg Equilibrium Checker';
const description = 'Hardy-Weinberg equilibrium checker with a live 3D population diagram and charts. Run a chi-square goodness-of-fit test comparing observed genotype counts to Hardy-Weinberg-expected counts, with worked examples.';
const intro = 'Test whether a population is in Hardy-Weinberg equilibrium by comparing its observed genotype counts to the counts predicted from allele frequencies, using a chi-square goodness-of-fit test. Two 3D diagrams compare a population matching equilibrium expectations to one clearly deviating from them, and charts show observed vs. expected counts side by side.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What does it mean for a population to be "in Hardy-Weinberg equilibrium"?', a: "It means the population's observed genotype counts closely match what's predicted from its allele frequencies under p²+2pq+q²=1 — a signal that the population isn't currently experiencing significant evolutionary forces like selection, non-random mating, or genetic drift for that gene." },
  { q: 'How is the chi-square test used here?', a: 'The test compares each genotype\'s observed count to its Hardy-Weinberg-expected count using χ² = Σ(O−E)²/E, then compares that total to a critical value (3.841 for 1 degree of freedom at the standard 0.05 significance level) — exceeding it means the population significantly deviates from equilibrium.' },
  { q: 'Why does this test use 1 degree of freedom?', a: 'There are 3 genotype categories, giving 2 degrees of freedom initially, but 1 is used up estimating the allele frequency from the data itself — leaving 1 degree of freedom for the final test.' },
  { q: 'What does it mean if a population fails the equilibrium test?', a: "A significant deviation suggests one of the Hardy-Weinberg assumptions is being violated — commonly non-random mating (like inbreeding, which increases homozygotes), natural selection, genetic drift in a small population, migration, or new mutation." },
  { q: 'How is this different from the Hardy-Weinberg Allele Frequency Calculator?', a: 'That calculator solves for expected equilibrium frequencies given an assumed allele frequency. This tool instead takes real observed genotype counts and statistically tests whether they actually match Hardy-Weinberg expectations — a genuine hypothesis test, not just a prediction.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Hardy-Weinberg Equilibrium Checker',
  description: 'Run a chi-square test comparing observed genotype counts to Hardy-Weinberg-expected counts.',
  steps: [
    { name: 'Enter observed genotype counts', text: 'The number of AA, Aa, and aa individuals actually observed in the population.' },
    { name: 'Review expected counts', text: 'Allele frequencies are calculated from your data, then used to predict equilibrium genotype counts.' },
    { name: 'Read the test result', text: 'The chi-square statistic and a pass/fail equilibrium conclusion are shown instantly.' },
  ],
};

const formulas = [
  { expr: 'p = (2×AA + Aa) / (2N)', note: 'dominant allele frequency estimated from observed genotype counts' },
  { expr: 'Expected: p²N, 2pqN, q²N', note: 'Hardy-Weinberg-predicted genotype counts, using the estimated p and q' },
  { expr: 'χ² = Σ(O − E)² / E', note: 'chi-square statistic — compare to 3.841 (1 df, α=0.05) to test equilibrium' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a population matching equilibrium', tone: 'slate',
    given: 'A population of 100 individuals: 64 AA, 32 Aa, 4 aa.',
    rows: [
      { label: 'Allele frequencies:', value: 'p = (2×64+32)/200 = 0.8, q = 0.2' },
      { label: 'Expected counts:', value: 'p²(100)=64, 2pq(100)=32, q²(100)=4 — identical to observed' },
      { label: 'Result:', value: 'χ² = 0 — a perfect match, the population is in Hardy-Weinberg equilibrium', full: true },
    ],
    note: 'This population was deliberately constructed to match equilibrium exactly, giving a chi-square of zero — real data almost never lands this cleanly, but small deviations are expected and don\'t necessarily fail the test.',
  },
  {
    title: 'Worked example 2 — a population showing inbreeding', tone: 'amber',
    given: 'A population of 100 individuals: 70 AA, 10 Aa, 20 aa (an excess of homozygotes, a classic sign of inbreeding).',
    rows: [
      { label: 'Allele frequencies:', value: 'p = (2×70+10)/200 = 0.75, q = 0.25' },
      { label: 'Expected counts:', value: 'p²(100)=56.25, 2pq(100)=37.5, q²(100)=6.25' },
      { label: 'Result:', value: 'χ² ≈ 53.78, far exceeding 3.841 — this population significantly deviates from equilibrium', full: true },
    ],
    note: 'The stark excess of homozygotes and deficit of heterozygotes compared to expectation is the textbook chi-square signature of inbreeding within a population.',
  },
];

const comparison = {
  heading: 'Interpreting the chi-square result (1 degree of freedom, α=0.05)',
  note: 'Compare your calculated chi-square value to the standard critical value.',
  headers: [{ label: 'Chi-square value' }, { label: 'Conclusion' }],
  rows: [
    ['0 (exact match) ★', 'Perfectly matches Hardy-Weinberg equilibrium'],
    ['< 3.841', 'No significant deviation — consistent with equilibrium'],
    ['≥ 3.841', 'Significant deviation — population is not in equilibrium'],
    ['53.78 (worked example 2)', 'Strongly rejects equilibrium — some evolutionary force is acting'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 1). The critical value of 3.841 comes from the standard chi-square distribution table at 1 degree of freedom and the conventional 0.05 significance threshold.',
};

const realWorld = [
  { emoji: '🧬', title: 'Detecting non-random mating', body: 'A population significantly failing the Hardy-Weinberg test with excess homozygotes is a classic signature geneticists use to detect inbreeding or other forms of non-random mating.' },
  { emoji: '🏥', title: 'Genetic disease screening and epidemiology', body: 'Comparing observed disease-allele genotype frequencies to Hardy-Weinberg expectations helps researchers spot data errors, selection effects, or population substructure in genetic association studies.' },
  { emoji: '🦁', title: 'Conservation genetics', body: "Testing small, at-risk wildlife populations for Hardy-Weinberg deviations helps conservation biologists detect the genetic drift and inbreeding effects that often accompany a shrinking population." },
  { emoji: '🌾', title: 'Plant and animal breeding programs', body: "Breeders check whether a captive or cultivated population still matches Hardy-Weinberg expectations to monitor for unintended selection pressures introduced by breeding practices." },
];

const misconceptions = [
  { claim: '"A population failing the Hardy-Weinberg test must have a genotyping error."', truth: "A real, significant deviation is just as likely to reflect real evolutionary or demographic processes — selection, non-random mating, migration, or genetic drift — as it is to reflect a data or measurement error; both possibilities should be considered." },
  { claim: '"Hardy-Weinberg equilibrium means a population isn\'t evolving at all."', truth: "Hardy-Weinberg equilibrium is specifically defined per-gene, per-generation — a population can be in equilibrium for one gene while actively evolving at many others, and can even be in equilibrium for a gene despite other evolutionary forces acting on unrelated traits." },
  { claim: '"A small chi-square value always confirms with certainty the population isn\'t evolving."', truth: "Failing to detect a significant deviation doesn't prove a population is truly in equilibrium — it may simply mean the sample size was too small to detect a small real deviation, or that only one generation was sampled when longer-term monitoring is needed." },
  { claim: '"This test can be used with any number of alleles or genotype categories."', truth: 'The standard 1-degree-of-freedom critical value applies specifically to a simple two-allele, three-genotype case — testing genes with more alleles or genotype categories requires recalculating the appropriate degrees of freedom and critical value.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 20, "Evolution" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/20-1-population-evolution" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Hartl &amp; Clark, <em>Principles of Population Genetics</em></strong> — Testing for Hardy-Weinberg equilibrium chapter.' },
  { html: '<strong>Pearson (1900)</strong> — foundational chi-square goodness-of-fit test paper, <em>Philosophical Magazine</em>.' },
];
const sourcesNote = 'χ²=Σ(O−E)²/E, compared to 3.841 (1 df, α=0.05). Assumes a simple two-allele gene. Results are rounded for display.';

const howToUse = [
  { title: 'Enter observed genotype counts', body: 'The number of AA, Aa, and aa individuals actually observed.' },
  { title: 'Review calculated expectations', body: 'Allele frequencies and Hardy-Weinberg-expected counts are computed automatically.' },
  { title: 'Read the equilibrium conclusion', body: 'Chi-square value and pass/fail result against the standard critical value.' },
];

const related = [
  { href: '/tools/hardy-weinberg-calculator', emoji: '⚖️', title: 'Hardy-Weinberg Allele Frequency Calculator', desc: 'p²+2pq+q²=1 — predicted equilibrium frequencies.' },
  { href: '/tools/genotype-frequency-calculator', emoji: '🧮', title: 'Genotype Frequency Calculator', desc: 'Observed genotype and allele frequencies from counts.' },
  { href: '/tools/chi-square-genetics-calculator', emoji: '📊', title: 'Chi-Square Goodness of Fit Calculator', desc: 'Test whether observed ratios match an expected genetic ratio.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="if a population's real genotype counts closely match what its own allele frequencies predict under random mating, that agreement is itself evidence that no major evolutionary force is currently disturbing that gene — and a chi-square test turns 'closely match' from a gut feeling into a precise, defensible number."
  howIntro="Hardy-Weinberg equilibrium makes a specific, testable prediction: given a population's allele frequencies, genotypes should appear in the ratio p²:2pq:q². Estimating p and q directly from the observed data, then using them to calculate exactly how many of each genotype equilibrium would predict, gives a clean expected value to compare against what was actually counted. The chi-square statistic quantifies exactly how far the real data strays from that prediction, and comparing it to a standard critical value turns that comparison into a formal yes-or-no test: does this population's genetic makeup look the way undisturbed random mating alone would produce, or does something else — selection, inbreeding, drift, migration — appear to be at work?"
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the equilibrium test actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter observed genotype counts</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">AA count</span>
        <input id="aa" type="number" step="1" min="0" value="70" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Aa count</span>
        <input id="het" type="number" step="1" min="0" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">aa count</span>
        <input id="rec" type="number" step="1" min="0" value="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 overflow-x-auto rounded-xl border border-slate-200">
      <table class="w-full text-center text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600"><tr><th class="px-3 py-2 text-left">Genotype</th><th class="px-3 py-2">Observed</th><th class="px-3 py-2">Expected</th></tr></thead>
        <tbody id="hw-body" class="divide-y divide-slate-100"></tbody>
      </table>
    </div>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Chi-square (χ²)</div><div id="r-chisq" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Conclusion (critical value 3.841)</div><div id="r-conclusion" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="hwe-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Matching vs. deviating from equilibrium</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-match" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Matches equilibrium</h3>
          <p class="mt-1 text-sm text-slate-600">Observed genotype mix closely resembles the Hardy-Weinberg-predicted proportions.</p>
        </div>
        <div>
          <div id="diag-deviate" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Deviates from equilibrium</h3>
          <p class="mt-1 text-sm text-slate-600">A noticeable excess of homozygotes — a classic inbreeding signature.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Equilibrium test charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Observed vs. expected genotype counts</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-counts"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Chi-square value vs. the 3.841 critical threshold</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-chisq"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const fmt = (v) => parseFloat(v.toPrecision(4)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 4 });
      let charts = {};

      function update() {
        el('hwe-err').textContent = '';
        el('r-chisq').textContent = '—'; el('r-conclusion').textContent = '—';
        el('hw-body').innerHTML = '';
        const aa = parseFloat(el('aa').value), het = parseFloat(el('het').value), rec = parseFloat(el('rec').value);
        if (isNaN(aa) || isNaN(het) || isNaN(rec)) return;
        if (aa < 0 || het < 0 || rec < 0) { el('hwe-err').textContent = 'Counts cannot be negative.'; return; }
        const n = aa + het + rec;
        if (n === 0) { el('hwe-err').textContent = 'Total population cannot be zero.'; return; }
        const p = (2 * aa + het) / (2 * n), q = (2 * rec + het) / (2 * n);
        const eAA = p * p * n, eHet = 2 * p * q * n, eRec = q * q * n;
        const chisq = (eAA > 0 ? Math.pow(aa - eAA, 2) / eAA : 0) + (eHet > 0 ? Math.pow(het - eHet, 2) / eHet : 0) + (eRec > 0 ? Math.pow(rec - eRec, 2) / eRec : 0);
        el('hw-body').innerHTML =
          '<tr><td class="px-3 py-2 text-left font-medium text-slate-700">AA</td><td class="px-3 py-2">' + aa + '</td><td class="px-3 py-2">' + fmt(eAA) + '</td></tr>' +
          '<tr><td class="px-3 py-2 text-left font-medium text-slate-700">Aa</td><td class="px-3 py-2">' + het + '</td><td class="px-3 py-2">' + fmt(eHet) + '</td></tr>' +
          '<tr><td class="px-3 py-2 text-left font-medium text-slate-700">aa</td><td class="px-3 py-2">' + rec + '</td><td class="px-3 py-2">' + fmt(eRec) + '</td></tr>';
        el('r-chisq').textContent = fmt(chisq);
        const inEq = chisq < 3.841;
        el('r-conclusion').textContent = inEq ? '✓ Consistent with equilibrium' : '✗ Deviates from equilibrium';
        el('r-conclusion').className = 'mt-1 text-lg font-bold ' + (inEq ? 'text-emerald-600' : 'text-red-600');
        updateCharts(aa, het, rec, eAA, eHet, eRec, chisq);
      }
      ['aa', 'het', 'rec'].forEach((id) => el(id).addEventListener('input', update));

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.counts = new Chart(el('chart-counts'), {
          type: 'bar',
          data: { labels: ['AA', 'Aa', 'aa'], datasets: [{ label: 'Observed', data: [70, 10, 20], backgroundColor: '#6366f1' }, { label: 'Expected', data: [56.25, 37.5, 6.25], backgroundColor: '#f59e0b' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Count' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.chisq = new Chart(el('chart-chisq'), {
          type: 'bar',
          data: { labels: ['Your χ²', 'Critical value (3.841)'], datasets: [{ label: 'Value', data: [53.78, 3.841], backgroundColor: ['#ef4444', '#94a3b8'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Chi-square value' } } }, plugins: { legend: { display: false } } }),
        });
      }
      function updateCharts(aa, het, rec, eAA, eHet, eRec, chisq) {
        if (charts.counts) { charts.counts.data.datasets[0].data = [aa, het, rec]; charts.counts.data.datasets[1].data = [eAA, eHet, eRec]; charts.counts.update('none'); }
        if (charts.chisq) { charts.chisq.data.datasets[0].data = [chisq, 3.841]; charts.chisq.update('none'); }
      }

      function popScene(container, counts) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const colors = [0x6366f1, 0xf59e0b, 0x94a3b8];
        let idx = 0;
        counts.forEach((count, ci) => {
          for (let i = 0; i < count; i++) {
            const m = new THREE.Mesh(new THREE.SphereGeometry(0.16, 10, 8), new THREE.MeshStandardMaterial({ color: colors[ci] }));
            const angle = (idx / 30) * Math.PI * 2, r = 1.5 + (idx % 3) * 0.7;
            m.position.set(Math.cos(angle) * r, Math.sin(angle) * r * 0.6, (Math.random() - 0.5) * 1.5);
            s.scene.add(m);
            idx++;
          }
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagMatch = null, diagDeviate = null;
      function initDiagMatch() { const c = el('diag-match'); if (!c) throw new Error('no container'); diagMatch = popScene(c, [16, 8, 1]); }
      function initDiagDeviate() { const c = el('diag-deviate'); if (!c) throw new Error('no container'); diagDeviate = popScene(c, [14, 2, 4]); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[hardy-weinberg-equilibrium] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagMatch(); } catch (e) { console.error('[hardy-weinberg-equilibrium] match diagram failed', e); }
          try { initDiagDeviate(); } catch (e) { console.error('[hardy-weinberg-equilibrium] deviate diagram failed', e); }
        }
        mountResize([diagMatch, diagDeviate]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
