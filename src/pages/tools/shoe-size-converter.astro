---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Shoe Size Converter';
const description = 'Convert shoe sizes between US, UK, EU, and centimeters for men\'s and women\'s footwear.';
const intro = 'Convert a shoe size between US, UK, EU, and foot length in centimeters.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why do US and UK shoe sizes differ by only 1-2, not by 4 like clothing?', a: 'Shoe sizing uses a different base scale than clothing sizing. US men\'s sizes typically run about 1 full size larger than the equivalent UK number, and about 0.5-1 size larger than women\'s US-to-UK, unlike the roughly 4-point gap seen in dress sizing.' },
  { q: 'Do men\'s and women\'s shoe sizes convert the same way?', a: 'No. A women\'s US size is roughly 1.5-2 sizes larger than the equivalent men\'s US size for the same foot length, so always confirm which scale a size is listed in before converting.' },
  { q: 'Is EU shoe sizing based on centimeters?', a: 'EU (Paris point / Continental) sizing is based on the Paris point system, where each full size equals two-thirds of a centimeter of last length, not foot length directly, which is why EU sizes increase in smaller visual steps than US or UK.' },
  { q: 'How accurate is a size chart compared to measuring my foot?', a: 'A conversion chart gives a reliable starting point, but foot width, brand lasts, and material stretch all shift real-world fit — measuring foot length in centimeters and checking it against the brand\'s own chart is more reliable for a first purchase from a new brand.' },
];
const howTo = {
  name: 'How to convert a shoe size',
  steps: [
    { name: 'Choose gender scale', text: 'Select Men\'s or Women\'s sizing, since they do not share the same numbers for the same foot length.' },
    { name: 'Enter your known size', text: 'Pick the size and system you already know.' },
    { name: 'Read the converted sizes', text: 'US, UK, EU, and approximate foot length in centimeters appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {["Men's", "Women's"].map((d) => (
        <button data-gender={d} class="gender-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">{d}</button>
      ))}
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Known size system</span>
      <select id="system" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100">
        <option value="US">US</option>
        <option value="UK">UK</option>
        <option value="EU">EU</option>
      </select>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Size</span>
      <select id="size" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100"></select>
    </div>
    <div id="results" class="mt-6 grid gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">US</div><div id="r-us" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">UK</div><div id="r-uk" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-rose-600 p-3 text-center"><div class="text-sm text-rose-100">EU</div><div id="r-eu" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Foot length</div><div id="r-cm" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ssc-title ssc-desc">
      <title id="ssc-title">Foot outline with length measurement</title>
      <desc id="ssc-desc">An outline of a foot showing heel-to-toe length used as the basis for shoe size conversion</desc>
      <path d="M330 50 Q320 40 300 45 Q260 55 250 100 Q245 140 260 165 Q275 185 320 185 L480 185 Q500 185 500 165 L500 90 Q500 60 470 52 Q400 35 330 50Z" fill="#fecdd3" stroke="#e11d48" stroke-width="2" />
      <line x1="250" y1="200" x2="500" y2="200" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <polygon points="250,200 262,195 262,205" fill="#94a3b8" />
      <polygon points="500,200 488,195 488,205" fill="#94a3b8" />
      <text x="375" y="215" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Foot length (heel to longest toe)</text>
      <text x="600" y="120" font-size="12" fill="#94a3b8" font-family="system-ui,sans-serif">EU size ≈ foot length (cm) ÷ 0.667</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Shoe size systems all ultimately trace back to foot (last) length</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How shoe size conversion works</h2>
    <p class="mt-2 text-slate-600">
      Every shoe size system is a different way of labeling the same underlying measurement: the length of the last (the foot-shaped form a shoe is built on), which closely tracks actual foot length. US and UK sizing count up from a fixed reference point in roughly one-third-inch increments, while EU sizing uses the Paris point system, where one full size equals two-thirds of a centimeter of last length. Because the increments are different sizes, the same physical growth in foot length produces different-looking jumps across systems.
    </p>
    <p class="mt-3 text-slate-600">
      Men's and women's US sizing also do not share a scale — a women's US 8 and a men's US 8 are not the same foot length. The general accepted conversion is that a women's US size is about 1.5 sizes larger in number than the men's US size for the same physical foot, which is why unisex or "convert my men's size to women's" questions trip people up constantly.
    </p>
    <p class="mt-3 text-xs text-slate-400">Size relationships follow the standard Brannock-device / Paris-point conventions used across the footwear industry for US, UK, and EU (Continental) sizing.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A shopper wears a men's US 9 and wants to order sneakers from a UK-based site.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">US size:</span> <span class="text-slate-600">9</span></div>
        <div><span class="font-medium text-slate-700">UK equivalent:</span> <span class="text-slate-600"><strong>UK 8</strong></span></div>
        <div><span class="font-medium text-slate-700">EU equivalent:</span> <span class="text-slate-600"><strong>EU 42.5</strong></span></div>
        <div><span class="font-medium text-slate-700">Foot length:</span> <span class="text-slate-600">≈ <strong>26.7 cm</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Cross-border sneaker buying is the single biggest driver of shoe-size confusion, since limited-release drops are frequently only available through UK, EU, or Japanese retailers. A US 10.5 buyer who orders a "10.5" from a European site without checking the region assumption could end up half a size off in either direction depending on whether the site defaulted to US or EU numbering for that listing.
    </p>
    <p class="mt-3 text-slate-600">
      Gifting is the other common case — buying shoes for someone else means working from whatever size they told you, which may be in a system you don't normally use yourself. Converting first, then double-checking against the specific brand's chart (running shoe brands especially vary by up to half a size between models), avoids an awkward return.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"My US size is my EU size minus 32, just like clothing." <strong class="text-slate-900">No.</strong> Shoe sizing and clothing sizing use completely unrelated numbering systems; there is no shared offset between them, so a clothing-size mental shortcut will give a wrong shoe size.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Half sizes convert evenly across every system." <strong class="text-slate-900">Not always.</strong> Some EU sizes only exist in whole numbers depending on the brand's last, so a US half size sometimes rounds to the nearest available EU whole size rather than mapping to its own EU half size.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Clothing Size Converter</a>
      <a href="/tools/sock-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Sock Size Calculator</a>
      <a href="/tools/shoelace-length-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Shoelace Length Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let gender = "Men's";

    // [US, UK, EU, cm]
    const menTable = [
      [7, 6, 40, 25.0], [7.5, 6.5, 40.5, 25.4], [8, 7, 41, 25.7], [8.5, 7.5, 42, 26.0],
      [9, 8, 42.5, 26.7], [9.5, 8.5, 43, 27.0], [10, 9, 44, 27.3], [10.5, 9.5, 44.5, 27.9],
      [11, 10, 45, 28.3], [11.5, 10.5, 45.5, 28.6], [12, 11, 46, 29.0], [13, 12, 47, 29.9],
    ];
    const womenTable = [
      [5, 2.5, 35.5, 22.0], [5.5, 3, 36, 22.2], [6, 3.5, 36.5, 22.5], [6.5, 4, 37.5, 22.9],
      [7, 4.5, 38, 23.3], [7.5, 5, 38.5, 23.5], [8, 5.5, 39, 23.8], [8.5, 6, 40, 24.1],
      [9, 6.5, 40.5, 24.5], [9.5, 7, 41, 24.8], [10, 7.5, 42, 25.1], [10.5, 8, 42.5, 25.4], [11, 8.5, 43, 25.7],
    ];

    function populateSizes() {
      const sizeSel = el('size');
      const sys = el('system').value;
      const table = gender === "Men's" ? menTable : womenTable;
      const idx = sys === 'US' ? 0 : sys === 'UK' ? 1 : 2;
      sizeSel.innerHTML = '';
      table.forEach((row, i) => {
        const opt = document.createElement('option');
        opt.value = i;
        opt.textContent = row[idx];
        sizeSel.appendChild(opt);
      });
      update();
    }

    function update() {
      const table = gender === "Men's" ? menTable : womenTable;
      const idx = parseInt(el('size').value || '0', 10);
      const row = table[idx];
      if (!row) return;
      el('r-us').textContent = 'US ' + row[0];
      el('r-uk').textContent = 'UK ' + row[1];
      el('r-eu').textContent = 'EU ' + row[2];
      el('r-cm').textContent = row[3].toFixed(1) + ' cm';
    }

    document.querySelectorAll('.gender-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.gender-btn').forEach((b) => {
          b.className = 'gender-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50';
        });
        btn.className = 'gender-btn rounded-lg border border-rose-300 bg-rose-100 px-4 py-1.5 text-sm font-medium text-rose-700 transition';
        gender = btn.dataset.gender;
        populateSizes();
      });
    });

    el('system').addEventListener('change', populateSizes);
    el('size').addEventListener('change', update);
    document.querySelector('.gender-btn').click();
  </script>
</ToolLayout>
