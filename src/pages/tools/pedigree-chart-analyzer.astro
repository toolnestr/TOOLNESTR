---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Pedigree Chart Analyzer';
const description = "Pedigree chart analyzer: answer a short decision tree about how a trait runs through generations to infer its most likely inheritance pattern.";
const intro = "Answer a short series of questions about how a trait appears across a family's generations — whether it skips generations, and whether it shows a sex bias — to infer its most likely inheritance pattern: autosomal dominant, autosomal recessive, X-linked dominant, or X-linked recessive. Two 3D diagrams compare a trait appearing every generation to one skipping a generation, and charts summarize the four classic inheritance patterns.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a pedigree chart?', a: 'A pedigree chart is a family tree diagram showing which relatives are affected by a genetic trait across multiple generations, used to infer how that trait is inherited.' },
  { q: 'How do you tell if a trait is dominant or recessive from a pedigree?', a: 'If the trait "skips generations" — appearing in a grandparent, disappearing in the parents, then reappearing in a grandchild — it\'s almost always recessive. If every affected individual has at least one affected parent (no skipped generations), it\'s more likely dominant.' },
  { q: 'How do you tell if a trait is autosomal or X-linked?', a: "If the trait affects males and females in roughly equal numbers, it's likely autosomal. If it strongly favors one sex (typically males) and never passes from an affected father directly to a son, that pattern points to X-linked inheritance." },
  { q: 'Why does X-linked recessive inheritance affect more males than females?', a: 'Males have only one X chromosome, so a single copy of a recessive X-linked allele is enough to cause the trait. Females have two X chromosomes, so they need two copies (one from each parent) to be affected — making it much more likely for females to be unaffected carriers instead.' },
  { q: 'Why can\'t an affected father pass an X-linked trait to his sons?', a: "A father passes his Y chromosome, not his X chromosome, to his sons — so an X-linked trait carried on the father's X chromosome can only be passed to his daughters, never directly to his sons." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Pedigree Chart Analyzer',
  description: "Answer a short decision tree about a trait's pattern across generations to infer its inheritance mode.",
  steps: [
    { name: 'Answer whether the trait skips generations', text: 'Do two unaffected parents ever have an affected child?' },
    { name: 'Answer whether the trait shows a sex bias', text: 'Does it affect males and females equally, or mostly one sex?' },
    { name: 'For sex-biased traits, answer the father-to-son question', text: 'Do all daughters of an affected father show the trait, while sons never do?' },
  ],
};

const formulas = [
  { expr: 'Skips generations? → Recessive; Never skips? → Dominant', note: 'the first branching question' },
  { expr: 'Equal sex distribution? → Autosomal; Sex-biased, no father-to-son transmission? → X-linked', note: 'the second branching question' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — cystic fibrosis (autosomal recessive)', tone: 'slate',
    given: 'Two unaffected parents (both unknowing carriers) have a child with cystic fibrosis. The condition affects males and females in equal numbers across the population.',
    rows: [
      { label: 'Skips generations?', value: 'Yes — two unaffected parents had an affected child → suggests recessive' },
      { label: 'Sex distribution?', value: 'Equal between males and females → suggests autosomal' },
      { label: 'Conclusion:', value: 'Autosomal recessive inheritance', full: true },
    ],
    note: 'Cystic fibrosis is a textbook real-world example of autosomal recessive inheritance — both parents are unaffected carriers, each contributing one recessive allele.',
  },
  {
    title: 'Worked example 2 — hemophilia (X-linked recessive)', tone: 'amber',
    given: 'An unaffected woman (a carrier) has an affected son and an unaffected daughter (who is herself a carrier). The condition affects far more males than females across the family.',
    rows: [
      { label: 'Skips generations?', value: 'Yes — the trait can pass silently through unaffected carrier females → suggests recessive' },
      { label: 'Sex distribution?', value: 'Strongly biased toward males → suggests X-linked' },
      { label: 'Conclusion:', value: 'X-linked recessive inheritance', full: true },
    ],
    note: "Hemophilia's famous spread through European royal families, passed through unaffected carrier queens and princesses to affected sons and grandsons, is the classic historical example of this exact pattern.",
  },
];

const comparison = {
  heading: 'The four classic inheritance patterns',
  note: 'Each pattern leaves a distinctive signature across a pedigree\'s generations.',
  headers: [{ label: 'Pattern' }, { label: 'Skips generations?' }, { label: 'Sex distribution' }],
  rows: [
    ['Autosomal dominant', 'No', 'Equal'],
    ['Autosomal recessive ★', 'Yes', 'Equal'],
    ['X-linked dominant', 'No', 'More affected females; affected fathers pass to all daughters, no sons'],
    ['X-linked recessive', 'Yes', 'More affected males; never passes father to son'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Skipping generations combined with equal sex distribution is the classic signature of autosomal recessive inheritance.',
};

const realWorld = [
  { emoji: '🏥', title: 'Genetic counseling', body: 'Genetic counselors construct and analyze real family pedigrees using exactly this logic to estimate the probability that future children will inherit a genetic condition.' },
  { emoji: '🧬', title: 'Clinical diagnosis of inherited conditions', body: 'Recognizing a family\'s inheritance pattern helps clinicians narrow down which specific genetic condition (and which gene) might be responsible for a set of symptoms running in a family.' },
  { emoji: '👑', title: 'Historical genetics (the "royal disease")', body: 'Hemophilia\'s spread through European royalty in the 19th and 20th centuries is one of history\'s best-documented real-world pedigrees, and remains a classic teaching example of X-linked recessive inheritance.' },
  { emoji: '🐕', title: 'Veterinary and animal breeding genetics', body: 'Breeders use pedigree analysis to identify how inherited health conditions or desired traits are passed through breeding lines, guiding responsible breeding decisions.' },
];

const misconceptions = [
  { claim: '"If a trait skips a generation, it must be recessive."', truth: 'Skipping generations strongly suggests recessive inheritance, but it isn\'t absolute proof — reduced penetrance (a dominant allele not always producing the trait) can occasionally produce a similar-looking skipped pattern, though this is far less common than simple recessive inheritance.' },
  { claim: '"X-linked traits only ever affect males."', truth: "Females can absolutely be affected by X-linked traits — for a recessive X-linked trait, a female needs two copies (one from each parent) to be affected, which is less common than a male needing just one copy, but it does happen." },
  { claim: '"A pedigree can prove with 100% certainty which inheritance pattern is responsible."', truth: "A pedigree pattern only shows what's most consistent with the observed data — genetic testing is required to confirm the exact gene and inheritance mechanism responsible, especially since small family pedigrees don't always show every possible combination of matings needed to rule out every alternative pattern." },
  { claim: '"Every genetic trait follows one of these four simple patterns."', truth: 'Many real traits are more complex — polygenic (influenced by multiple genes), influenced by environment, or showing incomplete dominance or codominance — the four classic Mendelian patterns analyzed here are the simplest and most commonly taught case, not the only possibility.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 12, "Mendel\'s Experiments and Heredity" (free, peer-reviewed, includes pedigree analysis). <a href="https://openstax.org/books/biology-2e/pages/12-3-laws-of-inheritance" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Pedigree analysis chapter.' },
  { html: '<strong>Nussbaum, McInnes &amp; Willard, <em>Thompson &amp; Thompson Genetics in Medicine</em></strong> — Clinical pedigree interpretation chapter.' },
];
const sourcesNote = 'A simplified decision tree covering the four classic Mendelian inheritance patterns. Real pedigree analysis in clinical genetics considers additional factors like penetrance and pedigree size.';

const howToUse = [
  { title: 'Answer the generation-skipping question', body: 'Do two unaffected parents ever have an affected child?' },
  { title: 'Answer the sex-distribution question', body: 'Does the trait affect both sexes equally, or show a bias?' },
  { title: 'Read the inferred inheritance pattern', body: 'The most likely pattern displays automatically based on your answers.' },
];

const related = [
  { href: '/tools/punnett-square-calculator', emoji: '🔳', title: 'Punnett Square Calculator', desc: 'Build a monohybrid cross grid — genotype and phenotype ratios.' },
  { href: '/tools/sex-linked-trait-calculator', emoji: '🔬', title: 'Sex-Linked Trait Punnett Calculator', desc: 'X-linked inheritance crosses.' },
  { href: '/tools/genotype-frequency-calculator', emoji: '🧮', title: 'Genotype Frequency Calculator', desc: 'Observed genotype and allele frequencies from counts.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="each of the four classic inheritance patterns leaves its own distinctive fingerprint across a family tree — whether the trait can hide for a generation, and whether it favors one sex — so a couple of well-chosen yes/no questions about a pedigree is usually enough to identify which one is at work."
  howIntro="A recessive trait can hide silently in unaffected carriers for a generation before reappearing, while a dominant trait generally can't — every affected individual needs an affected parent. Separately, an autosomal trait (on one of the 22 non-sex chromosomes) affects both sexes equally, while an X-linked trait rides along on the X chromosome, producing a very different, sex-biased inheritance pattern — most distinctively, an affected father can never pass an X-linked trait to his sons, since sons always inherit his Y chromosome instead. Combining the answer to just these two questions — does it skip generations, and does it show a sex bias — narrows a real pedigree down to one of the four classic Mendelian inheritance patterns."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where pedigree analysis actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="space-y-4">
      <div>
        <p class="text-sm font-medium text-slate-700">1. Do two unaffected parents ever have an affected child (does the trait skip generations)?</p>
        <div class="mt-1 flex gap-2">
          <button data-q="skips" data-val="yes" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">Yes, it skips generations</button>
          <button data-q="skips" data-val="no" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">No, every affected person has an affected parent</button>
        </div>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-700">2. Does the trait affect males and females in roughly equal numbers?</p>
        <div class="mt-1 flex gap-2">
          <button data-q="equal" data-val="yes" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">Yes, roughly equal</button>
          <button data-q="equal" data-val="no" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">No, one sex is affected far more</button>
        </div>
      </div>
      <div id="q3-wrap" class="hidden">
        <p class="text-sm font-medium text-slate-700">3. Do all daughters of an affected father show the trait, while none of his sons ever do?</p>
        <div class="mt-1 flex gap-2">
          <button data-q="fatherdaughter" data-val="yes" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">Yes, all daughters affected</button>
          <button data-q="fatherdaughter" data-val="no" class="q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium">No, only some (carriers)</button>
        </div>
      </div>
    </div>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Most likely inheritance pattern</div>
      <div id="r-pattern" class="mt-1 text-2xl font-bold">Answer the questions above</div>
    </div>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Every generation vs. skipping a generation</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-dominant" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Appears every generation</h3>
          <p class="mt-1 text-sm text-slate-600">Every affected individual (amber) has an affected parent — consistent with dominant inheritance.</p>
        </div>
        <div>
          <div id="diag-recessive" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Skips a generation</h3>
          <p class="mt-1 text-sm text-slate-600">Unaffected carriers (grey) hide the trait for a generation — consistent with recessive inheritance.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Inheritance pattern reference charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Real-world example conditions by pattern</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-examples"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Typical male:female ratio by pattern</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ratio"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const answers = { skips: null, equal: null, fatherdaughter: null };

      function identify() {
        if (answers.skips === null || answers.equal === null) return null;
        if (answers.equal === 'yes') {
          return answers.skips === 'yes' ? 'Autosomal recessive' : 'Autosomal dominant';
        }
        if (answers.fatherdaughter === null) return 'need-q3';
        return answers.fatherdaughter === 'yes' ? 'X-linked dominant' : 'X-linked recessive';
      }
      function updateResult() {
        el('q3-wrap').classList.toggle('hidden', !(answers.skips !== null && answers.equal === 'no'));
        const result = identify();
        if (!result || result === 'need-q3') { el('r-pattern').textContent = result === 'need-q3' ? 'Answer question 3 above' : 'Answer the questions above'; return; }
        el('r-pattern').textContent = result;
      }
      document.querySelectorAll('.q-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const q = btn.getAttribute('data-q'), val = btn.getAttribute('data-val');
          answers[q] = val;
          document.querySelectorAll('.q-btn[data-q="' + q + '"]').forEach((b) => {
            b.className = b === btn ? 'q-btn rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white' : 'q-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium';
          });
          updateResult();
        });
      });

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        new Chart(el('chart-examples'), {
          type: 'bar',
          data: { labels: ['Autosomal\ndominant', 'Autosomal\nrecessive', 'X-linked\ndominant', 'X-linked\nrecessive'], datasets: [{ label: 'Example condition', data: [1, 1, 1, 1], backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#ef4444'] }] },
          options: Object.assign({}, base, {
            scales: { y: { display: false } },
            plugins: {
              legend: { display: false },
              tooltip: { callbacks: { label: (ctx) => ['Huntington\'s disease', 'Cystic fibrosis', 'Vitamin D-resistant rickets', 'Hemophilia'][ctx.dataIndex] } },
            },
          }),

        });
        new Chart(el('chart-ratio'), {
          type: 'bar',
          data: { labels: ['Autosomal\ndominant', 'Autosomal\nrecessive', 'X-linked\ndominant', 'X-linked\nrecessive'], datasets: [{ label: 'Typical sex ratio', data: [1, 1, 2, 0.5], backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Relative female:male ratio (1 = equal)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function pedigreeScene(container, everyGen) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const rows = 3;
        for (let r = 0; r < rows; r++) {
          const count = r === 0 ? 2 : r === 1 ? 4 : 3;
          for (let i = 0; i < count; i++) {
            let affected;
            if (everyGen) affected = true;
            else affected = r !== 1;
            const m = new THREE.Mesh(new THREE.SphereGeometry(0.22, 12, 10), new THREE.MeshStandardMaterial({ color: affected ? 0xf59e0b : 0x94a3b8 }));
            m.position.set((i - count / 2) * 0.9, (rows / 2 - r) * 1.4, 0);
            s.scene.add(m);
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagDominant = null, diagRecessive = null;
      function initDiagDominant() { const c = el('diag-dominant'); if (!c) throw new Error('no container'); diagDominant = pedigreeScene(c, true); }
      function initDiagRecessive() { const c = el('diag-recessive'); if (!c) throw new Error('no container'); diagRecessive = pedigreeScene(c, false); }

      function boot() {
        try { initCharts(); updateResult(); } catch (e) { console.error('[pedigree-analyzer] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagDominant(); } catch (e) { console.error('[pedigree-analyzer] dominant diagram failed', e); }
          try { initDiagRecessive(); } catch (e) { console.error('[pedigree-analyzer] recessive diagram failed', e); }
        }
        mountResize([diagDominant, diagRecessive]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
