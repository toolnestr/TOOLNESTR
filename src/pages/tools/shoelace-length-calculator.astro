---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Shoelace Length Calculator';
const description = 'Find the recommended shoelace length from the number of eyelet pairs on your shoe.';
const intro = 'Find the recommended shoelace length from the number of eyelet pairs on your shoe.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I count eyelet pairs?', a: 'Count the holes down one side of the shoe only (not both sides combined) — a typical adult sneaker has 6-8 eyelet pairs, while a tall boot can have 10 or more.' },
  { q: 'Does lacing style change how much lace I need?', a: 'Yes — this table assumes standard criss-cross lacing. Bar (straight) lacing typically uses noticeably less lace for the same eyelet count, while decorative lacing styles can use more.' },
  { q: 'What if my eyelet count falls between two rows in the table?', a: 'Round up to the next listed eyelet count for a safer estimate — a slightly longer lace can be tied with extra length tucked or wrapped, while a too-short lace may not reach to tie at all.' },
  { q: 'Does boot height matter beyond eyelet count?', a: 'Eyelet count is the main driver of length since it corresponds to the total lacing distance, but very tall boots with widely spaced eyelets may need a length toward the higher end of the range shown for that eyelet count.' },
];
const howTo = {
  name: 'How to find your shoelace length',
  steps: [
    { name: 'Count your eyelet pairs', text: 'Count the eyelets down one side of the shoe.' },
    { name: 'Select that count below', text: 'Choose the matching number of eyelet pairs.' },
    { name: 'Read the recommended lace length', text: 'A general recommended length for standard criss-cross lacing appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <span class="text-sm font-medium text-slate-700">Number of eyelet pairs (count one side)</span>
    <select id="pairs" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
      <option value="0">2 pairs</option>
      <option value="1">3 pairs</option>
      <option value="2">4 pairs</option>
      <option value="3">5 pairs</option>
      <option value="4" selected>6 pairs</option>
      <option value="5">7 pairs</option>
      <option value="6">8 pairs</option>
      <option value="7">9 pairs</option>
      <option value="8">10 pairs</option>
    </select>
    <div id="results" class="mt-6 grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">Inches</div><div id="r-in" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Centimeters</div><div id="r-cm" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="slc2-title slc2-desc">
      <title id="slc2-title">Shoe with criss-cross laced eyelets counted on one side</title>
      <desc id="slc2-desc">A shoe outline with eyelets on both sides connected by criss-crossing lace lines, with one side's eyelets marked for counting</desc>
      <path d="M150 160 Q140 100 220 80 L420 80 Q480 80 500 130 L500 170 L150 170 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      {[100, 140, 180, 220, 260].map((y, i) => (
        <>
          <circle cx="230" cy={y} r="5" fill="#c026d3" />
          <circle cx="380" cy={y} r="5" fill="#c026d3" />
        </>
      ))}
      <line x1="230" y1="100" x2="380" y2="140" stroke="#94a3b8" stroke-width="1.5" />
      <line x1="380" y1="100" x2="230" y2="140" stroke="#94a3b8" stroke-width="1.5" />
      <text x="150" y="100" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Count this side</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Eyelet pairs are counted down one side, not the total number of holes</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How shoelace length is estimated</h2>
    <p class="mt-2 text-slate-600">
      Lace length scales with the number of eyelet pairs because each additional row adds both more vertical distance to travel and more diagonal criss-cross length between the two sides. This calculator uses a general reference table widely used across the footwear industry, mapping common eyelet-pair counts to a recommended lace length that accounts for standard criss-cross lacing plus enough extra length to comfortably tie a bow.
    </p>
    <p class="mt-3 text-slate-600">
      Because actual eyelet spacing, shoe width, and lacing style all vary somewhat between shoe models, this is a general starting reference rather than an exact geometric calculation — if you have an old lace of a known good length, measuring it directly is more precise than any table.
    </p>
    <p class="mt-3 text-xs text-slate-400">Lengths reflect a commonly published general shoelace-length reference table used across footwear and shoe-care retailers, based on standard criss-cross lacing.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A pair of sneakers has 6 eyelet pairs on each side.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Eyelet pairs:</span> <span class="text-slate-600">6</span></div>
        <div><span class="font-medium text-slate-700">Recommended length:</span> <span class="text-slate-600"><strong>36 in (90 cm)</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Replacing a broken or worn-out lace is the most common reason to reach for a length reference, especially when buying laces online where you can't test the length in person before purchase — matching eyelet count to the table avoids the common frustration of a replacement lace that's too short to tie properly or so long it needs multiple wraps to manage.
    </p>
    <p class="mt-3 text-slate-600">
      Switching to a different lacing style (like bar lacing for a cleaner look, or a decorative pattern) often changes lace length needs from the standard criss-cross baseline, so this table works best as a starting point for standard lacing and should be adjusted for other styles.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Eyelet pairs means the total number of holes in the shoe." <strong class="text-slate-900">No — count one side only.</strong> A shoe with 12 total eyelet holes has 6 eyelet pairs, since each pair consists of one hole on each side at the same height.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All lacing styles need the same length for the same eyelet count." <strong class="text-slate-900">Not true.</strong> Bar lacing typically uses noticeably less lace than criss-cross for the same number of eyelets, since it has less diagonal travel between rows.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/shoe-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Shoe Size Converter</a>
      <a href="/tools/sock-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Sock Size Calculator</a>
      <a href="/tools/elastic-length-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Elastic Length Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    // [inches, cm]
    const lengths = [
      [18, 45], [24, 60], [27, 70], [30, 75], [36, 90], [40, 100], [45, 114], [54, 137], [63, 160],
    ];

    function update() {
      const idx = parseInt(el('pairs').value, 10);
      const [inches, cm] = lengths[idx];
      el('r-in').textContent = inches + ' in';
      el('r-cm').textContent = cm + ' cm';
    }

    el('pairs').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
