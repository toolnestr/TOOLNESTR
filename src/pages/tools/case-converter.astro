---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site.js';

const title = 'Case Converter';
const description =
  'Free online case converter. Instantly change text to UPPERCASE, lowercase, ' +
  'Title Case, Sentence case, capitalized or alternating case. Runs in your browser.';

const faqs = [
  { q: 'What is Title Case vs Sentence case?', a: 'Title Case capitalizes the first letter of most words (great for headings). Sentence case capitalizes only the first letter of each sentence, like normal writing.' },
  { q: 'Will it keep my line breaks?', a: 'Yes. Converting case only changes letters, so your paragraphs and line breaks stay exactly as they are.' },
  { q: 'Is there a character limit?', a: 'No. Paste as much text as you like — it is all processed instantly on your device.' },
  { q: 'Is my text private?', a: 'Yes. The converter runs entirely in your browser, so nothing is uploaded or stored.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: `${title} — ${site.name}`,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Any (web browser)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description,
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};

const buttons = [
  { id: 'upper', label: 'UPPERCASE' },
  { id: 'lower', label: 'lowercase' },
  { id: 'title', label: 'Title Case' },
  { id: 'sentence', label: 'Sentence case' },
  { id: 'capitalize', label: 'Capitalize Each Word' },
  { id: 'alternating', label: 'aLtErNaTiNg' },
  { id: 'inverse', label: 'InVeRsE cAsE' },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <nav class="mb-4 text-sm text-slate-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-1">›</span>
      <a href="/#everyday" class="hover:text-indigo-600">Everyday</a>
      <span class="mx-1">›</span>
      <span class="text-slate-700">Case Converter</span>
    </nav>

    <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Case Converter</h1>
    <p class="mt-2 text-slate-600">
      Paste your text, then pick a case. The text is converted instantly — copy it back with one click.
    </p>

    <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
      <textarea
        id="text-input"
        rows="8"
        placeholder="Type or paste your text here…"
        class="w-full resize-y rounded-xl border border-slate-300 p-4 text-base leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
      ></textarea>

      <div class="mt-4 flex flex-wrap gap-2">
        {buttons.map((b) => (
          <button
            data-case={b.id}
            class="case-btn rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700"
          >{b.label}</button>
        ))}
      </div>

      <div class="mt-4 flex flex-wrap gap-2 border-t border-slate-100 pt-4">
        <button id="copy-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Copy text</button>
        <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
        <span id="char-count" class="ml-auto self-center text-sm text-slate-400">0 characters</span>
      </div>
    </div>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">About this case converter</h2>
      <p class="mt-2 text-slate-600">
        A case converter changes the capitalization of your text without you retyping it. It's
        handy for fixing text typed with Caps Lock on, formatting headlines in Title Case,
        cleaning up ALL-CAPS messages, or creating fun alternating-case text for social media.
        Everything happens instantly in your browser.
      </p>

      <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
      <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
        <li>Type or paste your text into the box.</li>
        <li>Click the case you want (UPPERCASE, lowercase, Title Case, and more).</li>
        <li>The text updates in place — click another case to change it again.</li>
        <li>Press “Copy text” to copy the result, or “Clear” to start over.</li>
      </ol>

      <h2 class="mt-8 text-xl font-bold text-slate-900">Frequently asked questions</h2>
      <div class="mt-3 space-y-4">
        {faqs.map((f) => (
          <div class="rounded-xl border border-slate-200 bg-white p-4">
            <h3 class="font-semibold text-slate-900">{f.q}</h3>
            <p class="mt-1 text-sm text-slate-600">{f.a}</p>
          </div>
        ))}
      </div>

      <h2 class="mt-8 text-xl font-bold text-slate-900">Related tools</h2>
      <p class="mt-2 text-sm text-slate-600">
        Try the <a href="/tools/word-counter" class="font-medium text-indigo-600 hover:underline">Word &amp; Character Counter</a>, or
        <a href="/" class="font-medium text-indigo-600 hover:underline">browse all tools →</a>
      </p>
    </section>
  </div>

  <script is:inline>
    const input = document.getElementById('text-input');
    const charCount = document.getElementById('char-count');

    const toTitle = (s) => s.replace(/\w\S*/g, (w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase());
    const toSentence = (s) =>
      s.toLowerCase().replace(/(^\s*\w|[.!?]\s*\w)/g, (c) => c.toUpperCase());
    const toAlternating = (s) => {
      let i = 0;
      return s.replace(/[a-z]/gi, (c) => (i++ % 2 ? c.toUpperCase() : c.toLowerCase()));
    };
    const toInverse = (s) =>
      s.replace(/[a-z]/gi, (c) => (c === c.toUpperCase() ? c.toLowerCase() : c.toUpperCase()));

    const transforms = {
      upper: (s) => s.toUpperCase(),
      lower: (s) => s.toLowerCase(),
      title: toTitle,
      sentence: toSentence,
      capitalize: toTitle,
      alternating: toAlternating,
      inverse: toInverse,
    };

    function updateCount() {
      charCount.textContent = input.value.length.toLocaleString() + ' characters';
    }

    document.querySelectorAll('.case-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const fn = transforms[btn.dataset.case];
        if (fn) input.value = fn(input.value);
        updateCount();
      });
    });

    input.addEventListener('input', updateCount);

    document.getElementById('clear-btn').addEventListener('click', () => {
      input.value = '';
      updateCount();
      input.focus();
    });

    document.getElementById('copy-btn').addEventListener('click', async () => {
      if (!input.value) return;
      try {
        await navigator.clipboard.writeText(input.value);
        const btn = document.getElementById('copy-btn');
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => (btn.textContent = original), 1500);
      } catch (e) {}
    });

    updateCount();
  </script>
</BaseLayout>
