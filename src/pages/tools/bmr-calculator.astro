---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'BMR Calculator';
const description =
  'Free BMR calculator using the Mifflin-St Jeor equation. Find your Basal Metabolic Rate — ' +
  'the calories your body burns at rest — in metric or imperial units.';
const intro =
  'Enter your age, sex, height and weight to estimate your Basal Metabolic Rate (BMR) — the calories your body uses at complete rest.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is BMR?', a: 'Basal Metabolic Rate is the number of calories your body needs to perform basic life-sustaining functions (breathing, circulation, cell production) while at complete rest.' },
  { q: 'Which formula do you use?', a: 'We use the Mifflin-St Jeor equation, which is widely considered one of the most accurate BMR formulas for most people.' },
  { q: 'How is BMR different from daily calories?', a: 'BMR is calories at rest. Your total daily calorie need is your BMR multiplied by an activity factor — use our Calorie Calculator for that.' },
  { q: 'Does BMR change with age?', a: 'Yes — BMR naturally declines by about 1–2% per decade after age 20, mainly due to muscle loss. Strength training helps offset this decline and keep your resting metabolism higher.' },
  { q: 'Can I use my BMR to lose weight?', a: 'Yes. Once you know your BMR, you can estimate your total daily energy expenditure (TDEE) by multiplying it by an activity factor. Eating below your TDEE creates a calorie deficit for weight loss.' },
  { q: 'What factors affect my BMR?', a: 'The biggest factors are muscle mass, age, sex, and body size. People with more muscle burn more calories at rest. Genetics, hormones and thyroid function also play a role.' },
  { q: 'Can I increase my BMR?', a: 'Yes — building muscle through strength training is the most effective way. High-intensity exercise can also temporarily raise your post-exercise calorie burn. Crash dieting, on the other hand, lowers BMR.' },
  { q: 'Is BMR the same as metabolism?', a: 'Not exactly. Metabolism is the broader term for all chemical processes in your body. BMR is a specific measurement of one part of it — the calories needed to stay alive at rest.' },
  { q: 'How often should I recalculate my BMR?', a: 'Recalculate after a significant weight change (5 kg / 10 lb or more), after major changes in physical activity, or every year to account for age-related changes.' },
  { q: 'Does BMR differ between men and women?', a: 'Yes — men typically have a higher BMR because they tend to have more muscle mass and less body fat than women of the same age and weight. The Mifflin-St Jeor equation accounts for this.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
        <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="male">Male</option><option value="female">Female</option>
        </select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Age</span>
        <input id="age" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="metric" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-3" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Your BMR</div>
      <div id="bmr-val" class="mt-1 text-3xl font-bold">—</div>
      <div class="mt-1 text-sm opacity-80">calories/day at rest</div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Fill in your details to see your BMR.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About BMR</h2>
    <p class="mt-2 text-slate-600">
      Your <a href="https://www.mayoclinic.org/healthy-lifestyle/weight-loss/in-depth/metabolism/art-20046508" rel="noopener">Basal Metabolic Rate</a> is the foundation of any calorie or weight plan — it's how many
      calories you'd burn if you did nothing but rest all day. Knowing your BMR helps you
      understand how much you can eat to maintain, lose or gain weight once activity is added. Pair it with the <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> to see your total daily needs, and check your <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI</a> for a broader health picture.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical or dietary advice.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the BMR Calculator when you're planning a weight-management strategy and need to know your baseline calorie burn. Nutrition coaches often start with BMR to build a personalised meal plan. It's also useful if you're curious how ageing or changes in body composition affect your resting metabolism — for example, comparing your BMR before and after a strength-training programme.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Weigh yourself first thing in the morning after using the bathroom for the most consistent measurements.</li>
      <li>Use the same scale and measuring method each time to track changes accurately over weeks and months.</li>
      <li>Remember that BMR is just the starting point — multiply it by an activity factor using the <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> to get your true daily needs.</li>
    </ul>
  </section>

  <!-- BMR ranges bar chart -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different BMR ranges mean</h2>
    <p class="mt-2 text-slate-600">BMR varies significantly by age, sex and body composition. The bars below show typical ranges for a 70 kg man and a 60 kg woman at different life stages.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Age 20–29</span><span class="text-slate-400">1,500–1,800 cal/day</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:90%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Age 30–39</span><span class="text-slate-400">1,450–1,750 cal/day</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:85%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Age 40–49</span><span class="text-slate-400">1,400–1,700 cal/day</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:80%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Age 50–59</span><span class="text-slate-400">1,350–1,650 cal/day</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:75%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Age 60+</span><span class="text-slate-400">1,300–1,600 cal/day</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:70%"></div></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🥗</span>
      <h3 class="mt-2 font-semibold text-slate-900">Weight-conscious dieter</h3>
      <p class="mt-1 text-sm text-slate-600">Know your baseline calorie burn to set a realistic daily target that supports steady, sustainable weight loss without crashing your metabolism.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏋️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Strength athlete</h3>
      <p class="mt-1 text-sm text-slate-600">Track your BMR before and after a muscle-building programme to see how your increased lean mass has boosted your resting calorie burn.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Nutrition coach</h3>
      <p class="mt-1 text-sm text-slate-600">Use BMR as the starting point for building personalised meal plans and teaching clients why their metabolism isn't static.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Older adult</h3>
      <p class="mt-1 text-sm text-slate-600">Understand how age-related metabolic decline affects your energy needs and why strength training helps keep your BMR from dropping too fast.</p>
    </div>
  </section>

  <!-- BMR reference table -->
  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Age range</th><th class="p-3">Male (70 kg, 175 cm)</th><th class="p-3">Female (60 kg, 165 cm)</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">18–25</td><td class="p-3">~1,690 cal/day</td><td class="p-3">~1,394 cal/day</td></tr>
        <tr><td class="p-3 font-medium">26–35</td><td class="p-3">~1,640 cal/day</td><td class="p-3">~1,344 cal/day</td></tr>
        <tr><td class="p-3 font-medium">36–45</td><td class="p-3">~1,590 cal/day</td><td class="p-3">~1,294 cal/day</td></tr>
        <tr><td class="p-3 font-medium">46–55</td><td class="p-3">~1,540 cal/day</td><td class="p-3">~1,244 cal/day</td></tr>
        <tr><td class="p-3 font-medium">56–65</td><td class="p-3">~1,490 cal/day</td><td class="p-3">~1,194 cal/day</td></tr>
        <tr><td class="p-3 font-medium">66+</td><td class="p-3">~1,440 cal/day</td><td class="p-3">~1,144 cal/day</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How BMR is calculated</h2>
    <p class="mt-2 text-slate-600">
      BMR is estimated using the <strong><a href="https://pubmed.ncbi.nlm.nih.gov/2305711/" rel="noopener">Mifflin-St Jeor equation</a></strong>, one of the most widely validated formulas for estimating resting energy expenditure. It uses weight, height, age and sex — the four biggest predictors of basal metabolic rate.
    </p>
    <p class="mt-3 text-slate-600">
      <strong>Men:</strong> BMR = 10 × weight (kg) + 6.25 × height (cm) − 5 × age + 5<br>
      <strong>Women:</strong> BMR = 10 × weight (kg) + 6.25 × height (cm) − 5 × age − 161
    </p>
    <p class="mt-3 text-slate-600">
      The result is in calories per day. Muscle mass, genetics and hormone levels can cause individual variation of ±200–300 cal/day from the formula's estimate.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 35-year-old woman who is 165 cm tall and weighs 68 kg wants to know her BMR.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Equation:</span> <span class="text-slate-600">10 × 68 + 6.25 × 165 − 5 × 35 − 161</span></div>
        <div><span class="font-medium text-slate-700">Calculation:</span> <span class="text-slate-600">680 + 1,031.25 − 175 − 161</span></div>
        <div><span class="font-medium text-slate-700">BMR:</span> <span class="text-slate-600"><strong>1,375 calories/day</strong></span></div>
        <div><span class="font-medium text-slate-700">Meaning:</span> <span class="text-slate-600">Her body burns roughly 1,375 calories per day at complete rest — before any activity is factored in.</span></div>
        <div><span class="font-medium text-slate-700">Comparison:</span> <span class="text-slate-600">A 35-year-old man of the same height and weight would have BMR ≈ 1,541 cal/day (166 cal higher due to the +5 term).</span></div>
        <div><span class="font-medium text-slate-700">TDEE (light activity):</span> <span class="text-slate-600">1,375 × 1.375 ≈ <strong>1,891 cal/day</strong></span></div>
      </div>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the BMR Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your details</h3>
        <p class="mt-1 text-sm text-slate-600">Provide your age, sex, height and weight in either metric or imperial units. All inputs update the result instantly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your BMR</h3>
        <p class="mt-1 text-sm text-slate-600">Your Basal Metabolic Rate appears in calories per day — this is the energy your body needs at complete rest, before any activity.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Apply an activity factor</h3>
        <p class="mt-1 text-sm text-slate-600">Multiply your BMR by your activity level (1.2–1.9) using the Calorie Calculator to estimate your total daily energy needs.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate BMR tracking</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Build muscle to raise your BMR</h3>
        <p class="mt-1 text-sm text-slate-600">Strength training is the most effective way to increase your resting metabolism. Each kilogram of muscle burns roughly 13 extra calories per day at rest.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Weigh consistently</h3>
        <p class="mt-1 text-sm text-slate-600">Use the same scale at the same time of day (ideally morning, after the bathroom, before eating) for the most reliable BMR calculations over time.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Recalculate after changes</h3>
        <p class="mt-1 text-sm text-slate-600">Your BMR changes with age, weight shifts and changes in muscle mass. Recalculate every 5–10 kg of weight change or whenever your body composition shifts noticeably.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const age = parseFloat(el('age').value);
      let cm, kg;
      if (metric) { cm = parseFloat(el('m-h').value); kg = parseFloat(el('m-w').value); }
      else {
        const ft = parseFloat(el('i-ft').value) || 0, inch = parseFloat(el('i-in').value) || 0;
        cm = (ft * 12 + inch) * 2.54; kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      if (!age || !cm || !kg || age <= 0 || cm <= 0 || kg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      let bmr = 10 * kg + 6.25 * cm - 5 * age + (el('sex').value === 'male' ? 5 : -161);
      el('bmr-val').textContent = Math.round(bmr).toLocaleString();
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'age', 'm-h', 'm-w', 'i-ft', 'i-in', 'i-w'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
