---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'BMR Calculator';
const description =
  'Free BMR calculator using the Mifflin-St Jeor equation. Find your Basal Metabolic Rate — ' +
  'the calories your body burns at rest — in metric or imperial units.';
const intro =
  'Enter your age, sex, height and weight to estimate your Basal Metabolic Rate (BMR) — the calories your body uses at complete rest.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is BMR?', a: 'Basal Metabolic Rate is the number of calories your body needs to perform basic life-sustaining functions (breathing, circulation, cell production) while at complete rest.' },
  { q: 'Which formula do you use?', a: 'We use the Mifflin-St Jeor equation, which is widely considered one of the most accurate BMR formulas for most people.' },
  { q: 'How is BMR different from daily calories?', a: 'BMR is calories at rest. Your total daily calorie need is your BMR multiplied by an activity factor — use our Calorie Calculator for that.' },
  { q: 'Does BMR change with age?', a: 'Yes — BMR naturally declines by about 1–2% per decade after age 20, mainly due to muscle loss. Strength training helps offset this decline and keep your resting metabolism higher.' },
  { q: 'Can I use my BMR to lose weight?', a: 'Yes. Once you know your BMR, you can estimate your total daily energy expenditure (TDEE) by multiplying it by an activity factor. Eating below your TDEE creates a calorie deficit for weight loss.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
        <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="male">Male</option><option value="female">Female</option>
        </select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Age</span>
        <input id="age" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="metric" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-3" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Your BMR</div>
      <div id="bmr-val" class="mt-1 text-3xl font-bold">—</div>
      <div class="mt-1 text-sm opacity-80">calories/day at rest</div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Fill in your details to see your BMR.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About BMR</h2>
    <p class="mt-2 text-slate-600">
      Your Basal Metabolic Rate is the foundation of any calorie or weight plan — it's how many
      calories you'd burn if you did nothing but rest all day. Knowing your BMR helps you
      understand how much you can eat to maintain, lose or gain weight once activity is added. Pair it with the <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> to see your total daily needs, and check your <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI</a> for a broader health picture.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical or dietary advice.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the BMR Calculator when you're planning a weight-management strategy and need to know your baseline calorie burn. Nutrition coaches often start with BMR to build a personalised meal plan. It's also useful if you're curious how ageing or changes in body composition affect your resting metabolism — for example, comparing your BMR before and after a strength-training programme.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Weigh yourself first thing in the morning after using the bathroom for the most consistent measurements.</li>
      <li>Use the same scale and measuring method each time to track changes accurately over weeks and months.</li>
      <li>Remember that BMR is just the starting point — multiply it by an activity factor using the <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> to get your true daily needs.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const age = parseFloat(el('age').value);
      let cm, kg;
      if (metric) { cm = parseFloat(el('m-h').value); kg = parseFloat(el('m-w').value); }
      else {
        const ft = parseFloat(el('i-ft').value) || 0, inch = parseFloat(el('i-in').value) || 0;
        cm = (ft * 12 + inch) * 2.54; kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      if (!age || !cm || !kg || age <= 0 || cm <= 0 || kg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      let bmr = 10 * kg + 6.25 * cm - 5 * age + (el('sex').value === 'male' ? 5 : -161);
      el('bmr-val').textContent = Math.round(bmr).toLocaleString();
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'age', 'm-h', 'm-w', 'i-ft', 'i-in', 'i-w'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
