---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Liters to Gallons (US)"
  emoji="🧪"
  fromUnit="liters" toUnit="US gallons"
  fromTitle="Liters" toTitle="Gallons"
  fromSym="L" toSym="gal"
  quantity="volume"
  kind="factor" factor={0.264172}
  reverseSlug="gallons-to-liters" reverseLabel="Gallons to Liters Converter"
  hasReverse={true}
  related={[{"slug":"volume-converter","label":"Volume Converter"}]}
  useCase="Useful for fuel and large containers when a metric volume needs to be read in US gallons."
/>
