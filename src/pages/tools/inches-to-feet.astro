---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Inches to Feet"
  emoji="📏"
  fromUnit="inches" toUnit="feet"
  fromTitle="Inches" toTitle="Feet"
  fromSym="in" toSym="ft"
  quantity="length"
  kind="factor" factor={0.0833333}
  reverseSlug="feet-to-inches" reverseLabel="Feet to Inches Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Turn a long measurement in inches into feet and read room or material sizes more naturally."
/>
