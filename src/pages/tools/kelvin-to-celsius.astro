---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Kelvin to Celsius"
  emoji="🌡️"
  fromUnit="Kelvin" toUnit="degrees Celsius"
  fromTitle="Kelvin" toTitle="Celsius"
  fromSym="K" toSym="°C"
  quantity="temperature"
  kind="tempKC"
  reverseSlug="celsius-to-kelvin" reverseLabel="Celsius to Kelvin Converter"
  hasReverse={true}
  related={[{"slug":"celsius-to-fahrenheit","label":"Celsius to Fahrenheit Converter"},{"slug":"fahrenheit-to-celsius","label":"Fahrenheit to Celsius Converter"}]}
  useCase="Turn an absolute temperature in Kelvin from physics or chemistry into familiar Celsius."
/>
