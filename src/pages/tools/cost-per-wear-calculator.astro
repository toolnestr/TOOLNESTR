---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Cost-Per-Wear Calculator';
const description = 'Calculate the true cost of a garment per wear from its purchase price and how many times you actually wear it.';
const intro = 'Find out what a piece of clothing really costs by spreading its price across every time you wear it.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is cost-per-wear?', a: 'Cost-per-wear is a garment\'s purchase price divided by the number of times you\'ve worn (or expect to wear) it. It reframes "expensive" and "cheap" around actual usage rather than sticker price — a $200 coat worn 100 times ($2/wear) can be a better value than a $20 shirt worn twice ($10/wear).' },
  { q: 'How do I estimate future wears for a new purchase?', a: 'Estimate how many times per month you\'d realistically wear the item, multiply by how many months you expect to keep it (accounting for style longevity, fabric durability, and how versatile it is with your existing wardrobe), then divide price by that total.' },
  { q: 'Does cost-per-wear include care costs?', a: 'The basic calculation only covers the purchase price. Add dry cleaning, laundering, or repair costs to the numerator for a fuller "cost of ownership" figure, which this calculator supports as an optional field.' },
  { q: 'Is a lower cost-per-wear always the better choice?', a: 'Not necessarily — it\'s one input among several (comfort, ethical sourcing, resale value, how the item makes you feel). It\'s most useful for comparing similar items or deciding whether a higher upfront price is justified by expected use.' },
];
const howTo = {
  name: 'How to calculate cost-per-wear',
  steps: [
    { name: 'Enter the purchase price', text: 'Include the price you paid or plan to pay for the item.' },
    { name: 'Enter wear count', text: 'Enter actual wears so far, or an honest estimate of total expected wears.' },
    { name: 'Add optional care costs', text: 'Include cleaning or repair costs for a fuller lifetime-cost picture.' },
    { name: 'Read the cost per wear', text: 'The result shows what the item costs you each time you put it on.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Purchase price ($)</span>
        <input id="price" type="number" step="any" placeholder="e.g. 150" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of wears</span>
        <input id="wears" type="number" step="1" placeholder="e.g. 40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block sm:col-span-2"><span class="text-sm font-medium text-slate-700">Care/repair costs ($, optional)</span>
        <input id="care" type="number" step="any" placeholder="e.g. 20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Cost per wear</div>
        <div id="r-cpw" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="cpw-title cpw-desc">
      <title id="cpw-title">Garment price divided across repeated wears</title>
      <desc id="cpw-desc">A single price bar splitting into many smaller wear segments, illustrating cost-per-wear</desc>
      <rect x="60" y="40" width="180" height="40" rx="6" fill="#e11d48" />
      <text x="150" y="65" text-anchor="middle" font-size="13" fill="white" font-family="system-ui,sans-serif">Price paid</text>
      <text x="350" y="65" text-anchor="middle" font-size="20" fill="#94a3b8" font-family="system-ui,sans-serif">÷</text>
      <g transform="translate(400,40)">
        {Array.from({ length: 10 }).map((_, i) => (
          <rect x={i * 36} y="0" width="30" height="40" rx="4" fill="#fda4af" />
        ))}
      </g>
      <text x="590" y="100" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Number of wears</text>
      <text x="400" y="140" font-size="12" fill="#94a3b8" font-family="system-ui,sans-serif">Each block = one wear, each carrying a smaller share of the price</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">More wears spread the same price across more uses, lowering cost-per-wear</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How cost-per-wear is calculated</h2>
    <p class="mt-2 text-slate-600">
      Cost-per-wear takes a garment's price — plus any optional care or repair costs over its life — and divides that total by the number of times it's been or will be worn. The result reframes value away from sticker price alone: it's the actual cost you incur each time you choose that item, which is the number that matters for wardrobe planning and budgeting.
    </p>
    <p class="mt-3 text-slate-600">
      This is why fast-fashion pieces that are worn only a handful of times before falling apart or falling out of rotation often have a surprisingly high cost-per-wear despite a low sticker price, while a well-made, versatile piece worn hundreds of times over years can have a very low cost-per-wear despite costing far more upfront. The metric doesn't say a cheap item is automatically bad value or an expensive item automatically good value — it depends entirely on how much use you actually get.
    </p>
    <p class="mt-3 text-slate-600">
      For a purchase you haven't made yet, the wear count has to be an honest estimate. Overestimating expected wears (assuming you'll wear that statement blazer weekly when realistically it's a special-occasion piece) understates the true cost-per-wear and can justify purchases that don't actually pay off in use.
    </p>
    <p class="mt-3 text-xs text-slate-400">Cost-per-wear is a standard personal-finance and sustainable-fashion metric used across wardrobe-cost-tracking tools and fashion journalism.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A $150 winter coat worn 40 times, with $20 in dry cleaning over its life.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Price + care:</span> <span class="text-slate-600">150 + 20 = $170</span></div>
        <div><span class="font-medium text-slate-700">Wears:</span> <span class="text-slate-600">40</span></div>
        <div><span class="font-medium text-slate-700">Cost per wear:</span> <span class="text-slate-600">170 ÷ 40 = <strong>$4.25</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A $20 fast-fashion top worn twice before it pills or goes out of style has a cost-per-wear of $10 — the same as a $400 pair of well-made boots worn 40 times over several winters. The boots feel expensive at checkout, but on a per-use basis they're identical value, and if they last another 40 wears, the boots pull ahead decisively while the top is already discarded.
    </p>
    <p class="mt-3 text-slate-600">
      Capsule-wardrobe and sustainable-fashion advocates use cost-per-wear specifically to justify buying fewer, higher-quality, more versatile pieces — a neutral blazer that pairs with everything and gets worn weekly beats a trendy one-off piece that only works with one outfit, even at a much lower price, once wear count is factored in.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Expensive always means better value." <strong class="text-slate-900">Only if it's actually worn enough.</strong> A high price only pays off in cost-per-wear terms if the item gets proportionally more use — an expensive piece that sits unworn in the closet has an infinitely climbing cost-per-wear, not a low one.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Cost-per-wear is the only thing that matters when buying clothes." <strong class="text-slate-900">It's one factor among several.</strong> Fit, comfort, ethical sourcing, resale value, and personal style all matter too — cost-per-wear is best used to compare similar options or sanity-check an expensive purchase, not as the sole deciding factor.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/clothing-markup-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Clothing Markup Calculator</a>
      <a href="/tools/margin-vs-markup-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Margin vs Markup Calculator</a>
      <a href="/tools/custom-garment-price-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Custom Garment Price Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const price = parseFloat(el('price').value);
      const wears = parseFloat(el('wears').value);
      const care = parseFloat(el('care').value) || 0;
      if (!(price > 0 && wears > 0)) { el('results').classList.add('hidden'); return; }
      const total = price + care;
      const cpw = total / wears;
      el('r-cpw').textContent = '$' + cpw.toFixed(2);
      el('r-note').textContent = '$' + total.toFixed(2) + ' total across ' + wears + ' wears';
      el('results').classList.remove('hidden');
    }

    ['price', 'wears', 'care'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
