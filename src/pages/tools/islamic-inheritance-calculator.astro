---
import ToolLayout from '../../layouts/ToolLayout.astro';
import CurrencySelect from '../../components/CurrencySelect.astro';
const title = 'Islamic Inheritance (Faraid) Calculator';
const description = 'Estimate each heir’s Qur’anic share of an estate under Islamic inheritance law (Faraid) for spouse, parents, sons and daughters, with amounts.';
const intro = 'Enter the estate value and surviving heirs to estimate each person’s fixed Qur’anic share and amount.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'What is Faraid?', a: 'Faraid is the Islamic law of inheritance, derived mainly from the Qur’an (Surah an-Nisa), which assigns fixed shares of an estate to specific relatives such as the spouse, parents and children. It applies after debts and any valid bequest (up to one-third) are settled.' },
  { q: 'What is the 2:1 rule?', a: 'Where sons and daughters inherit together as residuary heirs, a son receives twice the share of a daughter. This reflects the male’s financial responsibility in Islam to maintain his family, while a woman’s wealth remains her own.' },
  { q: 'How much does a spouse inherit?', a: 'A husband inherits one-half if there are no children and one-quarter if there are children. A wife inherits one-quarter if there are no children and one-eighth if there are children. Multiple wives share the wife’s portion equally.' },
  { q: 'When should I consult a scholar?', a: 'This tool covers common cases with spouse, parents and children. Real estates can involve siblings, grandparents, grandchildren, blocking rules, ‘awl and radd adjustments. For anything beyond the basics, consult a qualified scholar or a specialist before distributing.' },
];
const sources = [
  { html: "<strong>The Qur’an</strong> — e.g. Surah an-Nisa (4:11–12, 4:176) for the fixed inheritance shares (fara’id)." },
  { html: "<strong>Sahih al-Bukhari &amp; Sahih Muslim</strong> — hadith on inheritance, zakat and nisab thresholds." },
  { html: "<strong>AAOIFI and recognized fiqh councils</strong> (e.g. Islamic Fiqh Academy) for contemporary rulings. <a href=\"https://aaoifi.com/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">aaoifi.com</a>" },
];
const sourcesNote = "Rulings differ between scholars and schools (madhahib), and calculated astronomical times/dates may differ from local sighting. Confirm with a qualified scholar before acting.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-800">
    <strong>Important:</strong> This calculator estimates common cases (spouse, parents, sons, daughters). It does not cover siblings, grandparents, grandchildren or special blocking rules. Always confirm a real distribution with a qualified scholar.
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <CurrencySelect />

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Estate value (after debts &amp; bequests)</span>
        <input id="estate" type="number" step="any" placeholder="100000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Surviving spouse</span>
        <select id="spouse" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="none">None</option><option value="husband">Husband</option><option value="wife">Wife</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of sons</span>
        <input id="sons" type="number" min="0" step="1" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of daughters</span>
        <input id="daughters" type="number" min="0" step="1" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 flex flex-wrap gap-5">
      <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700"><input id="father" type="checkbox" class="h-4 w-4 rounded border-slate-300" /> Father alive</label>
      <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700"><input id="mother" type="checkbox" class="h-4 w-4 rounded border-slate-300" /> Mother alive</label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div id="rows" class="space-y-2"></div>
      <p id="note" class="mt-3 text-sm text-slate-500"></p>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="240" viewBox="0 0 800 240" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fa-title fa-desc">
      <title id="fa-title">Family tree of fixed inheritance shares</title>
      <desc id="fa-desc">The estate flows to spouse, parents and children, each receiving a Qur’anic fixed share, with sons taking twice a daughter’s portion.</desc>
      <rect x="330" y="20" width="140" height="40" rx="8" fill="#6366f1" /><text x="400" y="45" text-anchor="middle" font-size="14" fill="#fff" font-family="system-ui,sans-serif" font-weight="bold">Estate</text>
      <line x1="400" y1="60" x2="160" y2="110" stroke="#cbd5e1" stroke-width="2" /><line x1="400" y1="60" x2="320" y2="110" stroke="#cbd5e1" stroke-width="2" /><line x1="400" y1="60" x2="480" y2="110" stroke="#cbd5e1" stroke-width="2" /><line x1="400" y1="60" x2="640" y2="110" stroke="#cbd5e1" stroke-width="2" />
      {[['Spouse',120],['Mother',280],['Father',440],['Children',600]].map((n) => (
        <g><rect x={n[1]} y="110" width="110" height="36" rx="8" fill="#eef2ff" stroke="#a5b4fc" /><text x={n[1] + 55} y="133" text-anchor="middle" font-size="13" fill="#3730a3" font-family="system-ui,sans-serif">{n[0]}</text></g>
      ))}
      <text x="655" y="180" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">son : daughter = 2 : 1</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Fixed shares are assigned first; remaining residue passes to the residuary heirs (asaba).</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How Islamic inheritance is calculated</h2>
    <p class="mt-2 text-slate-600">Islamic inheritance, or Faraid, distributes a deceased person’s estate according to fixed shares laid down in the Qur’an. Before distribution, the estate is reduced by funeral costs, outstanding debts, and any valid bequest of up to one-third to non-heirs. What remains is then divided among the rightful heirs in a precise order: those with fixed shares (ashab al-furud) first, then the residuary heirs (asaba) who take whatever is left.</p>
    <p class="mt-3 text-slate-600">This calculator handles the most common household: a surviving spouse, parents, and children. It assigns the spouse and mother their Qur’anic fractions, gives the father his one-sixth when children survive, and then distributes the remaining estate to the children. When sons are present they inherit as residuaries together with daughters in the ratio of two to one. When only daughters survive, they take their fixed share of one-half (a single daughter) or two-thirds (two or more), with any residue passing to the father.</p>
    <p class="mt-3 text-slate-600">The tool also applies two classical adjustments. If the fixed shares add up to more than the whole estate, it applies ‘awl, scaling every share down proportionally. If the shares fall short and there are no residuary heirs to absorb the remainder, it applies radd, returning the surplus to the blood heirs (excluding the spouse). Any amount that still cannot be assigned is flagged for a scholar’s review.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The fixed shares at a glance</h2>
    <div class="mt-3 overflow-x-auto rounded-xl border border-slate-200">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-slate-600"><tr><th class="px-4 py-2">Heir</th><th class="px-4 py-2">No children</th><th class="px-4 py-2">With children</th></tr></thead>
        <tbody class="divide-y divide-slate-100 text-slate-700">
          <tr><td class="px-4 py-2 font-medium">Husband</td><td class="px-4 py-2">1/2</td><td class="px-4 py-2">1/4</td></tr>
          <tr><td class="px-4 py-2 font-medium">Wife</td><td class="px-4 py-2">1/4</td><td class="px-4 py-2">1/8</td></tr>
          <tr><td class="px-4 py-2 font-medium">Mother</td><td class="px-4 py-2">1/3</td><td class="px-4 py-2">1/6</td></tr>
          <tr><td class="px-4 py-2 font-medium">Father</td><td class="px-4 py-2">residue (asaba)</td><td class="px-4 py-2">1/6 (+ residue if no son)</td></tr>
          <tr><td class="px-4 py-2 font-medium">Daughter(s), no son</td><td class="px-4 py-2">1/2 one · 2/3 two+</td><td class="px-4 py-2">—</td></tr>
          <tr><td class="px-4 py-2 font-medium">Son(s)</td><td class="px-4 py-2" colspan="2">residue, 2:1 with daughters</td></tr>
        </tbody>
      </table>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Estate 120,000; a wife, a mother, 2 sons and 1 daughter survive.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Wife (1/8):</span> <span class="text-slate-600">15,000</span></div>
        <div><span class="font-medium text-slate-700">Mother (1/6):</span> <span class="text-slate-600">20,000</span></div>
        <div class="sm:col-span-2"><span class="font-medium text-slate-700">Residue 85,000</span> split 2:1:1 → <span class="text-slate-600">each son 34,000, daughter 17,000</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/zakat-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat Calculator</a>
      <a href="/tools/khums-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Khums Calculator</a>
      <a href="/tools/age-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Age Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmtMoney = (n) => window.tnFmtMoney(n);
    const num = (id) => { const v = parseFloat(el(id).value); return isFinite(v) && v > 0 ? v : 0; };
    const intv = (id) => { const v = parseInt(el(id).value, 10); return isFinite(v) && v > 0 ? v : 0; };

    function calc() {
      const estate = num('estate');
      const spouse = el('spouse').value;
      const sons = intv('sons'), daughters = intv('daughters');
      const father = el('father').checked, mother = el('mother').checked;
      const hasChild = sons > 0 || daughters > 0;
      const S = {};
      if (spouse === 'husband') S['Husband'] = hasChild ? 1 / 4 : 1 / 2;
      if (spouse === 'wife') S['Wife'] = hasChild ? 1 / 8 : 1 / 4;
      if (mother) S['Mother'] = hasChild ? 1 / 6 : 1 / 3;
      let fatherFixed = father ? (hasChild ? 1 / 6 : 0) : 0;
      if (daughters > 0 && sons === 0) S['Daughters'] = daughters === 1 ? 1 / 2 : 2 / 3;

      let fixedSum = Object.values(S).reduce((a, b) => a + b, 0) + fatherFixed;
      let unallocated = 0, note = '';

      if (fixedSum > 1.000001) {
        const k = 1 / fixedSum;
        for (const key in S) S[key] *= k;
        fatherFixed *= k;
        if (father) S['Father'] = fatherFixed;
        note = '‘Awl applied: fixed shares exceeded the estate, so all shares were reduced proportionally.';
      } else {
        let residue = 1 - fixedSum;
        if (sons > 0) {
          const parts = sons * 2 + daughters;
          S['Sons'] = residue * (sons * 2 / parts);
          if (daughters > 0) S['Daughters'] = (S['Daughters'] || 0) + residue * (daughters / parts);
          if (father) S['Father'] = fatherFixed;
        } else if (father) {
          S['Father'] = fatherFixed + Math.max(residue, 0);
        } else if (residue > 0.000001) {
          const raddKeys = Object.keys(S).filter((k) => k !== 'Husband' && k !== 'Wife');
          const base = raddKeys.reduce((a, k) => a + S[k], 0);
          if (base > 0) { raddKeys.forEach((k) => S[k] += residue * (S[k] / base)); note = 'Radd applied: surplus returned to the blood heirs.'; }
          else { unallocated = residue; note = 'Remaining share has no eligible heir here — consult a scholar (it may pass to extended family or the public treasury).'; }
        }
      }

      const labels = { Sons: sons > 1 ? sons + ' sons (total)' : 'Son', Daughters: daughters > 1 ? daughters + ' daughters (total)' : 'Daughter' };
      const rows = Object.keys(S).filter((k) => S[k] > 0.0000001).map((k) => {
        const pct = (S[k] * 100);
        const amt = estate > 0 ? estate * S[k] : 0;
        const each = (k === 'Sons' && sons > 1) ? ' (each ' + fmtMoney(amt / sons) + ')'
                   : (k === 'Daughters' && daughters > 1) ? ' (each ' + fmtMoney(amt / daughters) + ')' : '';
        return '<div class="flex items-center justify-between rounded-xl bg-slate-50 px-4 py-3"><span class="font-medium text-slate-800">' + (labels[k] || k) +
          '</span><span class="text-right"><span class="font-bold text-indigo-700">' + pct.toFixed(2) + '%</span>' +
          (estate > 0 ? ' <span class="text-slate-600">· ' + fmtMoney(amt) + each + '</span>' : '') + '</span></div>';
      }).join('');

      if (!rows) { el('results').classList.add('hidden'); return; }
      el('rows').innerHTML = rows + (unallocated > 0 ? '<div class="flex items-center justify-between rounded-xl bg-amber-50 px-4 py-3"><span class="font-medium text-amber-800">Unallocated</span><span class="font-bold text-amber-800">' + (unallocated * 100).toFixed(2) + '%</span></div>' : '');
      el('note').textContent = note;
      el('results').classList.remove('hidden');
    }
    ['estate', 'sons', 'daughters'].forEach((id) => el(id).addEventListener('input', calc));
    ['spouse'].forEach((id) => el(id).addEventListener('change', calc));
    ['father', 'mother'].forEach((id) => el(id).addEventListener('change', calc));
    document.addEventListener('tn:currency', calc);
  </script>
</ToolLayout>
