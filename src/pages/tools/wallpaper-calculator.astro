---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Wallpaper Roll Calculator';
const description = 'Find how many rolls of wallpaper you need from your wall dimensions, roll size and pattern repeat, with a waste allowance for trimming and matching.';
const intro = 'Estimate the wallpaper rolls you need, from your wall dimensions, roll size, and pattern repeat, with waste for trimming and pattern matching.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How many rolls of wallpaper do I need?', a: 'Find the wall area in square feet, divide by the usable area of one roll after waste, and round up. A standard American double roll covers about 56 square feet, but usable coverage drops with a larger pattern repeat because more of each strip is trimmed to match the pattern.' },
  { q: 'What is a pattern repeat?', a: 'The pattern repeat is the vertical distance before a wallpaper design repeats itself. Every strip after the first must be shifted to line up the pattern, and that shift wastes part of each roll. A larger repeat wastes more material per strip.' },
  { q: 'What is a double roll?', a: 'Many wallpapers are sold in "double rolls," which is simply twice the length of a single roll bundled together, commonly giving about 56 square feet of coverage. Always check the specific roll size printed on your paper, since it varies by brand.' },
  { q: 'How much extra should I buy?', a: 'Buy 10 to 15 percent extra for straight or small-repeat patterns, and 15 to 20 percent for large repeats or a room with many corners, windows, and doors. Buying all rolls from one dye lot avoids visible color shifts between rolls.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall perimeter (ft)</span>
        <input id="perim" type="number" step="any" placeholder="44" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall height (ft)</span>
        <input id="height" type="number" step="any" placeholder="9" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Roll width (in)</span>
        <input id="rw" type="number" step="any" placeholder="20.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Roll length (ft)</span>
        <input id="rl" type="number" step="any" placeholder="33" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Pattern repeat (in, 0 if none)</span>
        <input id="repeat" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Openings to subtract (sq ft)</span>
        <input id="openings" type="number" step="any" placeholder="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Rolls needed</div>
        <div id="r-rolls" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-strips" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Wall area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Usable strip length</div><div id="r-usable" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Strips per roll</div><div id="r-perroll" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="280" viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="wp-title wp-desc">
      <title id="wp-title">Wallpaper strips with pattern repeat</title>
      <desc id="wp-desc">Vertical wallpaper strips on a wall, with waste at the top of each strip for pattern matching</desc>
      <g stroke="#6366f1" stroke-width="1.5">
        <rect x="100" y="70" width="50" height="160" fill="#e0e7ff"/><rect x="150" y="70" width="50" height="160" fill="#c7d2fe"/><rect x="200" y="70" width="50" height="160" fill="#e0e7ff"/><rect x="250" y="70" width="50" height="160" fill="#c7d2fe"/>
      </g>
      <rect x="150" y="70" width="50" height="18" fill="#fca5a5" opacity="0.6" />
      <rect x="250" y="70" width="50" height="18" fill="#fca5a5" opacity="0.6" />
      <text x="220" y="250" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">shaded = trimmed for pattern match</text>
      <rect x="400" y="90" width="340" height="130" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="420" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Roll estimate</text>
      <text x="420" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">strips = perimeter &divide; roll width</text>
      <text x="420" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">usable length = wall height + repeat</text>
      <text x="420" y="188" font-size="12" fill="#475569" font-family="system-ui,sans-serif">rolls = strips &divide; (roll length &divide; usable)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Each strip after the first is trimmed to align the pattern, which wastes part of the roll.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the wallpaper calculator works</h2>
    <p class="mt-2 text-slate-600">
      Wallpaper is hung in vertical strips the height of the wall, cut from a long roll. The number of strips needed is the wall's perimeter divided by the roll's width. Each strip needs a little more than the bare wall height so the pattern can be aligned with the strip next to it — that extra is the pattern repeat, the vertical distance before the design repeats.
    </p>
    <p class="mt-3 text-slate-600">
      Adding the repeat to the wall height gives the usable length of each strip. Dividing the roll's total length by that usable strip length tells you how many strips come out of one roll, and dividing the total strip count by strips-per-roll gives the number of rolls, rounded up. A larger repeat wastes more of each roll, since more length is trimmed off to keep the pattern lined up.
    </p>
    <p class="mt-3 text-slate-600">
      This follows the standard trade method for figuring wallcovering quantities. Openings like doors and large windows are subtracted from the wall area for reference, though in practice most installers still buy full strips across an opening and trim afterward, since partial strips are wasteful and hard to match.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the room</h3>
        <p class="mt-1 text-sm text-slate-600">Total wall perimeter and the ceiling height in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the roll and pattern</h3>
        <p class="mt-1 text-sm text-slate-600">Roll width and length from the label, and the pattern repeat if any.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the roll count</h3>
        <p class="mt-1 text-sm text-slate-600">Buy that many rolls from one dye lot, plus a little extra for mistakes.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Strips needed</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= perimeter(in) &divide; roll width(in)</span>. 44 ft (528&Prime;) &divide; 20.5&Prime; = 25.8 &rarr; <strong>26 strips</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Usable strip length</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= height + repeat</span>. 9 ft (108&Prime;) with a 21&Prime; repeat: 108 + 21 = <strong>129&Prime; per strip</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Rolls needed</p>
        <p class="mt-1 text-slate-600">
          A 33 ft (396&Prime;) roll gives 396&frasl;129 = 3 strips per roll. 26 strips &divide; 3 = 8.7 &rarr; <strong>9 rolls</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A small powder room, 32 ft perimeter, 8 ft walls, no pattern repeat, 20.5&Prime; wide by 33 ft rolls.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Strips:</span> <span class="text-slate-600">384&Prime; &divide; 20.5&Prime; = 19</span></div>
        <div><span class="font-medium text-slate-700">Usable length:</span> <span class="text-slate-600">96&Prime; (no repeat)</span></div>
        <div><span class="font-medium text-slate-700">Strips per roll:</span> <span class="text-slate-600">396&frasl;96 = 4</span></div>
        <div><span class="font-medium text-slate-700">Rolls:</span> <span class="text-slate-600">19&frasl;4 = 4.75 &rarr; <strong>5 rolls</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Hanging tips</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🎨</span>
        <h3 class="mt-2 font-semibold text-slate-900">Buy one dye lot</h3>
        <p class="mt-1 text-sm text-slate-600">Rolls printed in different production runs can differ slightly in color. Check the batch number on every roll and buy them all from the same run.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📏</span>
        <h3 class="mt-2 font-semibold text-slate-900">Start at the least-visible corner</h3>
        <p class="mt-1 text-sm text-slate-600">Walls are rarely perfectly square, so the last strip often needs a slightly awkward cut. Plan your starting point so that seam lands somewhere inconspicuous.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🖼️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Large repeats need more waste</h3>
        <p class="mt-1 text-sm text-slate-600">A big, bold pattern with a long repeat can push real usage above this estimate. When in doubt, round the roll count up rather than down.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📦</span>
        <h3 class="mt-2 font-semibold text-slate-900">Keep a spare roll</h3>
        <p class="mt-1 text-sm text-slate-600">Discontinued patterns can be hard to match later. An unopened extra roll makes future repairs or a small addition much easier.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/paint-coverage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Paint Coverage Calculator</a>
      <a href="/tools/square-footage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
      <a href="/tools/drywall-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Drywall Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const perimFt = parseFloat(el('perim').value);
      const heightFt = parseFloat(el('height').value);
      const rwIn = parseFloat(el('rw').value);
      const rlFt = parseFloat(el('rl').value);
      let repeatIn = parseFloat(el('repeat').value); if (!repeatIn || repeatIn < 0) repeatIn = 0;
      let openings = parseFloat(el('openings').value); if (!openings || openings < 0) openings = 0;
      if (!perimFt || !heightFt || !rwIn || !rlFt || perimFt <= 0 || heightFt <= 0 || rwIn <= 0 || rlFt <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const perimIn = perimFt * 12;
      const strips = Math.ceil(perimIn / rwIn);
      const usableIn = heightFt * 12 + repeatIn;
      const rollLenIn = rlFt * 12;
      const stripsPerRoll = Math.max(1, Math.floor(rollLenIn / usableIn));
      const rolls = Math.ceil(strips / stripsPerRoll);
      const area = Math.max(perimFt * heightFt - openings, 0);

      el('r-rolls').textContent = rolls.toLocaleString() + ' rolls';
      el('r-strips').textContent = strips + ' strips needed, ' + stripsPerRoll + ' per roll';
      el('r-area').textContent = area.toFixed(0) + ' ft²';
      el('r-usable').textContent = usableIn.toFixed(1) + ' in';
      el('r-perroll').textContent = stripsPerRoll.toLocaleString();
      el('results').classList.remove('hidden');
    }

    ['perim', 'height', 'rw', 'rl', 'repeat', 'openings'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
