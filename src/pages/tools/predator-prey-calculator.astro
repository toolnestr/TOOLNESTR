---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Predator-Prey (Lotka-Volterra) Simulator';
const description = 'Predator-prey simulator with a live 3D population-cycle diagram and charts. Solve the Lotka-Volterra equilibrium point and simulate oscillating predator and prey populations over time, with worked examples.';
const intro = "Solve the Lotka-Volterra predator-prey equations dPrey/dt = aPrey − bPrey·Predator and dPredator/dt = −cPredator + dPrey·Predator for the system's equilibrium point, and simulate how both populations cycle over time. Two 3D diagrams compare a prey-dominated moment in the cycle to a predator-dominated one, and charts trace the classic out-of-phase oscillation of both populations.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What are the Lotka-Volterra equations?', a: "They're a pair of differential equations modeling predator-prey population dynamics: prey grow exponentially but are consumed by predators (dPrey/dt = aPrey − bPrey·Predator), while predators decline without enough prey but grow by consuming it (dPredator/dt = −cPredator + dPrey·Predator)." },
  { q: 'What do a, b, c, and d represent?', a: "a is the prey's natural growth rate, b is how effectively predators catch prey, c is the predator's natural death rate, and d is how efficiently consumed prey converts into new predators." },
  { q: 'Why do predator and prey populations cycle instead of settling down?', a: 'As prey become abundant, predators have plenty of food and multiply, but the growing predator population then consumes prey faster than it can reproduce, crashing the prey population — which then starves the predators, letting prey recover, and the cycle repeats indefinitely.' },
  { q: 'What is the equilibrium point of the Lotka-Volterra system?', a: 'It occurs at Prey* = c/d and Predator* = a/b — the one population combination where both growth rates exactly cancel out, so neither population changes. In the idealized model, populations orbit around this point rather than settling directly onto it.' },
  { q: "What is the 'paradox of enrichment'?", a: "Counterintuitively, increasing the prey's resources or a predator's hunting efficiency (b) doesn't raise the predator equilibrium (which depends only on a/b) — instead it can destabilize the system into wider population swings, sometimes even risking extinction of one or both populations." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Predator-Prey (Lotka-Volterra) Simulator',
  description: "Solve the system's equilibrium point and simulate predator-prey population cycles over time.",
  steps: [
    { name: 'Enter the four rate parameters', text: 'Prey growth rate (a), predation rate (b), predator death rate (c), and predator reproduction efficiency (d).' },
    { name: 'Enter starting populations', text: 'Initial prey and predator population sizes.' },
    { name: 'Read the equilibrium point', text: 'The population combination where both growth rates exactly balance.' },
  ],
};

const formulas = [
  { expr: 'dPrey/dt = a·Prey − b·Prey·Predator', note: 'prey grow exponentially, minus losses to predation' },
  { expr: 'dPredator/dt = −c·Predator + d·Prey·Predator', note: 'predators decline naturally, plus growth from consuming prey' },
  { expr: 'Equilibrium: Prey* = c/d, Predator* = a/b', note: 'the one population combination where both rates of change are zero' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — finding the equilibrium point', tone: 'slate',
    given: 'Prey growth rate a = 0.5, predation rate b = 0.02, predator death rate c = 0.3, predator efficiency d = 0.01.',
    rows: [
      { label: 'Prey equilibrium:', value: 'Prey* = c/d = 0.3/0.01 = 30' },
      { label: 'Predator equilibrium:', value: 'Predator* = a/b = 0.5/0.02 = 25' },
      { label: 'Interpretation:', value: 'at exactly 30 prey and 25 predators, both populations would stay constant', full: true },
    ],
    note: 'In practice, real (and simulated) predator-prey systems rarely sit exactly at this point — they orbit around it in a repeating cycle instead.',
  },
  {
    title: 'Worked example 2 — the paradox of enrichment', tone: 'amber',
    given: 'Same parameters as example 1, but predation rate b doubles to 0.04 (predators become twice as effective hunters).',
    rows: [
      { label: 'Prey equilibrium (unchanged):', value: 'Prey* = c/d = 0.3/0.01 = 30 (b does not appear in this formula)' },
      { label: 'Predator equilibrium (halved):', value: 'Predator* = a/b = 0.5/0.04 = 12.5' },
      { label: 'Interpretation:', value: 'more efficient predators support a smaller predator population, not a larger one', full: true },
    ],
    note: "This is a genuinely counterintuitive result: making predators better hunters doesn't increase how many predators the system can support at equilibrium — it actually decreases it, since fewer predators are now needed to keep prey population in check.",
  },
];

const comparison = {
  heading: 'How each parameter shifts the equilibrium point',
  note: 'Only two of the four parameters set each equilibrium value.',
  headers: [{ label: 'Parameter' }, { label: 'Affects' }, { label: 'Direction' }],
  rows: [
    ['Prey growth rate (a)', 'Predator equilibrium ★', 'Higher a → more predators supportable'],
    ['Predation rate (b)', 'Predator equilibrium', 'Higher b → fewer predators needed at equilibrium'],
    ['Predator death rate (c)', 'Prey equilibrium', 'Higher c → more prey needed to sustain predators'],
    ['Predator efficiency (d)', 'Prey equilibrium', 'Higher d → fewer prey needed at equilibrium'],
  ],
  highlightIndex: 0,
  footnote: '★ Prey growth rate (a) and predation rate (b) together set the predator equilibrium (a/b) — neither one alone determines it.',
};

const realWorld = [
  { emoji: '🦌', title: 'Wildlife population management', body: 'Wildlife agencies use predator-prey models to predict how introducing or removing a predator species (like wolves) will affect prey populations (like deer or elk) over time.' },
  { emoji: '🐟', title: 'Fisheries and marine ecosystem modeling', body: "Fisheries scientists apply similar predator-prey models to understand how fishing pressure on one species ripples through the food web to affect its predators and prey." },
  { emoji: '🦗', title: 'Agricultural pest control', body: 'Biological pest control programs (introducing a natural predator to control a crop pest) are planned using predator-prey dynamics to predict whether the predator can actually establish a stable, self-sustaining population.' },
  { emoji: '🧫', title: 'Epidemiology and immune system modeling', body: 'The same mathematical structure describes other consumer-resource interactions, including simplified models of immune cells "predating" on pathogens within the body.' },
];

const misconceptions = [
  { claim: '"A stable ecosystem means predator and prey populations stay constant."', truth: "The Lotka-Volterra model shows that oscillation, not constancy, is the natural and stable long-term behavior of a simple predator-prey system — population cycles are a normal, expected pattern, not necessarily a sign of instability." },
  { claim: '"More predators always means fewer prey, in direct proportion."', truth: "The relationship is cyclical and time-delayed, not simply direct — a predator population boom eventually crashes the prey population, which then causes the predator population itself to crash afterward, creating an oscillating rather than a simple inverse relationship." },
  { claim: '"Removing predators is always good for the prey population long-term."', truth: 'Prey populations without predator control can overshoot their environment\'s carrying capacity, leading to resource depletion and a population crash of their own — a dynamic not even captured by the basic Lotka-Volterra model, which assumes unlimited prey resources.' },
  { claim: '"This model perfectly describes real predator-prey populations."', truth: "The basic Lotka-Volterra model is a simplified idealization — it assumes unlimited prey food supply, no other predators or competitors, and no environmental variation, all of which real ecosystems violate to some degree." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 45, "Population and Community Ecology" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/45-2-environmental-limits-to-population-growth" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Lotka (1925) &amp; Volterra (1926)</strong> — the original, independently derived predator-prey equations.' },
  { html: '<strong>Odum, <em>Fundamentals of Ecology</em></strong> — Predator-prey population dynamics chapter.' },
];
const sourcesNote = 'dPrey/dt=aPrey−bPrey·Predator; dPredator/dt=−cPredator+dPrey·Predator. Equilibrium: Prey*=c/d, Predator*=a/b. A simplified idealized model. Results are rounded for display.';

const howToUse = [
  { title: 'Enter the four rate parameters', body: 'Prey growth, predation rate, predator death rate, and predator efficiency.' },
  { title: 'Enter starting populations', body: 'Initial prey and predator counts for the simulation.' },
  { title: 'Read the equilibrium and cycle', body: 'The equilibrium point solves instantly, and the chart shows the resulting population cycle.' },
];

const related = [
  { href: '/tools/logistic-growth-calculator', emoji: '🌱', title: 'Logistic Growth / Carrying Capacity Calculator', desc: 'Population growth limited by a carrying capacity.' },
  { href: '/tools/exponential-population-growth-calculator', emoji: '📈', title: 'Exponential Population Growth Calculator', desc: 'N(t) = N₀e^(rt) — unconstrained population growth.' },
  { href: '/tools/energy-pyramid-calculator', emoji: '🔺', title: 'Energy Pyramid / 10% Rule Calculator', desc: 'Energy transfer efficiency across trophic levels.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="predator and prey populations never settle down to a stable balance — instead, each one's boom feeds directly into the other's future bust, driving both populations around a perpetual, out-of-phase cycle centered on a single equilibrium point they never quite land on."
  howIntro="Prey would grow exponentially on their own, but every encounter with a predator removes one — so prey growth slows as predator numbers rise. Predators, meanwhile, would starve and decline without food, but every prey they catch fuels new predator growth — so predator numbers rise only when prey is abundant. This feedback loop has exactly one equilibrium point, at Prey*=c/d and Predator*=a/b, where both effects perfectly cancel out — but because real populations rarely start exactly there, they instead orbit around it indefinitely: prey boom first, predators boom in response and overshoot, prey crash from overpredation, and predators then crash from starvation, resetting the cycle."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where predator-prey modeling actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Prey growth (a)</span>
        <input id="a" type="number" step="any" value="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Predation rate (b)</span>
        <input id="b" type="number" step="any" value="0.02" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Predator death (c)</span>
        <input id="c" type="number" step="any" value="0.3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Predator efficiency (d)</span>
        <input id="d" type="number" step="any" value="0.01" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Starting prey population</span>
        <input id="prey0" type="number" step="any" value="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Starting predator population</span>
        <input id="pred0" type="number" step="any" value="9" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Prey equilibrium (c/d)</div><div id="r-preyeq" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Predator equilibrium (a/b)</div><div id="r-predeq" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="pp-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Prey-dominated vs. predator-dominated moment</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-preyheavy" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Prey-dominated moment</h3>
          <p class="mt-1 text-sm text-slate-600">Abundant prey, few predators — the predator population is about to grow.</p>
        </div>
        <div>
          <div id="diag-predheavy" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Predator-dominated moment</h3>
          <p class="mt-1 text-sm text-slate-600">Many predators, scarce prey — the prey population is under heavy pressure.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Population cycle over time</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Prey and predator populations vs. time</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:260px;"><canvas id="chart-time"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Phase plot: predator vs. prey population</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:260px;"><canvas id="chart-phase"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};

      function simulate(a, b, c, d, prey0, pred0, steps, dt) {
        let prey = prey0, pred = pred0;
        const preyArr = [prey], predArr = [pred];
        for (let i = 0; i < steps; i++) {
          const dPrey = a * prey - b * prey * pred;
          const dPred = -c * pred + d * prey * pred;
          prey = Math.max(0, prey + dPrey * dt);
          pred = Math.max(0, pred + dPred * dt);
          preyArr.push(prey);
          predArr.push(pred);
        }
        return { preyArr, predArr };
      }

      // ---- calculator ----
      function update() {
        el('pp-err').textContent = '';
        el('r-preyeq').textContent = '—'; el('r-predeq').textContent = '—';
        const a = parseFloat(el('a').value), b = parseFloat(el('b').value), c = parseFloat(el('c').value), d = parseFloat(el('d').value);
        const prey0 = parseFloat(el('prey0').value), pred0 = parseFloat(el('pred0').value);
        if ([a, b, c, d, prey0, pred0].some(isNaN)) return;
        if (a <= 0 || b <= 0 || c <= 0 || d <= 0 || prey0 < 0 || pred0 < 0) { el('pp-err').textContent = 'Rate parameters must be positive; populations cannot be negative.'; return; }
        el('r-preyeq').textContent = fmt(c / d);
        el('r-predeq').textContent = fmt(a / b);
        const { preyArr, predArr } = simulate(a, b, c, d, prey0, pred0, 2000, 0.05);
        updateCharts(preyArr, predArr);
      }
      ['a', 'b', 'c', 'd', 'prey0', 'pred0'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.time = new Chart(el('chart-time'), {
          type: 'line',
          data: { labels: [], datasets: [
            { label: 'Prey', data: [], borderColor: '#10b981', backgroundColor: 'transparent', tension: 0.1, pointRadius: 0 },
            { label: 'Predator', data: [], borderColor: '#ef4444', backgroundColor: 'transparent', tension: 0.1, pointRadius: 0 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time' }, ticks: { maxTicksLimit: 10 } }, y: { title: { display: true, text: 'Population' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.phase = new Chart(el('chart-phase'), {
          type: 'line',
          data: { datasets: [{ label: 'Predator vs. prey', data: [], borderColor: '#6366f1', backgroundColor: 'transparent', showLine: true, pointRadius: 0, tension: 0.1 }] },
          options: Object.assign({}, base, { scales: { x: { type: 'linear', title: { display: true, text: 'Prey population' } }, y: { title: { display: true, text: 'Predator population' } } }, plugins: { legend: { display: false } } }),
        });
      }
      function updateCharts(preyArr, predArr) {
        if (!charts.time) return;
        const sampleEvery = 20;
        const labels = [], preySample = [], predSample = [], phasePoints = [];
        for (let i = 0; i < preyArr.length; i += sampleEvery) {
          labels.push((i * 0.05).toFixed(0));
          preySample.push(+preyArr[i].toFixed(2));
          predSample.push(+predArr[i].toFixed(2));
          phasePoints.push({ x: +preyArr[i].toFixed(2), y: +predArr[i].toFixed(2) });
        }
        charts.time.data.labels = labels;
        charts.time.data.datasets[0].data = preySample;
        charts.time.data.datasets[1].data = predSample;
        charts.time.update('none');
        charts.phase.data.datasets[0].data = phasePoints;
        charts.phase.update('none');
      }

      function popScene(container, preyCount, predCount) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < preyCount; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.14, 10, 8), new THREE.MeshStandardMaterial({ color: 0x10b981 }));
          m.position.set((Math.random() - 0.5) * 4.5, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 2);
          s.scene.add(m);
        }
        for (let i = 0; i < predCount; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.22, 10, 8), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
          m.position.set((Math.random() - 0.5) * 4.5, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 2);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagPreyHeavy = null, diagPredHeavy = null;
      function initDiagPreyHeavy() { const c = el('diag-preyheavy'); if (!c) throw new Error('no container'); diagPreyHeavy = popScene(c, 35, 3); }
      function initDiagPredHeavy() { const c = el('diag-predheavy'); if (!c) throw new Error('no container'); diagPredHeavy = popScene(c, 5, 20); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[predator-prey] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagPreyHeavy(); } catch (e) { console.error('[predator-prey] prey-heavy diagram failed', e); }
          try { initDiagPredHeavy(); } catch (e) { console.error('[predator-prey] predator-heavy diagram failed', e); }
        }
        mountResize([diagPreyHeavy, diagPredHeavy]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
