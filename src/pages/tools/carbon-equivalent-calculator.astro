---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Carbon Equivalent (CE) Calculator';
const description = 'Calculate the carbon equivalent (CE) of a steel alloy from its chemical composition using the IIW formula, to assess weldability and hydrogen-cracking risk.';
const intro = 'Calculate a steel’s carbon equivalent to assess its weldability, from its chemical composition.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'What is carbon equivalent (CE) in welding?', a: 'Carbon equivalent is a single number that combines a steel\'s carbon content with its other alloying elements (manganese, chromium, nickel, etc.) to estimate its overall hardenability and susceptibility to cracking during welding. Higher CE generally means higher risk of weld cracking without preheat or other precautions.' },
  { q: 'What is the IIW carbon equivalent formula?', a: 'The International Institute of Welding formula is CE = C + Mn/6 + (Cr+Mo+V)/5 + (Ni+Cu)/15, using each element\'s weight percentage from the mill certificate or material spec. It is the most widely used CE formula for structural steel.' },
  { q: 'What CE value indicates good weldability?', a: 'As a general guideline, a CE below about 0.40 indicates steel that is readily weldable without special precautions; a CE between 0.40 and 0.60 often needs preheat and controlled cooling; above 0.60 usually requires more careful procedures to avoid hydrogen-induced cracking. These are general guidelines — always follow the applicable welding code (such as AWS D1.1) for actual procedure requirements.' },
  { q: 'Why does carbon equivalent matter for structural welding?', a: 'A high-CE steel is more prone to forming a hard, brittle heat-affected zone during welding, which combined with trapped hydrogen can cause cracking, sometimes hours or days after welding. Knowing the CE helps a welder or engineer decide on preheat temperature and welding procedure before starting work on a given steel.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} structural={true}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="text-sm text-slate-500">Enter each element's weight percentage from the mill certificate (leave at 0 if not present).</p>
    <div class="mt-3 grid gap-4 sm:grid-cols-3 lg:grid-cols-6">
      <label class="block"><span class="text-sm font-medium text-slate-700">C (%)</span>
        <input id="c" type="number" step="any" placeholder="0.20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mn (%)</span>
        <input id="mn" type="number" step="any" placeholder="1.20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Cr (%)</span>
        <input id="cr" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mo (%)</span>
        <input id="mo" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">V (%)</span>
        <input id="v" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Ni + Cu (%)</span>
        <input id="nicu" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Carbon equivalent (CE&#8305;&#8311;&#8306;)</div>
        <div id="r-ce" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="rounded-xl p-3 text-center" id="r-risk-box"><div class="text-sm text-slate-500">Weldability guidance</div><div id="r-risk" class="mt-1 text-lg font-bold">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ce-title ce-desc">
      <title id="ce-title">Carbon equivalent from alloy composition</title>
      <desc id="ce-desc">A steel weld joint with the IIW carbon equivalent formula</desc>
      <rect x="80" y="90" width="90" height="60" fill="#cbd5e1" stroke="#475569" stroke-width="1.5" />
      <rect x="170" y="90" width="90" height="60" fill="#cbd5e1" stroke="#475569" stroke-width="1.5" />
      <path d="M155 95 Q170 80 185 95 Q170 110 155 95" fill="#f97316" stroke="#c2410c" stroke-width="1" />
      <text x="170" y="175" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">weld heat-affected zone</text>
      <rect x="420" y="55" width="330" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">IIW formula</text>
      <text x="440" y="106" font-size="11.5" fill="#475569" font-family="system-ui,sans-serif">CE = C + Mn&frasl;6 + (Cr+Mo+V)&frasl;5</text>
      <text x="440" y="128" font-size="11.5" fill="#475569" font-family="system-ui,sans-serif">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;+ (Ni+Cu)&frasl;15</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Higher CE means a harder, more crack-prone heat-affected zone around the weld.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the carbon equivalent calculator works</h2>
    <p class="mt-2 text-slate-600">
      Carbon equivalent (CE) is a single number that estimates how "hardenable," and therefore how crack-prone during welding, a given steel alloy is, based on its full chemical composition rather than carbon content alone. The most widely used version, published by the International Institute of Welding (IIW), is CE = C + Mn/6 + (Cr+Mo+V)/5 + (Ni+Cu)/15, where each element is entered as its weight percentage from the mill certificate or material specification.
    </p>
    <p class="mt-3 text-slate-600">
      Each alloying element is weighted differently because they don't all affect hardenability equally — manganese has a moderate effect (divided by 6), chromium, molybdenum, and vanadium have a somewhat stronger combined effect (divided by 5), and nickel and copper have the mildest effect (divided by 15). Adding them all to the base carbon content gives one comparable number across very different alloy compositions.
    </p>
    <p class="mt-3 text-slate-600">
      As a general guideline, steel with a CE below about 0.40 is considered readily weldable without special precautions. Between roughly 0.40 and 0.60, preheating the base metal and controlling the cooling rate typically becomes necessary to avoid a hard, brittle zone forming near the weld that can later crack, sometimes hours or days after welding, when combined with trapped hydrogen. Above 0.60, more careful welding procedures are usually required. These are general guidelines only — always follow the specific requirements of your governing welding code, such as AWS D1.1, for actual preheat and procedure decisions.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get the mill cert</h3>
        <p class="mt-1 text-sm text-slate-600">Find the exact element percentages for your steel.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter each element</h3>
        <p class="mt-1 text-sm text-slate-600">Leave any absent element at zero.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check the CE band</h3>
        <p class="mt-1 text-sm text-slate-600">Then confirm preheat needs against your welding code.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">IIW formula</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">CE = C + Mn&frasl;6 + (Cr+Mo+V)&frasl;5 + (Ni+Cu)&frasl;15</span>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Example calc</p>
        <p class="mt-1 text-slate-600">
          C=0.20, Mn=1.20, rest zero: 0.20 + 1.20÷6 = 0.20 + 0.20 = <strong>CE 0.40</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Guidance bands</p>
        <p class="mt-1 text-slate-600">
          &lt;0.40 readily weldable · 0.40-0.60 preheat likely needed · &gt;0.60 careful procedure required.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A low-alloy steel: C=0.30, Mn=1.50, Cr=0.50, Mo=0.20, Ni+Cu=0.30.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">C term:</span> <span class="text-slate-600">0.30</span></div>
        <div><span class="font-medium text-slate-700">Mn/6:</span> <span class="text-slate-600">1.50 ÷ 6 = 0.25</span></div>
        <div><span class="font-medium text-slate-700">(Cr+Mo)/5:</span> <span class="text-slate-600">0.70 ÷ 5 = 0.14</span></div>
        <div><span class="font-medium text-slate-700">CE total:</span> <span class="text-slate-600">0.30+0.25+0.14+0.02 = <strong>0.71</strong> — careful procedure needed</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/welding-amperage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Welding Amperage Calculator</a>
      <a href="/tools/metal-weight-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Metal Weight Calculator</a>
      <a href="/tools/bolt-torque-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Bolt Torque Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const c = parseFloat(el('c').value) || 0;
      const mn = parseFloat(el('mn').value) || 0;
      const cr = parseFloat(el('cr').value) || 0;
      const mo = parseFloat(el('mo').value) || 0;
      const v = parseFloat(el('v').value) || 0;
      const nicu = parseFloat(el('nicu').value) || 0;
      if (!(c > 0)) { el('results').classList.add('hidden'); return; }

      const ce = c + mn / 6 + (cr + mo + v) / 5 + nicu / 15;

      let risk, cls, boxCls;
      if (ce < 0.40) { risk = '✓ readily weldable'; cls = 'text-green-600'; boxCls = 'bg-green-50'; }
      else if (ce <= 0.60) { risk = '⚠ preheat likely needed'; cls = 'text-amber-600'; boxCls = 'bg-amber-50'; }
      else { risk = '✗ careful procedure required'; cls = 'text-red-600'; boxCls = 'bg-red-50'; }

      el('r-ce').textContent = ce.toFixed(3);
      el('r-note').textContent = 'IIW formula, weight % basis';
      el('r-risk').textContent = risk;
      el('r-risk').className = 'mt-1 text-lg font-bold ' + cls;
      el('r-risk-box').className = 'rounded-xl p-3 text-center ' + boxCls;
      el('results').classList.remove('hidden');
    }

    ['c', 'mn', 'cr', 'mo', 'v', 'nicu'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
