    ];

    function awgToDia(awg) {
      return 0.127 * Math.pow(92, (36 - awg) / 39);
    }

    function nearestAwg(diaMm) {
      let best = LOOKUP[0];
      let bestDiff = Math.abs(best.dia - diaMm);
      for (let i = 1; i < LOOKUP.length; i++) {
        const diff = Math.abs(LOOKUP[i].dia - diaMm);
        if (diff < bestDiff) {
          bestDiff = diff;
          best = LOOKUP[i];
        }
      }
      return best;
    }

    function getDisplayAwg(num) {
      if (num === -4) return '4/0 (0000)';
      if (num === -3) return '3/0 (000)';
      if (num === -2) return '2/0 (00)';
      if (num === -1) return '1/0 (0)';
      return num;
    }

    function setDirection(dir) {
      direction = dir;
      const btnAwgMm = el('dir-awg-mm');
      const btnMmAwg = el('dir-mm-awg');
      const inputLabel = el('input-label');
      const input = el('input');

      if (dir === 'awg-mm') {
        btnAwgMm.className = 'flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm';
        btnMmAwg.className = 'flex-1 rounded-lg py-2 text-slate-500';
        inputLabel.textContent = 'AWG number';
        input.placeholder = 'e.g. 12';
      } else {
        btnMmAwg.className = 'flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm';
        btnAwgMm.className = 'flex-1 rounded-lg py-2 text-slate-500';
        inputLabel.textContent = 'Diameter (mm)';
        input.placeholder = 'e.g. 2.05';
      }
      input.value = '';
      el('r-dia').textContent = '\u2014';
      el('r-area').textContent = '\u2014';
      el('r-label').classList.add('hidden');
      el('r-error').classList.add('hidden');
    }

    function convert() {
      const raw = el('input').value.trim();
      const errorEl = el('r-error');
      const labelEl = el('r-label');
      const diaEl = el('r-dia');
      const areaEl = el('r-area');

      errorEl.classList.add('hidden');
      labelEl.classList.add('hidden');

      if (raw === '') {
        diaEl.textContent = '\u2014';
        areaEl.textContent = '\u2014';
        return;
      }

      if (direction === 'awg-mm') {
        const awg = parseFloat(raw);
        if (isNaN(awg) || awg < -4 || awg > 40) {
          diaEl.textContent = '\u2014';
          areaEl.textContent = '\u2014';
          errorEl.textContent = 'Enter an AWG number between -4 (4/0) and 40.';
          errorEl.classList.remove('hidden');
          return;
        }
        const dia = awgToDia(awg);
        const area = Math.PI * Math.pow(dia / 2, 2);
        diaEl.textContent = dia.toFixed(3) + ' mm';
        areaEl.textContent = area.toFixed(2) + ' mm\u00b2';
        labelEl.textContent = 'AWG ' + getDisplayAwg(awg);
        labelEl.classList.remove('hidden');
      } else {
        const diaMm = parseFloat(raw);
        if (isNaN(diaMm) || diaMm <= 0) {
          diaEl.textContent = '\u2014';
          areaEl.textContent = '\u2014';
          errorEl.textContent = 'Enter a positive diameter in millimetres.';
          errorEl.classList.remove('hidden');
          return;
        }
        const area = Math.PI * Math.pow(diaMm / 2, 2);
        const nearest = nearestAwg(diaMm);
        diaEl.textContent = '(' + nearest.dia.toFixed(3) + ' mm closest)';
        areaEl.textContent = area.toFixed(2) + ' mm\u00b2';
        labelEl.textContent = 'Nearest AWG: ' + getDisplayAwg(nearest.num) + ' (d = ' + nearest.dia.toFixed(3) + ' mm)';
        labelEl.classList.remove('hidden');
      }
    }

    el('dir-awg-mm').addEventListener('click', () => setDirection('awg-mm'));
    el('dir-mm-awg').addEventListener('click', () => setDirection('mm-awg'));
    el('input').addEventListener('input', convert);
  </script>
</ToolLayout>
