---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Kinetic Energy Calculator';
const description = 'Kinetic energy calculator with a live 3D diagram and charts. Solve KE = ½mv² for kinetic energy, mass, or velocity, with worked examples and a crash-energy comparison table.';
const intro = 'Enter any two of kinetic energy, mass, or velocity to solve for the third using KE = ½mv². Two 3D diagrams compare a slow and a fast-moving object of the same mass, and charts show how kinetic energy grows with mass and with the square of velocity.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is kinetic energy?', a: 'Kinetic energy (KE) is the energy an object possesses due to its motion. The formula is KE = ½mv², where m is mass and v is velocity. The SI unit is the joule (J).' },
  { q: 'Why is velocity squared in the formula?', a: 'Kinetic energy depends on the square of velocity because energy is proportional to the distance over which a force must act to stop the object. Doubling velocity requires four times the stopping distance, so it takes four times the energy.' },
  { q: 'What is the difference between kinetic and potential energy?', a: 'Kinetic energy is energy of motion. Potential energy is stored energy due to position (gravitational), deformation (elastic), or configuration (chemical). Together they make up an object\'s total mechanical energy.' },
  { q: 'Can kinetic energy ever be negative?', a: 'No. Since mass is always positive and velocity squared is always non-negative, KE = ½mv² is always zero or positive. Negative kinetic energy has no physical meaning.' },
  { q: 'How does kinetic energy relate to work?', a: 'The work-energy theorem states that the net work done on an object equals its change in kinetic energy: W = ΔKE. This is a foundational bridge connecting forces to energy changes.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Kinetic Energy Calculator',
  description: 'Solve KE = ½mv² for kinetic energy, mass, or velocity from any two known values.',
  steps: [
    { name: 'Enter any two values', text: 'Provide kinetic energy, mass, or velocity — leave the third blank.' },
    { name: 'Read the result', text: 'The missing value solves instantly using KE = ½mv².' },
    { name: 'Compare on the chart', text: 'See how energy scales linearly with mass but quadratically with velocity.' },
  ],
};

const formulas = [
  { expr: 'KE = ½mv²', note: 'kinetic energy — m in kg, v in m/s, KE in joules' },
  { expr: 'v = √(2·KE/m)', note: 'rearranged to solve for velocity' },
  { expr: 'm = 2·KE/v²', note: 'rearranged to solve for mass' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a car at highway speed', tone: 'slate',
    given: 'A 1200 kg car travels at 25 m/s (90 km/h). Find its kinetic energy.',
    rows: [
      { label: 'Formula:', value: 'KE = ½mv²' },
      { label: 'Substitute:', value: 'KE = 0.5 × 1200 × 25² = 600 × 625' },
      { label: 'Result:', value: 'KE = 375,000 J = 375 kJ', full: true },
    ],
    note: 'This is enough energy to lift the same car about 32 metres straight up — a useful way to grasp how much energy a moving vehicle really carries.',
  },
  {
    title: 'Worked example 2 — doubling speed quadruples energy', tone: 'amber',
    given: 'The same 1200 kg car now travels at 50 m/s (double the speed). Find the new kinetic energy.',
    rows: [
      { label: 'Formula:', value: 'KE = ½mv²' },
      { label: 'Substitute:', value: 'KE = 0.5 × 1200 × 50² = 600 × 2500' },
      { label: 'Result:', value: 'KE = 1,500,000 J = 1500 kJ — exactly 4× the original energy', full: true },
    ],
    note: 'Doubling velocity quadruples kinetic energy because v is squared — this is exactly why crash severity increases so sharply with speed, not proportionally.',
  },
];

const comparison = {
  heading: 'How kinetic energy scales with speed (fixed 1200 kg car)',
  note: 'Mass stays fixed here — notice how energy grows with the square of speed, not in a straight line.',
  headers: [{ label: 'Speed' }, { label: 'Speed (m/s)' }, { label: 'Kinetic energy' }],
  rows: [
    ['20 km/h', '5.56', '18.5 kJ'],
    ['50 km/h', '13.9', '115.7 kJ'],
    ['90 km/h ★', '25.0', '375.0 kJ'],
    ['120 km/h', '33.3', '666.7 kJ'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). Going from 50 km/h to 90 km/h (1.8× the speed) more than triples the energy — the quadratic relationship in action.',
};

const realWorld = [
  { emoji: '🚗', title: 'Automotive crash safety', body: 'Crumple zones and airbags are engineered around exactly how much kinetic energy a vehicle carries at typical crash speeds — since that energy has to go somewhere, absorbing it safely is the entire goal of crash design.' },
  { emoji: '⚙️', title: 'Rotating machinery design', body: 'Flywheels, turbines, and robotic arms all carry kinetic energy tied to their speed — engineers use KE = ½mv² (or its rotational analogue) to specify safe operating speeds and braking requirements.' },
  { emoji: '🏃', title: 'Sports equipment and athlete safety', body: 'A thrown ball, a swung bat, or a sprinting athlete all carry kinetic energy that helmet and pad designers must account for when engineering protective equipment.' },
  { emoji: '🔬', title: 'Particle physics and ballistics', body: 'From particle accelerators to projectile motion, kinetic energy calculations underpin how physicists predict the outcome of high-speed collisions and impacts.' },
];

const misconceptions = [
  { claim: '"Doubling an object\'s speed doubles its kinetic energy."', truth: 'Because velocity is squared in the formula, doubling speed actually quadruples kinetic energy — this is why small increases in speed limits produce disproportionately severe crash outcomes.' },
  { claim: '"A heavier object always has more kinetic energy than a lighter one."', truth: 'Only if they move at the same speed — mass enters the formula linearly while velocity enters squared, so a light, fast object can easily carry more kinetic energy than a heavy, slow one.' },
  { claim: '"Kinetic energy and momentum are the same quantity."', truth: 'They are related but different: momentum (p = mv) scales linearly with velocity, while kinetic energy (KE = ½mv²) scales with velocity squared — two objects can have equal momentum but very different kinetic energies.' },
  { claim: '"An object at rest can still have kinetic energy if it has potential energy."', truth: 'Kinetic energy strictly requires motion (v > 0) — an object at rest has zero kinetic energy regardless of how much potential energy it stores.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 7, "Work and Kinetic Energy" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/7-1-work" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 7, Kinetic Energy and Work.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 7, Energy of a System.' },
];
const sourcesNote = 'KE = ½mv², m in kg, v in m/s, KE in joules. Results are rounded for display.';

const howToUse = [
  { title: 'Enter any two values', body: 'Provide kinetic energy, mass, or velocity — leave the unknown field blank.' },
  { title: 'Read the result', body: 'The missing value solves instantly, cross-checked using the same formula.' },
  { title: 'Compare on the chart', body: 'See the linear mass relationship versus the quadratic velocity relationship side by side.' },
];

const related = [
  { href: '/tools/potential-energy-calculator', emoji: '📈', title: 'Gravitational Potential Energy Calculator', desc: 'PE = mgh — solve for any variable.' },
  { href: '/tools/work-calculator', emoji: '🔧', title: 'Work Calculator', desc: 'W = Fd cos(θ) — work done by a force at any angle.' },
  { href: '/tools/momentum-calculator', emoji: '🎯', title: 'Momentum & Impulse Calculator', desc: 'p=mv plus impulse calculations.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="kinetic energy grows linearly with mass but quadratically with speed, so a small increase in velocity has a far bigger effect on an object's energy than the same relative increase in mass."
  howIntro="KE = ½mv² comes directly from integrating the work done by a net force accelerating an object from rest: W = ∫F dx = ∫ma dx, which works out to exactly ½mv² using the kinematic relationship v² = 2ax. Because v is squared, doubling speed doesn't just double the stopping distance needed to remove that energy — it quadruples it, which is the physical reason high-speed impacts are so much more destructive than their speed alone might suggest."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where kinetic energy actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Enter any two values, leave the third blank.</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Kinetic energy (KE)</span>
        <input id="ke" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mass" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Velocity (v)</span>
        <input id="vel" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Kinetic energy</div><div id="r-ke" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-mass" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Velocity</div><div id="r-vel" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="ke-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Same mass, different speed</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-slow" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Slow-moving object (short arrow)</h3>
          <p class="mt-1 text-sm text-slate-600">A shorter velocity arrow means far less kinetic energy — even though the mass is identical to the object on the right.</p>
        </div>
        <div>
          <div id="diag-fast" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Fast-moving object (long arrow)</h3>
          <p class="mt-1 text-sm text-slate-600">Twice the speed here means four times the kinetic energy of the object on the left — the squared relationship visualized.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Kinetic energy graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">KE vs mass (fixed v=25 m/s) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mass"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">KE vs velocity (fixed m=1200 kg) — a quadratic curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vel"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator (preserves original two-of-three solve logic) ----
      function update() {
        const ke = parseFloat(el('ke').value);
        const m = parseFloat(el('mass').value);
        const v = parseFloat(el('vel').value);
        const filled = [!isNaN(ke), !isNaN(m), !isNaN(v)];
        const count = filled.filter(Boolean).length;
        el('ke-err').textContent = '';
        ['r-ke', 'r-mass', 'r-vel'].forEach((id) => (el(id).textContent = '—'));
        if (count < 2) return;
        let rke = NaN, rm = NaN, rv = NaN;
        if (filled[0] && filled[1]) {
          if (ke < 0 || m < 0) { el('ke-err').textContent = 'Mass and KE cannot be negative.'; return; }
          rv = Math.sqrt((2 * ke) / m); rke = ke; rm = m;
        } else if (filled[0] && filled[2]) {
          if (ke < 0) { el('ke-err').textContent = 'KE cannot be negative.'; return; }
          rm = (2 * ke) / (v * v); rke = ke; rv = v;
        } else if (filled[1] && filled[2]) {
          if (m < 0) { el('ke-err').textContent = 'Mass cannot be negative.'; return; }
          rke = 0.5 * m * v * v; rm = m; rv = v;
        }
        if (!isNaN(rke)) el('r-ke').textContent = fmt(rke) + ' J';
        if (!isNaN(rm)) el('r-mass').textContent = fmt(rm) + ' kg';
        if (!isNaN(rv)) el('r-vel').textContent = fmt(rv) + ' m/s';
      }
      ['ke', 'mass', 'vel'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsM = [], dataM = [];
        for (let m = 200; m <= 2000; m += 200) { labelsM.push(m); dataM.push(+(0.5 * m * 25 * 25 / 1000).toFixed(1)); }
        charts.mass = new Chart(el('chart-mass'), {
          type: 'line',
          data: { labels: labelsM, datasets: [{ label: 'KE (kJ)', data: dataM, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Mass (kg)' } }, y: { title: { display: true, text: 'Kinetic energy (kJ)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsV = [], dataV = [];
        for (let v = 0; v <= 40; v += 4) { labelsV.push(v); dataV.push(+(0.5 * 1200 * v * v / 1000).toFixed(1)); }
        charts.vel = new Chart(el('chart-vel'), {
          type: 'line',
          data: { labels: labelsV, datasets: [{ label: 'KE (kJ)', data: dataV, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.35, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Velocity (m/s)' } }, y: { title: { display: true, text: 'Kinetic energy (kJ)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function speedScene(container, speedLen) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const obj = new THREE.Mesh(new THREE.BoxGeometry(1, 1, 1), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.4 }));
        s.scene.add(obj);
        s.scene.add(arrow(new THREE.Vector3(0.6, 0, 0), new THREE.Vector3(0.6 + speedLen, 0, 0), 0xf59e0b));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSlow = null, diagFast = null;
      function initDiagSlow() { const c = el('diag-slow'); if (!c) throw new Error('no container'); diagSlow = speedScene(c, 1.2); }
      function initDiagFast() { const c = el('diag-fast'); if (!c) throw new Error('no container'); diagFast = speedScene(c, 2.4); }

      function boot() {
        try { update(); } catch (e) { console.error('[kinetic-energy] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[kinetic-energy] charts failed', e); }
        if (window.THREE) {
          try { initDiagSlow(); } catch (e) { console.error('[kinetic-energy] slow diagram failed', e); }
          try { initDiagFast(); } catch (e) { console.error('[kinetic-energy] fast diagram failed', e); }
        }
        mountResize([diagSlow, diagFast]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
