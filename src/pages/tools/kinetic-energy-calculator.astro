---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Kinetic Energy Calculator';
const description = 'Free online kinetic energy calculator. Solve for kinetic energy, mass, or velocity using KE = ½mv². Works with SI and imperial units.';
const intro = 'Enter any two values — kinetic energy, mass, or velocity — to solve for the third.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is kinetic energy?', a: 'Kinetic energy (KE) is the energy an object possesses due to its motion. The formula is KE = ½mv², where m is mass and v is velocity. The SI unit is the joule (J).' },
  { q: 'Why is velocity squared in the formula?', a: 'Kinetic energy depends on the square of velocity because energy is proportional to the distance over which a force must act to stop the object. Doubling velocity requires four times the stopping distance.' },
  { q: 'What is the difference between kinetic and potential energy?', a: 'Kinetic energy is energy of motion. Potential energy is stored energy due to position (gravitational), deformation (elastic), or configuration (chemical). Together they make up mechanical energy.' },
  { q: 'Can kinetic energy ever be negative?', a: 'No. Since mass is always positive and velocity squared is always non-negative, KE = ½mv² is always zero or positive. Negative kinetic energy has no physical meaning.' },
  { q: 'How does kinetic energy relate to work?', a: 'The work-energy theorem states that the net work done on an object equals its change in kinetic energy: W = ΔKE. This is a foundational concept in physics connecting forces to energy changes.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values, leave the third blank</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Kinetic Energy (KE)</span>
        <input id="ke" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="mass" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Velocity (v)</span>
        <input id="vel" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="ke-result" class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Kinetic Energy</div><div id="r-ke" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-mass" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Velocity</div><div id="r-vel" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="ke-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ke-title ke-desc">
      <title id="ke-title">Moving object with kinetic energy bar chart</title>
      <desc id="ke-desc">An object moving to the right at velocity v, with an energy bar showing kinetic energy in joules</desc>
      <g transform="translate(30,20)">
        <rect x="100" y="120" width="180" height="110" rx="12" fill="#eef2ff" stroke="#6366f1" stroke-width="2.5"/>
        <text x="190" y="180" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">Object</text>
        <text x="190" y="200" text-anchor="middle" fill="#64748b" font-size="14">m = ?</text>
        <path d="M 60 165 L 100 165" stroke="#ef4444" stroke-width="3" stroke-linecap="round"/>
        <polygon points="60,155 45,165 60,175" fill="#ef4444"/>
        <text x="30" y="162" fill="#ef4444" font-size="16" font-weight="bold">v</text>
        <rect x="420" y="60" width="60" height="24" rx="4" fill="#fef3c7"/>
        <text x="450" y="77" text-anchor="middle" fill="#d97706" font-size="12" font-weight="bold">KE</text>
        <rect x="420" y="80" width="180" height="60" rx="6" fill="#eef2ff" stroke="#6366f1" stroke-width="2"/>
        <rect x="425" y="85" width="170" height="50" rx="4" fill="#6366f1" opacity="0.7"/>
        <text x="510" y="115" text-anchor="middle" fill="white" font-size="14" font-weight="bold">Energy</text>
        <text x="640" y="100" fill="#64748b" font-size="13">Speed ↑ means</text>
        <text x="640" y="118" fill="#64748b" font-size="13">KE ↑ by v²</text>
        <text x="300" y="260" text-anchor="middle" fill="#4338ca" font-size="20" font-weight="bold">KE = ½ × m × v²</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">A moving object with mass m and velocity v possesses kinetic energy proportional to ½mv²</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How kinetic energy is calculated</h2>
    <p class="mt-2 text-slate-600">Kinetic energy is the energy of motion. The formula <span class="font-mono">KE = ½ × m × v²</span> shows that energy increases linearly with mass but quadratically with velocity. Doubling the mass doubles the kinetic energy, but doubling the velocity quadruples it. This is why high-speed collisions are so destructive — the energy available to cause damage grows rapidly with speed. The formula can be rearranged to solve for mass or velocity when the other two are known.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 1200 kg car is travelling at 25 m/s (90 km/h). What is its kinetic energy?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Mass:</span> <span class="text-slate-600">1200 kg</span></div>
        <div><span class="font-medium text-slate-700">Velocity:</span> <span class="text-slate-600">25 m/s</span></div>
        <div><span class="font-medium text-slate-700">KE:</span> <span class="text-slate-600">½ × 1200 × 25² = 600 × 625 = 375,000 J</span></div>
        <div><span class="font-medium text-slate-700">In context:</span> <span class="text-slate-600">375 kJ — enough to lift the car about 32 m</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F697;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Automotive Safety Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the kinetic energy involved in vehicle collisions at various speeds. This informs crumple zone design, airbag deployment parameters, and structural reinforcement requirements.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4A1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Machine Designer</h3>
      <p class="mt-1 text-sm text-slate-600">Determine the kinetic energy of rotating components like flywheels, turbines, and robotic arms. Use the results to specify safe operating speeds and emergency braking systems.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3C3;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sports Equipment Designer</h3>
      <p class="mt-1 text-sm text-slate-600">Analyse the kinetic energy of balls, projectiles, and athletes to design safer equipment. A golf ball and a tennis ball have very different energies at their typical speeds.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F52C;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Physics Researcher</h3>
      <p class="mt-1 text-sm text-slate-600">Use the kinetic energy formula in particle physics, ballistics analysis, and energy conservation problems. The calculator provides quick verification of experimental data.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the kinetic energy calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter two values</h3>
        <p class="mt-1 text-sm text-slate-600">Type kinetic energy, mass, or velocity in the fields. Use SI units (J, kg, m/s) for best results. Leave the unknown field blank.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Instant update</h3>
        <p class="mt-1 text-sm text-slate-600">The missing value is computed and displayed immediately. The primary result box highlights the solved variable with a purple background.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Handles edge cases</h3>
        <p class="mt-1 text-sm text-slate-600">Negative values or impossible combinations are caught and explained. The calculator prevents division by zero and invalid square roots.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for kinetic energy calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Velocity is squared — small changes matter</h3>
        <p class="mt-1 text-sm text-slate-600">Since v² appears in the formula, a 10% increase in velocity results in a 21% increase in kinetic energy. This is why speed limits have such a significant impact on crash severity.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Energy conservation</h3>
        <p class="mt-1 text-sm text-slate-600">In the absence of friction, an object's total mechanical energy (KE + PE) stays constant. A falling object converts potential energy to kinetic energy: mgh → ½mv². Use this to find velocity from height.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Rotational kinetic energy</h3>
        <p class="mt-1 text-sm text-slate-600">Spinning objects also have kinetic energy: KE<sub>rot</sub> = ½Iω², where I is moment of inertia and ω is angular velocity. This calculator handles linear motion only.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/potential-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4C8;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Potential Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">PE = mgh — gravitational potential energy.</p>
      </a>
      <a href="/tools/force-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4A5;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Force Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">F = ma — solve for any variable.</p>
      </a>
      <a href="/tools/work-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F527;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Work Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Work done by force at any angle.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });
    function update() {
      const ke = parseFloat(el('ke').value);
      const m = parseFloat(el('mass').value);
      const v = parseFloat(el('vel').value);
      const filled = [!isNaN(ke), !isNaN(m), !isNaN(v)];
      const count = filled.filter(Boolean).length;
      el('ke-err').textContent = '';
      ['r-ke', 'r-mass', 'r-vel'].forEach(id => el(id).textContent = '—');
      if (count < 2) return;
      let rke = NaN, rm = NaN, rv = NaN;
      if (filled[0] && filled[1]) { if (ke < 0 || m < 0) { el('ke-err').textContent = 'Mass and KE cannot be negative.'; return; } rv = Math.sqrt(2 * ke / m); rke = ke; rm = m; }
      else if (filled[0] && filled[2]) { if (ke < 0) { el('ke-err').textContent = 'KE cannot be negative.'; return; } rm = 2 * ke / (v * v); rke = ke; rv = v; }
      else if (filled[1] && filled[2]) { if (m < 0) { el('ke-err').textContent = 'Mass cannot be negative.'; return; } rke = 0.5 * m * v * v; rm = m; rv = v; }
      if (!isNaN(rke)) el('r-ke').textContent = fmt(rke);
      if (!isNaN(rm)) el('r-mass').textContent = fmt(rm);
      if (!isNaN(rv)) el('r-vel').textContent = fmt(rv);
    }
    ['ke', 'mass', 'vel'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
