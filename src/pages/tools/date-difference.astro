---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Date Difference Calculator';
const description =
  'Free date difference calculator. Find the number of days, weeks, months and years ' +
  'between any two dates. Works for past and future dates, right in your browser.';
const intro =
  'Pick a start date and an end date to see exactly how much time is between them — in days, weeks, months and years.';
const category = { id: 'everyday', name: 'Everyday' };
const faqs = [
  { q: 'Does it count the end day?', a: 'By default we count the gap between the two dates. Tick "Include end day" to count both the start and end dates.' },
  { q: 'Can I use future dates?', a: 'Yes — use it to count down to an event, a deadline, a holiday or a due date.' },
  { q: 'How are months and years calculated?', a: 'Years and months use real calendar dates, so months of different lengths and leap years are handled correctly.' },
  { q: 'Is my data private?', a: 'Yes. Everything is calculated in your browser; no dates are uploaded.' },
  { q: 'Does it matter if the start date is after the end date?', a: 'No — the calculator automatically swaps them so you always get a positive result.' },
  { q: 'How many days are in a month for this calculation?', a: 'It uses real calendar dates, so February has 28 or 29 days in a leap year, and longer months like January have 31 days.' },
  { q: 'Can I calculate business days only?', a: 'Not yet, but the total days give you a solid starting point for your planning.' },
  { q: 'What is the maximum date range supported?', a: 'The calculator works for any dates between year 1 and 9999, so even historical or far-future dates are handled.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Start date</span>
        <input id="start" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">End date</span>
        <input id="end" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>

    <label class="mt-3 flex items-center gap-2 text-sm text-slate-600">
      <input id="include-end" type="checkbox" class="h-4 w-4 rounded border-slate-300" />
      Include the end day in the count
    </label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total difference</div>
        <div id="main-days" class="mt-1 text-2xl font-bold sm:text-3xl">—</div>
      </div>
      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="d-ymd" class="text-base font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Y / M / D</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="d-weeks" class="text-lg font-bold text-slate-800">0</div><div class="text-xs text-slate-500">Weeks</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="d-months" class="text-lg font-bold text-slate-800">0</div><div class="text-xs text-slate-500">Months</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="d-hours" class="text-lg font-bold text-slate-800">0</div><div class="text-xs text-slate-500">Hours</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Pick both dates to see the difference.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why date difference matters</h2>
    <p class="mt-2 text-slate-600">
      From project deadlines to lease agreements, from pregnancy due dates to retirement planning — the gap between two dates is one of the most common real-world calculations. Counting manually is tedious and error-prone with varying month lengths and leap years. This calculator gives you the exact difference in multiple units at a glance.
    </p>

    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Project deadline</span><span class="text-slate-400">14–90 days</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Rental / lease period</span><span class="text-slate-400">6–12 months</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:45%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Pregnancy term</span><span class="text-slate-400">~280 days (40 weeks)</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:60%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Visa / passport validity</span><span class="text-slate-400">5–10 years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:75%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Mortgage term</span><span class="text-slate-400">15–30 years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-violet-500" style="width:100%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📅</span>
      <h3 class="mt-2 font-semibold text-slate-900">Event Planning</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate days until a wedding, holiday, birthday or concert. Know exactly how much preparation time you have left.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💼</span>
      <h3 class="mt-2 font-semibold text-slate-900">Work & Projects</h3>
      <p class="mt-1 text-sm text-slate-600">Measure project duration, notice periods, contract terms and billing cycles. Essential for freelancers and managers.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">⚖️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Legal & Compliance</h3>
      <p class="mt-1 text-sm text-slate-600">Count exact days for visa stays, legal notice periods, warranty coverage, and statutory waiting periods.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏥</span>
      <h3 class="mt-2 font-semibold text-slate-900">Health & Medical</h3>
      <p class="mt-1 text-sm text-slate-600">Track pregnancy weeks, medication duration, recovery periods, and follow-up appointment intervals.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the date difference calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick start date</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the beginning of the period you want to measure.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick end date</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the end date. The calculator works in either direction.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the breakdown</h3>
        <p class="mt-1 text-sm text-slate-600">See the gap in days, weeks, months, years and hours — all updated instantly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for date calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Inclusive vs exclusive counting</h3>
        <p class="mt-1 text-sm text-slate-600">A "3 day" period from Monday to Thursday can mean 3 or 4 days depending on whether you count both start and end. Tick "Include end day" for inclusive counts.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Leap year awareness</h3>
        <p class="mt-1 text-sm text-slate-600">February 29 exists in leap years. The calculator handles this automatically, so you don't need to worry about "one extra day" every 4 years.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Month boundaries</h3>
        <p class="mt-1 text-sm text-slate-600">Dates near month boundaries can be tricky. The calculators year/month/day breakdown shows the actual calendar difference, not just round numbers.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const start = document.getElementById('start');
    const end = document.getElementById('end');
    const includeEnd = document.getElementById('include-end');
    const result = document.getElementById('result');
    const hint = document.getElementById('hint');
    const el = (id) => document.getElementById(id);

    end.value = new Date().toISOString().slice(0, 10);

    function diffYMD(from, to) {
      let y = to.getFullYear() - from.getFullYear();
      let m = to.getMonth() - from.getMonth();
      let d = to.getDate() - from.getDate();
      if (d < 0) { m--; d += new Date(to.getFullYear(), to.getMonth(), 0).getDate(); }
      if (m < 0) { y--; m += 12; }
      return { y, m, d };
    }

    function update() {
      if (!start.value || !end.value) return;
      let from = new Date(start.value);
      let to = new Date(end.value);
      if (to < from) { [from, to] = [to, from]; }

      let totalDays = Math.round((to - from) / 86400000);
      if (includeEnd.checked) totalDays += 1;

      const { y, m, d } = diffYMD(from, to);
      el('main-days').textContent = `${totalDays.toLocaleString()} day${totalDays === 1 ? '' : 's'}`;
      el('d-ymd').textContent = `${y}y ${m}m ${d}d`;
      el('d-weeks').textContent = `${Math.floor(totalDays / 7)}w ${totalDays % 7}d`;
      el('d-months').textContent = (y * 12 + m).toLocaleString();
      el('d-hours').textContent = (totalDays * 24).toLocaleString();

      result.classList.remove('hidden');
      hint.classList.add('hidden');
    }

    [start, end, includeEnd].forEach((e) => e.addEventListener('change', update));
  </script>
</ToolLayout>
