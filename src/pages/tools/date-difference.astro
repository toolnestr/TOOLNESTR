---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Date Difference Calculator';
const description =
  'Free date difference calculator. Find the number of days, weeks, months and years ' +
  'between any two dates. Works for past and future dates, right in your browser.';
const intro =
  'Pick a start date and an end date to see exactly how much time is between them — in days, weeks, months and years.';
const category = { id: 'everyday', name: 'Everyday' };
const faqs = [
  { q: 'Does it count the end day?', a: 'By default we count the gap between the two dates. Tick "Include end day" to count both the start and end dates.' },
  { q: 'Can I use future dates?', a: 'Yes — use it to count down to an event, a deadline, a holiday or a due date.' },
  { q: 'How are months and years calculated?', a: 'Years and months use real calendar dates, so months of different lengths and leap years are handled correctly.' },
  { q: 'Is my data private?', a: 'Yes. Everything is calculated in your browser; no dates are uploaded.' },
  { q: 'Does it matter if the start date is after the end date?', a: 'No — the calculator automatically swaps them so you always get a positive result.' },
  { q: 'How many days are in a month for this calculation?', a: 'It uses real calendar dates, so February has 28 or 29 days in a leap year, and longer months like January have 31 days.' },
  { q: 'Can I calculate business days only?', a: 'Not yet, but the total days give you a solid starting point for your planning.' },
  { q: 'What is the maximum date range supported?', a: 'The calculator works for any dates between year 1 and 9999, so even historical or far-future dates are handled.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Start date</span>
        <input id="start" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">End date</span>
        <input id="end" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>

    <label class="mt-3 flex items-center gap-2 text-sm text-slate-600">
      <input id="include-end" type="checkbox" class="h-4 w-4 rounded border-slate-300" />
      Include the end day in the count
    </label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total difference</div>
        <div id="main-days" class="mt-1 text-2xl font-bold sm:text-3xl">—</div>
      </div>
      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="d-ymd" class="text-base font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Y / M / D</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="d-weeks" class="text-lg font-bold text-slate-800">0</div><div class="text-xs text-slate-500">Weeks</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="d-months" class="text-lg font-bold text-slate-800">0</div><div class="text-xs text-slate-500">Months</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="d-hours" class="text-lg font-bold text-slate-800">0</div><div class="text-xs text-slate-500">Hours</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Pick both dates to see the difference.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How date difference is calculated</h2>
    <p class="mt-2 text-slate-600">
      The date difference is computed using a three-step process. First, the raw milliseconds between the two dates are converted to total days (86,400,000 ms per day). Second, a calendar-aware algorithm decomposes the span into years, months and remaining days by comparing year, month and day components. Third, total weeks, months and hours are derived from the day count.
    </p>
    <p class="mt-3 text-slate-600">
      The year/month/day breakdown follows the same logic as our age calculator: <code>years = endYear - startYear</code>, then adjust for month and day offsets. This ensures that a date range spanning, say, 31 January to 1 March correctly reports 1 month and 1 day (or 29 days in a non-leap year), not a misleading fractional result.
    </p>

    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Start: <strong>1 January 2026</strong> &nbsp;|&nbsp; End: <strong>25 June 2026</strong></p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Exact breakdown:</span> <span class="text-slate-600">0 years, 5 months, 24 days</span></div>
        <div><span class="font-medium text-slate-700">Total days:</span> <span class="text-slate-600">175</span></div>
        <div><span class="font-medium text-slate-700">Weeks + days:</span> <span class="text-slate-600">25 weeks, 0 days</span></div>
        <div><span class="font-medium text-slate-700">Total months:</span> <span class="text-slate-600">5</span></div>
        <div><span class="font-medium text-slate-700">Total hours:</span> <span class="text-slate-600">4,200</span></div>
        <div><span class="font-medium text-slate-700">With end day included:</span> <span class="text-slate-600">176 days</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why date difference matters</h2>
    <p class="mt-2 text-slate-600">
      From project deadlines to lease agreements, from pregnancy due dates to retirement planning — the gap between two dates is one of the most common real-world calculations. Counting manually is tedious and error-prone with varying month lengths and leap years. This calculator gives you the exact difference in multiple units at a glance.
    </p>

    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Project deadline</span><span class="text-slate-400">14–90 days</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Rental / lease period</span><span class="text-slate-400">6–12 months</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:45%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Pregnancy term</span><span class="text-slate-400">~280 days (40 weeks)</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:60%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Visa / passport validity</span><span class="text-slate-400">5–10 years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:75%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Mortgage term</span><span class="text-slate-400">15–30 years</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-violet-500" style="width:100%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📅</span>
      <h3 class="mt-2 font-semibold text-slate-900">Event Planning</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate days until a wedding, holiday, birthday or concert. Know exactly how much preparation time you have left.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💼</span>
      <h3 class="mt-2 font-semibold text-slate-900">Work & Projects</h3>
      <p class="mt-1 text-sm text-slate-600">Measure project duration, notice periods, contract terms and billing cycles. Essential for freelancers and managers.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">⚖️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Legal & Compliance</h3>
      <p class="mt-1 text-sm text-slate-600">Count exact days for visa stays, legal notice periods, warranty coverage, and statutory waiting periods.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏥</span>
      <h3 class="mt-2 font-semibold text-slate-900">Health & Medical</h3>
      <p class="mt-1 text-sm text-slate-600">Track pregnancy weeks, medication duration, recovery periods, and follow-up appointment intervals.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common date scenarios at a glance</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-sm">
        <thead><tr class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500"><th class="px-4 py-3">Scenario</th><th class="px-4 py-3">Typical span</th><th class="px-4 py-3">Common use</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <tr><td class="px-4 py-3 font-medium text-slate-900">Sprint / iteration</td><td class="px-4 py-3 text-slate-700">10–14 days</td><td class="px-4 py-3 text-slate-500">Agile software development cycles</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Notice period</td><td class="px-4 py-3 text-slate-700">30–90 days</td><td class="px-4 py-3 text-slate-500">Employment contract termination</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Visa-free stay</td><td class="px-4 py-3 text-slate-700">30–90 days</td><td class="px-4 py-3 text-slate-500">Tourist entry allowance per country</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Probation period</td><td class="px-4 py-3 text-slate-700">3–6 months</td><td class="px-4 py-3 text-slate-500">New employee trial period</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Pregnancy</td><td class="px-4 py-3 text-slate-700">~280 days (40 weeks)</td><td class="px-4 py-3 text-slate-500">Estimated due date calculation</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Car loan</td><td class="px-4 py-3 text-slate-700">36–72 months</td><td class="px-4 py-3 text-slate-500">Auto financing term length</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the date difference calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick start date</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the beginning of the period you want to measure.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick end date</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the end date. The calculator works in either direction.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the breakdown</h3>
        <p class="mt-1 text-sm text-slate-600">See the gap in days, weeks, months, years and hours — all updated instantly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for date calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Inclusive vs exclusive counting</h3>
        <p class="mt-1 text-sm text-slate-600">A "3 day" period from Monday to Thursday can mean 3 or 4 days depending on whether you count both start and end. Tick "Include end day" for inclusive counts.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Leap year awareness</h3>
        <p class="mt-1 text-sm text-slate-600">February 29 exists in leap years. The calculator handles this automatically, so you don't need to worry about "one extra day" every 4 years.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Month boundaries</h3>
        <p class="mt-1 text-sm text-slate-600">Dates near month boundaries can be tricky. The calculators year/month/day breakdown shows the actual calendar difference, not just round numbers.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use the date difference calculator</h2>
    <p class="mt-2 text-slate-600">
      The date difference calculator is valuable across multiple domains. Project managers use it to determine the exact duration between a project start date and its deadline. For example, a software project starting on March 1 and ending on June 15 spans 106 days, or roughly 15 weeks and 1 day. This information helps with sprint planning, milestone scheduling, and resource allocation throughout the project lifecycle.
    </p>
    <p class="mt-3 text-slate-600">
      Legal and compliance professionals rely on precise date calculations for contracts, visa stays, and notice periods. A 30-day notice period starting on January 15 ends on February 14. A 90-day visa-free stay beginning on June 1 expires on August 30. Getting these dates wrong can have legal or financial consequences, making an accurate calculator essential for compliance.
    </p>
    <p class="mt-3 text-slate-600">
      Individuals use date difference calculations for personal planning. Expecting parents track pregnancy duration from the last menstrual period to the estimated due date, approximately 280 days or 40 weeks. Travelers calculate the days until their next vacation to plan preparation activities. Students measure the time remaining until exam periods to schedule their study plans.
    </p>
    <p class="mt-3 text-slate-600">
      Financial professionals calculate date differences for bond maturity, loan terms, and interest accrual periods. A 12-month certificate of deposit opened on March 15 matures on March 15 of the following year. The exact day count is critical for calculating accrued interest, especially when dealing with short-term instruments where every day matters.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Limitations and considerations</h2>
    <p class="mt-2 text-slate-600">
      The date difference calculator provides accurate results but has limitations that users should understand. First, the calculator does not currently support business days or working days calculations. If you need to know how many weekdays fall between two dates excluding weekends and public holidays, you will need a more specialized tool or manual calculation.
    </p>
    <p class="mt-3 text-slate-600">
      Second, the year/month/day breakdown uses calendar months, which means that the number of days in a partial month varies depending on which months are involved. For example, the period from January 31 to March 1 spans 1 month and 1 day in a non-leap year for a total of 29 days, but from March 31 to May 1 also spans 1 month and 1 day for a total of 31 days. The day count differs, which can be confusing when comparing durations across different months.
    </p>
    <p class="mt-3 text-slate-600">
      Third, time of day is not considered in the calculation. The calculator operates on dates only, so a period from 8:00 AM on day 1 to 6:00 PM on day 2 counts as 1 day, not 1 day and 10 hours. For precise time-interval calculations including hours and minutes, a separate time duration tool is needed.
    </p>
    <p class="mt-3 text-slate-600">
      Fourth, historical date accuracy depends on the browser's Date implementation. While modern browsers handle dates from year 1 to 9999 correctly, very old dates before the adoption of the Gregorian calendar may not reflect historical calendar variations. For genealogical or historical research spanning centuries, specialized historical date tools may provide more accurate results.
    </p>
  </section>

  <script is:inline>
    const start = document.getElementById('start');
    const end = document.getElementById('end');
    const includeEnd = document.getElementById('include-end');
    const result = document.getElementById('result');
    const hint = document.getElementById('hint');
    const el = (id) => document.getElementById(id);

    function todayLocalISO() {
      const d = new Date();
      const mm = String(d.getMonth() + 1).padStart(2, '0');
      const dd = String(d.getDate()).padStart(2, '0');
      return `${d.getFullYear()}-${mm}-${dd}`;
    }
    end.value = todayLocalISO();

    // `from`/`to` are parsed from "YYYY-MM-DD" strings, which the Date constructor
    // treats as UTC midnight. Reading them back with local getters (getMonth/getDate)
    // shifts the calendar day by one for any timezone behind UTC, so all arithmetic
    // here uses the UTC getters/constructor to stay consistent with how they were parsed.
    function diffYMD(from, to) {
      // Advance `from` by whole years+months (clamping to the target month's real
      // length, e.g. Jan 31 + 1 month -> Feb 28) and take the remaining days from
      // that anchor date. A naive single-borrow subtraction goes negative whenever
      // `from`'s day-of-month doesn't exist a month later (e.g. 31 Jan -> 1 Mar).
      function addYM(date, years, months) {
        let year = date.getUTCFullYear() + years;
        let month = date.getUTCMonth() + months;
        year += Math.floor(month / 12);
        month = ((month % 12) + 12) % 12;
        const daysInMonth = new Date(Date.UTC(year, month + 1, 0)).getUTCDate();
        const day = Math.min(date.getUTCDate(), daysInMonth);
        return new Date(Date.UTC(year, month, day));
      }
      let y = to.getUTCFullYear() - from.getUTCFullYear();
      let m = to.getUTCMonth() - from.getUTCMonth();
      if (m < 0) { y--; m += 12; }
      let anchor = addYM(from, y, m);
      if (anchor > to) {
        m--;
        if (m < 0) { y--; m += 12; }
        anchor = addYM(from, y, m);
      }
      const d = Math.round((to - anchor) / 86400000);
      return { y, m, d };
    }

    function update() {
      if (!start.value || !end.value) return;
      let from = new Date(start.value);
      let to = new Date(end.value);
      if (to < from) { [from, to] = [to, from]; }

      let totalDays = Math.round((to - from) / 86400000);
      if (includeEnd.checked) totalDays += 1;

      const { y, m, d } = diffYMD(from, to);
      el('main-days').textContent = `${totalDays.toLocaleString()} day${totalDays === 1 ? '' : 's'}`;
      el('d-ymd').textContent = `${y}y ${m}m ${d}d`;
      el('d-weeks').textContent = `${Math.floor(totalDays / 7)}w ${totalDays % 7}d`;
      el('d-months').textContent = (y * 12 + m).toLocaleString();
      el('d-hours').textContent = (totalDays * 24).toLocaleString();

      result.classList.remove('hidden');
      hint.classList.add('hidden');
    }

    [start, end, includeEnd].forEach((e) => e.addEventListener('change', update));
  </script>
</ToolLayout>
