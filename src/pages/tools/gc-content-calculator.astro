---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'GC Content Calculator';
const description = 'GC content calculator with a live 3D base-composition diagram and charts. Compute GC% = (G+C)/total bases × 100 for any DNA sequence, with worked examples and organism GC% comparisons.';
const intro = 'Enter a DNA sequence to compute its GC content — the percentage of guanine and cytosine bases — a key measure used in genomics, PCR primer design, and species identification. Two 3D diagrams compare a GC-rich and an AT-rich sequence, and charts compare GC% across different organisms.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is GC content?', a: 'GC content is the percentage of a DNA (or RNA) sequence made up of guanine (G) and cytosine (C) bases, calculated as GC% = (G count + C count) / total base count × 100.' },
  { q: 'Why does GC content matter?', a: 'G-C base pairs form three hydrogen bonds (versus two for A-T pairs), making GC-rich DNA more thermally stable — this affects a sequence\'s melting temperature, PCR primer design, and even reflects an organism\'s evolutionary and ecological history.' },
  { q: 'Does GC content vary between species?', a: 'Yes, dramatically — human DNA averages around 41% GC content, while some bacteria range from below 25% to above 70% GC, and GC content is often used as a rough genomic fingerprint to help identify or classify organisms.' },
  { q: 'How does GC content affect PCR?', a: 'Higher GC content raises a DNA sequence\'s melting temperature (since G-C pairs are more thermally stable), which affects the annealing temperature needed for PCR primers — GC-rich templates often require adjusted PCR conditions to amplify successfully.' },
  { q: 'Is high or low GC content "better" for an organism?', a: 'Neither is inherently better — GC content reflects an organism\'s evolutionary history, mutation biases, and environmental adaptations rather than a "better" or "worse" quality, and both extremes are found in thriving, well-adapted species.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the GC Content Calculator',
  description: 'Compute the percentage of G and C bases in a DNA sequence.',
  steps: [
    { name: 'Enter a DNA sequence', text: 'Type a sequence using A, T, C, G bases (any length).' },
    { name: 'Read the GC%', text: 'The percentage of G and C bases, plus the individual base counts, solve instantly.' },
    { name: 'Compare to organisms', text: 'See how your sequence\'s GC% compares to typical values across different species.' },
  ],
};

const formulas = [
  { expr: 'GC% = (count(G) + count(C)) / total bases × 100', note: 'the percentage of the sequence made up of G and C bases' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a short 10-base sequence', tone: 'slate',
    given: 'DNA sequence: ATGCGCATCG (10 bases)',
    rows: [
      { label: 'Base counts:', value: 'A=2, T=1, G=3, C=4' },
      { label: 'Formula:', value: 'GC% = (G+C)/total × 100' },
      { label: 'Substitute:', value: 'GC% = (3+4)/10 × 100' },
      { label: 'Result:', value: 'GC% = 70%', full: true },
    ],
    note: 'This sequence is fairly GC-rich (70%), which would give it a relatively high melting temperature compared to an AT-rich sequence of the same length.',
  },
  {
    title: 'Worked example 2 — an AT-rich sequence', tone: 'amber',
    given: 'DNA sequence: AATATTAGCT (10 bases)',
    rows: [
      { label: 'Base counts:', value: 'A=4, T=4, G=1, C=1' },
      { label: 'Formula:', value: 'GC% = (G+C)/total × 100' },
      { label: 'Substitute:', value: 'GC% = (1+1)/10 × 100' },
      { label: 'Result:', value: 'GC% = 20%', full: true },
    ],
    note: 'An AT-rich sequence like this melts apart at a lower temperature than a GC-rich one of the same length, since A-T pairs form only two hydrogen bonds compared to G-C\'s three.',
  },
];

const comparison = {
  heading: 'Typical GC content across organisms',
  note: 'GC content varies enormously across the tree of life, from under 25% to over 70%.',
  headers: [{ label: 'Organism' }, { label: 'Typical GC%' }],
  rows: [
    ['Plasmodium falciparum (malaria parasite)', '~19%'],
    ['Homo sapiens (human) ★', '~41%'],
    ['Escherichia coli', '~51%'],
    ['Streptomyces (soil bacteria)', '~70%+'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference organism. Human genomic GC content varies regionally too — some chromosome regions are notably GC-richer than others.',
};

const realWorld = [
  { emoji: '🧬', title: 'PCR primer design', body: 'Primer design software checks GC content (ideally 40-60%) to ensure a primer binds with an appropriate, predictable melting temperature — too low or too high GC% can cause weak or non-specific binding.' },
  { emoji: '🦠', title: 'Species identification and classification', body: "A species' characteristic GC content can serve as a rough genomic fingerprint, historically used (before full genome sequencing was routine) to help distinguish and classify bacterial species." },
  { emoji: '🔬', title: 'Genome sequencing quality control', body: 'Unusual GC content in a sequenced region can flag potential contamination, sequencing errors, or genuinely unusual genomic regions (like GC-rich promoter regions) worth further investigation.' },
  { emoji: '🌡️', title: 'Predicting DNA thermal stability', body: 'Since G-C pairs form three hydrogen bonds versus A-T\'s two, GC content directly predicts how much heat energy is needed to separate (melt) a DNA double helix — critical for techniques like PCR and DNA hybridization.' },
];

const misconceptions = [
  { claim: '"Higher GC content always means a more complex or more evolved organism."', truth: "GC content has no established relationship with organismal complexity or evolutionary sophistication — some of the simplest bacteria have very high GC content, while some complex eukaryotes have relatively low GC content." },
  { claim: '"GC content is uniform across an entire genome."', truth: 'Real genomes show substantial regional variation in GC content — some stretches (like certain gene promoter regions) are notably GC-richer than the genome-wide average, a pattern geneticists actively study.' },
  { claim: '"A and T bases don\'t matter for a sequence\'s properties, only G and C do."', truth: 'A and T content is simply 100% minus GC content for a standard 4-base sequence — both matter equally, since they directly determine each other, and AT-rich regions have their own important properties (like typically being easier to separate/melt).' },
  { claim: '"GC content calculations require knowing the complementary strand too."', truth: "Because of Chargaff's rules (A pairs with T, G pairs with C across the double helix), a DNA sequence's GC content on one strand exactly equals its GC content on the complementary strand — you only need to analyze one strand to know the value for both." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 14, "DNA Structure and Function" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/14-1-historical-basis-of-modern-understanding" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Chapter 4, DNA, Chromosomes, and Genomes.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 16, The Molecular Basis of Inheritance.' },
];
const sourcesNote = 'GC% = (G+C)/total bases × 100. Organism GC% values are standard reference figures and can vary by strain/genome region. Input should use only A, T, C, G.';

const howToUse = [
  { title: 'Enter a DNA sequence', body: 'Type any sequence using A, T, C, G bases.' },
  { title: 'Read the GC%', body: 'The percentage and individual base counts solve instantly.' },
  { title: 'Compare across organisms', body: 'See how your sequence compares to typical values across the tree of life.' },
];

const related = [
  { href: '/tools/dna-melting-temperature-calculator', emoji: '🌡️', title: 'DNA Melting Temperature (Tm) Calculator', desc: 'Wallace rule — Tm = 4(G+C) + 2(A+T).' },
  { href: '/tools/dna-transcription-calculator', emoji: '🧬', title: 'DNA to mRNA Transcription Tool', desc: 'Convert a DNA template strand into mRNA.' },
  { href: '/tools/reverse-complement-calculator', emoji: '🔄', title: 'Reverse Complement Sequence Tool', desc: 'Find the reverse complement of a DNA strand.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="because G-C base pairs are held together by three hydrogen bonds versus A-T's two, the fraction of a sequence made of G and C directly predicts how thermally stable that stretch of DNA is — a simple percentage that carries real physical and biological weight."
  howIntro="GC content is a straightforward tally: count every G and every C in a sequence, divide by the total number of bases, and multiply by 100. What makes this simple percentage useful is the underlying chemistry — G-C pairs form three hydrogen bonds while A-T pairs form only two, so a higher GC% directly means a more thermally stable double helix, a higher melting temperature, and different practical requirements for techniques like PCR that rely on separating and reannealing DNA strands."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where GC content actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">DNA sequence (A/T/C/G only)</span>
      <input id="seq" type="text" value="ATGCGCATCG" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">GC content</div><div id="r-gc" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Base counts (A/T/C/G)</div><div id="r-counts" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="gc-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">GC-rich vs AT-rich sequences</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-gcrich" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A GC-rich sequence</h3>
          <p class="mt-1 text-sm text-slate-600">Mostly green (G) and red (C) spheres — a thermally stable, high-melting-point stretch of DNA.</p>
        </div>
        <div>
          <div id="diag-atrich" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. An AT-rich sequence</h3>
          <p class="mt-1 text-sm text-slate-600">Mostly indigo (A) and amber (T) spheres — a less thermally stable, lower-melting-point stretch of DNA.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">GC content graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">GC content across organisms</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-organisms"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Base composition of your sequence</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-composition"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const COLORS = { A: 0x6366f1, T: 0xf59e0b, C: 0xef4444, G: 0x10b981 };

      function counts(seq) {
        const c = { A: 0, T: 0, C: 0, G: 0 };
        seq.split('').forEach((b) => { if (c[b] !== undefined) c[b]++; });
        return c;
      }
      const charts = {};
      function update() {
        el('gc-err').textContent = '';
        const raw = (el('seq').value || '').toUpperCase().replace(/[^ATCG]/g, '');
        el('seq').value = el('seq').value.toUpperCase();
        if (!raw) { el('r-gc').textContent = '—'; el('r-counts').textContent = '—'; return; }
        const c = counts(raw);
        const total = raw.length;
        const gcPct = ((c.G + c.C) / total) * 100;
        el('r-gc').textContent = fmt(gcPct) + '%';
        el('r-counts').textContent = 'A=' + c.A + ' T=' + c.T + ' C=' + c.C + ' G=' + c.G;
        if (charts.composition) {
          charts.composition.data.datasets[0].data = [c.A, c.T, c.C, c.G];
          charts.composition.update();
        }
      }
      el('seq').addEventListener('input', update);

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.organisms = new Chart(el('chart-organisms'), {
          type: 'bar',
          data: { labels: ['P. falciparum', 'Human', 'E. coli', 'Streptomyces'], datasets: [{ label: 'GC%', data: [19, 41, 51, 70], backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'GC content (%)' }, max: 100 } }, plugins: { legend: { display: false } } }),
        });
        charts.composition = new Chart(el('chart-composition'), {
          type: 'pie',
          data: { labels: ['A', 'T', 'C', 'G'], datasets: [{ data: [2, 1, 4, 3], backgroundColor: ['#6366f1', '#f59e0b', '#ef4444', '#10b981'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function baseCloudScene(container, seq) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        seq.split('').forEach((b, i) => {
          const phi = Math.acos(1 - (2 * (i + 0.5)) / seq.length);
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const r = 2;
          const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.28, 12, 10), new THREE.MeshStandardMaterial({ color: COLORS[b] || 0x94a3b8 }));
          sph.position.set(x, y, z);
          s.scene.add(sph);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagGC = null, diagAT = null;
      function initDiagGC() { const c = el('diag-gcrich'); if (!c) throw new Error('no container'); diagGC = baseCloudScene(c, 'GCGCGCCGGC'); }
      function initDiagAT() { const c = el('diag-atrich'); if (!c) throw new Error('no container'); diagAT = baseCloudScene(c, 'ATATATTAAT'); }

      function boot() {
        try { initCharts(); } catch (e) { console.error('[gc-content] charts failed', e); }
        try { update(); } catch (e) { console.error('[gc-content] calc init failed', e); }
        if (window.THREE) {
          try { initDiagGC(); } catch (e) { console.error('[gc-content] gc diagram failed', e); }
          try { initDiagAT(); } catch (e) { console.error('[gc-content] at diagram failed', e); }
        }
        mountResize([diagGC, diagAT]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
