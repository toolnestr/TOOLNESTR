      function applyCase(str, caseType) {
        if (caseType === 'upper') return str.toUpperCase();
        if (caseType === 'lower') return str.toLowerCase();
        return str.charAt(0).toUpperCase() + str.slice(1).toLowerCase();
      }

      function generate() {
        var phrase = phraseEl.value.trim();
        if (!phrase) {
          resultsEl.classList.add('hidden');
          return;
        }

        var n = parseInt(nLettersEl.value, 10) || 1;
        var excludeStop = stopWordsEl.checked;
        var caseType = 'upper';
        for (var i = 0; i < caseRadios.length; i++) {
          if (caseRadios[i].checked) {
            caseType = caseRadios[i].value;
            break;
          }
        }

        var words = phrase.split(/\s+/).filter(Boolean);
        var filteredWords = [];
        for (var j = 0; j < words.length; j++) {
          var w = words[j].replace(/[^a-zA-Z0-9]/g, '');
          if (!w) continue;
          if (excludeStop && stopWords.has(w.toLowerCase())) continue;
          filteredWords.push(w);
        }

        if (filteredWords.length === 0) {
          resultsEl.classList.add('hidden');
          return;
        }

        var letters = [];
        var fullForms = [];
        for (var k = 0; k < filteredWords.length; k++) {
          var fw = filteredWords[k];
          var take = Math.min(n, fw.length);
          letters.push(fw.slice(0, take));
          fullForms.push(fw);
        }

        var acronym = letters.join('');
        acronym = applyCase(acronym, caseType);

        var expanded = [];
        for (var m = 0; m < filteredWords.length; m++) {
          expanded.push(applyCase(filteredWords[m], caseType));
        }

        acronymDisplay.textContent = acronym;
        standsFor.textContent = expanded.join(' ');

        var lower = acronym.toLowerCase();
        if (commonWords.has(lower)) {
          wordStatus.textContent = '"' + acronym + '" is a known English word';
          wordStatus.className = 'rounded-xl border border-slate-200 bg-emerald-50 p-4 text-sm font-medium text-emerald-700';
        } else if (lower.length >= 2) {
          wordStatus.textContent = '"' + acronym + '" is not a common English word';
          wordStatus.className = 'rounded-xl border border-slate-200 bg-amber-50 p-4 text-sm font-medium text-amber-700';
        } else {
          wordStatus.classList.add('hidden');
        }

        resultsEl.classList.remove('hidden');
      }

      genBtn.addEventListener('click', generate);

      phraseEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && e.ctrlKey) {
          generate();
        }
      });
    });
  </script>
</ToolLayout>
