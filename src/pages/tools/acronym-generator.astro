        <span class="rounded-full bg-white px-3 py-1 border border-slate-200">from</span>
        <span class="rounded-full bg-white px-3 py-1 border border-slate-200">is</span>
        <span class="rounded-full bg-white px-3 py-1 border border-slate-200">are</span>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/text-to-slug-generator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">URL Slug Generator</a>
      <a href="/tools/grammar-readability-checker" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">Grammar &amp; Readability Checker</a>
      <a href="/tools/citation-generator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">Citation Generator</a>
    </div>
  </section>

