      var phraseEl = document.getElementById('phrase');
      var nLettersEl = document.getElementById('n-letters');
      var stopWordsEl = document.getElementById('stop-words');
      var caseRadios = document.querySelectorAll('input[name="case"]');
      var genBtn = document.getElementById('gen-btn');
