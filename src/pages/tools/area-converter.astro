---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Square meters", sym: "m²", toBase: 1 }, { name: "Square kilometers", sym: "km²", toBase: 1000000 }, { name: "Square centimeters", sym: "cm²", toBase: 0.0001 }, { name: "Hectares", sym: "ha", toBase: 10000 }, { name: "Acres", sym: "ac", toBase: 4046.8564224 }, { name: "Square feet", sym: "ft²", toBase: 0.09290304 }, { name: "Square yards", sym: "yd²", toBase: 0.83612736 }, { name: "Square inches", sym: "in²", toBase: 0.00064516 }, { name: "Square miles", sym: "mi²", toBase: 2589988.110336 }];
---
<MultiUnitConverter
  title="Area Converter"
  emoji="📐"
  quantity="area"
  baseName="square meter"
  units={units}
  defaultFrom={0} defaultTo={5}
  intro="Convert between area units — square meters, square kilometers, square centimeters, hectares, acres and more."
  blurb="Area measures the size of a surface, used for land, flooring, paint and plots."
  related={[{"slug":"length-converter","label":"Length Converter Converter"},{"slug":"cm-to-inches","label":"Cm to Inches Converter"}]}
/>
