---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'CGPA to GPA Calculator';
const description =
  'Free CGPA to GPA calculator. Convert your CGPA (e.g. out of 10) to the US 4.0 GPA scale ' +
  'instantly. Handy for studying abroad and applications.';
const intro =
  'Convert your CGPA to the US 4.0 GPA scale. Set your CGPA scale (usually 10) and enter your CGPA.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'How do you convert CGPA to GPA?', a: 'A common estimate scales your CGPA proportionally onto the 4.0 system: GPA = (CGPA ÷ your scale) × 4. For a 10-point CGPA of 8.0, that’s (8 ÷ 10) × 4 = 3.2.' },
  { q: 'Is this the official conversion?', a: 'No single official formula exists — many US universities use credential-evaluation services. This gives a widely used estimate; always check your target university’s method.' },
  { q: 'What scale should I use?', a: 'Most CGPA systems are out of 10, but some use 5 or other values. Set your scale so the conversion is accurate.' },
  { q: 'How do US universities evaluate international grades?', a: 'Many US universities use professional evaluation services like WES (World Education Services) or ECE to convert international grades. Your result here is a quick estimate, not an official evaluation.' },
  { q: 'What is a good GPA on the 4.0 scale?', a: 'In the US system, 3.0 is generally considered a B average, 3.5 is a B+ average, and 4.0 is a perfect A average. Requirements vary by program and university.' },
  { q: 'Can I convert my US GPA to CGPA?', a: 'Yes — reverse the formula: CGPA = (GPA ÷ 4) × your scale. For example, a 3.2 GPA on a 10-point scale is (3.2 ÷ 4) × 10 = 8.0 CGPA.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Your CGPA</span>
        <input id="cgpa" type="number" step="any" placeholder="8.0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">CGPA scale (max)</span>
        <input id="scale" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Estimated GPA (4.0 scale)</div>
      <div id="gpa" class="mt-1 text-3xl font-bold">—</div>
      <div id="formula" class="mt-1 font-mono text-sm opacity-80"></div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your CGPA to estimate your 4.0 GPA.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About CGPA to GPA conversion</h2>
    <p class="mt-2 text-slate-600">
      Applying to a US university or job often means converting your CGPA to the 4.0 GPA scale.
      This calculator gives a quick, widely-used estimate by scaling your CGPA proportionally onto
      the 4.0 system, so you know roughly where you stand. You can also convert to the German system with our <a href="/tools/german-grade-calculator" class="font-medium text-indigo-600 hover:underline">German Grade Calculator</a>.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter your CGPA (e.g. 8.0 out of 10).</li>
      <li>Set your CGPA scale — most systems use 10, but some use 5 or 4.</li>
      <li>Your estimated GPA on the US 4.0 scale appears instantly with the formula.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Essential when applying to US universities, American scholarship programs, or US-based employers who evaluate candidates on the 4.0 GPA scale. Use it to get a sense of where your academic record stands in US terms, and to fill out application forms that only accept GPA values.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Confirm your CGPA scale — while 10 is most common, some universities use 4.0 or 5.0 scales, and setting the wrong scale will give an incorrect result.</li>
      <li>Keep in mind that this is an estimate — many US universities use professional credential evaluation services (like WES) for official conversions.</li>
      <li>For a more comprehensive picture of where your grades stand internationally, also try our <a href="/tools/german-grade-calculator" class="font-medium text-indigo-600 hover:underline">German Grade Calculator</a>.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function update() {
      const cgpa = parseFloat(el('cgpa').value), scale = parseFloat(el('scale').value);
      if (isNaN(cgpa) || isNaN(scale) || scale <= 0 || cgpa < 0 || cgpa > scale) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      const gpa = cgpa / scale * 4;
      el('gpa').textContent = (Math.round(gpa * 100) / 100).toFixed(2);
      el('formula').textContent = `(${cgpa} ÷ ${scale}) × 4 = ${(Math.round(gpa * 100) / 100).toFixed(2)}`;
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }
    ['cgpa', 'scale'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
