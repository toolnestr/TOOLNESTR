---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Laundry Symbol Decoder';
const description = 'Look up what a washing, bleaching, drying, ironing, or dry-cleaning care label symbol means. Decode any laundry symbol by its shape instantly.';
const intro = 'Decode any laundry care label symbol by shape — washing, bleaching, drying, ironing, or dry cleaning.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What do the dots inside a wash tub or iron symbol mean?', a: 'Dots indicate temperature level rather than an exact number in the international (ISO/GINETEX) symbol system: for washing, one dot is about 30°C, up to six dots for the hottest setting; for ironing, one dot is a low/synthetic setting, two dots medium/wool, and three dots high/cotton-linen.' },
  { q: 'What is the difference between the US and international symbol systems?', a: 'US care labels (following ASTM D5489) commonly show an exact temperature number inside the wash tub symbol, while the international system (ISO 3758, used by GINETEX) more often uses dots to indicate a temperature range rather than a precise number — the shapes themselves (tub, triangle, square, iron, circle) are consistent across both systems.' },
  { q: 'What does a circle mean on a care label?', a: 'A circle represents professional dry cleaning. A letter inside the circle (like P or F) tells a professional dry cleaner which solvent to use; an empty circle means dry clean with any solvent, and a circle with an X means do not dry clean.' },
  { q: 'What if a symbol has a line underneath it?', a: 'A single line underneath a washing, drying, or other symbol generally means "use a reduced/gentle setting" (like a permanent press cycle), and two lines underneath typically mean an even gentler setting (like a delicate/hand-wash-equivalent cycle).' },
];
const howTo = {
  name: 'How to decode a laundry symbol',
  steps: [
    { name: 'Identify the basic shape', text: 'Look at the symbol\'s outer shape: a tub, triangle, square, iron, or circle.' },
    { name: 'Select that shape below', text: 'Choose the matching category to see every symbol variation in that group.' },
    { name: 'Match the specific symbol', text: 'Find the exact symbol (with any dots, lines, or X) and read its meaning.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex flex-wrap gap-2">
      {['Washing', 'Bleaching', 'Drying', 'Ironing', 'Dry Cleaning'].map((d) => (
        <button data-cat={d} class="cat-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <div id="symbol-list" class="mt-4 grid gap-3 sm:grid-cols-2"></div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="160" viewBox="0 0 800 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="lsd-title lsd-desc">
      <title id="lsd-title">Five basic laundry symbol shapes</title>
      <desc id="lsd-desc">A tub, triangle, square, iron, and circle shown side by side, representing the five categories of laundry care symbols</desc>
      <rect x="60" y="50" width="70" height="50" rx="8" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <polygon points="230,50 265,100 195,100" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <rect x="330" y="50" width="60" height="60" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <path d="M470 55 Q510 50 515 75 Q518 95 490 100 L460 100 Z" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <circle cx="620" cy="80" r="30" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <text x="95" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Wash</text>
      <text x="230" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Bleach</text>
      <text x="360" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Dry</text>
      <text x="490" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Iron</text>
      <text x="620" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Dry clean</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Each care label symbol shape represents one category of care instruction</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How laundry symbols work</h2>
    <p class="mt-2 text-slate-600">
      Care labels use five basic shapes, each representing one type of care instruction: a tub for washing, a triangle for bleaching, a square for drying, an iron outline for ironing, and a circle for professional dry cleaning. Within each shape, dots indicate temperature or heat level, lines underneath indicate a gentler cycle, and an X drawn through the symbol means that action should not be done at all.
    </p>
    <p class="mt-3 text-slate-600">
      This system, standardized internationally through ISO 3758 and promoted by GINETEX, lets a garment carry care instructions understandable across languages without needing translated text — though US labels under ASTM D5489 sometimes show an exact temperature number inside the wash tub instead of the international dot system.
    </p>
    <p class="mt-3 text-xs text-slate-400">Symbol meanings follow the ISO 3758 international textile care labeling code and the equivalent ASTM D5489 standard used in the US.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A care label shows a tub with a hand inside, a triangle with two diagonal lines, a square with a circle and one dot, an iron with one dot, and a circle with an X.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Tub with hand:</span> <span class="text-slate-600">Hand wash only</span></div>
        <div><span class="font-medium text-slate-700">Triangle, two lines:</span> <span class="text-slate-600">Non-chlorine bleach only</span></div>
        <div><span class="font-medium text-slate-700">Square, circle, 1 dot:</span> <span class="text-slate-600">Tumble dry, low heat</span></div>
        <div><span class="font-medium text-slate-700">Iron, 1 dot:</span> <span class="text-slate-600">Iron on low heat</span></div>
        <div><span class="font-medium text-slate-700">Circle with X:</span> <span class="text-slate-600"><strong>Do not dry clean</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Buying secondhand or imported clothing without English-language care text is one of the most common reasons someone needs to decode symbols directly, since the pictogram system is intentionally language-independent — a garment made in one country and sold in another still carries the same universally readable shapes.
    </p>
    <p class="mt-3 text-slate-600">
      Delicate or expensive garments (silk, wool, structured formalwear) are where misreading a symbol has the highest cost — tumble drying something marked for line drying only, or machine washing something marked dry-clean-only, can shrink, felt, or otherwise permanently damage a garment that's expensive or impossible to replace.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"An empty triangle means do not bleach." <strong class="text-slate-900">The opposite.</strong> An empty (plain) triangle means bleaching is allowed with any bleach; it's only a triangle with an X through it that means no bleach at all.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All care symbols are identical worldwide with no variation." <strong class="text-slate-900">Mostly, but not entirely.</strong> The shapes and general logic are internationally standardized, but the US system's use of exact numbers versus the international system's dot-based scale is a real, practical difference worth knowing.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-care-wash-temperature-guide" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Care/Wash Temperature Guide</a>
      <a href="/tools/fabric-shrinkage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Shrinkage Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let cat = 'Washing';

    const symbols = {
      Washing: [
        ['🪣', 'Tub, plain', 'Machine wash, normal cycle'],
        ['🪣✋', 'Tub with hand', 'Hand wash only'],
        ['🪣✖', 'Tub with X', 'Do not wash'],
        ['🪣_', 'Tub, one line underneath', 'Permanent press cycle'],
        ['🪣__', 'Tub, two lines underneath', 'Gentle/delicate cycle'],
        ['🪣•', 'Tub with dots (1-6)', 'Max temperature: 1 dot ≈ 30°C, up to 6 dots ≈ 95°C'],
      ],
      Bleaching: [
        ['△', 'Empty triangle', 'Any bleach allowed'],
        ['△∕∕', 'Triangle, two diagonal lines', 'Non-chlorine (oxygen) bleach only'],
        ['△✖', 'Triangle with X', 'Do not bleach'],
      ],
      Drying: [
        ['◻◯', 'Square with circle', 'Tumble dry'],
        ['◻◯✖', 'Square with circle and X', 'Do not tumble dry'],
        ['◻◯•', 'Square, circle, dots', 'Heat level: 1 dot low, 2 medium, 3 high'],
        ['◻▭', 'Square, horizontal line', 'Dry flat'],
        ['◻|||', 'Square, vertical lines', 'Line dry / hang to dry'],
      ],
      Ironing: [
        ['🔺Iron', 'Iron, plain', 'Iron at any temperature'],
        ['🔺•', 'Iron, one dot', 'Low heat (synthetics)'],
        ['🔺••', 'Iron, two dots', 'Medium heat (wool, polyester blends)'],
        ['🔺•••', 'Iron, three dots', 'High heat (cotton, linen)'],
        ['🔺✖', 'Iron with X', 'Do not iron'],
      ],
      'Dry Cleaning': [
        ['◯', 'Empty circle', 'Dry clean, any solvent'],
        ['◯P', 'Circle with P', 'Dry clean, specific solvent (professional)'],
        ['◯F', 'Circle with F', 'Dry clean, petroleum solvent only'],
        ['◯✖', 'Circle with X', 'Do not dry clean'],
      ],
    };

    function render() {
      const list = el('symbol-list');
      list.innerHTML = '';
      symbols[cat].forEach(([icon, label, meaning]) => {
        const card = document.createElement('div');
        card.className = 'rounded-xl border border-slate-200 bg-slate-50 p-4';
        card.innerHTML = '<div class="font-semibold text-slate-900">' + label + '</div><div class="mt-1 text-sm text-slate-600">' + meaning + '</div>';
        list.appendChild(card);
      });
    }

    document.querySelectorAll('.cat-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.cat-btn').forEach((b) => {
          b.className = 'cat-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'cat-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        cat = btn.dataset.cat;
        render();
      });
    });

    document.querySelector('.cat-btn').click();
  </script>
</ToolLayout>
