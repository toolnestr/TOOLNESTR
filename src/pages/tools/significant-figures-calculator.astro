---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Significant Figures Calculator';
const description = 'Round numbers to a specified number of significant figures. Free online significant figures calculator with rules and explanations.';
const intro = 'Round any number to a chosen number of significant figures. Learn the rules for identifying and counting significant digits.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What are significant figures?', a: 'Significant figures (sig figs) are the meaningful digits in a number that contribute to its precision. They include all non-zero digits, zeros between non-zero digits, and trailing zeros in a decimal number.' },
  { q: 'How do I count significant figures?', a: 'All non-zero digits are significant. Zeros between non-zero digits are significant. Leading zeros (before the first non-zero digit) are not significant. Trailing zeros in a decimal are significant. For example, 0.00120 has 3 sig figs.' },
  { q: 'Why are significant figures important?', a: 'Sig figs indicate the precision of a measurement. Reporting 3.14 (3 sig figs) versus 3.14159 (6 sig figs) tells the reader how precisely you know the value. They prevent false precision in scientific and engineering work.' },
  { q: 'How do I round to significant figures?', a: 'Count the specified number of significant digits from the left, starting with the first non-zero digit. Then round the digit at that position based on the next digit (5 or more rounds up). Replace remaining digits with zeros or drop them after the decimal.' },
  { q: 'What is scientific notation for sig figs?', a: 'Scientific notation (e.g., 1.20 × 10³) makes sig figs explicit. The coefficient shows exactly which digits are significant. This avoids ambiguity about whether zeros in numbers like 1,200 are significant or just placeholders.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-3">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-sm font-medium text-slate-700" for="sf-number">Number</label>
        <input id="sf-number" type="text" value="0.0045670" placeholder="e.g. 0.0045670"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="w-28">
        <label class="block text-sm font-medium text-slate-700" for="sf-count">Sig figs</label>
        <input id="sf-count" type="number" step="1" value="3" min="1" max="20" placeholder="3"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>
    <div id="sf-result" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
      <span class="text-sm opacity-90">Rounded =</span>
      <span id="sf-rounded-val" class="ml-2 text-2xl font-bold">0.00457</span>
    </div>
    <div class="mt-3 grid gap-3 sm:grid-cols-2">
      <div id="sf-count-result" class="rounded-xl bg-slate-50 p-4 text-center text-sm text-slate-500">
        Original has <span id="sf-original-count" class="font-bold text-slate-800">5</span> sig figs
        <span class="ml-2 text-xs text-slate-400">| in scientific notation: <span id="sf-sci-not" class="font-mono">4.5670 × 10⁻³</span></span>
      </div>
      <div id="sf-rules" class="rounded-xl bg-slate-50 p-4 text-center text-sm">
        <span class="text-slate-500">Rounded to <span id="sf-target-count" class="font-bold text-slate-800">3</span> sig figs</span>
      </div>
    </div>
    <div id="sf-breakdown" class="mt-3 hidden rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="600" height="280" viewBox="0 0 600 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sf-title sf-desc">
      <title id="sf-title">Number 0.0045670 with color-coded significant digits</title>
      <desc id="sf-desc">The number 0.0045670 shown with each digit in a different color. Leading zeros (0.00) are grey (not significant). Digits 4,5,6,7 are blue (significant). Trailing zero is green (significant because it appears after the decimal point).</desc>
      <rect x="30" y="20" width="540" height="240" rx="10" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" />
      <text x="300" y="55" text-anchor="middle" fill="#1e293b" font-size="16" font-weight="bold">Significant Figures in 0.0045670</text>
      <rect x="100" y="90" width="30" height="50" rx="6" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1" />
      <text x="115" y="120" text-anchor="middle" fill="#94a3b8" font-size="18">0</text>
      <rect x="135" y="90" width="30" height="50" rx="6" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1" />
      <text x="150" y="120" text-anchor="middle" fill="#94a3b8" font-size="18">.</text>
      <rect x="170" y="90" width="30" height="50" rx="6" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1" />
      <text x="185" y="120" text-anchor="middle" fill="#94a3b8" font-size="18">0</text>
      <rect x="205" y="90" width="30" height="50" rx="6" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1" />
      <text x="220" y="120" text-anchor="middle" fill="#94a3b8" font-size="18">0</text>
      <text x="250" y="120" text-anchor="middle" fill="#94a3b8" font-size="14">Leading zeros — not significant</text>
      <rect x="100" y="160" width="30" height="50" rx="6" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
      <text x="115" y="190" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">4</text>
      <rect x="135" y="160" width="30" height="50" rx="6" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
      <text x="150" y="190" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">5</text>
      <rect x="170" y="160" width="30" height="50" rx="6" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
      <text x="185" y="190" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">6</text>
      <rect x="205" y="160" width="30" height="50" rx="6" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
      <text x="220" y="190" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">7</text>
      <rect x="240" y="160" width="30" height="50" rx="6" fill="#ecfdf5" stroke="#10b981" stroke-width="2" />
      <text x="255" y="190" text-anchor="middle" fill="#059669" font-size="18" font-weight="bold">0</text>
      <text x="350" y="190" text-anchor="middle" fill="#64748b" font-size="14">Significant: 4, 5, 6, 7, 0 (trailing zero in decimal counts)</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Color-coded significant figures: grey digits are not significant, blue digits are significant, and the green trailing zero is significant because it appears after the decimal point.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How significant figures work</h2>
    <p class="mt-2 text-slate-600">Significant figures (also called significant digits) are the digits in a number that carry meaning and contribute to its precision. They provide a way to express the accuracy of a measurement without explicitly stating the uncertainty. The rules for identifying significant figures are straightforward: all non-zero digits are significant, zeros between non-zero digits are significant, leading zeros are not significant (they are just placeholders), and trailing zeros in a decimal number are significant.</p>
    <p class="mt-3 text-slate-600">The concept of significant figures is fundamental in science and engineering because it prevents false precision. If a measurement reports a result as 12.0 grams, the trailing zero indicates that the measurement was precise to 0.1 grams — the actual value is between 11.95 and 12.05 grams. Without the zero, 12 grams would imply precision to only 1 gram (between 11.5 and 12.5 grams).</p>
    <p class="mt-3 text-slate-600">Rounding to significant figures is different from rounding to decimal places. For example, rounding 0.004567 to 3 significant figures gives 0.00457 (the first non-zero digit is where counting starts), while rounding to 3 decimal places gives 0.005. The calculator handles sig fig rounding correctly regardless of the magnitude of the number.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Sig fig counting rules</h3>
        <p class="mt-1 text-sm text-slate-600"><strong>1.</strong> All non-zero digits: significant<br><strong>2.</strong> Zeros between non-zero: significant<br><strong>3.</strong> Leading zeros: NOT significant<br><strong>4.</strong> Trailing zeros in decimal: significant<br><strong>5.</strong> Trailing zeros in whole number: ambiguous</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Rounding algorithm</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">Round to n sig figs:</p>
        <p class="mt-1 text-sm text-slate-600">Find the nth significant digit. If the next digit is 5+, round up. If 0-4, truncate. Replace remaining digits with zeros or drop them after the decimal.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: Round 0.0045670 to 3 sig figs</h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>Step 1: Identify the first non-zero digit: 4 (the 3rd decimal place)</p>
        <p>Step 2: Count 3 significant digits from here: 4, 5, 6 are the first 3 sig figs</p>
        <p>Step 3: Look at the next digit (7): since 7 ≥ 5, round the 6 up to 7</p>
        <p>Step 4: Replace remaining digits: the result becomes 0.00457</p>
        <p class="font-semibold text-emerald-700">Therefore: 0.0045670 rounded to 3 sig figs = 0.00457</p>
        <p class="mt-1 text-slate-500">In scientific notation: 4.5670 × 10⁻³ → 4.57 × 10⁻³ (3 sig figs). The original number had 5 sig figs (4, 5, 6, 7, and the trailing 0).</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F52C;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">All scientific measurements include sig figs. A reported value of 3.14 g (3 sig figs) is less precise than 3.1400 g (5 sig figs). Proper sig fig usage ensures that published results honestly reflect measurement precision and reproducibility.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Engineers</h3>
      <p class="mt-1 text-sm text-slate-600">Engineering tolerances and specifications rely on significant figures. A dimension of 10.0 mm means the part must be between 9.95 and 10.05 mm. Using the correct number of sig figs ensures that manufacturing tolerances are clear and achievable.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4D0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students</h3>
      <p class="mt-1 text-sm text-slate-600">Sig figs are a core topic in chemistry and physics courses. Lab reports require results to be reported with the correct number of significant figures based on the precision of the measuring instruments used in the experiment.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4C8;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Data Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">Reporting results with appropriate precision is key to honest data communication. Floating-point outputs from models often have spurious precision — rounding to 3-4 significant figures typically communicates the meaningful information without overstating accuracy.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the significant figures calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter a number</h3>
        <p class="mt-1 text-sm text-slate-600">Type any real number — with or without a decimal point, in standard or scientific notation. The calculator analyzes its significant figures.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the target count</h3>
        <p class="mt-1 text-sm text-slate-600">Choose how many significant figures you want in the result. The calculator handles 1 to 20 sig figs.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the results</h3>
        <p class="mt-1 text-sm text-slate-600">The rounded number, original sig fig count, scientific notation, and a detailed digit-level breakdown are all displayed instantly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for significant figures</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Ambiguous trailing zeros</h3>
        <p class="mt-1 text-sm text-slate-600">A number like 1,200 is ambiguous — it could have 2, 3, or 4 significant figures. To avoid ambiguity, use scientific notation: 1.2 × 10³ (2 sig figs), 1.20 × 10³ (3 sig figs), or 1.200 × 10³ (4 sig figs). The calculator assumes trailing zeros in whole numbers are not significant unless a decimal point is present.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Sig figs in calculations</h3>
        <p class="mt-1 text-sm text-slate-600">When multiplying or dividing, the result should have the same number of sig figs as the least precise measurement. For addition and subtraction, the result should have the same number of decimal places as the least precise measurement. These rules prevent the calculation from introducing false precision.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Exact numbers have infinite sig figs</h3>
        <p class="mt-1 text-sm text-slate-600">Defined constants and counted quantities have infinite significant figures. A dozen eggs is exactly 12 (not approximately 12). The conversion 1 inch = 2.54 cm is exact by definition. These do not limit the sig figs in a calculation. The calculator flags exact inputs for clarity.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Logarithms and sig figs</h3>
        <p class="mt-1 text-sm text-slate-600">When taking a logarithm, the result should have the same number of decimal places as the original has significant figures. For example, log(3.00 × 10³) = 3.477 (3 decimal places because the input has 3 sig figs). The integer part of the logarithm indicates the order of magnitude and does not count toward precision.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/number-base-converter/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F522;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Number Base Converter</h3>
        <p class="mt-0.5 text-xs text-slate-500">Convert numbers between binary, octal, decimal, and hexadecimal bases.</p>
      </a>
      <a href="/tools/scientific-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F9EE;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Scientific Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Full scientific calculator for complex mathematical expressions.</p>
      </a>
      <a href="/tools/rounding-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F504;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Rounding Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Round numbers to specified decimal places or significant figures.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const sfNumber = document.getElementById('sf-number');
    const sfCount = document.getElementById('sf-count');
    const sfRoundedVal = document.getElementById('sf-rounded-val');
    const sfOriginalCount = document.getElementById('sf-original-count');
    const sfSciNot = document.getElementById('sf-sci-not');
    const sfTargetCount = document.getElementById('sf-target-count');
    const sfBreakdown = document.getElementById('sf-breakdown');

    function countSigFigs(numStr) {
      const trimmed = numStr.trim();
      if (!trimmed || trimmed === '0' || trimmed === '0.') return 0;

      const normalized = trimmed.replace(/^[\+\-]/, '');
      const hasDecimal = normalized.includes('.');
      const noLeadingZeros = normalized.replace(/^0+/, '');

      if (!hasDecimal) {
        const digits = noLeadingZeros.replace(/[^0-9]/g, '');
        const allDigits = normalized.replace(/[^0-9]/g, '');
        const trailingZeros = digits.match(/0+$/);
        if (trailingZeros) {
          return allDigits.length - trailingZeros[0].length;
        }
        return allDigits.length;
      }

      const parts = normalized.split('.');
      const intPart = parts[0];
      const fracPart = parts[1] || '';

      if (parseInt(intPart) === 0) {
        const fracDigits = fracPart.replace(/^0+/, '');
        return fracDigits.length;
      }

      const intDigits = intPart.replace(/[^0-9]/g, '');
      const fracDigits = fracPart.replace(/[^0-9]/g, '');
      return intDigits.length + fracDigits.length;
    }

    function toScientific(numStr) {
      const num = parseFloat(numStr);
      if (isNaN(num) || num === 0) return '0';
      if (num < 0) return '-' + toScientific(numStr.replace('-', ''));
      const trimmed = numStr.trim().replace(/^\+/, '');
      const normalized = parseFloat(trimmed);
      const exp = Math.floor(Math.log10(Math.abs(normalized)));
      const mantissa = normalized / Math.pow(10, exp);
      const mantStr = mantissa.toLocaleString(undefined, { maximumFractionDigits: 10 });
      return `${mantStr} × 10<sup>${exp}</sup>`;
    }

    function roundToSigFigs(numStr, n) {
      const original = numStr.trim();
      const isNegative = original.startsWith('-');
      const clean = original.replace(/^[\+\-]/, '');
      const num = parseFloat(clean);

      if (isNaN(num) || num === 0 || n < 1) return original;

      if (n > 20) n = 20;

      const absNum = Math.abs(num);
      const log10 = Math.log10(absNum);
      const exp = Math.floor(log10);

      const factor = Math.pow(10, n - exp - 1);
      const rounded = Math.round(absNum * factor) / factor;

      const roundedStr = rounded.toFixed(Math.max(0, n - exp - 1));
      const finalStr = isNegative ? '-' + roundedStr : roundedStr;

      const currentCount = countSigFigs(finalStr);
      if (currentCount < n && finalStr.includes('.')) {
        const parts = finalStr.split('.');
        const frac = parts[1] || '';
        const needed = n - countSigFigs(finalStr.replace('-', ''));
        if (needed > 0) {
          return finalStr + '0'.repeat(needed);
        }
      }

      return finalStr;
    }

    function calculate() {
      const raw = sfNumber.value.trim();
      const target = parseInt(sfCount.value, 10);

      if (!raw || isNaN(target) || target < 1) {
        sfRoundedVal.textContent = '—';
        sfOriginalCount.textContent = '—';
        sfSciNot.textContent = '—';
        sfTargetCount.textContent = '—';
        sfBreakdown.classList.add('hidden');
        return;
      }

      const originalCount = countSigFigs(raw);
      sfOriginalCount.textContent = originalCount;
      sfTargetCount.textContent = target;

      const sciNot = toScientific(raw);
      sfSciNot.innerHTML = sciNot;

      const rounded = roundToSigFigs(raw, target);
      sfRoundedVal.textContent = rounded;

      let breakdownHtml = '<p class="font-semibold text-indigo-700">Digit-level analysis:</p>';
      const digits = raw.replace(/[\-]/g, '').split('');
      let inDecimal = false;
      let firstNonZeroFound = false;
      let sigCount = 0;
      let digitInfo = '';
      for (const ch of digits) {
        if (ch === '.') { inDecimal = true; digitInfo += `<span class="text-slate-300">.</span>`; continue; }
        if (ch === '0' && !firstNonZeroFound) {
          digitInfo += `<span class="text-slate-300">${ch}</span>`;
        } else {
          firstNonZeroFound = true;
          sigCount++;
          if (sigCount <= target) {
            digitInfo += `<span class="font-bold text-indigo-700">${ch}</span>`;
          } else {
            digitInfo += `<span class="text-slate-400 line-through">${ch}</span>`;
          }
        }
      }
      breakdownHtml += `<p class="mt-1 font-mono text-lg">${digitInfo}</p>`;
      breakdownHtml += `<p class="mt-1 text-xs text-slate-400">Significant: bold indigo. Dropped: struck-through grey. Grey: not significant.</p>`;
      breakdownHtml += `<p class="mt-2">Original sig figs: ${originalCount}. Target: ${target}. Rounded: ${rounded}.</p>`;

      sfBreakdown.innerHTML = breakdownHtml;
      sfBreakdown.classList.remove('hidden');
    }

    sfNumber.addEventListener('input', calculate);
    sfCount.addEventListener('input', calculate);
    calculate();
  </script>
</ToolLayout>
