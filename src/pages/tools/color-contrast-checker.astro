---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Color Contrast Checker (WCAG)';
const description = 'Check the contrast ratio between text and background colors against WCAG AA and AAA standards for normal and large text. Free accessibility tool.';
const intro = 'Check if two colors meet WCAG accessibility contrast standards.';
const category = { id: 'images', name: 'Image Tools' };
const faqs = [
  { q: 'What ratio do I need?', a: 'WCAG AA needs 4.5:1 for normal text, 3:1 for large text; AAA needs 7:1 and 4.5:1.' },
  { q: 'What counts as large text?', a: 'Roughly 18pt (24px) or 14pt (18.66px) bold and larger.' },
  { q: 'Does this guarantee accessibility?', a: 'Contrast is one factor; full accessibility also covers structure, alt text, and keyboard use.' },
  { q: 'How is contrast ratio calculated?', a: 'It uses the WCAG relative luminance formula for each color, then compares them.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-slate-700">Text color</label>
        <div class="mt-1 flex items-center gap-3">
          <input id="textColorPicker" type="color" value="#111827" class="h-10 w-14 cursor-pointer rounded border border-slate-300 p-0.5" />
          <input id="textColorHex" type="text" value="#111827" maxlength="7" placeholder="#rrggbb" class="w-full rounded-lg border border-slate-300 p-2.5 text-sm font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Background color</label>
        <div class="mt-1 flex items-center gap-3">
          <input id="bgColorPicker" type="color" value="#ffffff" class="h-10 w-14 cursor-pointer rounded border border-slate-300 p-0.5" />
          <input id="bgColorHex" type="text" value="#ffffff" maxlength="7" placeholder="#rrggbb" class="w-full rounded-lg border border-slate-300 p-2.5 text-sm font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
    </div>

    <div class="mt-6 flex items-center justify-center">
      <div id="preview" class="w-full rounded-xl border border-slate-200 p-8 text-center text-2xl font-semibold sm:text-3xl" style="color:#111827;background-color:#ffffff;border-color:#e2e8f0;">
        Sample text
      </div>
    </div>

    <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5 text-center">
      <span class="text-sm text-slate-500">Contrast ratio</span>
      <p id="ratioDisplay" class="mt-1 text-3xl font-bold text-indigo-700">&mdash;</p>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      <div id="aaNormal" class="rounded-lg border border-slate-200 bg-white p-3 text-center text-sm font-medium text-slate-500">AA Normal <span class="ml-1.5 inline-block rounded-full px-2 py-0.5 text-xs text-white" style="background:#94a3b8;">—</span></div>
      <div id="aaLarge" class="rounded-lg border border-slate-200 bg-white p-3 text-center text-sm font-medium text-slate-500">AA Large <span class="ml-1.5 inline-block rounded-full px-2 py-0.5 text-xs text-white" style="background:#94a3b8;">—</span></div>
      <div id="aaaNormal" class="rounded-lg border border-slate-200 bg-white p-3 text-center text-sm font-medium text-slate-500">AAA Normal <span class="ml-1.5 inline-block rounded-full px-2 py-0.5 text-xs text-white" style="background:#94a3b8;">—</span></div>
      <div id="aaaLarge" class="rounded-lg border border-slate-200 bg-white p-3 text-center text-sm font-medium text-slate-500">AAA Large <span class="ml-1.5 inline-block rounded-full px-2 py-0.5 text-xs text-white" style="background:#94a3b8;">—</span></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How contrast ratio works</h2>
    <p class="mt-2 text-slate-600">The WCAG (Web Content Accessibility Guidelines) define contrast ratio as a measure of the difference in perceived luminance between two colors — typically text and its background. A higher ratio means more readable text, especially for users with low vision, color vision deficiency, or when viewing a screen in bright sunlight.</p>
    <p class="mt-3 text-slate-600">The ratio is always expressed as a single number, like 4.5:1, 7:1, or 21:1. It is calculated from the <strong>relative luminance</strong> of each color using the sRGB color space formula defined by the W3C. The scale ranges from 1:1 (no contrast, e.g. the same color on itself) to 21:1 (maximum contrast, e.g. black on white).</p>
    <div class="mt-6 flex justify-center">
      <svg viewBox="0 0 400 120" class="w-full max-w-lg">
        <defs>
          <linearGradient id="contrastGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#ef4444" />
            <stop offset="33%" stop-color="#f59e0b" />
            <stop offset="66%" stop-color="#22c55e" />
            <stop offset="100%" stop-color="#16a34a" />
          </linearGradient>
        </defs>
        <rect x="20" y="20" width="360" height="24" rx="12" fill="url(#contrastGrad)" />
        <text x="40" y="70" text-anchor="middle" class="text-xs" fill="#94a3b8" font-size="12">1:1</text>
        <text x="152" y="70" text-anchor="middle" class="text-xs" fill="#94a3b8" font-size="12">3:1</text>
        <text x="264" y="70" text-anchor="middle" class="text-xs" fill="#94a3b8" font-size="12">4.5:1</text>
        <text x="370" y="70" text-anchor="middle" class="text-xs" fill="#94a3b8" font-size="12">7:1</text>
        <text x="40" y="100" text-anchor="middle" class="text-xs" fill="#ef4444" font-size="11" font-weight="bold">Fail</text>
        <text x="152" y="100" text-anchor="middle" class="text-xs" fill="#f59e0b" font-size="11" font-weight="bold">AA Large</text>
        <text x="264" y="100" text-anchor="middle" class="text-xs" fill="#22c55e" font-size="11" font-weight="bold">AA Normal</text>
        <text x="370" y="100" text-anchor="middle" class="text-xs" fill="#16a34a" font-size="11" font-weight="bold">AAA</text>
      </svg>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula</h2>
    <div class="mt-4 space-y-3 rounded-xl border border-slate-200 bg-slate-50 p-5 font-mono text-sm text-slate-700">
      <p class="text-slate-500">Per the WCAG 2.1 specification, relative luminance <strong>L</strong> for an sRGB color is:</p>
      <div class="rounded-lg bg-white p-3">
        L = 0.2126 &times; R<sub>lin</sub> + 0.7152 &times; G<sub>lin</sub> + 0.0722 &times; B<sub>lin</sub>
      </div>
      <p class="text-slate-500">where each linearized channel is:</p>
      <div class="rounded-lg bg-white p-3">
        C<sub>lin</sub> = ( C<sub>srgb</sub> / 255 )<sup>2.2</sup> &hellip; or the piecewise sRGB formula
      </div>
      <p class="text-slate-500">The contrast ratio between two colors L1 (lighter) and L2 (darker) is:</p>
      <div class="rounded-lg bg-white p-3 font-semibold text-indigo-700">
        (L1 + 0.05) &div; (L2 + 0.05)
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="mt-4 rounded-xl border border-slate-200 bg-white p-5">
      <p class="text-sm text-slate-600">Take text color <span class="font-mono font-medium text-slate-900">#595959</span> on a white background <span class="font-mono font-medium text-slate-900">#ffffff</span>.</p>
      <div class="mt-3 rounded-lg bg-slate-50 p-4 font-mono text-sm text-slate-700">
        <span class="text-slate-500">// Convert each channel to linear sRGB</span><br />
        R<sub>lin</sub> = 0.321, G<sub>lin</sub> = 0.321, B<sub>lin</sub> = 0.321 &rarr; L<sub>text</sub> = 0.321<br />
        <span class="text-slate-500">// White is always 1.0 in relative luminance</span><br />
        L<sub>bg</sub> = 1.0<br /><br />
        Contrast = (1.0 + 0.05) &div; (0.321 + 0.05)<br />
        <span class="font-semibold text-indigo-700">= <span class="not-italic">~7.0:1</span></span>
      </div>
      <p class="mt-3 text-sm text-slate-600">A ratio of 7.0:1 passes <strong>WCAG AA</strong> (both normal and large text) and <strong>WCAG AAA</strong> (both normal and large text) &mdash; this is a very accessible color pair.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common use cases</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Designing accessible websites</h3>
        <p class="mt-1 text-sm text-slate-600">When building a website, every text element &mdash; from body copy to navigation links, button labels, and placeholder text &mdash; must meet WCAG contrast requirements. Use this checker on your brand colors early in the design process instead of discovering a violation during a late-stage audit.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Checking brand colors</h3>
        <p class="mt-1 text-sm text-slate-600">Marketing teams often choose colors for aesthetic reasons without considering accessibility. A brand&rsquo;s primary blue on a white background might look fine but could fail AA for normal text. This tool helps you find accessible tints, shades, or complementary colors that preserve the brand identity while meeting the standard.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Meeting legal accessibility requirements</h3>
        <p class="mt-1 text-sm text-slate-600">Many governments and public-sector organizations mandate WCAG 2.1 AA compliance by law (e.g. Section 508 in the US, EN 301 549 in the EU, the Accessibility for Ontarians with Disabilities Act). A contrast failure can be grounds for a compliance finding, so verifying every color combination is essential.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Email and document design</h3>
        <p class="mt-1 text-sm text-slate-600">HTML emails and PDF documents also fall under accessibility guidelines. Whether you are designing a newsletter template, a data report, or a slide deck, checking contrast ratios ensures your content is readable by people using screen readers or who have low vision.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for meeting WCAG contrast</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Large text gets a lower threshold</h3>
        <p class="mt-1 text-sm text-slate-600">The WCAG guidelines distinguish between normal text and large text because larger characters are inherently easier to read. Large text is defined as at least 18 point (24 pixels) or 14 point (18.66 pixels) bold. For large text, AA requires only 3:1 instead of 4.5:1, and AAA requires 4.5:1 instead of 7:1. This means a slightly lower-contrast color combination may still be acceptable for headings and display text even if it fails for body copy.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Never rely on color alone</h3>
        <p class="mt-1 text-sm text-slate-600">Even if your contrast ratio passes, you must not use color as the only visual means of conveying information (e.g. red text for errors, green for success). Add icons, underlines, patterns, or text labels so that users who cannot perceive the color difference still understand the message. This is WCAG success criterion 1.4.1.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Test on real screens</h3>
        <p class="mt-1 text-sm text-slate-600">A passing ratio calculated in a tool is a strong signal, but real-world factors affect perceived contrast: screen brightness, ambient lighting, anti-aliasing, and font weight. For critical text (legal disclaimers, medical information), aim well above the minimum — 7:1 or higher — to ensure readability in adverse conditions.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Include hover and focus states</h3>
        <p class="mt-1 text-sm text-slate-600">Interactive elements like links and buttons change color on hover, focus, and active states. Each of those states must independently meet the contrast requirement against the background. Use this checker to validate every state in your component design system, not just the resting state.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 flex flex-wrap gap-3">
      <a href="/tools/ppi-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-700">PPI Calculator</a>
      <a href="/tools/aspect-ratio-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-700">Aspect Ratio Calculator</a>
      <a href="/tools/image-cropper" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-700">Image Cropper</a>
    </div>
  </section>

  <script is:inline>
    const textPicker = document.getElementById('textColorPicker');
    const textHex = document.getElementById('textColorHex');
    const bgPicker = document.getElementById('bgColorPicker');
    const bgHex = document.getElementById('bgColorHex');
    const preview = document.getElementById('preview');
    const ratioDisplay = document.getElementById('ratioDisplay');
    const aaNormal = document.getElementById('aaNormal');
    const aaLarge = document.getElementById('aaLarge');
    const aaaNormal = document.getElementById('aaaNormal');
    const aaaLarge = document.getElementById('aaaLarge');

    function parseHex(v) {
      v = v.trim();
      if (v.startsWith('#')) v = v.slice(1);
      if (v.length === 3) v = v[0] + v[0] + v[1] + v[1] + v[2] + v[2];
      if (!/^[0-9a-fA-F]{6}$/.test(v)) return null;
      return {
        r: parseInt(v.slice(0, 2), 16),
        g: parseInt(v.slice(2, 4), 16),
        b: parseInt(v.slice(4, 6), 16),
      };
    }

    function toHex(n) {
      return n.toString(16).padStart(2, '0');
    }

    function rgbToHex(r, g, b) {
      return '#' + toHex(r) + toHex(g) + toHex(b);
    }

    function linearize(c) {
      c = c / 255;
      return c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
    }

    function relativeLuminance(r, g, b) {
      return 0.2126 * linearize(r) + 0.7152 * linearize(g) + 0.0722 * linearize(b);
    }

    function contrastRatio(l1, l2) {
      const lighter = Math.max(l1, l2);
      const darker = Math.min(l1, l2);
      return (lighter + 0.05) / (darker + 0.05);
    }

    function updateBadge(el, passes) {
      const badge = el.querySelector('span');
      if (passes) {
        el.className = 'rounded-lg border border-green-200 bg-green-50 p-3 text-center text-sm font-medium text-green-800';
        badge.className = 'ml-1.5 inline-block rounded-full px-2 py-0.5 text-xs text-white';
        badge.style.background = '#22c55e';
        badge.textContent = 'Pass';
      } else {
        el.className = 'rounded-lg border border-red-200 bg-red-50 p-3 text-center text-sm font-medium text-red-800';
        badge.className = 'ml-1.5 inline-block rounded-full px-2 py-0.5 text-xs text-white';
        badge.style.background = '#ef4444';
        badge.textContent = 'Fail';
      }
    }

    function update() {
      const text = parseHex(textHex.value);
      const bg = parseHex(bgHex.value);

      if (!text || !bg) {
        preview.style.color = '#111827';
        preview.style.backgroundColor = '#ffffff';
        ratioDisplay.textContent = '\u2014';
        [aaNormal, aaLarge, aaaNormal, aaaLarge].forEach(el => {
          const badge = el.querySelector('span');
          el.className = 'rounded-lg border border-slate-200 bg-white p-3 text-center text-sm font-medium text-slate-500';
          badge.className = 'ml-1.5 inline-block rounded-full px-2 py-0.5 text-xs text-white';
          badge.style.background = '#94a3b8';
          badge.textContent = '\u2014';
        });
        return;
      }

      preview.style.color = rgbToHex(text.r, text.g, text.b);
      preview.style.backgroundColor = rgbToHex(bg.r, bg.g, bg.b);

      const L1 = relativeLuminance(text.r, text.g, text.b);
      const L2 = relativeLuminance(bg.r, bg.g, bg.b);
      const ratio = contrastRatio(L1, L2);

      ratioDisplay.textContent = ratio.toFixed(1) + ':1';

      updateBadge(aaNormal, ratio >= 4.5);
      updateBadge(aaLarge, ratio >= 3.0);
      updateBadge(aaaNormal, ratio >= 7.0);
      updateBadge(aaaLarge, ratio >= 4.5);
    }

    function syncPickerToHex(picker, hexInput) {
      hexInput.value = picker.value;
      update();
    }

    function syncHexToPicker(hexInput, picker) {
      const v = hexInput.value.trim();
      if (/^#[0-9a-fA-F]{6}$/.test(v) || /^#[0-9a-fA-F]{3}$/.test(v) || /^#?[0-9a-fA-F]{6}$/.test(v) || /^#?[0-9a-fA-F]{3}$/.test(v)) {
        let hex = v.startsWith('#') ? v : '#' + v;
        if (hex.length === 4) {
          hex = '#' + hex[1] + hex[1] + hex[2] + hex[2] + hex[3] + hex[3];
        }
        picker.value = hex;
      }
      update();
    }

    textPicker.addEventListener('input', () => syncPickerToHex(textPicker, textHex));
    bgPicker.addEventListener('input', () => syncPickerToHex(bgPicker, bgHex));
    textHex.addEventListener('input', () => syncHexToPicker(textHex, textPicker));
    bgHex.addEventListener('input', () => syncHexToPicker(bgHex, bgPicker));

    update();
  </script>
</ToolLayout>
