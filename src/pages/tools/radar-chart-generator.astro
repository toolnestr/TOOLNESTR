---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Radar Chart Generator';
const description = 'Create radar/spider charts for multivariate data comparison. Compare up to 3 datasets across 3-8 axes.';
const intro = 'Create radar/spider charts for multivariate data comparison.';
const category = { id: 'charts', name: 'Charts & Graphs' };
const faqs = [
  { q: 'What is a radar chart?', a: 'A chart that displays multivariate data in a 2D polar grid with each variable on its own axis.' },
  { q: 'How many datasets can I compare?', a: 'Up to 3 datasets, each with a different color, shown as overlapping polygons.' },
  { q: 'How many axes are supported?', a: 'Between 3 and 8 axes. Fewer than 3 is a line; more than 8 gets cluttered.' },
  { q: 'When should I use a radar chart?', a: 'Excellent for comparing skills, product features, performance metrics across categories.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 grid gap-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:grid-cols-2 sm:p-6">
    <div class="space-y-4">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Number of axes</span>
        <select id="axesCount" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5" selected>5</option>
          <option value="6">6</option>
          <option value="7">7</option>
          <option value="8">8</option>
        </select>
      </label>
      <div>
        <span class="text-sm font-medium text-slate-700">Axis labels</span>
        <div id="axesContainer" class="mt-1 grid grid-cols-2 gap-2"></div>
      </div>
      <hr class="border-slate-200" />
      <div class="space-y-3">
        <span class="text-sm font-medium text-slate-700">Dataset 1</span>
        <div class="grid grid-cols-3 gap-2">
          <label class="col-span-2 block">
            <span class="text-xs text-slate-500">Name</span>
            <input id="ds1Name" type="text" value="Product A" class="mt-0.5 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </label>
          <label class="block">
            <span class="text-xs text-slate-500">Color</span>
            <input id="ds1Color" type="color" value="#6366f1" class="mt-0.5 h-9 w-full cursor-pointer rounded-lg border border-slate-300" />
          </label>
        </div>
        <label class="block">
          <span class="text-xs text-slate-500">Values (comma-separated)</span>
          <input id="ds1Values" type="text" value="80, 65, 90, 60, 75" class="mt-0.5 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
      </div>
      <hr class="border-slate-200" />
      <div class="space-y-3">
        <span class="text-sm font-medium text-slate-700">Dataset 2</span>
        <div class="grid grid-cols-3 gap-2">
          <label class="col-span-2 block">
            <span class="text-xs text-slate-500">Name</span>
            <input id="ds2Name" type="text" value="Product B" class="mt-0.5 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </label>
          <label class="block">
            <span class="text-xs text-slate-500">Color</span>
            <input id="ds2Color" type="color" value="#10b981" class="mt-0.5 h-9 w-full cursor-pointer rounded-lg border border-slate-300" />
          </label>
        </div>
        <label class="block">
          <span class="text-xs text-slate-500">Values (comma-separated)</span>
          <input id="ds2Values" type="text" value="55, 70, 45, 85, 50" class="mt-0.5 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
      </div>
      <hr class="border-slate-200" />
      <div class="space-y-3">
        <span class="text-sm font-medium text-slate-700">Dataset 3</span>
        <div class="grid grid-cols-3 gap-2">
          <label class="col-span-2 block">
            <span class="text-xs text-slate-500">Name</span>
            <input id="ds3Name" type="text" placeholder="Optional" class="mt-0.5 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </label>
          <label class="block">
            <span class="text-xs text-slate-500">Color</span>
            <input id="ds3Color" type="color" value="#f59e0b" class="mt-0.5 h-9 w-full cursor-pointer rounded-lg border border-slate-300" />
          </label>
        </div>
        <label class="block">
          <span class="text-xs text-slate-500">Values (comma-separated)</span>
          <input id="ds3Values" type="text" placeholder="e.g. 60, 50, 70, 55, 80" class="mt-0.5 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
      </div>
      <hr class="border-slate-200" />
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Chart title</span>
        <input id="chartTitle" type="text" placeholder="Product Comparison" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <button id="generateBtn" class="w-full rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">Generate Chart</button>
      <p id="err" class="hidden text-sm text-red-600"></p>
    </div>
    <div class="flex flex-col items-center justify-center">
      <div id="result" class="hidden w-full">
        <div class="w-full overflow-hidden rounded-xl border border-slate-200 bg-white p-2">
          <canvas id="chartCanvas" class="w-full"></canvas>
        </div>
        <button id="downloadBtn" class="mt-4 w-full rounded-lg bg-emerald-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-emerald-700">Download PNG</button>
      </div>
      <p id="hint" class="text-center text-sm text-slate-400">Configure your chart above and click Generate.</p>
    </div>
  </div>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" width="600" height="460" viewBox="0 0 600 460" class="w-full rounded-xl border border-slate-200 bg-white">
      <title>Radar Chart Diagram</title>
      <desc>Polar grid with 5 axes (Speed, Power, Accuracy, Durability, Range) and two overlapping polygons in indigo and emerald</desc>
      <rect width="600" height="460" fill="#f8fafc" rx="8" />
      <g transform="translate(280,225)">
        <circle cx="0" cy="0" r="40" fill="none" stroke="#e2e8f0" stroke-width="1" />
        <circle cx="0" cy="0" r="80" fill="none" stroke="#e2e8f0" stroke-width="1" />
        <circle cx="0" cy="0" r="120" fill="none" stroke="#e2e8f0" stroke-width="1" />
        <circle cx="0" cy="0" r="160" fill="none" stroke="#cbd5e1" stroke-width="1.5" />
        <line x1="0" y1="0" x2="0" y2="-160" stroke="#cbd5e1" stroke-width="1" />
        <line x1="0" y1="0" x2="152" y2="-49" stroke="#cbd5e1" stroke-width="1" />
        <line x1="0" y1="0" x2="94" y2="129" stroke="#cbd5e1" stroke-width="1" />
        <line x1="0" y1="0" x2="-94" y2="129" stroke="#cbd5e1" stroke-width="1" />
        <line x1="0" y1="0" x2="-152" y2="-49" stroke="#cbd5e1" stroke-width="1" />
        <polygon points="0,-128 91,-30 85,116 -66,91 -76,-25" fill="#6366f1" fill-opacity="0.15" stroke="#6366f1" stroke-width="2" />
        <polygon points="0,-80 107,-35 38,52 -75,104 -91,-30" fill="#10b981" fill-opacity="0.15" stroke="#10b981" stroke-width="2" />
        <circle cx="0" cy="-128" r="3" fill="#6366f1" />
        <circle cx="91" cy="-30" r="3" fill="#6366f1" />
        <circle cx="85" cy="116" r="3" fill="#6366f1" />
        <circle cx="-66" cy="91" r="3" fill="#6366f1" />
        <circle cx="-76" cy="-25" r="3" fill="#6366f1" />
        <circle cx="0" cy="-80" r="3" fill="#10b981" />
        <circle cx="107" cy="-35" r="3" fill="#10b981" />
        <circle cx="38" cy="52" r="3" fill="#10b981" />
        <circle cx="-75" cy="104" r="3" fill="#10b981" />
        <circle cx="-91" cy="-30" r="3" fill="#10b981" />
      </g>
      <text x="280" y="50" font-family="system-ui,sans-serif" font-size="13" fill="#1e293b" text-anchor="middle" font-weight="bold">Speed</text>
      <text x="445" y="163" font-family="system-ui,sans-serif" font-size="13" fill="#1e293b" text-anchor="middle" font-weight="bold">Power</text>
      <text x="390" y="400" font-family="system-ui,sans-serif" font-size="13" fill="#1e293b" text-anchor="middle" font-weight="bold">Accuracy</text>
      <text x="170" y="400" font-family="system-ui,sans-serif" font-size="13" fill="#1e293b" text-anchor="middle" font-weight="bold">Durability</text>
      <text x="115" y="163" font-family="system-ui,sans-serif" font-size="13" fill="#1e293b" text-anchor="middle" font-weight="bold">Range</text>
      <text x="280" y="52" font-family="system-ui,sans-serif" font-size="10" fill="#6366f1" text-anchor="start">80</text>
      <text x="420" y="150" font-family="system-ui,sans-serif" font-size="10" fill="#6366f1" text-anchor="start">65</text>
      <text x="355" y="385" font-family="system-ui,sans-serif" font-size="10" fill="#6366f1" text-anchor="start">90</text>
      <text x="185" y="385" font-family="system-ui,sans-serif" font-size="10" fill="#6366f1" text-anchor="start">60</text>
      <text x="85" y="150" font-family="system-ui,sans-serif" font-size="10" fill="#6366f1" text-anchor="end">75</text>
      <rect x="32" y="425" width="12" height="12" fill="#6366f1" rx="2" opacity="0.6" />
      <text x="50" y="435" font-family="system-ui,sans-serif" font-size="11" fill="#475569">Product A</text>
      <rect x="145" y="425" width="12" height="12" fill="#10b981" rx="2" opacity="0.6" />
      <text x="163" y="435" font-family="system-ui,sans-serif" font-size="11" fill="#475569">Product B</text>
    </svg>
    <figcaption class="mt-2 text-sm text-slate-500">Radar chart comparing two products across five performance axes. The indigo polygon scores high on Speed and Accuracy; the emerald polygon leads on Durability and Range.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is a radar chart?</h2>
    <p class="mt-2 text-slate-600">A radar chart — also called a spider chart, web chart, or polar chart — displays multivariate data in a two-dimensional polar grid. Each variable is assigned its own radial axis that starts from the centre and extends outward. Data values are plotted along each axis and connected by lines to form a polygon. The shape and size of the polygon reveal patterns, strengths, and weaknesses across all variables at a glance.</p>
    <p class="mt-3 text-slate-600">Radar charts are particularly effective when you need to compare multiple entities across the same set of dimensions. The overlapping polygons make it easy to see which dataset performs better on which axis, and the overall shape gives an intuitive sense of balance or imbalance in the data.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How radar charts work</h2>
    <p class="mt-2 text-slate-600">Each axis in a radar chart represents a separate variable, and all axes share a common scale. The centre point represents the minimum value (typically zero), and the outer edge of the grid represents the maximum value. Values are plotted at the appropriate distance from the centre along each axis, and consecutive points are connected with straight lines to create a closed polygon.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Axes:</span> <span class="text-slate-600">Speed, Power, Accuracy, Durability, Range</span></div>
        <div><span class="font-medium text-slate-700">Product A:</span> <span class="text-slate-600">80, 65, 90, 60, 75</span></div>
        <div><span class="font-medium text-slate-700">Product B:</span> <span class="text-slate-600">55, 70, 45, 85, 50</span></div>
        <div><span class="font-medium text-slate-700">Scale:</span> <span class="text-slate-600">0–100 (common for percentage-based comparisons)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to create a radar chart</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set up your axes</h3>
        <p class="mt-1 text-sm text-slate-600">Choose how many axes you need (3–8) and label each one. The labels appear around the chart perimeter. Each axis represents a variable you want to measure.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your datasets</h3>
        <p class="mt-1 text-sm text-slate-600">Add up to 3 datasets, each with a unique name and color. Type the values as comma-separated numbers in the same order as your axis labels. Leave a dataset blank to exclude it.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Generate and export</h3>
        <p class="mt-1 text-sm text-slate-600">Click Generate to render the radar chart with your data. The chart shows overlapping polygons for easy comparison. Download as PNG for reports and presentations.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Employee Skill Assessments</h3>
      <p class="mt-1 text-sm text-slate-600">Plot team members across skills such as communication, technical ability, leadership, creativity, and reliability. Managers can identify training needs and build balanced teams by comparing skill polygons side by side.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4CA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Product Feature Comparison</h3>
      <p class="mt-1 text-sm text-slate-600">Compare competing products across attributes like price, performance, durability, design, and support. Radar charts make it obvious which product leads in each category and where trade-offs exist.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x26BD;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sports Player Analysis</h3>
      <p class="mt-1 text-sm text-slate-600">Evaluate athletes across stats like speed, endurance, strength, agility, and accuracy. Coaches use radar charts to compare players, scout opponents, and design training programs targeting weak areas.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3AF;</span>
      <h3 class="mt-2 font-semibold text-slate-900">User Experience Evaluation</h3>
      <p class="mt-1 text-sm text-slate-600">Measure UX dimensions like learnability, efficiency, memorability, error recovery, and satisfaction. Map the experience of different user groups or compare before-and-after redesigns on a single chart.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for effective radar charts</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Keep axes independent</h3>
        <p class="mt-1 text-sm text-slate-600">Each axis should measure a distinct dimension. Avoid combining correlated metrics on the same chart — if two axes always move together, consider merging them into a single composite score.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Normalise your scales</h3>
        <p class="mt-1 text-sm text-slate-600">All axes must share the same scale range for the polygon shapes to be meaningful. A common approach is to use percentages (0–100) or z-scores. Mixing scales on different axes distorts the visual comparison.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Aim for 5–7 axes</h3>
        <p class="mt-1 text-sm text-slate-600">Three axes produce a triangle (minimal information) and more than eight axes create a cluttered, hard-to-read chart. Five to seven axes provide the best balance between detail and readability.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Limit overlapping datasets</h3>
        <p class="mt-1 text-sm text-slate-600">Comparing more than three datasets on one radar chart becomes visually confusing. If you need to compare more entities, create separate charts or use small multiples with consistent scales.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use a radar chart</h2>
    <p class="mt-2 text-slate-600">Radar charts shine when the goal is to compare multivariate profiles across a small number of entities. Use them for skill gap analysis, competitive benchmarking, product feature comparison, performance reviews, and any scenario where the overall balance across dimensions matters as much as the individual scores. The human eye quickly recognises symmetrical vs skewed polygons, making radar charts excellent for spotting outliers and dominant performers.</p>
    <p class="mt-3 text-slate-600">However, radar charts are less effective for precise value comparisons — the human eye is better at comparing bar heights or line slopes than polygon vertex positions. Always pair radar charts with exact numeric labels or a table for readers who need absolute figures.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Limitations to consider</h2>
    <p class="mt-2 text-slate-600">Radar charts have a few well-known limitations. The perceived area of a polygon can be misleading — a dataset that scores 100 on every axis creates a large outer polygon, but one that scores 50 on all axes still creates a recognisable shape. Area perception does not scale linearly, so small differences near the centre appear proportionally larger than the same differences near the outer edge.</p>
    <p class="mt-3 text-slate-600">Ordering of axes also affects how the polygon looks. Changing the axis order rotates the shape and can create a different visual impression even when the data is identical. Always present axes in a logical order (by category, ranked importance, or natural grouping) to avoid accidentally emphasising one axis over another.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Scaling and axis ranges</h2>
    <p class="mt-2 text-slate-600">This tool uses a fixed 0–100 scale for all axes to ensure consistent, readable charts. All values you enter are interpreted relative to this scale. If your raw data has a different range (e.g. 1–5 Likert scores or 0–10 ratings), multiply each value by a factor that maps it onto 0–100. For example, a Likert score of 4 out of 5 becomes 80 on the 0–100 scale. This normalisation ensures that every axis contributes equally to the final chart and that polygon shapes reflect relative performance rather than arbitrary differences in measurement units.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <ul class="mt-3 list-disc space-y-1 pl-5 text-slate-600">
      <li><a href="/tools/pie-chart-generator" class="text-indigo-600 hover:text-indigo-700 hover:underline">Pie Chart Generator</a> — show proportions of a whole with circular slices</li>
      <li><a href="/tools/scatter-plot-generator" class="text-indigo-600 hover:text-indigo-700 hover:underline">Scatter Plot Generator</a> — visualise relationships between two numerical variables</li>
      <li><a href="/tools/box-plot-generator" class="text-indigo-600 hover:text-indigo-700 hover:underline">Box Plot Generator</a> — display distribution statistics with quartiles and outliers</li>
    </ul>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);
    const axesCount = $('axesCount');
    const axesContainer = $('axesContainer');
    const ds1Name = $('ds1Name');
    const ds1Values = $('ds1Values');
    const ds1Color = $('ds1Color');
    const ds2Name = $('ds2Name');
    const ds2Values = $('ds2Values');
    const ds2Color = $('ds2Color');
    const ds3Name = $('ds3Name');
    const ds3Values = $('ds3Values');
    const ds3Color = $('ds3Color');
    const chartTitle = $('chartTitle');
    const canvas = $('chartCanvas');
    const result = $('result');
    const hint = $('hint');
    const err = $('err');
    const generateBtn = $('generateBtn');
    const downloadBtn = $('downloadBtn');

    const DEFAULT_LABELS = ['Speed', 'Power', 'Accuracy', 'Durability', 'Range', 'Agility', 'Endurance', 'Strength'];

    function buildAxisInputs(count) {
      axesContainer.innerHTML = '';
      for (let i = 0; i < count; i++) {
        const label = DEFAULT_LABELS[i] || 'Axis ' + (i + 1);
        const wrapper = document.createElement('div');
        wrapper.innerHTML =
          '<label class="block text-xs text-slate-500">Axis ' + (i + 1) +
          '<input type="text" value="' + label +
          '" class="axis-label mt-0.5 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />' +
          '</label>';
        axesContainer.appendChild(wrapper);
      }
    }

    axesCount.addEventListener('change', function () {
      buildAxisInputs(parseInt(axesCount.value));
    });
    buildAxisInputs(parseInt(axesCount.value));

    async function generateChart() {
      var labels = [];
      document.querySelectorAll('.axis-label').forEach(function (el) {
        var v = el.value.trim();
        if (v) labels.push(v);
      });

      if (labels.length < 3) {
        err.textContent = 'Enter at least 3 axis labels.';
        err.classList.remove('hidden');
        return;
      }

      var dsConfigs = [
        { name: ds1Name, values: ds1Values, color: ds1Color },
        { name: ds2Name, values: ds2Values, color: ds2Color },
        { name: ds3Name, values: ds3Values, color: ds3Color },
      ];

      var datasets = [];
      for (var i = 0; i < dsConfigs.length; i++) {
        var cfg = dsConfigs[i];
        var name = cfg.name.value.trim();
        var vals = cfg.values.value.split(',').map(function (s) { return parseFloat(s.trim()); }).filter(function (n) { return !isNaN(n); });
        if (!name || vals.length === 0) continue;
        if (vals.length !== labels.length) {
          err.textContent = 'Dataset "' + name + '" has ' + vals.length + ' values but you defined ' + labels.length + ' axes.';
          err.classList.remove('hidden');
          return;
        }
        datasets.push({
          label: name,
          data: vals,
          backgroundColor: cfg.color.value + '33',
          borderColor: cfg.color.value,
          borderWidth: 2,
          pointBackgroundColor: cfg.color.value,
          pointRadius: 4,
          pointHoverRadius: 6,
        });
      }

      if (datasets.length === 0) {
        err.textContent = 'Enter at least one dataset with a name and values.';
        err.classList.remove('hidden');
        return;
      }
      err.classList.add('hidden');

      try {
        var mod = await import('https://esm.sh/chart.js@4');
        var Chart = mod.Chart;
        var RadarController = mod.RadarController;
        var RadialLinearScale = mod.RadialLinearScale;
        var PointElement = mod.PointElement;
        var LineElement = mod.LineElement;
        var Filler = mod.Filler;
        var Legend = mod.Legend;
        var TitleMod = mod.Title;
        var Tooltip = mod.Tooltip;
        Chart.register(RadarController, RadialLinearScale, PointElement, LineElement, Filler, Legend, TitleMod, Tooltip);
      } catch (e) {
        err.textContent = 'Failed to load Chart.js library. Check your internet connection and try again.';
        err.classList.remove('hidden');
        return;
      }

      if (window._radarChart) {
        window._radarChart.destroy();
      }

      var titleText = chartTitle.value.trim();

      var rect = canvas.parentElement.getBoundingClientRect();
      var w = Math.min(rect.width || 600, 600);

      window._radarChart = new Chart(canvas, {
        type: 'radar',
        data: {
          labels: labels,
          datasets: datasets,
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              position: 'bottom',
              labels: { font: { size: 12 }, padding: 16 },
            },
            title: {
              display: !!titleText,
              text: titleText || '',
              font: { size: 16, weight: 'bold' },
              padding: { bottom: 12 },
            },
            tooltip: {
              callbacks: {
                label: function (ctx) {
                  return ctx.dataset.label + ': ' + ctx.parsed.r;
                },
              },
            },
          },
          scales: {
            r: {
              beginAtZero: true,
              max: 100,
              ticks: {
                stepSize: 20,
                backdropColor: 'transparent',
                font: { size: 10 },
              },
              pointLabels: {
                font: { size: 11, weight: 'bold' },
                padding: 8,
              },
              grid: {
                color: ['#e2e8f0', '#e2e8f0', '#e2e8f0', '#e2e8f0', '#cbd5e1'],
              },
              angleLines: {
                color: '#cbd5e1',
              },
            },
          },
        },
      });

      result.classList.remove('hidden');
      hint.classList.add('hidden');
    }

    generateBtn.addEventListener('click', generateChart);
    downloadBtn.addEventListener('click', function () {
      if (!window._radarChart) return;
      var link = document.createElement('a');
      link.download = 'radar-chart.png';
      link.href = canvas.toDataURL('image/png');
      link.click();
    });
  </script>
</ToolLayout>
