---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Fuel Economy Converter';
const description =
  'Convert fuel economy between MPG (US and UK), L/100km, and km/L with instant results.';
const intro =
  'Convert fuel economy between MPG (US and UK), litres per 100 kilometres, and kilometres per litre.';
const category = { id: 'converters', name: 'Converters' };
const faqs = [
  { q: 'What is the difference between US MPG and UK MPG?', a: 'A US gallon is 3.785 litres while a UK (imperial) gallon is 4.546 litres. A car that does 30 MPG US gets 36 MPG UK.' },
  { q: 'Which fuel economy unit is most common?', a: 'L/100km is standard in Europe, Canada, Australia, and most of the world. MPG is standard in the US and UK.' },
  { q: 'Is higher or lower L/100km better?', a: 'Lower L/100km is better — it means you burn fewer litres per 100 km. For MPG, higher is better.' },
  { q: 'How do I convert L/100km to MPG?', a: 'Divide 235.215 by L/100km for US MPG. Divide 282.481 by L/100km for UK MPG.' },
  { q: 'What is a good fuel economy?', a: 'Under 6 L/100km (39+ MPG) is excellent, 6–8 L/100km (29–39 MPG) is average, over 10 L/100km (under 24 MPG) is poor.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Enter value</span>
      <input id="val" type="number" step="any" min="0" value="8"
        class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </label>
    <label class="block mt-3">
      <span class="text-sm font-medium text-slate-700">From unit</span>
      <select id="fromUnit"
        class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="lp100k" selected>L/100km</option>
        <option value="mpgus">MPG (US)</option>
        <option value="mpguk">MPG (UK)</option>
        <option value="kmpl">km/L</option>
      </select>
    </label>
    <div class="mt-6 grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">L/100km</div>
        <div id="r-lp100k" class="mt-1 text-2xl font-bold text-slate-800">—</div>
      </div>
      <div class="rounded-xl bg-indigo-50 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-indigo-600">km/L</div>
        <div id="r-kmpl" class="mt-1 text-2xl font-bold text-indigo-700">—</div>
      </div>
      <div class="rounded-xl bg-emerald-50 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-emerald-600">MPG (US)</div>
        <div id="r-mpgus" class="mt-1 text-2xl font-bold text-emerald-700">—</div>
      </div>
      <div class="rounded-xl bg-amber-50 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-amber-600">MPG (UK)</div>
        <div id="r-mpguk" class="mt-1 text-2xl font-bold text-amber-700">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="240" viewBox="0 0 800 240" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fe-chart-title fe-chart-desc">
      <title id="fe-chart-title">Fuel economy conversion curve</title>
      <desc id="fe-chart-desc">Graph showing the nonlinear relationship between MPG and L/100km with labelled axis</desc>
      <rect x="60" y="20" width="680" height="180" rx="8" fill="#f8fafc" stroke="#e2e8f0" />
      <text x="400" y="14" text-anchor="middle" fill="#475569" font-size="13" font-weight="bold">MPG (US) vs L/100km — nonlinear inverse relationship</text>
      <line x1="100" y1="40" x2="100" y2="180" stroke="#cbd5e1" stroke-width="1" />
      <line x1="100" y1="180" x2="720" y2="180" stroke="#cbd5e1" stroke-width="1" />
      <text x="80" y="110" text-anchor="middle" fill="#64748b" font-size="11" transform="rotate(-90,80,110)">L/100km</text>
      <text x="410" y="200" text-anchor="middle" fill="#64748b" font-size="11">MPG (US)</text>
      <text x="110" y="172" fill="#94a3b8" font-size="10">10</text>
      <text x="180" y="172" fill="#94a3b8" font-size="10">20</text>
      <text x="260" y="172" fill="#94a3b8" font-size="10">30</text>
      <text x="340" y="172" fill="#94a3b8" font-size="10">40</text>
      <text x="410" y="172" fill="#94a3b8" font-size="10">50</text>
      <text x="480" y="172" fill="#94a3b8" font-size="10">60</text>
      <text x="560" y="172" fill="#94a3b8" font-size="10">70</text>
      <text x="95" y="50" fill="#94a3b8" font-size="10">30</text>
      <text x="95" y="78" fill="#94a3b8" font-size="10">20</text>
      <text x="95" y="111" fill="#94a3b8" font-size="10">10</text>
      <text x="95" y="140" fill="#94a3b8" font-size="10">5</text>
      <path d="M110,170 Q200,155 270,130 Q340,105 410,75 Q480,55 550,40 Q620,32 700,28" stroke="#6366f1" stroke-width="3" fill="none" stroke-linecap="round" />
      <circle cx="270" cy="130" r="5" fill="#f97316" />
      <text x="280" y="124" fill="#f97316" font-size="11" font-weight="bold">30 MPG = 7.8 L/100km</text>
      <line x1="270" y1="130" x2="270" y2="180" stroke="#f97316" stroke-width="1" stroke-dasharray="3 3" />
      <line x1="100" y1="130" x2="270" y2="130" stroke="#f97316" stroke-width="1" stroke-dasharray="3 3" />
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The relationship between MPG and L/100km follows a hyperbolic curve</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fuel economy conversion works</h2>
    <p class="mt-2 text-slate-600">
      Fuel economy is measured in different units around the world, but they all describe the same thing: how far a vehicle travels on a given amount of fuel. L/100km (litres per 100 kilometres) and km/L (kilometres per litre) are metric units. MPG (miles per gallon) is used in the US and UK, with the important distinction that a US gallon (3.785 L) is smaller than a UK imperial gallon (4.546 L).
    </p>
    <p class="mt-3 text-slate-600">
      The relationship between L/100km and MPG is inversely proportional — as one goes up, the other goes down. This means the conversion is nonlinear: improving from 10 to 12 MPG saves more fuel than improving from 30 to 32 MPG. This converter handles all four units simultaneously so you can see the full picture at once.
    </p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-1 rounded-xl bg-white p-4 font-mono text-sm text-slate-700">
      <div><span class="font-semibold">L/100km to MPG (US):</span> MPG = 235.215 ÷ L/100km</div>
      <div><span class="font-semibold">L/100km to MPG (UK):</span> MPG = 282.481 ÷ L/100km</div>
      <div><span class="font-semibold">L/100km to km/L:</span> km/L = 100 ÷ L/100km</div>
    </div>
    <h3 class="mt-4 font-semibold text-slate-900">Worked example</h3>
    <p class="mt-1 text-sm text-slate-600">Convert <strong>8 L/100km</strong> to all units.</p>
    <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
      <div><span class="font-medium text-slate-700">MPG (US):</span> <span class="text-slate-600">235.215 ÷ 8 = 29.4 MPG</span></div>
      <div><span class="font-medium text-slate-700">MPG (UK):</span> <span class="text-slate-600">282.481 ÷ 8 = 35.3 MPG</span></div>
      <div><span class="font-medium text-slate-700">km/L:</span> <span class="text-slate-600">100 ÷ 8 = 12.5 km/L</span></div>
      <div><span class="font-medium text-slate-700">Annual fuel (15,000 km):</span> <span class="text-slate-600">15000 ÷ 100 × 8 = 1,200 L</span></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚗</span>
      <h3 class="mt-2 font-semibold text-slate-900">Car Shopping Comparison</h3>
      <p class="mt-1 text-sm text-slate-600">Compare vehicles from different markets. Convert a European car's L/100km to MPG to compare with US models.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📋</span>
      <h3 class="mt-2 font-semibold text-slate-900">Road Trip Planning</h3>
      <p class="mt-1 text-sm text-slate-600">Know your car's MPG but travelling through a country that lists fuel economy in L/100km? Convert instantly.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔬</span>
      <h3 class="mt-2 font-semibold text-slate-900">Fleet Management</h3>
      <p class="mt-1 text-sm text-slate-600">Standardise fuel economy across a mixed fleet of US and imported vehicles into a single metric.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📊</span>
      <h3 class="mt-2 font-semibold text-slate-900">Efficiency Tracking</h3>
      <p class="mt-1 text-sm text-slate-600">Track your car's fuel economy over time. Enter fill-up data and convert between units for your log.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the fuel economy converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your value</h3>
        <p class="mt-1 text-sm text-slate-600">Type the fuel economy number you want to convert, like 8 for 8 L/100km.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose the unit</h3>
        <p class="mt-1 text-sm text-slate-600">Select whether your number is L/100km, MPG (US), MPG (UK), or km/L.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">See all equivalents</h3>
        <p class="mt-1 text-sm text-slate-600">All four units update instantly. Compare US MPG vs UK MPG and metric at a glance.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for fuel economy</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always check which gallon</h3>
        <p class="mt-1 text-sm text-slate-600">UK MPG is about 20% higher than US MPG for the same fuel efficiency. A 40 MPG UK car is only 33 MPG US. Always specify which gallon you are using.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Lower L/100km is better</h3>
        <p class="mt-1 text-sm text-slate-600">Unlike MPG where higher is better, L/100km is the opposite. This inverse relationship can be confusing when switching between the two systems.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Fuel economy varies by driving</h3>
        <p class="mt-1 text-sm text-slate-600">City driving typically uses 20–40% more fuel than highway cruising. Use your combined rating rather than the highway figure for accurate annual estimates.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use L/100km for fuel cost</h3>
        <p class="mt-1 text-sm text-slate-600">Most fuel cost calculators work in L/100km. Convert your MPG to L/100km first, then use it with our fuel cost calculator for accurate trip budgeting.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/fuel-cost-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">⛽</span>
        <h3 class="mt-1 font-semibold text-slate-900">Fuel Cost Calculator</h3>
        <p class="text-sm text-slate-600">Estimate trip fuel cost from distance and efficiency.</p>
      </a>
      <a href="/tools/mpg-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📏</span>
        <h3 class="mt-1 font-semibold text-slate-900">MPG Calculator</h3>
        <p class="text-sm text-slate-600">Calculate your car's actual MPG from odometer and fuel.</p>
      </a>
      <a href="/tools/ev-efficiency-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">⚡</span>
        <h3 class="mt-1 font-semibold text-slate-900">EV Efficiency Calculator</h3>
        <p class="text-sm text-slate-600">Convert between kWh/100km and MPGe.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    function fmt(n) { return n.toLocaleString(undefined, { maximumFractionDigits: 2 }); }
    function update() {
      const v = parseFloat(document.getElementById('val').value) || 0;
      const u = document.getElementById('fromUnit').value;
      let lp100k;
      if (u === 'lp100k') lp100k = v;
      else if (u === 'mpgus') lp100k = 235.215 / v;
      else if (u === 'mpguk') lp100k = 282.481 / v;
      else if (u === 'kmpl') lp100k = 100 / v;
      if (v <= 0) { lp100k = 0; }
      document.getElementById('r-lp100k').textContent = lp100k > 0 ? fmt(lp100k) + ' L/100km' : '—';
      document.getElementById('r-kmpl').textContent = lp100k > 0 ? fmt(100 / lp100k) + ' km/L' : '—';
      document.getElementById('r-mpgus').textContent = lp100k > 0 ? fmt(235.215 / lp100k) + ' MPG' : '—';
      document.getElementById('r-mpguk').textContent = lp100k > 0 ? fmt(282.481 / lp100k) + ' MPG' : '—';
    }
    document.getElementById('val').addEventListener('input', update);
    document.getElementById('fromUnit').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
