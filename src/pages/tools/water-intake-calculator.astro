---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Daily Water Intake Calculator';
const description =
  'Estimate how much water to drink per day in litres, cups, and oz based on your weight, exercise level, and climate. Get a personalized hydration target.';
const intro =
  'Estimate how much water to drink per day from your weight, exercise, and climate.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'Is it really 8 glasses a day?', a: 'That is a rough rule; actual needs scale with weight, activity, and climate.' },
  { q: 'Can I drink too much water?', a: 'Yes, rarely — excessive intake can dilute sodium; this tool targets normal ranges.' },
  { q: 'Do coffee and tea count?', a: 'They contribute to fluids despite mild diuretic effects; water is still best.' },
  { q: 'Does the climate really matter?', a: 'Yes — hot weather increases sweating and fluid loss, so you need more water.' },
];
const sources = [
  { html: "<strong>NIH / National Institutes of Health</strong> and <strong>CDC</strong> reference values and formulas. <a href=\"https://www.nih.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nih.gov</a>" },
  { html: "<strong>Peer-reviewed equations</strong> (e.g. Mifflin-St Jeor, Harris-Benedict) as originally published." },
  { html: "<strong>ACOG</strong> for pregnancy, ovulation and due-date methodology. <a href=\"https://www.acog.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">acog.org</a>" },
];
const sourcesNote = "Not medical advice. Estimates only — consult a qualified healthcare professional for any personal health decision.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="weight" type="number" step="any" placeholder="e.g. 70" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Exercise per day (minutes)</span>
        <input id="exercise" type="number" step="1" value="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Climate</span>
        <div class="mt-1 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
          <button id="c-normal" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Normal</button>
          <button id="c-hot" class="flex-1 rounded-lg py-2 text-slate-500">Hot</button>
        </div>
      </label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Recommended daily water</div>
        <div id="r-litres" class="mt-1 text-3xl font-bold">—</div>
        <div class="mt-1 text-sm opacity-80">litres per day</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center">
          <div class="text-sm text-slate-500">Cups</div>
          <div id="r-cups" class="mt-1 text-xl font-bold text-slate-800">—</div>
          <div class="text-xs text-slate-400">(≈4.2 cups/L)</div>
        </div>
        <div class="rounded-xl bg-slate-50 p-4 text-center">
          <div class="text-sm text-slate-500">Fluid oz</div>
          <div id="r-oz" class="mt-1 text-xl font-bold text-slate-800">—</div>
          <div class="text-xs text-slate-400">(≈33.8 oz/L)</div>
        </div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your weight to see an estimate.</p>
    <p class="mt-3 text-center text-xs text-slate-400">This is a guideline, not a strict medical rule.</p>
  </div>

  <p class="mt-4 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">
    ⚕️ This tool is for general information only and is not medical advice. Talk to a healthcare
    professional about your individual hydration needs.
  </p>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="wi-title wi-desc">
      <title id="wi-title">Water intake factors diagram</title>
      <desc id="wi-desc">Flow diagram showing weight plus exercise plus climate feeding into a daily water target.</desc>
      <rect x="40" y="75" width="150" height="50" rx="10" fill="#6366f1" />
      <text x="115" y="105" text-anchor="middle" font-size="14" fill="#fff" font-weight="bold">Weight</text>
      <rect x="230" y="75" width="150" height="50" rx="10" fill="#6366f1" />
      <text x="305" y="105" text-anchor="middle" font-size="14" fill="#fff" font-weight="bold">Exercise</text>
      <rect x="420" y="75" width="150" height="50" rx="10" fill="#6366f1" />
      <text x="495" y="105" text-anchor="middle" font-size="14" fill="#fff" font-weight="bold">Climate</text>
      <line x1="190" y1="100" x2="230" y2="100" stroke="#94a3b8" stroke-width="2" />
      <line x1="380" y1="100" x2="420" y2="100" stroke="#94a3b8" stroke-width="2" />
      <line x1="495" y1="125" x2="495" y2="150" stroke="#94a3b8" stroke-width="2" />
      <line x1="305" y1="125" x2="305" y2="150" stroke="#94a3b8" stroke-width="2" />
      <line x1="115" y1="125" x2="115" y2="150" stroke="#94a3b8" stroke-width="2" />
      <line x1="115" y1="150" x2="495" y2="150" stroke="#94a3b8" stroke-width="2" />
      <line x1="305" y1="150" x2="305" y2="155" stroke="#94a3b8" stroke-width="2" />
      <polygon points="495,155 485,145 505,145" fill="#94a3b8" />
      <rect x="570" y="75" width="190" height="50" rx="10" fill="#22c55e" />
      <text x="665" y="105" text-anchor="middle" font-size="14" fill="#fff" font-weight="bold">Daily Water</text>
      <line x1="495" y1="100" x2="570" y2="100" stroke="#94a3b8" stroke-width="2" />
      <polygon points="570,100 560,95 560,105" fill="#94a3b8" />
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Your weight, exercise level, and climate all affect how much water you need each day.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How daily water intake is calculated</h2>
    <p class="mt-2 text-slate-600">
      This calculator uses a simple evidence-based formula that adjusts your baseline water needs for activity and environment. The general recommendation from health authorities is around 30–40 ml of water per kilogram of body weight, with additional allowances for exercise and heat exposure.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-white p-4">
      <p class="font-semibold text-slate-900">The formula</p>
      <p class="mt-1 text-slate-600">
        <strong>Base</strong> = weight (kg) × 33 ml<br />
        <strong>Exercise adjustment</strong> = (minutes ÷ 30) × 350 ml<br />
        <strong>Climate adjustment</strong> = 500 ml if hot<br />
        <strong>Total (ml)</strong> = base + exercise + climate<br />
        <strong>Total (L)</strong> = total ml ÷ 1,000
      </p>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A person who weighs 70 kg and exercises for 30 minutes per day in a normal climate wants to know their daily water target.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">70 kg</span></div>
        <div><span class="font-medium text-slate-700">Base:</span> <span class="text-slate-600">70 × 33 = 2,310 ml</span></div>
        <div><span class="font-medium text-slate-700">Exercise:</span> <span class="text-slate-600">30 min → (30 ÷ 30) × 350 = 350 ml</span></div>
        <div><span class="font-medium text-slate-700">Climate:</span> <span class="text-slate-600">Normal → 0 ml</span></div>
        <div><span class="font-medium text-slate-700">Total:</span> <span class="text-slate-600">2,310 + 350 + 0 = 2,660 ml ≈ <strong>2.7 L/day</strong></span></div>
        <div><span class="font-medium text-slate-700">In cups:</span> <span class="text-slate-600">2.66 × 4.2 ≈ 11 cups</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-2xl">🎯</span>
        <h3 class="mt-2 font-semibold text-slate-900">Daily hydration goal</h3>
        <p class="mt-1 text-sm text-slate-600">Set a personalised daily water target based on your body weight rather than following generic advice. Knowing your number makes it easier to stay on track.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-2xl">🏃</span>
        <h3 class="mt-2 font-semibold text-slate-900">Adjusting for workouts</h3>
        <p class="mt-1 text-sm text-slate-600">Exercise increases fluid loss through sweat and breathing. Use the calculator to add the extra water you need on training days so you can perform and recover better.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-2xl">☀️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Hot climate adjustment</h3>
        <p class="mt-1 text-sm text-slate-600">When the temperature rises, your body sweats more to cool down. Toggle to "Hot" to account for the additional fluid loss during summer months or in tropical climates.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Practical hydration tips</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Food counts too</h3>
        <p class="mt-1 text-sm text-slate-600">
          About 20–30% of your daily water comes from food. Fruits and vegetables like watermelon, cucumber, oranges, and lettuce have high water content. Soups, stews, and smoothies also contribute significantly to your total fluid intake. The calculator estimates your total water needs from all sources, so you don't need to drink every single millilitre — food counts toward the goal.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Thirst and urine colour are real-time guides</h3>
        <p class="mt-1 text-sm text-slate-600">
          Your body has built-in hydration signals. Thirst is an obvious but slightly delayed cue — by the time you feel thirsty, you may already be mildly dehydrated. Urine colour is a more reliable daily indicator: pale straw or light yellow means you are well-hydrated, while dark amber suggests you need to drink more. Clear urine can mean you are over-hydrated, which is rarely harmful but suggests you can ease up.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Building a hydration habit</h3>
        <p class="mt-1 text-sm text-slate-600">
          The easiest way to meet your target is to spread intake across the day rather than chugging large amounts at once. Keep a reusable water bottle on your desk and refill it at set times — first thing in the morning, with each meal, and after exercise. Many people find that using a marked bottle or setting phone reminders helps them stay consistent until the habit becomes automatic.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Do other drinks count?</h3>
        <p class="mt-1 text-sm text-slate-600">
          Yes — coffee, tea, milk, and juice all contribute to your daily fluid balance. While caffeine has a mild diuretic effect, the water in coffee and tea still counts toward hydration for most people. Sugary sodas and energy drinks provide water but come with extra calories and additives that make them a less healthy choice. Plain water remains the best option because it hydrates without any downsides.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-amber-200 bg-amber-50 p-6">
    <h2 class="text-lg font-bold text-amber-900">Medical disclaimer</h2>
    <p class="mt-2 text-sm text-amber-800">
      This calculator provides a general estimate of daily water needs based on common physiological formulas. It is not a substitute for professional medical advice. Individual hydration requirements vary based on health conditions, medication use, pregnancy, breastfeeding, kidney function, and other factors. People with kidney disease, heart conditions, or fluid-restricted diets should consult their doctor before changing their water intake. If you experience symptoms of dehydration (dizziness, confusion, dark urine, dry mouth) or over-hydration (nausea, headache, confusion), seek medical attention. For general information only, not medical advice.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 grid gap-3 sm:grid-cols-3">
      <a href="/tools/calorie-deficit-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-indigo-600 transition hover:border-indigo-300 hover:shadow-sm">
        Calorie Deficit Calculator
      </a>
      <a href="/tools/bmr-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-indigo-600 transition hover:border-indigo-300 hover:shadow-sm">
        BMR Calculator
      </a>
      <a href="/tools/ideal-weight/" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-indigo-600 transition hover:border-indigo-300 hover:shadow-sm">
        Ideal Weight Calculator
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let hot = false;

    function update() {
      const wt = parseFloat(el('weight').value);
      const ex = parseInt(el('exercise').value, 10) || 0;
      if (!wt || wt <= 0) {
        el('result').classList.add('hidden');
        el('hint').classList.remove('hidden');
        return;
      }
      const base = wt * 33;
      const exAdj = Math.floor(ex / 30) * 350;
      const clAdj = hot ? 500 : 0;
      let total = base + exAdj + clAdj;
      if (total < 500) total = 500;
      if (total > 10000) total = 10000;
      const litres = total / 1000;
      const cups = litres * 4.2;
      const oz = litres * 33.8;
      el('r-litres').textContent = litres.toFixed(1) + ' L';
      el('r-cups').textContent = cups.toFixed(0);
      el('r-oz').textContent = oz.toFixed(0);
      el('result').classList.remove('hidden');
      el('hint').classList.add('hidden');
    }

    function setClimate(isHot) {
      hot = isHot;
      el('c-normal').className = 'flex-1 rounded-lg py-2 ' + (!isHot ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('c-hot').className = 'flex-1 rounded-lg py-2 ' + (isHot ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    el('c-normal').addEventListener('click', () => setClimate(false));
    el('c-hot').addEventListener('click', () => setClimate(true));
    el('weight').addEventListener('input', update);
    el('exercise').addEventListener('input', update);
  </script>
</ToolLayout>
