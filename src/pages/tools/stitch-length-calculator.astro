---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Stitch Length Calculator';
const description = 'Convert sewing machine stitch length between millimeters and stitches per inch (SPI). Get the right setting for any fabric or sewing technique.';
const intro = 'Convert stitch length between millimeters and stitches per inch (SPI).';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why do vintage patterns specify SPI instead of millimeters?', a: 'Stitches per inch (SPI) was the standard way to specify stitch density on older sewing machines, especially in the US, before millimeter-based stitch length dials became the modern standard on most machines.' },
  { q: 'What stitch length should I use for general sewing?', a: 'A stitch length of about 2.5mm (roughly 10 SPI) is a common default for medium-weight woven fabric; use a shorter stitch (1.5-2mm) for delicate fabric or a longer stitch (3-4mm) for basting or topstitching.' },
  { q: 'Does a shorter stitch length always mean a stronger seam?', a: 'Generally yes, up to a point — shorter stitches distribute stress across more stitch points, but too short a stitch on some fabrics can perforate and weaken the fabric along the seam line, so there\'s a practical lower limit depending on fabric weight.' },
  { q: 'Is this conversion exact?', a: 'Yes — it uses the exact inch-to-millimeter conversion (25.4mm per inch), so converting between SPI and millimeters is precise, not an approximation.' },
];
const howTo = {
  name: 'How to convert stitch length',
  steps: [
    { name: 'Enter the known value', text: 'Enter your stitch length in millimeters, or your stitches-per-inch count.' },
    { name: 'Choose the direction', text: 'Select which unit you\'re converting from.' },
    { name: 'Read the converted value', text: 'The equivalent stitch length in the other unit appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['mm → SPI', 'SPI → mm'].map((d) => (
        <button data-mode={d} class="mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span id="input-label" class="text-sm font-medium text-slate-700">Stitch length (mm)</span>
      <input id="value" type="number" step="any" placeholder="e.g. 2.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div id="output-label" class="text-sm opacity-80">Stitches per inch</div>
        <div id="r-value" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="160" viewBox="0 0 800 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="slc-title slc-desc">
      <title id="slc-title">Row of stitches along one inch of fabric</title>
      <desc id="slc-desc">A horizontal line with evenly spaced tick marks representing individual stitches within a one-inch span</desc>
      <line x1="100" y1="90" x2="700" y2="90" stroke="#c026d3" stroke-width="2" />
      {[100, 160, 220, 280, 340, 400, 460, 520, 580, 640, 700].map((x) => (
        <line x1={x} y1="80" x2={x} y2="100" stroke="#c026d3" stroke-width="2" />
      ))}
      <line x1="100" y1="120" x2="700" y2="120" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="400" y="140" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">One inch of stitching</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Stitches per inch counts how many stitches fit in one inch of seam</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How stitch length conversion works</h2>
    <p class="mt-2 text-slate-600">
      Stitch length in millimeters measures the physical distance covered by one stitch, while stitches per inch (SPI) counts how many stitches fit into one inch of seam — the two are simply inverse measures of the same thing, connected through the fixed conversion of 25.4 millimeters per inch. Dividing 25.4 by the millimeter stitch length gives SPI, and dividing 25.4 by the SPI count gives the millimeter stitch length.
    </p>
    <p class="mt-3 text-slate-600">
      This matters most when working from an older or imported pattern that specifies stitch settings in a system your machine doesn't use directly — a vintage American pattern calling for "12 stitches per inch" translates to a 25.4 ÷ 12 ≈ 2.1mm setting on a modern millimeter-dial machine.
    </p>
    <p class="mt-3 text-xs text-slate-400">This uses the exact international inch-to-millimeter conversion (1 inch = 25.4mm), not an approximation.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A modern machine is set to a 2.5mm stitch length, and a vintage pattern specifies the equivalent in stitches per inch.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Stitch length:</span> <span class="text-slate-600">2.5 mm</span></div>
        <div><span class="font-medium text-slate-700">SPI:</span> <span class="text-slate-600">25.4 ÷ 2.5 = <strong>10.16 SPI</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Following a vintage sewing pattern or a historical costuming reference is the most common place SPI specifications appear, since many older American patterns and tailoring references were written before millimeter-dial machines became standard — converting the specified SPI to a millimeter setting lets a modern sewist replicate the intended stitch density accurately.
    </p>
    <p class="mt-3 text-slate-600">
      Quilters also reference SPI frequently, particularly for hand-quilting stitch density comparisons, where a higher SPI count is traditionally associated with finer, more skilled hand-quilting work — converting that traditional benchmark to a machine's millimeter setting helps replicate a similar look by machine.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A higher SPI number means a longer stitch." <strong class="text-slate-900">The opposite.</strong> More stitches per inch means each individual stitch is shorter, not longer — SPI and millimeter stitch length move in opposite directions from each other.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Every sewing machine's stitch length dial is calibrated identically." <strong class="text-slate-900">Not guaranteed.</strong> While most modern machines use millimeter settings, exact calibration can vary slightly between brands and models, so test a sample seam when precision genuinely matters.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/needle-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Needle Size Calculator</a>
      <a href="/tools/thread-consumption-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Thread Consumption Calculator</a>
      <a href="/tools/seam-allowance-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Seam Allowance Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'mm → SPI';
    const CONST = 25.4;

    function update() {
      const v = parseFloat(el('value').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const result = CONST / v;
      el('r-value').textContent = result.toFixed(2);
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach((b) => {
          b.className = 'mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'mode-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        mode = btn.dataset.mode;
        el('input-label').textContent = mode === 'mm → SPI' ? 'Stitch length (mm)' : 'Stitches per inch (SPI)';
        el('output-label').textContent = mode === 'mm → SPI' ? 'Stitches per inch' : 'Stitch length (mm)';
        el('value').placeholder = mode === 'mm → SPI' ? 'e.g. 2.5' : 'e.g. 10';
        update();
      });
    });

    el('value').addEventListener('input', update);
    document.querySelector('.mode-btn').click();
  </script>
</ToolLayout>
