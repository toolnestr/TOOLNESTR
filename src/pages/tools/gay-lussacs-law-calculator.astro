---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Gay-Lussac's Law Calculator";
const description = "Gay-Lussac's Law calculator with static 3D diagrams and charts. Solve P1/T1 = P2/T2 for any variable.";
const intro = "Solve P₁/T₁ = P₂/T₂ for any of the four variables — temperature is always converted to kelvin automatically. Two static 3D diagrams show a sealed rigid vessel heating up and the family of P–T lines through absolute zero, alongside charts of the classic straight-line relationship.";
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is Gay-Lussac's law?", a: "Gay-Lussac's law states that at constant volume and a fixed amount of gas, pressure and absolute temperature are directly proportional: P₁/T₁ = P₂/T₂. Heat a sealed, rigid container and the pressure inside rises in direct proportion to the temperature in kelvin." },
  { q: "Why must temperature be in kelvin, not Celsius, for Gay-Lussac's law?", a: 'The proportionality P ∝ T only holds for absolute temperature. Celsius has an arbitrary zero point (the freezing point of water), so ratios of Celsius values are meaningless here — 40°C is not "twice as hot" as 20°C. Kelvin starts at absolute zero, where a gas\'s pressure would theoretically reach zero, so ratios of kelvin temperatures correctly track ratios of pressure. Always convert with K = °C + 273.15 before using the formula.' },
  { q: "What has to stay constant for Gay-Lussac's law to apply?", a: "Volume and the amount of gas (moles) must both stay fixed — the gas has to be sealed in a rigid container that cannot expand or contract. Gay-Lussac's law isolates the pressure–temperature relationship only when those two are held constant; if volume also changes, you need the combined gas law instead." },
  { q: "Why do pressure cookers and aerosol cans carry heat warnings?", a: "Both are sealed, essentially rigid containers holding gas at some initial pressure. Heating them raises the internal pressure in direct proportion to absolute temperature — Gay-Lussac's law in action. Enough heat can push the pressure past what the container is rated for, which is exactly why aerosol cans warn against storage near heat and pressure cookers use calibrated relief valves." },
  { q: "How is Gay-Lussac's law different from Charles's law?", a: "Charles's law holds pressure constant and relates volume to temperature (V₁/T₁ = V₂/T₂) in a container that can expand, like a balloon. Gay-Lussac's law holds volume constant instead and relates pressure to temperature (P₁/T₁ = P₂/T₂) in a sealed, rigid container that cannot change size. They are two different slices through the same ideal gas law, PV = nRT." },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: "How to use the Gay-Lussac's Law Calculator",
  description: 'Calculate the missing pressure or temperature value using P1/T1 = P2/T2, with automatic Celsius-to-Kelvin conversion.',
  steps: [
    { name: 'Enter three values', text: 'Type any three of P₁, T₁, P₂, T₂. Leave the unknown one blank. Switch the temperature unit toggle between °C and K as needed.' },
    { name: 'Read the result', text: 'The fourth value solves instantly, with temperatures always converted to kelvin internally.' },
    { name: 'Study the diagrams', text: 'The sealed-vessel and P–T line diagrams below show why pressure rises with temperature at constant volume.' },
  ],
};

const formulas = [
  { expr: 'P₁/T₁ = P₂/T₂', note: 'pressure ÷ absolute temperature is constant at fixed V and n' },
  { expr: 'K = °C + 273.15', note: 'convert to kelvin before using the formula — always' },
  { expr: 'P₂ = P₁ × T₂ / T₁', note: 'solve for the new pressure' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — heating a sealed gas canister', tone: 'slate',
    given: 'A sealed, rigid gas canister holds gas at 1.00 atm and 20°C. It is heated at constant volume to 80°C. Find the new pressure.',
    rows: [
      { label: 'Convert to kelvin:', value: 'T₁ = 20 + 273.15 = 293.15 K, T₂ = 80 + 273.15 = 353.15 K', full: true },
      { label: 'Rearrange:', value: 'P₂ = P₁ × T₂ ÷ T₁' },
      { label: 'Substitute:', value: 'P₂ = 1.00 × 353.15 ÷ 293.15' },
      { label: 'New pressure:', value: 'P₂ ≈ 1.20 atm', full: true },
    ],
    note: 'Using Celsius directly (80 ÷ 20 = 4×) would badly overstate the pressure rise — the correct kelvin ratio gives only about a 20% increase.',
  },
  {
    title: 'Worked example 2 — an aerosol can left in a hot car', tone: 'amber',
    given: 'An aerosol can is at 2.50 atm and 25°C. Left in a hot car, it warms at constant volume to 95°C. Find the new pressure.',
    rows: [
      { label: 'Convert to kelvin:', value: 'T₁ = 25 + 273.15 = 298.15 K, T₂ = 95 + 273.15 = 368.15 K', full: true },
      { label: 'Rearrange:', value: 'P₂ = P₁ × T₂ ÷ T₁' },
      { label: 'Substitute:', value: 'P₂ = 2.50 × 368.15 ÷ 298.15' },
      { label: 'New pressure:', value: 'P₂ ≈ 3.09 atm', full: true },
    ],
    note: 'The pressure climbs by roughly 23% — a real margin for a can rated for a specific working pressure, which is exactly why aerosol cans warn against heat exposure.',
  },
];

const comparison = {
  heading: "Gay-Lussac's law vs Boyle's law vs Charles's law",
  note: 'Gay-Lussac\'s law is the pressure–temperature pair: hold volume and moles fixed in a sealed, rigid container, and pressure tracks absolute temperature exactly.',
  headers: [{ label: 'Law' }, { label: 'Held constant' }, { label: 'Relationship' }],
  rows: [
    ["Gay-Lussac's law", 'Volume, moles', 'P and T — directly proportional (P₁/T₁ = P₂/T₂)'],
    ["Boyle's law", 'Temperature, moles', 'P and V — inversely proportional (P₁V₁ = P₂V₂)'],
    ["Charles's law", 'Pressure, moles', 'V and T — directly proportional (V₁/T₁ = V₂/T₂)'],
  ],
  highlightIndex: 0,
  footnote: 'All three are special cases of the combined/ideal gas law PV = nRT, each freezing one variable to isolate the other two.',
};

const realWorld = [
  { emoji: '🍲', title: 'Pressure cookers', body: 'A pressure cooker is a sealed, nearly rigid vessel. Heating the water inside raises the pressure of the trapped steam in direct proportion to absolute temperature, which is precisely what lets food cook faster at higher temperatures than boiling at normal atmospheric pressure.' },
  { emoji: '🧴', title: 'Aerosol can safety warnings', body: 'Aerosol cans are sealed rigid containers holding pressurised gas. Warming them — in direct sunlight, a hot car, or near a flame — raises the internal pressure sharply, which is why every can carries an explicit warning against heat exposure and incineration.' },
  { emoji: '🚗', title: 'Car tire pressure and ambient temperature', body: 'A tire is close to a fixed-volume container. On a hot day, or right after highway driving heats the air inside, tire pressure reads noticeably higher than on a cold morning — the same P/T proportionality, which is why manufacturers specify a "cold" tire pressure.' },
  { emoji: '🏭', title: 'Industrial sealed containers', body: 'Storage tanks, gas cylinders and sealed process vessels in industrial settings are engineered with pressure relief valves precisely because heating a fixed volume of gas raises its pressure predictably — Gay-Lussac\'s law lets engineers calculate exactly how much a temperature swing will raise internal pressure.' },
];

const misconceptions = [
  { claim: '"You can plug Celsius values straight into Gay-Lussac\'s law."', truth: 'False — this is the single most common student error. The P ∝ T proportionality only holds for absolute temperature. You must convert every temperature to kelvin (K = °C + 273.15) before using P₁/T₁ = P₂/T₂, or the answer will be badly wrong.' },
  { claim: '"Gay-Lussac\'s law applies to any sealed container, regardless of whether it can expand."', truth: "False — it specifically requires constant volume, meaning a rigid container that cannot expand or contract. If the container can change size (like a balloon or a piston), volume is no longer fixed and you need the combined gas law, P₁V₁/T₁ = P₂V₂/T₂, instead." },
  { claim: '"Gay-Lussac\'s law works even if volume changes too."', truth: "False — volume (and the amount of gas) must be held constant. That constraint is the entire premise of the law. If volume changes as well, the simple P/T proportionality no longer applies." },
  { claim: '"Pressure and temperature are equal to each other."', truth: 'False — they are proportional, not equal. P/T is a constant ratio, not P = T. Doubling the absolute temperature doubles the pressure; it does not make the pressure numerically equal to the temperature.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — gas laws and Gay-Lussac\'s law (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/9-2-relating-pressure-volume-amount-and-temperature-the-ideal-gas-law" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 10, Gases.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — the gas laws and kinetic molecular theory.' },
];
const sourcesNote = "Gay-Lussac's law assumes constant volume and a fixed amount of gas (n). Temperatures are converted to kelvin internally. Results are rounded for display.";

const howToUse = [
  { title: 'Enter three values', body: 'Fill any three of P₁, T₁, P₂, T₂; the fourth solves live.' },
  { title: 'Mind the units', body: 'Toggle °C or K for each temperature field — conversion to kelvin happens automatically before solving.' },
  { title: 'Study the diagrams', body: 'The sealed-vessel diagram and the P–T line family below illustrate why pressure rises in a rigid container as temperature climbs.' },
];

const related = [
  { href: '/tools/boyles-law-calculator', emoji: '🎈', title: "Boyle's Law Calculator", desc: 'P₁V₁ = P₂V₂ — solve any variable.' },
  { href: '/tools/charles-law-calculator', emoji: '🔺', title: "Charles's Law Calculator", desc: 'V₁/T₁ = V₂/T₂ — solve any variable.' },
  { href: '/tools/ideal-gas-law-calculator', emoji: '🧮', title: 'Ideal Gas Law Calculator', desc: 'PV = nRT — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="heat a gas sealed in a rigid, fixed-volume container and its pressure rises in direct proportion to its absolute temperature — but that proportion only works in kelvin, never Celsius."
  howIntro="Rearranged, P₁/T₁ = P₂/T₂ solves any of the four variables: P₂ = P₁T₂/T₁ and T₂ = T₁P₂/P₁. It only holds when volume and the amount of gas (moles) stay fixed — the container must be rigid — and temperature must be absolute (kelvin), since the direct proportionality breaks down completely if you use Celsius, whose zero point is arbitrary rather than physical."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Gay-Lussac's law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 rounded-lg bg-amber-50 p-3 text-sm text-amber-800"><strong>Important:</strong> Gay-Lussac's law requires absolute temperature. Enter °C or K below — °C is converted to kelvin automatically before solving.</p>
    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Pressure P₁</span>
        <input id="P1" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature T₁</span>
        <div class="mt-1 flex gap-1">
          <input id="T1" type="number" step="any" placeholder="value" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <select id="T1u" class="rounded-xl border border-slate-300 px-2 text-sm"><option value="C">°C</option><option value="K">K</option></select>
        </div></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pressure P₂</span>
        <input id="P2" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature T₂</span>
        <div class="mt-1 flex gap-1">
          <input id="T2" type="number" step="any" placeholder="value" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <select id="T2u" class="rounded-xl border border-slate-300 px-2 text-sm"><option value="C">°C</option><option value="K">K</option></select>
        </div></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P₁</div><div id="r-P1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">T₁</div><div id="r-T1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P₂</div><div id="r-P2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">T₂</div><div id="r-T2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="gl-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-vessel" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Same rigid vessel, hotter gas, higher pressure</h3>
          <p class="mt-1 text-sm text-slate-600">A cold, <span class="font-semibold text-sky-500">low-pressure</span> sealed vessel with a fixed lid next to a hot, <span class="font-semibold text-rose-500">high-pressure</span> one — the same fixed volume of gas at two different absolute temperatures. The lid never moves; only the pressure gauge changes.</p>
        </div>
        <div>
          <div id="diag-pt-lines" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Every line points to absolute zero</h3>
          <p class="mt-1 text-sm text-slate-600">Straight P-vs-T lines for different gas samples all extrapolate back to the same point: P = 0 at 0 K. That shared intercept is the same reasoning that located absolute zero using Charles's law.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Gay-Lussac's law graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pressure vs kelvin temperature — a straight line through absolute zero</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">P/T ratio vs temperature — constant, by Gay-Lussac's law</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ptconst"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function toK(val, unit) { return unit === 'C' ? val + 273.15 : val; }
      function fromK(k, unit) { return unit === 'C' ? k - 273.15 : k; }

      // ---- calculator ----
      function update() {
        el('gl-err').textContent = '';
        ['r-P1', 'r-T1', 'r-P2', 'r-T2'].forEach((id) => (el(id).textContent = '—'));
        const P1 = parseFloat(el('P1').value);
        const P2 = parseFloat(el('P2').value);
        const T1u = el('T1u').value, T2u = el('T2u').value;
        const T1raw = parseFloat(el('T1').value), T2raw = parseFloat(el('T2').value);
        const T1 = isNaN(T1raw) ? NaN : toK(T1raw, T1u);
        const T2 = isNaN(T2raw) ? NaN : toK(T2raw, T2u);
        const vals = { P1, T1, P2, T2 };
        const filled = Object.keys(vals).filter((k) => !isNaN(vals[k]));
        if (filled.length < 3) return;
        const missing = Object.keys(vals).filter((k) => isNaN(vals[k]));

        function fmtT(k, unit) { return fmt(k) + ' K (' + fmt(fromK(k, unit)) + '°C)'; }

        if (missing.length !== 1) {
          if (T1 <= 0 || T2 <= 0) { el('gl-err').textContent = 'Absolute temperature must be above 0 K.'; return; }
          el('r-P1').textContent = fmt(P1) + ' atm';
          el('r-T1').textContent = fmtT(T1, T1u);
          el('r-P2').textContent = fmt(P2) + ' atm';
          el('r-T2').textContent = fmtT(T2, T2u);
          return;
        }
        const m = missing[0];
        let out = { P1, T1, P2, T2 };
        try {
          if (m === 'P1') { if (T1 <= 0) throw new Error('T1 must be above 0 K.'); out.P1 = (P2 * T1) / T2; }
          else if (m === 'T1') { if (P1 === 0) throw new Error('P1 cannot be zero.'); out.T1 = (P1 * T2) / P2; if (out.T1 <= 0) throw new Error('Resulting T1 is at or below absolute zero — check inputs.'); }
          else if (m === 'P2') { if (T1 <= 0) throw new Error('T1 must be above 0 K.'); out.P2 = (P1 * T2) / T1; }
          else if (m === 'T2') { if (P1 === 0) throw new Error('P1 cannot be zero.'); out.T2 = (P2 * T1) / P1; if (out.T2 <= 0) throw new Error('Resulting T2 is at or below absolute zero — check inputs.'); }
        } catch (e) { el('gl-err').textContent = e.message; return; }
        el('r-P1').textContent = fmt(out.P1) + ' atm';
        el('r-T1').textContent = fmtT(out.T1, T1u);
        el('r-P2').textContent = fmt(out.P2) + ' atm';
        el('r-T2').textContent = fmtT(out.T2, T2u);
      }
      ['P1', 'T1', 'P2', 'T2', 'T1u', 'T2u'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const K_RATIO = 1.00 / 293.15; // fixed P1/T1 = 1.00 atm / 293.15 K for chart reference
      const charts = {};

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.pt = new Chart(el('chart-pt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'P', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Temperature (K)' } }, y: { title: { display: true, text: 'Pressure (atm)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ptconst = new Chart(el('chart-ptconst'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'P/T', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Temperature (K)' } }, y: { title: { display: true, text: 'P / T (atm/K)' }, suggestedMin: 0, suggestedMax: K_RATIO * 2 } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts();
      }
      function updateCharts() {
        if (!charts.ready) return;
        const L = [], D = [], C = [];
        for (let tt = 0; tt <= 500.001; tt += 10) { L.push(tt.toFixed(0)); D.push(+(K_RATIO * tt).toFixed(4)); C.push(+K_RATIO.toFixed(6)); }
        charts.pt.data.labels = L; charts.pt.data.datasets[0].data = D; charts.pt.update();
        charts.ptconst.data.labels = L; charts.ptconst.data.datasets[0].data = C; charts.ptconst.update();
      }

      // ---- standalone diagram: sealed rigid vessel at two static temperatures ----
      function rigidVessel(THREE, radius) {
        const g = new THREE.Group();
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        g.add(new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, 5, 32, 1, true), glassMat));
        const bottom = new THREE.Mesh(new THREE.CircleGeometry(radius, 32), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
        // fixed lid — never moves (unlike a piston), the visual distinguisher from Boyle's law
        const lidMat = new THREE.MeshStandardMaterial({ color: 0x64748b, roughness: 0.4, metalness: 0.3 });
        const lid = new THREE.Mesh(new THREE.CylinderGeometry(radius * 0.98, radius * 0.98, 0.25, 32), lidMat);
        lid.position.y = 2.5; g.add(lid);
        return g;
      }
      function gauge(color) {
        const grp = new THREE.Group();
        const dial = new THREE.Mesh(new THREE.CircleGeometry(0.5, 24), new THREE.MeshStandardMaterial({ color: 0xf8fafc, side: THREE.DoubleSide }));
        grp.add(dial);
        const needle = new THREE.Mesh(new THREE.BoxGeometry(0.06, 0.42, 0.02), new THREE.MeshStandardMaterial({ color }));
        needle.position.y = 0.18; grp.add(needle);
        return grp;
      }
      function initDiagVessel() {
        const c = el('diag-vessel'); if (!c) throw new Error('no container');
        const s = makeScene(c, 15, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        const coldMat = new THREE.MeshStandardMaterial({ color: 0x38bdf8 });
        const hotMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
        function vesselAt(x, radius, gasColorMat, nParticles, gaugeColor) {
          const grp = new THREE.Group(); grp.position.x = x;
          grp.add(rigidVessel(THREE, radius));
          for (let i = 0; i < nParticles; i++) {
            const p = new THREE.Mesh(new THREE.SphereGeometry(0.12, 10, 10), gasColorMat);
            const r = Math.sqrt(Math.random()) * radius * 0.85, a = Math.random() * Math.PI * 2;
            p.position.set(Math.cos(a) * r, -2.2 + Math.random() * 4.2, Math.sin(a) * r);
            grp.add(p);
          }
          const g = gauge(gaugeColor); g.position.set(0, 3.1, radius + 0.2); grp.add(g);
          return grp;
        }
        s.scene.add(vesselAt(-3.2, 1.8, coldMat, 14, 0x38bdf8));  // cold: low pressure
        s.scene.add(vesselAt(3.2, 1.8, hotMat, 14, 0xf43f5e));    // hot: high pressure
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }

      // ---- standalone diagram: family of P-vs-T lines through absolute zero ----
      function initDiagPTLines() {
        const c = el('diag-pt-lines'); if (!c) throw new Error('no container');
        const s = makeScene(c, 15, new THREE.Vector3(5, 3, 0), MOL_OPTS);
        const grid = new THREE.GridHelper(12, 12, 0xe2e8f0, 0xeef2f7); grid.position.set(6, 0, 6); s.scene.add(grid);
        const slopes = [0.003412, 0.006, 0.009]; // different P/T ratios (different gas samples)
        slopes.forEach((m) => {
          const pts = [];
          for (let t = 0; t <= 500; t += 25) pts.push(new THREE.Vector3(t / 50, Math.min(10, m * t * 10), 0));
          const col = m === 0.003412 ? 0x6366f1 : 0x94a3b8;
          const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: col, transparent: m !== 0.003412, opacity: m === 0.003412 ? 1 : 0.6 }));
          s.scene.add(line);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0035); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }

      let diagVessel = null, diagPTLines = null;

      function boot() {
        try { update(); } catch (e) { console.error('[gaylussac] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[gaylussac] charts failed', e); }
        if (window.THREE) {
          try { diagVessel = initDiagVessel(); } catch (e) { console.error('[gaylussac] vessel diagram failed', e); }
          try { diagPTLines = initDiagPTLines(); } catch (e) { console.error('[gaylussac] P-T lines diagram failed', e); }
        }
        mountResize([diagVessel, diagPTLines]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
