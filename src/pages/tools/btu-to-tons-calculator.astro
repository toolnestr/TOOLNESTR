---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'BTU to Tons Calculator';
const description = 'Convert HVAC cooling capacity between BTU/hr, tons, and kW. Quickly size or compare air-conditioner units. Free and instant.';
const intro = 'Convert air-conditioner cooling capacity between BTU/hr and tons.';
const category = { id: 'engineering', name: 'Engineering' };
const faqs = [
  { q: 'How many BTU is 1 ton?', a: 'Exactly 12,000 BTU per hour.' },
  { q: 'What size AC do I need?', a: 'Rough rule ~20 BTU per square foot, but get a proper load calculation for accuracy.' },
  { q: 'What is a ton in kW?', a: 'About 3.52 kW of cooling per ton.' },
  { q: 'Where does "ton" come from?', a: 'It originated from the cooling power of one ton of ice melting per day — a legacy unit still common in HVAC.' },
];
const sources = [
  { html: "<strong>NFPA 70 — National Electrical Code (NEC)</strong>, conduit fill, box fill and conductor ampacity. <a href=\"https://www.nfpa.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nfpa.org</a>" },
  { html: "<strong>IPC-2221</strong>, Generic Standard on Printed Board Design (trace width / current). <a href=\"https://www.ipc.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">ipc.org</a>" },
  { html: "<strong>NIST</strong> reference constants and unit definitions; <strong>IEEE</strong> standards where applicable. <a href=\"https://www.nist.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nist.gov</a>" },
];
const sourcesNote = "For educational and preliminary use. Verify against full engineering calculations and the governing standard before any real design.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700">Conversion direction</label>
      <div class="mt-1 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
        <button id="dir-btu" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">BTU/hr &rarr; tons</button>
        <button id="dir-tons" class="flex-1 rounded-lg py-2 text-slate-500">tons &rarr; BTU/hr</button>
      </div>
    </div>

    <label class="block"><span class="text-sm font-medium text-slate-700">Cooling capacity</span>
      <input id="input" type="number" step="any" placeholder="e.g. 24000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </label>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Tons</div><div id="r-tons" class="mt-1 text-2xl font-bold">&mdash;</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">BTU/hr</div><div id="r-btu" class="mt-1 text-2xl font-bold text-emerald-600">&mdash;</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Kilowatts (kW)</div><div id="r-kw" class="mt-1 text-2xl font-bold text-slate-800">&mdash;</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How BTU to tons conversion works</h2>
    <p class="mt-2 text-slate-600">The relationship between BTU per hour and tons of cooling is fixed: one ton of refrigeration equals exactly 12,000 BTU per hour. This standard originates from the days when ice was the primary cooling medium — one ton of ice melting over 24 hours absorbs 288,000 BTU of heat, which works out to 12,000 BTU per hour. To convert BTU/hr to tons, divide by 12,000. To convert tons to BTU/hr, multiply by 12,000.</p>
    <p class="mt-3 text-slate-600">Kilowatts of cooling can be derived from BTU/hr using the conversion factor 1 BTU/hr = 0.000293071 kW. This is equivalent to multiplying BTU/hr by 0.000293071, or multiplying tons by 3.517 (since 12,000 &times; 0.000293071 &asymp; 3.517). These three units — BTU/hr, tons, and kW — are the most common ways air-conditioner cooling capacity is specified across different regions and manufacturers.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Given:</span> <span class="text-slate-600">24,000 BTU/hr cooling capacity</span></div>
        <div><span class="font-medium text-slate-700">Convert to tons:</span> <span class="text-slate-600">24,000 / 12,000 = 2 tons</span></div>
        <div><span class="font-medium text-slate-700">Convert to kW:</span> <span class="text-slate-600">24,000 &times; 0.000293071 = 7.03 kW</span></div>
        <div><span class="font-medium text-slate-700">Check:</span> <span class="text-slate-600">2 tons &times; 3.517 = 7.03 kW &#10003;</span></div>
      </div>
    </div>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="btu-title btu-desc" xmlns="http://www.w3.org/2000/svg">
      <title id="btu-title">BTU to Tons Conversion Diagram</title>
      <desc id="btu-desc">Diagram showing BTU/hr divided by 12,000 gives tons, and tons multiplied by 12,000 gives BTU/hr</desc>
      <rect x="40" y="60" width="180" height="80" rx="12" fill="#e0e7ff" stroke="#6366f1" stroke-width="2.5"/>
      <text x="130" y="95" text-anchor="middle" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="#4338ca">BTU/hr</text>
      <text x="130" y="115" text-anchor="middle" font-family="Arial,sans-serif" font-size="12" fill="#6366f1">cooling capacity</text>
      <line x1="220" y1="80" x2="280" y2="80" stroke="#6366f1" stroke-width="2.5"/>
      <polygon points="280,75 295,80 280,85" fill="#6366f1"/>
      <text x="258" y="60" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#6366f1">&divide; 12,000</text>
      <rect x="300" y="60" width="180" height="80" rx="12" fill="#e0e7ff" stroke="#6366f1" stroke-width="2.5"/>
      <text x="390" y="95" text-anchor="middle" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="#4338ca">Tons</text>
      <text x="390" y="115" text-anchor="middle" font-family="Arial,sans-serif" font-size="12" fill="#6366f1">refrigeration</text>
      <line x1="480" y1="80" x2="540" y2="80" stroke="#475569" stroke-width="2.5"/>
      <polygon points="540,75 555,80 540,85" fill="#475569"/>
      <text x="518" y="60" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#475569">&times; 12,000</text>
      <rect x="560" y="60" width="180" height="80" rx="12" fill="#e2e8f0" stroke="#64748b" stroke-width="2.5"/>
      <text x="650" y="95" text-anchor="middle" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="#334155">BTU/hr</text>
      <text x="650" y="115" text-anchor="middle" font-family="Arial,sans-serif" font-size="12" fill="#64748b">cooling capacity</text>
      <text x="390" y="190" text-anchor="middle" font-family="Arial,sans-serif" font-size="14" fill="#64748b">1 ton = 12,000 BTU/hr &asymp; 3.517 kW</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">BTU/hr &harr; tons conversion relationship</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common AC sizes at a glance</h2>
    <p class="mt-2 text-slate-600">Residential air-conditioners typically range from 1 to 5 tons. Here are the most common sizes and their equivalents across all three units.</p>
    <div class="mt-5 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Tons</th><th class="p-3">BTU/hr</th><th class="p-3">kW</th><th class="p-3">Typical coverage</th></tr></thead>
        <tbody class="divide-y divide-slate-100 text-slate-700">
          <tr><td class="p-3 font-medium">1.0</td><td class="p-3">12,000</td><td class="p-3">3.52</td><td class="p-3">400 &ndash; 600 sq ft</td></tr>
          <tr><td class="p-3 font-medium">1.5</td><td class="p-3">18,000</td><td class="p-3">5.28</td><td class="p-3">600 &ndash; 900 sq ft</td></tr>
          <tr><td class="p-3 font-medium">2.0</td><td class="p-3">24,000</td><td class="p-3">7.03</td><td class="p-3">900 &ndash; 1,200 sq ft</td></tr>
          <tr><td class="p-3 font-medium">2.5</td><td class="p-3">30,000</td><td class="p-3">8.79</td><td class="p-3">1,200 &ndash; 1,500 sq ft</td></tr>
          <tr><td class="p-3 font-medium">3.0</td><td class="p-3">36,000</td><td class="p-3">10.55</td><td class="p-3">1,500 &ndash; 1,800 sq ft</td></tr>
          <tr><td class="p-3 font-medium">4.0</td><td class="p-3">48,000</td><td class="p-3">14.07</td><td class="p-3">1,800 &ndash; 2,500 sq ft</td></tr>
          <tr><td class="p-3 font-medium">5.0</td><td class="p-3">60,000</td><td class="p-3">17.58</td><td class="p-3">2,500 &ndash; 3,200 sq ft</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3E0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sizing an AC unit</h3>
      <p class="mt-1 text-sm text-slate-600">When shopping for a new air-conditioner, different brands quote capacity in different units. A 2-ton unit from one manufacturer might be listed at 24,000 BTU/hr by another. This calculator helps you compare them directly.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F527;</span>
      <h3 class="mt-2 font-semibold text-slate-900">HVAC specifications</h3>
      <p class="mt-1 text-sm text-slate-600">HVAC engineers work with BTU/hr for heat load calculations and duct sizing, but specify equipment in tons. Quickly convert between the two without pulling out reference tables.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4CA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Comparing quotes</h3>
      <p class="mt-1 text-sm text-slate-600">Contractors may quote you in tons while equipment datasheets list BTU/hr. Use the calculator to verify you are comparing the same cooling capacity across different proposals.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F30D;</span>
      <h3 class="mt-2 font-semibold text-slate-900">International standards</h3>
      <p class="mt-1 text-sm text-slate-600">BTU/hr is common in North America, while kW is the preferred unit in Europe and Asia. When specifying equipment for an international project, convert all capacities to a common unit.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for AC capacity conversion</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">&quot;Ton&quot; means cooling power, not weight</h3>
        <p class="mt-1 text-sm text-slate-600">In HVAC, a &quot;ton&quot; refers to the rate of heat removal, not the physical weight of the equipment. One ton of cooling removes 12,000 BTU of heat per hour. A 3-ton air-conditioner does not weigh 3 tons &mdash; it removes heat at the same rate as melting 3 tons of ice per day.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Room sizing depends on many factors</h3>
        <p class="mt-1 text-sm text-slate-600">The rough rule of 20 BTU per square foot is a starting point, but actual cooling requirements depend on ceiling height, window area and orientation, insulation levels, number of occupants, heat-producing appliances, local climate, and sun exposure. Always get a proper Manual J load calculation before purchasing equipment.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Oversizing is worse than undersizing</h3>
        <p class="mt-1 text-sm text-slate-600">An oversized AC unit cools the space quickly but shuts off before removing enough humidity, leaving the room feeling cold and clammy. Short cycling also increases wear on the compressor and reduces efficiency. Proper sizing is critical for both comfort and equipment longevity.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Check the SEER rating too</h3>
        <p class="mt-1 text-sm text-slate-600">Cooling capacity (tons/BTU) tells you how much cooling the unit can provide, but SEER (Seasonal Energy Efficiency Ratio) tells you how efficiently it does so. A higher SEER means lower operating costs. Modern minimum standards are 14&ndash;15 SEER, with premium units reaching 25+ SEER.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Understanding HVAC cooling units</h2>
    <p class="mt-2 text-slate-600">The British Thermal Unit (BTU) is a measure of heat energy. One BTU is the amount of heat required to raise the temperature of one pound of water by one degree Fahrenheit. When applied to air conditioning, BTU per hour (BTU/hr) measures the rate at which heat is removed from a space. This is the most common specification for residential air-conditioners, heat pumps, and furnaces in North America.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">The ton of refrigeration</h2>
    <p class="mt-2 text-slate-600">The &quot;ton of refrigeration&quot; is a historical unit that dates back to the ice-harvesting era. The latent heat of fusion of ice is 144 BTU per pound. One short ton (2,000 lb) of ice absorbs 2,000 &times; 144 = 288,000 BTU of heat as it melts over 24 hours. Dividing by 24 hours gives 12,000 BTU per hour, which became the standard definition of one ton of cooling. Despite being an archaic unit, it remains the standard for specifying residential and light commercial HVAC equipment in the United States and Canada.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Kilowatts in HVAC</h2>
    <p class="mt-2 text-slate-600">In most of the world, cooling capacity is specified in kilowatts (kW). One kW equals 3,412 BTU/hr, so converting the other way: 1 BTU/hr = 0.000293071 kW or approximately 0.293 watts. For a 2-ton (24,000 BTU/hr) unit, the cooling capacity is 24,000 &times; 0.000293071 = 7.03 kW. Note that this is the thermal cooling output, not the electrical input power. The actual electrical consumption depends on the unit&apos;s efficiency (EER or SEER).</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Practical applications</h2>
    <p class="mt-2 text-slate-600">HVAC professionals use these conversions daily. When performing heat load calculations, the total cooling load is computed in BTU/hr based on the Manual J methodology. The result is then converted to tons to select the appropriate equipment. Duct sizing uses BTU/hr, refrigerant line sizing uses tons, and electrical design uses kW. Being fluent across all three units is essential for proper system design.</p>
    <p class="mt-3 text-slate-600">For homeowners, understanding these units helps when comparing quotes from different contractors, reading equipment specification sheets, and discussing options with HVAC professionals. A contractor who offers a &quot;3-ton unit&quot; and another who offers a &quot;36,000 BTU system&quot; are offering the same capacity &mdash; knowing the conversion prevents confusion and ensures you receive comparable proposals.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/kva-to-kw-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4CA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">kVA to kW Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Convert apparent power to real power with power factor.</p>
      </a>
      <a href="/tools/lumens-to-lux-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4A1;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Lumens to Lux Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Convert light output to illuminance over any area.</p>
      </a>
      <a href="/tools/fuel-cost-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x26FD;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Fuel Cost Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Estimate fuel costs for trips and compare vehicles.</p>
      </a>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the BTU to Tons Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set direction</h3>
        <p class="mt-1 text-sm text-slate-600">Choose whether you want to convert BTU/hr to tons or the reverse. The calculator updates instantly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the value</h3>
        <p class="mt-1 text-sm text-slate-600">Type the cooling capacity in the input field. The tool accepts decimals and works with any value, including zero.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read all results</h3>
        <p class="mt-1 text-sm text-slate-600">Tons, BTU/hr, and kW are shown simultaneously so you have the complete picture without extra steps.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let direction = 'btu'; // 'btu' = BTU/hr -> tons, 'tons' = tons -> BTU/hr

    function setDir(dir) {
      direction = dir;
      el('dir-btu').className = 'flex-1 rounded-lg py-2 ' + (dir === 'btu' ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('dir-tons').className = 'flex-1 rounded-lg py-2 ' + (dir === 'tons' ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('input').value = '';
      el('r-tons').textContent = '\u2014';
      el('r-btu').textContent = '\u2014';
      el('r-kw').textContent = '\u2014';
      el('input').placeholder = dir === 'btu' ? 'e.g. 24000' : 'e.g. 2';
    }

    function update() {
      const raw = parseFloat(el('input').value);

      if (isNaN(raw) || raw === 0) {
        el('r-tons').textContent = isNaN(raw) ? '\u2014' : '0.00';
        el('r-btu').textContent = isNaN(raw) ? '\u2014' : '0';
        el('r-kw').textContent = isNaN(raw) ? '\u2014' : '0.00';
        return;
      }

      let tons, btu, kw;
      if (direction === 'btu') {
        btu = raw;
        tons = raw / 12000;
      } else {
        tons = raw;
        btu = raw * 12000;
      }
      kw = btu * 0.000293071;

      el('r-tons').textContent = tons.toFixed(2);
      el('r-btu').textContent = Math.round(btu).toLocaleString();
      el('r-kw').textContent = kw.toFixed(2);
    }

    el('dir-btu').addEventListener('click', () => setDir('btu'));
    el('dir-tons').addEventListener('click', () => setDir('tons'));
    el('input').addEventListener('input', update);
  </script>
</ToolLayout>
