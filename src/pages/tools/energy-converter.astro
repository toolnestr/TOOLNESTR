---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Joules", sym: "J", toBase: 1 }, { name: "Kilojoules", sym: "kJ", toBase: 1000 }, { name: "Calories", sym: "cal", toBase: 4.184 }, { name: "Kilocalories", sym: "kcal", toBase: 4184 }, { name: "Watt-hours", sym: "Wh", toBase: 3600 }, { name: "Kilowatt-hours", sym: "kWh", toBase: 3600000 }, { name: "British thermal units", sym: "BTU", toBase: 1055.05585 }, { name: "Foot-pounds", sym: "ft·lb", toBase: 1.3558179 }];
---
<MultiUnitConverter
  title="Energy Converter"
  emoji="⚡"
  quantity="energy"
  baseName="joule"
  units={units}
  defaultFrom={0} defaultTo={3}
  intro="Convert between energy units — joules, kilojoules, calories, kilocalories, watt-hours and more."
  blurb="Energy is the capacity to do work, measured in joules, calories and kilowatt-hours."
  related={[{"slug":"power-converter","label":"Power Converter Converter"}]}
/>
