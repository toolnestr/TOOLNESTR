---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Normality Calculator';
const description = 'Normality calculator with a live 3D beaker and charts. Solve N = equivalents ÷ litres, convert molarity to normality (N = M × n), with worked examples.';
const intro = 'Find normality from equivalents and volume, or convert molarity to normality with N = M × n. A live 3D beaker and charts show what equivalents-per-litre means.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is normality?', a: 'Normality (N) is the number of gram-equivalents of solute per litre of solution: N = equivalents / L. Its unit is eq/L, written N or "normal". It is molarity weighted by how many reactive units each molecule provides.' },
  { q: 'How does normality relate to molarity?', a: 'N = M × n, where n is the number of equivalents per mole — the number of H⁺ for an acid, OH⁻ for a base, or electrons transferred in a redox reaction. For example, 1 M H₂SO₄ is 2 N because each molecule provides two H⁺.' },
  { q: 'What is an equivalent?', a: 'An equivalent is the amount of a substance that supplies (or reacts with) one mole of reactive units — one mole of H⁺, OH⁻, or electrons. Equivalent weight = molar mass ÷ n.' },
  { q: 'When is normality used instead of molarity?', a: 'In acid–base titrations and redox chemistry, where what matters is the number of reactive units, not molecules. At the endpoint, equivalents of acid equal equivalents of base: N₁V₁ = N₂V₂.' },
  { q: 'Is normality always greater than molarity?', a: 'It is greater than or equal to molarity, never less, because n ≥ 1. When n = 1 (e.g. HCl, NaOH) normality equals molarity; when n > 1 (H₂SO₄, Ca(OH)₂) normality is a multiple of it.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Normality Calculator',
  description: 'Calculate normality from equivalents and volume, or from molarity and equivalents-per-mole.',
  steps: [
    { name: 'Pick a mode', text: 'Choose "Equivalents" (N = eq/L) or "From molarity" (N = M × n).' },
    { name: 'Enter the values', text: 'Type any two of the three quantities in the chosen mode.' },
    { name: 'Read the result', text: 'The normality solves instantly, and the 3D beaker updates.' },
  ],
};

const formulas = [
  { expr: 'N = eq / V', note: 'normality from equivalents &amp; litres' },
  { expr: 'N = M × n', note: 'from molarity, n = equivalents per mole' },
  { expr: 'eq&nbsp;wt = M<sub>r</sub> / n', note: 'equivalent weight from molar mass' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — sulfuric acid', tone: 'slate',
    given: '0.50 mol of H₂SO₄ is made up to 2.0 L of solution. It is a diprotic acid (n = 2). Find the normality.',
    rows: [
      { label: 'Molarity:', value: 'M = 0.50 ÷ 2.0 = 0.25 mol/L' },
      { label: 'Normality:', value: 'N = M × n = 0.25 × 2 = 0.50 N' },
      { label: 'Check (equivalents):', value: 'eq = 0.50 mol × 2 = 1.0 eq → N = 1.0 ÷ 2.0 = 0.50 N', full: true },
    ],
  },
  {
    title: 'Worked example 2 — titration endpoint', tone: 'amber',
    given: '25 mL of an unknown NaOH is neutralised by 20 mL of 0.10 N HCl. Find the NaOH normality using N₁V₁ = N₂V₂.',
    rows: [
      { label: 'Rearrange:', value: 'N₁ = N₂V₂ ÷ V₁' },
      { label: 'NaOH normality:', value: 'N₁ = (0.10 × 20) ÷ 25 = 0.08 N' },
    ],
    note: 'Because NaOH has n = 1, this 0.08 N is also 0.08 M.',
  },
];

const comparison = {
  heading: 'Normality vs molarity for common reagents',
  note: 'The multiplier n is what separates them — count the reactive units per molecule.',
  headers: [{ label: 'Reagent' }, { label: 'n (eq/mol)' }, { label: '1 M equals' }],
  rows: [
    ['HCl (monoprotic)', '1', '1 N'],
    ['NaOH', '1', '1 N'],
    ['H₂SO₄ (diprotic)', '2', '2 N'],
    ['Ca(OH)₂', '2', '2 N'],
    ['H₃PO₄ (triprotic)', '3', '3 N'],
  ],
  highlightIndex: 2,
  footnote: 'n = number of H⁺, OH⁻ or electrons per formula unit. Normality = molarity × n, so it is always ≥ molarity.',
};

const realWorld = [
  { emoji: '⚗️', title: 'Acid–base titrations', body: 'At the endpoint, equivalents of acid equal equivalents of base, so N₁V₁ = N₂V₂ gives the unknown concentration directly — no need to track stoichiometric ratios by hand.' },
  { emoji: '🔋', title: 'Redox chemistry', body: 'For oxidation–reduction, n is the number of electrons transferred. Normality lets you match oxidant and reductant equivalents one-to-one, which is why it persists in analytical and electrochemical work.' },
  { emoji: '💧', title: 'Water treatment', body: 'Hardness, alkalinity and acid dosing are often expressed in equivalents, so normality is the natural unit for balancing neutralisation and ion-exchange calculations.' },
];

const misconceptions = [
  { claim: '"Normality and molarity are the same."', truth: 'Only when n = 1. For H₂SO₄ (n = 2) a 1 M solution is 2 N — the same solution, two different numbers, because normality counts reactive units, not molecules.' },
  { claim: '"n is a property of the substance."', truth: 'n depends on the reaction. The same acid can supply different numbers of H⁺ in different reactions, changing its equivalents. Always define n for the reaction at hand.' },
  { claim: '"Equivalents are the same as moles."', truth: 'Equivalents = moles × n. One mole of H₂SO₄ provides two equivalents of H⁺. Only when n = 1 do equivalents and moles coincide.' },
  { claim: '"Normality can be less than molarity."', truth: 'Never — n is at least 1, so normality is always molarity or a whole multiple of it.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — solution concentration and equivalents (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/3-4-other-units-for-solution-concentrations" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 4, Aqueous Reactions and Solution Stoichiometry.' },
  { html: '<strong>Skoog, West &amp; Holler, <em>Fundamentals of Analytical Chemistry</em></strong> — equivalents, normality and titrimetric analysis.' },
];
const sourcesNote = 'Normality = molarity × equivalents-per-mole (n ≥ 1). Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"Equivalents" for N = eq/L; "From molarity" to multiply molarity by n.' },
  { title: 'Enter two values', body: 'Fill any two of the three fields; the third solves live.' },
  { title: 'See it in the beaker', body: 'Use the sliders to watch equivalent density track the normality.' },
];

const related = [
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'M = mol/L — solve for any variable.' },
  { href: '/tools/dilution-calculator', emoji: '💧', title: 'Dilution Calculator', desc: 'C₁V₁ = C₂V₂ — solve for any variable.' },
  { href: '/tools/percent-concentration-calculator', emoji: '🧴', title: 'Percent Concentration Calculator', desc: 'w/v, w/w and v/v percent.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="normality is molarity that counts reactive units — how many H⁺, OH⁻ or electrons each molecule actually brings to the reaction, per litre."
  howIntro="Rearranged, the equivalents form solves any variable: eq = N × V and V = eq / N. In an acid–base or redox titration the endpoint condition <span class='font-mono'>N₁V₁ = N₂V₂</span> then gives an unknown concentration in one step."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where normality actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-eq" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Equivalents (N = eq/L)</button>
      <button id="mode-m" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From molarity (N = M×n)</button>
    </div>
    <div id="eq-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Normality (N)</span>
        <input id="N" type="number" step="any" placeholder="eq/L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Equivalents (eq)</span>
        <input id="eq" type="number" step="any" placeholder="eq" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume (L)</span>
        <input id="V" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="m-fields" class="hidden gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Molarity (M)</span>
        <input id="M" type="number" step="any" placeholder="mol/L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Equivalents per mole (n)</span>
        <input id="n" type="number" step="any" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Normality</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Equivalents</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Volume</div><div id="r-3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="nm-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D beaker + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D normality</h2>
      <p class="mt-1 text-sm text-slate-500">Set the equivalents of solute and the volume; the beaker fills to the volume and the reactive-unit density tracks the normality. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Equivalents <span id="out-beq" class="font-mono text-green-600">1.00 eq</span></span>
          <input id="b-eq" type="range" min="0" max="5" step="0.05" value="1" class="mt-2 w-full accent-green-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Volume <span id="out-bv" class="font-mono text-green-600">1.00 L</span></span>
          <input id="b-v" type="range" min="0.1" max="5" step="0.05" value="1" class="mt-2 w-full accent-green-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-green-50 p-3 text-center text-sm text-green-700">Normality N = <span id="out-bn" class="font-mono font-bold">1.00 N</span></div>
      <div id="beaker3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="beaker3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Normality graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Normality vs volume (fixed equivalents) — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-nv"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Normality vs molarity for n = 1, 2, 3</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-nm"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'eq';
      function switchMode(m) {
        mode = m;
        el('mode-eq').className = m === 'eq' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-m').className = m === 'm' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('eq-fields').className = m === 'eq' ? 'grid gap-4 sm:grid-cols-3' : 'hidden';
        el('m-fields').className = m === 'm' ? 'grid gap-4 sm:grid-cols-2' : 'hidden gap-4 sm:grid-cols-2';
        el('lab-1').textContent = 'Normality';
        el('lab-2').textContent = m === 'eq' ? 'Equivalents' : 'Molarity';
        el('lab-3').textContent = m === 'eq' ? 'Volume' : 'n (eq/mol)';
        update();
      }
      function update() {
        el('nm-err').textContent = '';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        if (mode === 'eq') {
          const N = parseFloat(el('N').value), eq = parseFloat(el('eq').value), V = parseFloat(el('V').value);
          const filled = [!isNaN(N), !isNaN(eq), !isNaN(V)];
          if (filled.filter(Boolean).length < 2) return;
          let rN = NaN, req = NaN, rV = NaN;
          if (filled[1] && filled[2]) { if (V === 0) { el('nm-err').textContent = 'Volume cannot be zero.'; return; } rN = eq / V; req = eq; rV = V; }
          else if (filled[0] && filled[2]) { req = N * V; rN = N; rV = V; }
          else if (filled[0] && filled[1]) { if (N === 0) { el('nm-err').textContent = 'Normality cannot be zero when solving for volume.'; return; } rV = eq / N; rN = N; req = eq; }
          if (!isNaN(rN)) el('r-1').textContent = fmt(rN) + ' N';
          if (!isNaN(req)) el('r-2').textContent = fmt(req) + ' eq';
          if (!isNaN(rV)) el('r-3').textContent = fmt(rV) + ' L';
        } else {
          const M = parseFloat(el('M').value), n = parseFloat(el('n').value);
          if (isNaN(M) || isNaN(n)) return;
          if (n <= 0) { el('nm-err').textContent = 'n must be at least 1.'; return; }
          el('r-1').textContent = fmt(M * n) + ' N';
          el('r-2').textContent = fmt(M) + ' M';
          el('r-3').textContent = fmt(n) + ' eq/mol';
        }
      }
      el('mode-eq').addEventListener('click', () => switchMode('eq'));
      el('mode-m').addEventListener('click', () => switchMode('m'));
      ['N', 'eq', 'V', 'M', 'n'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let beaker = null;
      function bState() { const eq = parseFloat(el('b-eq').value), v = parseFloat(el('b-v').value); return { eq, v, N: v > 0 ? eq / v : 0 }; }
      function onB() {
        const s = bState();
        el('out-beq').textContent = s.eq.toFixed(2) + ' eq';
        el('out-bv').textContent = s.v.toFixed(2) + ' L';
        el('out-bn').textContent = fmt(s.N) + ' N';
        try { if (beaker) beaker.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-eq').addEventListener('input', onB);
      el('b-v').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.nv = new Chart(el('chart-nv'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'N', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Volume (L)' } }, y: { title: { display: true, text: 'Normality (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.nm = new Chart(el('chart-nm'), {
          type: 'line',
          data: { labels: ['0', '0.5', '1', '1.5', '2'], datasets: [
            { label: 'n=1', data: [0, 0.5, 1, 1.5, 2], borderColor: '#94a3b8', pointRadius: 0, tension: 0 },
            { label: 'n=2', data: [0, 1, 2, 3, 4], borderColor: '#6366f1', pointRadius: 0, tension: 0 },
            { label: 'n=3', data: [0, 1.5, 3, 4.5, 6], borderColor: '#ef4444', pointRadius: 0, tension: 0 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Molarity (mol/L)' } }, y: { title: { display: true, text: 'Normality (N)' }, beginAtZero: true } }, plugins: { legend: { position: 'bottom' } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L = [], D = [];
        for (let vv = 0.1; vv <= 5.001; vv += 0.1) { L.push(vv.toFixed(1)); D.push(+(s.eq / vv).toFixed(4)); }
        charts.nv.data.labels = L; charts.nv.data.datasets[0].data = D; charts.nv.update();
      }

      // ---- interactive beaker ----
      function glassBeaker(THREE) {
        const g = new THREE.Group();
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        g.add(new THREE.Mesh(new THREE.CylinderGeometry(2.2, 2.2, 5, 40, 1, true), glassMat));
        const bottom = new THREE.Mesh(new THREE.CircleGeometry(2.2, 40), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
        return g;
      }
      function initBeaker() {
        const c = el('beaker3d'); if (!c) throw new Error('no beaker');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        s.scene.add(glassBeaker(THREE));
        const liquidMat = new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.45, roughness: 0.3 });
        let liquid = null;
        const MAX_P = 120;
        const particleGeo = new THREE.SphereGeometry(0.11, 10, 10);
        const particleMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
        const particles = [];
        for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(particleGeo, particleMat); p.visible = false; s.scene.add(p); particles.push(p); }
        function update(state) {
          const frac = Math.max(0.02, Math.min(1, state.v / 5));
          const hLiq = frac * 4.6;
          if (liquid) { s.scene.remove(liquid); liquid.geometry.dispose(); }
          liquid = new THREE.Mesh(new THREE.CylinderGeometry(2.08, 2.08, hLiq, 40), liquidMat);
          liquid.position.y = -2.4 + hLiq / 2; s.scene.add(liquid);
          const nShow = Math.max(0, Math.min(MAX_P, Math.round(state.N * 22)));
          for (let i = 0; i < MAX_P; i++) {
            const p = particles[i];
            if (i < nShow) { const r = Math.sqrt(Math.random()) * 1.9, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -2.4 + Math.random() * hLiq, Math.sin(a) * r); p.visible = true; }
            else p.visible = false;
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        beaker = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { switchMode('eq'); } catch (e) { console.error('[normality] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[normality] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[normality] charts failed', e); }
        if (window.THREE) {
          try { initBeaker(); } catch (e) { console.error('[normality] beaker failed', e); el('beaker3d-fallback').classList.remove('hidden'); }
        } else { el('beaker3d-fallback').classList.remove('hidden'); }
        mountResize([beaker]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
