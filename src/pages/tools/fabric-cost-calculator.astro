---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fabric Cost Calculator';
const description = 'Calculate the total cost of fabric for a project from yardage needed, price per yard, and tax.';
const intro = 'Calculate the total cost of a fabric purchase from yardage, price per yard, and tax.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I know how many yards I need?', a: 'Use the Fabric Yardage Calculator to work out yardage from your piece dimensions first, then bring that number here to price it out — this tool assumes you already know (or have estimated) the yardage.' },
  { q: 'Should I price per yard or per meter?', a: 'Match whatever unit the fabric retailer sells in — many US and UK retailers price by the yard, while many European retailers price by the meter. Use the toggle to match the listing you\'re comparing.' },
  { q: 'Does this include shipping?', a: 'No — this calculates only the fabric subtotal plus any sales tax you enter. Add shipping separately if you\'re comparing the total landed cost between two online retailers.' },
  { q: 'How can I use this to compare two fabric options?', a: 'Run each fabric\'s price and required yardage through the calculator separately, then compare the two total costs directly — this is especially useful when one fabric is narrower and needs more yardage to cover the same project.' },
];
const howTo = {
  name: 'How to calculate fabric cost',
  steps: [
    { name: 'Enter yardage needed', text: 'Enter the total amount of fabric required for your project.' },
    { name: 'Enter price per unit', text: 'Enter the price per yard or per meter, matching the retailer\'s listing.' },
    { name: 'Add tax if applicable', text: 'Enter your local sales tax rate to see the final total.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Per yard', 'Per meter'].map((d) => (
        <button data-unit={d} class="unit-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <label class="block"><span id="qty-label" class="text-sm font-medium text-slate-700">Yards needed</span>
        <input id="qty" type="number" step="any" placeholder="e.g. 3.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span id="price-label" class="text-sm font-medium text-slate-700">Price per yard ($)</span>
        <input id="price" type="number" step="any" placeholder="e.g. 12.99" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Sales tax (%)</span>
        <input id="tax" type="number" step="any" value="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total cost</div>
        <div id="r-total" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Subtotal</div><div id="r-sub" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Tax amount</div><div id="r-tax" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fcc-title fcc-desc">
      <title id="fcc-title">Fabric bolt with a price tag</title>
      <desc id="fcc-desc">A rolled fabric bolt icon next to a price tag, illustrating cost calculated from yardage and unit price</desc>
      <rect x="120" y="60" width="80" height="100" rx="10" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <ellipse cx="160" cy="60" rx="40" ry="12" fill="#f0abfc" stroke="#c026d3" stroke-width="2" />
      <path d="M400 80 L460 80 L500 120 L460 160 L400 160 Z" fill="none" stroke="#94a3b8" stroke-width="2.5" />
      <circle cx="420" cy="100" r="5" fill="#94a3b8" />
      <text x="620" y="115" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">yards × price = cost</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Total cost is yardage multiplied by the unit price, plus tax</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fabric cost is calculated</h2>
    <p class="mt-2 text-slate-600">
      This calculator multiplies the yardage (or meterage) you need by the retailer's price per unit to get a subtotal, then applies your local sales tax rate on top to show the final total you'd actually pay at checkout. It's a simple multiplication, but doing it explicitly for several fabric options side by side makes comparison shopping faster and catches the case where a cheaper-per-yard fabric actually costs more overall because a narrower bolt needs more yardage for the same project.
    </p>
    <p class="mt-3 text-slate-600">
      Switching between "per yard" and "per meter" pricing lets you compare fabric listed in either unit without converting by hand first — 1 yard equals 0.9144 meters, so a fabric priced per meter needs its yardage entered as meters instead, which the toggle handles automatically.
    </p>
    <p class="mt-3 text-xs text-slate-400">Yard-to-meter conversion uses the exact international definition (1 yard = 0.9144 meters).</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A project needs 3.5 yards of fabric at $12.99 per yard, with 7% sales tax.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Subtotal:</span> <span class="text-slate-600">3.5 × $12.99 = $45.47</span></div>
        <div><span class="font-medium text-slate-700">Tax:</span> <span class="text-slate-600">$45.47 × 0.07 = $3.18</span></div>
        <div><span class="font-medium text-slate-700">Total:</span> <span class="text-slate-600"><strong>$48.65</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Budgeting a sewing project before committing to it is the main use case — knowing a dress will cost roughly $50 in fabric alone, before cutting into a limited budget, helps decide between a mid-range cotton and a pricier silk before either is purchased and non-returnable.
    </p>
    <p class="mt-3 text-slate-600">
      Comparing two online fabric retailers with different bolt widths is a less obvious but common case: a narrower fabric at a lower per-yard price can end up costing more in total once the extra yardage needed to cover the same pattern pieces is factored in, which only becomes clear once both totals are calculated side by side rather than compared by unit price alone.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"The cheapest price per yard is always the best deal." <strong class="text-slate-900">Not once yardage differs.</strong> A narrower or less efficiently printed fabric can require significantly more yardage for the same project, erasing the per-yard savings once the total is calculated.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Fabric prices always include tax." <strong class="text-slate-900">Rarely online.</strong> Most online fabric retailers show a pre-tax price and calculate tax at checkout based on your shipping address, so budget for it separately when comparing listed prices.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Yardage Calculator</a>
      <a href="/tools/fabric-unit-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Unit Converter</a>
      <a href="/tools/quick-cost-sheet-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Quick Cost Sheet Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let unit = 'Per yard';

    function update() {
      const qty = parseFloat(el('qty').value);
      const price = parseFloat(el('price').value);
      const tax = parseFloat(el('tax').value) || 0;
      if (!qty || !price || qty <= 0 || price <= 0) { el('results').classList.add('hidden'); return; }
      const sub = qty * price;
      const taxAmt = sub * (tax / 100);
      const total = sub + taxAmt;
      el('r-sub').textContent = '$' + sub.toFixed(2);
      el('r-tax').textContent = '$' + taxAmt.toFixed(2);
      el('r-total').textContent = '$' + total.toFixed(2);
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.unit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.unit-btn').forEach((b) => {
          b.className = 'unit-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'unit-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        unit = btn.dataset.unit;
        const u = unit === 'Per yard' ? 'yard' : 'meter';
        el('qty-label').textContent = u.charAt(0).toUpperCase() + u.slice(1) + 's needed';
        el('price-label').textContent = 'Price per ' + u + ' ($)';
        update();
      });
    });

    ['qty', 'price', 'tax'].forEach((id) => el(id).addEventListener('input', update));
    document.querySelector('.unit-btn').click();
  </script>
</ToolLayout>
