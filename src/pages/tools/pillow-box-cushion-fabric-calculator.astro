---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Pillow Cover / Box Cushion Fabric Calculator';
const description = 'Calculate fabric needed for a flat pillow cover or a box cushion with a boxing strip, from finished dimensions.';
const intro = 'Calculate fabric yardage for a flat pillow cover or a box cushion with side boxing.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is a boxing strip?', a: 'A boxing strip (or gusset) is the fabric band sewn around the sides of a box cushion, giving it depth — a flat pillow cover has no boxing strip since front and back panels are sewn directly together at the edge.' },
  { q: 'How much seam allowance should I add?', a: 'A standard 0.5-inch seam allowance is common for pillow and cushion covers; enter your finished size and the calculator adds the seam allowance to all sides automatically.' },
  { q: 'Do I need extra fabric for a zipper?', a: 'A small additional allowance (often 1-2 inches) on the panel with the zipper opening is common to accommodate the zipper facing and overlap — add this to your seam allowance input if your design includes a zipper closure.' },
  { q: 'How is boxing strip length calculated for an odd-shaped cushion?', a: 'This calculator assumes a rectangular cushion, where boxing strip length equals the perimeter (2 × length + 2 × width). For a round or custom-shaped cushion, measure the actual perimeter directly and use it in place of the calculated rectangular perimeter.' },
];
const howTo = {
  name: 'How to calculate pillow and cushion fabric',
  steps: [
    { name: 'Choose flat pillow or box cushion', text: 'Select whether you\'re making a flat pillow cover or a box cushion with boxing.' },
    { name: 'Enter finished dimensions', text: 'Enter width, length, and (for box cushions) height, plus seam allowance.' },
    { name: 'Read fabric needed', text: 'Total fabric yardage for all panels appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Flat pillow', 'Box cushion'].map((d) => (
        <button data-type={d} class="type-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (in)</span>
        <input id="width" type="number" step="any" placeholder="e.g. 20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (in)</span>
        <input id="length" type="number" step="any" placeholder="e.g. 20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label id="height-field" class="hidden block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="height" type="number" step="any" placeholder="e.g. 4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Seam allowance (in)</span>
        <input id="sa" type="number" step="any" value="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fabric width (in)</span>
        <input id="fabWid" type="number" step="any" value="54" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Fabric needed</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="pbc-title pbc-desc">
      <title id="pbc-title">Box cushion with front, back, and boxing strip labeled</title>
      <desc id="pbc-desc">A 3D-style cushion diagram showing a top panel, bottom panel, and a boxing strip wrapped around the sides</desc>
      <rect x="300" y="40" width="200" height="120" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <rect x="270" y="60" width="30" height="100" fill="#f0abfc" stroke="#c026d3" stroke-width="1.5" />
      <text x="400" y="105" text-anchor="middle" font-size="13" fill="#86198f" font-family="system-ui,sans-serif">Top panel</text>
      <text x="600" y="100" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Boxing strip</text>
      <text x="600" y="118" font-size="13" fill="#475569" font-family="system-ui,sans-serif">wraps the sides</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A box cushion needs two panels plus a boxing strip around the perimeter</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How pillow and cushion fabric is calculated</h2>
    <p class="mt-2 text-slate-600">
      A flat pillow cover needs two panels (front and back), each the finished width and length plus seam allowance on every side, so total fabric is simply twice that panel's area, laid out to fit your fabric's width. A box cushion needs the same two panels for top and bottom, plus a boxing strip that wraps around the sides — this strip's length equals the cushion's perimeter (2 × width + 2 × length) and its width equals the cushion height plus seam allowance.
    </p>
    <p class="mt-3 text-slate-600">
      The calculator adds these pieces together, accounting for how many fit per row across your fabric's width, to give a total yardage figure covering every panel needed for the cover.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows standard home-decor sewing construction for flat pillow covers and boxed cushions with a separate boxing strip.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 20 × 20 inch box cushion, 4 inches deep, 0.5-inch seam allowance, 54-inch fabric.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Panel size (each):</span> <span class="text-slate-600">21 × 21 in</span></div>
        <div><span class="font-medium text-slate-700">Boxing strip:</span> <span class="text-slate-600">perimeter 84 in × 5 in wide</span></div>
        <div><span class="font-medium text-slate-700">Total length needed:</span> <span class="text-slate-600">≈ 42 + 84 = 126 in</span></div>
        <div><span class="font-medium text-slate-700">Fabric needed:</span> <span class="text-slate-600">126 ÷ 36 ≈ <strong>3.5 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Outdoor patio furniture cushions are one of the most common box-cushion projects, since replacement covers for weathered factory cushions are often expensive to buy pre-made but straightforward to sew once fabric quantity is known — getting the boxing strip length right the first time avoids piecing together short offcuts around a cushion's full perimeter.
    </p>
    <p class="mt-3 text-slate-600">
      Matching a set of throw pillows to a room's decor is the classic flat-pillow-cover use case, and calculating combined yardage for several pillows at once (rather than estimating per pillow) usually finds a more efficient fabric layout and avoids buying in awkward partial-yard increments repeatedly.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A box cushion just needs a bit more fabric than a flat pillow of the same size." <strong class="text-slate-900">Often significantly more.</strong> The boxing strip alone can equal or exceed the fabric used for both flat panels combined, especially on a deep cushion, so box cushions frequently need noticeably more total fabric than a flat cover of the same footprint.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Seam allowance only matters on the outer edges." <strong class="text-slate-900">It applies everywhere fabric pieces join.</strong> The boxing strip needs seam allowance on both long edges (where it joins the top and bottom panels), not just where it's cut to length.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/tablecloth-fabric-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Tablecloth Fabric Calculator</a>
      <a href="/tools/zipper-length-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Zipper Length Calculator</a>
      <a href="/tools/fabric-cost-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Cost Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let type = 'Flat pillow';

    function update() {
      const width = parseFloat(el('width').value);
      const length = parseFloat(el('length').value);
      const sa = parseFloat(el('sa').value) || 0;
      const fabWid = parseFloat(el('fabWid').value);
      if (!width || !length || !fabWid || width <= 0 || length <= 0 || fabWid <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const panelW = width + 2 * sa;
      const panelL = length + 2 * sa;
      const perRow = Math.max(1, Math.floor(fabWid / panelW));
      const rows = Math.ceil(2 / perRow); // 2 panels: front + back / top + bottom
      let totalIn = rows * panelL;

      if (type === 'Box cushion') {
        const perimeter = 2 * (width + length);
        totalIn += perimeter; // boxing strip cut along its own length
      }

      el('r-yards').textContent = (totalIn / 36).toFixed(2) + ' yd';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.type-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.type-btn').forEach((b) => {
          b.className = 'type-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'type-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        type = btn.dataset.type;
        el('height-field').classList.toggle('hidden', type !== 'Box cushion');
        update();
      });
    });

    ['width', 'length', 'height', 'sa', 'fabWid'].forEach((id) => el(id).addEventListener('input', update));
    document.querySelector('.type-btn').click();
  </script>
</ToolLayout>
