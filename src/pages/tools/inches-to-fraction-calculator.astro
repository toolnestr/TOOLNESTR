---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Inches to Fraction Calculator';
const description =
  'Convert decimal inches to fractional inches with denominators of 1/2, 1/4, 1/8, 1/16, 1/32, and 1/64.';
const intro =
  'Convert decimal inches to the nearest fractional inch with your choice of denominator.';
const category = { id: 'converters', name: 'Converters' };
const faqs = [
  { q: 'What denominators are supported?', a: '1/2, 1/4, 1/8, 1/16, 1/32, and 1/64. Select the precision you need — finer denominators give more accurate conversions.' },
  { q: 'How do I read a fraction like 3/16?', a: 'The top number (numerator) tells how many parts, the bottom (denominator) tells the size of each part. 3/16 means 3 parts of a 16th of an inch.' },
  { q: 'What is the most common fraction in construction?', a: '1/16 inch increments are standard for most tape measures. 1/32 is used for precision woodworking and machining.' },
  { q: 'Can I convert fractions back to decimal?', a: 'Yes. Select the denominator and the calculator shows the exact decimal equivalent of the result fraction.' },
  { q: 'Why would I need 1/64 precision?', a: 'Machining, metalworking, and engineering tolerances often require 1/64 inch precision or finer.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Decimal inches</span>
      <input id="decimal" type="number" step="any" min="0" value="2.375"
        class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </label>
    <label class="block mt-3">
      <span class="text-sm font-medium text-slate-700">Fraction precision</span>
      <select id="denom"
        class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="2">1/2</option>
        <option value="4">1/4</option>
        <option value="8">1/8</option>
        <option value="16" selected>1/16</option>
        <option value="32">1/32</option>
        <option value="64">1/64</option>
      </select>
    </label>
    <div class="mt-6 grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-slate-50 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Fraction</div>
        <div id="r-frac" class="mt-1 text-2xl font-bold text-slate-800">—</div>
      </div>
      <div class="rounded-xl bg-indigo-50 p-4">
        <div class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Exact decimal</div>
        <div id="r-exact" class="mt-1 text-2xl font-bold text-indigo-700">—</div>
      </div>
    </div>
    <div id="error" class="mt-3 hidden rounded-xl bg-amber-50 p-3 text-sm text-amber-800">Enter a positive number.</div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ruler-title ruler-desc">
      <title id="ruler-title">Ruler with fraction ticks</title>
      <desc id="ruler-desc">A ruler showing inch markings with increasingly smaller tick marks for halves, quarters, eighths, and sixteenths</desc>
      <rect x="40" y="60" width="720" height="30" rx="4" fill="#fbbf24" stroke="#d97706" stroke-width="1.5" />
      <line x1="40" y1="60" x2="40" y2="40" stroke="#92400e" stroke-width="2" />
      <text x="40" y="35" text-anchor="middle" fill="#92400e" font-size="11" font-weight="bold">0</text>
      <line x1="220" y1="60" x2="220" y2="40" stroke="#92400e" stroke-width="2" />
      <text x="220" y="35" text-anchor="middle" fill="#92400e" font-size="11" font-weight="bold">1</text>
      <line x1="400" y1="60" x2="400" y2="40" stroke="#92400e" stroke-width="2" />
      <text x="400" y="35" text-anchor="middle" fill="#92400e" font-size="11" font-weight="bold">2</text>
      <line x1="580" y1="60" x2="580" y2="40" stroke="#92400e" stroke-width="2" />
      <text x="580" y="35" text-anchor="middle" fill="#92400e" font-size="11" font-weight="bold">3</text>
      <line x1="760" y1="60" x2="760" y2="40" stroke="#92400e" stroke-width="2" />
      <text x="760" y="35" text-anchor="middle" fill="#92400e" font-size="11" font-weight="bold">4</text>
      <line x1="130" y1="60" x2="130" y2="50" stroke="#d97706" stroke-width="2" />
      <line x1="310" y1="60" x2="310" y2="50" stroke="#d97706" stroke-width="2" />
      <line x1="490" y1="60" x2="490" y2="50" stroke="#d97706" stroke-width="2" />
      <line x1="670" y1="60" x2="670" y2="50" stroke="#d97706" stroke-width="2" />
      <text x="310" y="48" text-anchor="middle" fill="#d97706" font-size="9">1/2</text>
      <line x1="85" y1="60" x2="85" y2="55" stroke="#b45309" stroke-width="1.5" />
      <line x1="175" y1="60" x2="175" y2="55" stroke="#b45309" stroke-width="1.5" />
      <line x1="265" y1="60" x2="265" y2="55" stroke="#b45309" stroke-width="1.5" />
      <line x1="355" y1="60" x2="355" y2="55" stroke="#b45309" stroke-width="1.5" />
      <text x="175" y="54" text-anchor="middle" fill="#b45309" font-size="8">1/4</text>
      <line x1="62" y1="60" x2="62" y2="57" stroke="#92400e" stroke-width="1" />
      <line x1="107" y1="60" x2="107" y2="57" stroke="#92400e" stroke-width="1" />
      <line x1="152" y1="60" x2="152" y2="57" stroke="#92400e" stroke-width="1" />
      <line x1="197" y1="60" x2="197" y2="57" stroke="#92400e" stroke-width="1" />
      <text x="107" y="56" text-anchor="middle" fill="#92400e" font-size="7">1/8</text>
      <rect x="300" y="130" width="200" height="40" rx="8" fill="#eef2ff" stroke="#c7d2fe" stroke-width="1.5" />
      <text x="400" y="155" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">2 &frac38; inches</text>
      <path d="M400 60 L400 130" stroke="#6366f1" stroke-width="2" stroke-dasharray="4 4" marker-end="url(#fa)" />
      <defs><marker id="fa" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M0 0 L10 5 L0 10" fill="#6366f1" /></marker></defs>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Fraction precision on a ruler: 1/2, 1/4, 1/8, and 1/16 inch tick marks</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How inches to fraction conversion works</h2>
    <p class="mt-2 text-slate-600">
      Converting a decimal inch value to a fraction involves finding the nearest fractional equivalent at a given precision level. The calculator takes your decimal input, separates the whole number part from the fractional part, and finds the closest fraction with the chosen denominator. For example, 2.375 inches becomes 2 and 3/8 inches when using 1/8 precision, or 2 and 6/16 when using 1/16 precision.
    </p>
    <p class="mt-3 text-slate-600">
      The algorithm multiplies the fractional decimal by the chosen denominator, rounds to the nearest integer to get the numerator, and then simplifies the fraction by dividing both numerator and denominator by their greatest common divisor. If the fraction equals or exceeds the denominator, it rolls over into the whole number portion. The result is always shown as a whole number plus a proper fraction.
    </p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-1 rounded-xl bg-white p-4 font-mono text-sm text-slate-700">
      <div><span class="font-semibold">Numerator</span> = round(decimalPart × denominator)</div>
      <div><span class="font-semibold">Fraction</span> = numerator / denominator, simplified by GCD</div>
      <div><span class="font-semibold">Exact decimal</span> = whole + numerator / denominator</div>
    </div>
    <h3 class="mt-4 font-semibold text-slate-900">Worked example</h3>
    <p class="mt-1 text-sm text-slate-600">Convert <strong>2.375 inches</strong> to the nearest <strong>1/8</strong>.</p>
    <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
      <div><span class="font-medium text-slate-700">Whole part:</span> <span class="text-slate-600">2</span></div>
      <div><span class="font-medium text-slate-700">Decimal part:</span> <span class="text-slate-600">0.375</span></div>
      <div><span class="font-medium text-slate-700">Numerator:</span> <span class="text-slate-600">round(0.375 × 8) = round(3) = 3</span></div>
      <div><span class="font-medium text-slate-700">Fraction:</span> <span class="text-slate-600">3/8 (already simplified)</span></div>
      <div><span class="font-medium text-slate-700">Result:</span> <span class="text-slate-600">2 &frac38; inches</span></div>
      <div><span class="font-medium text-slate-700">Exact decimal:</span> <span class="text-slate-600">2 + 3/8 = 2.375</span></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🪚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Woodworking Plans</h3>
      <p class="mt-1 text-sm text-slate-600">Convert decimal measurements from digital plans to fractional inches for your tape measure. Most woodworking uses 1/16 or 1/32 precision.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔧</span>
      <h3 class="mt-2 font-semibold text-slate-900">Machining</h3>
      <p class="mt-1 text-sm text-slate-600">Engineering drawings often specify decimal tolerances. Convert to fractional inches for setup with imperial tools and measuring devices.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏠</span>
      <h3 class="mt-2 font-semibold text-slate-900">Home Renovation</h3>
      <p class="mt-1 text-sm text-slate-600">Standard tape measures show 1/16 increments. Convert any decimal measurement from a laser measure or digital caliper to readable fractions.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📐</span>
      <h3 class="mt-2 font-semibold text-slate-900">DIY Projects</h3>
      <p class="mt-1 text-sm text-slate-600">Whether building a shelf or framing a wall, convert between decimal and fractional inches to match the markings on your tools.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the inches to fraction calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter decimal</h3>
        <p class="mt-1 text-sm text-slate-600">Type the decimal inch value, such as 2.375 from a digital caliper or laser measure.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose precision</h3>
        <p class="mt-1 text-sm text-slate-600">Select your denominator from 1/2 to 1/64. Higher denominators give more precise but less readable fractions.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read and compare</h3>
        <p class="mt-1 text-sm text-slate-600">See the simplified fraction and its exact decimal equivalent side by side. Adjust precision as needed.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for fraction conversions</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Match precision to your tool</h3>
        <p class="mt-1 text-sm text-slate-600">A standard tape measure is marked in 1/16 increments. Use 1/32 or 1/64 only when working with machinist tools or engineering drawings.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Rounding introduces error</h3>
        <p class="mt-1 text-sm text-slate-600">Converting to a coarser fraction introduces rounding error. For example, 2.374 rounded to 1/8 gives 2 3/8 = 2.375, an error of 0.001 inches.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use mixed numbers</h3>
        <p class="mt-1 text-sm text-slate-900">Always express fractions in mixed number format (whole + fraction). An improper fraction like 19/8 is harder to read on a tape measure than 2 3/8.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/feet-and-inches-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📏</span>
        <h3 class="mt-1 font-semibold text-slate-900">Feet & Inches Calculator</h3>
        <p class="text-sm text-slate-600">Add, subtract, multiply measurements in ft+in.</p>
      </a>
      <a href="/tools/fraction-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">➗</span>
        <h3 class="mt-1 font-semibold text-slate-900">Fraction Calculator</h3>
        <p class="text-sm text-slate-600">General fraction arithmetic tool.</p>
      </a>
      <a href="/tools/unit-converter" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📐</span>
        <h3 class="mt-1 font-semibold text-slate-900">Unit Converter</h3>
        <p class="text-sm text-slate-600">All-purpose length and measurement converter.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    function gcd(a, b) { return b ? gcd(b, a % b) : a; }
    function update() {
      const dec = parseFloat(document.getElementById('decimal').value);
      const den = parseInt(document.getElementById('denom').value, 10);
      const err = document.getElementById('error');
      if (isNaN(dec) || dec < 0) { err.classList.remove('hidden'); return; }
      err.classList.add('hidden');
      const whole = Math.floor(dec);
      const frac = dec - whole;
      const num = Math.round(frac * den);
      let n = num, d = den;
      if (num >= den) { whole + Math.floor(num / den); n = num % den; }
      const g = gcd(n, d);
      n = n / g; d = d / g;
      const fracStr = n === 0 ? '' : n + '/' + d;
      const disp = whole > 0 && n > 0 ? whole + ' ' + n + '/' + d : (whole > 0 ? String(whole) : (n > 0 ? n + '/' + d : '0'));
      document.getElementById('r-frac').textContent = disp + ' in';
      const exact = whole + n / d;
      document.getElementById('r-exact').textContent = exact.toFixed(6) + ' in';
    }
    document.getElementById('decimal').addEventListener('input', update);
    document.getElementById('denom').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
