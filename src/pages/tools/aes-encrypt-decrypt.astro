---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'AES Encrypt & Decrypt';
const description = 'Encrypt or decrypt text with AES-256-CBC using a passphrase. All processing happens in your browser.';
const intro = 'Encrypt or decrypt text with AES-256-CBC using a passphrase.';
const category = { id: 'security', name: 'Security & Hash' };
const faqs = [
  { q: 'Is my data sent to a server?', a: 'No — encryption and decryption happen entirely in your browser using the Web Crypto API.' },
  { q: 'What encryption standard is used?', a: 'AES-256-CBC (Advanced Encryption Standard, 256-bit key in Cipher Block Chaining mode).' },
  { q: 'Can you decrypt without the password?', a: 'No — AES-256 is computationally infeasible to brute force with current technology.' },
  { q: 'What format is the encrypted output?', a: 'Base64-encoded ciphertext with the IV and salt prepended (salt+IV+ciphertext format).' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="space-y-4">
      <div>
        <label class="text-sm font-medium text-slate-700" for="plaintext">Plain text / Ciphertext</label>
        <textarea id="plaintext" rows="5" placeholder="Type or paste text to encrypt, or paste ciphertext to decrypt…" class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-4 font-mono text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></textarea>
      </div>

      <div>
        <label class="text-sm font-medium text-slate-700" for="password">Passphrase</label>
        <div class="relative mt-1">
          <input id="password" type="password" placeholder="Enter your passphrase…" class="w-full rounded-xl border border-slate-300 p-3 pr-12 font-mono text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <button id="toggle-pw" type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600" aria-label="Toggle passphrase visibility">
            <svg id="eye-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
          </button>
        </div>
      </div>

      <div class="flex flex-wrap gap-2">
        <button id="encrypt-btn" class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Encrypt</button>
        <button id="decrypt-btn" class="rounded-lg border border-indigo-300 px-5 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-50">Decrypt</button>
        <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
      </div>

      <div>
        <label class="text-sm font-medium text-slate-700">Output</label>
        <div class="mt-1 flex items-stretch gap-2">
          <textarea id="output" readonly rows="4" placeholder="Result will appear here…" class="w-full resize-y rounded-xl border border-slate-200 bg-slate-50 p-4 font-mono text-sm outline-none"></textarea>
          <button id="copy-btn" class="shrink-0 rounded-xl bg-indigo-600 px-4 text-sm font-medium text-white transition hover:bg-indigo-700">Copy</button>
        </div>
      </div>

      <div id="status" class="hidden rounded-lg px-3 py-2 text-sm font-medium"></div>
    </div>
  </div>

  <figure>
    <svg xmlns="http://www.w3.org/2000/svg" width="800" height="220" viewBox="0 0 800 220">
      <title>AES-256-CBC Encryption and Decryption Diagram</title>
      <desc>Flow diagram showing plaintext, key, and encryption producing ciphertext; then ciphertext and key decryption producing plaintext</desc>
