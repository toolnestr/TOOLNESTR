      <text x="350" y="54" font-family="sans-serif" font-size="10" fill="#c7d2fe" text-anchor="middle">Encryption</text>
      <text x="350" y="70" font-family="sans-serif" font-size="10" fill="#c7d2fe" text-anchor="middle">PBKDF2 key derivation</text>
      <text x="350" y="86" font-family="sans-serif" font-size="10" fill="#c7d2fe" text-anchor="middle">100,000 iterations</text>
      <line x1="450" y1="60" x2="510" y2="60" stroke="#6366f1" stroke-width="2" />
      <polygon points="510,55 525,60 510,65" fill="#6366f1" />
      <rect x="530" y="30" width="150" height="60" fill="#fef3c7" rx="8" stroke="#f59e0b" stroke-width="1" />
