      <polygon points="350,105 345,115 355,115" fill="#94a3b8" />
      <rect x="250" y="115" width="200" height="90" fill="#10b981" rx="8" />
      <text x="350" y="138" font-family="sans-serif" font-size="13" fill="#ffffff" text-anchor="middle" font-weight="bold">AES-256-CBC</text>
      <text x="350" y="154" font-family="sans-serif" font-size="10" fill="#d1fae5" text-anchor="middle">Decryption</text>
      <text x="350" y="170" font-family="sans-serif" font-size="10" fill="#d1fae5" text-anchor="middle">Same passphrase required</text>
      <text x="350" y="186" font-family="sans-serif" font-size="10" fill="#d1fae5" text-anchor="middle">Same salt + IV extracted</text>
      <line x1="450" y1="160" x2="510" y2="160" stroke="#10b981" stroke-width="2" />
      <polygon points="510,155 525,160 510,165" fill="#10b981" />
      <rect x="530" y="130" width="150" height="60" fill="#e2e8f0" rx="8" />
      <text x="605" y="156" font-family="sans-serif" font-size="13" fill="#475569" text-anchor="middle" font-weight="bold">Plaintext</text>
      <text x="605" y="174" font-family="monospace" font-size="10" fill="#64748b" text-anchor="middle">"Hello, World!"</text>
      <rect x="20" y="130" width="130" height="60" fill="#e0f2fe" rx="8" stroke="#0ea5e9" stroke-width="1" />
      <text x="85" y="156" font-family="sans-serif" font-size="13" fill="#0284c7" text-anchor="middle" font-weight="bold">Passphrase</text>
      <text x="85" y="174" font-family="monospace" font-size="10" fill="#0c4a6e" text-anchor="middle">"my secret key"</text>
      <path d="M 85 130 L 85 108 L 240 108" fill="none" stroke="#f59e0b" stroke-width="1.5" />
      <polygon points="240,103 250,108 240,113" fill="#f59e0b" />
