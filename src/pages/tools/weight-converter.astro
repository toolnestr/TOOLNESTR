---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Kilograms", sym: "kg", toBase: 1 }, { name: "Grams", sym: "g", toBase: 0.001 }, { name: "Milligrams", sym: "mg", toBase: 0.000001 }, { name: "Metric tons", sym: "t", toBase: 1000 }, { name: "Pounds", sym: "lb", toBase: 0.45359237 }, { name: "Ounces", sym: "oz", toBase: 0.0283495231 }, { name: "Stone", sym: "st", toBase: 6.35029 }];
---
<MultiUnitConverter
  title="Weight Converter"
  emoji="⚖️"
  quantity="weight"
  baseName="kilogram"
  units={units}
  defaultFrom={0} defaultTo={4}
  intro="Convert between weight units — kilograms, grams, milligrams, metric tons, pounds and more."
  blurb="Weight (mass) is measured in metric and imperial units that this tool moves between."
  related={[{"slug":"kg-to-lbs","label":"Kg to Lbs Converter"},{"slug":"grams-to-ounces","label":"Grams to Ounces Converter"},{"slug":"stone-to-kg","label":"Stone to Kg Converter"}]}
/>
