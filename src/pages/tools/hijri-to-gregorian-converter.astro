---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Hijri to Gregorian Converter';
const description = 'Convert any Hijri (Islamic) date to the Gregorian calendar instantly, using the Umm al-Qura calendar, with the weekday shown.';
const intro = 'Pick a Hijri day, month and year to see the matching Gregorian date and weekday.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const months = ['Muharram', 'Safar', "Rabi' al-Awwal", "Rabi' al-Thani", 'Jumada al-Awwal', 'Jumada al-Thani', 'Rajab', "Sha'ban", 'Ramadan', 'Shawwal', "Dhul-Qa'dah", 'Dhul-Hijjah'];
const faqs = [
  { q: 'How does the Hijri calendar work?', a: 'The Hijri calendar is lunar, with 12 months of 29 or 30 days and a year of about 354 days — roughly 11 days shorter than the Gregorian year. Months traditionally begin with the sighting of the new crescent moon.' },
  { q: 'Why can the converted date differ by a day?', a: 'Calculated calendars like Umm al-Qura may differ by a day from local moon-sighting, since the start of a month depends on whether the crescent is actually seen. Treat the result as a close estimate and verify important dates locally.' },
  { q: 'What is the Umm al-Qura calendar?', a: 'Umm al-Qura is the official calculated Islamic calendar of Saudi Arabia, widely used for administrative dates. This converter uses it through your browser’s internationalisation engine.' },
  { q: 'Does the Hijri calendar have leap years?', a: 'In tabular versions, 11 of every 30 years are leap years with an extra day in the last month. Umm al-Qura is based on astronomical calculation rather than a fixed leap pattern, so month lengths vary year to year.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Day</span>
        <input id="hd" type="number" min="1" max="30" step="1" placeholder="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Month</span>
        <select id="hm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">{months.map((m, i) => <option value={i + 1}>{i + 1}. {m}</option>)}</select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Year (AH)</span>
        <input id="hy" type="number" min="1" step="1" placeholder="1446" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-6 text-center text-white">
      <div class="text-sm opacity-80">Gregorian date</div>
      <div id="r-date" class="mt-1 text-2xl font-bold">—</div>
      <div id="r-week" class="mt-1 text-sm opacity-90"></div>
    </div>
    <p id="err" class="mt-3 hidden text-sm text-rose-600"></p>
  </div>

  <figure class="mt-10">
    <svg width="800" height="170" viewBox="0 0 800 170" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="hg-title hg-desc">
      <title id="hg-title">Dual calendar strip Hijri to Gregorian</title>
      <desc id="hg-desc">A Hijri date on the left maps across to its Gregorian equivalent on the right.</desc>
      <rect x="40" y="55" width="300" height="60" rx="10" fill="#eef2ff" stroke="#a5b4fc" /><text x="190" y="80" text-anchor="middle" font-size="14" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">Hijri (AH)</text><text x="190" y="100" text-anchor="middle" font-size="12" fill="#4f46e5" font-family="system-ui,sans-serif">lunar · ~354 days</text>
      <path d="M350 85 L450 85" stroke="#94a3b8" stroke-width="2" marker-end="url(#ar)" /><defs><marker id="ar" markerWidth="10" markerHeight="10" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#94a3b8" /></marker></defs>
      <rect x="460" y="55" width="300" height="60" rx="10" fill="#f8fafc" stroke="#cbd5e1" /><text x="610" y="80" text-anchor="middle" font-size="14" fill="#1e293b" font-family="system-ui,sans-serif" font-weight="bold">Gregorian (CE)</text><text x="610" y="100" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">solar · ~365 days</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Each Hijri date maps to one Gregorian date using the Umm al-Qura calendar.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the converter works</h2>
    <p class="mt-2 text-slate-600">The Hijri (Islamic) calendar and the Gregorian calendar count time differently. The Hijri year is lunar — twelve cycles of the moon totalling about 354 days — while the Gregorian year is solar, at roughly 365 days. Because of this 11-day gap, the same Hijri date lands on a different Gregorian date every year, drifting earlier through the seasons. This tool removes the guesswork by mapping any Hijri date you enter to its exact Gregorian equivalent.</p>
    <p class="mt-3 text-slate-600">Under the hood, the converter uses your browser’s built-in Umm al-Qura calendar — the official calculated Islamic calendar of Saudi Arabia. It searches for the Gregorian day whose Umm al-Qura date matches your input exactly, then reports that date along with the day of the week. Everything is computed locally, so your dates are never sent anywhere.</p>
    <p class="mt-3 text-slate-600">Use it to translate a birthday, an anniversary, a historical event or a religious occasion from the Islamic calendar into a date you can mark on a standard calendar. Because calculated calendars can differ from local moon-sighting by a day, treat the result as an accurate estimate and confirm critical dates with your local authority.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The Hijri months</h2>
    <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
      {months.map((m, i) => (<div class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700"><span class="font-semibold text-indigo-600">{i + 1}.</span> {m}</div>))}
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">1 Ramadan 1446 AH converts to around 1 March 2025 CE — the likely first day of fasting that year, subject to local sighting.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/gregorian-to-hijri-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gregorian to Hijri Converter</a>
      <a href="/tools/hijri-date-today" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Today’s Hijri Date</a>
      <a href="/tools/age-in-hijri-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Age in Hijri Years</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', { day: 'numeric', month: 'numeric', year: 'numeric', timeZone: 'UTC' });
    function hijriOf(d) { const o = {}; fmt.formatToParts(d).forEach((p) => { if (p.type !== 'literal') o[p.type] = parseInt(p.value, 10); }); return o; }
    function toGregorian(hy, hm, hd) {
      let date = new Date(Date.UTC(Math.floor(hy * 0.970224 + 621), 0, 1));
      for (let i = 0; i < 8; i++) {
        const h = hijriOf(date);
        const diff = (hy - h.year) * 354 + (hm - h.month) * 29.53 + (hd - h.day);
        if (Math.abs(diff) < 1) break;
        date = new Date(date.getTime() + Math.round(diff) * 86400000);
      }
      let guard = 0;
      while (guard++ < 90) {
        const h = hijriOf(date);
        if (h.year === hy && h.month === hm && h.day === hd) return date;
        const cmp = (h.year - hy) || (h.month - hm) || (h.day - hd);
        date = new Date(date.getTime() + (cmp > 0 ? -1 : 1) * 86400000);
      }
      return date;
    }
    function update() {
      const hd = parseInt(el('hd').value, 10), hm = parseInt(el('hm').value, 10), hy = parseInt(el('hy').value, 10);
      el('err').classList.add('hidden');
      if (!hd || !hm || !hy || hd < 1 || hd > 30) { el('result').classList.add('hidden'); return; }
      try {
        const g = toGregorian(hy, hm, hd);
        const check = hijriOf(g);
        el('r-date').textContent = g.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
        el('r-week').textContent = g.toLocaleDateString('en-US', { weekday: 'long', timeZone: 'UTC' });
        if (check.day !== hd || check.month !== hm) { el('err').textContent = 'That day may not exist in this Hijri month — showing the nearest date.'; el('err').classList.remove('hidden'); }
        el('result').classList.remove('hidden');
      } catch (e) { el('err').textContent = 'Conversion not supported in this browser.'; el('err').classList.remove('hidden'); }
    }
    ['hd', 'hy'].forEach((id) => el(id).addEventListener('input', update));
    el('hm').addEventListener('change', update);
  </script>
</ToolLayout>
