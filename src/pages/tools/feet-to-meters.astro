---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Feet to Meters"
  emoji="📏"
  fromUnit="feet" toUnit="meters"
  fromTitle="Feet" toTitle="Meters"
  fromSym="ft" toSym="m"
  quantity="length"
  kind="factor" factor={0.3048}
  reverseSlug="meters-to-feet" reverseLabel="Meters to Feet Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Turn distances in feet into meters for architecture, athletics and scientific work."
/>
