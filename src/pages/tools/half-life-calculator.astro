---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Half-Life Calculator';
const description = "Half-life calculator. Solve for remaining quantity, initial quantity, elapsed time, or half-life using exponential decay.";
const intro = 'Enter any three of initial quantity, remaining quantity, elapsed time, or half-life to solve for the fourth. Two 3D diagrams compare an early-decay and late-decay sample, and charts trace the exponential decay curve and compare common isotope half-lives.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is half-life?', a: 'Half-life (t½) is the time required for a radioactive substance to decay to half of its original amount. After one half-life, 50% remains; after two, 25%; after three, 12.5%, and so on.' },
  { q: 'Is half-life always constant?', a: 'Yes — half-life is a fixed property of each radioactive isotope. It does not change with temperature, pressure, or chemical state. Carbon-14 has a half-life of 5,730 years regardless of its environment.' },
  { q: 'How is half-life used in carbon dating?', a: 'Carbon-14 has a half-life of 5,730 years. By measuring the remaining C-14 in an organic sample relative to the initial amount, scientists can determine roughly how long ago the organism died.' },
  { q: 'What is the decay constant?', a: 'The decay constant λ is related to half-life by λ = ln(2) / t½. It represents the probability of decay per unit time and appears in the exponential decay formula N = N₀ × e^(−λt).' },
  { q: 'Does half-life apply to non-radioactive processes?', a: 'Yes — the half-life concept applies to any process following exponential decay, including drug metabolism in the body, capacitor discharge, and the removal of pollutants from the environment.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Half-Life Calculator',
  description: 'Solve for remaining quantity, initial quantity, elapsed time, or half-life using exponential decay.',
  steps: [
    { name: 'Enter any three values', text: 'Provide initial quantity, remaining quantity, elapsed time, or half-life — leave the unknown blank.' },
    { name: 'Read the result', text: 'The missing value solves instantly using the exponential decay relationship.' },
    { name: 'Compare isotopes', text: 'Reference common half-lives to understand realistic decay timescales.' },
  ],
};

const formulas = [
  { expr: 'N = N₀ × (½)^(t / t½)', note: 'remaining quantity — N₀=initial, t=elapsed time, t½=half-life' },
  { expr: 'N = N₀ × e^(−λt)', note: 'equivalent exponential form, λ = ln(2) / t½ (decay constant)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — Cobalt-60 decay over time', tone: 'slate',
    given: 'A 10 g sample of Cobalt-60 (half-life 5.27 years) is stored for 15.81 years. How much remains?',
    rows: [
      { label: 'Half-lives elapsed:', value: '15.81 / 5.27 = 3 half-lives' },
      { label: 'Formula:', value: 'N = N₀ × (½)^n' },
      { label: 'Result:', value: 'N = 10 × (½)³ = 10 × 0.125 = 1.25 g', full: true },
    ],
    note: 'After exactly 3 half-lives, only 12.5% of the original Cobalt-60 remains — this predictable decay pattern is why Cobalt-60 sources need periodic replacement in radiotherapy machines.',
  },
  {
    title: 'Worked example 2 — finding half-life from decay data', tone: 'amber',
    given: 'A 50 g sample decays to 6.25 g after 12 years. Find the half-life.',
    rows: [
      { label: 'Fraction remaining:', value: 'N/N₀ = 6.25/50 = 0.125 = (½)³, so 3 half-lives have elapsed' },
      { label: 'Formula:', value: 't½ = t / (elapsed half-lives)' },
      { label: 'Result:', value: 't½ = 12 / 3 = 4 years', full: true },
    ],
    note: 'Recognizing that 0.125 is exactly (½)³ makes this calculation straightforward — the general formula handles cases where the fraction isn\'t a clean power of ½.',
  },
];

const comparison = {
  heading: 'Half-lives of common isotopes',
  note: 'Half-lives span an enormous range — from fractions of a second to billions of years — depending entirely on the isotope\'s nuclear stability.',
  headers: [{ label: 'Isotope' }, { label: 'Half-life' }, { label: 'Common use' }],
  rows: [
    ['Technetium-99m', '6.01 hours', 'Medical imaging'],
    ['Iodine-131', '8.02 days', 'Thyroid treatment'],
    ['Cobalt-60 ★', '5.27 years', 'Radiotherapy, sterilization'],
    ['Carbon-14', '5,730 years', 'Archaeological dating'],
    ['Uranium-238', '4.47 × 10⁹ years', 'Geological dating'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). Each isotope\'s half-life dictates its practical use — short half-lives suit quick medical procedures, long ones suit dating ancient materials.',
};

const realWorld = [
  { emoji: '🕰️', title: 'Radiocarbon dating', body: 'Archaeologists estimate the age of once-living organic material by measuring how much Carbon-14 remains relative to stable Carbon-12, using its well-known 5,730-year half-life.' },
  { emoji: '🏥', title: 'Nuclear medicine and radiotherapy', body: 'Medical physicists calculate how radioactive tracers and treatment sources decay in the body or in equipment, ensuring the correct dose reaches target tissue while minimizing exposure elsewhere.' },
  { emoji: '☢️', title: 'Nuclear waste storage planning', body: 'Nuclear engineers calculate radioactive decay for spent fuel storage, determining how long waste must be safely contained before its radioactivity drops to acceptable levels.' },
  { emoji: '🧬', title: 'Environmental contamination tracking', body: 'Environmental scientists use half-life data to predict how long radioactively contaminated areas will remain hazardous and to plan remediation timelines.' },
];

const misconceptions = [
  { claim: '"After 2 half-lives, all of the substance has decayed."', truth: 'After 2 half-lives, 25% remains, not 0% — decay is exponential, so the quantity approaches (but mathematically never quite reaches) zero, no matter how many half-lives pass.' },
  { claim: '"You can find remaining quantity by simple linear subtraction (e.g. half the original amount lost every year for a 1-year half-life)."', truth: "Decay is exponential, not linear — each half-life removes half of whatever remains at that point, not a fixed absolute amount. After 7 half-lives, less than 1% of the original material remains." },
  { claim: '"A radioactive material\'s half-life depends on its temperature or chemical form."', truth: "Half-life is a fixed nuclear property of each isotope, completely unaffected by temperature, pressure, or the chemical compound the atom is part of — only the nucleus itself determines the decay rate." },
  { claim: '"Half-life measures how long until a substance becomes completely safe."', truth: 'Half-life only measures the time for half the material to decay — a substance can remain measurably radioactive for many half-lives beyond the first, so "safe" thresholds depend on the specific isotope and application, not a single half-life.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 21, "Nuclear Chemistry" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/21-4-transmutation-and-nuclear-energy" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 21, Nuclear Chemistry.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Radioactive decay kinetics.' },
];
const sourcesNote = 'N = N₀×(½)^(t/t½), equivalently N = N₀×e^(−λt) with λ=ln(2)/t½. Reference half-lives are standard nuclear-data values. Results are rounded for display.';

const howToUse = [
  { title: 'Enter any three values', body: 'Provide initial quantity, remaining quantity, elapsed time, or half-life — leave the unknown blank.' },
  { title: 'Read the fourth value', body: 'The missing value solves instantly, using consistent units throughout.' },
  { title: 'Reference common isotopes', body: 'Compare your result against known half-lives for medical, dating, or industrial isotopes.' },
];

const related = [
  { href: '/tools/arrhenius-equation-calculator', emoji: '🏔️', title: 'Arrhenius Equation Calculator', desc: 'k = Ae^(-Ea/RT), or find Ea from two (T,k) points.' },
  { href: '/tools/reaction-rate-calculator', emoji: '⏳', title: 'Reaction Rate Calculator', desc: 'rate = |ΔX| / (coefficient × Δt) — reactant or product.' },
  { href: '/tools/isotope-calculator', emoji: '☢️', title: 'Isotope Calculator', desc: 'Protons, neutrons, electrons — plus weighted average atomic mass.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="radioactive decay always removes the same fraction (one half) of whatever quantity currently remains during each half-life period — never a fixed absolute amount — which is exactly what makes the decay curve exponential rather than a straight line."
  howIntro="Each half-life period, by definition, halves whatever quantity remains: N = N₀ × (½)^(t/t½) captures this directly, where t/t½ counts how many half-life periods have elapsed (including fractional ones). The equivalent exponential form N = N₀ × e^(−λt) uses the decay constant λ = ln(2)/t½, which represents the same physics in the natural-log-based form more common in calculus-based derivations of decay kinetics."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where half-life actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any three values to solve for the fourth.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial quantity (N₀)</span>
        <input id="n0" type="number" step="any" placeholder="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Remaining (N)</span>
        <input id="n" type="number" step="any" placeholder="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Elapsed time (t)</span>
        <input id="t" type="number" step="any" placeholder="years" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Half-life (t½)</span>
        <input id="hl" type="number" step="any" placeholder="years" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Initial (N₀)</div><div id="r-n0" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Remaining (N)</div><div id="r-n" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Elapsed (t)</div><div id="r-t" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Half-life (t½)</div><div id="r-hl" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="hl-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Early vs late decay</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-early" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Early in the decay (many atoms remain)</h3>
          <p class="mt-1 text-sm text-slate-600">A dense cluster of undecayed atoms (indigo) with only a few decayed atoms (grey) so far.</p>
        </div>
        <div>
          <div id="diag-late" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Several half-lives later (few atoms remain)</h3>
          <p class="mt-1 text-sm text-slate-600">Most atoms have now decayed (grey) — only a small fraction of the original indigo atoms remain undecayed.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Half-life graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Exponential decay curve (N₀=100, t½=5 years)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-decay"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Half-life comparison across isotopes (log scale)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-isotopes"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator (preserves original three-of-four solve logic) ----
      function update() {
        const n0 = parseFloat(el('n0').value);
        const n = parseFloat(el('n').value);
        const t = parseFloat(el('t').value);
        const hl = parseFloat(el('hl').value);
        const filled = [!isNaN(n0), !isNaN(n), !isNaN(t), !isNaN(hl)];
        const count = filled.filter(Boolean).length;
        el('hl-err').textContent = '';
        ['r-n0', 'r-n', 'r-t', 'r-hl'].forEach((id) => (el(id).textContent = '—'));
        if (count < 3) return;
        if (n0 < 0 || n < 0 || hl < 0) { el('hl-err').textContent = 'Quantities and half-life cannot be negative.'; return; }
        let rn0 = NaN, rn = NaN, rt = NaN, rhl = NaN;
        if (!filled[0]) { rn0 = n * Math.pow(2, t / hl); rn = n; rt = t; rhl = hl; }
        else if (!filled[1]) { rn = n0 * Math.pow(0.5, t / hl); rn0 = n0; rt = t; rhl = hl; }
        else if (!filled[2]) { if (n <= 0 || n0 <= 0) { el('hl-err').textContent = 'Quantities must be positive.'; return; } rt = hl * (Math.log(n / n0) / Math.log(0.5)); rn0 = n0; rn = n; rhl = hl; }
        else if (!filled[3]) { if (n <= 0 || n0 <= 0) { el('hl-err').textContent = 'Quantities must be positive.'; return; } const ratio = n / n0; if (ratio >= 1) { el('hl-err').textContent = 'Remaining must be less than initial.'; return; } rhl = t / (Math.log(ratio) / Math.log(0.5)); rn0 = n0; rn = n; rt = t; }
        if (!isNaN(rn0)) el('r-n0').textContent = fmt(rn0);
        if (!isNaN(rn)) el('r-n').textContent = fmt(rn);
        if (!isNaN(rt)) el('r-t').textContent = fmt(rt);
        if (!isNaN(rhl)) el('r-hl').textContent = fmt(rhl);
      }
      ['n0', 'n', 't', 'hl'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsT = [], dataN = [];
        for (let t = 0; t <= 20; t += 1) { labelsT.push(t); dataN.push(+(100 * Math.pow(0.5, t / 5)).toFixed(2)); }
        charts.decay = new Chart(el('chart-decay'), {
          type: 'line',
          data: { labels: labelsT, datasets: [{ label: 'N', data: dataN, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (years)' } }, y: { title: { display: true, text: 'Remaining quantity' } } }, plugins: { legend: { display: false } } }),
        });
        const isos = [{ n: 'Tc-99m (hr)', v: 6.01 / 8760 }, { n: 'I-131 (yr)', v: 8.02 / 365 }, { n: 'Co-60', v: 5.27 }, { n: 'C-14', v: 5730 }, { n: 'U-238', v: 4.47e9 }];
        charts.isotopes = new Chart(el('chart-isotopes'), {
          type: 'bar',
          data: { labels: isos.map((i) => i.n), datasets: [{ label: 'Half-life (years)', data: isos.map((i) => i.v), backgroundColor: ['#94a3b8', '#38bdf8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Half-life (years, log scale)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function decayScene(container, remainingFrac) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const total = 30;
        const remaining = Math.round(total * remainingFrac);
        for (let i = 0; i < total; i++) {
          const phi = Math.acos(1 - (2 * (i + 0.5)) / total);
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const r = 2.2;
          const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
          const color = i < remaining ? 0x6366f1 : 0x94a3b8;
          const atom = new THREE.Mesh(new THREE.SphereGeometry(0.28, 14, 12), new THREE.MeshStandardMaterial({ color }));
          atom.position.set(x, y, z);
          s.scene.add(atom);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagEarly = null, diagLate = null;
      function initDiagEarly() { const c = el('diag-early'); if (!c) throw new Error('no container'); diagEarly = decayScene(c, 0.87); }
      function initDiagLate() { const c = el('diag-late'); if (!c) throw new Error('no container'); diagLate = decayScene(c, 0.12); }

      function boot() {
        try { update(); } catch (e) { console.error('[half-life] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[half-life] charts failed', e); }
        if (window.THREE) {
          try { initDiagEarly(); } catch (e) { console.error('[half-life] early diagram failed', e); }
          try { initDiagLate(); } catch (e) { console.error('[half-life] late diagram failed', e); }
        }
        mountResize([diagEarly, diagLate]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
