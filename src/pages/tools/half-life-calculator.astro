---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Half-Life Calculator';
const description = 'Free online half-life calculator. Calculate remaining quantity, initial quantity, elapsed time, or half-life for radioactive decay.';
const intro = 'Enter any three values — initial quantity, remaining quantity, elapsed time, or half-life — to solve for the fourth.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is half-life?', a: 'Half-life (t½) is the time required for a radioactive substance to decay to half of its original amount. After one half-life, 50% remains; after two, 25%; after three, 12.5%, and so on.' },
  { q: 'Is half-life always constant?', a: 'Yes, half-life is a fixed property of each radioactive isotope. It does not change with temperature, pressure, or chemical state. Carbon-14 has a half-life of 5,730 years regardless of its environment.' },
  { q: 'How is half-life used in carbon dating?', a: 'Carbon-14 has a half-life of 5,730 years. By measuring the remaining C-14 in an organic sample and comparing it to the initial amount, scientists can determine how long ago the organism died.' },
  { q: 'What is the decay constant?', a: 'The decay constant λ is related to half-life by λ = ln(2) / t½. It represents the probability of decay per unit time and is used in the exponential decay formula N = N₀ × e^(-λt).' },
  { q: 'Can half-life be used for non-radioactive processes?', a: 'Yes. The half-life concept applies to any process that follows exponential decay, including drug metabolism in the body, capacitor discharge, and the elimination of pollutants from the environment.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any three values to solve for the fourth</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial quantity (N₀)</span>
        <input id="n0" type="number" step="any" placeholder="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Remaining (N)</span>
        <input id="n" type="number" step="any" placeholder="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Elapsed time (t)</span>
        <input id="t" type="number" step="any" placeholder="years" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Half-life (t½)</span>
        <input id="hl" type="number" step="any" placeholder="years" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Initial (N₀)</div><div id="r-n0" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Remaining (N)</div><div id="r-n" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Elapsed (t)</div><div id="r-t" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Half-life (t½)</div><div id="r-hl" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="hl-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="hl-title hl-desc">
      <title id="hl-title">Exponential decay curve stepping down by half</title>
      <desc id="hl-desc">A step-wise exponential decay curve showing the quantity halving after each half-life period</desc>
      <g transform="translate(40,10)">
        <line x1="60" y1="240" x2="740" y2="240" stroke="#94a3b8" stroke-width="2"/>
        <line x1="60" y1="240" x2="60" y2="30" stroke="#94a3b8" stroke-width="2"/>
        <path d="M 60 30 L 200 30 L 200 130 L 340 130 L 340 185 L 480 185 L 480 215 L 620 215 L 620 230 L 740 230" stroke="#6366f1" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="60" cy="30" r="5" fill="#6366f1"/>
        <text x="60" y="20" text-anchor="middle" fill="#4338ca" font-size="12" font-weight="bold">100%</text>
        <circle cx="200" cy="130" r="5" fill="#6366f1"/>
        <text x="200" y="120" text-anchor="middle" fill="#4338ca" font-size="12" font-weight="bold">50%</text>
        <circle cx="340" cy="185" r="5" fill="#6366f1"/>
        <text x="340" y="175" text-anchor="middle" fill="#4338ca" font-size="12" font-weight="bold">25%</text>
        <circle cx="480" cy="215" r="5" fill="#6366f1"/>
        <text x="480" y="208" text-anchor="middle" fill="#4338ca" font-size="12" font-weight="bold">12.5%</text>
        <circle cx="620" cy="230" r="5" fill="#6366f1"/>
        <text x="620" y="223" text-anchor="middle" fill="#4338ca" font-size="12" font-weight="bold">6.25%</text>
        <line x1="130" y1="255" x2="130" y2="240" stroke="#f59e0b" stroke-width="1.5" stroke-dasharray="3 2"/>
        <text x="130" y="270" text-anchor="middle" fill="#f59e0b" font-size="11">t½</text>
        <line x1="270" y1="255" x2="270" y2="240" stroke="#f59e0b" stroke-width="1.5" stroke-dasharray="3 2"/>
        <text x="270" y="270" text-anchor="middle" fill="#f59e0b" font-size="11">t½</text>
        <line x1="410" y1="255" x2="410" y2="240" stroke="#f59e0b" stroke-width="1.5" stroke-dasharray="3 2"/>
        <text x="410" y="270" text-anchor="middle" fill="#f59e0b" font-size="11">t½</text>
        <text x="400" y="295" text-anchor="middle" fill="#64748b" font-size="13">Time →</text>
        <text x="20" y="140" text-anchor="middle" fill="#64748b" font-size="13" transform="rotate(-90 20 140)">Quantity</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Exponential decay curve: after each half-life, exactly half of the remaining radioactive atoms decay</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How half-life is calculated</h2>
    <p class="mt-2 text-slate-600">Radioactive decay follows an exponential pattern described by <span class="font-mono">N = N₀ × (½)^(t / t½)</span>, where N₀ is the initial quantity, N is the remaining quantity, t is elapsed time, and t½ is the half-life. The decay can also be expressed using the decay constant: <span class="font-mono">N = N₀ × e^(-λt)</span>, where λ = ln(2) / t½. After n half-lives, the fraction remaining is (½)^n.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 10 g sample of Cobalt-60 (half-life 5.27 years) is stored for 15.81 years. How much remains?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Initial mass:</span> <span class="text-slate-600">10 g</span></div>
        <div><span class="font-medium text-slate-700">Elapsed time:</span> <span class="text-slate-600">15.81 years</span></div>
        <div><span class="font-medium text-slate-700">Half-lives:</span> <span class="text-slate-600">15.81 / 5.27 = 3 half-lives</span></div>
        <div><span class="font-medium text-slate-700">Remaining:</span> <span class="text-slate-600">10 × (½)³ = 10 × 0.125 = 1.25 g</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x2697;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Nuclear Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate radioactive decay for spent fuel storage, determine when waste becomes safe, and design shielding based on isotope activity over time.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F52C;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Medical Physicist</h3>
      <p class="mt-1 text-sm text-slate-600">Plan radiation therapy treatments by calculating how radioactive tracers decay in the body. Ensure the correct dose is delivered to the target tissue while minimising exposure to healthy tissue.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F9EC;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Environmental Scientist</h3>
      <p class="mt-1 text-sm text-slate-600">Track environmental contamination from radioactive isotopes. Calculate how long affected areas will remain hazardous and plan remediation timelines based on half-life data.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Chemistry Student</h3>
      <p class="mt-1 text-sm text-slate-600">Solve half-life problems for homework and exam preparation. Understand the exponential nature of radioactive decay and the relationship between half-life and decay constant.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the half-life calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter three known values</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in any three of the four fields. All values should use consistent units — typically grams and years, but any unit works as long as you are consistent.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Instant fourth value</h3>
        <p class="mt-1 text-sm text-slate-600">The missing value is solved and displayed immediately. The highlighted box shows the solved variable in the set of four.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Common isotope reference</h3>
        <p class="mt-1 text-sm text-slate-600">Carbon-14 (5730 yr), Uranium-238 (4.47×10⁹ yr), Iodine-131 (8.02 days), Technetium-99m (6.01 hr). Use these half-lives for dating and medical applications.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for half-life calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Exponential decay is not linear</h3>
        <p class="mt-1 text-sm text-slate-600">After 7 half-lives, less than 1% of the original material remains. After 10 half-lives, less than 0.1%. You cannot simply divide the total decay time by the half-life linearly — use the exponential formula.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use consistent time units</h3>
        <p class="mt-1 text-sm text-slate-600">Both elapsed time and half-life must use the same time unit (years, days, hours, seconds). If half-life is in years and elapsed time is in days, convert first.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Radioactive dating applications</h3>
        <p class="mt-1 text-sm text-slate-600">Carbon-14 dating works for organic materials up to about 50,000 years old. Uranium-lead dating can date rocks billions of years old. Each isotope has a useful dating range based on its half-life.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/atomic-mass-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2697;&#xFE0F;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molar Mass Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Sum atomic masses from chemical formula.</p>
      </a>
      <a href="/tools/ideal-gas-law-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1FAEB;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Ideal Gas Law Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">PV=nRT — solve for any variable.</p>
      </a>
      <a href="/tools/ph-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F9EA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">pH Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">pH from hydrogen ion concentration.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 4, maximumFractionDigits: 6 });
    function update() {
      const n0 = parseFloat(el('n0').value);
      const n = parseFloat(el('n').value);
      const t = parseFloat(el('t').value);
      const hl = parseFloat(el('hl').value);
      const filled = [!isNaN(n0), !isNaN(n), !isNaN(t), !isNaN(hl)];
      const count = filled.filter(Boolean).length;
      el('hl-err').textContent = '';
      ['r-n0', 'r-n', 'r-t', 'r-hl'].forEach(id => el(id).textContent = '—');
      if (count < 3) return;
      if (n0 < 0 || n < 0 || hl < 0) { el('hl-err').textContent = 'Quantities and half-life cannot be negative.'; return; }
      let rn0 = NaN, rn = NaN, rt = NaN, rhl = NaN;
      if (!filled[0]) { rn0 = n * Math.pow(2, t / hl); rn = n; rt = t; rhl = hl; }
      else if (!filled[1]) { rn = n0 * Math.pow(0.5, t / hl); rn0 = n0; rt = t; rhl = hl; }
      else if (!filled[2]) { if (n <= 0 || n0 <= 0) { el('hl-err').textContent = 'Quantities must be positive.'; return; } rt = hl * (Math.log(n / n0) / Math.log(0.5)); rn0 = n0; rn = n; rhl = hl; }
      else if (!filled[3]) { if (n <= 0 || n0 <= 0) { el('hl-err').textContent = 'Quantities must be positive.'; return; } const ratio = n / n0; if (ratio >= 1) { el('hl-err').textContent = 'Remaining must be less than initial.'; return; } rhl = t / (Math.log(ratio) / Math.log(0.5)); rn0 = n0; rn = n; rt = t; }
      if (!isNaN(rn0)) el('r-n0').textContent = fmt(rn0);
      if (!isNaN(rn)) el('r-n').textContent = fmt(rn);
      if (!isNaN(rt)) el('r-t').textContent = fmt(rt);
      if (!isNaN(rhl)) el('r-hl').textContent = fmt(rhl);
    }
    ['n0', 'n', 't', 'hl'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
