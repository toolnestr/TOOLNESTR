---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Quilt Binding Calculator';
const description = 'Calculate how much binding fabric and how many strips you need for a quilt from its dimensions. Get accurate yardage before you cut any fabric.';
const intro = 'Calculate binding strips and total fabric yardage needed from your quilt\'s dimensions.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What binding strip width should I use?', a: 'A 2.5-inch strip width is the most common choice for standard double-fold binding on a quilt with typical batting thickness; use a narrower 2-inch strip for a thinner finished binding, or wider (2.75-3 inches) for thicker batting.' },
  { q: 'Why does the calculator add extra to the perimeter?', a: 'Mitered corners and the diagonal seam used to join binding strips into one continuous length both consume a bit more fabric than the quilt\'s exact perimeter, so a standard allowance (about 10-15 inches) is added to avoid running short at the very end.' },
  { q: 'How wide is the usable strip length from my fabric?', a: 'This depends on your fabric\'s width minus a small trim allowance for the selvage edges — this calculator assumes a standard 40-inch usable width from a typical 42-44 inch quilting cotton bolt, which you can adjust.' },
  { q: 'Should I cut strips on the straight grain or the bias?', a: 'Straight-grain strips are standard for most quilts with straight edges; bias-cut binding is used for quilts with curved edges since it stretches to follow curves, but bias binding uses noticeably more fabric for the same finished length.' },
];
const howTo = {
  name: 'How to calculate quilt binding',
  steps: [
    { name: 'Enter quilt dimensions', text: 'Enter the finished quilt length and width in inches.' },
    { name: 'Set strip width and fabric width', text: 'Enter your chosen binding strip width and the usable width of your fabric.' },
    { name: 'Read strips and yardage needed', text: 'The calculator shows how many strips to cut and the total fabric needed.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Quilt length (in)</span>
        <input id="qLen" type="number" step="any" placeholder="e.g. 90" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Quilt width (in)</span>
        <input id="qWid" type="number" step="any" placeholder="e.g. 66" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Binding strip width (in)</span>
        <input id="stripWid" type="number" step="any" value="2.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Usable fabric width (in)</span>
        <input id="fabWid" type="number" step="any" value="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Fabric needed for binding</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Perimeter + allowance</div><div id="r-perim" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Strips to cut</div><div id="r-strips" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="qbc-title qbc-desc">
      <title id="qbc-title">Quilt rectangle with binding strip around the edge</title>
      <desc id="qbc-desc">A rectangle representing a quilt with a colored border strip around its perimeter representing the binding</desc>
      <rect x="220" y="30" width="360" height="160" fill="#f5d0fe" stroke="#c026d3" stroke-width="10" />
      <text x="400" y="115" text-anchor="middle" font-size="14" fill="#86198f" font-family="system-ui,sans-serif">Quilt top</text>
      <text x="620" y="55" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Binding wraps</text>
      <text x="620" y="73" font-size="13" fill="#475569" font-family="system-ui,sans-serif">the perimeter</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Binding length must cover the full perimeter, joined from multiple strips</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How quilt binding is calculated</h2>
    <p class="mt-2 text-slate-600">
      Binding needs to wrap the entire perimeter of the quilt, so the calculator starts with 2 × (length + width), then adds a standard allowance (about 10-15 inches) for the diagonal seams that join binding strips end to end and for turning mitered corners cleanly, both of which use slightly more fabric than the flat perimeter measurement alone.
    </p>
    <p class="mt-3 text-slate-600">
      That total binding length is then divided by your usable fabric width to find how many strips need to be cut, and the number of strips multiplied by your chosen strip width gives the total fabric needed, converted to yards.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows the standard perimeter-plus-allowance method used across quilting references for straight-grain, continuous double-fold binding.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 90 × 66 inch quilt, 2.5-inch binding strips, cut from 40-inch-usable-width fabric.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Perimeter:</span> <span class="text-slate-600">2 × (90 + 66) = 312 in</span></div>
        <div><span class="font-medium text-slate-700">With allowance:</span> <span class="text-slate-600">312 + 12 = 324 in</span></div>
        <div><span class="font-medium text-slate-700">Strips needed:</span> <span class="text-slate-600">ceil(324 ÷ 40) = 9</span></div>
        <div><span class="font-medium text-slate-700">Fabric needed:</span> <span class="text-slate-600">9 × 2.5 = 22.5 in ÷ 36 ≈ <strong>0.63 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Running short on binding fabric right at the final step of a quilt is a uniquely frustrating problem, since binding is usually the very last thing sewn after weeks or months of piecing and quilting — calculating the exact number of strips needed before cutting avoids discovering a shortfall when the project is otherwise finished.
    </p>
    <p class="mt-3 text-slate-600">
      Scrap-binding quilts, where the binding is pieced from many different leftover fabrics rather than one yardage cut, still benefit from this perimeter math — knowing the total binding length needed tells you how many scrap strips of varying length you need to piece together to reach that total.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Binding length equals the quilt perimeter exactly." <strong class="text-slate-900">Slightly more is needed.</strong> Mitered corners and the diagonal joining seams between strips both consume extra length beyond the flat perimeter measurement, which is why the standard allowance exists.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Wider binding strips always look better." <strong class="text-slate-900">Depends on the quilt.</strong> A binding strip that's too wide relative to the quilt's batting thickness can look bulky or uneven; strip width should be chosen to match batting loft, not just personal preference for a bigger border.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Yardage Calculator</a>
      <a href="/tools/bias-tape-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Bias Tape Calculator</a>
      <a href="/tools/fabric-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Cost Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const ALLOWANCE = 12;

    function update() {
      const qLen = parseFloat(el('qLen').value);
      const qWid = parseFloat(el('qWid').value);
      const stripWid = parseFloat(el('stripWid').value);
      const fabWid = parseFloat(el('fabWid').value);
      if (!qLen || !qWid || !stripWid || !fabWid || qLen <= 0 || qWid <= 0 || stripWid <= 0 || fabWid <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const perimeter = 2 * (qLen + qWid) + ALLOWANCE;
      const strips = Math.ceil(perimeter / fabWid);
      const totalIn = strips * stripWid;
      const yards = totalIn / 36;

      el('r-perim').textContent = perimeter.toFixed(0) + ' in';
      el('r-strips').textContent = strips;
      el('r-yards').textContent = yards.toFixed(2) + ' yd';
      el('results').classList.remove('hidden');
    }

    ['qLen', 'qWid', 'stripWid', 'fabWid'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
