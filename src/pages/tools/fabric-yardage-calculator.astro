---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fabric Yardage Calculator';
const description = 'Calculate how much fabric to buy for a sewing project from piece dimensions, fabric width, and quantity.';
const intro = 'Calculate the total fabric yardage needed for any project from piece size, quantity, and fabric width.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What fabric width should I enter?', a: 'Use the usable width printed on the fabric bolt or listing, typically 44-45 inches for quilting cotton, 54-60 inches for home decor and apparel fabric, or 60 inches for many knits. This is the width across the bolt, not the length.' },
  { q: 'Why does the calculator round up to full rows?', a: 'Fabric can only be cut in whole pieces across its width — if 2.3 pieces fit across the fabric width, you can only actually cut 2, so the remaining piece needs its own additional length, which is why the calculator rounds down pieces-per-row and rounds up rows needed.' },
  { q: 'How much extra should I buy for waste?', a: 'A 10% buffer is a common default for straightforward projects; increase it to 15-20% for directional prints, plaids that need pattern matching, or fabric with nap (like velvet) that must all run the same direction.' },
  { q: 'Does this account for seam allowances?', a: 'Enter your piece dimensions already including seam allowance for the most accurate result — if your pattern lists finished size only, add your seam allowance to each dimension before entering it here.' },
];
const howTo = {
  name: 'How to calculate fabric yardage',
  steps: [
    { name: 'Enter piece dimensions and quantity', text: 'Enter the length and width of one piece (including seam allowance) and how many pieces you need.' },
    { name: 'Enter fabric width', text: 'Enter the usable width of the fabric bolt you plan to buy.' },
    { name: 'Read total yardage', text: 'The calculator shows total yards needed, including your chosen waste buffer.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Piece length (in)</span>
        <input id="pLen" type="number" step="any" placeholder="e.g. 30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Piece width (in)</span>
        <input id="pWid" type="number" step="any" placeholder="e.g. 20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of pieces</span>
        <input id="qty" type="number" step="1" placeholder="e.g. 4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fabric width (in)</span>
        <input id="fWid" type="number" step="any" value="45" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block sm:col-span-2"><span class="text-sm font-medium text-slate-700">Waste buffer (%)</span>
        <input id="waste" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Fabric to buy</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Pieces per row</div><div id="r-perrow" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Rows needed</div><div id="r-rows" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Total length (in)</div><div id="r-length" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fyc-title fyc-desc">
      <title id="fyc-title">Fabric bolt with pieces laid out in rows</title>
      <desc id="fyc-desc">A rectangle representing a fabric bolt width, with smaller rectangles arranged in rows to show how pieces are cut across it</desc>
      <rect x="100" y="30" width="600" height="160" fill="none" stroke="#94a3b8" stroke-width="2" />
      <rect x="110" y="40" width="140" height="65" fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      <rect x="260" y="40" width="140" height="65" fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      <rect x="110" y="115" width="140" height="65" fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      <rect x="260" y="115" width="140" height="65" fill="#f5d0fe" stroke="#c026d3" stroke-width="1.5" />
      <text x="400" y="20" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Fabric width</text>
      <text x="500" y="72" font-size="13" fill="#94a3b8" font-family="system-ui,sans-serif">2 pieces per row × 2 rows</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Yardage depends on how many pieces fit across the fabric width per row</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fabric yardage is calculated</h2>
    <p class="mt-2 text-slate-600">
      The calculator first works out how many pieces fit side by side across the fabric's width, by dividing fabric width by piece width and rounding down — you can't cut a partial piece across the width. It then divides your total quantity by that number and rounds up to find how many rows of pieces you need down the length of the fabric, since any leftover pieces still require a full additional row.
    </p>
    <p class="mt-3 text-slate-600">
      Multiplying rows needed by piece length gives the total fabric length required, in inches. Dividing by 36 converts that to yards, and the waste buffer percentage is added on top to cover cutting mistakes, pattern matching, and shrinkage from pre-washing.
    </p>
    <p class="mt-3 text-xs text-slate-400">This is standard yardage-estimation math used across the home-sewing industry; directional prints, large-scale plaids, and napped fabrics (velvet, corduroy) need a larger waste buffer than the general default.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">4 pillow panels, each 30 × 20 in, cut from 45-inch-wide fabric, with a 10% waste buffer.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Pieces per row:</span> <span class="text-slate-600">floor(45 ÷ 20) = 2</span></div>
        <div><span class="font-medium text-slate-700">Rows needed:</span> <span class="text-slate-600">ceil(4 ÷ 2) = 2</span></div>
        <div><span class="font-medium text-slate-700">Total length:</span> <span class="text-slate-600">2 × 30 = 60 in</span></div>
        <div><span class="font-medium text-slate-700">With 10% waste:</span> <span class="text-slate-600">60 × 1.1 = 66 in ÷ 36 ≈ <strong>1.83 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Sewing multiple identical pieces — quilt blocks, matching pillow covers, a set of napkins — is where this piece-and-row math matters most, since buying "roughly enough" fabric for multiples often leaves an awkward small remainder that isn't enough for one more full row. Calculating rows exactly avoids either an unexpected extra fabric-store trip or an expensive over-purchase.
    </p>
    <p class="mt-3 text-slate-600">
      Garment sewists run into this constantly when cutting several pattern pieces from the same yardage — sleeves, front and back bodice panels, and facings can often nest efficiently across a wider fabric, and understanding the pieces-per-row logic helps estimate whether a narrower or wider bolt will actually use less total fabric for the same set of pieces.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Doubling the fabric width always halves the yardage needed." <strong class="text-slate-900">Only if pieces divide evenly.</strong> If piece width doesn't divide cleanly into the fabric width, you can end up with leftover unusable strips regardless of how wide the bolt is, so the pieces-per-row rounding matters more than raw width.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"10% waste covers any fabric type." <strong class="text-slate-900">Not for directional prints.</strong> Fabric with a one-way design, nap, or a large-repeat pattern that needs matching across seams can require 20% or more extra to avoid mismatched or upside-down pieces.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Cost Calculator</a>
      <a href="/tools/fabric-unit-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Unit Converter</a>
      <a href="/tools/garment-fabric-estimator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Garment Fabric Estimator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const pLen = parseFloat(el('pLen').value);
      const pWid = parseFloat(el('pWid').value);
      const qty = parseInt(el('qty').value, 10);
      const fWid = parseFloat(el('fWid').value);
      const waste = parseFloat(el('waste').value) || 0;
      if (!pLen || !pWid || !qty || !fWid || pLen <= 0 || pWid <= 0 || qty <= 0 || fWid <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const perRow = Math.max(1, Math.floor(fWid / pWid));
      const rows = Math.ceil(qty / perRow);
      const lengthIn = rows * pLen;
      const yards = (lengthIn * (1 + waste / 100)) / 36;

      el('r-perrow').textContent = perRow;
      el('r-rows').textContent = rows;
      el('r-length').textContent = lengthIn.toFixed(1) + ' in';
      el('r-yards').textContent = yards.toFixed(2) + ' yd';
      el('results').classList.remove('hidden');
    }

    ['pLen', 'pWid', 'qty', 'fWid', 'waste'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
