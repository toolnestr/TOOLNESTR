---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Zakat on Gold Calculator';
const description = 'Calculate the 2.5% Zakat due on gold from its weight, karat (24, 22, 21 or 18) and current price per gram, with automatic nisab checking.';
const intro = 'Enter your gold weight, its karat and the live price per gram to see its value and the Zakat due.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'How does karat affect Zakat on gold?', a: 'Karat measures purity. 24 karat is pure gold (100%), 22 karat is 91.67%, 21 karat is 87.5% and 18 karat is 75%. Zakat is based on the actual gold content, so the calculator multiplies your weight by the karat purity before applying the price and the 2.5% rate.' },
  { q: 'How do I convert tola to grams?', a: 'One tola equals 11.6638 grams. If you weigh gold in tola, multiply by 11.6638 to get grams. This calculator accepts grams or tola directly and converts for you.' },
  { q: 'Is Zakat due on gold jewellery?', a: 'According to the majority view, Zakat is due on gold jewellery that is owned as wealth once it reaches the nisab. Some scholars exempt jewellery in regular personal use. Many people pay to be safe; follow the ruling you trust.' },
  { q: 'What is the nisab for gold?', a: 'The gold nisab is 87.48 grams of pure gold. If your total pure-gold content reaches or exceeds this and a lunar year has passed, Zakat of 2.5% of the value is due.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Gold weight</span>
        <input id="weight" type="number" step="any" placeholder="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Unit</span>
        <select id="unit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="g">Grams</option><option value="tola">Tola (11.6638 g)</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Price per gram (24k)</span>
        <input id="price" type="number" step="any" placeholder="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Karat (purity)</span>
      <div class="mt-1 flex flex-wrap gap-2">
        {['24k', '22k', '21k', '18k'].map((k) => (
          <button data-karat={k} class="karat-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{k}</button>
        ))}
      </div>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div id="due-card" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Zakat on this gold (2.5%)</div>
        <div id="r-due" class="mt-1 text-3xl font-bold tabular-nums">—</div>
        <div id="r-status" class="mt-1 text-sm opacity-90"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Pure gold content</div><div id="r-pure" class="mt-1 text-lg font-bold tabular-nums text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Gold value</div><div id="r-value" class="mt-1 text-lg font-bold tabular-nums text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Nisab (87.48 g)</div><div id="r-nisab" class="mt-1 text-lg font-bold tabular-nums text-slate-800">—</div></div>
      </div>
      <p class="rounded-xl bg-indigo-50 p-3 text-sm text-indigo-900 dark:bg-indigo-950/40 dark:text-indigo-200">
        Most scholars recommend the lower <strong>silver nisab</strong>. If you also hold any cash, silver or business assets, combine everything in the <a href="/tools/zakat-calculator" class="font-semibold underline">Zakat Calculator</a> — Zakat is then due on the total, including this gold, even when the gold alone is under the 87.48&nbsp;g gold nisab.
      </p>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="280" viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="zg-title zg-desc">
      <title id="zg-title">Gold bar with a karat purity scale</title>
      <desc id="zg-desc">A gold bar labelled by karat from 18k to 24k, showing that higher karat means higher purity and higher zakatable value.</desc>
      <rect x="120" y="90" width="240" height="100" rx="10" fill="#fbbf24" stroke="#b45309" stroke-width="2" />
      <rect x="140" y="105" width="200" height="20" rx="4" fill="#fde68a" />
      <text x="240" y="150" text-anchor="middle" font-size="18" font-weight="bold" fill="#78350f" font-family="system-ui,sans-serif">GOLD</text>
      <text x="240" y="172" text-anchor="middle" font-size="12" fill="#92400e" font-family="system-ui,sans-serif">weight &times; purity</text>
      {[['18k','75%'],['21k','87.5%'],['22k','91.7%'],['24k','100%']].map((p, i) => (
        <g>
          <rect x={430} y={70 + i * 32} width="120" height="24" rx="4" fill="#fef3c7" stroke="#f59e0b" />
          <text x={445} y={87 + i * 32} font-size="13" font-weight="bold" fill="#78350f" font-family="system-ui,sans-serif">{p[0]}</text>
          <text x={535} y={87 + i * 32} text-anchor="end" font-size="13" fill="#92400e" font-family="system-ui,sans-serif">{p[1]}</text>
        </g>
      ))}
      <text x="240" y="230" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Value &times; 2.5% = Zakat</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Zakat on gold is based on the pure gold content — weight multiplied by karat purity.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the gold Zakat calculator works</h2>
    <p class="mt-2 text-slate-600">Gold is one of the clearest forms of zakatable wealth in Islam. When the gold you own reaches the nisab and you have held it for a lunar year, 2.5% of its value is due as Zakat. This tool removes the arithmetic: you enter the weight, choose the karat, and add the live 24-karat price per gram, and it works out the pure gold content, the market value and the Zakat owed — all privately in your browser.</p>
    <p class="mt-3 text-slate-600">Because most jewellery is not pure gold, purity matters. A 22-karat chain is 91.67% gold and an 18-karat ring is only 75% gold. The calculator converts your weight to a pure-gold equivalent using the karat factor, so two pieces of the same weight but different karat are valued correctly. It then checks that pure-gold figure against the 87.48-gram nisab.</p>
    <p class="mt-3 text-slate-600">If you weigh gold in tola — common across South Asia and the Gulf — switch the unit and the tool converts using 1 tola = 11.6638 grams. Whatever unit you use, the final step is the same: value above the nisab is multiplied by 0.025 to give the Zakat amount.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4"><p class="font-semibold text-slate-900">Pure gold content</p><p class="mt-1 text-slate-600"><span class="font-mono">Pure g = weight (g) &times; karat purity</span> — 24k = 1.0, 22k = 0.9167, 21k = 0.875, 18k = 0.75.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-4"><p class="font-semibold text-slate-900">Value &amp; Zakat</p><p class="mt-1 text-slate-600"><span class="font-mono">Value = pure g &times; price per gram</span>; <span class="font-mono">Zakat = value &times; 0.025</span> when pure g &ge; 87.48.</p></div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">100 g of 22-karat gold, 24k price 60 per gram.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Pure gold:</span> <span class="text-slate-600">100 &times; 0.9167 = 91.67 g</span></div>
        <div><span class="font-medium text-slate-700">Value:</span> <span class="text-slate-600">91.67 &times; 60 = 5,500</span></div>
        <div><span class="font-medium text-slate-700">Meets nisab?</span> <span class="text-slate-600">91.67 &ge; 87.48 → yes</span></div>
        <div><span class="font-medium text-slate-700">Zakat:</span> <span class="text-slate-600">5,500 &times; 0.025 = <strong>137.50</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common situations</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">💍</span><h3 class="mt-2 font-semibold text-slate-900">Mixed jewellery</h3><p class="mt-1 text-sm text-slate-600">If you own pieces in different karats, calculate each separately and add the values, or convert all to pure-gold grams first. This keeps a 24k coin and an 18k bangle valued fairly.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🪙</span><h3 class="mt-2 font-semibold text-slate-900">Coins and bars</h3><p class="mt-1 text-sm text-slate-600">Investment coins and bars are usually 24k or 22k. They are clearly held as wealth, so Zakat applies straightforwardly once the nisab and lunar year are met.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">⚖️</span><h3 class="mt-2 font-semibold text-slate-900">Below the nisab</h3><p class="mt-1 text-sm text-slate-600">If your gold alone is below 87.48 g, combine its value with cash and silver in the main Zakat calculator — together they may still cross the threshold.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">📈</span><h3 class="mt-2 font-semibold text-slate-900">Price changes</h3><p class="mt-1 text-sm text-slate-600">Use the gold price on your Zakat anniversary, not the day you bought it. Because gold prices move, the value — and the Zakat — is taken at the moment Zakat falls due.</p></div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/zakat-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat Calculator</a>
      <a href="/tools/zakat-on-silver-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat on Silver Calculator</a>
      <a href="/tools/nisab-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Nisab Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let karat = '24k';
    const purity = { '24k': 1, '22k': 0.9167, '21k': 0.875, '18k': 0.75 };
    const num = (id) => { const v = parseFloat(el(id).value); return isFinite(v) ? v : 0; };

    function update() {
      let w = num('weight');
      if (el('unit').value === 'tola') w *= 11.6638;
      const price = num('price');
      if (w <= 0) { el('results').classList.add('hidden'); return; }
      const pure = w * purity[karat];
      const value = pure * price;
      const nisab = 87.48;
      const meets = pure >= nisab;
      const due = value * 0.025;
      const fmt = (n) => n.toLocaleString(undefined, { maximumFractionDigits: 2 });
      el('r-pure').textContent = fmt(pure) + ' g';
      el('r-value').textContent = price > 0 ? fmt(value) : '—';
      el('r-nisab').textContent = '87.48 g';
      el('r-due').textContent = price > 0 ? fmt(due) : 'enter price';
      el('r-status').textContent = meets
        ? 'This gold alone meets the 87.48 g gold nisab — Zakat is due.'
        : 'Below the 87.48 g (~7.5 tola) gold-only nisab. If gold is your only wealth, none is due — but under the recommended silver nisab, or with any other savings, the amount above applies.';
      el('due-card').className = 'rounded-xl p-5 text-center text-white ' + (meets ? 'bg-indigo-600' : 'bg-amber-600');
      el('results').classList.remove('hidden');
    }
    document.querySelectorAll('.karat-btn').forEach((btn) => btn.addEventListener('click', () => {
      document.querySelectorAll('.karat-btn').forEach((b) => b.className = 'karat-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50');
      btn.className = 'karat-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
      karat = btn.dataset.karat; update();
    }));
    ['weight', 'price'].forEach((id) => el(id).addEventListener('input', update));
    el('unit').addEventListener('change', update);
    document.querySelector('.karat-btn').click();
  </script>
</ToolLayout>
