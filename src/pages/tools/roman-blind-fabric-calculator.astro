---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Roman Blind Fabric Calculator';
const description = 'Calculate fabric needed for a Roman blind from window width and drop, including piecing for wide windows.';
const intro = 'Calculate fabric yardage for a Roman blind from window width, drop, and allowances.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How much extra should I add beyond the window measurement?', a: 'A common approach is adding roughly 3-4 inches to the width (for side hems and mounting) and 6-8 inches to the drop (for the header/mounting board allowance and bottom hem), though exact allowances depend on your specific mounting method.' },
  { q: 'Do Roman blinds need a fullness ratio like curtains?', a: 'No — unlike gathered curtains, Roman blinds are flat when raised and don\'t need extra fullness width, since the folds are created by the lift cords and rings, not by excess fabric.' },
  { q: 'What if my window is wider than the fabric?', a: 'The calculator adds a second fabric width seamed together (typically down the center or offset to avoid a visible center seam) when the required width exceeds one fabric width — this uses roughly double the length for the width portion of the blind.' },
  { q: 'Do I need extra fabric for a lining?', a: 'Most Roman blinds are lined for structure and light control, and that lining typically needs roughly the same yardage as the face fabric — calculate it separately since lining fabric width may differ from your face fabric.' },
];
const howTo = {
  name: 'How to calculate Roman blind fabric',
  steps: [
    { name: 'Enter window width and drop', text: 'Measure your window opening or the desired finished blind size.' },
    { name: 'Add width and drop allowances', text: 'Add allowances for side hems, header, and bottom hem.' },
    { name: 'Read fabric needed', text: 'Total fabric yardage, accounting for piecing if the window is wide, appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Window width (in)</span>
        <input id="winWidth" type="number" step="any" placeholder="e.g. 36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Window drop (in)</span>
        <input id="drop" type="number" step="any" placeholder="e.g. 48" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width allowance (in)</span>
        <input id="widAllow" type="number" step="any" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Drop allowance (in)</span>
        <input id="dropAllow" type="number" step="any" value="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block sm:col-span-2"><span class="text-sm font-medium text-slate-700">Fabric width (in)</span>
        <input id="fabWid" type="number" step="any" value="54" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Fabric needed</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Finished width</div><div id="r-width" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Fabric widths needed</div><div id="r-panels" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rbc-title rbc-desc">
      <title id="rbc-title">Roman blind shown flat and folded</title>
      <desc id="rbc-desc">A Roman blind diagram showing the flat fabric panel next to the same blind raised with horizontal folds</desc>
      <rect x="150" y="30" width="140" height="160" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <text x="220" y="205" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Lowered (flat)</text>
      <rect x="450" y="30" width="140" height="60" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <line x1="450" y1="45" x2="590" y2="45" stroke="#c026d3" stroke-width="1" />
      <line x1="450" y1="60" x2="590" y2="60" stroke="#c026d3" stroke-width="1" />
      <line x1="450" y1="75" x2="590" y2="75" stroke="#c026d3" stroke-width="1" />
      <text x="520" y="105" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Raised (folded)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Roman blinds fold flat, so no extra fullness width is needed</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How Roman blind fabric is calculated</h2>
    <p class="mt-2 text-slate-600">
      Unlike gathered curtains, Roman blinds hang flat when lowered and fold horizontally via lift cords and rings when raised, so no fullness ratio is needed — the fabric width simply needs to match the finished blind width plus a small allowance for side hems and mounting. This calculator adds your window width and width allowance together, then checks whether that fits within one width of your chosen fabric.
    </p>
    <p class="mt-3 text-slate-600">
      If the finished width exceeds the fabric's width, a second fabric width is added, seamed in (often centered or offset to keep the seam less visible), which uses the full drop length again for that second width. The drop is calculated similarly: window drop plus your drop allowance for the header/mounting board and bottom hem.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows standard home-decor sewing construction for flat, ring-and-cord Roman blinds.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 36-inch-wide, 48-inch-drop window, 4-inch width allowance, 8-inch drop allowance, 54-inch fabric.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Finished width:</span> <span class="text-slate-600">36 + 4 = 40 in</span></div>
        <div><span class="font-medium text-slate-700">Fabric widths needed:</span> <span class="text-slate-600">ceil(40 ÷ 54) = 1</span></div>
        <div><span class="font-medium text-slate-700">Cut length:</span> <span class="text-slate-600">48 + 8 = 56 in</span></div>
        <div><span class="font-medium text-slate-700">Fabric needed:</span> <span class="text-slate-600">56 ÷ 36 ≈ <strong>1.56 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Kitchen and bathroom windows are common Roman blind projects since the flat, tailored look suits smaller windows well, and most standard window widths fit comfortably within a single fabric width — making the calculation straightforward and the piecing question rarely come up.
    </p>
    <p class="mt-3 text-slate-600">
      Patio doors and picture windows are where the seaming question matters most, since these openings frequently exceed 54-60 inches — knowing in advance that a centered seam is needed lets a maker choose a fabric pattern that hides a seam well, rather than discovering the problem after the fabric is already cut.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Roman blinds need fullness fabric like curtains do." <strong class="text-slate-900">They don't.</strong> Roman blinds are flat when lowered, so unlike gathered curtains, no fullness ratio multiplier applies — only the window width plus a small hem/mounting allowance.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any leftover fabric from a wide seam can be reused for another project." <strong class="text-slate-900">Sometimes too narrow to be useful.</strong> The offcut from trimming a second fabric width down to fit is often an awkward narrow strip, so don't count on it covering a separate project when planning total purchases.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/curtain-panel-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Curtain Panel Calculator</a>
      <a href="/tools/lining-fabric-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Lining Fabric Calculator</a>
      <a href="/tools/fabric-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Cost Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const winWidth = parseFloat(el('winWidth').value);
      const drop = parseFloat(el('drop').value);
      const widAllow = parseFloat(el('widAllow').value) || 0;
      const dropAllow = parseFloat(el('dropAllow').value) || 0;
      const fabWid = parseFloat(el('fabWid').value);
      if (!winWidth || !drop || !fabWid || winWidth <= 0 || drop <= 0 || fabWid <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const finWidth = winWidth + widAllow;
      const panels = Math.ceil(finWidth / fabWid);
      const cutLen = drop + dropAllow;
      const totalIn = panels * cutLen;

      el('r-width').textContent = finWidth.toFixed(1) + ' in';
      el('r-panels').textContent = panels;
      el('r-yards').textContent = (totalIn / 36).toFixed(2) + ' yd';
      el('results').classList.remove('hidden');
    }

    ['winWidth', 'drop', 'widAllow', 'dropAllow', 'fabWid'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
