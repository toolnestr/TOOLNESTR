---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Heart Rate Zone Calculator';
const description =
  'Free heart rate zone calculator. Calculate your 5 heart rate training zones from your age and resting heart rate using the Karvonen method.';
const intro =
  'Enter your age and resting heart rate to find your 5 heart rate training zones for optimal exercise intensity.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What are heart rate zones?', a: 'Heart rate zones are intensity ranges expressed as a percentage of your maximum or reserve heart rate. Zone 1 (very light, 50-60%) through Zone 5 (maximum effort, 90-100%) help you train at the right intensity for your goals.' },
  { q: 'What is the Karvonen method?', a: 'The Karvonen formula uses your heart rate reserve (HRR = max HR minus resting HR) to calculate target zones. It is more personalised than simple percentage of max HR because it accounts for your resting heart rate.' },
  { q: 'How do I find my resting heart rate?', a: 'Measure your pulse first thing in the morning before getting out of bed. Count beats for 60 seconds. Do this for 3 mornings and average the results for the most accurate resting HR.' },
  { q: 'What is a normal max heart rate?', a: 'The traditional formula is 220 minus your age, but this has wide individual variation. A more accurate formula is 208 - 0.7 × age. Athletes may have higher or lower max HR than predicted.' },
  { q: 'Which zone should I train in?', a: 'Zone 2 (aerobic, 60-70%) builds endurance and is great for long sessions. Zone 3 (tempo, 70-80%) improves lactate threshold. Zone 4-5 (threshold/sprint) improves speed and power. Most training should be in Zones 2-3.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Age (years)</span>
      <input id="age" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Resting heart rate (bpm)</span>
      <input id="rest" type="number" step="1" placeholder="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated max heart rate</div>
        <div id="r-max" class="mt-1 text-3xl font-bold">—</div>
        <div class="text-sm opacity-80">bpm</div>
      </div>

      <div class="mt-4 space-y-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="flex items-center justify-between px-2"><span class="font-semibold text-slate-800">Zone 1</span><span class="text-sm text-slate-500">Very light</span><span class="font-medium text-indigo-600" id="r-z1">—</span></div><div class="mt-1 h-2 w-full rounded-full bg-slate-200"><div class="h-2 rounded-full bg-blue-400" id="b-z1" style="width:0%"></div></div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="flex items-center justify-between px-2"><span class="font-semibold text-slate-800">Zone 2</span><span class="text-sm text-slate-500">Light / Aerobic</span><span class="font-medium text-emerald-600" id="r-z2">—</span></div><div class="mt-1 h-2 w-full rounded-full bg-slate-200"><div class="h-2 rounded-full bg-green-500" id="b-z2" style="width:0%"></div></div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="flex items-center justify-between px-2"><span class="font-semibold text-slate-800">Zone 3</span><span class="text-sm text-slate-500">Moderate / Tempo</span><span class="font-medium text-amber-600" id="r-z3">—</span></div><div class="mt-1 h-2 w-full rounded-full bg-slate-200"><div class="h-2 rounded-full bg-amber-500" id="b-z3" style="width:0%"></div></div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="flex items-center justify-between px-2"><span class="font-semibold text-slate-800">Zone 4</span><span class="text-sm text-slate-500">Hard / Threshold</span><span class="font-medium text-orange-600" id="r-z4">—</span></div><div class="mt-1 h-2 w-full rounded-full bg-slate-200"><div class="h-2 rounded-full bg-orange-500" id="b-z4" style="width:0%"></div></div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="flex items-center justify-between px-2"><span class="font-semibold text-slate-800">Zone 5</span><span class="text-sm text-slate-500">Maximum / Sprint</span><span class="font-medium text-red-600" id="r-z5">—</span></div><div class="mt-1 h-2 w-full rounded-full bg-slate-200"><div class="h-2 rounded-full bg-red-500" id="b-z5" style="width:0%"></div></div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your age and resting heart rate to see your zones.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About heart rate zone training</h2>
    <p class="mt-2 text-slate-600">
      Heart rate zone training is one of the most effective ways to structure your exercise programme. By training at specific intensities, you can target different physiological adaptations. Zone 2 training builds your aerobic base and improves fat metabolism. Zone 3 (tempo) improves your lactate threshold. Zone 4 and 5 work on your anaerobic capacity and maximum power output. This calculator uses the <a href="https://pubmed.ncbi.nlm.nih.gov/15574794/" rel="noopener">Karvonen method (heart rate reserve)</a>, which is more personalised than the simple 220-minus-age formula because it accounts for your resting heart rate. For more ways to measure fitness, see the <a href="/tools/vo2-max-calculator" class="font-medium text-indigo-600 hover:underline">VO2 Max Calculator</a> and <a href="/tools/pace-calculator" class="font-medium text-indigo-600 hover:underline">Pace Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">For general information only. Consult a doctor before starting a new exercise programme.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" role="img" aria-labelledby="hrz-title hrz-desc">
      <title id="hrz-title">Heart rate training zones</title>
      <desc id="hrz-desc">Five concentric coloured bands representing heart rate zones 1 through 5 from outer to inner.</desc>
      <rect x="60" y="30" width="680" height="170" rx="10" fill="#e2e8f0" />
      <rect x="100" y="40" width="600" height="150" rx="8" fill="#bfdbfe" /><text x="400" y="100" text-anchor="middle" font-size="14" fill="#1e40af" font-weight="bold">Zone 1: 50-60%</text><text x="400" y="120" text-anchor="middle" font-size="12" fill="#1e40af">Very light — warm up / recovery</text>
      <rect x="140" y="55" width="520" height="120" rx="6" fill="#86efac" /><text x="400" y="100" text-anchor="middle" font-size="14" fill="#166534" font-weight="bold">Zone 2: 60-70%</text><text x="400" y="120" text-anchor="middle" font-size="12" fill="#166534">Light — aerobic endurance</text>
      <rect x="200" y="70" width="400" height="90" rx="4" fill="#fde68a" /><text x="400" y="100" text-anchor="middle" font-size="14" fill="#92400e" font-weight="bold">Zone 3: 70-80%</text><text x="400" y="120" text-anchor="middle" font-size="12" fill="#92400e">Moderate — tempo / lactate threshold</text>
      <rect x="280" y="85" width="240" height="60" rx="4" fill="#fdba74" /><text x="400" y="110" text-anchor="middle" font-size="12" fill="#7c2d12" font-weight="bold">Zone 4: 80-90% Hard</text>
      <rect x="360" y="100" width="80" height="30" rx="4" fill="#fca5a5" /><text x="400" y="120" text-anchor="middle" font-size="11" fill="#7f1d1d" font-weight="bold">Z5</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Five concentric heart rate zones — from outer (Zone 1, light) to inner (Zone 5, maximum)</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The calculator first estimates your maximum heart rate using the Tanaka formula (208 − 0.7 × age), which is more accurate than the traditional 220 minus age formula. It then calculates your Heart Rate Reserve (HRR = max HR − resting HR). Each zone is a percentage range of your HRR, added to your resting heart rate. For example, Zone 2 (60–70%) uses the formula: target HR = (HRR × 0.6) + resting HR to (HRR × 0.7) + resting HR. This method is personalised — a fit person with a low resting HR will have narrower zones than someone with a higher resting HR.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Max HR</strong> = 208 − 0.7 × age (Tanaka formula)<br>
      <strong>Heart Rate Reserve (HRR)</strong> = Max HR − Resting HR<br>
      <strong>Target HR</strong> = (HRR × intensity%) + Resting HR
    </p>
    <p class="mt-3 text-slate-600">
      The five zones are: Zone 1 (50–60%), Zone 2 (60–70%), Zone 3 (70–80%), Zone 4 (80–90%), Zone 5 (90–100%).
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 35-year-old with a resting heart rate of 62 bpm wants to find their Zone 2 range.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Max HR:</span> <span class="text-slate-600">208 − 0.7 × 35 = <strong>183.5 bpm</strong></span></div>
        <div><span class="font-medium text-slate-700">HRR:</span> <span class="text-slate-600">183.5 − 62 = <strong>121.5 bpm</strong></span></div>
        <div><span class="font-medium text-slate-700">Zone 2 low:</span> <span class="text-slate-600">(121.5 × 0.6) + 62 = <strong>135 bpm</strong></span></div>
        <div><span class="font-medium text-slate-700">Zone 2 high:</span> <span class="text-slate-600">(121.5 × 0.7) + 62 = <strong>147 bpm</strong></span></div>
        <div><span class="font-medium text-slate-700">Zone 3 low:</span> <span class="text-slate-600">(121.5 × 0.7) + 62 = <strong>147 bpm</strong></span></div>
        <div><span class="font-medium text-slate-700">Zone 4 low:</span> <span class="text-slate-600">(121.5 × 0.8) + 62 = <strong>159 bpm</strong></span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏃</span>
      <h3 class="mt-2 font-semibold text-slate-900">Endurance runner</h3>
      <p class="mt-1 text-sm text-slate-600">Use Zone 2 for long runs to build aerobic base without excessive fatigue. Most easy running should be in Zone 2.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚴</span>
      <h3 class="mt-2 font-semibold text-slate-900">Cyclist</h3>
      <p class="mt-1 text-sm text-slate-600">Train with power and heart rate zones together. Zone 3 tempo efforts build sustainable speed for longer rides.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏋️</span>
      <h3 class="mt-2 font-semibold text-slate-900">HIIT athlete</h3>
      <p class="mt-1 text-sm text-slate-600">Use Zone 4–5 for intervals. The high-intensity efforts improve VO2 max and anaerobic capacity.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🩺</span>
      <h3 class="mt-2 font-semibold text-slate-900">Cardiac rehab patient</h3>
      <p class="mt-1 text-sm text-slate-600">Zone 1–2 training under medical supervision helps rebuild cardiovascular fitness safely after a cardiac event.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your age</h3>
        <p class="mt-1 text-sm text-slate-600">Your age is used to estimate your maximum heart rate using the Tanaka formula.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure resting HR</h3>
        <p class="mt-1 text-sm text-slate-600">Take your resting pulse first thing in the morning for the most accurate result. Average over 3 mornings.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Train by zone</h3>
        <p class="mt-1 text-sm text-slate-600">Use a heart rate monitor during workouts. Stay within the target zone range for each session type and adjust as your fitness improves.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for zone training</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Spend most time in Zone 2</h3>
        <p class="mt-1 text-sm text-slate-600">The 80/20 rule suggests 80% of training should be easy (Zones 1–2) and 20% hard (Zones 4–5). This approach yields the best results for most athletes.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Re-test resting HR regularly</h3>
        <p class="mt-1 text-sm text-slate-600">As your fitness improves, your resting HR drops, which shifts your zones. Re-measure your resting HR every 4–6 weeks to keep your zones accurate.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use perceived exertion too</h3>
        <p class="mt-1 text-sm text-slate-600">Heart rate can lag during short intervals and drift during long sessions. Combine zones with Rate of Perceived Exertion (RPE) for the most effective training intensity management.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/vo2-max-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">VO2 Max Calculator</a>
      <a href="/tools/pace-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Pace Calculator</a>
      <a href="/tools/calories-burned-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Calories Burned Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const age = parseFloat(el('age').value);
      const rest = parseFloat(el('rest').value);
      if (!age || !rest || age <= 0 || rest <= 0 || rest > 220) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const max = 208 - 0.7 * age;
      const hrr = max - rest;
      const zones = [
        [50, 60, 'z1'],
        [60, 70, 'z2'],
        [70, 80, 'z3'],
        [80, 90, 'z4'],
        [90, 100, 'z5']
      ];
      el('r-max').textContent = Math.round(max);
      zones.forEach((z) => {
        const lo = Math.round(hrr * z[0] / 100 + rest);
        const hi = Math.round(hrr * z[1] / 100 + rest);
        el('r-' + z[2]).textContent = lo + ' - ' + hi + ' bpm';
        const barPct = z[0] + (z[1] - z[0]) / 2;
        el('b-' + z[2]).style.width = barPct + '%';
      });
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    ['age', 'rest'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
