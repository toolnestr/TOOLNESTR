---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Meters", sym: "m", toBase: 1 }, { name: "Kilometers", sym: "km", toBase: 1000 }, { name: "Centimeters", sym: "cm", toBase: 0.01 }, { name: "Millimeters", sym: "mm", toBase: 0.001 }, { name: "Miles", sym: "mi", toBase: 1609.344 }, { name: "Yards", sym: "yd", toBase: 0.9144 }, { name: "Feet", sym: "ft", toBase: 0.3048 }, { name: "Inches", sym: "in", toBase: 0.0254 }, { name: "Nautical miles", sym: "nmi", toBase: 1852 }];
---
<MultiUnitConverter
  title="Length Converter"
  emoji="📏"
  quantity="length"
  baseName="meter"
  units={units}
  defaultFrom={0} defaultTo={6}
  intro="Convert between length units — meters, kilometers, centimeters, millimeters, miles and more."
  blurb="Length measures distance, from the thickness of a wire to the span of a journey."
  related={[{"slug":"cm-to-inches","label":"Cm to Inches Converter"},{"slug":"km-to-miles","label":"Km to Miles Converter"},{"slug":"meters-to-feet","label":"Meters to Feet Converter"}]}
/>
