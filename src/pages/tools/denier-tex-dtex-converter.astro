---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Denier / Tex / Dtex Converter';
const description = 'Convert yarn and thread thickness between denier, tex, and decitex (dtex) instantly. Enter a value in any unit for an accurate conversion in textile production.';
const intro = 'Convert yarn linear density between denier, tex, and decitex (dtex).';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What do denier, tex, and dtex actually measure?', a: 'All three measure linear density — how much a fixed length of yarn or thread weighs. Denier is grams per 9,000 meters, tex is grams per 1,000 meters, and decitex (dtex) is grams per 10,000 meters. A higher number in any system means a thicker, heavier yarn.' },
  { q: 'Which system is used where?', a: 'Denier is common in the US for hosiery, synthetic filament yarns, and fabric weight claims (like "40 denier tights"). Tex and decitex are the international (SI-based) standard used more broadly across global textile manufacturing and technical specifications.' },
  { q: 'Why is the conversion factor 9 between denier and tex?', a: 'It comes directly from the definitions: denier is weight per 9,000 meters and tex is weight per 1,000 meters, a 9-to-1 length ratio, so the same yarn\'s denier number is always 9 times its tex number.' },
  { q: 'Is a 70 denier fabric thicker than a 40 denier fabric?', a: 'Yes — in denier, tex, and dtex, all higher numbers mean a thicker, heavier yarn (this is the opposite of indirect systems like Ne cotton count, where a higher number means a finer yarn).' },
];
const howTo = {
  name: 'How to convert yarn thickness units',
  steps: [
    { name: 'Enter the known value', text: 'Type the yarn thickness value you already have.' },
    { name: 'Choose its unit', text: 'Select denier, tex, or dtex to match your starting value.' },
    { name: 'Read all three conversions', text: 'The equivalent values in the other two systems appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Value</span>
        <input id="value" type="number" step="any" placeholder="e.g. 70" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <div>
        <span class="text-sm font-medium text-slate-700">Unit</span>
        <select id="unit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
          <option value="denier">Denier</option>
          <option value="tex">Tex</option>
          <option value="dtex">Decitex (dtex)</option>
        </select>
      </div>
    </div>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">Denier</div><div id="r-denier" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Tex</div><div id="r-tex" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Dtex</div><div id="r-dtex" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dtc-title dtc-desc">
      <title id="dtc-title">Three yarn lengths of different fixed distances</title>
      <desc id="dtc-desc">Three horizontal lines of different reference lengths illustrating the different length bases of denier, tex, and dtex</desc>
      <line x1="80" y1="40" x2="720" y2="40" stroke="#c026d3" stroke-width="3" />
      <text x="80" y="30" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Denier: weight per 9,000 m</text>
      <line x1="80" y1="90" x2="400" y2="90" stroke="#94a3b8" stroke-width="3" />
      <text x="80" y="80" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Tex: weight per 1,000 m</text>
      <line x1="80" y1="140" x2="450" y2="140" stroke="#f0abfc" stroke-width="3" />
      <text x="80" y="130" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Dtex: weight per 10,000 m</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Each system weighs a different fixed reference length of yarn</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the denier/tex/dtex conversion works</h2>
    <p class="mt-2 text-slate-600">
      All three units follow the same underlying idea — weigh a fixed length of yarn and use that weight in grams as the thickness number — but each uses a different reference length. Denier weighs 9,000 meters, tex weighs 1,000 meters, and decitex (dtex) weighs 10,000 meters. Because these lengths are exact multiples of each other, converting between them is straightforward division and multiplication: tex equals denier divided by 9, and dtex equals denier multiplied by 10/9.
    </p>
    <p class="mt-3 text-slate-600">
      These are all "direct" numbering systems, meaning a bigger number always means a thicker, heavier yarn — this is the opposite of "indirect" systems like Ne cotton count, where a bigger number means a finer yarn, which is why converting between a direct and indirect system (see the Yarn Count Converter) requires a different kind of formula entirely.
    </p>
    <p class="mt-3 text-xs text-slate-400">Denier, tex, and decitex are internationally standardized yarn linear-density units (ISO 1144); the conversion factors used here are exact by definition, not approximations.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A pair of tights is labeled 70 denier, and the equivalent tex and dtex values are needed for a spec sheet.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Denier:</span> <span class="text-slate-600">70</span></div>
        <div><span class="font-medium text-slate-700">Tex:</span> <span class="text-slate-600">70 ÷ 9 ≈ <strong>7.78</strong></span></div>
        <div><span class="font-medium text-slate-700">Dtex:</span> <span class="text-slate-600">70 × (10/9) ≈ <strong>77.8</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Sourcing synthetic yarn or thread from an overseas mill is the most common place this conversion matters in practice, since a US-based buyer used to denier specifications may receive a supplier's technical sheet listing everything in tex or dtex, and comparing yarn options across suppliers requires converting them all to one common unit first.
    </p>
    <p class="mt-3 text-slate-600">
      Hosiery and legwear specifically use denier as a consumer-facing marketing number (sheer 8-denier tights versus opaque 100-denier tights), while the underlying technical yarn specifications a manufacturer works from are frequently recorded in tex or dtex, making this conversion a routine bridge between consumer labeling and production specs.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Denier measures the fabric's overall weight, like GSM." <strong class="text-slate-900">No.</strong> Denier measures the yarn's own thickness before it's woven or knit into fabric; a fabric's finished GSM depends on both yarn denier and how tightly it's constructed, so the two numbers aren't interchangeable.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Denier and Ne cotton count can be converted the same simple way." <strong class="text-slate-900">They can't.</strong> Denier is a direct system (bigger number = thicker yarn) while Ne is indirect (bigger number = finer yarn), so converting between them uses an inverse relationship, not simple multiplication.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/yarn-count-converter/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Yarn Count Converter (Ne ↔ Denier)</a>
      <a href="/tools/fabric-weight-gsm-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">GSM / Fabric Weight Calculator</a>
      <a href="/tools/thread-consumption-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Thread Consumption Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const v = parseFloat(el('value').value);
      const unit = el('unit').value;
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      let denier;
      if (unit === 'denier') denier = v;
      else if (unit === 'tex') denier = v * 9;
      else denier = v * 0.9; // dtex

      const tex = denier / 9;
      const dtex = denier * (10 / 9);

      el('r-denier').textContent = denier.toFixed(2);
      el('r-tex').textContent = tex.toFixed(2);
      el('r-dtex').textContent = dtex.toFixed(2);
      el('results').classList.remove('hidden');
    }

    el('value').addEventListener('input', update);
    el('unit').addEventListener('change', update);
  </script>
</ToolLayout>
