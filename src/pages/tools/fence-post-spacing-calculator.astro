---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fence Post Spacing Calculator';
const description = 'Work out how many fence posts you need and how deep to set them below your local frost line, from the fence run length and your target post spacing.';
const intro = 'Find the number of fence posts and the hole depth for a fence run, from the total length, target post spacing, and post height.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How far apart should fence posts be?', a: 'Most residential wood fences space posts 6 to 8 feet apart, and vinyl or panel fencing often follows a fixed panel width such as 6 or 8 feet. Taller or heavier fences, and fences on windy or sloped sites, do better with closer spacing.' },
  { q: 'How deep should a fence post hole be?', a: 'A common rule is to bury one-third of the post length, with a minimum of 24 inches for most residential fences, and always below the local frost line so freezing soil cannot heave the post. Confirm your local frost depth, since it varies widely by region.' },
  { q: 'Why does frost depth matter for fence posts?', a: 'Water in the soil expands as it freezes. If a post bottom sits above the frost line, the freezing and thawing soil around it can slowly heave the post out of the ground over several winters, even though it felt solid when set.' },
  { q: 'How much concrete do I need per post?', a: 'For a typical 8 to 10 inch diameter hole and a 4x4 post, one 50 lb bag of fast-setting concrete mix is a common estimate per post; larger holes or posts need more. Check the bag instructions for your hole size.' },
];
const howTo = {
  name: 'How to calculate fence post spacing and depth',
  steps: [
    { name: 'Enter the run', text: 'Total fence length and your target spacing, both in feet.' },
    { name: 'Set post and frost depth', text: 'Post length in feet and your local frost depth in inches.' },
    { name: 'Read post count and depth', text: 'Get posts, real spacing, hole depth, and finished fence height.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Fence run length (ft)</span>
        <input id="length" type="number" step="any" placeholder="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Target spacing (ft)</span>
        <input id="spacing" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Post length (ft)</span>
        <input id="postlen" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Local frost depth (in)</span>
        <input id="frost" type="number" step="any" placeholder="36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Posts needed</div>
        <div id="r-posts" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-spacing" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Bays (spans)</div><div id="r-bays" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Hole depth</div><div id="r-depth" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Height above ground</div><div id="r-above" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fp-title fp-desc">
      <title id="fp-title">Fence post depth versus frost line</title>
      <desc id="fp-desc">A fence post set in the ground below the frost line, with the spacing and depth formulas</desc>
      <line x1="60" y1="180" x2="500" y2="180" stroke="#94a3b8" stroke-width="2" />
      <rect x="60" y="180" width="440" height="90" fill="#e0f2fe" opacity="0.5" />
      <line x1="60" y1="220" x2="500" y2="220" stroke="#0284c7" stroke-width="1.5" stroke-dasharray="4 3" />
      <text x="510" y="224" font-size="11" fill="#0284c7" font-family="system-ui,sans-serif">frost line</text>
      <rect x="230" y="90" width="20" height="180" fill="#a5b4fc" stroke="#6366f1" stroke-width="2" />
      <text x="240" y="80" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">post</text>
      <rect x="560" y="90" width="220" height="150" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="580" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Post spacing</text>
      <text x="580" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">posts = length&frasl;spacing + 1</text>
      <text x="580" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">depth = max(1&frasl;3 post, frost, 24&Prime;)</text>
      <text x="580" y="188" font-size="12" fill="#475569" font-family="system-ui,sans-serif">bays = posts &minus; 1</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Posts must be set below the local frost line so freezing soil cannot heave them.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the fence post spacing calculator works</h2>
    <p class="mt-2 text-slate-600">
      Posts break a fence run into equal bays, so the number of posts is the run length divided by your target spacing, rounded up, plus one extra post to close both ends. Dividing that same length by the actual post count gives the real, evenly divided spacing, which is usually a little tighter than your target since posts rarely divide a run perfectly.
    </p>
    <p class="mt-3 text-slate-600">
      Hole depth follows three rules at once, and the calculator uses whichever is deepest. A common carpentry rule buries one-third of the total post length. Most residential codes also set a practical minimum around 24 inches. And critically, the hole should reach below the local frost line, the depth to which the ground freezes in winter, so freezing and thawing soil cannot slowly heave the post loose.
    </p>
    <p class="mt-3 text-slate-600">
      Frost depth follows IRC foundation frost-protection guidance and varies enormously by region, from near zero in warm climates to 48 inches or more in the coldest parts of the country — check your local building department for the figure that applies to you, since using a generic number can leave a post too shallow.
    </p>
    <p class="mt-3 text-xs text-slate-400">Minimum footing depth relative to the frost line follows IRC Table R403.1(1) and local building-department frost-depth maps; the one-third-of-post-length rule is a widely used residential carpentry guideline.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the run</h3>
        <p class="mt-1 text-sm text-slate-600">Total fence length and your target spacing, both in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set post and frost depth</h3>
        <p class="mt-1 text-sm text-slate-600">Post length in feet and your local frost depth in inches.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read post count and depth</h3>
        <p class="mt-1 text-sm text-slate-600">Get posts, real spacing, hole depth, and finished fence height.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Post count</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= ceil(length &divide; spacing) + 1</span>. A 100 ft run at 8 ft spacing: ceil(12.5) + 1 = 13 + 1 = <strong>14 posts</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Hole depth</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= max(post&frasl;3, frost, 24&Prime;)</span>. An 8 ft (96&Prime;) post, 36&Prime; frost line: max(32, 36, 24) = <strong>36 in</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Height above ground</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= post length &minus; depth</span>. 96&Prime; &minus; 36&Prime; = <strong>60 in (5 ft)</strong> of finished fence height.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 64 ft backyard fence, 6 ft target spacing, 7 ft posts, 30&Prime; frost line.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Posts:</span> <span class="text-slate-600">ceil(64&frasl;6) + 1 = 11 + 1 = 12</span></div>
        <div><span class="font-medium text-slate-700">Real spacing:</span> <span class="text-slate-600">64&frasl;11 = 5.8 ft</span></div>
        <div><span class="font-medium text-slate-700">Depth:</span> <span class="text-slate-600">max(28, 30, 24) = <strong>30 in</strong></span></div>
        <div><span class="font-medium text-slate-700">Above ground:</span> <span class="text-slate-600">84 &minus; 30 = 54 in</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Setting posts right</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🕳️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Widen the hole, not just the depth</h3>
        <p class="mt-1 text-sm text-slate-600">A hole about three times the post's width gives room for concrete to fully surround the post, which resists wind and frost heave far better than a snug hole.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">💧</span>
        <h3 class="mt-2 font-semibold text-slate-900">Add drainage at the bottom</h3>
        <p class="mt-1 text-sm text-slate-600">A few inches of gravel under the post keeps standing water off the end grain, reducing rot in wood posts and corrosion in metal ones.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📐</span>
        <h3 class="mt-2 font-semibold text-slate-900">Check corner and gate posts</h3>
        <p class="mt-1 text-sm text-slate-600">Corner, end, and gate posts carry more load than mid-run posts and often need a larger post, a deeper hole, or extra concrete beyond the standard spacing plan.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌬️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Tighten spacing for wind</h3>
        <p class="mt-1 text-sm text-slate-600">Solid privacy fencing catches wind like a sail. In windy areas, spacing posts closer than the panel maximum reduces the leverage that can loosen or snap a post over time.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A warm-climate backyard fence shows how shallow frost lines simplify the job. A 150 ft run at 6 ft spacing with 8 ft posts and only a 12-inch frost line needs ceil(150&frasl;6) = 25 bays, so <strong>26 posts</strong>, with real spacing landing at an even 6 ft. Hole depth is max(32, 12, 24) = <strong>32 inches</strong>, driven by the one-third-of-post-length rule rather than frost, since the frost line here is shallower than the practical 24-inch minimum would need anyway.
    </p>
    <p class="mt-3 text-slate-600">
      A cold-climate fence flips which rule controls. A 40 ft run at 8 ft spacing with 6 ft posts and a 48-inch frost line needs ceil(40&frasl;8) = 5 bays, so <strong>6 posts</strong> at an even 8 ft real spacing. Hole depth is max(24, 48, 24) = <strong>48 inches</strong> — the frost line now dominates, and the post only sticks up 72 − 48 = <strong>24 inches</strong> above grade, which is worth checking against the target fence height before ordering posts.
    </p>
    <p class="mt-3 text-slate-600">
      A tall privacy fence needs closer spacing to resist wind load. An 80 ft run at 6 ft spacing with 9 ft posts and a 30-inch frost line needs ceil(80&frasl;6) = 14 bays, so <strong>15 posts</strong>, with real spacing tightening to about 5.7 ft. Hole depth is max(36, 30, 24) = <strong>36 inches</strong>, leaving 108 − 36 = 72 inches (6 ft) of finished fence height — a good illustration of how much more concrete and post length a tall privacy fence consumes compared with a short picket fence.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"If I bury one-third of the post, I'm always safe." <strong class="text-slate-900">Not in cold climates.</strong> The one-third rule is only a starting point — if it puts the post bottom above the local frost line, freeze-thaw cycles can still heave the post over successive winters. The calculator always uses whichever of the one-third rule, the frost line, or the 24-inch practical minimum is deepest.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Dividing the fence length by the spacing gives the post count." <strong class="text-slate-900">It's off by one.</strong> Posts sit at both ends of a run as well as between spans, so the post count is the number of bays (spans) plus one — a 100 ft fence at 10 ft spacing needs 11 posts, not 10, or the last section comes up short.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fence-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fence Calculator</a>
      <a href="/tools/concrete-footing-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Footing Calculator</a>
      <a href="/tools/sonotube-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Sonotube Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('length').value);
      const sp = parseFloat(el('spacing').value);
      const postLenFt = parseFloat(el('postlen').value);
      const frost = parseFloat(el('frost').value);
      if (!L || !sp || !postLenFt || L <= 0 || sp <= 0 || postLenFt <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const bays = Math.ceil(L / sp);
      const posts = bays + 1;
      const realSpacing = L / bays;
      const postLenIn = postLenFt * 12;
      const oneThird = postLenIn / 3;
      const frostSafe = isNaN(frost) ? 0 : frost;
      const depth = Math.max(oneThird, frostSafe, 24);
      const above = postLenIn - depth;

      el('r-posts').textContent = posts.toLocaleString() + ' posts';
      el('r-spacing').textContent = 'actual spacing ' + realSpacing.toFixed(2) + ' ft';
      el('r-bays').textContent = bays.toLocaleString();
      el('r-depth').textContent = depth.toFixed(0) + ' in';
      el('r-above').textContent = above > 0 ? (above / 12).toFixed(2) + ' ft' : '⚠ post too short';
      el('results').classList.remove('hidden');
    }

    ['length', 'spacing', 'postlen', 'frost'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
