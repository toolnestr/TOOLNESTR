---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'LC Resonant Frequency Calculator';
const description = 'Free LC resonant frequency calculator. Calculate the resonant frequency of an LC tank circuit from inductance (L) and capacitance (C) values.';
const intro = 'Enter the inductance and capacitance of your LC circuit to find the resonant frequency, angular frequency and period.';
const category = { id: 'engineering', name: 'Electrical Engineering' };
const faqs = [
  { q: 'What is the resonant frequency of an LC circuit?', a: 'The resonant frequency is the frequency at which an LC circuit naturally oscillates with maximum amplitude. It is given by the formula f = 1 / (2\u03c0\u221a(LC)), where L is inductance in henries and C is capacitance in farads.' },
  { q: 'How do I calculate the resonant frequency?', a: 'To calculate resonant frequency, multiply L and C, take the square root, multiply by 2\u03c0, then take the reciprocal. For example, with L = 10 \u00b5H and C = 100 pF: f = 1 / (2\u03c0 \u00d7 \u221a(10\u00d710\u207b\u2076 \u00d7 100\u00d710\u207b\u00b9\u00b2)) \u2248 5.03 MHz.' },
  { q: 'What is angular frequency in an LC circuit?', a: 'Angular frequency \u03c9 = 2\u03c0f, measured in radians per second. It is the rate of change of the sinusoidal waveform in the tank circuit. The formula is \u03c9 = 1 / \u221a(LC). It is commonly used in filter design and signal analysis.' },
  { q: 'What are tank circuits used for?', a: 'LC tank circuits are fundamental in radio frequency design. They are used in radio tuners (selecting stations), oscillators (generating carrier waves), bandpass filters (passing specific frequencies), and impedance matching networks.' },
  { q: 'How do I choose L and C values for a specific frequency?', a: 'Use the formula LC = 1/(2\u03c0f)\u00b2. For a given frequency, there are infinite L/C combinations. Larger L with smaller C gives higher impedance; smaller L with larger C gives lower impedance. The choice depends on your circuit impedance requirements.' },
  { q: 'What is the Q factor of an LC circuit?', a: 'The Q factor (Quality factor) measures the sharpness of resonance. Q = \u03c9L/R for a series resonant circuit. Higher Q means narrower bandwidth and better frequency selectivity. Practical LC circuits have Q factors from 10 to several hundred.' },
  { q: 'Does the resonant frequency change with load?', a: 'Yes. Connecting a load to the LC circuit alters its effective impedance and can shift the resonant frequency slightly. External capacitance from traces and components also adds to the total capacitance, lowering the frequency.' },
  { q: 'What is the difference between series and parallel resonance?', a: 'In series resonance, impedance is minimum at the resonant frequency. In parallel resonance, impedance is maximum. Series LC circuits are used for bandpass filtering, while parallel LC circuits (tank circuits) are used in oscillators and RF amplifiers.' },
  { q: 'How does temperature affect LC resonance?', a: 'Inductors and capacitors have temperature coefficients. As temperature changes, component values drift, shifting the resonant frequency. NP0/C0G capacitors and air-core inductors offer the best temperature stability for precision circuits.' },
  { q: 'Can I use this calculator for audio crossover design?', a: 'Yes. LC resonant circuits are used in audio crossover networks to split frequencies between speakers. For example, a 1 mH inductor with a 10 \u00b5F capacitor resonates at about 1.59 kHz, suitable for a midrange crossover point.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Inductance (L)</span>
        <div class="mt-1 flex gap-2"><input id="lVal" type="number" step="any" placeholder="10" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <select id="lUnit" class="rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="uH">\u00b5H</option><option value="mH">mH</option><option value="H">H</option></select></div></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Capacitance (C)</span>
        <div class="mt-1 flex gap-2"><input id="cVal" type="number" step="any" placeholder="100" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <select id="cUnit" class="rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="pF">pF</option><option value="nF">nF</option><option value="uF">\u00b5F</option></select></div></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Resonant frequency</div><div id="r-freq" class="mt-1 text-2xl font-bold">\u2014</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Angular frequency</div><div id="r-omega" class="mt-1 text-2xl font-bold text-emerald-600">\u2014</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Period</div><div id="r-period" class="mt-1 text-2xl font-bold text-slate-800">\u2014</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How LC resonant frequency is calculated</h2>
    <p class="mt-2 text-slate-600">The resonant frequency of an LC circuit is determined by the Thomson formula: f = 1 / (2&pi;&radic;(LC)), where L is inductance in henries and C is capacitance in farads. The frequency is inversely proportional to the square root of both L and C &mdash; doubling either value reduces the frequency by a factor of &radic;2.</p>
    <p class="mt-3 text-slate-600">The angular frequency &omega; = 1 / &radic;(LC) (measured in radians per second) and the period T = 1 / f are also displayed. At resonance, inductive reactance X<sub>L</sub> = 2&pi;fL equals capacitive reactance X<sub>C</sub> = 1/(2&pi;fC).</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Inductance:</span> <span class="text-slate-600">10 mH (0.01 H)</span></div>
        <div><span class="font-medium text-slate-700">Capacitance:</span> <span class="text-slate-600">100 nF (1 &times; 10<sup>&minus;7</sup> F)</span></div>
        <div><span class="font-medium text-slate-700">LC product:</span> <span class="text-slate-600">0.01 &times; 1e-7 = 1 &times; 10<sup>&minus;9</sup></span></div>
        <div><span class="font-medium text-slate-700">&radic;(LC):</span> <span class="text-slate-600">&radic;(1e-9) = 3.162 &times; 10<sup>&minus;5</sup></span></div>
        <div><span class="font-medium text-slate-700">Frequency:</span> <span class="text-slate-600">f = 1 / (2&pi; &times; 3.162e-5) = 159.2 Hz</span></div>
        <div><span class="font-medium text-slate-700">Period:</span> <span class="text-slate-600">T = 1 / 159.2 = 6.28 ms</span></div>
      </div>
    </div>
  </section>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="lc-title lc-desc">
      <title id="lc-title">LC resonant tank circuit</title>
      <desc id="lc-desc">An inductor and capacitor connected in parallel forming an LC tank circuit, with a resonant sine wave shown above and the resonant frequency formula</desc>
      <g transform="translate(60,10)">
        <text x="340" y="25" text-anchor="middle" fill="#475569" font-size="13" font-weight="bold">LC Parallel Tank Circuit</text>
        <line x1="160" y1="50" x2="160" y2="160" stroke="#475569" stroke-width="2"/>
        <line x1="520" y1="50" x2="520" y2="160" stroke="#475569" stroke-width="2"/>
        <line x1="160" y1="70" x2="520" y2="70" stroke="#475569" stroke-width="2"/>
        <line x1="160" y1="140" x2="520" y2="140" stroke="#475569" stroke-width="2"/>
        <path d="M200 70 C230 40 260 100 290 70 C320 40 350 100 380 70 C410 40 440 100 470 70 L480 70" stroke="#f59e0b" stroke-width="3" fill="none"/>
        <text x="340" y="55" text-anchor="middle" fill="#f59e0b" font-size="12" font-weight="bold">L (Inductor)</text>
        <line x1="200" y1="140" line2="200" y2="130" stroke="#6366f1" stroke-width="2"/>
        <line x1="480" y1="140" x2="480" y2="130" stroke="#6366f1" stroke-width="2"/>
        <line x1="200" y1="130" x2="480" y2="130" stroke="#6366f1" stroke-width="3"/>
        <line x1="200" y1="130" x2="480" y2="130" stroke="#6366f1" stroke-width="1" transform="translate(0,10)"/>
        <line x1="200" y1="130" x2="200" y2="150" stroke="#6366f1" stroke-width="2"/>
        <line x1="480" y1="130" x2="480" y2="150" stroke="#6366f1" stroke-width="2"/>
        <rect x="260" y="125" width="160" height="20" rx="4" fill="none" stroke="#6366f1" stroke-width="2"/>
        <text x="340" y="139" text-anchor="middle" fill="#6366f1" font-size="12" font-weight="bold">C (Capacitor)</text>
        <path d="M340 40 C310 20 320 10 340 10 C360 10 370 20 340 40" stroke="#10b981" stroke-width="2" fill="none" transform="translate(0,-50) scale(1,-1)"/>
        <path d="M340 40 C310 20 320 10 340 10 C360 10 370 20 340 40" stroke="#10b981" stroke-width="2" fill="none" transform="translate(0,-60) scale(1,-1)"/>
        <text x="340" y="185" text-anchor="middle" fill="#6366f1" font-size="14" font-weight="bold">f = 1 / (2&pi;&#8730;(LC))</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">At resonance, inductive reactance equals capacitive reactance: X<sub>L</sub> = X<sub>C</sub></figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Frequency bands for LC circuits</h2>
    <p class="mt-2 text-slate-600">LC circuits are used across a wide range of frequencies. Different component values are needed for different frequency bands.</p>
    <div class="mt-5 space-y-3">
      <div><div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Audio</span><span class="text-slate-400">20 Hz \u2013 20 kHz</span></div><div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:5%"></div></div></div>
      <div><div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Radio (AM / SW)</span><span class="text-slate-400">100 kHz \u2013 100 MHz</span></div><div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:30%"></div></div></div>
      <div><div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">VHF</span><span class="text-slate-400">100 \u2013 300 MHz</span></div><div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:15%"></div></div></div>
      <div><div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">UHF</span><span class="text-slate-400">300 MHz \u2013 3 GHz</span></div><div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:20%"></div></div></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">📡</span><h3 class="mt-2 font-semibold text-slate-900">RF Engineer</h3><p class="mt-1 text-sm text-slate-600">Design antenna matching networks, filters and oscillators for wireless communication systems with precise frequency targets.</p></div>
    <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🔊</span><h3 class="mt-2 font-semibold text-slate-900">Audio Crossover Designer</h3><p class="mt-1 text-sm text-slate-600">Calculate LC values for speaker crossover networks to split audio signals between tweeters, midranges and woofers.</p></div>
    <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">📻</span><h3 class="mt-2 font-semibold text-slate-900">Ham Radio Operator</h3><p class="mt-1 text-sm text-slate-600">Build and tune resonant circuits for your amateur radio equipment, from crystal filters to tank circuits in transmitters.</p></div>
    <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🔬</span><h3 class="mt-2 font-semibold text-slate-900">Electronics Student</h3><p class="mt-1 text-sm text-slate-600">Explore the relationship between inductance, capacitance and resonant frequency in foundational circuit analysis.</p></div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Inductance</th><th class="p-3">Capacitance</th><th class="p-3">Resonant frequency</th><th class="p-3">Application</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">10 \u00b5H</td><td class="p-3">100 pF</td><td class="p-3">5.03 MHz</td><td class="p-3">Shortwave radio</td></tr>
        <tr><td class="p-3 font-medium">100 \u00b5H</td><td class="p-3">100 pF</td><td class="p-3">1.59 MHz</td><td class="p-3">AM radio</td></tr>
        <tr><td class="p-3 font-medium">1 mH</td><td class="p-3">1 nF</td><td class="p-3">159 kHz</td><td class="p-3">Longwave</td></tr>
        <tr><td class="p-3 font-medium">1 mH</td><td class="p-3">10 \u00b5F</td><td class="p-3">1.59 kHz</td><td class="p-3">Audio crossover</td></tr>
        <tr><td class="p-3 font-medium">10 \u00b5H</td><td class="p-3">10 pF</td><td class="p-3">15.9 MHz</td><td class="p-3">FM radio / VHF</td></tr>
        <tr><td class="p-3 font-medium">1 \u00b5H</td><td class="p-3">10 pF</td><td class="p-3">50.3 MHz</td><td class="p-3">VHF TV</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the LC Resonant Frequency Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center"><span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span><h3 class="mt-3 font-semibold text-slate-900">Enter inductance</h3><p class="mt-1 text-sm text-slate-600">Type the inductor value and select the correct unit (\u00b5H, mH or H). Most RF inductors are in the microhenry (\u00b5H) range.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center"><span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span><h3 class="mt-3 font-semibold text-slate-900">Enter capacitance</h3><p class="mt-1 text-sm text-slate-600">Type the capacitor value with the correct unit (pF, nF or \u00b5F). Small capacitors in the pF range are typical for RF applications.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center"><span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span><h3 class="mt-3 font-semibold text-slate-900">Read the results</h3><p class="mt-1 text-sm text-slate-600">The calculator instantly shows the resonant frequency, angular frequency and period \u2014 all three values update as you type.</p></div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with LC circuits</h2>
    <div class="mt-4 space-y-5">
      <div><h3 class="font-semibold text-slate-900">Account for parasitic capacitance</h3><p class="mt-1 text-sm text-slate-600">Every inductor has self-capacitance between its windings, which creates self-resonance. Above this frequency, the inductor behaves like a capacitor. Choose inductors with self-resonant frequency well above your operating frequency.</p></div>
      <div><h3 class="font-semibold text-slate-900">Use a trimmer capacitor for tuning</h3><p class="mt-1 text-sm text-slate-900">For adjustable resonant circuits, use a trimmer capacitor (typically 5-50 pF) in parallel with a fixed capacitor. This allows fine-tuning the resonant frequency to compensate for component tolerances and PCB parasitics.</p></div>
      <div><h3 class="font-semibold text-slate-900">Minimize stray inductance and capacitance</h3><p class="mt-1 text-sm text-slate-600">Keep leads short and use ground planes to minimize stray inductance and capacitance that shift the resonant frequency. Surface-mount components have significantly lower parasitics than through-hole parts at RF frequencies.</p></div>
      <div><h3 class="font-semibold text-slate-900">Consider the impedance at resonance</h3><p class="mt-1 text-sm text-slate-600">The impedance of a parallel LC tank circuit at resonance is Z = L/(RC), where R is the series resistance of the inductor. Higher Q means higher impedance. For matching networks, this impedance determines how well the circuit couples to the load.</p></div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The LC resonance formula: f = 1 / (2\u03c0\u221a(LC))</h2>
    <p class="mt-2 text-slate-600">The resonant frequency of an LC circuit is determined by the Thomson formula f = 1/(2\u03c0\u221a(LC)). This equation shows that frequency is inversely proportional to the square root of both L and C. Doubling inductance reduces frequency by a factor of \u221a2. The formula works for both series and parallel resonant circuits; what changes is the impedance behavior, not the resonant frequency itself.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Applications of LC resonant circuits</h2>
    <p class="mt-2 text-slate-600">LC resonant circuits are everywhere in electronics. In radio receivers, they select the desired station while rejecting others. In oscillators, they set the operating frequency for transmitters and clock generators. In filter design, they pass or block specific frequency bands. In power electronics, they enable resonant converters with high efficiency and low switching losses. In audio, they split signals between speaker drivers in crossover networks.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Understanding inductor and capacitor behavior</h2>
    <p class="mt-2 text-slate-600">At resonance, the inductive reactance (X\u2097 = 2\u03c0fL) equals the capacitive reactance (X\u1d04 = 1/(2\u03c0fC)). Below resonance, X\u1d04 dominates and the circuit behaves capacitively. Above resonance, X\u2097 dominates and the circuit behaves inductively. In a series LC circuit, impedance is minimum at resonance. In a parallel LC circuit, impedance is maximum at resonance.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Quality factor and bandwidth</h2>
    <p class="mt-2 text-slate-600">The Q factor determines the bandwidth of the resonant circuit: BW = f\u2080/Q. A high Q circuit has a narrow bandwidth and sharp selectivity, ideal for radio tuners. A lower Q circuit has wider bandwidth, useful for audio applications. Q is primarily limited by the inductor\u2019s series resistance. Air-core inductors have higher Q than ferrite-core types but are physically larger.</p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function fmtFreq(hz) {
      if (hz >= 1000000) return (hz / 1000000).toFixed(3) + ' MHz';
      if (hz >= 1000) return (hz / 1000).toFixed(3) + ' kHz';
      return hz.toFixed(2) + ' Hz';
    }
    function fmtOmega(rad) {
      if (rad >= 1000000) return (rad / 1000000).toFixed(3) + ' Mrad/s';
      if (rad >= 1000) return (rad / 1000).toFixed(3) + ' krad/s';
      return rad.toFixed(2) + ' rad/s';
    }
    function fmtPeriod(t) {
      if (t >= 1) return t.toFixed(4) + ' s';
      if (t >= 0.001) return (t * 1000).toFixed(4) + ' ms';
      if (t >= 0.000001) return (t * 1000000).toFixed(2) + ' \u00b5s';
      return (t * 1000000000).toFixed(2) + ' ns';
    }
    function update() {
      const lVal = parseFloat(el('lVal').value);
      const lUnit = el('lUnit').value;
      const cVal = parseFloat(el('cVal').value);
      const cUnit = el('cUnit').value;
      if (isNaN(lVal) || isNaN(cVal) || lVal <= 0 || cVal <= 0) {
        el('r-freq').textContent = '\u2014';
        el('r-omega').textContent = '\u2014';
        el('r-period').textContent = '\u2014';
        return;
      }
      let lH = lUnit === 'uH' ? lVal / 1000000 : lUnit === 'mH' ? lVal / 1000 : lVal;
      let cF = cUnit === 'pF' ? cVal / 1000000000000 : cUnit === 'nF' ? cVal / 1000000000 : cVal / 1000000;
      let freq = 1 / (2 * Math.PI * Math.sqrt(lH * cF));
      let omega = 1 / Math.sqrt(lH * cF);
      let period = 1 / freq;
      el('r-freq').textContent = fmtFreq(freq);
      el('r-omega').textContent = fmtOmega(omega);
      el('r-period').textContent = fmtPeriod(period);
    }
    ['lVal','lUnit','cVal','cUnit'].forEach(id => el(id).addEventListener('input', update));
    ['lUnit','cUnit'].forEach(id => el(id).addEventListener('change', update));
  </script>
</ToolLayout>
