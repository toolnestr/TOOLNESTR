---
import ToolLayout from '../../layouts/ToolLayout.astro';

const platforms = [
  { id: 'instagram', name: 'Instagram' },
  { id: 'facebook', name: 'Facebook' },
  { id: 'twitter', name: 'Twitter / X' },
  { id: 'linkedin', name: 'LinkedIn' },
  { id: 'youtube', name: 'YouTube' },
  { id: 'tiktok', name: 'TikTok' },
  { id: 'pinterest', name: 'Pinterest' },
];

const sizes = {
  instagram: [
    { type: 'Profile Picture', dim: '320×320', aspect: '1:1', note: 'Circular crop, keep content centered' },
    { type: 'Feed Post (Square)', dim: '1080×1080', aspect: '1:1', note: 'Most common format' },
    { type: 'Feed Post (Portrait)', dim: '1080×1350', aspect: '4:5', note: 'Taller images perform better' },
    { type: 'Feed Post (Landscape)', dim: '1080×566', aspect: '1.91:1', note: 'Less common, use for wide scenes' },
    { type: 'Story / Reels', dim: '1080×1920', aspect: '9:16', note: 'Full screen vertical format' },
    { type: 'IGTV Cover', dim: '420×654', aspect: '1:1.55', note: 'Shows in IGTV grid' },
    { type: 'Carousel', dim: '1080×1080', aspect: '1:1', note: 'Multiple images, same format' },
  ],
  facebook: [
    { type: 'Profile Picture', dim: '180×180', aspect: '1:1', note: 'Displays at 170×170 on desktop' },
    { type: 'Cover Photo', dim: '820×312', aspect: '2.63:1', note: 'Safe zones for profile pic overlay' },
    { type: 'Shared Image', dim: '1200×630', aspect: '1.91:1', note: 'Open Graph share size' },
    { type: 'Story', dim: '1080×1920', aspect: '9:16', note: 'Disappears after 24 hours' },
    { type: 'Event Cover', dim: '1920×1080', aspect: '16:9', note: 'Shows on event page' },
    { type: 'Group Cover', dim: '1640×856', aspect: '1.91:1', note: 'Desktop and mobile crop' },
  ],
  twitter: [
    { type: 'Profile Picture', dim: '400×400', aspect: '1:1', note: 'Circular crop, minimum 200×200' },
    { type: 'Header Photo', dim: '1500×500', aspect: '3:1', note: 'Subject in center safe zone' },
    { type: 'In-Stream Image', dim: '1600×900', aspect: '16:9', note: 'Expands in timeline' },
    { type: 'Card Image (Summary)', dim: '1200×628', aspect: '1.91:1', note: 'Twitter Card preview' },
    { type: 'Card Image (Large)', dim: '800×800', aspect: '1:1', note: 'Summary card with large image' },
  ],
  linkedin: [
    { type: 'Profile Picture', dim: '400×400', aspect: '1:1', note: 'Up to 8MB' },
    { type: 'Cover / Banner', dim: '1584×396', aspect: '4:1', note: 'Full width background' },
    { type: 'Shared Image', dim: '1200×627', aspect: '1.91:1', note: 'Link share thumbnail' },
    { type: 'Company Logo', dim: '300×300', aspect: '1:1', note: 'Company page logo' },
    { type: 'Company Cover', dim: '1128×191', aspect: '6:1', note: 'Very wide format' },
    { type: 'Life Tab Hero', dim: '1128×376', aspect: '3:1', note: 'Company culture photos' },
  ],
  youtube: [
    { type: 'Channel Icon', dim: '800×800', aspect: '1:1', note: 'Circular crop on most views' },
    { type: 'Channel Banner', dim: '2048×1152', aspect: '16:9', note: 'Safe area: 1235×338 center' },
    { type: 'Video Thumbnail', dim: '1280×720', aspect: '16:9', note: 'MaxRes, under 2MB' },
    { type: 'Video Upload (16:9)', dim: '1920×1080', aspect: '16:9', note: '1080p HD standard' },
    { type: 'Story', dim: '1080×1920', aspect: '9:16', note: 'YouTube Shorts format' },
  ],
  tiktok: [
    { type: 'Profile Picture', dim: '200×200', aspect: '1:1', note: 'Circular crop display' },
    { type: 'Video', dim: '1080×1920', aspect: '9:16', note: 'Full screen vertical' },
    { type: 'Thumbnail', dim: '1080×1920', aspect: '9:16', note: 'Custom or auto-generated' },
    { type: 'Story', dim: '1080×1920', aspect: '9:16', note: 'Same format as videos' },
  ],
  pinterest: [
    { type: 'Profile Picture', dim: '165×165', aspect: '1:1', note: 'Circular crop' },
    { type: 'Pin (Standard)', dim: '1000×1500', aspect: '2:3', note: 'Optimal vertical format' },
    { type: 'Pin (Square)', dim: '1000×1000', aspect: '1:1', note: 'Alternative format' },
    { type: 'Pin (Infographic)', dim: '1000×2100', aspect: '1:2.1', note: 'Tall pins perform well' },
    { type: 'Board Cover', dim: '600×600', aspect: '1:1', note: 'First 4 pins auto-arranged' },
    { type: 'Story Pin', dim: '1080×1920', aspect: '9:16', note: 'Tappable multi-page format' },
  ],
};

const title = 'Social Media Image Size Cheat Sheet';
const description = 'The definitive cheat sheet for image dimensions across all social platforms — updated for 2025 — covering profile, cover, and post image sizes.';
const intro = 'The definitive cheat sheet for image dimensions across all social platforms.';
const category = { id: 'creators', name: 'Creators' };

const faqs = [
  { q: 'What is the best image size for Instagram posts?', a: 'Instagram feed posts look best at 1080×1350 px (4:5 portrait), which takes up the most vertical space in the feed. Square posts are 1080×1080 px and Stories/Reels are 1080×1920 px (9:16).' },
  { q: 'What size should a Facebook shared-link image be?', a: 'Use 1200×630 px (1.91:1). This is the Open Graph share size Facebook reads from the og:image tag, and it prevents cropping in the news feed.' },
  { q: 'Should I upload social images at 2× resolution?', a: 'Yes. Platforms downsample aggressively, so uploading at 2× the listed dimensions keeps images crisp on Retina and high-DPI phones, where most views happen.' },
  { q: 'What aspect ratio works across the most platforms?', a: 'A 1:1 square and a 9:16 vertical cover the widest range: square works for feed posts and profile pictures, while 9:16 fits Stories, Reels, TikTok and YouTube Shorts.' },
  { q: 'Why does my image look cropped or blurry after uploading?', a: 'It usually means the aspect ratio did not match the platform slot (so it was auto-cropped) or the file was below the recommended pixel size (so it was upscaled). Match the dimensions in the table above and export at the exact ratio.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mx-auto max-w-4xl">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-wrap gap-2" id="platform-tabs">
        {platforms.map((p) => (
          <button data-platform={p.id} class="platform-tab rounded-lg px-3 py-1.5 text-sm font-medium transition hover:bg-indigo-100 hover:text-indigo-700" style="cursor:pointer">&#64;{p.name}</button>
        ))}
      </div>
      {platforms.map((p) => (
        <div id={"table-" + p.id} class="platform-table mt-4 hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-slate-200">
                  <th class="pb-2 font-semibold text-slate-700">Image Type</th>
                  <th class="pb-2 font-semibold text-slate-700">Dimensions (px)</th>
                  <th class="pb-2 font-semibold text-slate-700">Aspect Ratio</th>
                  <th class="pb-2 font-semibold text-slate-700">Notes</th>
                </tr>
              </thead>
              <tbody>
                {sizes[p.id].map((s) => (
                  <tr class="border-b border-slate-100">
                    <td class="py-2.5 font-medium text-slate-800">{s.type}</td>
                    <td class="py-2.5 font-mono text-xs text-slate-600">{s.dim}</td>
                    <td class="py-2.5 font-mono text-xs text-slate-600">{s.aspect}</td>
                    <td class="py-2.5 text-xs text-slate-500">{s.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))}
    </div>

    <figure class="mt-10">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 180" width="800" height="180" role="img" aria-labelledby="sizes-svg-title sizes-svg-desc" class="w-full max-w-2xl mx-auto">
        <title id="sizes-svg-title">Social media image formats overlay diagram</title>
        <desc id="sizes-svg-desc">A mobile phone screen showing overlapping rectangles representing different social media image formats and their aspect ratios</desc>
        <rect x="300" y="10" width="200" height="160" rx="20" fill="#1e293b" />
        <rect x="320" y="30" width="160" height="120" rx="8" fill="#e2e8f0" />
        <rect x="328" y="42" width="144" height="96" rx="4" fill="#818cf8" opacity="0.2" />
        <rect x="350" y="55" width="60" height="60" rx="2" fill="#818cf8" opacity="0.4" />
        <text x="400" y="95" text-anchor="middle" fill="#fff" font-family="sans-serif" font-size="8">1:1</text>
        <rect x="328" y="80" width="144" height="24" rx="2" fill="#f59e0b" opacity="0.3" />
        <text x="400" y="95" text-anchor="middle" fill="#1e293b" font-family="sans-serif" font-size="7">1.91:1</text>
        <rect x="370" y="42" width="48" height="96" rx="2" fill="#10b981" opacity="0.3" />
        <text x="394" y="95" text-anchor="middle" fill="#fff" font-family="sans-serif" font-size="7" transform="rotate(-90 394 95)">9:16</text>
        <text x="100" y="100" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="13">Each platform</text>
        <text x="100" y="120" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="13">uses different</text>
        <text x="100" y="140" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="13">image formats</text>
        <text x="650" y="70" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="11">Square (1:1)</text>
        <rect x="590" y="82" width="120" height="12" rx="2" fill="#818cf8" opacity="0.5" />
        <text x="650" y="100" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="11">Landscape (16:9)</text>
        <rect x="590" y="112" width="120" height="12" rx="2" fill="#f59e0b" opacity="0.5" />
        <text x="650" y="130" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="11">Portrait (9:16)</text>
        <rect x="590" y="142" width="40" height="12" rx="2" fill="#10b981" opacity="0.5" />
        <line x1="520" y1="35" x2="580" y2="88" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="4,3" />
        <line x1="490" y1="90" x2="580" y2="118" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="4,3" />
        <line x1="490" y1="55" x2="590" y2="148" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="4,3" />
      </svg>
      <figcaption class="mt-2 text-center text-sm text-slate-500">Understanding the three main aspect ratios used across social platforms</figcaption>
    </figure>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">Why image sizing matters</h2>
      <p class="mt-2 text-slate-600">Using the correct image dimensions for each social platform ensures your content displays sharply without being cropped, stretched, or compressed. Each platform has specific requirements based on its layout, and these dimensions change periodically as platforms update their interfaces. An image that looks perfect on Instagram may be awkwardly cropped on Facebook or LinkedIn.</p>
      <p class="mt-3 text-slate-600">The most common cause of blurry social media images is uploading files that are too small. Platforms tend to downsample images aggressively, so starting with the recommended dimensions gives you the best result. For Retina and high-DPI displays, consider uploading images at 2x the listed resolution — the file will be larger, but your images will look crisp on modern smartphones and high-resolution monitors.</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">Pro tips</h2>
      <ul class="mt-3 list-inside list-disc space-y-2 text-sm text-slate-600">
        <li>Always use 2x resolution for Retina displays — upload at the full recommended size.</li>
        <li>Keep important content (text, logos, faces) in the center safe zone, especially for profile pictures and cover photos.</li>
        <li>Test your images on mobile — over 60% of social media views happen on phones.</li>
        <li>JPEG is best for photos, PNG for graphics with text, and GIF for simple animations.</li>
        <li>Platforms update their image specs periodically — check official documentation for the latest requirements.</li>
      </ul>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="text-lg font-bold text-slate-900">Related tools</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        <a href="/tools/youtube-thumbnail-downloader" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">YouTube Thumbnail Downloader</a>
        <a href="/tools/color-palette-generator" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Color Palette Generator</a>
        <a href="/tools/gradient-generator" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">CSS Gradient Generator</a>
      </div>
    </section>
  </div>
</ToolLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var tabs = document.querySelectorAll('.platform-tab');
    var tables = document.querySelectorAll('.platform-table');

    function showPlatform(id) {
      tables.forEach(function(t) { t.classList.add('hidden'); });
      var target = document.getElementById('table-' + id);
      if (target) target.classList.remove('hidden');
      tabs.forEach(function(tab) {
        tab.classList.remove('bg-indigo-600', 'text-white');
        tab.classList.add('bg-slate-100', 'text-slate-700');
        if (tab.dataset.platform === id) {
          tab.classList.remove('bg-slate-100', 'text-slate-700');
          tab.classList.add('bg-indigo-600', 'text-white');
        }
      });
    }

    if (tabs.length > 0) {
      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() { showPlatform(tab.dataset.platform); });
      });
      showPlatform('instagram');
    }
  });
</script>