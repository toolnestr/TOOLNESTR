---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Cm to Inches"
  emoji="📏"
  fromUnit="centimeters" toUnit="inches"
  fromTitle="Centimeters" toTitle="Inches"
  fromSym="cm" toSym="in"
  quantity="length"
  kind="factor" factor={0.3937007874}
  reverseSlug="inches-to-cm" reverseLabel="Inches to Cm Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Perfect for screen sizes, clothing measurements and DIY when a metric length needs to be read in inches."
/>
