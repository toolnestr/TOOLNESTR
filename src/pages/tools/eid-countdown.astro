---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Eid Countdown';
const description = 'Live countdown to Eid al-Fitr and Eid al-Adha — see how many days, hours and minutes remain until the next Eid celebration.';
const intro = 'Choose an Eid for a live countdown to the next celebration.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'When is Eid this year?', a: 'The countdown shows the estimated date based on the Umm al-Qura calendar. The actual day depends on the sighting of the new moon, so it may shift by a day. Follow your local mosque’s announcement for confirmation.' },
  { q: 'Why is the date only an estimate?', a: 'Eid al-Fitr begins on the first of Shawwal and Eid al-Adha on the tenth of Dhul-Hijjah, both determined by moon-sighting. Calculated calendars give a close prediction that can differ from the local sighting by a day.' },
  { q: 'What is the difference between the two Eids?', a: 'Eid al-Fitr marks the end of Ramadan and the completion of fasting. Eid al-Adha falls during the Hajj season and commemorates the sacrifice of Prophet Ibrahim, marked by the sacrifice (Qurbani) of livestock.' },
  { q: 'What is the Takbir of Eid?', a: 'It is the proclamation “Allahu Akbar, Allahu Akbar, la ilaha illa Allah…”, recited from the eve and morning of Eid, and after prayers during the days of Eid al-Adha.' },
];
const sources = [
  { html: "<strong>The Qur’an</strong> — e.g. Surah an-Nisa (4:11–12, 4:176) for the fixed inheritance shares (fara’id)." },
  { html: "<strong>Sahih al-Bukhari &amp; Sahih Muslim</strong> — hadith on inheritance, zakat and nisab thresholds." },
  { html: "<strong>AAOIFI and recognized fiqh councils</strong> (e.g. Islamic Fiqh Academy) for contemporary rulings. <a href=\"https://aaoifi.com/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">aaoifi.com</a>" },
];
const sourcesNote = "Rulings differ between scholars and schools (madhahib), and calculated astronomical times/dates may differ from local sighting. Confirm with a qualified scholar before acting.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      <button data-eid="fitr" class="eid-btn flex-1 rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Eid al-Fitr</button>
      <button data-eid="adha" class="eid-btn flex-1 rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Eid al-Adha</button>
    </div>
    <div class="mt-4 rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-700 p-6 text-center text-white">
      <div class="text-3xl">🎉</div>
      <div id="cd-label" class="mt-1 text-sm opacity-80">Time until Eid</div>
      <div class="mt-3 grid grid-cols-4 gap-2">
        {['Days', 'Hours', 'Min', 'Sec'].map((l, i) => (
          <div class="rounded-xl bg-white/10 p-3"><div id={'cd-' + i} class="text-2xl font-bold tabular-nums sm:text-3xl">—</div><div class="mt-1 text-xs opacity-80">{l}</div></div>
        ))}
      </div>
      <div id="cd-date" class="mt-4 text-sm opacity-90">—</div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="160" viewBox="0 0 800 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ec-title ec-desc">
      <title id="ec-title">Eid celebration banner</title>
      <desc id="ec-desc">Lanterns and a crescent representing the Eid celebration countdown.</desc>
      <path d="M120 80 a40 40 0 1 0 27 38 a30 30 0 1 1 -27 -38 Z" fill="#fbbf24" />
      {[260, 340, 420].map((x) => (<g><line x1={x} y1="35" x2={x} y2="55" stroke="#94a3b8" stroke-width="2" /><rect x={x - 16} y="55" width="32" height="46" rx="8" fill="#a5b4fc" /><rect x={x - 10} y="63" width="20" height="30" rx="4" fill="#eef2ff" /></g>))}
      <rect x="500" y="60" width="240" height="46" rx="10" fill="#eef2ff" stroke="#a5b4fc" /><text x="620" y="89" text-anchor="middle" font-size="15" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">Eid Mubarak</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Counting down to the next day of celebration.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About the Eid countdown</h2>
    <p class="mt-2 text-slate-600">The Muslim year has two festivals of Eid. Eid al-Fitr falls on the first day of Shawwal, immediately after Ramadan, celebrating the completion of a month of fasting. Eid al-Adha falls on the tenth of Dhul-Hijjah, during the days of Hajj, commemorating the willingness of Prophet Ibrahim to sacrifice his son in obedience to Allah. This tool gives a live countdown to whichever Eid you select, refreshing every second.</p>
    <p class="mt-3 text-slate-600">It calculates the next occurrence of your chosen Eid using the Umm al-Qura calendar in your browser, automatically rolling forward to next year if this year’s date has already passed. The countdown runs locally with nothing stored or sent. Switch between the two Eids using the buttons to compare how far away each celebration is.</p>
    <p class="mt-3 text-slate-600">Because both Eids depend on the sighting of the new moon, the displayed date is a calculated estimate that can differ from the official local announcement by a day. Use the countdown to plan travel, gifts, meals and gatherings, and always confirm the final date with your local community.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The two Eids compared</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5"><h3 class="font-semibold text-slate-900">Eid al-Fitr</h3><p class="mt-1 text-sm text-slate-600">The “festival of breaking the fast” on 1 Shawwal. It opens with the Eid prayer and is preceded by Zakat al-Fitr, a small charity given so the needy can also celebrate.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><h3 class="font-semibold text-slate-900">Eid al-Adha</h3><p class="mt-1 text-sm text-slate-600">The “festival of sacrifice” on 10 Dhul-Hijjah, during Hajj. Those able offer Qurbani, sharing the meat with family, neighbours and the poor.</p></div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/ramadan-countdown/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Ramadan Countdown</a>
      <a href="/tools/hijri-date-today/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Today’s Hijri Date</a>
      <a href="/tools/zakat-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const hfmt = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', { day: 'numeric', month: 'numeric', year: 'numeric', timeZone: 'UTC' });
    function hijriOf(d) { const o = {}; hfmt.formatToParts(d).forEach((p) => { if (p.type !== 'literal') o[p.type] = parseInt(p.value, 10); }); return o; }
    function toGregorian(hy, hm, hd) {
      let date = new Date(Date.UTC(Math.floor(hy * 0.970224 + 621), 0, 1));
      for (let i = 0; i < 8; i++) { const h = hijriOf(date); const diff = (hy - h.year) * 354 + (hm - h.month) * 29.53 + (hd - h.day); if (Math.abs(diff) < 1) break; date = new Date(date.getTime() + Math.round(diff) * 86400000); }
      let g = 0; while (g++ < 90) { const h = hijriOf(date); if (h.year === hy && h.month === hm && h.day === hd) return date; const cmp = (h.year - hy) || (h.month - hm) || (h.day - hd); date = new Date(date.getTime() + (cmp > 0 ? -1 : 1) * 86400000); }
      return date;
    }
    let target = null, timer = null, supported = true;
    function setEid(kind) {
      try {
        const hm = kind === 'adha' ? 12 : 10, hd = kind === 'adha' ? 10 : 1;
        const hy = hijriOf(new Date()).year;
        target = toGregorian(hy, hm, hd);
        if (target.getTime() <= Date.now()) target = toGregorian(hy + 1, hm, hd);
        el('cd-label').textContent = 'Time until ' + (kind === 'adha' ? 'Eid al-Adha' : 'Eid al-Fitr');
        el('cd-date').textContent = 'Estimated: ' + target.toLocaleDateString('en-US', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
      } catch (e) { supported = false; el('cd-date').textContent = 'Calendar not supported in this browser'; }
    }
    function tick() {
      if (!target) return;
      let diff = Math.max(0, target.getTime() - Date.now());
      const d = Math.floor(diff / 86400000); diff -= d * 86400000;
      const h = Math.floor(diff / 3600000); diff -= h * 3600000;
      const m = Math.floor(diff / 60000); diff -= m * 60000;
      const s = Math.floor(diff / 1000);
      el('cd-0').textContent = d; el('cd-1').textContent = h; el('cd-2').textContent = m; el('cd-3').textContent = s;
    }
    document.querySelectorAll('.eid-btn').forEach((btn) => btn.addEventListener('click', () => {
      document.querySelectorAll('.eid-btn').forEach((b) => b.className = 'eid-btn flex-1 rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50');
      btn.className = 'eid-btn flex-1 rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-2 text-sm font-medium text-indigo-700 transition';
      setEid(btn.dataset.eid); tick();
    }));
    document.querySelector('.eid-btn').click();
    if (supported) timer = setInterval(tick, 1000);
  </script>
</ToolLayout>
