---
import ToolLayout from '../../layouts/ToolLayout.astro';
import SubjectToolLibs from '../../components/SubjectToolLibs.astro';

const title = 'Dilution Calculator';
const description = "Dilution calculator with a live 3D beaker and charts. Solve C₁V₁ = C₂V₂ for any variable, get plain-English \"how much water to add\" steps.";
const intro = 'Enter any three of C₁, V₁, C₂, V₂ to solve the fourth — and get exactly how much solvent to add. A live 3D beaker and charts show concentration dropping as volume grows.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };
const faqs = [
  { q: 'What is the dilution equation?', a: 'C₁V₁ = C₂V₂. C₁ and V₁ are the initial concentration and volume, C₂ and V₂ the final ones. It holds because adding solvent changes the volume and concentration but not the number of moles of solute.' },
  { q: 'What units should I use?', a: 'Any consistent pair works — molarity with litres, mg/mL with mL, % with mL. The only rule is that both concentrations share one unit and both volumes share another; you never mix them within a side.' },
  { q: 'What is a serial dilution?', a: 'A stepwise dilution where each step reduces concentration by the same factor. Three 1:10 steps give 10 × 10 × 10 = 1000× total dilution — the standard way to reach very low, accurate concentrations for calibration and microbiology.' },
  { q: 'How do I prepare a dilution from a stock solution?', a: 'Rearrange to V₁ = C₂V₂ / C₁ to find the stock volume, then top up with solvent to V₂. For 100 mL of 0.1 M from a 1 M stock: V₁ = (0.1 × 100)/1 = 10 mL of stock, plus 90 mL of water.' },
  { q: 'Does diluting change the amount of solute?', a: 'No. Dilution adds solvent only; the moles of solute stay constant. That conservation of solute is exactly why C₁V₁ (moles before) equals C₂V₂ (moles after).' },
  { q: 'Which do I add to which — acid to water or water to acid?', a: 'Always add acid to water, slowly and while stirring. Diluting concentrated acid releases a lot of heat; adding water to acid can make it boil and spit dangerously.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to use the Dilution Calculator',
    description: 'Solve the dilution equation C₁V₁ = C₂V₂ for any missing variable and find how much solvent to add.',
    step: [
      { '@type': 'HowToStep', name: 'Enter three values', text: 'Fill any three of C₁, V₁, C₂, V₂ using consistent units.' },
      { '@type': 'HowToStep', name: 'Read the fourth', text: 'The missing quantity solves instantly from C₁V₁ = C₂V₂.' },
      { '@type': 'HowToStep', name: 'Follow the steps', text: 'When it is a dilution, the tool tells you how much stock to take and how much solvent to add.' },
    ],
  })} />

  <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">
    <span class="h-2 w-2 rounded-full bg-green-500"></span> Chemistry
  </span>

  <style is:global>
    @media print {
      .no-print { display: none !important; }
      a[href]::after { content: none !important; }
      section { break-inside: avoid; }
    }
  </style>

  <!-- ============ CALCULATOR ============ -->
  <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any three values to solve for the fourth.</p>
    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">C₁ (initial conc.)</span>
        <input id="c1" type="number" step="any" placeholder="M" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">V₁ (initial volume)</span>
        <input id="v1" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">C₂ (final conc.)</span>
        <input id="c2" type="number" step="any" placeholder="M" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">V₂ (final volume)</span>
        <input id="v2" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">C₁</div><div id="r-c1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">V₁</div><div id="r-v1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">C₂</div><div id="r-c2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">V₂</div><div id="r-v2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="dil-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
    <div id="dil-instructions" class="mt-4 hidden rounded-xl bg-green-50 p-4 text-sm text-green-700"></div>
  </div>

  <!-- ============ INTERACTIVE 3D BEAKER ============ -->
  <section class="mt-8 no-print">
    <h2 class="text-lg font-bold text-slate-900">Live 3D dilution</h2>
    <p class="mt-1 text-sm text-slate-500">Fix the solute (a stock C₁V₁), then grow the final volume — watch the liquid rise while the particles spread thinner and the concentration drops. Drag to orbit.</p>
    <div class="mt-3 grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Moles of solute (C₁·V₁) <span id="out-bmol" class="font-mono text-green-600">1.00</span></span>
        <input id="b-mol" type="range" min="0.1" max="5" step="0.05" value="1" class="mt-2 w-full accent-green-600" />
      </label>
      <label class="block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Final volume V₂ <span id="out-bvol" class="font-mono text-green-600">1.00 L</span></span>
        <input id="b-vol" type="range" min="0.1" max="5" step="0.05" value="1" class="mt-2 w-full accent-green-600" />
      </label>
    </div>
    <div class="mt-2 rounded-xl bg-green-50 p-3 text-center text-sm text-green-700">Final concentration C₂ = <span id="out-bc" class="font-mono font-bold">1.00 M</span> &nbsp;(dilution factor <span id="out-bdf" class="font-mono font-bold">1.0×</span>)</div>
    <div id="beaker3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
    <p id="beaker3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
  </section>

  <!-- ============ LIVE CHARTS ============ -->
  <section class="mt-10 no-print">
    <h2 class="text-lg font-bold text-slate-900">Dilution graphs</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Concentration vs final volume (fixed solute) — an inverse curve</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-cv"></canvas></div>
      </figure>
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Serial 1:10 dilution — concentration drops ×10 each step (log scale)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-serial"></canvas></div>
      </figure>
      <figure class="sm:col-span-2">
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Stock volume needed for 1 L of target concentration (from a 12 M stock)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:260px;"><canvas id="chart-stock"></canvas></div>
      </figure>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How dilution is calculated</h2>
    <p class="mt-2 text-slate-600"><strong>The core idea in one line:</strong> pouring in solvent spreads the same amount of solute through a bigger volume, so the concentration falls in exact proportion to how much the volume grows.</p>
    <p class="mt-3 text-slate-600">Because the moles of solute are conserved, "moles before = moles after" becomes the dilution equation, which rearranges four ways:</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">C₁ = C₂V₂/V₁</p></div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">V₁ = C₂V₂/C₁</p></div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">C₂ = C₁V₁/V₂</p></div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center"><p class="font-mono text-slate-800">V₂ = C₁V₁/C₂</p></div>
    </div>
    <p class="mt-4 text-slate-600">The <strong>dilution factor</strong> ties it together: C₁/C₂ = V₂/V₁. A 10× dilution factor means the final volume is ten times the stock volume, and the concentration is one tenth. The formula is unit-agnostic — molarity, %, mg/mL, ppm all work, as long as each side is internally consistent.</p>

    <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 1 — diluting acid</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> you have 50 mL of 6 M HCl. How much water makes it 1 M?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Final volume:</span> <span class="text-slate-600">V₂ = (6 × 50) / 1 = 300 mL</span></div>
        <div><span class="font-medium text-slate-700">Water to add:</span> <span class="text-slate-600">300 − 50 = 250 mL</span></div>
        <div class="sm:col-span-2 text-slate-600">Add the 50 mL of acid <em>to</em> the water (never the reverse), then top up to 300 mL.</div>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 2 — a serial dilution</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> starting from 1 M, you do three successive 1:10 dilutions (take 1 part, add 9 parts solvent, three times). What is the final concentration?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Each step:</span> <span class="text-slate-600">C₂ = C₁ / 10</span></div>
        <div><span class="font-medium text-slate-700">After 3 steps:</span> <span class="text-slate-600">1 / 10³ = 0.001 M (1 mM)</span></div>
        <div class="sm:col-span-2 text-slate-600">Serial dilution reaches tiny, accurate concentrations that a single dilution can't measure out precisely.</div>
      </div>
    </div>
  </section>

  <!-- ============ STANDALONE 3D DIAGRAMS ============ -->
  <section class="mt-12 no-print">
    <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <div>
        <div id="diag-two" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">1. Same particles, more water</h3>
        <p class="mt-1 text-sm text-slate-600">Both beakers hold the <strong>same</strong> number of solute particles. The right one just has more solvent, so they're spread thinner — lower concentration, identical moles.</p>
      </div>
      <div>
        <div id="diag-serial" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">2. Serial dilution multiplies</h3>
        <p class="mt-1 text-sm text-slate-600">Each beaker takes a little of the one before and tops up with solvent. Three 1:10 steps stack to 1000× — the particle density visibly collapses along the row.</p>
      </div>
    </div>
  </section>

  <!-- ============ COMPARISON TABLE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Making 1 L of solution from a 12 M stock</h2>
    <p class="mt-1 text-sm text-slate-600">The more dilute the target, the less stock you need — stock volume is inversely proportional to the dilution factor.</p>
    <div class="mt-3 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full table-fixed text-center text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Target C₂<span class="block text-[10px] font-normal text-slate-400">M</span></th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Dilution factor</th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Stock V₁<span class="block text-[10px] font-normal text-slate-400">mL</span></th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">Water added<span class="block text-[10px] font-normal text-slate-400">mL</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700 tabular-nums">
          <tr><td class="px-2 py-2.5 sm:px-3">6</td><td class="px-2 py-2.5 sm:px-3">2×</td><td class="px-2 py-2.5 sm:px-3">500</td><td class="px-2 py-2.5 sm:px-3">500</td></tr>
          <tr><td class="px-2 py-2.5 sm:px-3">1</td><td class="px-2 py-2.5 sm:px-3">12×</td><td class="px-2 py-2.5 sm:px-3">83.3</td><td class="px-2 py-2.5 sm:px-3">916.7</td></tr>
          <tr class="bg-indigo-50 font-semibold text-indigo-700"><td class="px-2 py-2.5 sm:px-3">0.1 ★</td><td class="px-2 py-2.5 sm:px-3">120×</td><td class="px-2 py-2.5 sm:px-3">8.33</td><td class="px-2 py-2.5 sm:px-3">991.7</td></tr>
          <tr><td class="px-2 py-2.5 sm:px-3">0.01</td><td class="px-2 py-2.5 sm:px-3">1200×</td><td class="px-2 py-2.5 sm:px-3">0.83</td><td class="px-2 py-2.5 sm:px-3">999.2</td></tr>
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-slate-400">★ Below ~1 mL of stock, measuring accurately by pipette gets hard — that's exactly when a serial dilution beats a single step. V₁ = C₂ × 1000 mL ÷ 12.</p>
  </section>

  <!-- ============ REAL-WORLD CONTEXT ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Where dilution actually matters</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🧪 The lab bench</h3>
        <p class="mt-1 text-sm text-slate-600">Concentrated stocks are cheaper to store and more stable, so almost every working solution is made by dilution. C₁V₁ = C₂V₂ is used dozens of times a day to turn stock into precise reagents.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">💊 Medicine &amp; pharmacy</h3>
        <p class="mt-1 text-sm text-slate-600">IV drips, injectable drugs and reconstituted antibiotics are diluted to an exact concentration. Here a dilution error is a dosing error, so the calculation is checked and re-checked.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🔬 Calibration &amp; microbiology</h3>
        <p class="mt-1 text-sm text-slate-600">Serial dilutions build the ladder of known standards that calibrate instruments, and thin out bacterial cultures to countable colonies — accuracy at the bottom depends entirely on the dilution maths.</p>
      </div>
    </div>
  </section>

  <!-- ============ MISCONCEPTIONS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"V₂ is the amount of water you add."</p>
        <p class="mt-1 text-sm text-slate-600">V₂ is the <em>total final</em> volume, not the water added. The solvent to add is V₂ − V₁. Topping up to a mark on a volumetric flask gives V₂ directly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Diluting removes some solute."</p>
        <p class="mt-1 text-sm text-slate-600">It doesn't — the moles of solute are unchanged, just spread through more volume. That conservation is the whole reason C₁V₁ = C₂V₂ works.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"C₁ and C₂ can be in different units."</p>
        <p class="mt-1 text-sm text-slate-600">They must match. Mixing M on one side and mg/mL on the other breaks the equation. Convert first so both concentrations share a unit and both volumes share a unit.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Add water to concentrated acid — it's faster."</p>
        <p class="mt-1 text-sm text-slate-600">Dangerous. Diluting acid is strongly exothermic; adding water to acid can make it boil and splash. Always add acid to water, slowly, with stirring.</p>
      </div>
    </div>
  </section>

  <!-- ============ FORMULA SOURCES ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Formula sources &amp; further reading</h2>
    <p class="mt-2 text-slate-600">The dilution relationship is standard general chemistry, traceable to:</p>
    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      <li>• <strong>OpenStax, <em>Chemistry 2e</em></strong> — §3.4 "Molarity" (dilution of solutions; free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/3-4-other-units-for-solution-concentrations" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a></li>
      <li>• <strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 4, Concentrations of Solutions (Dilution).</li>
      <li>• <strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Chapter 4, Solution Stoichiometry.</li>
    </ul>
    <p class="mt-3 text-xs text-slate-400">C₁V₁ = C₂V₂ works with any consistent concentration and volume units. Results are rounded for display.</p>
  </section>

  <!-- ============ HOW TO USE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter three values</h3>
        <p class="mt-1 text-sm text-slate-600">Fill any three of C₁, V₁, C₂, V₂ with consistent units — concentrations matching, volumes matching.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get the fourth + steps</h3>
        <p class="mt-1 text-sm text-slate-600">The missing value solves live, and for a dilution you get plain-English "take X, add Y solvent" instructions.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">See it in the beaker</h3>
        <p class="mt-1 text-sm text-slate-600">Use the sliders to watch concentration and particle density fall as the final volume grows.</p>
      </div>
    </div>
  </section>

  <!-- ============ RELATED TOOLS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/molarity-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🧪</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molarity Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">M = mol/L — solve for any variable.</p>
      </a>
      <a href="/tools/atomic-mass-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">⚗️</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molar Mass Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Sum atomic masses from a formula.</p>
      </a>
      <a href="/tools/ph-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🧫</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">pH Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">pH from hydrogen-ion concentration.</p>
      </a>
    </div>
  </section>

  <!-- Libraries: Three.js + Chart.js + shared subject kit (window.STK) -->
  <SubjectToolLibs />

  <script is:inline>
  (function () {
    'use strict';
    const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
    const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

    // ================= CALCULATOR (preserves original 4-way solve + instructions) =================
    function update() {
      const c1 = parseFloat(el('c1').value), v1 = parseFloat(el('v1').value), c2 = parseFloat(el('c2').value), v2 = parseFloat(el('v2').value);
      const filled = [!isNaN(c1), !isNaN(v1), !isNaN(c2), !isNaN(v2)];
      el('dil-err').textContent = '';
      el('dil-instructions').classList.add('hidden');
      ['r-c1', 'r-v1', 'r-c2', 'r-v2'].forEach((id) => (el(id).textContent = '—'));
      if (filled.filter(Boolean).length < 3) return;
      let rc1 = NaN, rv1 = NaN, rc2 = NaN, rv2 = NaN;
      if (!filled[0]) { if (v1 === 0) { el('dil-err').textContent = 'V₁ cannot be zero.'; return; } rc1 = c2 * v2 / v1; rv1 = v1; rc2 = c2; rv2 = v2; }
      else if (!filled[1]) { if (c1 === 0) { el('dil-err').textContent = 'C₁ cannot be zero.'; return; } rv1 = c2 * v2 / c1; rc1 = c1; rc2 = c2; rv2 = v2; }
      else if (!filled[2]) { if (v2 === 0) { el('dil-err').textContent = 'V₂ cannot be zero.'; return; } rc2 = c1 * v1 / v2; rc1 = c1; rv1 = v1; rv2 = v2; }
      else if (!filled[3]) { if (c2 === 0) { el('dil-err').textContent = 'C₂ cannot be zero.'; return; } rv2 = c1 * v1 / c2; rc1 = c1; rv1 = v1; rc2 = c2; }
      if (!isNaN(rc1)) el('r-c1').textContent = fmt(rc1);
      if (!isNaN(rv1)) el('r-v1').textContent = fmt(rv1);
      if (!isNaN(rc2)) el('r-c2').textContent = fmt(rc2);
      if (!isNaN(rv2)) el('r-v2').textContent = fmt(rv2);
      const fc1 = isNaN(rc1) ? c1 : rc1, fv1 = isNaN(rv1) ? v1 : rv1, fc2 = isNaN(rc2) ? c2 : rc2, fv2 = isNaN(rv2) ? v2 : rv2;
      if (fc1 > fc2 && fv2 > fv1) {
        const add = fv2 - fv1;
        el('dil-instructions').classList.remove('hidden');
        el('dil-instructions').innerHTML = 'Take <strong>' + fmt(fv1) + '</strong> of the stock (C₁) and add <strong>' + fmt(add) + '</strong> of solvent to reach a final volume of <strong>' + fmt(fv2) + '</strong> — a <strong>' + fmt(fc1 / fc2) + '×</strong> dilution.';
      }
    }
    ['c1', 'v1', 'c2', 'v2'].forEach((id) => el(id).addEventListener('input', update));

    // ================= 3D + charts shared state =================
    const charts = {};
    let beaker = null;
    function bState() {
      const mol = parseFloat(el('b-mol').value), vol = parseFloat(el('b-vol').value);
      return { mol, vol, C: vol > 0 ? mol / vol : 0, df: mol > 0 ? vol / (mol / 1) : 1 };
    }
    function onBChange() {
      const s = bState();
      el('out-bmol').textContent = s.mol.toFixed(2);
      el('out-bvol').textContent = s.vol.toFixed(2) + ' L';
      el('out-bc').textContent = fmt(s.C) + ' M';
      // dilution factor relative to a 1 L reference (C at 1 L = mol/1)
      const cRef = s.mol / 1;
      el('out-bdf').textContent = (s.C > 0 ? (cRef / s.C).toFixed(1) : '1.0') + '×';
      try { if (beaker) beaker.update(s); } catch (e) {}
      try { if (charts.ready) updateCharts(s); } catch (e) {}
    }
    el('b-mol').addEventListener('input', onBChange);
    el('b-vol').addEventListener('input', onBChange);

    // ================= CHARTS =================
    function initCharts() {
      if (!window.Chart) return;
      const base = chartSetup();
      charts.cv = new Chart(el('chart-cv'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'C', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Final volume (L)' } }, y: { title: { display: true, text: 'Concentration (M)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.serial = new Chart(el('chart-serial'), {
        type: 'line',
        data: { labels: ['Stock', '1', '2', '3', '4', '5'], datasets: [{ label: 'C (M)', data: [1, 0.1, 0.01, 0.001, 0.0001, 0.00001], borderColor: '#6366f1', pointRadius: 3, tension: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Dilution step' } }, y: { type: 'logarithmic', title: { display: true, text: 'Concentration (M, log)' } } }, plugins: { legend: { display: false } } }),
      });
      charts.stock = new Chart(el('chart-stock'), {
        type: 'bar',
        data: { labels: ['6 M', '1 M', '0.1 M', '0.01 M'], datasets: [{ label: 'Stock volume (mL)', data: [500, 83.3, 8.33, 0.83], backgroundColor: '#f59e0b' }] },
        options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Stock from 12 M (mL, log)' } } }, plugins: { legend: { display: false } } }),
      });
      charts.ready = true;
      updateCharts(bState());
    }
    function updateCharts(s) {
      if (!charts.ready) return;
      const L = [], D = [];
      for (let vv = 0.1; vv <= 5.001; vv += 0.1) { L.push(vv.toFixed(1)); D.push(+(s.mol / vv).toFixed(4)); }
      charts.cv.data.labels = L; charts.cv.data.datasets[0].data = D; charts.cv.update();
    }

    // ================= 3D beaker =================
    function glassBeaker(THREE) {
      const g = new THREE.Group();
      const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
      const wall = new THREE.Mesh(new THREE.CylinderGeometry(2.2, 2.2, 5, 40, 1, true), glassMat); g.add(wall);
      const bottom = new THREE.Mesh(new THREE.CircleGeometry(2.2, 40), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
      return g;
    }
    function initBeaker() {
      const c = el('beaker3d'); if (!c) throw new Error('no beaker');
      const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
      s.scene.add(glassBeaker(THREE));
      const liquidMat = new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.45, roughness: 0.3 });
      let liquid = null;
      const MAX_P = 120;
      const particleGeo = new THREE.SphereGeometry(0.11, 10, 10);
      const particleMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
      const particles = [];
      for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(particleGeo, particleMat); p.visible = false; s.scene.add(p); particles.push(p); }
      function update(state) {
        const frac = Math.max(0.02, Math.min(1, state.vol / 5));
        const hLiq = frac * 4.6;
        if (liquid) { s.scene.remove(liquid); liquid.geometry.dispose(); }
        liquid = new THREE.Mesh(new THREE.CylinderGeometry(2.08, 2.08, hLiq, 40), liquidMat);
        liquid.position.y = -2.4 + hLiq / 2; s.scene.add(liquid);
        const nShow = Math.max(0, Math.min(MAX_P, Math.round(state.C * 22)));
        for (let i = 0; i < MAX_P; i++) {
          const p = particles[i];
          if (i < nShow) { const r = Math.sqrt(Math.random()) * 1.9, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -2.4 + Math.random() * hLiq, Math.sin(a) * r); p.visible = true; }
          else p.visible = false;
        }
      }
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
      frame();
      beaker = { update, resize: s.resize };
      update(bState());
    }

    // ---- diagram: two beakers, same particles ----
    function initDiagTwo() {
      const c = el('diag-two'); if (!c) throw new Error('no diag');
      const s = makeScene(c, 15, new THREE.Vector3(0, 0, 0), MOL_OPTS);
      const pGeo = new THREE.SphereGeometry(0.12, 10, 10);
      const pMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
      function beakerAt(x, liquidH, radius) {
        const grp = new THREE.Group(); grp.position.x = x;
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
        grp.add(new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, 5, 32, 1, true), glassMat));
        const liq = new THREE.Mesh(new THREE.CylinderGeometry(radius * 0.95, radius * 0.95, liquidH, 32), new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.4 }));
        liq.position.y = -2.4 + liquidH / 2; grp.add(liq);
        for (let i = 0; i < 12; i++) { const p = new THREE.Mesh(pGeo, pMat); const r = Math.sqrt(Math.random()) * radius * 0.8, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -2.4 + Math.random() * liquidH, Math.sin(a) * r); grp.add(p); }
        return grp;
      }
      s.scene.add(beakerAt(-3.2, 2.2, 1.6));
      s.scene.add(beakerAt(3.2, 4.4, 2.0));
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagTwo = { resize: s.resize };
    }

    // ---- diagram: serial dilution row (falling particle density) ----
    function initDiagSerial() {
      const c = el('diag-serial'); if (!c) throw new Error('no diag');
      const s = makeScene(c, 17, new THREE.Vector3(0, 0, 0), MOL_OPTS);
      const pGeo = new THREE.SphereGeometry(0.13, 10, 10);
      const pMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
      const counts = [16, 8, 4, 2];
      counts.forEach((n, i) => {
        const grp = new THREE.Group(); grp.position.x = -5.4 + i * 3.6;
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.22, roughness: 0.1, side: THREE.DoubleSide });
        grp.add(new THREE.Mesh(new THREE.CylinderGeometry(1.3, 1.3, 4, 28, 1, true), glassMat));
        const liq = new THREE.Mesh(new THREE.CylinderGeometry(1.24, 1.24, 3.4, 28), new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.4 }));
        liq.position.y = -0.3; grp.add(liq);
        for (let k = 0; k < n; k++) { const p = new THREE.Mesh(pGeo, pMat); const r = Math.sqrt(Math.random()) * 1.05, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -1.9 + Math.random() * 3.2, Math.sin(a) * r); grp.add(p); }
        s.scene.add(grp);
      });
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagSerial = { resize: s.resize };
    }

    let diagTwo = null, diagSerial = null;

    // ================= BOOT =================
    function boot() {
      try { update(); } catch (e) { console.error('[dilution] calc init failed', e); }
      try { onBChange(); } catch (e) { console.error('[dilution] slider init failed', e); }
      try { initCharts(); } catch (e) { console.error('[dilution] charts failed', e); }
      if (window.THREE) {
        try { initBeaker(); } catch (e) { console.error('[dilution] beaker failed', e); el('beaker3d-fallback').classList.remove('hidden'); }
        try { initDiagTwo(); } catch (e) { console.error('[dilution] two-beaker diagram failed', e); }
        try { initDiagSerial(); } catch (e) { console.error('[dilution] serial diagram failed', e); }
      } else {
        el('beaker3d-fallback').classList.remove('hidden');
      }
      mountResize([beaker, diagTwo, diagSerial]);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
  </script>
</ToolLayout>
