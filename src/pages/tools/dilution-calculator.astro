---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Dilution Calculator';
const description = 'Free online dilution calculator. Solve for any variable in C₁V₁ = C₂V₂. Perfect for lab dilutions, serial dilutions, and solution preparation.';
const intro = 'Enter any three values — initial concentration, initial volume, final concentration, or final volume — to solve for the fourth.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is the dilution equation?', a: 'C₁V₁ = C₂V₂, where C₁ and V₁ are the initial concentration and volume, and C₂ and V₂ are the final concentration and volume. The number of moles of solute remains constant during dilution.' },
  { q: 'What units should I use?', a: 'Any consistent concentration and volume units work — molarity with litres, mg/mL with mL, percentage with mL. Just make sure both concentrations use the same unit and both volumes use the same unit.' },
  { q: 'What is a serial dilution?', a: 'A serial dilution is a stepwise dilution where each step dilutes the previous solution by a fixed factor. For example, a 1:10 serial dilution reduces concentration by a factor of 10 at each step.' },
  { q: 'How do I prepare a dilution from a stock solution?', a: 'Use C₁V₁ = C₂V₂. If you need 100 mL of 0.1 M NaCl from a 1 M stock: V₁ = (0.1 × 100) / 1 = 10 mL. Take 10 mL of stock and add 90 mL of solvent (water).' },
  { q: 'Why is "like dissolves like" important?', a: 'Polar solvents (water, ethanol) dissolve polar solutes (salts, sugars). Nonpolar solvents (hexane, benzene) dissolve nonpolar solutes (oils, fats). Using the wrong solvent prevents proper dissolution and dilution.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any three values to solve for the fourth</p>
    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">C₁ (initial conc.)</span>
        <input id="c1" type="number" step="any" placeholder="M" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">V₁ (initial volume)</span>
        <input id="v1" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">C₂ (final conc.)</span>
        <input id="c2" type="number" step="any" placeholder="M" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">V₂ (final volume)</span>
        <input id="v2" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">C₁</div><div id="r-c1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">V₁</div><div id="r-v1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">C₂</div><div id="r-c2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">V₂</div><div id="r-v2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="dil-err" class="mt-3 text-center text-sm text-red-600"></p>
    <div id="dil-instructions" class="mt-4 hidden rounded-xl bg-indigo-50 p-4 text-sm text-indigo-700"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="280" viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dil-title dil-desc">
      <title id="dil-title">Concentrated solution being diluted with arrow and water addition</title>
      <desc id="dil-desc">Two beakers side by side: left shows concentrated solution with many solute particles, right shows diluted solution with more solvent volume and fewer particles per volume</desc>
      <g transform="translate(20,20)">
        <path d="M 100 40 L 100 220 Q 100 240 120 240 L 240 240 Q 260 240 260 220 L 260 40" fill="#fef3c7" stroke="#f59e0b" stroke-width="2.5"/>
        <rect x="110" y="70" width="140" height="20" rx="4" fill="#fca5a5" opacity="0.5"/>
        <circle cx="140" cy="120" r="8" fill="#ef4444" opacity="0.6"/>
        <circle cx="180" cy="140" r="8" fill="#ef4444" opacity="0.6"/>
        <circle cx="210" cy="115" r="8" fill="#ef4444" opacity="0.6"/>
        <circle cx="160" cy="170" r="8" fill="#ef4444" opacity="0.6"/>
        <circle cx="200" cy="185" r="8" fill="#ef4444" opacity="0.6"/>
        <text x="180" y="25" text-anchor="middle" fill="#d97706" font-size="14" font-weight="bold">Concentrated</text>
        <text x="180" y="265" text-anchor="middle" fill="#64748b" font-size="12">C₁, V₁</text>
        <path d="M 300 130 Q 340 100 380 130" stroke="#10b981" stroke-width="2.5" fill="none"/>
        <polygon points="380,130 372,120 372,140" fill="#10b981"/>
        <text x="340" y="90" text-anchor="middle" fill="#10b981" font-size="13" font-weight="bold">Add water</text>
        <path d="M 470 40 L 470 220 Q 470 240 490 240 L 610 240 Q 630 240 630 220 L 630 40" fill="#e0f2fe" stroke="#0ea5e9" stroke-width="2.5"/>
        <circle cx="510" cy="120" r="8" fill="#ef4444" opacity="0.4"/>
        <circle cx="560" cy="140" r="8" fill="#ef4444" opacity="0.4"/>
        <circle cx="530" cy="170" r="8" fill="#ef4444" opacity="0.4"/>
        <text x="550" y="25" text-anchor="middle" fill="#0ea5e9" font-size="14" font-weight="bold">Diluted</text>
        <text x="550" y="265" text-anchor="middle" fill="#64748b" font-size="12">C₂, V₂</text>
        <text x="400" y="200" text-anchor="middle" fill="#4338ca" font-size="18" font-weight="bold">C₁ × V₁ = C₂ × V₂</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Adding solvent to a concentrated solution reduces its concentration while keeping the total amount of solute constant.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How dilution is calculated</h2>
    <p class="mt-2 text-slate-600">The dilution equation <span class="font-mono">C₁V₁ = C₂V₂</span> expresses the principle that the amount of solute remains constant when you add more solvent. C₁ and V₁ are the starting concentration and volume, and C₂ and V₂ are the final values. The equation works with any consistent concentration units (molarity, percentage, mg/mL, ppm) and volume units. The dilution factor is C₁/C₂ = V₂/V₁ — the ratio of initial to final concentration equals the ratio of final to initial volume.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">You have 50 mL of 6 M HCl. How much water must you add to make 1 M HCl?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">C₁:</span> <span class="text-slate-600">6 M</span></div>
        <div><span class="font-medium text-slate-700">V₁:</span> <span class="text-slate-600">50 mL</span></div>
        <div><span class="font-medium text-slate-700">C₂:</span> <span class="text-slate-600">1 M</span></div>
        <div><span class="font-medium text-slate-700">V₂:</span> <span class="text-slate-600">V₂ = (6 × 50) / 1 = 300 mL</span></div>
        <div><span class="font-medium text-slate-700">Water to add:</span> <span class="text-slate-600">300 − 50 = 250 mL</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F9EA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Lab Technician</h3>
      <p class="mt-1 text-sm text-slate-600">Prepare working solutions from concentrated stock solutions. Calculate exact volumes needed for dilutions in chemistry, biology, and clinical labs with precision and confidence.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F33F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Environmental Analyst</h3>
      <p class="mt-1 text-sm text-slate-600">Dilute environmental samples to bring concentrations within the detection range of analytical instruments. Prepare calibration standards for spectrophotometers and chromatographs.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F48A;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Pharmaceutical Scientist</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate drug formulation dilutions to achieve exact dosages. Ensure that tablet coating solutions, injectable preparations, and oral suspensions have the correct concentration.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F34E;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Food & Beverage Technologist</h3>
      <p class="mt-1 text-sm text-slate-600">Dilute concentrated flavourings, preservatives, and colourings to the correct strength for food products. Ensure consistent taste and appearance across production batches.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the dilution calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter three values</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in any three of C₁, V₁, C₂, and V₂. Use consistent units — if C₁ is in molarity, C₂ must also be in molarity. Same for volumes.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Instant fourth value</h3>
        <p class="mt-1 text-sm text-slate-600">The missing variable is calculated and displayed in real time. The highlighted box shows the solved value among the four.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get step-by-step instructions</h3>
        <p class="mt-1 text-sm text-slate-600">When all four values are entered, the calculator shows exactly how much solvent to add to prepare the dilution in plain English instructions.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for dilution calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always add acid to water, not water to acid</h3>
        <p class="mt-1 text-sm text-slate-600">When diluting concentrated acids, always add the acid to water slowly while stirring. Adding water to concentrated acid can cause violent boiling and splashing due to the exothermic heat of dilution.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use volumetric flasks for accuracy</h3>
        <p class="mt-1 text-sm text-slate-900">For precise dilutions, use a volumetric flask. Pipette the stock solution into the flask, then add solvent up to the calibration mark. Graduated cylinders are less accurate.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">C₁V₁ = C₂V₂ works for any concentration unit</h3>
        <p class="mt-1 text-sm text-slate-600">Whether you're working with molarity, percent concentration, mg/mL, ppm, or even beer's wort gravity units, the dilution formula holds as long as you use the same unit on both sides of the equation.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/molarity-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F9EA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molarity Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">M = mol/L — solve for any variable.</p>
      </a>
      <a href="/tools/ph-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F9EA;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">pH Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">pH from hydrogen ion concentration.</p>
      </a>
      <a href="/tools/atomic-mass-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2697;&#xFE0F;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molar Mass Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Sum atomic masses from chemical formula.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(6)).toLocaleString(undefined, { minimumFractionDigits: 4, maximumFractionDigits: 6 });
    function update() {
      const c1 = parseFloat(el('c1').value);
      const v1 = parseFloat(el('v1').value);
      const c2 = parseFloat(el('c2').value);
      const v2 = parseFloat(el('v2').value);
      const filled = [!isNaN(c1), !isNaN(v1), !isNaN(c2), !isNaN(v2)];
      const count = filled.filter(Boolean).length;
      el('dil-err').textContent = '';
      el('dil-instructions').classList.add('hidden');
      ['r-c1', 'r-v1', 'r-c2', 'r-v2'].forEach(id => el(id).textContent = '—');
      if (count < 3) return;
      let rc1 = NaN, rv1 = NaN, rc2 = NaN, rv2 = NaN;
      if (!filled[0]) { if (v1 === 0) { el('dil-err').textContent = 'V₁ cannot be zero.'; return; } rc1 = c2 * v2 / v1; rv1 = v1; rc2 = c2; rv2 = v2; }
      else if (!filled[1]) { if (c1 === 0) { el('dil-err').textContent = 'C₁ cannot be zero.'; return; } rv1 = c2 * v2 / c1; rc1 = c1; rc2 = c2; rv2 = v2; }
      else if (!filled[2]) { if (v2 === 0) { el('dil-err').textContent = 'V₂ cannot be zero.'; return; } rc2 = c1 * v1 / v2; rc1 = c1; rv1 = v1; rv2 = v2; }
      else if (!filled[3]) { if (c2 === 0) { el('dil-err').textContent = 'C₂ cannot be zero.'; return; } rv2 = c1 * v1 / c2; rc1 = c1; rv1 = v1; rc2 = c2; }
      if (!isNaN(rc1)) el('r-c1').textContent = fmt(rc1);
      if (!isNaN(rv1)) el('r-v1').textContent = fmt(rv1);
      if (!isNaN(rc2)) el('r-c2').textContent = fmt(rc2);
      if (!isNaN(rv2)) el('r-v2').textContent = fmt(rv2);
      if (filled.every(Boolean) && c1 > c2) {
        const add = v2 - v1;
        if (add > 0) {
          el('dil-instructions').classList.remove('hidden');
          el('dil-instructions').innerHTML = 'Take <strong>' + fmt(v1) + '</strong> of the stock solution and add <strong>' + fmt(add) + '</strong> of solvent to reach a final volume of <strong>' + fmt(v2) + '</strong>.';
        }
      }
    }
    ['c1', 'v1', 'c2', 'v2'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
