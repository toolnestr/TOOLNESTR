---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Currency Converter – Real-Time Exchange Rates';
const description = "Free real-time currency converter with 50+ currencies, live exchange rates via ECB, searchable dropdowns, and popular-pair grid.";

const faqs = [
  { q: 'Where does the exchange rate data come from?', a: 'Exchange rates are fetched from the Frankfurter API, which sources its data from the European Central Bank (ECB). ECB rates are updated every business day, typically around 16:00 Central European Time. These rates are mid-market rates — the midpoint between buy and sell prices — and do not include the spread that banks or exchange services charge. Your actual conversion rate at a bank or ATM will differ.' },
  { q: 'How often are the rates updated?', a: 'The European Central Bank publishes reference rates once per business day. Rates are not available on weekends or ECB public holidays. When you refresh the page or click the reload button, the tool fetches the most recent available rates from the Frankfurter API. Rates are cached in your browser for the current session to avoid unnecessary API calls.' },
  { q: 'What is the difference between a mid-market rate and a bank rate?', a: 'The mid-market rate (also called the interbank rate) is the midpoint of the global currency market. Banks and exchange services buy currencies slightly below this rate and sell slightly above it — the difference is their margin or spread. Consumer exchange services typically add a 1–4% margin; some airport kiosks and credit cards add 5% or more. Always compare the mid-market rate to the rate you are offered to understand the true cost of conversion.' },
  { q: 'How do I use the search in the currency dropdowns?', a: 'Click or tap either the From or To field to open the dropdown. You can immediately start typing to search by currency code (USD, EUR, GBP) or by country or currency name (dollar, euro, pound). The list filters in real time as you type. Click or tap any result to select it. On mobile this avoids the native select picker scrolling off the screen.' },
  { q: 'Are cryptocurrency rates included?', a: 'No. This tool covers 50+ traditional fiat currencies sourced from the European Central Bank. The ECB does not publish cryptocurrency rates, and crypto prices change by the second — a daily ECB snapshot would not be useful for crypto. For crypto conversions, use a dedicated cryptocurrency exchange or API that provides live prices.' },
  { q: 'Why are some currencies missing?', a: 'The Frankfurter API covers the currencies for which the European Central Bank publishes official daily reference rates. This includes all major world currencies and most secondary currencies. Some smaller or less-traded currencies — such as the North Korean won, the Cuban peso, or certain Pacific island currencies — are not part of the ECB reference rate programme and are therefore not available.' },
  { q: 'Can I use this for financial decisions?', a: 'This tool is intended for informational and reference purposes. The rates shown are mid-market reference rates and will differ from rates offered by banks, brokers, payment apps or exchange kiosks. For significant financial transactions, always verify rates with your financial institution before proceeding. Exchange rates can change rapidly, and even a short delay between viewing a rate and executing a transaction can result in a different final rate.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Currency Converter',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  browserRequirements: 'Requires JavaScript',
  description: 'Real-time currency converter with 50+ currencies and live ECB exchange rates.',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to convert currency',
  description: 'Convert between 50+ currencies using live European Central Bank exchange rates.',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Enter an amount', text: 'Type the amount you want to convert.' },
    { '@type': 'HowToStep', position: 2, name: 'Choose currencies', text: 'Pick the From and To currencies — type to search by code, country or currency name.' },
    { '@type': 'HowToStep', position: 3, name: 'See the result', text: 'The converted amount updates instantly using the latest ECB reference rate.' },
    { '@type': 'HowToStep', position: 4, name: 'Swap or pick a pair', text: 'Use the swap button to reverse the pair, or tap a popular pair for a one-click conversion.' },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={[faqSchema, toolSchema, howToSchema]}>
  <style is:inline>
    :root {
      --primary:#6366f1; --success:#10b981; --error:#ef4444; --warn:#f59e0b;
      --bg:#f8fafc; --card:#ffffff; --text:#1e293b; --muted:#64748b; --border:#e2e8f0;
    }

    /* ── Hero ── */
    .cc-hero {
      background:linear-gradient(135deg,#1e1b4b 0%,#312e81 30%,#4c1d95 65%,#2e1065 100%);
      position:relative; overflow:hidden; padding:40px 20px 44px; text-align:center;
    }
    .cc-hero::before { content:''; position:absolute; top:-80px; right:-80px; width:320px; height:320px; background:radial-gradient(circle,rgba(167,139,250,.22) 0%,transparent 70%); pointer-events:none; }
    .cc-hero::after  { content:''; position:absolute; bottom:-60px; left:-60px; width:240px; height:240px; background:radial-gradient(circle,rgba(99,102,241,.18) 0%,transparent 70%); pointer-events:none; }
    .cc-badge { display:inline-flex; align-items:center; gap:5px; margin-bottom:12px; background:rgba(255,255,255,.12); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.22); color:#e0e7ff; font-size:.72rem; font-weight:700; letter-spacing:.08em; padding:4px 14px; border-radius:20px; position:relative; z-index:1; }
    .cc-hero h1 { font-size:clamp(1.5rem,4vw,2.2rem); font-weight:700; color:#fff; margin:0 0 6px; letter-spacing:-.02em; position:relative; z-index:1; }
    .cc-hero p  { font-size:clamp(.85rem,2vw,1rem); color:#c4b5fd; margin:0; position:relative; z-index:1; }

    /* ── Wrap ── */
    .cc-wrap { max-width:700px; margin:0 auto; padding:24px 16px 0; }

    /* ── Converter card ── */
    .conv-card { background:var(--card); border:1.5px solid var(--border); border-radius:18px; padding:24px; margin-bottom:18px; }
    .conv-row { display:flex; align-items:flex-end; gap:10px; flex-wrap:wrap; }
    .conv-field { flex:1; min-width:120px; }
    .conv-label { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:var(--muted); margin-bottom:6px; }
    .conv-input { width:100%; padding:12px 14px; border:1.5px solid var(--border); border-radius:12px; font-size:1.2rem; font-weight:700; background:var(--bg); color:var(--text); outline:none; }
    .conv-input:focus { border-color:var(--primary); }
    .conv-sel { flex:1.4; min-width:170px; position:relative; }
    .swap-btn { padding:10px 14px; border-radius:12px; border:1.5px solid var(--border); background:var(--bg); cursor:pointer; font-size:1.2rem; transition:all .15s; flex-shrink:0; height:46px; }
    .swap-btn:hover { border-color:var(--primary); color:var(--primary); }

    /* ── Custom dropdown ── */
    .cdd { position:relative; }
    .cdd-trigger { width:100%; padding:11px 12px; border:1.5px solid var(--border); border-radius:12px; background:var(--bg); color:var(--text); cursor:pointer; display:flex; align-items:center; gap:7px; font-size:.92rem; font-weight:600; transition:border-color .15s; height:46px; }
    .cdd-trigger:focus { outline:none; border-color:var(--primary); }
    .cdd-trigger.open { border-color:var(--primary); border-bottom-left-radius:0; border-bottom-right-radius:0; border-bottom-color:transparent; }
    .cdd-flag { font-size:1.1rem; line-height:1; flex-shrink:0; }
    .cdd-code { font-weight:700; font-size:.9rem; }
    .cdd-name { color:var(--muted); font-size:.78rem; font-weight:500; flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .cdd-arrow { margin-left:auto; font-size:.6rem; color:var(--muted); transition:transform .2s; flex-shrink:0; }
    .cdd-trigger.open .cdd-arrow { transform:rotate(180deg); }

    .cdd-panel { position:absolute; top:calc(100% - 1px); left:0; right:0; background:var(--card); border:1.5px solid var(--primary); border-top:none; border-radius:0 0 12px 12px; z-index:200; box-shadow:0 8px 24px rgba(0,0,0,.14); max-height:260px; display:none; flex-direction:column; }
    .cdd-panel.open { display:flex; }
    .cdd-search { padding:9px 12px; border:none; border-bottom:1px solid var(--border); outline:none; background:var(--card); color:var(--text); font-size:.86rem; width:100%; flex-shrink:0; }
    .cdd-search::placeholder { color:var(--muted); }
    .cdd-list { overflow-y:auto; flex:1; overscroll-behavior:contain; }
    .cdd-opt { display:flex; align-items:center; gap:8px; padding:9px 12px; cursor:pointer; font-size:.86rem; transition:background .1s; }
    .cdd-opt:hover, .cdd-opt.focused { background:#f1f5f9; }
    .cdd-opt.selected { background:#eef2ff; }
    .cdd-opt .of { font-size:.95rem; flex-shrink:0; }
    .cdd-opt .oc { font-weight:700; min-width:38px; font-size:.84rem; }
    .cdd-opt .on { color:var(--muted); font-size:.8rem; }
    .cdd-no { padding:14px; color:var(--muted); font-size:.85rem; text-align:center; }

    /* ── Result ── */
    .result-card { background:linear-gradient(135deg,#eef2ff,#f5f3ff); border:2px solid #a5b4fc; border-radius:16px; padding:22px; text-align:center; margin-bottom:18px; }
    .result-val { font-size:clamp(1.8rem,5vw,2.6rem); font-weight:900; color:var(--primary); letter-spacing:-.03em; }
    .result-sub { font-size:.85rem; color:var(--muted); margin-top:6px; }
    .result-rate { font-size:.78rem; color:var(--muted); margin-top:4px; }
    .result-ts   { font-size:.74rem; color:var(--muted); margin-top:3px; }
    .reload-btn  { margin-top:10px; padding:6px 16px; border-radius:8px; border:1.5px solid var(--border); background:transparent; color:var(--muted); cursor:pointer; font-size:.8rem; }
    .reload-btn:hover { border-color:var(--primary); color:var(--primary); }

    /* ── Popular grid ── */
    .pop-title { font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:var(--muted); margin-bottom:10px; }
    .pop-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:8px; margin-bottom:24px; }
    @media(min-width:480px) { .pop-grid { grid-template-columns:repeat(3,1fr); } }
    @media(min-width:640px) { .pop-grid { grid-template-columns:repeat(4,1fr); } }
    .pop-item { background:var(--card); border:1.5px solid var(--border); border-radius:12px; padding:10px; cursor:pointer; transition:all .15s; }
    .pop-item:hover { border-color:var(--primary); transform:translateY(-1px); }
    .pop-item .pf { font-size:1rem; }
    .pop-item .pc { font-size:.7rem; font-weight:700; color:var(--muted); margin-top:2px; }
    .pop-item .pv { font-size:.88rem; font-weight:800; color:var(--text); margin-top:2px; }

    .cc-loading { display:flex; align-items:center; justify-content:center; gap:8px; color:var(--muted); font-size:.9rem; padding:16px; }
    .cc-spin { width:18px; height:18px; border:2px solid var(--border); border-top-color:var(--primary); border-radius:50%; animation:spin .7s linear infinite; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .cc-error { padding:14px 16px; background:#fef2f2; border:1px solid #fca5a5; border-radius:10px; color:#b91c1c; font-size:.88rem; margin-bottom:14px; }

    /* About / FAQ */
    .about-section { max-width:700px; margin:32px auto 0; padding:0 16px; }
    .about-card { background:var(--card); border:1.5px solid var(--border); border-radius:16px; padding:28px; }
    .about-card h2 { font-size:1.3rem; font-weight:800; margin-bottom:16px; }
    .about-card p  { font-size:.92rem; line-height:1.8; color:var(--muted); margin-bottom:14px; }
    .about-card p:last-child { margin-bottom:0; }
    .about-card h3 { font-size:1rem; font-weight:700; color:var(--text); margin:20px 0 8px; }
    .faq-section { max-width:700px; margin:28px auto 40px; padding:0 16px; }
    .faq-title { font-size:1.2rem; font-weight:800; margin-bottom:16px; }
    .faq-item { background:var(--card); border:1px solid var(--border); border-radius:12px; margin-bottom:10px; }
    .faq-q { padding:14px 16px; font-weight:600; cursor:pointer; display:flex; justify-content:space-between; align-items:center; font-size:.93rem; }
    .faq-q:hover { color:var(--primary); }
    .faq-a { padding:0 16px 14px; font-size:.88rem; color:var(--muted); line-height:1.65; display:none; }
    .faq-item.open .faq-a { display:block; }
    .faq-item.open .faq-arrow { transform:rotate(180deg); }
    .faq-arrow { transition:transform .2s; font-size:.75rem; color:var(--muted); }
  </style>

  <!-- Hero -->
  <div class="cc-hero">
    <div class="cc-badge">★ FLAGSHIP TOOL</div>
    <h1>💱 Currency Converter</h1>
    <p>Live exchange rates · 50+ currencies · ECB data · No sign-up</p>
  </div>

  <div class="cc-wrap">
    <div id="ccError" class="cc-error" style="display:none;"></div>

    <!-- Converter card -->
    <div class="conv-card">
      <div class="conv-row">
        <div class="conv-field">
          <div class="conv-label">Amount</div>
          <input class="conv-input" type="number" id="amountInput" value="1" min="0" step="any">
        </div>
        <div class="conv-sel">
          <div class="conv-label">From</div>
          <div class="cdd" id="fromCdd"></div>
        </div>
        <button class="swap-btn" id="swapBtn" title="Swap currencies">⇄</button>
        <div class="conv-sel">
          <div class="conv-label">To</div>
          <div class="cdd" id="toCdd"></div>
        </div>
      </div>
    </div>

    <!-- Result -->
    <div class="result-card" id="resultCard">
      <div class="cc-loading" id="loadingEl"><div class="cc-spin"></div> Fetching rates…</div>
      <div id="resultEl" style="display:none;">
        <div class="result-val" id="resultVal">–</div>
        <div class="result-sub" id="resultSub"></div>
        <div class="result-rate" id="resultRate"></div>
        <div class="result-ts" id="resultTs"></div>
        <button class="reload-btn" id="reloadBtn">🔄 Refresh rates</button>
      </div>
    </div>

    <!-- Popular pairs -->
    <div class="pop-title">Popular conversions</div>
    <div class="pop-grid" id="popGrid"></div>
  </div>

  <!-- About -->
  <section class="about-section">
    <div class="about-card">
      <h2>About the Currency Converter</h2>
      <p>The ToolNestr Currency Converter provides real-time exchange rates for over 50 world currencies, sourced from the European Central Bank through the Frankfurter API. Unlike many currency converters that require you to create an account or install a mobile app, this tool works instantly in your browser without any registration. Simply enter an amount, choose your source and target currencies, and the converted value appears immediately.</p>
      <p>Exchange rates are mid-market reference rates published by the European Central Bank on every business day. The ECB rate is the fairest benchmark for comparison because it sits exactly at the midpoint between the buy and sell prices traded on global foreign exchange markets. When a bank or money transfer service quotes you a different rate, the difference between their rate and the ECB mid-market rate is the fee or margin they are charging you.</p>

      <h3>Searchable currency dropdowns</h3>
      <p>With 50+ currencies in the list, scrolling through a long dropdown can be frustrating — especially on a mobile device where native select elements often display as a small wheel picker that scrolls off the bottom of the screen. The custom searchable dropdowns in this tool solve that problem. Click or tap either currency field and start typing: the list filters instantly by currency code (USD, EUR, JPY) or by name (dollar, euro, yen). You can find any currency in seconds without scrolling through the entire list.</p>
      <p>The dropdown is also fully keyboard-accessible. Press Tab to focus, start typing to filter, use the arrow keys to move through results, and press Enter to select. This makes the tool comfortable to use in any context, whether you are on a phone, a tablet, or a desktop computer with only a keyboard.</p>

      <h3>Popular conversions grid</h3>
      <p>Below the main converter, a grid of popular currency pairs shows the equivalent value for your current amount in 16 commonly traded currencies. This lets you compare rates at a glance without having to change your selected currencies. Clicking any card in the grid instantly sets that currency as your target and updates the main result. The popular conversions update in real time as you change the amount or base currency, making it easy to scan multiple scenarios quickly.</p>

      <h3>Swap and reload</h3>
      <p>The swap button (⇄) reverses your from and to currencies with a single click — useful when you want to check the inverse rate, for example converting from USD to EUR and then checking EUR to USD. The reload button fetches the latest available ECB rates; since ECB rates are updated once per business day, you will rarely need this, but it is useful if you have had the page open for a long time and want to make sure you have the most current data.</p>

      <h3>Which currencies are included</h3>
      <p>The tool covers all currencies for which the European Central Bank publishes daily reference rates. This includes the major G10 currencies (USD, EUR, GBP, JPY, CHF, CAD, AUD, NZD, SEK, NOK, DKK), the largest emerging-market currencies (CNY, INR, BRL, MXN, ZAR, TRY), currencies from the Middle East (AED, SAR, QAR, KWD, BHD, ILS), African currencies (EGP, NGN, KES, GHS, MAD), Southeast Asian currencies (THB, MYR, IDR, PHP, VND, SGD), South Asian currencies (PKR, BDT, LKR, NPR), and Latin American currencies (CLP, COP, ARS, PEN, UYU). This covers the vast majority of international trade and travel currency needs.</p>

      <h3>Data privacy</h3>
      <p>All currency conversion calculations are performed entirely in your browser. The only external request this tool makes is to the Frankfurter API to retrieve the latest exchange rates for your chosen base currency. No personal data, no conversion amounts, and no user identifiers are ever sent to any server. The tool does not use cookies or local storage.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <h2 class="faq-title">Frequently Asked Questions</h2>
    {faqs.map((f) => (
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
          {f.q}<span class="faq-arrow">▼</span>
        </div>
        <div class="faq-a">{f.a}</div>
      </div>
    ))}
  </section>

  <script is:inline>
  (function () {
    const CURRENCIES = [
      { code:'USD', flag:'🇺🇸', name:'US Dollar' },
      { code:'EUR', flag:'🇪🇺', name:'Euro' },
      { code:'GBP', flag:'🇬🇧', name:'British Pound' },
      { code:'JPY', flag:'🇯🇵', name:'Japanese Yen' },
      { code:'CHF', flag:'🇨🇭', name:'Swiss Franc' },
      { code:'CAD', flag:'🇨🇦', name:'Canadian Dollar' },
      { code:'AUD', flag:'🇦🇺', name:'Australian Dollar' },
      { code:'NZD', flag:'🇳🇿', name:'New Zealand Dollar' },
      { code:'CNY', flag:'🇨🇳', name:'Chinese Yuan' },
      { code:'INR', flag:'🇮🇳', name:'Indian Rupee' },
      { code:'KRW', flag:'🇰🇷', name:'South Korean Won' },
      { code:'SGD', flag:'🇸🇬', name:'Singapore Dollar' },
      { code:'HKD', flag:'🇭🇰', name:'Hong Kong Dollar' },
      { code:'MXN', flag:'🇲🇽', name:'Mexican Peso' },
      { code:'BRL', flag:'🇧🇷', name:'Brazilian Real' },
      { code:'SEK', flag:'🇸🇪', name:'Swedish Krona' },
      { code:'NOK', flag:'🇳🇴', name:'Norwegian Krone' },
      { code:'DKK', flag:'🇩🇰', name:'Danish Krone' },
      { code:'PLN', flag:'🇵🇱', name:'Polish Zloty' },
      { code:'CZK', flag:'🇨🇿', name:'Czech Koruna' },
      { code:'HUF', flag:'🇭🇺', name:'Hungarian Forint' },
      { code:'RON', flag:'🇷🇴', name:'Romanian Leu' },
      { code:'BGN', flag:'🇧🇬', name:'Bulgarian Lev' },
      { code:'RUB', flag:'🇷🇺', name:'Russian Ruble' },
      { code:'TRY', flag:'🇹🇷', name:'Turkish Lira' },
      { code:'ZAR', flag:'🇿🇦', name:'South African Rand' },
      { code:'ILS', flag:'🇮🇱', name:'Israeli Shekel' },
      { code:'AED', flag:'🇦🇪', name:'UAE Dirham' },
      { code:'SAR', flag:'🇸🇦', name:'Saudi Riyal' },
      { code:'QAR', flag:'🇶🇦', name:'Qatari Riyal' },
      { code:'KWD', flag:'🇰🇼', name:'Kuwaiti Dinar' },
      { code:'BHD', flag:'🇧🇭', name:'Bahraini Dinar' },
      { code:'EGP', flag:'🇪🇬', name:'Egyptian Pound' },
      { code:'NGN', flag:'🇳🇬', name:'Nigerian Naira' },
      { code:'KES', flag:'🇰🇪', name:'Kenyan Shilling' },
      { code:'GHS', flag:'🇬🇭', name:'Ghanaian Cedi' },
      { code:'MAD', flag:'🇲🇦', name:'Moroccan Dirham' },
      { code:'DZD', flag:'🇩🇿', name:'Algerian Dinar' },
      { code:'TND', flag:'🇹🇳', name:'Tunisian Dinar' },
      { code:'THB', flag:'🇹🇭', name:'Thai Baht' },
      { code:'MYR', flag:'🇲🇾', name:'Malaysian Ringgit' },
      { code:'IDR', flag:'🇮🇩', name:'Indonesian Rupiah' },
      { code:'PHP', flag:'🇵🇭', name:'Philippine Peso' },
      { code:'VND', flag:'🇻🇳', name:'Vietnamese Dong' },
      { code:'PKR', flag:'🇵🇰', name:'Pakistani Rupee' },
      { code:'BDT', flag:'🇧🇩', name:'Bangladeshi Taka' },
      { code:'LKR', flag:'🇱🇰', name:'Sri Lankan Rupee' },
      { code:'NPR', flag:'🇳🇵', name:'Nepalese Rupee' },
      { code:'CLP', flag:'🇨🇱', name:'Chilean Peso' },
      { code:'COP', flag:'🇨🇴', name:'Colombian Peso' },
      { code:'ARS', flag:'🇦🇷', name:'Argentine Peso' },
      { code:'PEN', flag:'🇵🇪', name:'Peruvian Sol' },
      { code:'UYU', flag:'🇺🇾', name:'Uruguayan Peso' },
      { code:'ISK', flag:'🇮🇸', name:'Icelandic Krona' },
    ];

    const POPULAR = ['USD','EUR','GBP','JPY','CHF','CAD','AUD','CNY','INR','AED','SAR','SGD','MXN','BRL','TRY','ZAR'];

    let fromCode = 'USD';
    let toCode   = 'EUR';
    let rates    = null;
    let ratesTs  = null;

    function byCode(code) { return CURRENCIES.find(c => c.code === code) || { code, flag:'🌐', name:code }; }

    // ── Custom Dropdown factory ──
    function makeDropdown(container, initialCode, onChange) {
      let selected = initialCode;
      let filtered = [...CURRENCIES];
      let focusIdx = -1;

      const trigger = document.createElement('button');
      trigger.type = 'button';
      trigger.className = 'cdd-trigger';

      const panel = document.createElement('div');
      panel.className = 'cdd-panel';

      const searchInput = document.createElement('input');
      searchInput.className = 'cdd-search';
      searchInput.placeholder = 'Search code or name…';
      searchInput.setAttribute('autocomplete', 'off');

      const list = document.createElement('div');
      list.className = 'cdd-list';
      panel.appendChild(searchInput);
      panel.appendChild(list);
      container.appendChild(trigger);
      container.appendChild(panel);

      function renderTrigger() {
        const c = byCode(selected);
        trigger.innerHTML = `<span class="cdd-flag">${c.flag}</span><span class="cdd-code">${c.code}</span><span class="cdd-name">${c.name}</span><span class="cdd-arrow">▼</span>`;
      }

      function renderList() {
        if (!filtered.length) { list.innerHTML = `<div class="cdd-no">No results</div>`; return; }
        list.innerHTML = filtered.map((c, i) =>
          `<div class="cdd-opt${c.code === selected ? ' selected' : ''}${i === focusIdx ? ' focused' : ''}" data-code="${c.code}">
            <span class="of">${c.flag}</span><span class="oc">${c.code}</span><span class="on">${c.name}</span>
          </div>`
        ).join('');
        const sel = list.querySelector('.selected');
        if (sel) sel.scrollIntoView({ block:'nearest' });
      }

      function open() {
        trigger.classList.add('open');
        panel.classList.add('open');
        searchInput.value = '';
        filtered = [...CURRENCIES];
        focusIdx = -1;
        renderList();
        setTimeout(() => searchInput.focus(), 10);
      }

      function close() {
        trigger.classList.remove('open');
        panel.classList.remove('open');
        focusIdx = -1;
      }

      function select(code) {
        selected = code;
        renderTrigger();
        close();
        onChange(code);
      }

      trigger.addEventListener('click', () => panel.classList.contains('open') ? close() : open());

      searchInput.addEventListener('input', () => {
        const q = searchInput.value.trim().toLowerCase();
        filtered = q ? CURRENCIES.filter(c => c.code.toLowerCase().includes(q) || c.name.toLowerCase().includes(q)) : [...CURRENCIES];
        focusIdx = -1;
        renderList();
      });

      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          focusIdx = Math.min(focusIdx + 1, filtered.length - 1);
          renderList();
          const el = list.querySelectorAll('.cdd-opt')[focusIdx];
          if (el) el.scrollIntoView({ block:'nearest' });
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          focusIdx = Math.max(focusIdx - 1, 0);
          renderList();
          const el = list.querySelectorAll('.cdd-opt')[focusIdx];
          if (el) el.scrollIntoView({ block:'nearest' });
        } else if (e.key === 'Enter' && focusIdx >= 0 && filtered[focusIdx]) {
          select(filtered[focusIdx].code);
        } else if (e.key === 'Escape') {
          close();
        }
      });

      list.addEventListener('click', (e) => {
        const opt = e.target.closest('.cdd-opt');
        if (opt) select(opt.dataset.code);
      });

      document.addEventListener('click', (e) => {
        if (!container.contains(e.target)) close();
      }, true);

      renderTrigger();

      return {
        get value() { return selected; },
        setValue(code) { selected = code; renderTrigger(); },
      };
    }

    const fromDd = makeDropdown(document.getElementById('fromCdd'), fromCode, (code) => { fromCode = code; fetchRates(); });
    const toDd   = makeDropdown(document.getElementById('toCdd'),   toCode,   (code) => { toCode = code;   convert(); });

    const loadingEl   = document.getElementById('loadingEl');
    const resultEl    = document.getElementById('resultEl');
    const resultVal   = document.getElementById('resultVal');
    const resultSub   = document.getElementById('resultSub');
    const resultRate  = document.getElementById('resultRate');
    const resultTs    = document.getElementById('resultTs');
    const amountInput = document.getElementById('amountInput');
    const popGrid     = document.getElementById('popGrid');
    const ccError     = document.getElementById('ccError');

    async function fetchRates() {
      loadingEl.style.display = 'flex';
      resultEl.style.display  = 'none';
      ccError.style.display   = 'none';
      try {
        const res  = await fetch(`https://api.frankfurter.dev/v1/latest?from=${fromCode}`);
        const data = await res.json();
        rates   = data.rates;
        rates[fromCode] = 1;
        ratesTs = data.date;
        convert();
      } catch (e) {
        loadingEl.style.display = 'none';
        ccError.style.display   = 'block';
        ccError.textContent     = '⚠ Could not fetch exchange rates. Please check your connection and try again.';
      }
    }

    function fmt(val, code) {
      try {
        return new Intl.NumberFormat('en-US', {
          style:'currency', currency:code,
          maximumFractionDigits: val >= 1000 ? 2 : val >= 1 ? 4 : 6
        }).format(val);
      } catch { return val.toFixed(4) + ' ' + code; }
    }

    function convert() {
      if (!rates) return;
      const amount = parseFloat(amountInput.value) || 0;
      const rate   = rates[toCode];
      if (!rate) return;
      const result = amount * rate;
      const f = byCode(fromCode);
      const t = byCode(toCode);
      loadingEl.style.display = 'none';
      resultEl.style.display  = 'block';
      resultVal.textContent   = fmt(result, toCode);
      resultSub.textContent   = `${amount.toLocaleString()} ${f.flag} ${f.code} = ${fmt(result, toCode)} ${t.flag} ${t.code}`;
      resultRate.textContent  = `1 ${f.code} = ${rates[toCode]} ${toCode}  ·  1 ${t.code} = ${(1/rates[toCode]).toFixed(6)} ${fromCode}`;
      resultTs.textContent    = `Rates date: ${ratesTs || 'Loading…'}`;
      renderPopular(amount);
    }

    function renderPopular(amount) {
      popGrid.innerHTML = POPULAR.filter(c => c !== fromCode).slice(0, 16).map(code => {
        const c  = byCode(code);
        const rt = rates[code];
        const v  = rt !== undefined ? amount * rt : null;
        return `<div class="pop-item" data-code="${code}">
          <div class="pf">${c.flag}</div>
          <div class="pc">${c.code} — ${c.name}</div>
          <div class="pv">${v !== null ? fmt(v, code) : '–'}</div>
        </div>`;
      }).join('');
    }

    popGrid.addEventListener('click', (e) => {
      const item = e.target.closest('.pop-item');
      if (!item) return;
      toCode = item.dataset.code;
      toDd.setValue(toCode);
      convert();
    });

    amountInput.addEventListener('input', convert);

    document.getElementById('swapBtn').addEventListener('click', () => {
      [fromCode, toCode] = [toCode, fromCode];
      fromDd.setValue(fromCode);
      toDd.setValue(toCode);
      fetchRates();
    });

    document.getElementById('reloadBtn').addEventListener('click', () => {
      rates = null;
      fetchRates();
    });

    fetchRates();
  })();
  </script>
</BaseLayout>
