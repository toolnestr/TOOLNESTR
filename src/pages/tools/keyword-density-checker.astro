---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Keyword Density Checker';
const description =
  'Free online keyword density checker. Analyze keyword frequency, density percentage and prominence in any text. Runs in your browser.';
const intro =
  'Paste or type your text below to see keyword frequency, density percentage and prominence analysis for every word.';
const category = { id: 'seo', name: 'SEO Tools' };
const faqs = [
  { q: 'What is keyword density?', a: 'Keyword density is the percentage of times a keyword appears in your content compared to the total word count. It is calculated as (keyword count / total words) x 100.' },
  { q: 'What is the ideal keyword density for SEO?', a: 'Most SEO experts recommend a natural keyword density between 0.5% and 2.5%. Going above 4% may trigger spam filters search engines.' },
  { q: 'What is keyword prominence?', a: 'Keyword prominence measures how early in the text a keyword appears. Words appearing at the beginning of your content or in headings have higher prominence.' },
  { q: 'Is keyword density still important for SEO?', a: 'Yes, but it is not the ranking factor it once was. Search engines now prioritize semantic relevance, user intent and content quality over exact-match density.' },
  { q: 'What happens if my keyword density is too high?', a: 'Excessive keyword density (over 4-5%) can be flagged as keyword stuffing, which may result in a ranking penalty or manual action from search engines.' },
  { q: 'Should I use the same keyword multiple times?', a: 'Use your primary keyword naturally a few times, but also include synonyms, related terms and variations. This improves readability and helps with semantic search.' },
  { q: 'How does this tool calculate prominence?', a: 'Prominence is determined by the position of the first occurrence of a keyword in the text. Earlier appearances score higher prominence.' },
  { q: 'What is a good unique-to-total word ratio?', a: 'A healthy ratio is typically 40-60% unique words. Higher unique word counts suggest richer, more varied content that tends to perform better.' },
  { q: 'Can I use this tool for multiple languages?', a: 'Yes. The tool counts words based on whitespace separation and works with any language that uses spaces between words.' },
  { q: 'Is my text stored or sent anywhere?', a: 'No. Everything runs locally in your browser. Your text never leaves your device.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea
      id="text-input"
      rows="10"
      placeholder="Paste your text here to analyze keyword density..."
      class="w-full resize-y rounded-xl border border-slate-300 p-4 text-base leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>

    <div class="mt-4 flex flex-wrap items-center gap-3">
      <button id="analyze-btn" class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Analyze</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
    </div>

    <div id="stats" class="mt-4 hidden grid-cols-3 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-50 p-3 text-center">
        <div id="stat-total" class="text-xl font-bold text-indigo-700">0</div>
        <div class="text-xs font-medium text-slate-500">Total words</div>
      </div>
      <div class="rounded-xl bg-indigo-50 p-3 text-center">
        <div id="stat-unique" class="text-xl font-bold text-indigo-700">0</div>
        <div class="text-xs font-medium text-slate-500">Unique words</div>
      </div>
      <div class="rounded-xl bg-indigo-50 p-3 text-center">
        <div id="stat-unique-ratio" class="text-xl font-bold text-indigo-700">0%</div>
        <div class="text-xs font-medium text-slate-500">Unique ratio</div>
      </div>
    </div>

    <div id="results" class="mt-4 hidden overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead><tr class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500"><th class="px-4 py-3">Keyword</th><th class="px-4 py-3">Count</th><th class="px-4 py-3">Density %</th><th class="px-4 py-3">Prominence</th></tr></thead>
        <tbody id="results-body" class="divide-y divide-slate-100 text-slate-700"></tbody>
      </table>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How keyword density and prominence are calculated</h2>
    <p class="mt-2 text-slate-600">
      Keyword density measures how often a word appears relative to total word count: <code>Density = (Keyword Count ÷ Total Words) × 100</code>. For example, if the word "SEO" appears 12 times in a 600-word article, its density is (12 ÷ 600) × 100 = 2.0%. This is within the recommended 0.5%–2.5% range for natural optimization.
    </p>
    <p class="mt-3 text-slate-600">
      Prominence scores the earliness of a keyword's first appearance using character position. Words appearing in the first 100 characters get "Highest" prominence; under 500 get "High" or "Medium"; later occurrences score "Low". Search engines give greater weight to keywords that appear early — particularly in the first paragraph, H1, or opening sentences.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 500-word blog post about "content marketing" uses the phrase 14 times:</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Density:</span> <span class="text-slate-600">14 ÷ 500 × 100 = <strong>2.8%</strong> (slightly high — consider reducing)</span></div>
        <div><span class="font-medium text-slate-700">Unique ratio:</span> <span class="text-slate-600">210 unique words ÷ 500 total = <strong>42%</strong> (healthy range 40–60%)</span></div>
        <div><span class="font-medium text-slate-700">Prominence:</span> <span class="text-slate-600">First mention at character 47 = <strong>"Highest"</strong> prominence</span></div>
        <div><span class="font-medium text-slate-700">Target adjustment:</span> <span class="text-slate-600">Replace 3–4 instances with synonyms to bring density to ~2.2%</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different keyword density ranges mean</h2>
    <p class="mt-2 text-slate-600">How your keyword density percentage affects SEO performance.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Under-optimized</span><span class="text-slate-400">&lt; 0.5%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-slate-400" style="width:10%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Natural</span><span class="text-slate-400">0.5% – 2.5%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:40%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Optimized</span><span class="text-slate-400">2.5% – 4%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Over-optimized</span><span class="text-slate-400">&gt; 4%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:20%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F469;&#x200D;&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Writer</h3>
      <p class="mt-1 text-sm text-slate-600">Writes blog posts and landing pages. Uses density analysis to ensure primary keywords appear naturally without over-stuffing, keeping content readable and SEO-friendly.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F50D;</span>
      <h3 class="mt-2 font-semibold text-slate-900">SEO Specialist</h3>
      <p class="mt-1 text-sm text-slate-600">Optimizes existing content for search rankings. Reviews keyword density across pages to identify under-optimized content and adjust targeting.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4DD;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Blogger</h3>
      <p class="mt-1 text-sm text-slate-600">Runs a personal or niche blog. Balances multiple keywords per post to avoid cannibalization and improve topic coverage for better search visibility.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4C4;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Copywriter</h3>
      <p class="mt-1 text-sm text-slate-600">Writes sales copy and ad text. Checks keyword prominence to make sure key terms appear early enough to capture attention and improve ad relevance.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Keyword density guidelines by content type</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-sm">
        <thead><tr class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500"><th class="px-4 py-3">Content type</th><th class="px-4 py-3">Recommended density</th><th class="px-4 py-3">Notes</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <tr><td class="px-4 py-3 font-medium text-slate-900">Blog post</td><td class="px-4 py-3 text-slate-700">0.5 – 2%</td><td class="px-4 py-3 text-slate-500">Focus on readability; use LSI terms</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Product page</td><td class="px-4 py-3 text-slate-700">1 – 3%</td><td class="px-4 py-3 text-slate-500">Short content, tighter density tolerance</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Landing page</td><td class="px-4 py-3 text-slate-700">1 – 2.5%</td><td class="px-4 py-3 text-slate-500">Balance primary and secondary keywords</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">News article</td><td class="px-4 py-3 text-slate-700">0.3 – 1%</td><td class="px-4 py-3 text-slate-500">Low density expected; natural writing style</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Category page</td><td class="px-4 py-3 text-slate-700">1.5 – 3%</td><td class="px-4 py-3 text-slate-500">Multiple related keywords expected</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">White paper</td><td class="px-4 py-3 text-slate-700">0.5 – 1.5%</td><td class="px-4 py-3 text-slate-500">Long-form; avoid repetition</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Keyword Density Checker</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste your content</h3>
        <p class="mt-1 text-sm text-slate-600">Copy any text from your article, blog post or webpage and paste it into the input area.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Click Analyze</h3>
        <p class="mt-1 text-sm text-slate-600">The tool processes every word and returns a table sorted by frequency, with density and prominence scores.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Review and optimize</h3>
        <p class="mt-1 text-sm text-slate-600">Check if your primary keywords fall in the natural range. Adjust usage based on density and prominence data.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for keyword optimization</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Focus on semantic relevance, not exact matches</h3>
        <p class="mt-1 text-sm text-slate-600">Search engines understand synonyms and related concepts. Use LSI (Latent Semantic Indexing) keywords naturally throughout your content instead of repeating the exact same phrase.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Place keywords strategically</h3>
        <p class="mt-1 text-sm text-slate-600">Your primary keyword should appear in the first 100 words, at least one H2 heading, and the meta description. This improves both prominence and relevance signals.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Watch the 4% ceiling</h3>
        <p class="mt-1 text-sm text-slate-600">Density above 4% looks unnatural and may trigger spam filters. If the tool shows high density for your target keyword, replace some instances with pronouns or related terms.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is keyword density?</h2>
    <p class="mt-2 text-slate-600">Keyword density is a metric that shows how often a specific keyword appears in your content relative to the total word count. It is expressed as a percentage. While it was once a primary SEO factor, modern search engines use it as one of many signals alongside content quality, user engagement and backlinks.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Ideal density range</h2>
    <p class="mt-2 text-slate-600">Most SEO professionals agree that a keyword density of 0.5% to 2.5% feels natural to readers and performs well with search engines. For a 1,000-word article, that means using your primary keyword 5 to 25 times. The exact sweet spot depends on your content length, topic and competition.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Prominence explained</h2>
    <p class="mt-2 text-slate-600">Prominence refers to how early and prominently a keyword appears in your content. Keywords in the title, first paragraph, H1 and H2 headings carry more weight. Search engines consider early placement a stronger relevance signal than later mentions.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Over-optimization risks</h2>
    <p class="mt-2 text-slate-600">Keyword stuffing — artificially inflating keyword density beyond natural levels — can harm your rankings. Search engines may penalize pages that appear to prioritize keywords over user experience. Modern algorithms are sophisticated enough to detect manipulation, so always write for humans first.</p>
  </section>

  <script is:inline>
    const input = document.getElementById('text-input');
    const analyzeBtn = document.getElementById('analyze-btn');
    const clearBtn = document.getElementById('clear-btn');
    const resultsDiv = document.getElementById('results');
    const resultsBody = document.getElementById('results-body');
    const statsDiv = document.getElementById('stats');
    const statTotal = document.getElementById('stat-total');
    const statUnique = document.getElementById('stat-unique');
    const statUniqueRatio = document.getElementById('stat-unique-ratio');

    function getWords(text) {
      return text.trim().toLowerCase().split(/\s+/).filter(w => w.length > 0);
    }

    function analyze() {
      const text = input.value.trim();
      if (!text) {
        resultsDiv.classList.add('hidden');
        statsDiv.classList.add('hidden');
        return;
      }

      const words = getWords(text);
      const total = words.length;
      const freq = {};
      words.forEach(w => { freq[w] = (freq[w] || 0) + 1; });

      const entries = Object.entries(freq)
        .map(([word, count]) => ({
          word,
          count,
          density: (count / total) * 100,
          prominence: text.toLowerCase().indexOf(word) + 1,
        }))
        .sort((a, b) => b.count - a.count);

      const unique = entries.length;

      statTotal.textContent = total.toLocaleString();
      statUnique.textContent = unique.toLocaleString();
      statUniqueRatio.textContent = Math.round((unique / total) * 100) + '%';
      statsDiv.classList.remove('hidden');

      resultsBody.innerHTML = entries.map(e =>
        '<tr>' +
          '<td class="px-4 py-3 font-medium text-slate-900">' + escapeHtml(e.word) + '</td>' +
          '<td class="px-4 py-3 text-slate-700">' + e.count + '</td>' +
          '<td class="px-4 py-3 text-slate-700">' + e.density.toFixed(2) + '%</td>' +
          '<td class="px-4 py-3 text-slate-700">' + (e.prominence === 1 ? 'Highest' : e.prominence < 100 ? 'High' : e.prominence < 500 ? 'Medium' : 'Low') + '</td>' +
        '</tr>'
      ).join('');

      resultsDiv.classList.remove('hidden');
    }

    function escapeHtml(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    analyzeBtn.addEventListener('click', analyze);

    clearBtn.addEventListener('click', () => {
      input.value = '';
      resultsDiv.classList.add('hidden');
      statsDiv.classList.add('hidden');
      input.focus();
    });
  </script>
</ToolLayout>
