---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Glove Size Calculator';
const description = 'Find your glove size in numeric and alpha (S/M/L/XL) sizing from hand circumference.';
const intro = 'Convert a hand circumference measurement into numeric and alpha glove sizes.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I measure my hand for gloves?', a: 'Wrap a tape measure around your dominant hand at its widest point, just below the knuckles, not including the thumb. Keep your hand flat and fingers together, and read the measurement in inches.' },
  { q: 'Why do numeric glove sizes look like 8 or 8.5 instead of small/medium/large?', a: 'Numeric glove sizing is the hand circumference in inches itself, rounded to the nearest half inch — the "size" is literally the measurement, which is more precise than a broad alpha category for fitted gloves like dress or driving gloves.' },
  { q: 'Should I measure my dominant or non-dominant hand?', a: 'Measure your dominant hand, since it is typically slightly larger and gloves are usually sold as a matched pair sized to fit both comfortably.' },
  { q: 'Do winter and work gloves size the same as dress gloves?', a: 'Bulkier winter and work gloves often run size charts slightly larger than fitted dress or driving gloves to leave room for insulation or liners, so check the specific product\'s chart when in doubt.' },
];
const howTo = {
  name: 'How to find your glove size',
  steps: [
    { name: 'Measure your hand', text: 'Wrap a tape measure around your dominant hand below the knuckles, excluding the thumb.' },
    { name: 'Enter the circumference', text: 'Type the measurement in inches into the calculator.' },
    { name: 'Read your size', text: 'Your numeric and alpha glove sizes appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Hand circumference (inches)</span>
      <input id="circ" type="number" step="any" placeholder="e.g. 8.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-rose-600 p-3 text-center"><div class="text-sm text-rose-100">Numeric size</div><div id="r-num" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Alpha size</div><div id="r-alpha" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="gsc-title gsc-desc">
      <title id="gsc-title">Hand outline showing where to measure circumference</title>
      <desc id="gsc-desc">An outline of a hand with a dashed line around the palm below the knuckles, showing the glove-sizing measurement point</desc>
      <path d="M340 180 L340 90 Q340 75 352 75 Q364 75 364 90 L364 130 M364 100 Q364 85 376 85 Q388 85 388 100 L388 130 M388 105 Q388 92 400 92 Q412 92 412 105 L412 132 M412 110 Q412 98 424 98 Q436 98 436 110 L436 140 M340 140 Q310 145 300 165 Q295 180 310 190 L440 190 Q460 190 460 165 L460 140 Z" fill="#fecdd3" stroke="#e11d48" stroke-width="2" />
      <line x1="295" y1="150" x2="465" y2="150" stroke="#1e293b" stroke-width="2" stroke-dasharray="6 3" />
      <text x="380" y="205" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Measure around palm, below knuckles</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Glove size is the hand circumference measured just below the knuckles</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How glove sizing works</h2>
    <p class="mt-2 text-slate-600">
      Numeric glove sizing is unusually direct compared to most clothing sizing: the number on the glove is essentially the hand circumference in inches, rounded to the nearest half inch. An 8.5-inch hand circumference is sold as a size 8.5 (or "8½") glove, with no separate arbitrary scale layered on top.
    </p>
    <p class="mt-3 text-slate-600">
      Alpha sizing groups several numeric sizes into broader S/M/L/XL bands for casual and work gloves, where a precise fit matters less than for fitted dress or driving gloves. This calculator shows both, since some retailers only list one or the other.
    </p>
    <p class="mt-3 text-xs text-slate-400">Sizing follows the standard glove-industry convention of circumference-in-inches as the numeric size, cross-checked against common alpha-size groupings published by glove manufacturers.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A tape measure around the palm below the knuckles reads 9 inches.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Circumference:</span> <span class="text-slate-600">9 in</span></div>
        <div><span class="font-medium text-slate-700">Numeric size:</span> <span class="text-slate-600"><strong>9</strong></span></div>
        <div><span class="font-medium text-slate-700">Alpha size:</span> <span class="text-slate-600"><strong>L</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Dress and driving gloves need the tightest fit tolerance of any glove category, since excess material at the fingertips looks visibly wrong and bunches uncomfortably around the steering wheel or a formal cuff — this is exactly the use case numeric sizing was built for, since a half-inch of slack is noticeable at that scale.
    </p>
    <p class="mt-3 text-slate-600">
      Work and safety gloves lean the other way: a slightly loose fit is often preferred for dexterity and to accommodate a liner in cold weather, which is why alpha sizing (with its wider bands) dominates that category instead of precise numeric sizing.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Glove size scales directly with clothing size." <strong class="text-slate-900">No consistent relationship exists.</strong> Hand circumference does not correlate reliably with chest, waist, or shoe size, so glove size has to be measured independently.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A slightly tight glove will stretch to fit over time." <strong class="text-slate-900">Rarely, for most materials.</strong> Leather stretches a little with wear, but most modern glove materials (synthetic, knit, insulated) hold their shape, so buy for your measured size rather than expecting a tight glove to loosen.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/ring-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Ring Size Calculator</a>
      <a href="/tools/hat-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Hat Size Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Clothing Size Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function alphaFor(size) {
      if (size <= 6.5) return 'XXS';
      if (size <= 7) return 'XS';
      if (size <= 7.5) return 'S';
      if (size <= 8.5) return 'M';
      if (size <= 9.5) return 'L';
      if (size <= 10.5) return 'XL';
      return 'XXL';
    }

    function update() {
      const v = parseFloat(el('circ').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const rounded = Math.round(v * 2) / 2;
      el('r-num').textContent = rounded;
      el('r-alpha').textContent = alphaFor(rounded);
      el('results').classList.remove('hidden');
    }

    el('circ').addEventListener('input', update);
  </script>
</ToolLayout>
