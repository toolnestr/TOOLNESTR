---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Sehri & Iftar Time Calculator';
const description = 'Get today’s Sehri (Suhoor) and Iftar times for your city during Ramadan, with selectable calculation methods. Free and accurate prayer-time data.';
const intro = 'Enter your city to get today’s Sehri (Suhoor end) and Iftar times.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'How are Sehri and Iftar times calculated?', a: 'Sehri (Suhoor) ends at the start of Fajr (dawn), and Iftar begins at Maghrib (sunset). Times are computed from your city’s coordinates and the sun’s position using a standard calculation method, fetched from a reliable prayer-times service.' },
  { q: 'Why do calculation methods differ?', a: 'Methods such as ISNA, Muslim World League and Umm al-Qura use slightly different sun-angle conventions for Fajr and Isha, which can change Sehri by a few minutes. Choose the method your local mosque follows.' },
  { q: 'Should I add a precaution margin?', a: 'Many people stop eating a few minutes before the calculated Fajr and break fast right at Maghrib. Following your local mosque’s timetable is the safest approach.' },
  { q: 'Does it work offline?', a: 'No — it fetches the latest times for your city when you search. Once shown, you can note them down. For prayer directions, use our Qibla finder.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">City</span>
        <input id="city" type="text" placeholder="e.g. London" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Country</span>
        <input id="country" type="text" placeholder="e.g. UK" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Method</span>
        <select id="method" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="2">ISNA (North America)</option><option value="3">Muslim World League</option><option value="4">Umm al-Qura (Makkah)</option><option value="1">Karachi</option><option value="5">Egyptian</option><option value="8">Gulf Region</option><option value="12">Union des Org. (France)</option>
        </select></label>
    </div>
    <button id="go" class="mt-4 w-full rounded-xl bg-indigo-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700 sm:w-auto">Get times</button>

    <div id="result" class="mt-6 hidden">
      <div id="r-place" class="text-center text-sm text-slate-500">—</div>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <div class="rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-700 p-5 text-center text-white"><div class="text-2xl">🌙</div><div class="mt-1 text-sm opacity-80">Sehri ends (Fajr)</div><div id="r-sehri" class="mt-1 text-3xl font-bold tabular-nums">—</div></div>
        <div class="rounded-2xl bg-gradient-to-br from-amber-500 to-rose-600 p-5 text-center text-white"><div class="text-2xl">🌅</div><div class="mt-1 text-sm opacity-80">Iftar (Maghrib)</div><div id="r-iftar" class="mt-1 text-3xl font-bold tabular-nums">—</div></div>
      </div>
      <div id="r-all" class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-5"></div>
    </div>
    <p id="status" class="mt-3 hidden text-sm text-slate-500"></p>
    <p id="err" class="mt-3 hidden text-sm text-rose-600"></p>
  </div>

  <figure class="mt-10">
    <svg width="800" height="170" viewBox="0 0 800 170" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="si-title si-desc">
      <title id="si-title">Sun and horizon timeline for Sehri and Iftar</title>
      <desc id="si-desc">A horizon line showing Sehri ending at dawn on the left and Iftar at sunset on the right.</desc>
      <line x1="40" y1="120" x2="760" y2="120" stroke="#cbd5e1" stroke-width="2" />
      <path d="M40 120 Q400 -10 760 120" stroke="#fbbf24" stroke-width="2" stroke-dasharray="5 5" fill="none" />
      <circle cx="120" cy="92" r="16" fill="#a5b4fc" /><text x="120" y="150" text-anchor="middle" font-size="13" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">Sehri / Fajr</text>
      <circle cx="680" cy="92" r="16" fill="#f97316" /><text x="680" y="150" text-anchor="middle" font-size="13" fill="#9a3412" font-family="system-ui,sans-serif" font-weight="bold">Iftar / Maghrib</text>
      <text x="400" y="60" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Fasting hours</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Suhoor ends at dawn (Fajr); the fast is broken at sunset (Maghrib).</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How Sehri and Iftar times are found</h2>
    <p class="mt-2 text-slate-600">During Ramadan, the daily fast begins at Suhoor — the pre-dawn meal that must end before Fajr — and is broken at Iftar, the moment of sunset marked by Maghrib. Both depend on the position of the sun at your location, which is why they shift by a minute or two each day and vary from city to city. This tool fetches today’s accurate Fajr and Maghrib times for the city you enter, so you know exactly when to stop eating and when to break your fast.</p>
    <p class="mt-3 text-slate-600">Enter your city and country, choose the calculation method your community follows, and the tool retrieves the timings from a trusted prayer-times service. It shows Sehri (the Fajr time) and Iftar (the Maghrib time) prominently, along with the full set of daily prayer times for context. Because the data is requested live, you always see up-to-date figures for the current day.</p>
    <p class="mt-3 text-slate-600">Calculation methods differ mainly in the sun angles used for dawn and dusk, which can move Sehri by a few minutes. If you are unsure, pick the method used by your local mosque, and consider stopping Suhoor a couple of minutes early as a precaution. For the start of Ramadan itself, pair this with the Ramadan countdown.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/ramadan-countdown" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Ramadan Countdown</a>
      <a href="/tools/qibla-direction-finder" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Qibla Direction Finder</a>
      <a href="/tools/hijri-date-today" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Today’s Hijri Date</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function show12(t) { if (!t) return '—'; const [h, m] = t.split(':').map(Number); const ap = h >= 12 ? 'PM' : 'AM'; const h12 = ((h + 11) % 12) + 1; return h12 + ':' + String(m).padStart(2, '0') + ' ' + ap; }
    async function getTimes() {
      const city = el('city').value.trim(), country = el('country').value.trim(), method = el('method').value;
      el('err').classList.add('hidden');
      if (!city) { el('err').textContent = 'Please enter a city.'; el('err').classList.remove('hidden'); return; }
      el('status').textContent = 'Fetching times…'; el('status').classList.remove('hidden');
      try {
        const url = 'https://api.aladhan.com/v1/timingsByCity?city=' + encodeURIComponent(city) + '&country=' + encodeURIComponent(country || city) + '&method=' + method;
        const res = await fetch(url);
        const data = await res.json();
        if (!data || data.code !== 200 || !data.data) throw new Error('not found');
        const t = data.data.timings, d = data.data.date;
        el('r-sehri').textContent = show12(t.Fajr);
        el('r-iftar').textContent = show12(t.Maghrib);
        el('r-place').textContent = (city.charAt(0).toUpperCase() + city.slice(1)) + (country ? ', ' + country : '') + ' · ' + (d && d.readable ? d.readable : 'today');
        const order = ['Fajr', 'Sunrise', 'Dhuhr', 'Asr', 'Maghrib', 'Isha'];
        el('r-all').innerHTML = order.map((k) => '<div class="rounded-xl bg-slate-50 p-2 text-center"><div class="text-xs text-slate-500">' + k + '</div><div class="text-sm font-bold text-slate-800">' + show12(t[k]) + '</div></div>').join('');
        el('result').classList.remove('hidden'); el('status').classList.add('hidden');
      } catch (e) {
        el('status').classList.add('hidden');
        el('err').textContent = 'Could not find times for that city. Check the spelling or try adding the country.';
        el('err').classList.remove('hidden');
      }
    }
    el('go').addEventListener('click', getTimes);
    ['city', 'country'].forEach((id) => el(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') getTimes(); }));
  </script>
</ToolLayout>
