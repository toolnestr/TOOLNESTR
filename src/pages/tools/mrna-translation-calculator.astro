---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'mRNA to Protein Translation Tool';
const description = "mRNA to protein translation tool. Translate an mRNA sequence into its amino acid chain using the standard genetic code.";
const intro = 'Enter an mRNA sequence to translate it codon-by-codon into its amino acid chain, starting at AUG and stopping at the first stop codon, using the standard genetic code. Two 3D diagrams show a ribosome reading mRNA and the resulting growing amino acid chain, and charts show codon usage and amino acid properties.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is translation?', a: 'Translation is the process where a ribosome reads an mRNA sequence in three-base codons and assembles the corresponding chain of amino acids, guided by transfer RNA (tRNA) molecules matching each codon.' },
  { q: 'What is the start codon?', a: 'AUG is the universal start codon, marking where translation begins and also coding for the amino acid methionine — nearly every protein starts with a methionine (sometimes later removed).' },
  { q: 'What are stop codons?', a: 'UAA, UAG, and UGA are the three stop codons. They don\'t code for any amino acid — instead, they signal the ribosome to release the finished protein chain and end translation.' },
  { q: 'Why do multiple codons code for the same amino acid?', a: 'The genetic code is described as "degenerate" — with 64 possible codons but only 20 amino acids, many amino acids are specified by more than one codon (often differing only in the third position), which provides some built-in protection against certain mutations.' },
  { q: 'Is the genetic code the same in every organism?', a: 'The standard genetic code is nearly universal across almost all known life, from bacteria to humans — a powerful piece of evidence for the common evolutionary origin of life, though a small number of exceptions exist (like in some mitochondria).' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the mRNA to Protein Translation Tool',
  description: 'Translate an mRNA sequence into its amino acid chain using the standard genetic code.',
  steps: [
    { name: 'Enter the mRNA sequence', text: 'Type a sequence using A, U, C, G — ideally starting with the AUG start codon.' },
    { name: 'Read the amino acid chain', text: 'Codons are translated three at a time until a stop codon is reached.' },
    { name: 'Check individual codons', text: 'Each codon and its corresponding amino acid abbreviation are shown in sequence.' },
  ],
};

const formulas = [
  { expr: 'AUG = start codon (Met)', note: 'marks the beginning of the protein-coding sequence' },
  { expr: 'UAA, UAG, UGA = stop codons', note: 'signal the end of translation, no amino acid added' },
  { expr: '64 codons → 20 amino acids', note: 'the genetic code is degenerate — most amino acids have multiple codons' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a short mRNA with a start and stop codon', tone: 'slate',
    given: "mRNA sequence (5'→3'): AUG GCC UAG",
    rows: [
      { label: 'Codon 1:', value: 'AUG → Met (start)' },
      { label: 'Codon 2:', value: 'GCC → Ala' },
      { label: 'Codon 3:', value: 'UAG → Stop (translation ends here)' },
      { label: 'Resulting protein:', value: 'Met-Ala (a 2-amino-acid chain)', full: true },
    ],
    note: 'The stop codon (UAG) is never translated into an amino acid — it simply signals the ribosome to release the finished chain.',
  },
  {
    title: 'Worked example 2 — a longer coding sequence', tone: 'amber',
    given: "mRNA sequence (5'→3'): AUG UUU CCG AAA UAA",
    rows: [
      { label: 'Codon 1:', value: 'AUG → Met (start)' },
      { label: 'Codon 2:', value: 'UUU → Phe' },
      { label: 'Codon 3:', value: 'CCG → Pro' },
      { label: 'Codon 4:', value: 'AAA → Lys' },
      { label: 'Codon 5:', value: 'UAA → Stop' },
      { label: 'Resulting protein:', value: 'Met-Phe-Pro-Lys (a 4-amino-acid chain)', full: true },
    ],
    note: 'Reading frame matters enormously here — starting translation even one base off from the true AUG would produce a completely different, usually non-functional, sequence of codons.',
  },
];

const comparison = {
  heading: 'Sample codons and their amino acids',
  note: 'Notice how several different codons can code for the very same amino acid — a feature called degeneracy.',
  headers: [{ label: 'Codon' }, { label: 'Amino acid' }, { label: 'Notes' }],
  rows: [
    ['AUG ★', 'Methionine (Met)', 'Start codon'],
    ['UUU, UUC', 'Phenylalanine (Phe)', 'Two codons, same amino acid'],
    ['CGU, CGC, CGA, CGG, AGA, AGG', 'Arginine (Arg)', 'Six codons — the most degenerate amino acid'],
    ['UAA, UAG, UGA', 'None (stop)', 'End translation'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (both worked examples). AUG is unique in serving double duty as both the start signal and the codon for methionine.',
};

const realWorld = [
  { emoji: '💊', title: 'Understanding how mutations affect proteins', body: 'Translating a mutated mRNA sequence reveals exactly how a DNA change (like a single base substitution) alters the resulting protein — sometimes silently (same amino acid), sometimes catastrophically (a premature stop codon).' },
  { emoji: '🧬', title: 'Protein engineering and synthetic biology', body: 'Researchers designing synthetic genes must carefully choose codons to produce a desired amino acid sequence, sometimes optimizing codon usage for efficient expression in a particular host organism.' },
  { emoji: '🔬', title: 'Diagnosing genetic diseases', body: 'Many genetic diseases stem directly from mutations that introduce a premature stop codon or change a critical amino acid — translating the mutated sequence is often the key diagnostic step.' },
  { emoji: '🎓', title: 'Teaching the central dogma of molecular biology', body: 'Translation is the final step of the central dogma (DNA→RNA→protein), completing students\' understanding of how genetic information becomes a functional molecule.' },
];

const misconceptions = [
  { claim: '"Every three-letter combination is a valid, meaningful codon that produces a unique amino acid."', truth: 'While every possible 3-base combination IS technically a codon, 3 of the 64 (UAA, UAG, UGA) are stop signals producing no amino acid at all, and most amino acids share their codon with several others due to the code\'s degeneracy.' },
  { claim: '"Translation can start at any AUG found anywhere in an mRNA."', truth: "In reality, ribosomes typically scan for and initiate at the FIRST appropriately-positioned AUG in the correct context (with help from surrounding sequence signals) — not simply any AUG that happens to appear anywhere in the transcript." },
  { claim: '"A single DNA mutation always changes the resulting protein."', truth: 'Because the genetic code is degenerate, some mutations (called silent mutations) change a codon to a different one that still codes for the exact same amino acid — the DNA changes, but the resulting protein sequence does not.' },
  { claim: '"Translation and transcription happen in the same location in all cells."', truth: "In eukaryotic cells, transcription happens in the nucleus and translation happens afterward in the cytoplasm at ribosomes — they are physically separated. In prokaryotic cells (with no nucleus), both processes can actually happen simultaneously in the same location." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 15, "Genes and Proteins" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/15-4-translation" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Chapter 6, How Cells Read the Genome: From DNA to Protein.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 17, Gene Expression: From Gene to Protein.' },
];
const sourcesNote = 'Uses the standard genetic code (NCBI translation table 1). Input should use only A, U, C, G. Translation stops at the first in-frame stop codon.';

const howToUse = [
  { title: 'Enter the mRNA sequence', body: "Type a sequence of A, U, C, G bases, ideally beginning with AUG." },
  { title: 'Read the amino acid chain', body: 'The translated protein sequence (as 3-letter amino acid codes) appears instantly.' },
  { title: 'Check the codon breakdown', body: 'Every individual codon and its amino acid is listed in translation order.' },
];

const related = [
  { href: '/tools/dna-transcription-calculator', emoji: '🧬', title: 'DNA to mRNA Transcription Tool', desc: 'Convert a DNA template strand into mRNA.' },
  { href: '/tools/gc-content-calculator', emoji: '🔬', title: 'GC Content Calculator', desc: 'GC% = (G+C)/total bases × 100.' },
  { href: '/tools/codon-usage-calculator', emoji: '📊', title: 'Codon Usage Calculator', desc: 'Analyze codon frequency in a coding sequence.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a ribosome reads mRNA three bases at a time, and each of those non-overlapping three-base 'words' (codons) unambiguously specifies exactly one amino acid to add next — or a stop signal to end the chain — so the entire genetic code boils down to a fixed 64-entry lookup table."
  howIntro="Because there are 4 possible RNA bases and codons are read 3 at a time, there are exactly 4³=64 possible codons — more than enough to uniquely specify the 20 standard amino acids, with room to spare for redundancy and for dedicated start/stop signals. Translation begins by locating the start codon (AUG), then the ribosome reads each subsequent non-overlapping triplet, matching it against the standard genetic code table to add the corresponding amino acid to the growing chain, continuing until a stop codon (UAA, UAG, or UGA) is reached and the finished protein is released."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where mRNA translation actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">mRNA sequence (5'→3'), letters A/U/C/G only</span>
      <input id="mrna" type="text" value="AUGUUUCCGAAAUAA" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Amino acid chain</div>
      <div id="r-protein" class="mt-1 break-all font-mono text-lg font-bold">—</div>
    </div>
    <div class="mt-3 rounded-xl border border-slate-100 bg-slate-50 p-4">
      <div class="text-xs text-slate-500">Codon-by-codon breakdown</div>
      <div id="r-codons" class="mt-1 break-all font-mono text-sm text-slate-700">—</div>
    </div>
    <p id="tl-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Ribosome and growing protein chain</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-ribosome" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A ribosome reading mRNA</h3>
          <p class="mt-1 text-sm text-slate-600">The large ribosomal structure (indigo) reads an mRNA strand (colored beads) three bases at a time.</p>
        </div>
        <div>
          <div id="diag-chain" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. The growing amino acid chain</h3>
          <p class="mt-1 text-sm text-slate-600">Each amino acid (amber sphere) links to the next, forming the polypeptide chain that will become the finished protein.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Translation graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Codons per amino acid (degeneracy) for select amino acids</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-degeneracy"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Codon count in this example sequence</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-usage"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const CODE = {
        UUU: 'Phe', UUC: 'Phe', UUA: 'Leu', UUG: 'Leu', CUU: 'Leu', CUC: 'Leu', CUA: 'Leu', CUG: 'Leu',
        AUU: 'Ile', AUC: 'Ile', AUA: 'Ile', AUG: 'Met', GUU: 'Val', GUC: 'Val', GUA: 'Val', GUG: 'Val',
        UCU: 'Ser', UCC: 'Ser', UCA: 'Ser', UCG: 'Ser', CCU: 'Pro', CCC: 'Pro', CCA: 'Pro', CCG: 'Pro',
        ACU: 'Thr', ACC: 'Thr', ACA: 'Thr', ACG: 'Thr', GCU: 'Ala', GCC: 'Ala', GCA: 'Ala', GCG: 'Ala',
        UAU: 'Tyr', UAC: 'Tyr', UAA: 'Stop', UAG: 'Stop', CAU: 'His', CAC: 'His', CAA: 'Gln', CAG: 'Gln',
        AAU: 'Asn', AAC: 'Asn', AAA: 'Lys', AAG: 'Lys', GAU: 'Asp', GAC: 'Asp', GAA: 'Glu', GAG: 'Glu',
        UGU: 'Cys', UGC: 'Cys', UGA: 'Stop', UGG: 'Trp', CGU: 'Arg', CGC: 'Arg', CGA: 'Arg', CGG: 'Arg',
        AGU: 'Ser', AGC: 'Ser', AGA: 'Arg', AGG: 'Arg', GGU: 'Gly', GGC: 'Gly', GGA: 'Gly', GGG: 'Gly',
      };

      function translate(seq) {
        const codons = [];
        const aminos = [];
        for (let i = 0; i + 3 <= seq.length; i += 3) {
          const codon = seq.slice(i, i + 3);
          const aa = CODE[codon];
          if (!aa) break;
          codons.push(codon);
          if (aa === 'Stop') { aminos.push('Stop'); break; }
          aminos.push(aa);
        }
        return { codons, aminos };
      }
      function update() {
        el('tl-err').textContent = '';
        const raw = (el('mrna').value || '').toUpperCase().replace(/[^AUCG]/g, '');
        el('mrna').value = el('mrna').value.toUpperCase();
        if (!raw) { el('r-protein').textContent = '—'; el('r-codons').textContent = '—'; return; }
        const { codons, aminos } = translate(raw);
        const proteinChain = aminos.filter((a) => a !== 'Stop');
        el('r-protein').textContent = proteinChain.length ? proteinChain.join('-') : '—';
        el('r-codons').textContent = codons.map((c, i) => c + '=' + aminos[i]).join(', ') || '—';
      }
      el('mrna').addEventListener('input', update);

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.degeneracy = new Chart(el('chart-degeneracy'), {
          type: 'bar',
          data: { labels: ['Met', 'Trp', 'Phe', 'Lys', 'Ala', 'Ser', 'Leu', 'Arg'], datasets: [{ label: 'Number of codons', data: [1, 1, 2, 2, 4, 6, 6, 6], backgroundColor: '#6366f1' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Number of codons' } } }, plugins: { legend: { display: false } } }),
        });
        const { codons } = translate('AUGUUUCCGAAAUAA');
        const counts = {};
        codons.forEach((c) => (counts[c] = (counts[c] || 0) + 1));
        charts.usage = new Chart(el('chart-usage'), {
          type: 'bar',
          data: { labels: Object.keys(counts), datasets: [{ label: 'Occurrences', data: Object.values(counts), backgroundColor: '#f59e0b' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Occurrences' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function ribosomeScene(container) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const ribo = new THREE.Mesh(new THREE.SphereGeometry(1.4, 24, 20), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.5, transparent: true, opacity: 0.55 }));
        s.scene.add(ribo);
        const colors = [0x6366f1, 0xa855f7, 0xef4444, 0xf59e0b, 0x10b981];
        for (let i = 0; i < 8; i++) {
          const b = new THREE.Mesh(new THREE.SphereGeometry(0.24, 12, 10), new THREE.MeshStandardMaterial({ color: colors[i % colors.length] }));
          b.position.set((i - 3.5) * 0.6, -2, 0);
          s.scene.add(b);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function chainScene(container) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < 5; i++) {
          const aa = new THREE.Mesh(new THREE.SphereGeometry(0.4, 16, 14), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.4 }));
          aa.position.set((i - 2) * 0.9, Math.sin(i * 0.8) * 0.4, 0);
          s.scene.add(aa);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagRibosome = null, diagChain = null;
      function initDiagRibosome() { const c = el('diag-ribosome'); if (!c) throw new Error('no container'); diagRibosome = ribosomeScene(c); }
      function initDiagChain() { const c = el('diag-chain'); if (!c) throw new Error('no container'); diagChain = chainScene(c); }

      function boot() {
        try { update(); } catch (e) { console.error('[mrna-translation] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[mrna-translation] charts failed', e); }
        if (window.THREE) {
          try { initDiagRibosome(); } catch (e) { console.error('[mrna-translation] ribosome diagram failed', e); }
          try { initDiagChain(); } catch (e) { console.error('[mrna-translation] chain diagram failed', e); }
        }
        mountResize([diagRibosome, diagChain]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
