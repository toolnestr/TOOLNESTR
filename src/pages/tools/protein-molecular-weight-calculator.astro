---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Protein Molecular Weight Calculator';
const description = "Protein molecular weight calculator. Solve total protein mass from an amino acid sequence by summing residue masses, with worked examples.";
const intro = 'Solve a protein\'s molecular weight by summing the average residue mass of every amino acid in its sequence, then adding back one water molecule for the chain\'s two free ends. Two 3D diagrams compare a short peptide chain to a long one, and charts show how molecular weight builds up as a chain grows and how residue mass varies across amino acids.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'How is protein molecular weight calculated from a sequence?', a: 'Sum the average residue mass of every amino acid in the sequence, then add 18.02 Da (one water molecule) to account for the free amino and carboxyl groups at the two ends of the finished chain.' },
  { q: 'Why is water added back at the end?', a: "Standard residue mass tables already subtract one water molecule per amino acid to account for the water lost when each peptide bond forms during protein synthesis — adding one water back at the end restores the mass of the two terminal groups that never lost their water in the first place." },
  { q: 'Why do different amino acids have different residue masses?', a: "Residue mass depends entirely on the size and composition of each amino acid's side chain (R group) — small amino acids like glycine have a residue mass around 57 Da, while large ones like tryptophan reach about 186 Da." },
  { q: 'Is this the exact same molecular weight reported by mass spectrometry?', a: "This calculation gives the average (not monoisotopic) molecular weight, and doesn't account for post-translational modifications like phosphorylation or glycosylation — real proteins measured by mass spectrometry can differ from this sequence-only estimate for exactly those reasons." },
  { q: 'Does protein molecular weight relate to gene/DNA length?', a: "Yes — since each amino acid is encoded by a 3-base codon, a protein's amino acid count (and therefore roughly its molecular weight) scales directly with the length of its coding DNA sequence, though untranslated regions and introns don't contribute to protein length." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Protein Molecular Weight Calculator',
  description: 'Solve total protein molecular weight by summing residue masses across an amino acid sequence.',
  steps: [
    { name: 'Enter a protein sequence', text: 'Type a sequence using standard one-letter amino acid codes.' },
    { name: 'Read the molecular weight', text: 'Total mass in Daltons calculates instantly, along with the amino acid composition.' },
  ],
};

const formulas = [
  { expr: 'MW = Σ(residue masses) + 18.02', note: '18.02 Da (one water molecule) restores the mass of the chain\'s two free ends' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a short tripeptide', tone: 'slate',
    given: 'The tripeptide Ala-Gly-Ser (A-G-S).',
    rows: [
      { label: 'Residue masses:', value: 'Ala=71.08, Gly=57.05, Ser=87.08' },
      { label: 'Sum:', value: '71.08 + 57.05 + 87.08 = 215.21' },
      { label: 'Result:', value: 'MW = 215.21 + 18.02 = 233.23 Da', full: true },
    ],
    note: 'Even a tiny 3-residue peptide already shows the pattern — every additional amino acid adds its own residue mass directly to the running total.',
  },
  {
    title: 'Worked example 2 — a four-residue peptide with larger side chains', tone: 'amber',
    given: 'The tetrapeptide Met-Lys-Val-Leu (M-K-V-L).',
    rows: [
      { label: 'Residue masses:', value: 'Met=131.19, Lys=128.17, Val=99.13, Leu=113.16' },
      { label: 'Sum:', value: '131.19 + 128.17 + 99.13 + 113.16 = 471.65' },
      { label: 'Result:', value: 'MW = 471.65 + 18.02 = 489.67 Da', full: true },
    ],
    note: 'Despite having only one more residue than the first example, this peptide is noticeably heavier — its amino acids simply have larger side chains, illustrating that molecular weight depends on composition, not just chain length.',
  },
];

const comparison = {
  heading: 'Residue mass range across amino acids',
  note: 'Residue mass depends entirely on side chain size.',
  headers: [{ label: 'Amino acid' }, { label: 'Residue mass (Da)' }, { label: 'Side chain size' }],
  rows: [
    ['Glycine (G) ★', '57.05', 'Smallest (just an H)'],
    ['Alanine (A)', '71.08', 'Small (methyl group)'],
    ['Leucine (L)', '113.16', 'Medium (branched)'],
    ['Tryptophan (W)', '186.21', 'Largest (bicyclic ring)'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row. Glycine\'s minimal side chain (a single hydrogen atom) makes it both the smallest and most structurally flexible amino acid.',
};

const realWorld = [
  { emoji: '🧬', title: 'Mass spectrometry protein identification', body: "Comparing a measured protein's molecular weight against sequence-predicted values is a standard first check in proteomics for confirming protein identity and detecting modifications." },
  { emoji: '💊', title: 'Therapeutic protein and antibody development', body: "Molecular weight is a fundamental quality-control specification for biologic drugs (like antibody therapeutics), verified at every manufacturing stage against the sequence-predicted value." },
  { emoji: '🔬', title: 'Gel electrophoresis (SDS-PAGE) interpretation', body: "Predicted molecular weight from a protein's sequence lets researchers identify which band on an SDS-PAGE gel corresponds to their protein of interest." },
  { emoji: '🧪', title: 'Recombinant protein expression', body: 'Researchers cloning and expressing a new recombinant protein calculate its expected molecular weight in advance to confirm successful expression and correct size on later analysis.' },
];

const misconceptions = [
  { claim: '"Protein molecular weight is just the sum of the free amino acid weights."', truth: "Simply adding up free amino acid weights overcounts the mass — each peptide bond formed during protein synthesis releases one water molecule, so residue masses (which already account for this) must be used instead, with only one water added back at the very end." },
  { claim: '"Two proteins with the same number of amino acids always have similar molecular weights."', truth: "Molecular weight depends heavily on amino acid composition, not just chain length — a chain rich in large amino acids (like tryptophan) will be substantially heavier than an equally long chain rich in small ones (like glycine)." },
  { claim: '"Sequence-based molecular weight calculations always match experimentally measured values exactly."', truth: "Real, mature proteins often carry post-translational modifications (phosphate groups, sugar chains, cleaved signal sequences) that change their actual mass from the simple sequence-based prediction — the calculated value is a starting-point estimate, not always the final word." },
  { claim: '"Molecular weight tells you everything about a protein\'s size and shape."', truth: 'Molecular weight only measures total mass — it says nothing about a protein\'s 3D shape, whether it exists as multiple subunits bound together, or how compactly it folds, all of which matter for a protein\'s actual physical size and function.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 3, "Biological Macromolecules" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/3-4-proteins" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>ExPASy (Swiss Institute of Bioinformatics)</strong> — standard reference amino acid residue masses.' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Protein structure fundamentals chapter.' },
];
const sourcesNote = 'MW = Σ(residue masses) + 18.02 Da. Uses standard average (not monoisotopic) residue masses. Does not account for post-translational modifications. Results are rounded for display.';

const howToUse = [
  { title: 'Enter a protein sequence', body: 'Type the sequence using standard one-letter amino acid codes (A, R, N, D, C, etc.).' },
  { title: 'Read molecular weight', body: 'Total mass in Daltons calculates instantly from the sequence.' },
  { title: 'Check composition', body: 'The amino acid breakdown chart shows which residues contribute most to the total mass.' },
];

const related = [
  { href: '/tools/amino-acid-sequence-analyzer', emoji: '🧬', title: 'Amino Acid Sequence Analyzer', desc: 'Composition, hydrophobicity, and charge from a sequence.' },
  { href: '/tools/mrna-translation-calculator', emoji: '🧩', title: 'mRNA to Protein Translation Tool', desc: 'Translate mRNA codons into an amino acid chain.' },
  { href: '/tools/atomic-weight-calculator', emoji: '🔶', title: 'Atomic Mass Calculator', desc: 'Look up an element\'s standard atomic weight.' },
];

// [1-letter code, 3-letter, residue mass Da]
const aminoAcids = [
  ['G','Gly',57.05],['A','Ala',71.08],['S','Ser',87.08],['P','Pro',97.12],['V','Val',99.13],
  ['T','Thr',101.10],['C','Cys',103.14],['L','Leu',113.16],['I','Ile',113.16],['N','Asn',114.10],
  ['D','Asp',115.09],['Q','Gln',128.13],['K','Lys',128.17],['E','Glu',129.12],['M','Met',131.19],
  ['H','His',137.14],['F','Phe',147.18],['R','Arg',156.19],['Y','Tyr',163.18],['W','Trp',186.21],
];
const aaJson = JSON.stringify(aminoAcids);
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a protein's total weight is simply the sum of its building blocks' weights, with one small correction for the water molecule chemistry removes every time two amino acids link together — and adds back only once, at the very ends of the finished chain."
  howIntro="Every time two amino acids join to form a peptide bond, the cell removes one water molecule as a byproduct — so a chain's individual amino acid residues each weigh slightly less than their free, unlinked form. Standard residue mass tables already account for this loss, which means summing residue masses across an entire sequence, then adding exactly one water molecule back (18.02 Da, for the chain's two untouched terminal ends), gives the finished protein's true molecular weight directly from its sequence alone."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where protein molecular weight actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Protein sequence (one-letter codes)</span>
      <textarea id="seq" rows="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">MKVL</textarea></label>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Molecular weight</div><div id="r-mw" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Residue count</div><div id="r-count" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Average residue mass</div><div id="r-avg" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="pmw-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Short vs. long peptide chain</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-short" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Short peptide</h3>
          <p class="mt-1 text-sm text-slate-600">Few residues linked together — a low total molecular weight.</p>
        </div>
        <div>
          <div id="diag-long" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Long polypeptide</h3>
          <p class="mt-1 text-sm text-slate-600">Many residues linked together — a much higher total molecular weight.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Molecular weight charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Residue mass by amino acid</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-residues"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Cumulative molecular weight along your sequence</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-cumulative"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline define:vars={{ aaJson }}>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const aminoAcids = JSON.parse(aaJson);
      const massMap = {};
      aminoAcids.forEach(([code, , mass]) => { massMap[code] = mass; });
      let charts = {};

      function update() {
        el('pmw-err').textContent = '';
        el('r-mw').textContent = '—'; el('r-count').textContent = '—'; el('r-avg').textContent = '—';
        const seq = (el('seq').value || '').toUpperCase().replace(/[^A-Z]/g, '');
        if (!seq) return;
        let sum = 0, cumulative = [];
        for (const c of seq) {
          if (!massMap[c]) { el('pmw-err').textContent = 'Unrecognized amino acid code: ' + c; return; }
          sum += massMap[c];
          cumulative.push(sum + 18.02);
        }
        const mw = sum + 18.02;
        el('r-mw').textContent = mw.toFixed(2) + ' Da';
        el('r-count').textContent = String(seq.length);
        el('r-avg').textContent = (sum / seq.length).toFixed(2) + ' Da';
        updateCumulative(seq, cumulative);
      }
      el('seq').addEventListener('input', update);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.residues = new Chart(el('chart-residues'), {
          type: 'bar',
          data: { labels: aminoAcids.map((a) => a[0]), datasets: [{ label: 'Residue mass (Da)', data: aminoAcids.map((a) => a[2]), backgroundColor: '#6366f1' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Residue mass (Da)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.cumulative = new Chart(el('chart-cumulative'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Cumulative MW (Da)', data: [], borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.1, pointRadius: 2 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Residue position' } }, y: { title: { display: true, text: 'Cumulative MW (Da)' } } }, plugins: { legend: { display: false } } }),
        });
      }
      function updateCumulative(seq, cumulative) {
        if (!charts.cumulative) return;
        charts.cumulative.data.labels = seq.split('').map((c, i) => (i + 1) + c);
        charts.cumulative.data.datasets[0].data = cumulative;
        charts.cumulative.update('none');
      }

      function chainScene(container, count) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const positions = [];
        for (let i = 0; i < count; i++) positions.push(new THREE.Vector3((i - count / 2) * 0.8, Math.sin(i * 0.8) * 0.5, 0));
        const geo = new THREE.BufferGeometry().setFromPoints(positions);
        s.scene.add(new THREE.Line(geo, new THREE.LineBasicMaterial({ color: 0x94a3b8 })));
        positions.forEach((p) => {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.28, 14, 12), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          sph.position.copy(p);
          s.scene.add(sph);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagShort = null, diagLong = null;
      function initDiagShort() { const c = el('diag-short'); if (!c) throw new Error('no container'); diagShort = chainScene(c, 4); }
      function initDiagLong() { const c = el('diag-long'); if (!c) throw new Error('no container'); diagLong = chainScene(c, 10); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[protein-mw] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagShort(); } catch (e) { console.error('[protein-mw] short diagram failed', e); }
          try { initDiagLong(); } catch (e) { console.error('[protein-mw] long diagram failed', e); }
        }
        mountResize([diagShort, diagLong]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
