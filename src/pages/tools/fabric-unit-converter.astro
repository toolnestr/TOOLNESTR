---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fabric Unit Converter';
const description = 'Convert fabric length between yards, meters, inches, and centimeters instantly.';
const intro = 'Convert a fabric length between yards, meters, inches, and centimeters.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why do fabric retailers use different units in different countries?', a: 'The US and UK traditionally sell fabric by the yard, while most of continental Europe, Asia, and Australia sell by the meter — both are legitimate length units, they simply come from different historical measurement systems (imperial and metric).' },
  { q: 'Is a meter longer than a yard?', a: 'Yes, a meter (39.37 inches) is slightly longer than a yard (36 inches) — about 9.4% longer — so 1 yard of fabric is not quite the same as 1 meter, and treating them as interchangeable without converting will leave you short.' },
  { q: 'How precise is this conversion?', a: 'This uses the exact international definitions: 1 yard = 0.9144 meters exactly, and 1 inch = 2.54 centimeters exactly, so results are precise to the decimal places shown, not approximations.' },
  { q: 'Should I round up when converting for a purchase?', a: 'Yes — when converting a required length into the unit your retailer sells in, round up to the next practical increment (often the nearest quarter yard or 10cm) rather than buying the exact converted decimal, since most retailers sell in fixed increments anyway.' },
];
const howTo = {
  name: 'How to convert fabric length units',
  steps: [
    { name: 'Enter a length', text: 'Type the fabric length you want to convert.' },
    { name: 'Choose the starting unit', text: 'Select whether you entered yards, meters, inches, or centimeters.' },
    { name: 'Read all four conversions', text: 'The equivalent length in every other unit appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length</span>
        <input id="value" type="number" step="any" placeholder="e.g. 3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <div>
        <span class="text-sm font-medium text-slate-700">Unit</span>
        <select id="unit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100">
          <option value="yd">Yards</option>
          <option value="m">Meters</option>
          <option value="in">Inches</option>
          <option value="cm">Centimeters</option>
        </select>
      </div>
    </div>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-rose-600 p-3 text-center"><div class="text-sm text-rose-100">Yards</div><div id="r-yd" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Meters</div><div id="r-m" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Inches</div><div id="r-in" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Centimeters</div><div id="r-cm" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="160" viewBox="0 0 800 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fuc-title fuc-desc">
      <title id="fuc-title">Ruler showing yards, meters, inches and centimeters aligned</title>
      <desc id="fuc-desc">A ruler-style bar comparing yard and meter tick marks to show a meter is slightly longer than a yard</desc>
      <line x1="80" y1="80" x2="720" y2="80" stroke="#94a3b8" stroke-width="3" />
      <line x1="80" y1="65" x2="80" y2="95" stroke="#e11d48" stroke-width="3" />
      <text x="80" y="55" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">0</text>
      <line x1="620" y1="65" x2="620" y2="95" stroke="#e11d48" stroke-width="3" />
      <text x="620" y="55" text-anchor="middle" font-size="13" fill="#e11d48" font-family="system-ui,sans-serif">1 yard</text>
      <line x1="660" y1="70" x2="660" y2="90" stroke="#94a3b8" stroke-width="3" />
      <text x="660" y="115" text-anchor="middle" font-size="13" fill="#94a3b8" font-family="system-ui,sans-serif">1 meter</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A meter is about 9.4% longer than a yard</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fabric unit conversion works</h2>
    <p class="mt-2 text-slate-600">
      This converter uses the exact international unit definitions rather than rounded approximations: one yard equals precisely 0.9144 meters, and one inch equals precisely 2.54 centimeters. From those two fixed constants, every other conversion (yards to inches, meters to centimeters, and so on) follows directly through simple multiplication or division.
    </p>
    <p class="mt-3 text-slate-600">
      For sewing and fabric shopping specifically, the yard-versus-meter distinction matters most: since a meter is about 9.4% longer than a yard, buying "3" of a fabric priced by the meter gives you noticeably more length than buying "3" of the same fabric priced by the yard — always check which unit a listing uses before comparing prices or planning yardage.
    </p>
    <p class="mt-3 text-xs text-slate-400">Conversion factors use the internationally defined yard (0.9144 m) and inch (2.54 cm), both exact by definition, not rounded approximations.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A pattern calls for 3 yards of fabric, but the only listing available is priced by the meter.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">3 yards in meters:</span> <span class="text-slate-600">3 × 0.9144 = <strong>2.74 m</strong></span></div>
        <div><span class="font-medium text-slate-700">3 yards in inches:</span> <span class="text-slate-600">3 × 36 = <strong>108 in</strong></span></div>
        <div><span class="font-medium text-slate-700">3 yards in centimeters:</span> <span class="text-slate-600">108 × 2.54 = <strong>274.3 cm</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Following a pattern from a different country than your local fabric shop is the most direct trigger for this conversion — a US pattern written in yards but shopping at a European or Australian fabric retailer that sells by the meter means converting the pattern's yardage requirement before placing an order, or risking buying noticeably too little.
    </p>
    <p class="mt-3 text-slate-600">
      International sewing pattern communities and online fabric marketplaces increasingly mix both units in the same listings and discussions, so a quick, precise converter avoids the common mental-math shortcut of treating a yard and a meter as roughly the same length, which compounds into a real shortfall on a multi-yard project.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A yard and a meter are close enough to treat as the same." <strong class="text-slate-900">Not for larger projects.</strong> The 9.4% difference seems small per unit, but on a project needing several yards or meters, that gap adds up to a real fabric shortfall if the units are mixed up.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Fabric width and fabric length use the same unit system on a given bolt." <strong class="text-slate-900">Not always.</strong> Some listings state width in inches while pricing length in meters, or vice versa, so check both figures independently rather than assuming one unit applies to the whole listing.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Yardage Calculator</a>
      <a href="/tools/fabric-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Cost Calculator</a>
      <a href="/tools/yards-to-meters" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Yards to Meters Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const v = parseFloat(el('value').value);
      const unit = el('unit').value;
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      let inches;
      if (unit === 'yd') inches = v * 36;
      else if (unit === 'm') inches = (v / 2.54) * 100;
      else if (unit === 'in') inches = v;
      else inches = v / 2.54;

      const yd = inches / 36;
      const m = (inches * 2.54) / 100;
      const cm = inches * 2.54;

      el('r-yd').textContent = yd.toFixed(3) + ' yd';
      el('r-m').textContent = m.toFixed(3) + ' m';
      el('r-in').textContent = inches.toFixed(2) + ' in';
      el('r-cm').textContent = cm.toFixed(2) + ' cm';
      el('results').classList.remove('hidden');
    }

    el('value').addEventListener('input', update);
    el('unit').addEventListener('change', update);
  </script>
</ToolLayout>
