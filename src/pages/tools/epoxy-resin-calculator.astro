---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Epoxy Resin Calculator';
const description = 'Find how much epoxy resin you need to pour a tabletop, river table or floor coating from the surface area and pour depth, in fluid ounces and gallons.';
const intro = 'Find how much epoxy resin you need for a pour, from the surface area and depth.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate how much epoxy resin I need?', a: 'Multiply the surface area by the pour depth to get the volume, then convert to fluid ounces: 1 cubic inch equals about 0.554 fluid ounces. A 24×36 in tabletop poured 1/8 inch deep: 864 in² × 0.125 in = 108 in³ × 0.554 ≈ 60 fl oz.' },
  { q: 'What is the maximum pour depth for epoxy resin?', a: 'Standard "table top" epoxy is usually limited to about 1/8 to 1/4 inch per pour to avoid excess heat buildup during curing, which can cause cracking, yellowing, or clouding. Deep-pour epoxy formulations, designed for thick single pours, can go up to 1-2 inches or more in one layer — check your specific product\'s rated maximum depth.' },
  { q: 'Do I need multiple pours for a thick coating?', a: 'Yes, if using standard tabletop epoxy for a thick pour. Multiple thin layers, each allowed to cure before the next, avoid the heat and shrinkage problems of one deep pour. Deep-pour epoxy is formulated specifically to avoid this and can often go in one pour.' },
  { q: 'How much extra epoxy should I buy?', a: 'A common practice is buying 10-15% extra to account for mixing loss (resin left in cups and mixing sticks), uneven surfaces, and drips over the edge. This calculator applies a default 10% overage, which you can adjust.' },
];
const howTo = {
  name: 'How to calculate how much epoxy resin you need',
  steps: [
    { name: 'Measure the surface', text: 'Measure the length and width of the surface in inches.' },
    { name: 'Set the pour depth', text: 'Check that it is within your epoxy product\'s rated maximum depth.' },
    { name: 'Buy with overage', text: 'Add 10-15% extra for mixing loss on cups and stir sticks.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (in)</span>
        <input id="len" type="number" step="any" placeholder="36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (in)</span>
        <input id="width" type="number" step="any" placeholder="24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pour depth (in)</span>
        <input id="depth" type="number" step="any" placeholder="0.125" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Overage (%)</span>
        <input id="overage" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Epoxy needed</div>
        <div id="r-oz" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic inches</div><div id="r-cin" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">In gallons</div><div id="r-gal" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl p-3 text-center" id="r-depth-box"><div class="text-sm text-slate-500">Depth check</div><div id="r-depthcheck" class="mt-1 text-lg font-bold">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="er-title er-desc">
      <title id="er-title">Epoxy pour volume formula</title>
      <desc id="er-desc">A tabletop with a thin epoxy layer and the volume-to-ounces formula</desc>
      <rect x="80" y="90" width="220" height="60" fill="#78350f" stroke="#451a03" stroke-width="1.5" />
      <rect x="80" y="82" width="220" height="10" fill="#fef3c7" opacity="0.85" stroke="#d97706" stroke-width="1" />
      <text x="190" y="175" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">thin epoxy layer over the surface</text>
      <rect x="420" y="55" width="330" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Epoxy volume</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">in&sup3; = L &times; W &times; depth</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">fl oz = in&sup3; &times; 0.554</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Standard tabletop epoxy is poured in thin layers to avoid excess cure heat.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the epoxy resin calculator works</h2>
    <p class="mt-2 text-slate-600">
      Epoxy resin volume follows straightforward geometry: multiply the surface's length by its width by the pour depth to get cubic inches, then convert to fluid ounces using the fact that one cubic inch holds about 0.554 fluid ounces. This works for any flat pour — a tabletop coating, a river table fill, or a floor topcoat — as long as you know the area and how thick a layer you're pouring.
    </p>
    <p class="mt-3 text-slate-600">
      Depth matters beyond just the material quantity: standard tabletop epoxy is formulated for thin pours, usually limited to about 1/8 to 1/4 inch at a time, because a thicker single pour traps more curing heat and can crack, yellow, or cloud as a result. Deep-pour epoxy formulations are chemically different, designed to cure slower and cooler, and can often go 1 to 2 inches or more in a single pour — always check the specific product's rated maximum depth rather than assuming.
    </p>
    <p class="mt-3 text-slate-600">
      Because some resin is inevitably lost in mixing cups, on stir sticks, and to minor drips over an edge, a 10 to 15% overage is standard practice on top of the calculated volume — this tool defaults to 10%, adjustable for a particularly involved pour. For anything beyond a single thin coat, plan on multiple pours with standard epoxy rather than exceeding its safe single-pour depth.
    </p>
    <p class="mt-3 text-xs text-slate-400">Maximum pour depth and mix-ratio guidance follow manufacturer technical data sheets typical of major epoxy resin brands.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the surface</h3>
        <p class="mt-1 text-sm text-slate-600">Length and width in inches.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the pour depth</h3>
        <p class="mt-1 text-sm text-slate-600">Check it's within your epoxy's rated max.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Buy with overage</h3>
        <p class="mt-1 text-sm text-slate-600">10-15% extra for mixing loss.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= L &times; W &times; depth</span>. A 36×24 in table, 0.125 in deep: 864 × 0.125 = <strong>108 in³</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Fluid ounces</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= in&sup3; &times; 0.554</span> = 108 × 0.554 = <strong>59.8 fl oz</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">With overage</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">&times; 1.10</span> = 59.8 × 1.10 = <strong>65.8 fl oz</strong> to buy.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 48×30 in bar top, poured 1/4 inch deep, 15% overage.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">48×30×0.25 = 360 in³</span></div>
        <div><span class="font-medium text-slate-700">Fl oz:</span> <span class="text-slate-600">360 × 0.554 = 199.4 fl oz</span></div>
        <div><span class="font-medium text-slate-700">With overage:</span> <span class="text-slate-600">199.4 × 1.15 = <strong>229.3 fl oz</strong></span></div>
        <div><span class="font-medium text-slate-700">In gallons:</span> <span class="text-slate-600">≈ 1.8 gallons</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Where this calculator gets used</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🪵</span>
        <h3 class="mt-2 font-semibold text-slate-900">River tables</h3>
        <p class="mt-1 text-sm text-slate-600">Filling the "river" gap between two live-edge wood slabs is the classic deep-pour application, often 3/4 to 1+ inch deep and requiring a deep-pour formulation rather than standard tabletop epoxy.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🍽️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Bar and countertop coating</h3>
        <p class="mt-1 text-sm text-slate-600">A thin 1/8 to 1/4 inch clear topcoat over a bar, countertop, or dining table protects the surface while showcasing wood grain, pigments, or embedded objects underneath.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🎨</span>
        <h3 class="mt-2 font-semibold text-slate-900">Resin art and coasters</h3>
        <p class="mt-1 text-sm text-slate-600">Small-format resin art, coasters, and jewelry molds use tiny volumes, often under an ounce, where getting the mix ratio and overage right matters more than the raw calculation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏭</span>
        <h3 class="mt-2 font-semibold text-slate-900">Garage and industrial floor coatings</h3>
        <p class="mt-1 text-sm text-slate-600">Large floor areas use a thin, self-leveling epoxy coat, so total volume is driven mostly by square footage rather than depth — buying in gallon quantities makes sense at this scale.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A 60 in by 30 in river table with a 1 inch deep pour needs 1,800 cubic inches of resin. Converted at 0.554 fluid ounces per cubic inch and with a 10% overage, that comes to about 1,097 fluid ounces — roughly 8.6 gallons. A pour this deep and this large absolutely requires a deep-pour epoxy formulation, since standard tabletop epoxy poured this thick would generate enough exothermic heat during cure to crack or discolor.
    </p>
    <p class="mt-3 text-slate-600">
      At the opposite extreme, a small 4 in by 4 in coaster poured 1/4 inch deep needs only 4 cubic inches of resin. With a 15% overage that's about 2.5 fluid ounces — less than a shot glass — which is why small resin art projects are usually measured and mixed in small disposable cups rather than by the gallon.
    </p>
    <p class="mt-3 text-slate-600">
      A 120 in by 96 in garage floor (10 ft by 8 ft) coated at a thin 1/8 inch needs 1,440 cubic inches, which works out to about 878 fluid ounces, or roughly 6.9 gallons with a 10% overage. Floor coatings stay thin deliberately — a thicker coat wastes material without adding meaningful durability, since floor epoxy relies more on the substrate prep than on coating thickness.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any epoxy resin works for any pour depth, I just need to buy enough of it." <strong class="text-slate-900">Depth determines the product, not just the quantity.</strong> Standard tabletop epoxy poured too thick can overheat during its exothermic cure and crack, yellow, or cloud. Deep pours need a deep-pour formulation engineered to cure slower and cooler, regardless of how much you buy.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Epoxy resin and hardener mix 1:1 by volume for every brand." <strong class="text-slate-900">Mix ratios vary by product.</strong> Some brands use a 1:1 ratio, others 2:1 or 3:1 by volume or weight. Using the wrong ratio results in a soft, tacky, or improperly cured surface — always check the specific product's technical data sheet before mixing.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/board-foot-lumber-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Board Foot Calculator</a>
      <a href="/tools/paint-coverage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Paint Coverage Calculator</a>
      <a href="/tools/gallons-per-square-foot-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gallons per Square Foot Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('len').value);
      const W = parseFloat(el('width').value);
      const D = parseFloat(el('depth').value);
      let overage = parseFloat(el('overage').value); if (!(overage >= 0)) overage = 0;
      if (!(L > 0 && W > 0 && D > 0)) { el('results').classList.add('hidden'); return; }
      const cin = L * W * D;
      const flozRaw = cin * 0.554113;
      const floz = flozRaw * (1 + overage / 100);
      const gal = floz / 128;
      const deep = D > 0.25;

      el('r-oz').textContent = floz.toFixed(1) + ' fl oz';
      el('r-note').textContent = 'for a ' + D + ' in deep pour, ' + overage + '% overage';
      el('r-cin').textContent = cin.toFixed(1) + ' in³';
      el('r-gal').textContent = gal.toFixed(2) + ' gal';
      el('r-depthcheck').textContent = deep ? '⚠ check max depth' : '✓ within typical 1/4 in';
      el('r-depthcheck').className = 'mt-1 text-lg font-bold ' + (deep ? 'text-amber-600' : 'text-green-600');
      el('r-depth-box').className = 'rounded-xl p-3 text-center ' + (deep ? 'bg-amber-50' : 'bg-green-50');
      el('results').classList.remove('hidden');
    }

    ['len', 'width', 'depth', 'overage'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
