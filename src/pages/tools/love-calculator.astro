---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Love Calculator';
const description =
  'Free love calculator. Enter two names to get a fun love-compatibility score out of 100. ' +
  'A lighthearted game to share with friends — just for fun!';
const intro =
  'Enter two names and tap calculate for a fun love-compatibility score. Just for fun — no science involved!';
const category = { id: 'creators', name: 'Creators' };
const faqs = [
  { q: 'Is the love calculator real?', a: 'No — it’s purely for fun and entertainment. The score is generated from the letters in the names, so the same two names always give the same result.' },
  { q: 'Why do the same names give the same score?', a: 'The result is calculated from the names themselves, so it’s consistent every time — which makes it fun to share.' },
  { q: 'Is my data saved?', a: 'No. Everything runs in your browser and nothing is stored or sent anywhere.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Your name</span>
        <input id="a" type="text" placeholder="Alex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Their name</span>
        <input id="b" type="text" placeholder="Sam" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <button id="calc" class="mt-4 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">💕 Calculate love</button>

    <div id="result" class="mt-6 hidden text-center">
      <div id="score" class="text-5xl font-bold text-pink-600">—</div>
      <div class="mx-auto mt-3 h-3 w-full max-w-sm overflow-hidden rounded-full bg-slate-200">
        <div id="bar" class="h-full w-0 rounded-full bg-gradient-to-r from-pink-400 to-rose-600 transition-all duration-700"></div>
      </div>
      <p id="msg" class="mt-3 text-slate-600"></p>
    </div>
    <p class="mt-4 text-center text-xs text-slate-400">Just for fun — not a scientific measure of anything! 😄</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About the love calculator</h2>
    <p class="mt-2 text-slate-600">
      The love calculator is a classic, lighthearted bit of fun — pop in two names and get a
      “compatibility” percentage to share and laugh about with friends. It’s entirely for
      entertainment, generated from the letters in the names, so the result is the same every time.
    </p>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/fancy-text" class="font-medium text-indigo-600 hover:underline">Fancy Text Generator</a>
      or <a href="/tools/emoji-picker" class="font-medium text-indigo-600 hover:underline">Emoji Picker</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function score(a, b) {
      const s = [a.trim().toLowerCase(), b.trim().toLowerCase()].sort().join('+');
      let h = 0;
      for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) % 100000;
      return (h % 100) + 1; // 1..100
    }
    function message(p) {
      if (p >= 90) return 'A perfect match made in heaven! 💞';
      if (p >= 70) return 'Lots of chemistry here — looking good! 💖';
      if (p >= 50) return 'A solid spark worth exploring. 💗';
      if (p >= 30) return 'Could work with a little effort. 💓';
      return 'Opposites attract… sometimes! 💔';
    }
    el('calc').addEventListener('click', () => {
      const a = el('a').value, b = el('b').value;
      if (!a.trim() || !b.trim()) { el('result').classList.remove('hidden'); el('score').textContent = '—'; el('msg').textContent = 'Enter both names first!'; el('bar').style.width = '0'; return; }
      const p = score(a, b);
      el('result').classList.remove('hidden');
      el('score').textContent = p + '%';
      el('msg').textContent = message(p);
      el('bar').style.width = '0';
      requestAnimationFrame(() => { el('bar').style.width = p + '%'; });
    });
  </script>
</ToolLayout>
