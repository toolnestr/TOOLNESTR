---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Love Calculator';
const description =
  'Free love calculator. Enter two names to get a fun love-compatibility score out of 100. ' +
  'A lighthearted game to share with friends — just for fun!';
const intro =
  'Enter two names and tap calculate for a fun love-compatibility score. Just for fun — no science involved!';
const category = { id: 'creators', name: 'Creators' };
const faqs = [
  { q: 'Is the love calculator real?', a: 'No — it\'s purely for fun and entertainment. The score is generated from the letters in the names, so the same two names always give the same result.' },
  { q: 'Why do the same names give the same score?', a: 'The result is calculated from the names themselves, so it\'s consistent every time — which makes it fun to share.' },
  { q: 'Is my data saved?', a: 'No. Everything runs in your browser and nothing is stored or sent anywhere.' },
  { q: 'Can I use nicknames instead of full names?', a: 'Absolutely — use whatever name you like! The calculation is based on the text you enter, so nicknames, usernames or even emojis all work.' },
  { q: 'What score range can I get?', a: 'Scores range from 1 to 100. The messages change depending on how high or low the score is.' },
  { q: 'Why is this just for fun?', a: 'Real compatibility depends on personality, values and communication — not name arithmetic! This is a lighthearted game inspired by playground love calculators.' },
  { q: 'Can I share my result?', a: 'Yes — the score and message appear on screen. You can screenshot it or share the names and score with friends manually.' },
  { q: 'Do spaces and punctuation affect the score?', a: 'Yes — the calculation uses the full text you enter, so adding or removing spaces and punctuation will change the result.' },
  { q: 'What happens if I enter the same name twice?', a: 'You get a self-compatibility score. It\'s a fun way to see what the calculator thinks of your own name!' },
  { q: 'Is there a maximum name length?', a: 'No hard limit, but very long text may produce the same scores due to hash collisions. Short names work best for varied results.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Your name</span>
        <input id="a" type="text" placeholder="Alex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Their name</span>
        <input id="b" type="text" placeholder="Sam" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <button id="calc" class="mt-4 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">&#x1f495; Calculate love</button>

    <div id="result" class="mt-6 hidden text-center">
      <div id="score" class="text-5xl font-bold text-pink-600">—</div>
      <div class="mx-auto mt-3 h-3 w-full max-w-sm overflow-hidden rounded-full bg-slate-200">
        <div id="bar" class="h-full w-0 rounded-full bg-gradient-to-r from-pink-400 to-rose-600 transition-all duration-700"></div>
      </div>
      <p id="msg" class="mt-3 text-slate-600"></p>
    </div>
    <p class="mt-4 text-center text-xs text-slate-400">Just for fun — not a scientific measure of anything! &#x1f604;</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter your name and the other person's name in the two fields.</li>
      <li>Click "Calculate love" to see the compatibility score.</li>
      <li>Share the result with a friend for a laugh — the same names always give the same score.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      The love calculator is perfect for parties, sleepovers or group chats when you need an icebreaker or something silly to share. Friends use it to test fictional character pairings, celebrity couples, or just for a laugh between themselves. Streamers and content creators sometimes use it as a fun interactive segment with their audience. It's also a nostalgic throwback to the playground love calculators many of us grew up with.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different score ranges mean</h2>
    <p class="mt-2 text-slate-600">Each score range comes with its own message and level of enthusiasm. Here is how the calculator interprets your result.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">90–100%</span><span class="text-slate-400">A perfect match made in heaven!</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">70–89%</span><span class="text-slate-400">Lots of chemistry — looking good!</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:80%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">50–69%</span><span class="text-slate-400">A solid spark worth exploring</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:60%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">30–49%</span><span class="text-slate-400">Could work with a little effort</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-400" style="width:40%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">1–29%</span><span class="text-slate-400">Opposites attract… sometimes!</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-400" style="width:20%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f496;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Best Friends</h3>
      <p class="mt-1 text-sm text-slate-600">Tests friend compatibility for fun during sleepovers, road trips, or group hangouts. A lighthearted way to spark conversation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f3ac;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Creator</h3>
      <p class="mt-1 text-sm text-slate-600">Engages the audience during live streams by calculating love scores for viewer couples, fictional characters, or celebrity pairs.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f467;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teenager</h3>
      <p class="mt-1 text-sm text-slate-600">Shares results with crushes or friends as a playful icebreaker. The nostalgic format makes it popular in schools and youth groups.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f9d1;&#x200d;&#x1f91d;&#x200d;&#x1f9d1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Couple</h3>
      <p class="mt-1 text-sm text-slate-600">Tests their own names for fun — a silly, romantic activity that couples enjoy sharing on social media or in private messages.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Score Range</th><th class="p-3">Message</th><th class="p-3">Vibe</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">90–100%</td><td class="p-3">A perfect match made in heaven!</td><td class="p-3">&#x1f49e; Soulmate energy</td></tr>
        <tr><td class="p-3 font-medium">70–89%</td><td class="p-3">Lots of chemistry here — looking good!</td><td class="p-3">&#x1f496; Romantic potential</td></tr>
        <tr><td class="p-3 font-medium">50–69%</td><td class="p-3">A solid spark worth exploring.</td><td class="p-3">&#x1f497; Could develop</td></tr>
        <tr><td class="p-3 font-medium">30–49%</td><td class="p-3">Could work with a little effort.</td><td class="p-3">&#x1f493; Needs work</td></tr>
        <tr><td class="p-3 font-medium">1–29%</td><td class="p-3">Opposites attract… sometimes!</td><td class="p-3">&#x1f494; Friends only</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the love calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter two names</h3>
        <p class="mt-1 text-sm text-slate-600">Type your name and the other person's name into the two input fields provided.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Calculate the score</h3>
        <p class="mt-1 text-sm text-slate-600">Click the Calculate button to generate a love-compatibility percentage based on the names.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Share the result</h3>
        <p class="mt-1 text-sm text-slate-600">Screenshot or share the score and message with friends — the same names always give the same result.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for getting the most out of it</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Try full names for variety</h3>
        <p class="mt-1 text-sm text-slate-600">Using both first and last names creates more unique character combinations, leading to a wider range of possible scores.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Test fictional pairings</h3>
        <p class="mt-1 text-sm text-slate-600">Enter names from books, movies, or games to see what the calculator decides about your favourite fictional couples.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Keep it lighthearted</h3>
        <p class="mt-1 text-sm text-slate-600">Remember this is pure entertainment. Real relationships are built on trust, communication, and shared values — not name hashing!</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About the love calculator</h2>
    <p class="mt-2 text-slate-600">
      The love calculator is a classic, lighthearted bit of fun — pop in two names and get a
      "compatibility" percentage to share and laugh about with friends. It's entirely for
      entertainment, generated from the letters in the names, so the result is the same every time.
      For more creative fun, try the <a href="/tools/fancy-text" class="font-medium text-indigo-600 hover:underline">Fancy Text Generator</a>
      to style your names, or the <a href="/tools/emoji-picker" class="font-medium text-indigo-600 hover:underline">Emoji Picker</a>
      to add hearts and decorations to your results.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function score(a, b) {
      const s = [a.trim().toLowerCase(), b.trim().toLowerCase()].sort().join('+');
      let h = 0;
      for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) % 100000;
      return (h % 100) + 1; // 1..100
    }
    function message(p) {
      if (p >= 90) return 'A perfect match made in heaven! 💞';
      if (p >= 70) return 'Lots of chemistry here — looking good! 💖';
      if (p >= 50) return 'A solid spark worth exploring. 💗';
      if (p >= 30) return 'Could work with a little effort. 💓';
      return 'Opposites attract… sometimes! 💔';
    }
    el('calc').addEventListener('click', () => {
      const a = el('a').value, b = el('b').value;
      if (!a.trim() || !b.trim()) { el('result').classList.remove('hidden'); el('score').textContent = '—'; el('msg').textContent = 'Enter both names first!'; el('bar').style.width = '0'; return; }
      const p = score(a, b);
      el('result').classList.remove('hidden');
      el('score').textContent = p + '%';
      el('msg').textContent = message(p);
      el('bar').style.width = '0';
      requestAnimationFrame(() => { el('bar').style.width = p + '%'; });
    });
  </script>
</ToolLayout>
