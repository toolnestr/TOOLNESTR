---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Fahrenheit to Celsius"
  emoji="🌡️"
  fromUnit="degrees Fahrenheit" toUnit="degrees Celsius"
  fromTitle="Fahrenheit" toTitle="Celsius"
  fromSym="°F" toSym="°C"
  quantity="temperature"
  kind="tempFC"
  reverseSlug="celsius-to-fahrenheit" reverseLabel="Celsius to Fahrenheit Converter"
  hasReverse={true}
  related={[{"slug":"celsius-to-kelvin","label":"Celsius to Kelvin Converter"},{"slug":"kelvin-to-celsius","label":"Kelvin to Celsius Converter"}]}
  useCase="Read US weather reports, oven settings and body temperatures in the Celsius scale used worldwide."
/>
