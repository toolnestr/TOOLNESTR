---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Asphalt Driveway Calculator';
const description = 'Estimate the tons of hot-mix asphalt you need for a driveway from its area and compacted thickness, using standard asphalt density.';
const intro = 'Estimate the tons of asphalt you need for a driveway, from its area and compacted thickness, using standard hot-mix asphalt density.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much asphalt do I need for a driveway?', a: 'Multiply the driveway area by the compacted thickness to get the volume, then multiply by the density of compacted asphalt, typically about 145 pounds per cubic foot, to get the weight in tons.' },
  { q: 'How thick should a residential driveway be?', a: 'A typical residential asphalt driveway is 2 to 3 inches thick over a properly prepared and compacted gravel base. Driveways carrying heavier vehicles, like RVs or delivery trucks, often use 3 to 4 inches.' },
  { q: 'Why does the calculator use 145 pounds per cubic foot?', a: 'That is a standard nominal density for compacted hot-mix asphalt used across the paving industry, following Asphalt Institute density norms. Actual mix density varies a little by aggregate and mix design, so a paving contractor\'s figure for your specific mix may differ slightly.' },
  { q: 'Do I need a base layer under the asphalt?', a: 'Yes, almost always. A compacted crushed-stone base spreads the load and provides drainage under the asphalt layer. This calculator estimates the asphalt only; use the road base calculator separately for the base material underneath.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="length" type="number" step="any" placeholder="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="width" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Compacted thickness (in)</span>
        <input id="thick" type="number" step="any" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Asphalt needed</div>
        <div id="r-tons" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Volume</div><div id="r-vol" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Weight (lb)</div><div id="r-lb" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="280" viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ad-title ad-desc">
      <title id="ad-title">Asphalt driveway cross-section</title>
      <desc id="ad-desc">A driveway cross-section showing the compacted asphalt layer over a base, with the tonnage formula</desc>
      <rect x="100" y="180" width="300" height="16" fill="#334155" stroke="#1e293b" stroke-width="1.5" />
      <rect x="100" y="196" width="300" height="30" fill="#cbd5e1" stroke="#94a3b8" stroke-width="1.5" />
      <text x="420" y="192" font-size="12" fill="#475569" font-family="system-ui,sans-serif">asphalt (2-3&Prime;)</text>
      <text x="420" y="216" font-size="12" fill="#475569" font-family="system-ui,sans-serif">compacted base</text>
      <rect x="480" y="90" width="290" height="130" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="500" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Asphalt tonnage</text>
      <text x="500" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">volume = area &times; (thick&frasl;12)</text>
      <text x="500" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">weight = volume &times; 145 lb/ft&sup3;</text>
      <text x="500" y="188" font-size="12" fill="#475569" font-family="system-ui,sans-serif">tons = weight &divide; 2000</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Asphalt weight scales with area, thickness, and the standard compacted density of about 145 lb/ft³.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the asphalt driveway calculator works</h2>
    <p class="mt-2 text-slate-600">
      Asphalt is ordered and priced by weight, not volume, so the calculator first finds the volume of material needed — length times width times the compacted thickness — then converts that volume to weight using a standard density figure for compacted hot-mix asphalt.
    </p>
    <p class="mt-3 text-slate-600">
      Compacted asphalt weighs about 145 pounds per cubic foot, a nominal figure that follows Asphalt Institute density norms used across the paving industry. Multiplying your volume in cubic feet by that density gives the total weight in pounds, and dividing by 2,000 converts it to tons, the unit asphalt is typically ordered and delivered in.
    </p>
    <p class="mt-3 text-slate-600">
      This estimates the asphalt surface layer only. Nearly every asphalt driveway sits on a compacted crushed-stone base that spreads the load and drains water away from the pavement — size that separately with a road base calculator, since it uses a different material and density.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the driveway</h3>
        <p class="mt-1 text-sm text-slate-600">Length and width in feet, and your intended compacted thickness in inches.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check the result in tons</h3>
        <p class="mt-1 text-sm text-slate-600">Asphalt suppliers quote and deliver by the ton, so this is your ordering number.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Add the base separately</h3>
        <p class="mt-1 text-sm text-slate-600">Use the road base calculator for the crushed-stone layer underneath.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= L &times; W &times; (T&frasl;12)</span>. 40 ft &times; 12 ft &times; (3&frasl;12): 480 &times; 0.25 = <strong>120 ft&sup3;</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Weight</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= volume &times; 145 lb/ft&sup3;</span> = 120 &times; 145 = <strong>17,400 lb</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Tons</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= weight &divide; 2000</span> = 17,400 &divide; 2000 = <strong>8.7 tons</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A wider 60 ft &times; 16 ft driveway, 2.5 in compacted thickness.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Area:</span> <span class="text-slate-600">60 &times; 16 = 960 ft²</span></div>
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">960 &times; (2.5/12) = 200 ft³</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">200 &times; 145 = 29,000 lb</span></div>
        <div><span class="font-medium text-slate-700">Tons:</span> <span class="text-slate-600"><strong>14.5 tons</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/road-base-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Road Base Calculator</a>
      <a href="/tools/gravel-sand-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gravel &amp; Sand Calculator</a>
      <a href="/tools/concrete-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const DENSITY = 145; // lb per ft3, compacted asphalt

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      const T = parseFloat(el('thick').value);
      if (!L || !W || !T || L <= 0 || W <= 0 || T <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const area = L * W;
      const vol = area * (T / 12);
      const lb = vol * DENSITY;
      const tons = lb / 2000;

      el('r-tons').textContent = tons.toFixed(1) + ' tons';
      el('r-note').textContent = 'at ' + T + ' in compacted thickness';
      el('r-area').textContent = area.toFixed(0) + ' ft²';
      el('r-vol').textContent = vol.toFixed(1) + ' ft³';
      el('r-lb').textContent = Math.round(lb).toLocaleString();
      el('results').classList.remove('hidden');
    }

    ['length', 'width', 'thick'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
