---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Zakat on Silver Calculator';
const description = 'Calculate the 2.5% Zakat due on silver from its weight and current price per gram, with automatic checking against the 612.36 g silver nisab.';
const intro = 'Enter your silver weight and the live price per gram to see its value and the Zakat due.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'What is the silver nisab?', a: 'The silver nisab is 612.36 grams of silver. If the silver you own (or its value combined with other wealth) reaches this threshold and a lunar year has passed, Zakat of 2.5% is due.' },
  { q: 'Why is the silver nisab lower than gold?', a: 'The two nisab levels were set at the value of 87.48 g of gold and 612.36 g of silver. Today silver is much cheaper per gram than gold, so the silver nisab is a lower monetary value — which is why many scholars recommend it, as it makes more people liable and benefits the poor.' },
  { q: 'Can I combine silver with other assets?', a: 'Yes. Zakat is assessed on your total wealth — silver, gold, cash, business stock and receivables. If silver alone is below the nisab, add it to your other zakatable assets, which together may exceed the threshold.' },
  { q: 'Where do I get the silver price?', a: 'Use the current market price per gram in your own currency from a reliable bullion source or jeweller. Apply the price on your Zakat anniversary, since metal prices change over time.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="mb-4 block"><span class="text-sm font-medium text-slate-700">Currency</span>
      <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="USD">USD $ — US Dollar</option><option value="PKR">PKR ₨ — Pakistani Rupee</option><option value="INR">INR ₹ — Indian Rupee</option><option value="BDT">BDT ৳ — Bangladeshi Taka</option><option value="IDR">IDR Rp — Indonesian Rupiah</option><option value="MYR">MYR RM — Malaysian Ringgit</option><option value="SAR">SAR — Saudi Riyal</option><option value="AED">AED — UAE Dirham</option><option value="QAR">QAR — Qatari Riyal</option><option value="KWD">KWD — Kuwaiti Dinar</option><option value="EGP">EGP — Egyptian Pound</option><option value="TRY">TRY ₺ — Turkish Lira</option><option value="NGN">NGN ₦ — Nigerian Naira</option><option value="ZAR">ZAR — South African Rand</option><option value="MAD">MAD — Moroccan Dirham</option><option value="GBP">GBP £ — British Pound</option><option value="EUR">EUR € — Euro</option><option value="CAD">CAD $ — Canadian Dollar</option><option value="AUD">AUD $ — Australian Dollar</option>
      </select></label>

    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Silver weight</span>
        <input id="weight" type="number" step="any" placeholder="700" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Unit</span>
        <select id="unit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="g">Grams</option><option value="tola">Tola (11.6638 g)</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Price per gram</span>
        <input id="price" type="number" step="any" placeholder="0.85" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div id="due-card" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Zakat on this silver (2.5%)</div>
        <div id="r-due" class="mt-1 text-3xl font-bold tabular-nums">—</div>
        <div id="r-status" class="mt-1 text-sm opacity-90"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Weight</div><div id="r-weight" class="mt-1 text-lg font-bold tabular-nums text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Silver value</div><div id="r-value" class="mt-1 text-lg font-bold tabular-nums text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Nisab (612.36 g)</div><div id="r-nisab" class="mt-1 text-lg font-bold tabular-nums text-slate-800">—</div></div>
      </div>
      <p class="rounded-xl bg-indigo-50 p-3 text-sm text-indigo-900 dark:bg-indigo-950/40 dark:text-indigo-200">
        If you also hold cash, gold or business assets, combine everything in the <a href="/tools/zakat-calculator" class="font-semibold underline">Zakat Calculator</a> — Zakat is then due on the total even when silver alone is below the nisab.
      </p>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="260" viewBox="0 0 800 260" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="zs-title zs-desc">
      <title id="zs-title">Silver weighing scale against the nisab</title>
      <desc id="zs-desc">A balance scale comparing silver weight against the 612.36 gram nisab; if it meets nisab, Zakat is 2.5 percent of value.</desc>
      <line x1="400" y1="40" x2="400" y2="200" stroke="#94a3b8" stroke-width="4" />
      <line x1="250" y1="70" x2="550" y2="70" stroke="#94a3b8" stroke-width="4" />
      <circle cx="400" cy="40" r="8" fill="#64748b" />
      <line x1="250" y1="70" x2="250" y2="120" stroke="#cbd5e1" stroke-width="2" />
      <line x1="550" y1="70" x2="550" y2="120" stroke="#cbd5e1" stroke-width="2" />
      <ellipse cx="250" cy="125" rx="55" ry="14" fill="#e2e8f0" stroke="#94a3b8" />
      <ellipse cx="550" cy="125" rx="55" ry="14" fill="#e2e8f0" stroke="#94a3b8" />
      <text x="250" y="160" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif" font-weight="bold">Your silver</text>
      <text x="550" y="160" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif" font-weight="bold">612.36 g nisab</text>
      <rect x="225" y="105" width="50" height="16" rx="3" fill="#cbd5e1" stroke="#94a3b8" />
      <rect x="535" y="105" width="30" height="16" rx="3" fill="#94a3b8" />
      <text x="400" y="220" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Value &times; 2.5% = Zakat (if &ge; nisab)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Silver becomes zakatable once it reaches 612.36 grams or its value joins your other wealth above the nisab.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the silver Zakat calculator works</h2>
    <p class="mt-2 text-slate-600">Silver has always been one of the two metals on which Zakat is assessed, and it sets the lower of the two nisab thresholds. This calculator takes the weight of silver you own, multiplies it by the current price per gram to find its value, and applies the 2.5% Zakat rate once the 612.36-gram nisab is reached. The whole calculation happens in your browser and nothing is stored.</p>
    <p class="mt-3 text-slate-600">Silver is usually close to pure in coins and bullion, so unlike gold there is no karat factor — the weight you enter is taken at face value. If you weigh in tola, switch the unit and the tool converts at 1 tola = 11.6638 grams. The result tells you the value, whether you have crossed the nisab, and the Zakat owed.</p>
    <p class="mt-3 text-slate-600">Because silver is inexpensive per gram, its nisab is a low monetary amount. This is why the silver standard is widely recommended: it captures more savers and channels more Zakat to those in need. If your silver alone is under 612.36 grams, combine its value with cash and gold in the main Zakat calculator to see your full position.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4"><p class="font-semibold text-slate-900">Silver value</p><p class="mt-1 text-slate-600"><span class="font-mono">Value = weight (g) &times; price per gram</span>.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-4"><p class="font-semibold text-slate-900">Zakat due</p><p class="mt-1 text-slate-600"><span class="font-mono">Zakat = value &times; 0.025</span> when weight &ge; 612.36 g.</p></div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">800 g of silver at 0.85 per gram.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Value:</span> <span class="text-slate-600">800 &times; 0.85 = 680</span></div>
        <div><span class="font-medium text-slate-700">Meets nisab?</span> <span class="text-slate-600">800 &ge; 612.36 → yes</span></div>
        <div><span class="font-medium text-slate-700">Zakat:</span> <span class="text-slate-600">680 &times; 0.025 = <strong>17.00</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Things to keep in mind</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🥈</span><h3 class="mt-2 font-semibold text-slate-900">Sterling vs pure silver</h3><p class="mt-1 text-sm text-slate-600">Sterling silver is 92.5% pure. For precision you can multiply the weight by 0.925, but most people assess household silver at full weight for simplicity and caution.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🧮</span><h3 class="mt-2 font-semibold text-slate-900">Combine your wealth</h3><p class="mt-1 text-sm text-slate-600">Silver rarely stands alone. Add its value to cash, gold and business assets to judge your total Zakat — small holdings still count toward the threshold.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">📅</span><h3 class="mt-2 font-semibold text-slate-900">Price on the due date</h3><p class="mt-1 text-sm text-slate-600">Apply the silver price as it stands on your Zakat anniversary, not when you acquired the metal, so the value reflects the moment Zakat falls due.</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5"><span class="text-2xl">🤲</span><h3 class="mt-2 font-semibold text-slate-900">Pay promptly</h3><p class="mt-1 text-sm text-slate-600">Once calculated, give your Zakat to eligible recipients without delay. Prompt payment keeps the obligation fulfilled and the blessing intact.</p></div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/zakat-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat Calculator</a>
      <a href="/tools/zakat-on-gold-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Zakat on Gold Calculator</a>
      <a href="/tools/nisab-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Nisab Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const REGION_CUR = { PK: 'PKR', IN: 'INR', BD: 'BDT', ID: 'IDR', MY: 'MYR', SA: 'SAR', AE: 'AED', QA: 'QAR', KW: 'KWD', EG: 'EGP', TR: 'TRY', NG: 'NGN', ZA: 'ZAR', MA: 'MAD', GB: 'GBP', US: 'USD', CA: 'CAD', AU: 'AUD', FR: 'EUR', DE: 'EUR', IT: 'EUR', ES: 'EUR' };
    function defaultCurrency() { try { var s = localStorage.getItem('tn_currency'); if (s) return s; } catch (e) {} try { var p = (navigator.language || '').split('-')[1]; if (p && REGION_CUR[p.toUpperCase()]) return REGION_CUR[p.toUpperCase()]; } catch (e) {} return 'USD'; }
    let CUR = defaultCurrency();
    function fmtMoney(n) { try { return new Intl.NumberFormat(undefined, { style: 'currency', currency: CUR, maximumFractionDigits: 2 }).format(n); } catch (e) { return n.toLocaleString(undefined, { maximumFractionDigits: 2 }); } }
    const num = (id) => { const v = parseFloat(el(id).value); return isFinite(v) ? v : 0; };
    function update() {
      let w = num('weight');
      if (el('unit').value === 'tola') w *= 11.6638;
      const price = num('price');
      if (w <= 0) { el('results').classList.add('hidden'); return; }
      const value = w * price;
      const meets = w >= 612.36;
      const due = value * 0.025;
      const fmt = (n) => n.toLocaleString(undefined, { maximumFractionDigits: 2 });
      el('r-weight').textContent = fmt(w) + ' g';
      el('r-value').textContent = price > 0 ? fmtMoney(value) : '—';
      el('r-nisab').textContent = '612.36 g';
      el('r-due').textContent = price > 0 ? fmtMoney(due) : 'enter price';
      el('r-status').textContent = meets
        ? 'This silver meets the 612.36 g silver nisab — Zakat is due.'
        : 'Below the 612.36 g silver nisab. If silver is your only wealth, none is due — but combined with any other savings, the amount above applies.';
      el('due-card').className = 'rounded-xl p-5 text-center text-white ' + (meets ? 'bg-indigo-600' : 'bg-amber-600');
      el('results').classList.remove('hidden');
    }
    ['weight', 'price'].forEach((id) => el(id).addEventListener('input', update));
    el('unit').addEventListener('change', update);
    (function () { const c = document.getElementById('cur'); if (!c) return; c.value = CUR; c.addEventListener('change', function () { CUR = c.value; try { localStorage.setItem('tn_currency', CUR); } catch (e) {} update(); }); })();
  </script>
</ToolLayout>
