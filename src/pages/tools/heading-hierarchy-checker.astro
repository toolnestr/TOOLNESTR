---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Heading Hierarchy Checker';
const description = 'Free online heading hierarchy checker. Validate heading structure (H1 to H6) from pasted HTML to ensure proper document outline.';
const intro = 'Paste HTML source code to check the heading hierarchy and get a visual outline of your document structure.';
const category = { id: 'seo', name: 'SEO Tools' };
const faqs = [
  { q: 'What does the heading hierarchy checker do?', a: 'It parses pasted HTML, extracts all H1-H6 tags, and analyzes the heading structure for issues like missing H1, skipped levels, and multiple H1 tags.' },
  { q: 'Why is heading hierarchy important?', a: 'Headings create a document outline that helps search engines understand content structure and enables screen reader users to navigate efficiently.' },
  { q: 'What issues does it detect?', a: 'It detects missing H1, skipped heading levels (e.g., H1 to H3), multiple H1 tags, empty headings, and incorrect heading order.' },
  { q: 'What is considered a proper hierarchy?', a: 'A proper hierarchy follows H1 > H2 > H3 > H4 > H5 > H6 without skipping levels. Each section should have one H1 at the top.' },
  { q: 'Is my HTML sent to a server?', a: 'No. All processing happens in your browser. Nothing is uploaded or stored.' },
  { q: 'Do I need full HTML or just headings?', a: 'Paste any HTML content that contains headings. The checker parses the markup and finds all heading elements.' },
  { q: 'Can I check multiple pages at once?', a: 'No. You need to paste one HTML document at a time for analysis.' },
  { q: 'What does the overall score mean?', a: 'The score reflects the quality of your heading hierarchy. A passing score means no critical issues were found.' },
  { q: 'Does it check heading text content?', a: 'Yes. It flags empty headings (headings with no text content) as a warning.' },
  { q: 'How do I fix skipped heading levels?', a: 'Ensure that an H2 follows an H1, an H3 follows an H2, and so on. Do not jump from H1 to H3 or H2 to H4.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <span class="text-sm font-medium text-slate-700">HTML source code</span>
    <textarea
      id="html-input"
      rows="8"
      placeholder="Paste HTML source code with heading tags..."
      class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-4 text-base leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <button id="check-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Check hierarchy</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
    </div>

    <div id="results" class="mt-4 hidden">
      <div class="flex items-center gap-3 rounded-xl border p-4" id="score-card">
        <span id="score-icon" class="text-2xl"></span>
        <div>
          <span id="score-text" class="text-lg font-bold"></span>
          <p id="score-detail" class="text-sm text-slate-500"></p>
        </div>
      </div>

      <div class="mt-4 grid gap-4 sm:grid-cols-6">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-center"><span id="h1-count" class="text-lg font-bold text-slate-800">0</span><p class="text-xs text-slate-500">H1</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-center"><span id="h2-count" class="text-lg font-bold text-slate-800">0</span><p class="text-xs text-slate-500">H2</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-center"><span id="h3-count" class="text-lg font-bold text-slate-800">0</span><p class="text-xs text-slate-500">H3</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-center"><span id="h4-count" class="text-lg font-bold text-slate-800">0</span><p class="text-xs text-slate-500">H4</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-center"><span id="h5-count" class="text-lg font-bold text-slate-800">0</span><p class="text-xs text-slate-500">H5</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-center"><span id="h6-count" class="text-lg font-bold text-slate-800">0</span><p class="text-xs text-slate-500">H6</p></div>
      </div>

      <div id="warnings" class="mt-4 space-y-2"></div>

      <div class="mt-4 rounded-xl border border-slate-200 p-4">
        <h3 class="text-sm font-semibold text-slate-900">Document outline</h3>
        <div id="outline" class="mt-2 space-y-1 text-sm"></div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common heading hierarchy issues</h2>
    <p class="mt-2 text-slate-600">The most frequently found problems in heading structures across websites.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Missing H1</span><span class="text-slate-400">30%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Skipped heading levels</span><span class="text-slate-400">25%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:25%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Multiple H1</span><span class="text-slate-400">20%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Empty headings</span><span class="text-slate-400">15%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-violet-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Incorrect order</span><span class="text-slate-400">10%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-rose-400" style="width:10%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f50d;</span>
      <h3 class="mt-2 font-semibold text-slate-900">SEO Specialist</h3>
      <p class="mt-1 text-sm text-slate-600">Validates heading structure during technical SEO audits to ensure optimal search engine understanding of page content.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4bb;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Web Developer</h3>
      <p class="mt-1 text-sm text-slate-600">Checks that dynamically generated templates produce valid heading hierarchies before deployment.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4dd;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Writer</h3>
      <p class="mt-1 text-sm text-slate-600">Ensures articles and blog posts follow proper heading structure for both readability and SEO.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x267f;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Accessibility Auditor</h3>
      <p class="mt-1 text-sm text-slate-600">Verifies that heading levels create a logical document outline that works with screen reader navigation tools.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Level</th><th class="p-3">Purpose</th><th class="p-3">Example</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">H1</td><td class="p-3">Page title / main topic</td><td class="p-3">"Complete Guide to SEO"</td></tr>
        <tr><td class="p-3 font-medium">H2</td><td class="p-3">Major section</td><td class="p-3">"On-Page SEO"</td></tr>
        <tr><td class="p-3 font-medium">H3</td><td class="p-3">Sub-section under H2</td><td class="p-3">"Title Tags"</td></tr>
        <tr><td class="p-3 font-medium">H4</td><td class="p-3">Detailed sub-section</td><td class="p-3">"Optimal Title Length"</td></tr>
        <tr><td class="p-3 font-medium">H5-H6</td><td class="p-3">Deeply nested content</td><td class="p-3">Rarely used, for complex hierarchies</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Heading Hierarchy Checker</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste HTML</h3>
        <p class="mt-1 text-sm text-slate-600">Copy the HTML source code from your page and paste it into the input area.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check hierarchy</h3>
        <p class="mt-1 text-sm text-slate-600">Click Check hierarchy to analyze heading tags and generate a document outline.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Fix warnings</h3>
        <p class="mt-1 text-sm text-slate-600">Review warnings for skipped levels, missing H1, or multiple H1 tags and update your HTML accordingly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for heading hierarchy</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">One H1 per page</h3>
        <p class="mt-1 text-sm text-slate-600">Each page should have exactly one H1 that describes the main topic. Multiple H1 tags confuse search engines and screen readers.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Never skip levels</h3>
        <p class="mt-1 text-sm text-slate-600">Always follow H1 with H2, H2 with H3, and so on. Skipping from H2 to H4 breaks the logical document structure.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use headings for structure, not styling</h3>
        <p class="mt-1 text-sm text-slate-600">Don't use heading tags just to make text bigger or bolder. Use CSS for styling and reserve headings for document structure.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why heading hierarchy matters</h2>
    <p class="mt-2 text-slate-600">
      Headings are the backbone of a well-structured document. They create a logical outline that helps search engines index content correctly and enables users, especially those using screen readers, to navigate efficiently. A clear hierarchy improves both user experience and search rankings.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Proper document outline</h2>
    <p class="mt-2 text-slate-600">
      A proper document outline starts with a single H1, followed by H2s for main sections, H3s for subsections, and so on. This creates a tree structure that mirrors the content's logical organization. Think of it like a book: H1 is the title, H2s are chapter names, and H3s are section headings within chapters.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">SEO impact</h2>
    <p class="mt-2 text-slate-600">
      Search engines use heading tags to understand the relative importance of content sections. Pages with clear, hierarchical headings tend to rank better because the content structure is easier to parse. Proper use of heading keywords also signals relevance to search queries.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Accessibility</h2>
    <p class="mt-2 text-slate-600">
      Screen readers allow users to navigate by heading levels, jumping from one section to another. A broken or missing heading hierarchy makes this navigation impossible, creating a poor experience for visually impaired users. WCAG guidelines require logical heading structure for compliance.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function check() {
      const html = el('html-input').value;
      if (!html.trim()) { el('results').classList.add('hidden'); return; }

      const doc = document.createElement('div');
      doc.innerHTML = html;

      const allHeadings = doc.querySelectorAll('h1, h2, h3, h4, h5, h6');
      const counts = { h1: 0, h2: 0, h3: 0, h4: 0, h5: 0, h6: 0 };
      const outline = [];
      const warnings = [];

      allHeadings.forEach(h => {
        const tag = h.tagName.toLowerCase();
        counts[tag]++;
        const text = h.textContent.trim() || '(empty)';
        outline.push({ tag: tag.toUpperCase(), text });
      });

      el('h1-count').textContent = counts.h1;
      el('h2-count').textContent = counts.h2;
      el('h3-count').textContent = counts.h3;
      el('h4-count').textContent = counts.h4;
      el('h5-count').textContent = counts.h5;
      el('h6-count').textContent = counts.h6;

      if (counts.h1 === 0) warnings.push({ type: 'error', msg: 'Missing H1 — every page should have exactly one H1.' });
      if (counts.h1 > 1) warnings.push({ type: 'error', msg: 'Multiple H1 tags (' + counts.h1 + ' found) — use only one H1 per page.' });

      const headingTags = allHeadings;
      let prevLevel = 0;
      for (let i = 0; i < headingTags.length; i++) {
        const level = parseInt(headingTags[i].tagName[1]);
        if (prevLevel > 0 && level > prevLevel + 1) {
          warnings.push({ type: 'warning', msg: 'Skipped heading level: ' + headingTags[i-1].tagName.toUpperCase() + ' → ' + headingTags[i].tagName.toUpperCase() + ' at "' + (headingTags[i].textContent.trim() || '(empty)') + '".' });
        }
        if (!headingTags[i].textContent.trim()) {
          warnings.push({ type: 'warning', msg: 'Empty ' + headingTags[i].tagName.toUpperCase() + ' tag found.' });
        }
        prevLevel = level;
      }

      const warnDiv = el('warnings');
      if (warnings.length) {
        warnDiv.innerHTML = '<h3 class="text-sm font-semibold text-slate-900 mb-2">Warnings (' + warnings.length + ')</h3>' +
          warnings.map(w =>
            '<div class="flex items-start gap-2 rounded-lg px-3 py-2 ' +
            (w.type === 'error' ? 'bg-rose-50 text-rose-700' : 'bg-amber-50 text-amber-700') +
            ' text-sm"><span>' + (w.type === 'error' ? '&#x26a0;' : '&#x26a0;') + '</span>' + w.msg + '</div>'
          ).join('');
      } else {
        warnDiv.innerHTML = '<div class="rounded-lg bg-emerald-50 px-3 py-2 text-sm text-emerald-700">No heading hierarchy issues found.</div>';
      }

      el('outline').innerHTML = outline.map(h => {
        const level = parseInt(h.tag[1]);
        const indent = (level - 1) * 16;
        return '<div style="margin-left:' + indent + 'px" class="py-0.5 flex items-center gap-2"><span class="inline-flex items-center justify-center rounded bg-indigo-100 px-1.5 py-0.5 text-xs font-medium text-indigo-700">' + h.tag + '</span><span class="text-slate-700">' + h.text + '</span></div>';
      }).join('') || '<span class="text-slate-400">No headings found.</span>';

      const score = warnings.filter(w => w.type === 'error').length === 0 ? 'pass' : 'fail';
      if (score === 'pass') {
        el('score-icon').textContent = '&#x2705;';
        el('score-text').textContent = 'Pass';
        el('score-card').className = 'flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4';
        el('score-detail').textContent = 'Heading hierarchy looks good' + (warnings.length ? ' with ' + warnings.length + ' minor warning(s).' : '.');
      } else {
        el('score-icon').textContent = '&#x274c;';
        el('score-text').textContent = 'Fail';
        el('score-card').className = 'flex items-center gap-3 rounded-xl border border-rose-200 bg-rose-50 p-4';
        el('score-detail').textContent = warnings.filter(w => w.type === 'error').length + ' critical issue(s) found.';
      }

      el('results').classList.remove('hidden');
    }

    el('check-btn').addEventListener('click', check);
    el('clear-btn').addEventListener('click', () => {
      el('html-input').value = '';
      el('results').classList.add('hidden');
      el('html-input').focus();
    });
  </script>
</ToolLayout>
