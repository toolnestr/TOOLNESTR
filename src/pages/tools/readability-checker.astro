---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Text Readability Checker';
const description = 'Free online readability checker. Calculate Flesch-Kincaid Reading Ease, Grade Level, Gunning Fog Index and SMOG scores for any text.';
const intro = 'Paste any text to get comprehensive readability scores showing how easy or difficult it is to read.';
const category = { id: 'seo', name: 'SEO Tools' };
const faqs = [
  { q: 'What is the Flesch-Kincaid Reading Ease score?', a: 'It rates text on a 0-100 scale where higher scores mean easier readability. 90-100 is very easy, 60-70 is standard, and 0-30 is very difficult.' },
  { q: 'What is a good readability score for web content?', a: 'For general web content, aim for a Flesch-Kincaid Reading Ease of 60-70 and a Grade Level of 8-9. This matches the average reading ability of most adults.' },
  { q: 'How is the Gunning Fog Index calculated?', a: 'It estimates the years of formal education needed to understand the text based on sentence length and the percentage of complex words (3+ syllables).' },
  { q: 'What does the SMOG Index measure?', a: 'SMOG (Simple Measure of Gobbledygook) estimates the grade level required to understand text, focusing on polysyllabic word density.' },
  { q: 'Is my text sent to a server?', a: 'No. All calculations happen in your browser. Nothing is uploaded or stored.' },
  { q: 'What syllable count method is used?', a: 'Syllables are estimated by counting vowel groups. This gives a good approximation for English text.' },
  { q: 'Can I check very long texts?', a: 'Yes, but for best results use a representative sample of 100-500 words. Very long texts may cause brief browser lag.' },
  { q: 'Which score should I prioritize?', a: 'Flesch-Kincaid Reading Ease and Grade Level are the most widely used. Gunning Fog and SMOG provide additional confirmation.' },
  { q: 'What is the average words per sentence?', a: 'Most readability experts recommend an average of 15-20 words per sentence for good readability.' },
  { q: 'Do different audiences need different scores?', a: 'Yes. Children\'s content should score 80-90, general audience 60-70, academic content 30-50, and legal documents often below 30.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <span class="text-sm font-medium text-slate-700">Text to analyze</span>
    <textarea
      id="text-input"
      rows="8"
      placeholder="Paste your text here..."
      class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-4 text-base leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <button id="analyze-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Analyze readability</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
    </div>

    <div id="results" class="mt-4 hidden">
      <div class="grid gap-4 sm:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
          <span id="flesch-score" class="text-2xl font-bold text-indigo-600">0</span>
          <p class="text-xs text-slate-500">Flesch Reading Ease</p>
          <div id="flesch-bar" class="mt-2 h-2 w-full rounded-full bg-slate-200"><div class="h-2 rounded-full" style="width:0%"></div></div>
          <span id="flesch-label" class="text-xs text-slate-400"></span>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
          <span id="grade-score" class="text-2xl font-bold text-indigo-600">0</span>
          <p class="text-xs text-slate-500">Grade Level</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
          <span id="gunning-score" class="text-2xl font-bold text-indigo-600">0</span>
          <p class="text-xs text-slate-500">Gunning Fog Index</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
          <span id="smog-score" class="text-2xl font-bold text-indigo-600">0</span>
          <p class="text-xs text-slate-500">SMOG Index</p>
        </div>
      </div>

      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 p-3">
          <span id="total-sentences" class="text-lg font-bold text-slate-800">0</span>
          <p class="text-xs text-slate-500">Sentences</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-3">
          <span id="total-words" class="text-lg font-bold text-slate-800">0</span>
          <p class="text-xs text-slate-500">Words</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-3">
          <span id="total-syllables" class="text-lg font-bold text-slate-800">0</span>
          <p class="text-xs text-slate-500">Syllables</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-3">
          <span id="avg-words-per-sentence" class="text-lg font-bold text-slate-800">0</span>
          <p class="text-xs text-slate-500">Words/sentence</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-3">
          <span id="avg-syllables-per-word" class="text-lg font-bold text-slate-800">0</span>
          <p class="text-xs text-slate-500">Syllables/word</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-3">
          <span id="complex-words" class="text-lg font-bold text-slate-800">0</span>
          <p class="text-xs text-slate-500">Complex words (3+ syllables)</p>
        </div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How readability scores are calculated</h2>
    <p class="mt-2 text-slate-600">
      Readability formulas use two basic measurements: average sentence length and syllable count per word. The <strong>Flesch-Kincaid Reading Ease</strong> formula is: <code>206.835 − 1.015 × (total words ÷ total sentences) − 84.6 × (total syllables ÷ total words)</code>. The result is a 0–100 score where higher values mean easier reading.
    </p>
    <p class="mt-3 text-slate-600">
      The <strong>Grade Level</strong> converts the same inputs to a US school grade: <code>0.39 × (words ÷ sentences) + 11.8 × (syllables ÷ words) − 15.59</code>. The <strong>Gunning Fog Index</strong> counts complex words (3+ syllables) as <code>0.4 × ((words ÷ sentences) + 100 × (complex words ÷ words))</code>. The <strong>SMOG Index</strong> uses <code>1.0430 × √(30 × complex words ÷ sentences) + 3.1291</code>. Syllables are estimated by counting vowel groups.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Text: "The cat sat on the mat. It was a sunny day. The bird sang in the tree."</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Words:</span> <span class="text-slate-600">16</span></div>
        <div><span class="font-medium text-slate-700">Sentences:</span> <span class="text-slate-600">3</span></div>
        <div><span class="font-medium text-slate-700">Syllables:</span> <span class="text-slate-600">18</span></div>
        <div><span class="font-medium text-slate-700">Flesch-Kincaid:</span> <span class="text-slate-600"><strong>89.2</strong> (Very Easy)</span></div>
        <div><span class="font-medium text-slate-700">Grade Level:</span> <span class="text-slate-600"><strong>3.2</strong> (3rd grade)</span></div>
        <div><span class="font-medium text-slate-700">Gunning Fog:</span> <span class="text-slate-600"><strong>3.9</strong> (4th grade)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Reading ease score ranges</h2>
    <p class="mt-2 text-slate-600">Flesch-Kincaid Reading Ease scores and their interpretations.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Very easy (90-100)</span><span class="text-slate-400">Comics, children's books</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Easy (80-89)</span><span class="text-slate-400">YA fiction, magazines</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Fairly easy (70-79)</span><span class="text-slate-400">Popular novels, blogs</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Standard (60-69)</span><span class="text-slate-400">Newspapers, general web</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Fairly difficult (50-59)</span><span class="text-slate-400">Quality magazines, textbooks</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Difficult (30-49)</span><span class="text-slate-400">Academic, technical</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-rose-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Very difficult (0-29)</span><span class="text-slate-400">Legal, scientific papers</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-rose-600" style="width:20%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x270d;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Writer</h3>
      <p class="mt-1 text-sm text-slate-600">Uses readability scores to tailor content to the target audience and ensure the text is accessible to the intended readership.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4f0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Copywriter</h3>
      <p class="mt-1 text-sm text-slate-600">Optimizes marketing copy for readability to improve conversion rates and ensure key messages are easily understood.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4ac;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Blogger</h3>
      <p class="mt-1 text-sm text-slate-600">Aims for a Grade Level of 8-9 to reach the widest possible audience and improve engagement metrics.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Evaluates whether texts are appropriate for specific grade levels and identifies overly complex passages for students.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Publication Type</th><th class="p-3">Reading Ease</th><th class="p-3">Grade Level</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Comics / children's books</td><td class="p-3">90-100</td><td class="p-3">1-5</td></tr>
        <tr><td class="p-3 font-medium">Young adult fiction</td><td class="p-3">70-80</td><td class="p-3">6-8</td></tr>
        <tr><td class="p-3 font-medium">Newspapers</td><td class="p-3">60-70</td><td class="p-3">8-10</td></tr>
        <tr><td class="p-3 font-medium">Popular magazines</td><td class="p-3">60-75</td><td class="p-3">7-9</td></tr>
        <tr><td class="p-3 font-medium">Academic journals</td><td class="p-3">30-50</td><td class="p-3">12-16</td></tr>
        <tr><td class="p-3 font-medium">Legal documents</td><td class="p-3">10-30</td><td class="p-3">16+</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Readability Checker</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste text</h3>
        <p class="mt-1 text-sm text-slate-600">Copy the text you want to analyze and paste it into the input area. A sample of 100-500 words works best.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Click Analyze</h3>
        <p class="mt-1 text-sm text-slate-600">Click Analyze readability to compute all four readability scores and supporting statistics.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Interpret scores</h3>
        <p class="mt-1 text-sm text-slate-600">Compare scores against target ranges for your audience. Adjust sentence length and word choice to improve readability.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for improving readability</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Shorten sentences</h3>
        <p class="mt-1 text-sm text-slate-600">Aim for an average of 15-20 words per sentence. Split long sentences into shorter, clearer ones.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use simpler words</h3>
        <p class="mt-1 text-sm text-slate-600">Replace multi-syllable words with shorter alternatives where possible. Prefer everyday vocabulary over jargon.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Know your audience</h3>
        <p class="mt-1 text-sm text-slate-600">General web content should target Grade Level 8-9. Technical content can be higher, but always consider the reader's background.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is readability</h2>
    <p class="mt-2 text-slate-600">
      Readability measures how easy a text is to read and understand. It considers factors like sentence length, syllable count, and word complexity. Readability scores help writers ensure their content matches the reading ability of their target audience.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Different formulas explained</h2>
    <p class="mt-2 text-slate-600">
      The Flesch-Kincaid Reading Ease scores text from 0 (very difficult) to 100 (very easy) based on syllables per word and words per sentence. The Grade Level formula converts this to a US school grade. Gunning Fog focuses on complex words (3+ syllables). SMOG is particularly accurate for health and technical content.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Target scores by audience</h2>
    <p class="mt-2 text-slate-600">
      For general web content, target a Flesch-Kincaid Reading Ease of 60-70 and Grade Level 8-9. Marketing copy benefits from 70-80. Academic content falls at 30-50. Legal documents typically score below 30. Understanding your audience is key to choosing the right target.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Limitations and considerations of readability formulas</h2>
    <p class="mt-2 text-slate-600">
      Readability formulas are powerful tools, but they have important limitations that every user should understand. The most significant limitation is that these formulas measure only surface-level text features — sentence length and syllable count — and do not evaluate meaning, coherence, clarity, or organization. A text with short sentences and simple words can still be confusing if the ideas are poorly structured, and conversely, a well-organized text with some longer sentences can be perfectly readable.
    </p>
    <p class="mt-3 text-slate-600">
      Readability scores are also language-dependent. All major formulas were developed for English text and may not transfer well to other languages. Spanish, French, and German have different syllable patterns and sentence structures that can produce misleading scores. Some languages have their own adapted readability formulas, but these are less common and less standardized than the English-based ones that our checker uses.
    </p>
    <p class="mt-3 text-slate-600">
      Another consideration is that readability formulas do not account for domain-specific vocabulary. Technical terms that are familiar to a specialist audience may be marked as "complex" by the formula because they have multiple syllables, but they are perfectly appropriate for that audience. The SMOG and Gunning Fog indices are particularly sensitive to this, as they heavily weigh polysyllabic words regardless of context or audience familiarity with the terminology.
    </p>
    <p class="mt-3 text-slate-600">
      Finally, readability scores should be used as guidelines, not absolute rules. A Flesch-Kincaid score of 55 might be perfectly appropriate for a quality magazine article aimed at educated adults, even though the formula labels it "fairly difficult." The best approach is to use readability scores as one input in your writing process, combined with human judgment about your specific audience, purpose, and context. No formula can replace a thoughtful editor.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function countSyllables(word) {
      word = word.toLowerCase().replace(/[^a-z]/g, '');
      if (!word) return 0;
      if (word.length <= 3) return 1;
      const vowels = word.match(/[aeiouy]+/g);
      let count = vowels ? vowels.length : 0;
      if (word.endsWith('e') && !word.endsWith('le')) count--;
      if (word.endsWith('le') && word.length > 2 && !'aeiouy'.includes(word[word.length-3])) count++;
      if (word.endsWith('es') || word.endsWith('ed')) count = Math.max(count - 1, 1);
      return Math.max(count, 1);
    }

    function analyze() {
      const text = el('text-input').value.trim();
      if (!text) { el('results').classList.add('hidden'); return; }

      const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
      const words = text.split(/[\s\n\r]+/).filter(w => w.length > 0).filter(w => /[a-zA-Z]/.test(w));
      if (!words.length) { el('results').classList.add('hidden'); return; }

      const totalSentences = sentences.length;
      const totalWords = words.length;
      const totalSyllables = words.reduce((s, w) => s + countSyllables(w), 0);
      const complexWords = words.filter(w => countSyllables(w) >= 3).length;

      const avgWordsPerSentence = totalWords / totalSentences;
      const avgSyllablesPerWord = totalSyllables / totalWords;

      const flesch = 206.835 - 1.015 * avgWordsPerSentence - 84.6 * avgSyllablesPerWord;
      const fleschClamped = Math.round(Math.max(0, Math.min(100, flesch)));
      const gradeLevel = 0.39 * avgWordsPerSentence + 11.8 * avgSyllablesPerWord - 15.59;
      const gradeClamped = Math.round(Math.max(1, Math.min(20, gradeLevel)) * 10) / 10;
      const gunning = 0.4 * (avgWordsPerSentence + 100 * (complexWords / totalWords));
      const gunningClamped = Math.round(Math.max(1, Math.min(20, gunning)) * 10) / 10;

      const smogRaw = 1.0430 * Math.sqrt(complexWords * (30 / totalSentences)) + 3.1291;
      const smogClamped = Math.round(Math.max(1, Math.min(20, smogRaw)) * 10) / 10;

      el('flesch-score').textContent = fleschClamped;
      el('grade-score').textContent = gradeClamped;
      el('gunning-score').textContent = gunningClamped;
      el('smog-score').textContent = smogClamped;
      el('total-sentences').textContent = totalSentences;
      el('total-words').textContent = totalWords;
      el('total-syllables').textContent = totalSyllables;
      el('avg-words-per-sentence').textContent = avgWordsPerSentence.toFixed(1);
      el('avg-syllables-per-word').textContent = avgSyllablesPerWord.toFixed(2);
      el('complex-words').textContent = complexWords;

      const bar = el('flesch-bar').querySelector('div');
      bar.style.width = fleschClamped + '%';
      if (fleschClamped >= 70) bar.className = 'h-2 rounded-full bg-emerald-500';
      else if (fleschClamped >= 50) bar.className = 'h-2 rounded-full bg-indigo-500';
      else if (fleschClamped >= 30) bar.className = 'h-2 rounded-full bg-amber-400';
      else bar.className = 'h-2 rounded-full bg-rose-500';

      let label;
      if (fleschClamped >= 90) label = 'Very easy';
      else if (fleschClamped >= 80) label = 'Easy';
      else if (fleschClamped >= 70) label = 'Fairly easy';
      else if (fleschClamped >= 60) label = 'Standard';
      else if (fleschClamped >= 50) label = 'Fairly difficult';
      else if (fleschClamped >= 30) label = 'Difficult';
      else label = 'Very difficult';
      el('flesch-label').textContent = label;

      el('results').classList.remove('hidden');
    }

    el('analyze-btn').addEventListener('click', analyze);
    el('clear-btn').addEventListener('click', () => {
      el('text-input').value = '';
      el('results').classList.add('hidden');
      el('text-input').focus();
    });
  </script>
</ToolLayout>
