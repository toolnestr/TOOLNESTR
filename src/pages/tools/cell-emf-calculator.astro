---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Cell EMF Calculator';
const description = 'Cell EMF calculator with a live 3D galvanic cell diagram and charts. Find the standard cell potential from cathode and anode reduction potentials, plus Gibbs free energy and spontaneity, with worked examples.';
const intro = 'Solve E¬įcell = E¬įcathode ‚ąí E¬įanode for the standard electromotive force of a galvanic cell, and use it to find the standard Gibbs free energy change and predict spontaneity. Two 3D diagrams show a galvanic cell\'s electron flow and compare a spontaneous cell to a non-spontaneous one, with charts comparing common half-cell potentials.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: 'ūüß™' };

const faqs = [
  { q: 'What is cell EMF (electromotive force)?', a: 'Cell EMF, or standard cell potential E¬įcell, is the maximum voltage a galvanic cell can produce under standard conditions, found from E¬įcell = E¬įcathode ‚ąí E¬įanode using standard reduction potentials for each half-reaction.' },
  { q: 'How do you know which electrode is the cathode and which is the anode?', a: 'The half-reaction with the higher (more positive) standard reduction potential becomes the cathode, where reduction occurs. The half-reaction with the lower reduction potential becomes the anode, where oxidation occurs (reversed from its tabulated reduction direction).' },
  { q: 'What does a positive E¬įcell mean?', a: 'A positive E¬įcell means the cell reaction is spontaneous as written, and the cell can do electrical work ‚ÄĒ this is the situation in any working battery. A negative E¬įcell means the reaction is non-spontaneous in that direction and requires external energy input (electrolysis) to proceed.' },
  { q: 'How is E¬įcell related to Gibbs free energy?', a: 'őĒG¬į = ‚ąínFE¬įcell, where n is the number of electrons transferred and F is Faraday\'s constant (96,485 C/mol). A positive E¬įcell always corresponds to a negative őĒG¬į, confirming the reaction is thermodynamically spontaneous.' },
  { q: 'Does E¬įcell depend on how the equation is balanced?', a: 'No ‚ÄĒ standard reduction potentials are intensive properties (per electron transferred), so E¬įcell stays the same no matter how you scale the balanced equation. Only őĒG¬į (which depends on n) changes with the stoichiometric scaling.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Cell EMF Calculator',
  description: 'Find the standard cell potential and Gibbs free energy change from cathode and anode reduction potentials.',
  steps: [
    { name: 'Enter the two half-cell potentials', text: 'Provide the standard reduction potential for the cathode (reduction) and the anode (before reversal).' },
    { name: 'Enter the number of electrons transferred', text: 'Provide n, the number of electrons transferred in the balanced overall cell reaction.' },
    { name: 'Read the result', text: 'E¬įcell and őĒG¬į solve instantly, along with whether the reaction is spontaneous.' },
  ],
};

const formulas = [
  { expr: 'E¬įcell = E¬įcathode ‚ąí E¬įanode', note: 'standard cell potential from standard reduction potentials' },
  { expr: 'őĒG¬į = ‚ąínFE¬įcell', note: 'Gibbs free energy ‚ÄĒ F = 96,485 C/mol (Faraday\'s constant)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 ‚ÄĒ the Daniell cell (Zn‚ÄďCu)', tone: 'slate',
    given: 'A zinc-copper galvanic cell: cathode Cu¬≤‚Āļ/Cu has E¬į = +0.34 V, anode Zn¬≤‚Āļ/Zn has E¬į = ‚ąí0.76 V, with n = 2 electrons transferred.',
    rows: [
      { label: 'Formula:', value: 'E¬įcell = E¬įcathode ‚ąí E¬įanode' },
      { label: 'Substitute:', value: 'E¬įcell = 0.34 ‚ąí (‚ąí0.76) = 1.10 V' },
      { label: 'Gibbs free energy:', value: 'őĒG¬į = ‚ąínFE¬įcell = ‚ąí2 √ó 96,485 √ó 1.10 ‚Čą ‚ąí212,267 J/mol ‚Čą ‚ąí212.3 kJ/mol', full: true },
    ],
    note: 'Positive E¬įcell and negative őĒG¬į both confirm this classic cell is spontaneous ‚ÄĒ the same reaction that powers a simple zinc-copper battery.',
  },
  {
    title: 'Worked example 2 ‚ÄĒ a silver-nickel cell', tone: 'amber',
    given: 'Cathode Ag‚Āļ/Ag has E¬į = +0.80 V, anode Ni¬≤‚Āļ/Ni has E¬į = ‚ąí0.25 V, with n = 2 electrons transferred overall (2Ag‚Āļ + Ni ‚Üí 2Ag + Ni¬≤‚Āļ).',
    rows: [
      { label: 'Formula:', value: 'E¬įcell = E¬įcathode ‚ąí E¬įanode' },
      { label: 'Substitute:', value: 'E¬įcell = 0.80 ‚ąí (‚ąí0.25) = 1.05 V' },
      { label: 'Gibbs free energy:', value: 'őĒG¬į = ‚ąínFE¬įcell = ‚ąí2 √ó 96,485 √ó 1.05 ‚Čą ‚ąí202,618.5 J/mol ‚Čą ‚ąí202.6 kJ/mol', full: true },
    ],
    note: 'Again positive E¬įcell and negative őĒG¬į ‚ÄĒ silver ions spontaneously oxidize nickel metal, plating out silver in the process.',
  },
];

const comparison = {
  heading: 'Standard reduction potentials for common half-cells',
  note: 'A higher (more positive) reduction potential means a species is more easily reduced ‚ÄĒ pairing any two half-cells, the higher one becomes the cathode.',
  headers: [{ label: 'Half-reaction' }, { label: 'E¬į (V)' }],
  rows: [
    ['F‚āā + 2e‚ĀĽ ‚Üí 2F‚ĀĽ', '+2.87'],
    ['Ag‚Āļ + e‚ĀĽ ‚Üí Ag', '+0.80'],
    ['Cu¬≤‚Āļ + 2e‚ĀĽ ‚Üí Cu ‚ėÖ', '+0.34'],
    ['2H‚Āļ + 2e‚ĀĽ ‚Üí H‚āā', '0.00'],
    ['Ni¬≤‚Āļ + 2e‚ĀĽ ‚Üí Ni', '‚ąí0.25'],
    ['Zn¬≤‚Āļ + 2e‚ĀĽ ‚Üí Zn', '‚ąí0.76'],
    ['Li‚Āļ + e‚ĀĽ ‚Üí Li', '‚ąí3.04'],
  ],
  highlightIndex: 2,
  footnote: '‚ėÖ Reference row (worked example 1). Fluorine is the strongest common oxidizer (most positive E¬į); lithium metal is the strongest common reducer (most negative E¬į).',
};

const realWorld = [
  { emoji: 'ūüĒč', title: 'Battery design', body: 'Battery manufacturers pick electrode materials specifically for the size of E¬įcell they produce and how well they hold up over repeated charge/discharge cycles ‚ÄĒ this calculation is the starting point for every battery chemistry.' },
  { emoji: '‚ö°', title: 'Corrosion protection (galvanization)', body: "Zinc is used to coat steel (galvanization) because zinc's very negative reduction potential makes it corrode preferentially, sacrificially protecting the more valuable steel underneath ‚ÄĒ a direct application of comparing standard potentials." },
  { emoji: 'ūüĒ¨', title: 'Electroplating', body: 'Electroplating processes rely on carefully chosen cell potentials to deposit a thin, controlled layer of metal (like silver or chromium) onto another surface via a spontaneous or driven redox reaction.' },
  { emoji: 'ūüöó', title: 'Electric vehicle battery chemistry', body: 'Choosing electrode materials with a large E¬įcell (like lithium-based chemistries) is central to maximizing the energy density of rechargeable batteries used in electric vehicles and portable electronics.' },
];

const misconceptions = [
  { claim: '"A negative E¬įcell means the reaction cannot happen at all."', truth: 'A negative E¬įcell means the reaction is non-spontaneous as written under standard conditions ‚ÄĒ it can still be driven forward by supplying external electrical energy, which is exactly what happens in electrolysis.' },
  { claim: '"Doubling the balanced equation doubles E¬įcell."', truth: 'E¬įcell is an intensive property (voltage per electron transferred) and does not change when you scale the balanced equation ‚ÄĒ only őĒG¬į (which depends on the total moles of electrons, n) scales with the equation.' },
  { claim: '"The half-reaction with the larger E¬į value is always the anode."', truth: "It's the opposite ‚ÄĒ the half-reaction with the higher (more positive) reduction potential becomes the cathode, where reduction happens. The lower-potential half-reaction becomes the anode, running in reverse (as oxidation)." },
  { claim: '"E¬įcell tells you how fast a reaction will occur."', truth: 'E¬įcell (and the related őĒG¬į) describes only whether a reaction is thermodynamically favorable, not how quickly it proceeds ‚ÄĒ reaction rate is a kinetics question, governed by factors like activation energy, not by cell potential.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> ‚ÄĒ Chapter 17, "Electrochemistry" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/17-2-galvanic-cells" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> ‚ÄĒ Chapter 20, Electrochemistry.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> ‚ÄĒ Standard reduction potentials and cell EMF.' },
];
const sourcesNote = 'E¬įcell = E¬įcathode ‚ąí E¬įanode; őĒG¬į = ‚ąínFE¬įcell with F = 96,485 C/mol. Standard reduction potentials are textbook reference values measured at 25¬įC, 1 atm, 1 M concentrations. Results are rounded for display.';

const howToUse = [
  { title: 'Enter cathode and anode potentials', body: 'Provide the standard reduction potentials for both half-reactions (in volts).' },
  { title: 'Enter n (electrons transferred)', body: 'Provide the number of electrons transferred in the overall balanced cell reaction.' },
  { title: 'Read the result', body: 'E¬įcell and őĒG¬į solve live, along with a spontaneity verdict.' },
];

const related = [
  { href: '/tools/nernst-equation-calculator', emoji: 'ūüĒč', title: 'Nernst Equation Calculator', desc: 'E_cell = E¬į_cell ‚ąí (0.0592/n)log(Q) at 25¬įC.' },
  { href: '/tools/gibbs-free-energy-calculator', emoji: '‚ě°ÔłŹ', title: 'Gibbs Free Energy Calculator', desc: 'őĒG = őĒH ‚ąí TőĒS ‚ÄĒ solve any variable, plus spontaneity.' },
  { href: '/tools/faradays-law-calculator', emoji: 'ūü™ę', title: "Faraday's Law of Electrolysis Calculator", desc: 'm = (I√ót√óM)/(n√óF) ‚ÄĒ mass deposited during electrolysis.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a galvanic cell's voltage is simply the difference between how badly one half-reaction 'wants' electrons (the cathode) and how badly the other 'wants' to give them up (the anode) ‚ÄĒ a bigger gap between the two means a stronger cell."
  howIntro="Standard reduction potentials rank every half-reaction on a common scale of how favorably it accepts electrons. Pairing any two half-cells, the one with the higher reduction potential runs forward as written (reduction, at the cathode), while the one with the lower potential is forced to run in reverse (oxidation, at the anode) ‚ÄĒ subtracting the anode's potential from the cathode's gives E¬įcell = E¬įcathode ‚ąí E¬įanode. Once E¬įcell is known, őĒG¬į = ‚ąínFE¬įcell converts that voltage directly into the thermodynamic free-energy change, confirming spontaneity whenever E¬įcell is positive."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where cell EMF actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Cathode E¬į (V)</span>
        <input id="Ecat" type="number" step="any" value="0.34" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Anode E¬į (V)</span>
        <input id="Ean" type="number" step="any" value="-0.76" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Electrons transferred (n)</span>
        <input id="n" type="number" step="1" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Standard cell potential E¬įcell</div><div id="r-ecell" class="mt-1 text-2xl font-bold">‚ÄĒ</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Gibbs free energy őĒG¬į</div><div id="r-dg" class="mt-1 text-2xl font-bold text-slate-800">‚ÄĒ</div></div>
    </div>
    <p id="emf-verdict" class="mt-3 text-center text-sm font-semibold"></p>
    <p id="emf-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Inside a galvanic cell</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-cell" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Electron flow in a galvanic cell</h3>
          <p class="mt-1 text-sm text-slate-600">Electrons flow from the anode (oxidation, left) through the external wire to the cathode (reduction, right) ‚ÄĒ the direct source of the cell's usable current.</p>
        </div>
        <div>
          <div id="diag-spont" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Spontaneous vs non-spontaneous cells</h3>
          <p class="mt-1 text-sm text-slate-600">A tall <span class="font-semibold text-amber-500">positive-E¬įcell</span> bar (spontaneous) versus a short <span class="font-semibold text-slate-500">negative-E¬įcell</span> bar (needs external energy).</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Cell EMF graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Common standard reduction potentials</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-potentials"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">őĒG¬į vs E¬įcell (fixed n=2)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dg"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const F = 96485;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('emf-err').textContent = ''; el('emf-verdict').textContent = '';
        el('r-ecell').textContent = '‚ÄĒ'; el('r-dg').textContent = '‚ÄĒ';
        const Ecat = parseFloat(el('Ecat').value), Ean = parseFloat(el('Ean').value), n = parseFloat(el('n').value);
        if (isNaN(Ecat) || isNaN(Ean) || isNaN(n)) return;
        if (n <= 0) { el('emf-err').textContent = 'Number of electrons transferred must be greater than 0.'; return; }
        const Ecell = Ecat - Ean;
        const dG = -n * F * Ecell;
        el('r-ecell').textContent = fmt(Ecell) + ' V';
        el('r-dg').textContent = fmt(dG / 1000) + ' kJ/mol';
        el('emf-verdict').className = 'mt-3 text-center text-sm font-semibold ' + (Ecell >= 0 ? 'text-green-600' : 'text-red-600');
        el('emf-verdict').textContent = Ecell >= 0 ? 'Spontaneous (E¬įcell ‚Č• 0, őĒG¬į ‚Č§ 0)' : 'Non-spontaneous (E¬įcell < 0, őĒG¬į > 0)';
      }
      ['Ecat', 'Ean', 'n'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const half = [{ n: 'F‚āā/F‚ĀĽ', e: 2.87 }, { n: 'Ag‚Āļ/Ag', e: 0.80 }, { n: 'Cu¬≤‚Āļ/Cu', e: 0.34 }, { n: 'H‚Āļ/H‚āā', e: 0 }, { n: 'Ni¬≤‚Āļ/Ni', e: -0.25 }, { n: 'Zn¬≤‚Āļ/Zn', e: -0.76 }, { n: 'Li‚Āļ/Li', e: -3.04 }];
        charts.potentials = new Chart(el('chart-potentials'), {
          type: 'bar',
          data: { labels: half.map((h) => h.n), datasets: [{ label: 'E¬į (V)', data: half.map((h) => h.e), backgroundColor: half.map((h) => (h.e >= 0 ? '#6366f1' : '#f59e0b')) }] },
          options: Object.assign({}, base, { indexAxis: 'y', scales: { x: { title: { display: true, text: 'E¬į (V)' } } }, plugins: { legend: { display: false } } }),
        });
        const labels = [], data = [];
        for (let e = -2; e <= 2; e += 0.25) { labels.push(e.toFixed(2)); data.push(+(-2 * F * e / 1000).toFixed(1)); }
        charts.dg = new Chart(el('chart-dg'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'őĒG¬į (kJ/mol)', data, borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'E¬įcell (V)' } }, y: { title: { display: true, text: 'őĒG¬į (kJ/mol)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: galvanic cell electron flow ----
      let diagCell = null;
      function initDiagCell() {
        const c = el('diag-cell'); if (!c) throw new Error('no container');
        const s = makeScene(c, 11, new THREE.Vector3(0, 0, 0), OPTS);
        const beakerMat = new THREE.MeshStandardMaterial({ color: 0xbfdbfe, roughness: 0.3, transparent: true, opacity: 0.5 });
        const beaker1 = new THREE.Mesh(new THREE.CylinderGeometry(1.1, 1.1, 2.2, 24, 1, true), beakerMat);
        beaker1.position.set(-2.2, 0, 0); s.scene.add(beaker1);
        const beaker2 = new THREE.Mesh(new THREE.CylinderGeometry(1.1, 1.1, 2.2, 24, 1, true), beakerMat);
        beaker2.position.set(2.2, 0, 0); s.scene.add(beaker2);
        const anode = new THREE.Mesh(new THREE.BoxGeometry(0.3, 1.8, 0.3), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5 }));
        anode.position.set(-2.2, 0.2, 0); s.scene.add(anode);
        const cathode = new THREE.Mesh(new THREE.BoxGeometry(0.3, 1.8, 0.3), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.5 }));
        cathode.position.set(2.2, 0.2, 0); s.scene.add(cathode);
        s.scene.add(arrow(new THREE.Vector3(-2.2, 1.6, 0), new THREE.Vector3(2.2, 1.6, 0), 0xef4444));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagCell = { resize: s.resize };
      }

      // ---- Diagram 2: spontaneous vs non-spontaneous bars ----
      let diagSpont = null;
      function initDiagSpont() {
        const c = el('diag-spont'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 1, 0), OPTS);
        const bar1 = new THREE.Mesh(new THREE.BoxGeometry(1, 2.4, 1), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5 }));
        bar1.position.set(-1.3, 1.2, 0); s.scene.add(bar1);
        const bar2 = new THREE.Mesh(new THREE.BoxGeometry(1, 0.6, 1), new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.5 }));
        bar2.position.set(1.3, 0.3, 0); s.scene.add(bar2);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagSpont = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[cell-emf] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[cell-emf] charts failed', e); }
        if (window.THREE) {
          try { initDiagCell(); } catch (e) { console.error('[cell-emf] cell diagram failed', e); }
          try { initDiagSpont(); } catch (e) { console.error('[cell-emf] spontaneity diagram failed', e); }
        }
        mountResize([diagCell, diagSpont]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
