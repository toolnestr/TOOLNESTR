      '00FC8B': 'Amazon Technologies',
      '04006E': 'Google',
      '0418D6': 'Ubiquiti Networks',
      '04C8B0': 'Google',
      '088BC8': 'Google',
      '0CEA14': 'Ubiquiti Networks',
      '18E829': 'Ubiquiti Networks',
      '28CDC1': 'Raspberry Pi',
      '2CCF67': 'Raspberry Pi',
      '3A3541': 'Raspberry Pi',
      '88A29E': 'Raspberry Pi',
      '98FE54': 'Raspberry Pi',
    };

    const el = (id) => document.getElementById(id);
    const input = el('mac-input');
    const btn = el('mac-lookup-btn');

    function normalizeMac(str) {
      let s = str.trim().toUpperCase().replace(/[^0-9A-F]/g, '');
      if (s.length !== 12) return null;
      return s;
    }

    function formatMac(str) {
      return str.match(/.{2}/g).join(':');
    }

    function getMacType(firstOctet) {
      const val = parseInt(firstOctet, 16);
      const isMulticast = !!(val & 1);
      const isLocal = !!(val & 2);
      let type = 'Unicast';
      if (isMulticast && formatMac(firstOctet + '0000000000') === 'FF:FF:FF:FF:FF:FF') type = 'Broadcast';
      else if (isMulticast) type = 'Multicast';
      return type + (isLocal ? ' (locally administered)' : ' (universally administered)');
    }

    function lookup() {
      const normalized = normalizeMac(input.value);
      const output = el('mac-output');
      if (!normalized) {
        output.classList.add('hidden');
        return;
      }
      output.classList.remove('hidden');

      const oui = normalized.slice(0, 6);
      const vendor = ouiMap[oui] || 'Unknown vendor (not in embedded database)';
      const isKnown = ouiMap.hasOwnProperty(oui);

      el('mac-full').textContent = formatMac(normalized);
      el('mac-oui').textContent = formatMac(oui + '000000');
      el('mac-vendor').textContent = vendor;

      const type = getMacType(normalized.slice(0, 2));
      el('mac-type').textContent = type;

      const badge = el('mac-badge');
      badge.textContent = isKnown ? 'Vendor Found' : 'Unknown OUI';
      badge.className = 'inline-block rounded-full px-3 py-1 text-sm font-semibold ' + (isKnown ? 'bg-emerald-100 text-emerald-800' : 'bg-yellow-100 text-yellow-800');
    }

    function populateOuiTable() {
      const tbody = el('oui-table-body');
      const entries = Object.entries(ouiMap);
      const shown = entries.slice(0, 15);
      tbody.innerHTML = shown
        .map(([oui, vendor]) =>
          '<tr class="border-b border-slate-100"><td class="py-1 font-mono text-xs">' +
          formatMac(oui + '000000') + '</td><td class="py-1 text-xs">' + vendor + '</td></tr>'
        )
        .join('');
    }

    btn.addEventListener('click', lookup);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') lookup(); });
    populateOuiTable();
  </script>
</ToolLayout>
