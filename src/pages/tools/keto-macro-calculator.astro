---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Keto Macro Calculator';
const description =
  'Get your daily fat, protein, and carb targets in grams for a ketogenic diet based on your calorie goal.';
const intro =
  'Get your daily fat, protein, and carb targets for a ketogenic diet.';
const category = { id: 'health', name: 'Health' };
const faqs = [
  { q: 'How many carbs on keto?', a: 'Commonly 20–50 g net carbs per day to maintain ketosis.' },
  { q: 'What is the macro split?', a: 'Roughly 70% fat, 25% protein, 5% carbs by calories — adjust to your needs.' },
  { q: 'Is keto safe for everyone?', a: 'Not necessarily — consult a doctor, especially with medical conditions.' },
  { q: 'Can too much protein kick me out of ketosis?', a: 'For some people, excess protein can be converted to glucose — keep it moderate.' },
];

const seoTitle = 'Keto Macro Calculator — Daily Fat, Protein & Carb Targets';
const seoDesc =
  'Calculate your daily keto macros — fat, protein, and carbs in grams — from your calorie target and goal. Free ketogenic diet macro calculator.';
const sources = [
  { html: "<strong>NIH / National Institutes of Health</strong> and <strong>CDC</strong> reference values and formulas. <a href=\"https://www.nih.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nih.gov</a>" },
  { html: "<strong>Peer-reviewed equations</strong> (e.g. Mifflin-St Jeor, Harris-Benedict) as originally published." },
  { html: "<strong>ACOG</strong> for pregnancy, ovulation and due-date methodology. <a href=\"https://www.acog.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">acog.org</a>" },
];
const sourcesNote = "Not medical advice. Estimates only — consult a qualified healthcare professional for any personal health decision.";

---

<ToolLayout title={seoTitle} description={seoDesc} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <!-- Goal toggle -->
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="g-lose" class="flex-1 rounded-lg py-2 text-slate-500">Lose</button>
      <button id="g-maintain" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Maintain</button>
      <button id="g-gain" class="flex-1 rounded-lg py-2 text-slate-500">Gain</button>
    </div>

    <div class="grid gap-4">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Daily calorie target</span>
        <input id="calories" type="number" step="any" placeholder="e.g. 2000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Max carbs (g)</span>
          <input id="carbs" type="number" step="any" value="25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Protein per kg body weight (g)</span>
          <input id="protein" type="number" step="any" value="1.6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </label>
      </div>

      <label class="block">
        <span class="text-sm font-medium text-slate-700">Body weight (kg)</span>
        <input id="weight" type="number" step="any" placeholder="e.g. 75" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>

    <button id="calc-btn" class="mt-4 w-full rounded-xl bg-indigo-600 py-3 font-semibold text-white transition hover:bg-indigo-700">Calculate macros</button>

    <!-- Result -->
    <div id="result" class="mt-6 hidden space-y-4">
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-indigo-50 p-4 text-center">
          <div class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Fat</div>
          <div id="r-fat-g" class="mt-1 text-2xl font-bold text-slate-900">—</div>
          <div id="r-fat-cal" class="text-sm text-slate-500">— cal</div>
          <div id="r-fat-pct" class="mt-1 inline-block rounded-full bg-indigo-200 px-3 py-0.5 text-xs font-bold text-indigo-800">—%</div>
        </div>
        <div class="rounded-xl bg-emerald-50 p-4 text-center">
          <div class="text-xs font-semibold uppercase tracking-wide text-emerald-600">Protein</div>
          <div id="r-protein-g" class="mt-1 text-2xl font-bold text-slate-900">—</div>
          <div id="r-protein-cal" class="text-sm text-slate-500">— cal</div>
          <div id="r-protein-pct" class="mt-1 inline-block rounded-full bg-emerald-200 px-3 py-0.5 text-xs font-bold text-emerald-800">—%</div>
        </div>
        <div class="rounded-xl bg-amber-50 p-4 text-center">
          <div class="text-xs font-semibold uppercase tracking-wide text-amber-600">Carbs</div>
          <div id="r-carbs-g" class="mt-1 text-2xl font-bold text-slate-900">—</div>
          <div id="r-carbs-cal" class="text-sm text-slate-500">— cal</div>
          <div id="r-carbs-pct" class="mt-1 inline-block rounded-full bg-amber-200 px-3 py-0.5 text-xs font-bold text-amber-800">—%</div>
        </div>
      </div>
      <div id="r-total" class="text-center text-sm font-medium text-slate-600"></div>
      <div id="r-goal" class="text-center text-xs text-slate-400"></div>
    </div>

    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your calorie target, body weight, and macros to calculate your keto targets.</p>
  </div>

  <p class="mt-4 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">
    ⚕️ For general information only, not medical advice. Consult a healthcare professional before starting any diet.
  </p>

  <!-- SVG pie chart: 70/25/5 split -->
  <figure class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Typical keto macro split</h2>
    <p class="mt-2 text-sm text-slate-600">A standard ketogenic diet splits daily calories roughly 70% fat, 25% protein, and 5% carbs.</p>
    <svg class="mx-auto mt-4" width="320" height="320" viewBox="0 0 320 320" role="img" aria-labelledby="pie-title pie-desc">
      <title id="pie-title">Keto macro pie chart: 70% fat, 25% protein, 5% carbs</title>
      <desc id="pie-desc">A pie chart showing the typical ketogenic diet macro split — 70 percent fat, 25 percent protein, 5 percent carbohydrates.</desc>
      <!-- Fat 70% (starts top, sweeps 252° clockwise) -->
      <path d="M 160 160 L 160 40 A 120 120 0 1 1 46 197 Z" fill="#6366f1" />
      <!-- Protein 25% (sweeps 90° clockwise) -->
      <path d="M 160 160 L 46 197 A 120 120 0 0 1 123 46 Z" fill="#22c55e" />
      <!-- Carbs 5% (sweeps 18° clockwise) -->
      <path d="M 160 160 L 123 46 A 120 120 0 0 1 160 40 Z" fill="#eab308" />
      <circle cx="160" cy="160" r="60" fill="#fff" />
      <text x="160" y="155" text-anchor="middle" font-size="22" font-weight="bold" fill="#1e293b">70/25/5</text>
      <text x="160" y="175" text-anchor="middle" font-size="11" fill="#64748b">% split</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Approximate calorie distribution on a standard ketogenic diet</figcaption>
  </figure>

  <!-- How keto macros are calculated -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How keto macros are calculated</h2>
    <p class="mt-2 text-slate-600">
      This calculator works backwards from your daily calorie target. It first assigns a fixed carb
      limit (you choose the number of grams), then calculates your protein based on your body weight,
      and finally fills the remaining calories with fat. The formulas are straightforward:
    </p>
    <div class="mt-4 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Carb calories</p>
        <p class="mt-1 text-slate-600">carbs (g) × 4 = carb calories</p>
        <p class="mt-1 text-sm text-slate-500">Example: 25 g × 4 = <strong>100 cal</strong></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Protein calories</p>
        <p class="mt-1 text-slate-600">protein (g) × 4 = protein calories</p>
        <p class="mt-1 text-sm text-slate-500">Example: 120 g × 4 = <strong>480 cal</strong></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Fat calories and grams</p>
        <p class="mt-1 text-slate-600">fat calories = total calories − carb calories − protein calories</p>
        <p class="mt-1 text-slate-600">fat (g) = fat calories ÷ 9</p>
        <p class="mt-1 text-sm text-slate-500">Example: 2,000 − 100 − 480 = 1,420 cal → 1,420 ÷ 9 ≈ <strong>158 g</strong></p>
      </div>
    </div>
  </section>

  <!-- Worked example -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A person following a 2,000-calorie ketogenic diet with 25 g of carbs and 1.6 g of protein per kg (75 kg body weight) would get:</p>
      <div class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Calorie target:</span> <span class="text-slate-600">2,000 cal</span></div>
        <div><span class="font-medium text-slate-700">Body weight:</span> <span class="text-slate-600">75 kg</span></div>
        <div><span class="font-medium text-slate-700">Carbs:</span> <span class="text-slate-600">25 g × 4 = 100 cal (5%)</span></div>
        <div><span class="font-medium text-slate-700">Protein:</span> <span class="text-slate-600">75 × 1.6 = 120 g × 4 = 480 cal (24%)</span></div>
        <div><span class="font-medium text-slate-700">Fat:</span> <span class="text-slate-600">2,000 − 100 − 480 = 1,420 cal ÷ 9 ≈ 158 g (71%)</span></div>
        <div><span class="font-medium text-slate-700">Total:</span> <span class="text-slate-600">2,000 cal ✓</span></div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Starting keto</h3>
        <p class="mt-1 text-sm text-slate-600">New to the ketogenic diet? Use this tool to set your initial macro targets so you know exactly how many grams of each nutrient to eat every day.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Recalculating after weight change</h3>
        <p class="mt-1 text-sm text-slate-600">As you lose or gain weight, your protein needs change. Re-run the calculator with your new body weight to keep your macros accurate.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Meal planning</h3>
        <p class="mt-1 text-sm text-slate-600">Use your macro targets as a framework for building keto-friendly meals. Knowing your daily fat, protein, and carb limits makes grocery shopping and meal prep easier.</p>
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for success on keto</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Keep protein moderate</h3>
        <p class="mt-1 text-sm text-slate-600">Too little protein can lead to muscle loss; too much can be converted to glucose via gluconeogenesis and potentially interfere with ketosis. The 1.2–2.0 g per kg of body weight range works for most people.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Track net carbs, not total carbs</h3>
        <p class="mt-1 text-sm text-slate-600">Net carbs = total carbs − fibre − sugar alcohols. Fibre doesn't affect blood sugar, so subtract it from your total to get the number that matters for ketosis. Many vegetables and nuts are keto-friendly once you account for fibre.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Don't fear healthy fats</h3>
        <p class="mt-1 text-sm text-slate-600">Fat is your primary fuel source on keto. Avocados, olive oil, nuts, seeds, and fatty fish provide essential nutrients alongside energy. Avoid trans fats and highly processed oils.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Stay on top of electrolytes</h3>
        <p class="mt-1 text-sm text-slate-600">The "keto flu" — headache, fatigue, cramping — is often caused by electrolyte shifts. Supplement sodium, potassium, and magnesium, especially during the first few weeks.</p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="mt-10 rounded-xl bg-slate-50 p-5">
    <h2 class="text-lg font-bold text-slate-900">Medical disclaimer</h2>
    <p class="mt-2 text-sm text-slate-600">
      This calculator is for general information and educational purposes only. It does not constitute
      medical advice, diagnosis, or treatment. Always consult a qualified healthcare professional
      before starting a ketogenic diet or making significant changes to your eating habits,
      especially if you have diabetes, kidney disease, a history of eating disorders, or any other
      medical condition. Individual macro needs vary based on age, sex, activity level, and health
      status.
    </p>
  </section>

  <!-- Related tools -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/calorie-deficit-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="block text-2xl">🔥</span>
        <span class="mt-1 block font-medium text-slate-900">Calorie Deficit Calculator</span>
      </a>
      <a href="/tools/bmr-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="block text-2xl">🔥</span>
        <span class="mt-1 block font-medium text-slate-900">BMR Calculator</span>
      </a>
      <a href="/tools/calorie-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="block text-2xl">🍎</span>
        <span class="mt-1 block font-medium text-slate-900">Calorie Calculator</span>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let goal = 'maintain';

    function setGoal(g) {
      goal = g;
      ['lose', 'maintain', 'gain'].forEach((id) => {
        const btn = el('g-' + id);
        btn.className = 'flex-1 rounded-lg py-2 ' + (id === g ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      });
    }

    el('g-lose').addEventListener('click', () => setGoal('lose'));
    el('g-maintain').addEventListener('click', () => setGoal('maintain'));
    el('g-gain').addEventListener('click', () => setGoal('gain'));

    function fmt(n) {
      return Math.round(n).toLocaleString();
    }

    el('calc-btn').addEventListener('click', () => {
      const calories = parseFloat(el('calories').value);
      let carbsG = parseFloat(el('carbs').value);
      const proteinPerKg = parseFloat(el('protein').value);
      const weight = parseFloat(el('weight').value);

      if (!calories || !weight || calories <= 0 || weight <= 0) {
        el('result').classList.add('hidden');
        el('hint').classList.remove('hidden');
        el('hint').textContent = 'Please enter your calorie target and body weight.';
        return;
      }

      if (!carbsG || carbsG < 10) carbsG = 10;
      if (!proteinPerKg || proteinPerKg <= 0) {
        el('result').classList.add('hidden');
        el('hint').classList.remove('hidden');
        el('hint').textContent = 'Please enter a valid protein amount per kg.';
        return;
      }

      const proteinG = Math.round(proteinPerKg * weight);
      const carbsCal = carbsG * 4;
      const proteinCal = proteinG * 4;
      const fatCal = Math.round(calories - carbsCal - proteinCal);
      const fatG = Math.round(fatCal / 9);

      if (fatCal < 0) {
        el('result').classList.add('hidden');
        el('hint').classList.remove('hidden');
        el('hint').textContent = 'Carbs and protein exceed your calorie target. Increase calories or lower your protein/carbs.';
        return;
      }

      const totalMacroCal = carbsCal + proteinCal + fatCal;
      const fatPct = Math.round((fatCal / totalMacroCal) * 100);
      const proteinPct = Math.round((proteinCal / totalMacroCal) * 100);
      const carbsPct = Math.round((carbsCal / totalMacroCal) * 100);

      el('r-fat-g').textContent = fmt(fatG) + ' g';
      el('r-fat-cal').textContent = fmt(fatCal) + ' cal';
      el('r-fat-pct').textContent = fatPct + '%';
      el('r-protein-g').textContent = fmt(proteinG) + ' g';
      el('r-protein-cal').textContent = fmt(proteinCal) + ' cal';
      el('r-protein-pct').textContent = proteinPct + '%';
      el('r-carbs-g').textContent = fmt(carbsG) + ' g';
      el('r-carbs-cal').textContent = fmt(carbsCal) + ' cal';
      el('r-carbs-pct').textContent = carbsPct + '%';
      el('r-total').textContent = 'Total: ' + fmt(totalMacroCal) + ' cal';
      el('r-goal').textContent = 'Goal: ' + goal.charAt(0).toUpperCase() + goal.slice(1);

      el('result').classList.remove('hidden');
      el('hint').classList.add('hidden');
    });
  </script>
</ToolLayout>
