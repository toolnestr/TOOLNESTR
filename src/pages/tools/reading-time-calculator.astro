---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Reading Time Calculator';
const description =
  'Free online reading time calculator. Estimate how long it takes to read any text, plus speaking time. Adjustable reading speeds.';
const intro =
  'Paste any text to see estimated reading time and speaking time at various speeds.';
const category = { id: 'text', name: 'Text Tools' };
const faqs = [
  { q: 'How is reading time calculated?', a: 'Reading time = total words ÷ reading speed (words per minute). Default average speed is 238 WPM based on comprehension studies.' },
  { q: 'What is the average reading speed?', a: 'The average adult reads at about 238 words per minute for non-fiction text with moderate comprehension.' },
  { q: 'Why show three reading speeds?', a: 'Reading speed varies by person, content difficulty and purpose. Slow (150 WPM) for dense material, average (238 WPM) for standard text, fast (300 WPM) for light content.' },
  { q: 'How does speaking time differ?', a: 'Speaking is slower than reading. Average conversational speaking is ~150 WPM, while fast speech can reach 200 WPM.' },
  { q: 'What is counted as a word?', a: 'Words are groups of letters separated by spaces. Numbers and abbreviations are counted as words.' },
  { q: 'What about character count?', a: 'Character counts include letters, numbers, spaces and punctuation. Some platforms use character limits for bios and posts.' },
  { q: 'Can I use this for speech preparation?', a: 'Yes. The speaking time estimates help you time presentations, podcast scripts, and video voiceovers accurately.' },
  { q: 'What is a good reading time for a blog post?', a: 'Most blog posts aim for 3–7 minutes reading time. Short-form content works at 1–3 minutes, while in-depth articles can exceed 10 minutes.' },
  { q: 'How many sentences per minute is average?', a: 'At average speed (238 WPM) with ~15 words per sentence, that is roughly 16 sentences per minute for typical text.' },
  { q: 'Is my text stored or shared?', a: 'No. Everything runs entirely in your browser. Nothing is uploaded or stored.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea
      id="input"
      rows="5"
      placeholder="Paste your text here…"
      class="w-full resize-y rounded-xl border border-slate-300 p-4 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    >The quick brown fox jumps over the lazy dog. This simple sentence contains every letter of the English alphabet at least once.</textarea>
    <div id="stats" class="mt-4 grid gap-3 sm:grid-cols-3">
      <div class="rounded-lg bg-indigo-50 p-3 text-center">
        <div class="text-2xl font-bold text-indigo-700" id="word-count">0</div>
        <div class="text-xs text-slate-500">Words</div>
      </div>
      <div class="rounded-lg bg-emerald-50 p-3 text-center">
        <div class="text-2xl font-bold text-emerald-700" id="char-count">0</div>
        <div class="text-xs text-slate-500">Characters</div>
      </div>
      <div class="rounded-lg bg-amber-50 p-3 text-center">
        <div class="text-2xl font-bold text-amber-700" id="sentence-count">0</div>
        <div class="text-xs text-slate-500">Sentences</div>
      </div>
    </div>
  </div>

  <div class="mt-6 grid gap-6 sm:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wide">Reading time</h3>
      <div class="mt-3 space-y-3">
        <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
          <span class="text-sm text-slate-600">Slow (150 WPM)</span>
          <span class="font-semibold text-slate-900" id="read-slow">0m 0s</span>
        </div>
        <div class="flex items-center justify-between rounded-lg bg-indigo-50 p-3">
          <span class="text-sm text-slate-600">Average (238 WPM)</span>
          <span class="font-semibold text-indigo-700" id="read-avg">0m 0s</span>
        </div>
        <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
          <span class="text-sm text-slate-600">Fast (300 WPM)</span>
          <span class="font-semibold text-slate-900" id="read-fast">0m 0s</span>
        </div>
      </div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
      <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wide">Speaking time</h3>
      <div class="mt-3 space-y-3">
        <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
          <span class="text-sm text-slate-600">Slow (100 WPM)</span>
          <span class="font-semibold text-slate-900" id="speak-slow">0m 0s</span>
        </div>
        <div class="flex items-center justify-between rounded-lg bg-emerald-50 p-3">
          <span class="text-sm text-slate-600">Average (150 WPM)</span>
          <span class="font-semibold text-emerald-700" id="speak-avg">0m 0s</span>
        </div>
        <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
          <span class="text-sm text-slate-600">Fast (200 WPM)</span>
          <span class="font-semibold text-slate-900" id="speak-fast">0m 0s</span>
        </div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Reading speed by content type</h2>
    <p class="mt-2 text-sm text-slate-600">Different content types are typically read at different speeds.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Children's books</span><span class="text-slate-400">120 WPM</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Fiction</span><span class="text-slate-400">200 WPM</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:33%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Non-fiction</span><span class="text-slate-400">240 WPM</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:40%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Academic</span><span class="text-slate-400">300 WPM</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-400" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Skimming</span><span class="text-slate-400">600 WPM</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-400" style="width:100%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4dd;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Blogger</h3>
      <p class="mt-1 text-sm text-slate-600">Estimates how long readers spend on each post. Uses reading time to optimise article length and improve engagement metrics.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4f0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Writer</h3>
      <p class="mt-1 text-sm text-slate-600">Plans content length based on target reading time for emails, newsletters, landing pages and documentation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f468;&#x200d;&#x1f3eb;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Times reading assignments to match students' grade-level reading speeds. Ensures homework is appropriately scoped.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f3e0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Public Speaker</h3>
      <p class="mt-1 text-sm text-slate-600">Estimates speaking duration for speeches, presentations and podcast scripts to fit within time limits.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Age / Content Type</th><th class="p-3">Average WPM</th><th class="p-3">Comprehension Level</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Children (6–8)</td><td class="p-3">80–120</td><td class="p-3">Basic, simple sentences</td></tr>
        <tr><td class="p-3 font-medium">Children (9–12)</td><td class="p-3">120–180</td><td class="p-3">Intermediate, moderate vocabulary</td></tr>
        <tr><td class="p-3 font-medium">Teenagers</td><td class="p-3">180–250</td><td class="p-3">Advanced, complex sentences</td></tr>
        <tr><td class="p-3 font-medium">Adult (fiction)</td><td class="p-3">200–250</td><td class="p-3">Narrative comprehension</td></tr>
        <tr><td class="p-3 font-medium">Adult (non-fiction)</td><td class="p-3">220–280</td><td class="p-3">Informational comprehension</td></tr>
        <tr><td class="p-3 font-medium">Academic</td><td class="p-3">280–350</td><td class="p-3">Critical analysis</td></tr>
        <tr><td class="p-3 font-medium">Skimming</td><td class="p-3">500–700</td><td class="p-3">Surface-level scanning</td></tr>
        <tr><td class="p-3 font-medium">Speed reading</td><td class="p-3">700+</td><td class="p-3">Variable, often reduced comprehension</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the reading time calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste your text</h3>
        <p class="mt-1 text-sm text-slate-600">Copy and paste any article, script, essay or document into the text area.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check the results</h3>
        <p class="mt-1 text-sm text-slate-600">View word count, character count, sentence count and estimated times at six different speeds.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Plan your content</h3>
        <p class="mt-1 text-sm text-slate-600">Use the estimates to trim or expand your text to meet a target reading or speaking duration.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for reading time estimation</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Know your audience's reading speed</h3>
        <p class="mt-1 text-sm text-slate-600">Children's content needs slower speeds (120–180 WPM), while academic readers can handle 300+ WPM. Match the estimate to your audience.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-600">Use for SEO and engagement</h3>
        <p class="mt-1 text-sm text-slate-600">Blog posts with 3–7 minute reading times tend to perform best. Very short articles may lack depth; very long ones may lose readers.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-700">Practice your speech timing</h3>
        <p class="mt-1 text-sm text-slate-600">Read your script aloud at least once with a timer. The speaking estimates are a starting point — your actual pace may vary with pauses and emphasis.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Average reading speed</h2>
    <p class="mt-2 text-slate-600">
      The average adult reads non-fiction text at approximately 238 words per minute with 60–80% comprehension. This figure comes from studies on silent reading fluency conducted over the past several decades. Reading speed varies significantly based on factors like text complexity, reader familiarity with the subject, purpose (browsing vs studying), and fatigue.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How reading time is calculated</h2>
    <p class="mt-2 text-slate-600">
      The calculator divides the total word count by the selected words-per-minute rate. For example, a 500-word article at 238 WPM gives 500 ÷ 238 ≈ 2.1 minutes (2 minutes 6 seconds). Character and sentence counts are also provided because some platforms (like social media) have character limits, and sentence count helps with speaking pace estimation.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Content length guidelines</h2>
    <p class="mt-2 text-slate-600">
      Different content types have different ideal lengths: social media posts (50–200 words), emails (150–500 words), blog posts (800–2,500 words), long-form articles (2,500–5,000 words), and academic papers (5,000–10,000+ words). Reading time helps creators match their content to audience expectations — most online readers prefer content they can finish in under 7 minutes.
    </p>
  </section>

  <script is:inline>
    const input = document.getElementById('input');
    const wordCountEl = document.getElementById('word-count');
    const charCountEl = document.getElementById('char-count');
    const sentenceCountEl = document.getElementById('sentence-count');
    const readSlow = document.getElementById('read-slow');
    const readAvg = document.getElementById('read-avg');
    const readFast = document.getElementById('read-fast');
    const speakSlow = document.getElementById('speak-slow');
    const speakAvg = document.getElementById('speak-avg');
    const speakFast = document.getElementById('speak-fast');

    function formatTime(minutes) {
      const m = Math.floor(minutes);
      const s = Math.round((minutes - m) * 60);
      return `${m}m ${s}s`;
    }

    function render() {
      const text = input.value || '';
      const words = text.trim() ? text.trim().split(/\s+/).length : 0;
      const chars = text.length;
      const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0).length;

      wordCountEl.textContent = words;
      charCountEl.textContent = chars;
      sentenceCountEl.textContent = sentences;

      const speeds = { read: [150, 238, 300], speak: [100, 150, 200] };
      if (words > 0) {
        readSlow.textContent = formatTime(words / speeds.read[0]);
        readAvg.textContent = formatTime(words / speeds.read[1]);
        readFast.textContent = formatTime(words / speeds.read[2]);
        speakSlow.textContent = formatTime(words / speeds.speak[0]);
        speakAvg.textContent = formatTime(words / speeds.speak[1]);
        speakFast.textContent = formatTime(words / speeds.speak[2]);
      } else {
        ['readSlow','readAvg','readFast','speakSlow','speakAvg','speakFast'].forEach(id => {
          const el = document.getElementById(id.replace(/([A-Z])/g, '-$1').toLowerCase().slice(1));
          if (el) el.textContent = '0m 0s';
        });
      }
    }

    input.addEventListener('input', render);
    render();
  </script>
</ToolLayout>
