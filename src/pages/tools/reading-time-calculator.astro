---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Reading Time Calculator';
const description =
  'Paste text to get word count, reading time, and speaking time instantly. Adjustable words-per-minute for blogs, speeches, and scripts.';
const intro =
  'Paste any text to see how long it takes to read — and to speak aloud.';
const category = { id: 'text', name: 'Text Tools' };
const faqs = [
  { q: "What's the average reading speed?", a: 'Most adults read 200–250 words per minute for general text.' },
  { q: 'How many words is a 5-minute speech?', a: 'About 650 words at a comfortable 130 wpm speaking pace.' },
  { q: 'Does it update as I type?', a: 'Yes — word count and times recalculate live.' },
  { q: 'Is my text stored?', a: 'No — everything runs in your browser.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea
      id="text-input"
      rows="9"
      placeholder="Paste an article, post, or script…"
      class="w-full resize-y rounded-xl border border-slate-300 p-4 text-base leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>

    <div class="mt-4 flex flex-wrap items-center gap-4">
      <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
        Reading speed
        <select id="speed-select" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="150">Slow (150 wpm)</option>
          <option value="200" selected>Average (200 wpm)</option>
          <option value="250">Fast (250 wpm)</option>
        </select>
      </label>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
    </div>

    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-50 p-3 text-center">
        <div id="stat-words" class="text-2xl font-bold text-indigo-700">0</div>
        <div class="text-xs font-medium text-slate-500">Words</div>
      </div>
      <div class="rounded-xl bg-emerald-50 p-3 text-center">
        <div id="stat-reading" class="text-2xl font-bold text-emerald-700">0:00</div>
        <div class="text-xs font-medium text-slate-500">Reading time (mm:ss)</div>
      </div>
      <div class="rounded-xl bg-amber-50 p-3 text-center">
        <div id="stat-speaking" class="text-2xl font-bold text-amber-700">0:00</div>
        <div class="text-xs font-medium text-slate-500">Speaking time (mm:ss @130 wpm)</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center">
        <div id="stat-chars" class="text-2xl font-bold text-slate-700">0</div>
        <div class="text-xs font-medium text-slate-500">Characters</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center">
        <div id="stat-sentences" class="text-2xl font-bold text-slate-700">0</div>
        <div class="text-xs font-medium text-slate-500">Sentences</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center">
        <div id="stat-paragraphs" class="text-2xl font-bold text-slate-700">0</div>
        <div class="text-xs font-medium text-slate-500">Paragraphs</div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How reading time is calculated</h2>
    <p class="mt-2 text-slate-600">
      The calculator works by first splitting your text on whitespace to count words, then dividing by your chosen reading speed. Speaking time uses a fixed pace of 130 words per minute, which is the average conversational speaking rate.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="text-2xl font-bold text-indigo-600">Words</span>
        <p class="mt-1 text-sm text-slate-600"><code>trim().split(/\s+/)</code></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="text-2xl font-bold text-indigo-600">Reading</span>
        <p class="mt-1 text-sm text-slate-600"><code>words / wpm</code> minutes</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="text-2xl font-bold text-indigo-600">Speaking</span>
        <p class="mt-1 text-sm text-slate-600"><code>words / 130</code> minutes</p>
      </div>
    </div>
  </section>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" width="800" height="220" viewBox="0 0 800 220" role="img" aria-label="Reading speed scale from 0 to 300 wpm with zones labelled Slow, Average and Fast">
      <title>Reading speed scale — speedometer-style diagram</title>
      <desc>A horizontal speedometer-style scale showing reading speed in words per minute. Slow zone 0-150 wpm, Average zone 150-250 wpm, Fast zone 250+ wpm with a needle at 200 wpm.</desc>
      <rect width="800" height="220" fill="#f8fafc" rx="12"/>
      <text x="400" y="30" text-anchor="middle" font-family="sans-serif" font-size="14" font-weight="bold" fill="#1e293b">Reading Speed Scale (words per minute)</text>
      <rect x="60" y="60" width="680" height="36" rx="18" fill="#e2e8f0"/>
      <rect x="60" y="60" width="200" height="36" rx="18" fill="#f97316"/>
      <text x="160" y="83" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="bold" fill="#fff">Slow</text>
      <rect x="260" y="60" width="240" height="36" rx="0" fill="#22c55e"/>
      <text x="380" y="83" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="bold" fill="#fff">Average</text>
      <rect x="500" y="60" width="240" height="36" rx="18" fill="#6366f1"/>
      <text x="620" y="83" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="bold" fill="#fff">Fast</text>
      <line x1="60" y1="60" x2="60" y2="220" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="4"/>
      <text x="60" y="216" text-anchor="middle" font-family="sans-serif" font-size="11" fill="#94a3b8">0</text>
      <line x1="286" y1="60" x2="286" y2="220" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="4"/>
      <text x="286" y="216" text-anchor="middle" font-family="sans-serif" font-size="11" fill="#94a3b8">150</text>
      <line x1="513" y1="60" x2="513" y2="220" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="4"/>
      <text x="513" y="216" text-anchor="middle" font-family="sans-serif" font-size="11" fill="#94a3b8">250</text>
      <line x1="740" y1="60" x2="740" y2="220" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="4"/>
      <text x="740" y="216" text-anchor="middle" font-family="sans-serif" font-size="11" fill="#94a3b8">300</text>
      <polygon points="400,95 392,130 408,130" fill="#1e293b"/>
      <rect x="365" y="130" width="70" height="22" rx="4" fill="#1e293b"/>
      <text x="400" y="145" text-anchor="middle" font-family="sans-serif" font-size="12" font-weight="bold" fill="#fff">200</text>
      <line x1="400" y1="130" x2="400" y2="180" stroke="#1e293b" stroke-width="2"/>
      <circle cx="400" cy="180" r="6" fill="#1e293b"/>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The average adult reads at 200–250 wpm — this tool lets you adjust between Slow (150), Average (200) and Fast (250) wpm.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">
        Take a typical 1,200-word blog post:
      </p>
      <div class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Words:</span> <span class="text-slate-600">1,200</span></div>
        <div><span class="font-medium text-slate-700">Reading (200 wpm):</span> <span class="text-slate-600">1,200 ÷ 200 = <strong>6:00 (6 minutes)</strong></span></div>
        <div><span class="font-medium text-slate-700">Reading (150 wpm):</span> <span class="text-slate-600">1,200 ÷ 150 = <strong>8:00</strong></span></div>
        <div><span class="font-medium text-slate-700">Speaking (130 wpm):</span> <span class="text-slate-600">1,200 ÷ 130 ≈ <strong>9:14 (9 minutes 14 seconds)</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common use cases</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📝</span>
        <h3 class="mt-2 font-semibold text-slate-900">Blog badges</h3>
        <p class="mt-1 text-sm text-slate-600">Display a "5 min read" badge on blog posts to set reader expectations. Posts with reading time badges have lower bounce rates because visitors know the commitment upfront.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🎤</span>
        <h3 class="mt-2 font-semibold text-slate-900">Speech timing</h3>
        <p class="mt-1 text-sm text-slate-600">Conference talks, wedding speeches and presentation scripts all need to fit strict time slots. Use the speaking-time estimate (130 wpm) to trim or expand your script until it lands on the target duration.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🎬</span>
        <h3 class="mt-2 font-semibold text-slate-900">Video scripts</h3>
        <p class="mt-1 text-sm text-slate-600">YouTube, TikTok and podcast scripts must match video length for pacing. A 10-minute video needs roughly 1,300 spoken words. Use the calculator to draft scripts that fit your format perfectly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate time estimates</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Know your audience's reading speed</h3>
        <p class="mt-1 text-sm text-slate-600">The average adult reads 200–250 words per minute for general content. Dense technical or academic material is often read slower (150–180 wpm), while light fiction can be read faster (250–300 wpm). Adjust the speed dropdown to match your content type and audience.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use speaking time for talks and presentations</h3>
        <p class="mt-1 text-sm text-slate-600">Speaking pace is slower than silent reading. The tool uses 130 wpm as the speaking baseline — this accounts for pauses, emphasis, and natural breath breaks. For fast-paced presentations, you may reach 150 wpm, but 130 wpm is a reliable safe estimate that ensures you won't run short.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Account for visuals and transitions</h3>
        <p class="mt-1 text-sm text-slate-600">In presentations, slides, demos and audience interactions add time. If your talk includes a lot of visual content, add 20–30% to the speaking estimate. For pure audio (podcasts, voiceovers), the estimate is more accurate.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 flex flex-wrap gap-3">
      <a href="/tools/tokens-to-words" class="rounded-lg bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-100">Tokens to Words</a>
      <a href="/tools/token-counter" class="rounded-lg bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-100">Token Counter</a>
      <a href="/tools/word-counter" class="rounded-lg bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-100">Word Counter</a>
    </div>
  </section>

  <script is:inline>
    const input = document.getElementById('text-input');
    const speedSelect = document.getElementById('speed-select');
    const clearBtn = document.getElementById('clear-btn');
    const el = (id) => document.getElementById(id);

    function pad(n) {
      return String(n).padStart(2, '0');
    }

    function formatTime(totalMinutes) {
      if (!isFinite(totalMinutes) || totalMinutes <= 0) return '0:00';
      const m = Math.floor(totalMinutes);
      const s = Math.round((totalMinutes - m) * 60);
      return m + ':' + pad(s);
    }

    let debounceTimer;
    function update() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const text = input.value;
        const trimmed = text.trim();
        const wpm = parseInt(speedSelect.value, 10);

        const words = trimmed ? trimmed.split(/\s+/).length : 0;
        const chars = text.length;
        const sentences = trimmed ? (trimmed.match(/[^.!?]+[.!?]+/g) || [trimmed]).length : 0;
        const paragraphs = trimmed ? trimmed.split(/\n+/).filter((p) => p.trim()).length : 0;

        const readingMins = words / wpm;
        const speakingMins = words / 130;

        el('stat-words').textContent = words.toLocaleString();
        el('stat-reading').textContent = formatTime(readingMins);
        el('stat-speaking').textContent = formatTime(speakingMins);
        el('stat-chars').textContent = chars.toLocaleString();
        el('stat-sentences').textContent = sentences.toLocaleString();
        el('stat-paragraphs').textContent = paragraphs.toLocaleString();
      }, words > 5000 ? 150 : 0);
    }

    input.addEventListener('input', update);
    speedSelect.addEventListener('change', update);
    clearBtn.addEventListener('click', () => {
      input.value = '';
      update();
      input.focus();
    });

    update();
  </script>
</ToolLayout>
