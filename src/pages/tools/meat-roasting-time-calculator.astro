---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Meat Roasting Time Calculator';
const description =
  'Free meat roasting time calculator. Get precise roasting times for beef, chicken, pork, and lamb based on weight, cut, and desired doneness level.';
const intro =
  'Select your meat type and cut, enter the weight, and choose your desired doneness to see the estimated roasting time and target internal temperature.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'How is roasting time calculated?', a: 'Roasting times are calculated using standard culinary formulas: a fixed number of minutes per unit of weight at a given oven temperature, adjusted for the cut and bone content of the meat. Boneless cuts cook faster than bone-in cuts, and larger roasts require fewer minutes per kilogram than smaller ones due to the surface-area-to-volume ratio.' },
  { q: 'Why does a bone-in roast take longer?', a: 'Bones conduct heat differently than meat and act as an insulator in the centre of the roast. A bone-in roast can take 15–25% longer to reach the same internal temperature as a boneless roast of the same weight because the bone slows heat penetration into the meat.' },
  { q: 'Should I rest the meat after roasting?', a: 'Absolutely. Resting allows the juices, which are forced to the centre during cooking, to redistribute throughout the meat. A roast should rest for 10–20 minutes (depending on size) loosely covered with foil before carving. The internal temperature will rise by about 2–5°C (5–10°F) during resting — this is called carryover cooking.' },
  { q: 'What internal temperature is medium-rare beef?', a: 'Medium-rare beef is achieved at an internal temperature of 52–54°C (125–130°F) before resting. After carryover cooking, it will rise to 55–57°C (130–135°F). Always insert the meat thermometer into the thickest part of the roast, avoiding bone and fat pockets.' },
  { q: 'Can I cook poultry from frozen?', a: 'The USDA advises against cooking whole poultry from frozen because the outside may burn before the inside is fully cooked. For individual cuts like breasts or thighs, you can cook from frozen by adding at least 50% more cooking time. Always verify the internal temperature reaches 74°C (165°F) in the thickest part.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Meat type</span>
        <select id="meatType" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="beef">Beef</option>
          <option value="chicken">Chicken</option>
          <option value="turkey">Turkey</option>
          <option value="pork">Pork</option>
          <option value="lamb">Lamb</option>
          <option value="veal">Veal</option>
        </select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Cut / Bone</span>
        <select id="cut" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="boneless">Boneless</option>
          <option value="bonein">Bone-in</option>
          <option value="whole">Whole (poultry)</option>
        </select></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight</span>
        <input id="weight" type="number" step="any" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Doneness</span>
        <select id="doneness" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="rare">Rare</option>
          <option value="med-rare">Medium-rare</option>
          <option value="medium">Medium</option>
          <option value="med-well">Medium-well</option>
          <option value="well">Well done</option>
        </select></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Roasting time</div>
        <div id="r-time" class="mt-1 text-3xl font-bold">—</div>
        <div id="r-temp" class="mt-1 text-sm opacity-80">Target internal: —</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Minutes per kg</div><div id="r-per-kg" class="mt-1 text-xl font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Weight</div><div id="r-weight" class="mt-1 text-xl font-bold text-slate-700">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Select meat type, cut, weight and doneness to see the roasting time.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The Meat Roasting Time Calculator uses standard culinary guidelines — minutes per kilogram at a given oven temperature — adjusted for the type of meat, whether the cut is bone-in or boneless, and the desired level of doneness. The calculations are based on recommendations from the USDA, the American Culinary Federation and established cookbooks.
    </p>
    <p class="mt-3 text-slate-600">
      The underlying principle is that heat penetrates meat at a predictable rate depending on the density, fat content, bone presence and starting temperature of the meat. Boneless roasts cook faster than bone-in roasts because bone conducts heat differently and slows centre-to-surface heat transfer. Poultry requires the highest internal temperature for safety (74°C / 165°F) regardless of doneness preference, while beef and lamb allow more flexibility depending on how well done you like your meat.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="mr-title mr-desc">
      <title id="mr-title">Meat roasting temperature guide</title>
      <desc id="mr-desc">Roasting pan illustration with a meat thermometer showing target internal temperatures for different doneness levels from rare to well done.</desc>
      <!-- Roasting pan -->
      <rect x="150" y="90" width="500" height="70" rx="10" fill="#e2e8f0" stroke="#94a3b8" stroke-width="2" />
      <rect x="170" y="100" width="460" height="50" rx="6" fill="#f1f5f9" />
      <!-- Meat joint -->
      <ellipse cx="400" cy="125" rx="80" ry="20" fill="#ef4444" />
      <!-- Thermometer -->
      <rect x="395" y="20" width="10" height="100" rx="3" fill="#cbd5e1" />
      <rect x="395" y="25" width="10" height="50" rx="3" fill="#ef4444" />
      <circle cx="400" cy="20" r="8" fill="#ef4444" />
      <text x="400" y="14" text-anchor="middle" font-size="10" fill="#ef4444" font-weight="bold">°C</text>
      <!-- Doneness labels -->
      <line x1="395" y1="30" x2="300" y2="30" stroke="#94a3b8" stroke-dasharray="3,3" />
      <text x="290" y="34" text-anchor="end" font-size="10" fill="#dc2626">52°C Rare</text>
      <line x1="395" y1="42" x2="300" y2="42" stroke="#94a3b8" stroke-dasharray="3,3" />
      <text x="290" y="46" text-anchor="end" font-size="10" fill="#ea580c">55°C Med-rare</text>
      <line x1="395" y1="54" x2="300" y2="54" stroke="#94a3b8" stroke-dasharray="3,3" />
      <text x="290" y="58" text-anchor="end" font-size="10" fill="#eab308">60°C Medium</text>
      <line x1="395" y1="66" x2="300" y2="66" stroke="#94a3b8" stroke-dasharray="3,3" />
      <text x="290" y="70" text-anchor="end" font-size="10" fill="#65a30d">65°C Med-well</text>
      <line x1="395" y1="75" x2="300" y2="75" stroke="#94a3b8" stroke-dasharray="3,3" />
      <text x="290" y="79" text-anchor="end" font-size="10" fill="#16a34a">71°C Well</text>

      <!-- Poultry note -->
      <text x="400" y="185" text-anchor="middle" font-size="12" fill="#64748b">Poultry: 74°C (165°F) minimum internal temperature</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Target internal temperatures for beef roasts by doneness level, with poultry safety threshold</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the roasting time is calculated</h2>
    <p class="mt-2 text-slate-600">
      The calculator uses minutes per kilogram at a standard roasting temperature (typically 160–180°C / 325–350°F). Boneless roasts use a higher minutes-per-kg rate than bone-in roasts. Poultry uses its own rates because it must reach a higher internal temperature.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">You have a 3 kg bone-in beef rib roast and want it medium-rare for Sunday dinner. What are the roasting parameters?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Meat type:</span> <span class="text-slate-600">Beef, bone-in rib roast</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">3 kg</span></div>
        <div><span class="font-medium text-slate-700">Doneness:</span> <span class="text-slate-600">Medium-rare (55°C / 130°F)</span></div>
        <div><span class="font-medium text-slate-700">Rate:</span> <span class="text-slate-600">40 min/kg (bone-in)</span></div>
        <div><span class="font-medium text-slate-700">Total time:</span> <span class="text-slate-600">3 × 40 = <strong>120 min (2 hours)</strong></span></div>
        <div><span class="font-medium text-slate-700">Rest:</span> <span class="text-slate-600">15 min loosely covered before carving</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎄</span>
      <h3 class="mt-2 font-semibold text-slate-900">Holiday cook</h3>
      <p class="mt-1 text-sm text-slate-600">Planning Christmas dinner with a large roast and need precise timing to coordinate the meat with all the sides so everything is ready at the same time.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🥩</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sunday roast enthusiast</h3>
      <p class="mt-1 text-sm text-slate-600">Perfecting your weekly roast dinner by tracking cook times and internal temperatures to achieve consistent, repeatable results every Sunday.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Cooking competition contestant</h3>
      <p class="mt-1 text-sm text-slate-600">Practising a timed cook for a competition where every minute counts — accurate roasting time estimates help plan the entire cooking schedule.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📋</span>
      <h3 class="mt-2 font-semibold text-slate-900">Meal planner</h3>
      <p class="mt-1 text-sm text-slate-600">Mapping out a week's menu and need to know which roasts fit into your schedule based on their cooking times and preparation requirements.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Meat Roasting Time Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select meat and cut</h3>
        <p class="mt-1 text-sm text-slate-600">Choose your meat type (beef, chicken, turkey, pork, lamb or veal) and whether it is boneless, bone-in or whole poultry.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter weight and doneness</h3>
        <p class="mt-1 text-sm text-slate-600">Type the weight in kilograms and select your desired doneness. For poultry, doneness is fixed at well done for safety.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Cook and rest</h3>
        <p class="mt-1 text-sm text-slate-600">Roast for the calculated time, verify with a meat thermometer and let the meat rest for 10–20 minutes before carving for juicier results.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always use a meat thermometer</h3>
        <p class="mt-1 text-sm text-slate-600">Time estimates are guides — actual cooking time depends on your oven, the shape of the roast and the starting temperature. A probe thermometer removes all guesswork and ensures food safety.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Account for carryover cooking</h3>
        <p class="mt-1 text-sm text-slate-600">Remove the roast from the oven when it is 3–5°C (5–10°F) below your target temperature. The internal temperature will continue to rise during resting, bringing it to the perfect doneness without overcooking.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Bring meat to room temperature first</h3>
        <p class="mt-1 text-sm text-slate-600">Let your roast sit at room temperature for 30–60 minutes (depending on size) before roasting. This promotes more even cooking and a better crust. Never leave meat out for more than 2 hours for food safety.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/food-thawing-time-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🧊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Food Thawing Time Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Safe thawing times by weight</p>
      </a>
      <a href="/tools/oven-temperature-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🌡️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Oven Temperature Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert °F, °C, gas mark and fan</p>
      </a>
      <a href="/tools/recipe-scaling-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">📝</span>
        <h3 class="mt-2 font-semibold text-slate-900">Recipe Scaling Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Scale recipes up or down by servings</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    const rates = {
      'beef': { boneless: 45, bonein: 40, whole: 35 },
      'chicken': { boneless: 35, bonein: 30, whole: 28 },
      'turkey': { boneless: 40, bonein: 35, whole: 30 },
      'pork': { boneless: 50, bonein: 45, whole: 40 },
      'lamb': { boneless: 45, bonein: 40, whole: 35 },
      'veal': { boneless: 50, bonein: 45, whole: 40 },
    };

    const temps = {
      'rare': { c: 52, f: 125, label: 'Rare' },
      'med-rare': { c: 55, f: 130, label: 'Medium-rare' },
      'medium': { c: 60, f: 140, label: 'Medium' },
      'med-well': { c: 65, f: 150, label: 'Medium-well' },
      'well': { c: 71, f: 160, label: 'Well done' },
    };

    function update() {
      const meat = el('meatType').value;
      const cut = el('cut').value;
      const w = parseFloat(el('weight').value);
      const done = el('doneness').value;

      if (!w || w <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      const rate = rates[meat][cut];
      const isPoultry = (meat === 'chicken' || meat === 'turkey');
      const targetTemp = isPoultry ? { c: 74, f: 165, label: 'Well done (safe)' } : temps[done];

      const totalMin = w * rate;
      const hours = Math.floor(totalMin / 60);
      const mins = Math.round(totalMin % 60);

      el('r-time').textContent = (hours > 0 ? hours + ' h ' : '') + mins + ' min';
      el('r-temp').textContent = 'Target internal: ' + targetTemp.c + '\u00B0C (' + targetTemp.f + '\u00B0F) ' + targetTemp.label;
      el('r-per-kg').textContent = rate + ' min/kg';
      el('r-weight').textContent = w.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' kg';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    ['meatType', 'cut', 'weight', 'doneness'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
