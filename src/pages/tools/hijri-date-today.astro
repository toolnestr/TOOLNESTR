---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Today’s Hijri Date';
const description = 'See today’s Hijri (Islamic) date — the current day, month name and year (AH) — calculated from the Umm al-Qura calendar.';
const intro = 'Your current Hijri date, calculated automatically from your device.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const months = ['Muharram', 'Safar', "Rabi' al-Awwal", "Rabi' al-Thani", 'Jumada al-Awwal', 'Jumada al-Thani', 'Rajab', "Sha'ban", 'Ramadan', 'Shawwal', "Dhul-Qa'dah", 'Dhul-Hijjah'];
const faqs = [
  { q: 'Why might this differ from my local Hijri date?', a: 'This date is calculated using the Umm al-Qura calendar. Many communities begin the month on local moon-sighting, which can fall a day earlier or later. For prayer, fasting and Eid, follow your local mosque’s announcement.' },
  { q: 'Which calendar is used?', a: 'It uses the Umm al-Qura calculated calendar — the official Islamic calendar of Saudi Arabia — read through your browser’s internationalisation engine.' },
  { q: 'Can I convert a specific date instead?', a: 'Yes. Use the Gregorian to Hijri converter for any past or future date, or the Hijri to Gregorian converter to go the other way.' },
  { q: 'What are the 12 Hijri months?', a: 'Muharram, Safar, Rabi al-Awwal, Rabi al-Thani, Jumada al-Awwal, Jumada al-Thani, Rajab, Sha’ban, Ramadan, Shawwal, Dhul-Qa’dah and Dhul-Hijjah.' },
];
const sources = [
  { html: "<strong>The Qur’an</strong> — e.g. Surah an-Nisa (4:11–12, 4:176) for the fixed inheritance shares (fara’id)." },
  { html: "<strong>Sahih al-Bukhari &amp; Sahih Muslim</strong> — hadith on inheritance, zakat and nisab thresholds." },
  { html: "<strong>AAOIFI and recognized fiqh councils</strong> (e.g. Islamic Fiqh Academy) for contemporary rulings. <a href=\"https://aaoifi.com/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">aaoifi.com</a>" },
];
const sourcesNote = "Rulings differ between scholars and schools (madhahib), and calculated astronomical times/dates may differ from local sighting. Confirm with a qualified scholar before acting.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm text-center">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-indigo-100 text-3xl">🌙</div>
    <div id="r-hijri" class="mt-4 text-3xl font-bold text-slate-900">—</div>
    <div id="r-greg" class="mt-1 text-slate-500">—</div>
    <div id="r-week" class="mt-1 text-sm font-medium text-indigo-600">—</div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ht-title ht-desc">
      <title id="ht-title">Crescent moon date card</title>
      <desc id="ht-desc">A crescent moon beside a card showing the current Hijri day, month and year.</desc>
      <path d="M120 90 a45 45 0 1 0 30 42 a35 35 0 1 1 -30 -42 Z" fill="#fbbf24" />
      <rect x="240" y="50" width="420" height="80" rx="12" fill="#eef2ff" stroke="#a5b4fc" />
      <text x="450" y="85" text-anchor="middle" font-size="18" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">Today in the Hijri calendar</text>
      <text x="450" y="110" text-anchor="middle" font-size="13" fill="#4f46e5" font-family="system-ui,sans-serif">day · month · year (AH)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Today’s Islamic date, calculated from the Umm al-Qura calendar.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About today’s Hijri date</h2>
    <p class="mt-2 text-slate-600">The Hijri calendar is the Islamic lunar calendar, counted from the year of the Prophet Muhammad’s migration (Hijrah) from Makkah to Madinah. Its years are marked “AH” for Anno Hegirae. Because each month follows the cycle of the moon, the Hijri year is about 354 days — roughly 11 days shorter than the Gregorian year — so today’s Islamic date shifts a little earlier against the Western calendar each year.</p>
    <p class="mt-3 text-slate-600">This page reads your device’s current date and converts it to the Hijri calendar using the Umm al-Qura system built into your browser. It shows the Islamic day, month name and year alongside today’s Gregorian date and weekday, updating automatically each time you open it. Nothing leaves your device.</p>
    <p class="mt-3 text-slate-600">Knowing the current Hijri date helps you keep track of blessed days and months — the white days of fasting, the sacred months, the approach of Ramadan, and the timing of Eid. Since the calculated date can differ from a local crescent sighting by a day, always defer to your local mosque for the exact start of religious observances.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The 12 months of the Hijri year</h2>
    <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
      {months.map((m, i) => (<div class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700"><span class="font-semibold text-indigo-600">{i + 1}.</span> {m}</div>))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/gregorian-to-hijri-converter/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gregorian to Hijri Converter</a>
      <a href="/tools/ramadan-countdown/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Ramadan Countdown</a>
      <a href="/tools/age-in-hijri-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Age in Hijri Years</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    try {
      const now = new Date();
      const h = new Intl.DateTimeFormat('en-u-ca-islamic-umalqura', { day: 'numeric', month: 'long', year: 'numeric' });
      el('r-hijri').textContent = h.format(now) + ' AH';
      el('r-greg').textContent = now.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
      el('r-week').textContent = now.toLocaleDateString('en-US', { weekday: 'long' });
    } catch (e) {
      el('r-hijri').textContent = 'Not supported in this browser';
    }
  </script>
</ToolLayout>
