---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'GSM / Fabric Weight Calculator';
const description = 'Convert fabric weight between GSM (grams per square meter) and ounces per square yard.';
const intro = 'Convert fabric weight between GSM (g/m²) and ounces per square yard (oz/yd²).';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is GSM in fabric?', a: 'GSM stands for grams per square meter, a standard measure of fabric weight and density used worldwide, especially outside the US. Higher GSM means a heavier, denser fabric — quilting cotton is typically 120-150 GSM, while a heavy canvas can run 300-500 GSM or more.' },
  { q: 'Why does the US use oz/yd² instead of GSM?', a: 'Ounces per square yard is the traditional imperial measure used in the US textile industry, tied to the yard-based measurement system still common in American fabric retail, while most of the rest of the world uses the metric GSM standard.' },
  { q: 'Is heavier fabric always better quality?', a: 'Not necessarily — weight relates to fiber density and intended use, not inherent quality. A lightweight voile and a heavyweight denim can both be high quality for their respective purposes; GSM just helps you predict drape, structure, and durability for a specific project.' },
  { q: 'What GSM is good for a t-shirt versus a coat?', a: 'A typical t-shirt knit runs roughly 140-180 GSM, quilting cotton around 120-150 GSM, denim 200-500 GSM depending on weight, and a structured coating fabric often runs 400 GSM or higher.' },
];
const howTo = {
  name: 'How to convert fabric weight',
  steps: [
    { name: 'Choose direction', text: 'Select whether you\'re converting GSM to oz/yd² or the reverse.' },
    { name: 'Enter the known weight', text: 'Type the fabric weight value you already know.' },
    { name: 'Read the converted weight', text: 'The equivalent weight in the other unit appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['GSM → oz/yd²', 'oz/yd² → GSM'].map((d) => (
        <button data-mode={d} class="mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span id="input-label" class="text-sm font-medium text-slate-700">GSM (g/m²)</span>
      <input id="value" type="number" step="any" placeholder="e.g. 150" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div id="output-label" class="text-sm opacity-80">oz/yd²</div>
        <div id="r-value" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="gsm-title gsm-desc">
      <title id="gsm-title">A one square meter fabric swatch on a scale</title>
      <desc id="gsm-desc">A square representing one square meter of fabric sitting on a small scale icon, illustrating weight-per-area measurement</desc>
      <rect x="330" y="20" width="140" height="140" fill="#fecdd3" stroke="#e11d48" stroke-width="2" />
      <text x="400" y="95" text-anchor="middle" font-size="14" fill="#9f1239" font-family="system-ui,sans-serif">1 m²</text>
      <text x="580" y="70" font-size="13" fill="#475569" font-family="system-ui,sans-serif">GSM = grams</text>
      <text x="580" y="90" font-size="13" fill="#475569" font-family="system-ui,sans-serif">per square meter</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">GSM measures how many grams one square meter of the fabric weighs</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the GSM conversion works</h2>
    <p class="mt-2 text-slate-600">
      GSM (grams per square meter) and oz/yd² (ounces per square yard) both measure fabric density — how much a given area of fabric weighs — just in different unit systems. The conversion factor between them is fixed: 1 oz/yd² equals exactly 33.906 GSM, derived from converting ounces to grams and square yards to square meters. This calculator applies that constant in either direction.
    </p>
    <p class="mt-3 text-slate-600">
      Knowing this conversion matters because US-based patterns and fabric shops often list weight in oz/yd², while international suppliers, especially in Asia and Europe, list GSM — comparing two fabrics from different regions requires converting one to match the other first.
    </p>
    <p class="mt-3 text-xs text-slate-400">The 33.906 g/m² per oz/yd² conversion factor follows the standard textile-industry unit relationship referenced in ASTM D3776 (Standard Test Methods for Mass Per Unit Area of Fabric).</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A fabric listing shows 150 GSM and needs to be compared to a US supplier's oz/yd² fabric.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">GSM:</span> <span class="text-slate-600">150</span></div>
        <div><span class="font-medium text-slate-700">Conversion:</span> <span class="text-slate-600">150 ÷ 33.906</span></div>
        <div><span class="font-medium text-slate-700">Result:</span> <span class="text-slate-600"><strong>4.42 oz/yd²</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Sourcing fabric from international wholesale suppliers is the most common place this conversion gets used — a US-based small apparel brand comparing a domestic 6 oz/yd² denim against an overseas 200 GSM alternative needs both numbers in the same unit before the comparison means anything.
    </p>
    <p class="mt-3 text-slate-600">
      Pattern instructions increasingly list a recommended weight range to guide fabric substitution — a pattern calling for "6-8 oz/yd² mid-weight cotton" is directly useful to a US shopper but needs converting to roughly 200-270 GSM for a shopper only able to find fabric listed in metric weight.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"GSM tells you the fabric's fiber content." <strong class="text-slate-900">No.</strong> GSM only measures weight per area, not what the fabric is made of — a 150 GSM cotton and a 150 GSM polyester can feel completely different despite sharing the same GSM number.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A higher GSM always means a stiffer fabric." <strong class="text-slate-900">Not necessarily.</strong> Weave structure and fiber type affect drape and stiffness as much as raw weight — a heavy, loosely woven fabric can still drape more softly than a lighter, tightly woven one.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-unit-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Unit Converter</a>
      <a href="/tools/denier-tex-dtex-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Denier/Tex/Dtex Converter</a>
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Yardage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'GSM → oz/yd²';
    const FACTOR = 33.906;

    function update() {
      const v = parseFloat(el('value').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const result = mode === 'GSM → oz/yd²' ? v / FACTOR : v * FACTOR;
      el('r-value').textContent = result.toFixed(2) + (mode === 'GSM → oz/yd²' ? ' oz/yd²' : ' GSM');
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach((b) => {
          b.className = 'mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50';
        });
        btn.className = 'mode-btn rounded-lg border border-rose-300 bg-rose-100 px-4 py-1.5 text-sm font-medium text-rose-700 transition';
        mode = btn.dataset.mode;
        el('input-label').textContent = mode === 'GSM → oz/yd²' ? 'GSM (g/m²)' : 'oz/yd²';
        el('value').placeholder = mode === 'GSM → oz/yd²' ? 'e.g. 150' : 'e.g. 4.4';
        update();
      });
    });

    el('value').addEventListener('input', update);
    document.querySelector('.mode-btn').click();
  </script>
</ToolLayout>
