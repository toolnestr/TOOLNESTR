---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Water Tank Volume Calculator';
const description = 'Find how many gallons or liters a water tank holds from its shape and dimensions — vertical cylinder, horizontal cylinder, or rectangular tank.';
const intro = 'Find how many gallons and liters your water tank holds, from its shape and dimensions.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate the volume of a water tank in gallons?', a: 'First find the tank volume in cubic feet from its shape — length × width × height for a rectangular tank, or π × radius² × height for a cylinder. Then multiply cubic feet by 7.48 to get US gallons.' },
  { q: 'How many gallons is a cubic foot of water?', a: 'One cubic foot holds 7.48 US gallons (or about 28.32 liters). This is a fixed conversion, so any tank volume in cubic feet can be turned into gallons by multiplying by 7.48.' },
  { q: 'Does tank wall thickness matter?', a: 'For an accurate capacity you should measure the inside dimensions, since the walls take up space the water cannot. On thin plastic or steel tanks the difference is small, but on thick concrete cisterns it is worth subtracting the wall thickness from each dimension.' },
  { q: 'Why is my tank never completely full?', a: 'Most tanks have an overflow or air gap near the top and a small dead space at the bottom below the outlet, so the usable volume is a few percent less than the full geometric volume this calculator gives.' },
];
const howTo = {
  name: 'How to calculate water tank volume',
  steps: [
    { name: 'Pick the shape', text: 'Vertical cylinder, horizontal cylinder, or rectangular.' },
    { name: 'Measure inside, in inches', text: 'Use internal dimensions for a true capacity.' },
    { name: 'Read the capacity', text: 'Get gallons, liters, and imperial gallons at once.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Tank shape</span>
      <select id="shape" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="vcyl" selected>Vertical cylinder</option>
        <option value="hcyl">Horizontal cylinder</option>
        <option value="rect">Rectangular</option>
      </select></label>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label id="w-dia" class="block"><span class="text-sm font-medium text-slate-700">Diameter (in)</span>
        <input id="dia" type="number" step="any" placeholder="36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-height" class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="height" type="number" step="any" placeholder="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-len" class="hidden"><span class="text-sm font-medium text-slate-700">Length (in)</span>
        <input id="len" type="number" step="any" placeholder="72" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-width" class="hidden"><span class="text-sm font-medium text-slate-700">Width (in)</span>
        <input id="width" type="number" step="any" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Tank capacity</div>
        <div id="r-gal" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic feet</div><div id="r-cf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Liters</div><div id="r-l" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Imperial gal</div><div id="r-ig" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="240" viewBox="0 0 800 240" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="wt-title wt-desc">
      <title id="wt-title">Water tank shapes and the gallon formula</title>
      <desc id="wt-desc">A vertical cylinder, horizontal cylinder, and rectangular tank with the cubic-feet-to-gallons conversion</desc>
      <rect x="60" y="60" width="70" height="130" rx="6" fill="#dbeafe" stroke="#3b82f6" stroke-width="1.5" />
      <text x="95" y="215" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">vertical</text>
      <rect x="190" y="100" width="150" height="70" rx="34" fill="#dbeafe" stroke="#3b82f6" stroke-width="1.5" />
      <text x="265" y="215" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">horizontal</text>
      <rect x="400" y="80" width="120" height="110" rx="4" fill="#dbeafe" stroke="#3b82f6" stroke-width="1.5" />
      <text x="460" y="215" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">rectangular</text>
      <rect x="560" y="80" width="210" height="90" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="580" y="108" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Gallons</text>
      <text x="580" y="134" font-size="12" fill="#475569" font-family="system-ui,sans-serif">gal = ft&sup3; &times; 7.48</text>
      <text x="580" y="156" font-size="12" fill="#475569" font-family="system-ui,sans-serif">liters = ft&sup3; &times; 28.32</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Every shape reduces to a volume in cubic feet, which converts to gallons with one constant.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the water tank volume calculator works</h2>
    <p class="mt-2 text-slate-600">
      A tank's capacity is just its internal volume expressed in the units you buy or measure water in. The method is always two steps: find the volume in cubic feet from the tank's geometry, then convert cubic feet to gallons or liters with a fixed constant. One cubic foot of water is 7.48 US gallons, 6.23 imperial gallons, or 28.32 liters.
    </p>
    <p class="mt-3 text-slate-600">
      The geometry depends on the shape. A rectangular tank is length × width × height. A cylinder — whether it stands upright or lies on its side — is π × radius² × the length along its axis; for a vertical cylinder that axis is the height, and for a horizontal cylinder it is the barrel length. Because we work in inches, the calculator divides the cubic-inch result by 1728 to get cubic feet before converting to gallons.
    </p>
    <p class="mt-3 text-slate-600">
      For the most accurate capacity, measure the inside of the tank rather than the outside, since the walls displace water. The geometric volume is the tank filled to the brim; the usable volume is slightly less because of the overflow air gap at the top and the dead space below the outlet at the bottom.
    </p>
    <p class="mt-3 text-xs text-slate-400">The cubic-foot-to-gallon conversion (7.48 US gal/ft³, 28.32 L/ft³) follows the standard US customary and SI water-volume equivalents published by NIST.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick the shape</h3>
        <p class="mt-1 text-sm text-slate-600">Vertical cylinder, horizontal cylinder, or rectangular.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure inside, in inches</h3>
        <p class="mt-1 text-sm text-slate-600">Use internal dimensions for a true capacity.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the capacity</h3>
        <p class="mt-1 text-sm text-slate-600">Get gallons, liters, and imperial gallons at once.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Cylinder volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= &pi; &times; (dia&frasl;2)&sup2; &times; length</span> in cubic inches, then &divide; 1728 for cubic feet. A 36 in diameter, 60 in tall vertical tank: π × 18² × 60 = 61,073 in³ ÷ 1728 = <strong>35.3 ft³</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Convert to gallons</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">gal = ft&sup3; &times; 7.48</span> = 35.3 × 7.48 = <strong>264 US gallons</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Rectangular volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= L &times; W &times; H</span> in cubic inches, same &divide; 1728 and × 7.48 to reach gallons.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A rectangular cistern 72 in long × 30 in wide × 48 in high (inside).</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">72 × 30 × 48 = 103,680 in³</span></div>
        <div><span class="font-medium text-slate-700">Cubic feet:</span> <span class="text-slate-600">103,680 ÷ 1728 = 60 ft³</span></div>
        <div><span class="font-medium text-slate-700">US gallons:</span> <span class="text-slate-600">60 × 7.48 = <strong>449 gal</strong></span></div>
        <div><span class="font-medium text-slate-700">Liters:</span> <span class="text-slate-600">60 × 28.32 = 1,699 L</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the water tank volume calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌧️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Rainwater harvesting</h3>
        <p class="mt-1 text-sm text-slate-600">Size a cistern to capture runoff from your roof, and compare its capacity against your household's daily water use to plan for dry-season storage.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚜</span>
        <h3 class="mt-2 font-semibold text-slate-900">Livestock and irrigation</h3>
        <p class="mt-1 text-sm text-slate-600">Calculate horizontal tank capacity for a trailer-mounted water hauler or stationary stock tank, and confirm it fits your delivery truck's payload limits.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🔥</span>
        <h3 class="mt-2 font-semibold text-slate-900">Fire suppression storage</h3>
        <p class="mt-1 text-sm text-slate-600">Verify a vertical storage tank meets a required minimum gallon capacity for a rural fire-suppression water supply or sprinkler system reserve.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🐟</span>
        <h3 class="mt-2 font-semibold text-slate-900">Aquaculture and ponds</h3>
        <p class="mt-1 text-sm text-slate-600">Find the gallon capacity of a rectangular holding tank for fish or aquaponics, which determines stocking density and filtration sizing.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A common vertical tote-style storage tank, 48 inches in diameter and 72 inches tall, works out to π × 24² × 72 = 130,288 cubic inches, or 75.4 cubic feet — that's 564 US gallons, right in line with the widely used 550-gallon IBC tote size found on many rural properties for backup water storage.
    </p>
    <p class="mt-3 text-slate-600">
      A horizontal water-hauling tank mounted on a utility trailer, 24 inches in diameter and 96 inches long, holds π × 12² × 96 = 43,429 cubic inches, or 25.1 cubic feet, which converts to 188 gallons — light enough at roughly 1,570 lb of water that it stays well within a half-ton pickup's typical payload rating even fully loaded.
    </p>
    <p class="mt-3 text-slate-600">
      A rectangular rainwater cistern built into a basement or crawlspace, 96 inches long, 48 inches wide, and 60 inches deep (measured inside the walls), holds 96 × 48 × 60 = 276,480 cubic inches, or 160 cubic feet — that's 1,197 US gallons, enough to cover several weeks of household use for a family practicing water conservation during a dry spell.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A tank's rated capacity on the label is exactly how much water it holds." <strong class="text-slate-900">Rated capacity is usually rounded down from geometric volume.</strong> Manufacturers typically label a tank below its brim-full geometric volume to account for the overflow port, fill neck, and a safety margin, so the calculator's filled-to-the-brim figure will often read slightly higher than the printed rating.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"US gallons and imperial gallons are close enough to use interchangeably." <strong class="text-slate-900">The difference is about 20%.</strong> One imperial gallon equals roughly 1.2 US gallons, so a tank rated at 500 imperial gallons actually holds about 600 US gallons — mixing up the two units when ordering a tank or estimating fill time causes a meaningful miscalculation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A horizontal cylindrical tank holds the same amount whether it's full to the top or only half full by height." <strong class="text-slate-900">Volume does not scale linearly with fill height in a horizontal cylinder.</strong> Because the cross-section is a circle rather than a rectangle, a tank filled to half its diameter actually holds exactly half the volume, but any other partial fill level requires circular-segment geometry, not a simple percentage of height.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pool-volume-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Pool Volume Calculator</a>
      <a href="/tools/pond-volume-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Pond Volume Calculator</a>
      <a href="/tools/pipe-volume-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Pipe Volume Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function sync() {
      const shape = el('shape').value;
      el('w-dia').classList.toggle('hidden', shape === 'rect');
      el('w-height').classList.toggle('hidden', shape === 'hcyl');
      el('w-len').classList.toggle('hidden', shape !== 'rect' && shape !== 'hcyl');
      el('w-width').classList.toggle('hidden', shape !== 'rect');
      // relabel length field for horizontal cylinder
      el('w-len').querySelector('span').textContent = shape === 'hcyl' ? 'Barrel length (in)' : 'Length (in)';
      update();
    }

    function update() {
      const shape = el('shape').value;
      let cubicIn = 0;
      if (shape === 'vcyl') {
        const d = parseFloat(el('dia').value), h = parseFloat(el('height').value);
        if (!(d > 0 && h > 0)) return hide();
        cubicIn = Math.PI * Math.pow(d / 2, 2) * h;
      } else if (shape === 'hcyl') {
        const d = parseFloat(el('dia').value), L = parseFloat(el('len').value);
        if (!(d > 0 && L > 0)) return hide();
        cubicIn = Math.PI * Math.pow(d / 2, 2) * L;
      } else {
        const L = parseFloat(el('len').value), W = parseFloat(el('width').value), H = parseFloat(el('height').value);
        if (!(L > 0 && W > 0 && H > 0)) return hide();
        cubicIn = L * W * H;
      }
      const cf = cubicIn / 1728;
      const gal = cubicIn / 231;
      const liters = cf * 28.3168;
      const impGal = gal * 0.832674;

      el('r-gal').textContent = gal.toFixed(1) + ' US gal';
      el('r-note').textContent = cf.toFixed(1) + ' ft³ filled to the brim';
      el('r-cf').textContent = cf.toFixed(2) + ' ft³';
      el('r-l').textContent = liters.toFixed(0) + ' L';
      el('r-ig').textContent = impGal.toFixed(1) + ' gal';
      el('results').classList.remove('hidden');
    }
    function hide() { el('results').classList.add('hidden'); }

    el('shape').addEventListener('change', sync);
    ['dia', 'height', 'len', 'width'].forEach((id) => el(id).addEventListener('input', update));
    sync();
  </script>
</ToolLayout>
