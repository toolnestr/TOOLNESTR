---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Mortgage Calculator';
const description =
  'Free mortgage calculator. Estimate your monthly home loan payment, total interest and ' +
  'total cost from the price, down payment, interest rate and term. Works in any currency.';
const intro =
  'Enter the home price, your down payment, the interest rate and the loan term to see your monthly payment and total cost.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'What does the monthly payment include?', a: 'The main figure is principal + interest (P&I). If you add yearly property tax and home insurance, we also show an estimated total monthly payment including those.' },
  { q: 'How is the monthly payment calculated?', a: 'It uses the standard amortizing loan formula based on the loan amount (price minus down payment), the monthly interest rate, and the number of monthly payments.' },
  { q: 'Does it work in my currency?', a: 'Yes — pick your currency symbol. The calculation is the same everywhere.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Currency</span>
        <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option>$</option><option>€</option><option>£</option><option>₹</option><option>₨</option><option>¥</option><option>₦</option><option>A$</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Home price</span>
        <input id="price" type="number" step="any" placeholder="300000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Down payment</span>
        <input id="down" type="number" step="any" placeholder="60000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Interest rate % (per year)</span>
        <input id="rate" type="number" step="any" placeholder="6.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Loan term (years)</span>
        <input id="term" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Property tax / year (optional)</span>
        <input id="tax" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Home insurance / year (optional)</span>
        <input id="ins" type="number" step="any" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Monthly payment (total)</div><div id="r-total-month" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Principal & interest</div><div id="r-pi" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Loan amount</div><div id="r-loan" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Total interest</div><div id="r-interest" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this mortgage calculator</h2>
    <p class="mt-2 text-slate-600">
      Buying a home is a big decision, and knowing the monthly payment up front helps you budget
      with confidence. This calculator estimates your principal-and-interest payment, and can add
      property tax and insurance for a fuller monthly figure, plus the total interest you’ll pay
      over the life of the loan.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter the home price and your down payment.</li>
      <li>Add the interest rate and loan term.</li>
      <li>Optionally add yearly property tax and insurance.</li>
      <li>See your monthly payment and total cost instantly.</li>
    </ol>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/auto-loan" class="font-medium text-indigo-600 hover:underline">Auto Loan Calculator</a>
      or <a href="/tools/emi-calculator" class="font-medium text-indigo-600 hover:underline">Loan / EMI Calculator</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const cur = el('cur');
    const fmt = (n) => cur.value + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    function update() {
      const price = parseFloat(el('price').value) || 0;
      const down = parseFloat(el('down').value) || 0;
      const annual = parseFloat(el('rate').value);
      const years = parseFloat(el('term').value);
      const loan = price - down;
      if (loan <= 0 || isNaN(annual) || isNaN(years) || years <= 0) {
        ['r-total-month', 'r-pi', 'r-loan', 'r-interest'].forEach((id) => (el(id).textContent = '—')); return;
      }
      const n = years * 12, r = annual / 100 / 12;
      const pi = r === 0 ? loan / n : loan * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
      const extras = ((parseFloat(el('tax').value) || 0) + (parseFloat(el('ins').value) || 0)) / 12;
      el('r-pi').textContent = fmt(pi);
      el('r-total-month').textContent = fmt(pi + extras);
      el('r-loan').textContent = fmt(loan);
      el('r-interest').textContent = fmt(pi * n - loan);
    }
    ['cur', 'price', 'down', 'rate', 'term', 'tax', 'ins'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
