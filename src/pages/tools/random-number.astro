---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Random Number Generator';
const description =
  'Free random number generator. Generate one or many random numbers in any range, with or ' +
  'without duplicates. Great for draws, games, lotteries and testing.';
const intro =
  'Set a range and how many numbers you need, then generate. Choose integers or decimals, and allow or prevent duplicates.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'Can I generate numbers without duplicates?', a: 'Yes — untick "allow duplicates" and every number generated will be unique (useful for raffles and draws).' },
  { q: 'Are the numbers truly random?', a: 'They use your browser\'s built-in random generator, which is more than random enough for games, draws and everyday use.' },
  { q: 'Can I generate decimals?', a: 'Yes — untick "integers only" to get decimal numbers within your range.' },
  { q: 'How many numbers can I generate at once?', a: 'Up to 1,000. For very large sets with no duplicates, make sure the range is larger than the count.' },
  { q: 'What happens if I set a range where min > max?', a: 'The calculator will show an error asking you to make the minimum less than or equal to the maximum.' },
  { q: 'Can I copy the generated numbers?', a: 'Yes — click the "Copy" button to copy the full list of numbers to your clipboard.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Minimum</span>
        <input id="min" type="number" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Maximum</span>
        <input id="max" type="number" value="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">How many</span>
        <input id="count" type="number" value="1" min="1" max="1000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-3 flex flex-wrap gap-4 text-sm text-slate-700">
      <label class="flex items-center gap-2"><input id="ints" type="checkbox" checked class="h-4 w-4 rounded border-slate-300" /> Integers only</label>
      <label class="flex items-center gap-2"><input id="dupes" type="checkbox" checked class="h-4 w-4 rounded border-slate-300" /> Allow duplicates</label>
    </div>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <button id="gen" class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700">Generate</button>
      <button id="copy" class="rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Copy</button>
    </div>
    <div id="output" class="mt-4 min-h-[3rem] rounded-xl border border-slate-200 bg-slate-50 p-4 text-center text-2xl font-bold text-indigo-600">—</div>
    <p id="err" class="mt-2 hidden text-sm text-red-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Set the minimum and maximum values for your range.</li>
      <li>Choose how many numbers to generate and whether they should be integers or decimals.</li>
      <li>Toggle "Allow duplicates" on or off, then click "Generate".</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Random number generators are used far beyond games and raffles. Teachers use them to randomly assign students to groups or pick quiz questions. Developers generate random test data to stress-test their applications. Statisticians use random sampling to select unbiased subsets from larger datasets. Event organisers rely on them for fair prize draws, and board game fans use them when they’ve misplaced their dice.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>For a fair raffle or draw, turn off "Allow duplicates" and set the count to match the number of prizes.</li>
      <li>Use decimal mode with a wide range (e.g., 0–1000) for more granular random values in simulations.</li>
      <li>If you need cryptographically secure random numbers, use the <a href="/tools/password-generator" class="font-medium text-indigo-600 hover:underline">Password Generator</a> instead.</li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this random number generator</h2>
    <p class="mt-2 text-slate-600">
      Need to pick a winner, roll a number, run a quick draw or generate test data? This tool
      creates random numbers in any range you set. Generate a single number or a whole list, with
      or without repeats — all instantly in your browser.
      Pair it with the <a href="/tools/password-generator" class="font-medium text-indigo-600 hover:underline">Password Generator</a>
      for secure random credentials or the <a href="/tools/standard-deviation" class="font-medium text-indigo-600 hover:underline">Standard Deviation Calculator</a>
      to analyse your generated data.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function generate() {
      const min = parseFloat(el('min').value), max = parseFloat(el('max').value);
      let count = Math.max(1, Math.min(parseInt(el('count').value, 10) || 1, 1000));
      const ints = el('ints').checked, dupes = el('dupes').checked;
      el('err').classList.add('hidden');
      if (isNaN(min) || isNaN(max) || min > max) { el('err').textContent = 'Minimum must be less than or equal to maximum.'; el('err').classList.remove('hidden'); return; }
      if (!dupes && ints) {
        const range = Math.floor(max) - Math.ceil(min) + 1;
        if (count > range) { el('err').textContent = `Only ${range} unique whole numbers fit in this range.`; el('err').classList.remove('hidden'); return; }
      }
      const out = [];
      const seen = new Set();
      let guard = 0;
      while (out.length < count && guard < count * 1000 + 1000) {
        guard++;
        let n = Math.random() * (max - min) + min;
        if (ints) n = Math.floor(Math.random() * (Math.floor(max) - Math.ceil(min) + 1)) + Math.ceil(min);
        else n = Math.round(n * 1000) / 1000;
        if (!dupes) { if (seen.has(n)) continue; seen.add(n); }
        out.push(n);
      }
      el('output').textContent = out.join(', ');
    }

    el('gen').addEventListener('click', generate);
    el('copy').addEventListener('click', async () => {
      const t = el('output').textContent;
      if (!t || t === '—') return;
      try { await navigator.clipboard.writeText(t); const b = el('copy'); const o = b.textContent; b.textContent = 'Copied!'; setTimeout(() => (b.textContent = o), 1200); } catch (e) {}
    });
    generate();
  </script>
</ToolLayout>
