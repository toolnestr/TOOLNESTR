---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Deck Calculator';
const description = 'Calculate the number of deck boards, joists, and fasteners needed for a deck from its dimensions. Plan materials and budget for your next deck build.';
const intro = 'Estimate all materials for your deck — boards, joists, and fasteners from dimensions.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'What is the standard spacing for deck joists?', a: 'Deck joists are typically spaced 16 inches on center for residential decks. For commercial or heavy-load decks, use 12-inch spacing. For lightweight decks, 24-inch spacing may be acceptable.' },
  { q: 'What size lumber should I use for deck joists?', a: 'For most residential decks, 2x8 or 2x10 joists are standard. The span determines the size — a 2x8 can span up to 10 ft, a 2x10 up to 13 ft, and a 2x12 up to 16 ft depending on wood species and spacing.' },
  { q: 'Do I need permits for building a deck?', a: 'Most municipalities require permits for decks over 30 inches above grade. Permits ensure the deck meets building codes for structural safety, railing height, and proper footing depth. Always check local requirements before starting.' },
  { q: 'What is the best wood for decking?', a: 'Pressure-treated pine is affordable and durable. Cedar and redwood are naturally rot-resistant but more expensive. Composite decking (Trex, TimberTech) costs more upfront but requires no staining or sealing.' },
];
const howTo = {
  name: 'How to calculate deck boards, joists, and fasteners',
  steps: [
    { name: 'Plan the deck size', text: 'Measure the planned deck length and width. Check local building codes for size limits.' },
    { name: 'Choose materials', text: 'Select board width, joist spacing, and decking gap. Composite and wood have different recommendations.' },
    { name: 'Order materials', text: 'Use the board, joist, and fastener counts to create a complete material list for your deck project.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Deck length (ft)</span>
        <input id="length" type="number" step="any" placeholder="16" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Deck width (ft)</span>
        <input id="width" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Board width (in)</span>
        <input id="bw" type="number" step="any" placeholder="5.5" value="5.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Joist spacing (in)</span>
        <input id="js" type="number" step="any" placeholder="16" value="16" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Decking gap</span>
      <div class="mt-1 flex gap-2">
        {['1/8"', '1/4"'].map((g) => (
          <button data-gap={g.replace(/[^0-9]/g, '')} class="gap-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{g}</button>
        ))}
      </div>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Deck boards needed</div>
        <div id="r-boards" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-sf" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Joists needed</div><div id="r-joists" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Deck area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Fasteners (lbs)</div><div id="r-fast" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="deck-title deck-desc">
      <title id="deck-title">Deck framing plan diagram</title>
      <desc id="deck-desc">An overhead view of a deck showing joist framing and deck board direction</desc>
      <rect x="80" y="60" width="560" height="240" fill="#f8fafc" stroke="#cbd5e1" stroke-width="2" rx="4" />
      <g fill="#d1d5db">
        <rect x="90" y="60" width="6" height="240" rx="1" />
        <rect x="200" y="60" width="6" height="240" rx="1" />
        <rect x="310" y="60" width="6" height="240" rx="1" />
        <rect x="420" y="60" width="6" height="240" rx="1" />
        <rect x="530" y="60" width="6" height="240" rx="1" />
        <rect x="634" y="60" width="6" height="240" rx="1" />
      </g>
      <g fill="#bfdbfe" opacity="0.5">
        <rect x="80" y="70" width="560" height="20" rx="1" />
        <rect x="80" y="100" width="560" height="20" rx="1" />
        <rect x="80" y="130" width="560" height="20" rx="1" />
        <rect x="80" y="160" width="560" height="20" rx="1" />
        <rect x="80" y="190" width="560" height="20" rx="1" />
        <rect x="80" y="220" width="560" height="20" rx="1" />
        <rect x="80" y="250" width="560" height="20" rx="1" />
        <rect x="80" y="280" width="560" height="20" rx="1" />
      </g>
      <text x="360" y="340" text-anchor="middle" font-size="13" fill="#64748b" font-family="system-ui,sans-serif">Deck boards run perpendicular to joists (shown as vertical lines)</text>
      <line x1="80" y1="40" x2="640" y2="40" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="360" y="30" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Deck length</text>
      <line x1="60" y1="60" x2="60" y2="300" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="48" y="185" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif" transform="rotate(-90 48 185)">Deck width</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Overhead view of deck framing — joists run lengthwise, deck boards run across them</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the deck calculator works</h2>
    <p class="mt-2 text-slate-600">
      The deck calculator estimates the materials needed for a rectangular deck. It calculates the surface area, the number of deck boards required based on board width and gap, the number of joists based on spacing, and an estimate of fasteners needed.
    </p>
    <p class="mt-3 text-slate-600">
      Deck boards are the visible surface of the deck. They run perpendicular to the joists and are spaced with a small gap for drainage. Standard 5/4-inch deck boards are 5.5 inches wide after milling. The calculator accounts for the board width plus the gap to determine how many boards fit across the deck width.
    </p>
    <p class="mt-3 text-slate-600">
      Joists are the structural supports beneath the deck boards. They run the length of the deck and are spaced at regular intervals. The number of joists depends on the deck length and the spacing. Rim joists at each end are included automatically. A double joist may be needed for heavy loads or where the deck attaches to the house.
    </p>
    <p class="mt-3 text-xs text-slate-400">Joist spacing and span guidance follows IRC (International Residential Code) Section R507 for deck construction and typical manufacturer span tables for pressure-treated lumber.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Plan the deck size</h3>
        <p class="mt-1 text-sm text-slate-600">Measure the planned deck length and width. Check local building codes for size limits.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose materials</h3>
        <p class="mt-1 text-sm text-slate-600">Select board width, joist spacing, and decking gap. Composite and wood have different recommendations.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Order materials</h3>
        <p class="mt-1 text-sm text-slate-600">Use the board, joist, and fastener counts to create a complete material list for your deck project.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Deck boards</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Boards = ceil(width / (bw/12 + gap/12))</span>. For a 12-ft wide deck with 5.5&Prime; boards and 1/8&Prime; gap: each board covers 5.625&Prime; (0.46875 ft). 12 / 0.46875 = <strong>25.6, round to 26 boards</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Joists</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Joists = ceil(length / (js/12)) + 1</span>. For a 16-ft deck with 16&Prime; spacing: (16 &times; 12) / 16 = 12 spaces. Joists = 12 + 1 = <strong>13 joists</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Fasteners</p>
        <p class="mt-1 text-slate-600">
          Roughly 2.5 lbs of deck screws per 100 sq ft of decking. For a 192 sq ft deck: 192 / 100 &times; 2.5 ≈ <strong>4.8 lbs of screws</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 14&prime; &times; 10&prime; deck using 5.5&Prime; boards with 1/8&Prime; gap, 16&Prime; joist spacing.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Deck area:</span> <span class="text-slate-600">14 &times; 10 = 140 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Boards across:</span> <span class="text-slate-600">10 / (5.5/12 + 0.125/12) = 21.3 → <strong>22 boards</strong></span></div>
        <div><span class="font-medium text-slate-700">Joists:</span> <span class="text-slate-600">(14&times;12)/16 + 1 = <strong>12 joists</strong></span></div>
        <div><span class="font-medium text-slate-700">Screws:</span> <span class="text-slate-600">140/100 &times; 2.5 ≈ <strong>3.5 lbs</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the deck calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Backyard deck</h3>
        <p class="mt-1 text-sm text-slate-600">Build a backyard deck for grilling and entertaining. The calculator helps you budget for materials, compare wood vs. composite pricing, and plan the complete material list before starting.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Pool deck</h3>
        <p class="mt-1 text-sm text-slate-600">A deck around an above-ground or in-ground pool needs special materials. Use composite or tropical hardwood for moisture resistance. The calculator adapts to any board width and spacing.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌿</span>
        <h3 class="mt-2 font-semibold text-slate-900">Platform and step</h3>
        <p class="mt-1 text-sm text-slate-600">Small platforms, porch steps, and landing pads use the same deck construction principles. Enter your smaller dimensions to get an accurate material count for these compact projects.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Walkway and bridge</h3>
        <p class="mt-1 text-sm text-slate-600">A raised walkway or small garden bridge uses deck framing techniques. Calculate the joists and deck boards needed, then add railing materials separately.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for building a deck</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use hidden fasteners for a clean look</h3>
        <p class="mt-1 text-sm text-slate-600">Hidden deck fasteners (clip systems) eliminate visible screw holes on the deck surface. They cost more per square foot but create a cleaner, more professional finish. Composite decking often requires hidden fasteners for warranty compliance.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Stagger deck board joints</h3>
        <p class="mt-1 text-sm text-slate-600">When joining boards end-to-end on long decks, stagger the joints across different joists rather than aligning them all on the same joist. This distributes the weak points and creates a stronger, more visually appealing deck surface.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Slope away from the house</h3>
        <p class="mt-1 text-sm text-slate-600">The deck surface should slope away from the house at 1/4 inch per foot to prevent water pooling near the foundation. This slight incline is barely noticeable but critical for preventing moisture damage to both the deck and the house structure.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A large entertaining deck shows how quickly material counts scale with size. A 20 ft by 16 ft deck using standard 5.5-inch boards with a 1/8-inch gap and 16-inch joist spacing has a 320 sq ft surface, needs 35 boards to span the 16 ft width, 16 joists along the 20 ft length, and about 8 lbs of deck screws — enough hardware that most builders buy screws by the 5 lb box rather than counting individual fasteners.
    </p>
    <p class="mt-3 text-slate-600">
      A small platform or porch landing uses the same math at a fraction of the scale. An 8 ft by 6 ft platform with the same 5.5-inch boards and 1/8-inch gap needs only 13 boards across the 6 ft width and 7 joists along the 8 ft length, with roughly 1.2 lbs of fasteners — small enough that a single box of screws typically covers two or three platforms like this.
    </p>
    <p class="mt-3 text-slate-600">
      A composite pool deck illustrates how tighter joist spacing changes the joist count more than the board count. A 24 ft by 12 ft deck with 5.5-inch boards, a wider 1/4-inch gap common with composite decking, and 12-inch joist spacing (often specified for composite to prevent sagging) has a 288 sq ft surface, needs 26 boards across the 12 ft width, but 25 joists along the 24 ft length — nearly double the joist count of a comparable 16-inch-spacing deck, since composite manufacturers frequently require the tighter spacing to maintain their structural warranty.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Composite decking can use the same joist spacing as wood." <strong class="text-slate-900">Usually not.</strong> Most composite manufacturers require 12-inch on-center joist spacing (versus the 16-inch standard for wood decking) because composite boards are more prone to deflection between supports, especially on angled or diagonal installations. Installing composite over 16-inch spacing can void the manufacturer's warranty even if the deck looks fine initially.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any deck under a couple feet off the ground doesn't need a permit or inspection." <strong class="text-slate-900">Height isn't the only trigger.</strong> While many jurisdictions do exempt low decks from permitting, structural attachment to the house (the ledger board connection), electrical work for lighting, and even deck size can independently require a permit regardless of height. Always check local code before assuming a low deck is exempt.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/board-foot-lumber-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Board Foot / Lumber Calculator</a>
      <a href="/tools/square-footage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
      <a href="/tools/fence-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fence Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let gapIn = 0.125;

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      const bw = parseFloat(el('bw').value);
      const js = parseFloat(el('js').value);
      if (!L || !W || !bw || !js || L <= 0 || W <= 0 || bw <= 0 || js <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const area = L * W;
      const boardCoverage = (bw + gapIn) / 12;
      const numBoards = Math.ceil(W / boardCoverage);
      const numJoists = Math.ceil((L * 12) / js) + 1;
      const fasteners = (area / 100) * 2.5;

      el('r-boards').textContent = numBoards.toLocaleString() + ' boards';
      el('r-sf').textContent = area.toFixed(1) + ' sq ft';
      el('r-joists').textContent = numJoists.toLocaleString() + ' joists';
      el('r-area').textContent = area.toFixed(1) + ' sq ft';
      el('r-fast').textContent = fasteners.toFixed(2) + ' lbs';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.gap-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.gap-btn').forEach((b) => {
          b.className = 'gap-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50';
        });
        btn.className = 'gap-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
        gapIn = parseInt(btn.dataset.gap, 10) / 8;
        update();
      });
    });

    ['length', 'width', 'bw', 'js'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
    document.querySelector('.gap-btn').click();
  </script>
</ToolLayout>
