---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Torque Calculator';
const description = 'Torque calculator with a live 3D lever arm and charts. Solve τ = rFsinθ for torque, lever arm, force, or angle, with worked examples for wrenches, doors, and tools.';
const intro = 'Solve τ = rFsinθ for any of torque, lever-arm distance, force, or the angle between them. A live 3D wrench arm rotates around a pivot as you adjust r, F and θ, and charts show how torque depends on angle and distance.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is torque?', a: 'Torque (τ) is the rotational equivalent of force — a measure of how much a force twists an object around a pivot or axis. τ = rFsinθ, where r is the lever-arm distance, F is the force magnitude, and θ is the angle between the lever arm and the force. Units are newton-metres (N·m).' },
  { q: 'Why does the angle matter?', a: 'Only the component of force perpendicular to the lever arm produces rotation. At θ = 90° (force perpendicular to the arm), sinθ = 1 and you get the maximum torque τ = rF. At θ = 0° or 180° (force along the arm), sinθ = 0 and the torque is zero — pushing or pulling straight along a wrench handle does not turn anything.' },
  { q: 'How is torque different from force?', a: 'Force causes linear acceleration (F = ma); torque causes angular acceleration. The same force produces more torque the farther it is applied from the pivot, which is why a longer wrench (or a longer handle) makes it easier to loosen a stuck bolt.' },
  { q: 'What is a "lever arm"?', a: 'The lever arm (or moment arm) is the perpendicular distance from the pivot to the line along which the force acts. In the simplified case where the force is applied perpendicular to a straight arm of length r, the lever arm equals r itself.' },
  { q: 'What does a negative or zero torque mean?', a: 'Sign indicates rotation direction — by convention, positive torque rotates counterclockwise and negative rotates clockwise. Zero torque means the force passes through the pivot (r = 0) or is applied exactly along the lever arm (θ = 0° or 180°), so it produces no rotation at all.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Torque Calculator',
  description: 'Calculate torque from lever-arm distance, force, and angle using τ = rFsinθ.',
  steps: [
    { name: 'Choose what to solve for', text: 'Pick torque, lever arm, force, or angle as the unknown.' },
    { name: 'Enter the other three values', text: 'Fill in the remaining quantities — angle defaults to 90°, the common perpendicular case.' },
    { name: 'Read the result', text: 'The torque solves instantly, and the 3D lever arm and charts update.' },
  ],
};

const formulas = [
  { expr: 'τ = r · F · sin θ', note: 'torque = lever arm × force × sine of the angle between them' },
  { expr: 'τ<sub>max</sub> = r · F', note: 'at θ = 90°, the common simplified case (force perpendicular to the arm)' },
  { expr: 'θ = arcsin(τ / rF)', note: 'solving for the angle given torque, r and F' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — tightening a bolt', tone: 'slate',
    given: 'A mechanic applies 150 N perpendicular to a 0.30 m wrench handle (θ = 90°). Find the torque.',
    rows: [
      { label: 'Formula:', value: 'τ = rFsinθ' },
      { label: 'Substitute:', value: 'τ = 0.30 × 150 × sin(90°) = 0.30 × 150 × 1' },
      { label: 'Torque:', value: 'τ = 45 N·m', full: true },
    ],
  },
  {
    title: 'Worked example 2 — pushing at an angle', tone: 'amber',
    given: 'A 0.25 m long door handle is pushed with 40 N, but at 30° to the handle rather than perpendicular. Find the torque.',
    rows: [
      { label: 'Formula:', value: 'τ = rFsinθ' },
      { label: 'Substitute:', value: 'τ = 0.25 × 40 × sin(30°) = 0.25 × 40 × 0.5' },
      { label: 'Torque:', value: 'τ = 5 N·m', full: true },
    ],
    note: 'Compare to a perpendicular push at the same distance and force: τ = 0.25 × 40 × 1 = 10 N·m — the angled push delivers only half the torque.',
  },
];

const comparison = {
  heading: 'Torque for common tools and tasks',
  note: 'Approximate values, assuming force applied perpendicular to the lever arm (θ = 90°).',
  headers: [{ label: 'Task' }, { label: 'Lever arm r', sub: 'm' }, { label: 'Force F', sub: 'N' }, { label: 'Torque τ', sub: 'N·m' }],
  rows: [
    ['Tightening a small screw', '0.05', '20', '1'],
    ['Car lug nut (hand wrench)', '0.30', '150', '45'],
    ['Opening a door', '0.80', '25', '20'],
    ['Car engine (typical peak)', '—', '—', '~200–400'],
    ['Bicycle pedal crank', '0.17', '300', '~51'],
  ],
  highlightIndex: 1,
  footnote: 'τ = rF at θ = 90°; real tools rarely apply force perfectly perpendicular, so effective torque is often somewhat lower.',
};

const realWorld = [
  { emoji: '🔧', title: 'Wrenches and bolts', body: 'A longer wrench handle increases the lever arm r, letting you produce the same torque with less force — or a much larger torque with the same force, which is why breaker bars exist for stuck bolts.' },
  { emoji: '🚪', title: 'Door hinges', body: 'Pushing a door near the hinge (small r) takes far more force to open than pushing near the handle (large r), because torque depends on the lever arm, not force alone. This is also why door handles are placed as far from the hinge as practical.' },
  { emoji: '🏎️', title: 'Engine torque specs', body: 'Car and motorcycle engines are rated by torque (N·m or lb-ft) as well as power. Torque measures the twisting force available at the crankshaft, which determines acceleration and towing capability at a given engine speed.' },
];

const misconceptions = [
  { claim: '"More force always means more torque."', truth: 'Only if the lever arm and angle stay the same. A small force far from the pivot, applied perpendicular to the arm, can out-torque a large force applied close to the pivot or at a shallow angle.' },
  { claim: '"Torque and force are the same physical quantity."', truth: 'They have different units (N·m vs N) and different roles: force causes linear acceleration, torque causes angular acceleration. Torque is force times a distance (and an angle factor), not force itself.' },
  { claim: '"Pushing along the handle still turns the bolt."', truth: 'A force applied exactly along the lever arm (θ = 0° or 180°) has sinθ = 0, so it produces zero torque — only the component of force perpendicular to the arm contributes to rotation.' },
  { claim: '"Doubling the wrench length always doubles the torque."', truth: 'True only if the applied force and angle stay the same. In practice a longer handle changes the geometry and grip, and torque scales with r only when F and θ are held fixed.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §10.6 "Torque" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/10-6-torque" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 10, Rotation.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 10, Rotation of a Rigid Object About a Fixed Axis.' },
];
const sourcesNote = 'Results are rounded for display. τ = rFsinθ; θ is the angle between the lever-arm and force vectors, measured in degrees here.';

const howToUse = [
  { title: 'Choose the unknown', body: 'The calculator solves for torque, r, F, or θ from the other three.' },
  { title: 'Enter the other values', body: 'Angle defaults to 90° (force perpendicular to the arm), the most common case.' },
  { title: 'Watch the lever arm', body: 'Use the sliders to see how r, F and θ change the rotation and torque arrow in 3D.' },
];

const related = [
  { href: '/tools/force-calculator', emoji: '💥', title: 'Force Calculator', desc: 'F = ma — solve for any variable.' },
  { href: '/tools/uniform-circular-motion-calculator', emoji: '🔄', title: 'Uniform Circular Motion Calculator', desc: 'Centripetal accel/force, period, ω from r and v.' },
  { href: '/tools/momentum-calculator', emoji: '🎯', title: 'Momentum & Impulse Calculator', desc: 'p = mv plus a combined impulse mode.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="torque is how much a force twists something around a pivot — it depends on how far from the pivot you push, how hard you push, and how perpendicular that push is."
  howIntro="Rearranged, τ = rFsinθ solves any variable: F = τ/(r sinθ), r = τ/(F sinθ), and θ = arcsin(τ/(rF)). The sinθ factor means only the perpendicular component of the force actually contributes to rotation — a push straight along the lever arm produces no torque at all."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where torque actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-tau" type="button" data-solve="tau" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Torque (τ)</button>
      <button id="mode-r" type="button" data-solve="r" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Lever arm (r)</button>
      <button id="mode-f" type="button" data-solve="f" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Force (F)</button>
      <button id="mode-theta" type="button" data-solve="theta" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Angle (θ)</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-4">
      <label id="field-tau" class="block"><span class="text-sm font-medium text-slate-700">Torque (τ)</span>
        <input id="tau" type="number" step="any" placeholder="N·m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-r" class="block"><span class="text-sm font-medium text-slate-700">Lever arm (r)</span>
        <input id="r" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-f" class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="f" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-theta" class="block"><span class="text-sm font-medium text-slate-700">Angle (θ)</span>
        <input id="theta" type="number" step="any" placeholder="°" value="90" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div id="box-tau" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Torque</div><div id="r-tau" class="mt-1 text-2xl font-bold">—</div></div>
      <div id="box-r" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Lever arm</div><div id="r-r" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-f" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Force</div><div id="r-f" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-theta" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Angle</div><div id="r-theta" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="tq-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-lever" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Torque needs a lever arm, force, and angle</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-indigo-600">indigo</span> arm of length r pivots at the centre. The <span class="font-semibold text-red-500">red</span> force arrow is applied at angle θ to the arm — only its perpendicular component actually twists the arm.</p>
        </div>
        <div>
          <div id="diag-sine" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Torque follows a sine curve</h3>
          <p class="mt-1 text-sm text-slate-600">Three lever arms (short, medium, long) traced as τ vs θ — every curve peaks at 90° and hits zero at 0° and 180°, because torque scales with sinθ.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Torque graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Torque vs angle (at your current r, F) — a sine curve, max at 90°</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-theta"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Torque vs lever arm (at your current F, θ) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-r"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };
      const D2R = Math.PI / 180;

      // ---- calculator ----
      let solveFor = 'tau';
      const modeBtns = { tau: 'mode-tau', r: 'mode-r', f: 'mode-f', theta: 'mode-theta' };
      const fieldEls = { tau: 'field-tau', r: 'field-r', f: 'field-f', theta: 'field-theta' };
      const boxEls = { tau: 'box-tau', r: 'box-r', f: 'box-f', theta: 'box-theta' };

      function switchSolve(s) {
        solveFor = s;
        Object.keys(modeBtns).forEach((k) => {
          el(modeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(fieldEls).forEach((k) => {
          el(fieldEls[k]).style.opacity = k === s ? '0.45' : '1';
        });
        Object.keys(boxEls).forEach((k) => {
          el(boxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        update();
      }

      function update() {
        el('tq-err').textContent = '';
        ['r-tau', 'r-r', 'r-f', 'r-theta'].forEach((id) => (el(id).textContent = '—'));
        const tau = parseFloat(el('tau').value);
        const r = parseFloat(el('r').value);
        const f = parseFloat(el('f').value);
        const theta = parseFloat(el('theta').value);

        if (solveFor === 'tau') {
          if (isNaN(r) || isNaN(f) || isNaN(theta)) return;
          const t = r * f * Math.sin(theta * D2R);
          el('r-tau').textContent = fmt(t) + ' N·m';
          el('r-r').textContent = fmt(r) + ' m';
          el('r-f').textContent = fmt(f) + ' N';
          el('r-theta').textContent = fmt(theta) + '°';
        } else if (solveFor === 'r') {
          if (isNaN(tau) || isNaN(f) || isNaN(theta)) return;
          const s = Math.sin(theta * D2R);
          if (f === 0 || s === 0) { el('tq-err').textContent = 'Force and sin(θ) must be nonzero to solve for r.'; return; }
          const rr = tau / (f * s);
          el('r-tau').textContent = fmt(tau) + ' N·m';
          el('r-r').textContent = fmt(rr) + ' m';
          el('r-f').textContent = fmt(f) + ' N';
          el('r-theta').textContent = fmt(theta) + '°';
        } else if (solveFor === 'f') {
          if (isNaN(tau) || isNaN(r) || isNaN(theta)) return;
          const s = Math.sin(theta * D2R);
          if (r === 0 || s === 0) { el('tq-err').textContent = 'Lever arm and sin(θ) must be nonzero to solve for F.'; return; }
          const ff = tau / (r * s);
          el('r-tau').textContent = fmt(tau) + ' N·m';
          el('r-r').textContent = fmt(r) + ' m';
          el('r-f').textContent = fmt(ff) + ' N';
          el('r-theta').textContent = fmt(theta) + '°';
        } else if (solveFor === 'theta') {
          if (isNaN(tau) || isNaN(r) || isNaN(f)) return;
          if (r === 0 || f === 0) { el('tq-err').textContent = 'Lever arm and force must be nonzero to solve for θ.'; return; }
          const ratio = tau / (r * f);
          if (ratio < -1 || ratio > 1) { el('tq-err').textContent = 'No valid angle: τ/(rF) must be between -1 and 1.'; return; }
          const th = Math.asin(ratio) / D2R;
          el('r-tau').textContent = fmt(tau) + ' N·m';
          el('r-r').textContent = fmt(r) + ' m';
          el('r-f').textContent = fmt(f) + ' N';
          el('r-theta').textContent = fmt(th) + '°';
        }
      }
      el('mode-tau').addEventListener('click', () => switchSolve('tau'));
      el('mode-r').addEventListener('click', () => switchSolve('r'));
      el('mode-f').addEventListener('click', () => switchSolve('f'));
      el('mode-theta').addEventListener('click', () => switchSolve('theta'));
      ['tau', 'r', 'f', 'theta'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts shared state ----
      const charts = {};
      const B = { r: 0.3, F: 150, theta: 90 };

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.theta = new Chart(el('chart-theta'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'τ', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Angle θ (°)' } }, y: { title: { display: true, text: 'Torque (N·m)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.r = new Chart(el('chart-r'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'τ', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.10)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Lever arm r (m)' } }, y: { title: { display: true, text: 'Torque (N·m)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(B);
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L1 = [], D1 = [];
        for (let th = 0; th <= 180.001; th += 5) { L1.push(th.toFixed(0)); D1.push(+(s.r * s.F * Math.sin(th * D2R)).toFixed(3)); }
        charts.theta.data.labels = L1; charts.theta.data.datasets[0].data = D1; charts.theta.update();

        const L2 = [], D2 = [];
        for (let rr = 0.05; rr <= 1.0001; rr += 0.05) { L2.push(rr.toFixed(2)); D2.push(+(rr * s.F * Math.sin(s.theta * D2R)).toFixed(3)); }
        charts.r.data.labels = L2; charts.r.data.datasets[0].data = D2; charts.r.update();
      }

      // ---- Diagram 1: lever arm, force vector at angle theta, static snapshot (auto-rotating) ----
      let diagLever = null;
      function initDiagLever() {
        const c = el('diag-lever'); if (!c) throw new Error('no container');
        const s = makeScene(c, 8, new THREE.Vector3(1.5, 0.6, 0), OPTS);
        s.scene.add(new THREE.GridHelper(10, 10, 0xe2e8f0, 0xeef2f7));
        const pivot = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 0.5, 20), new THREE.MeshStandardMaterial({ color: 0x334155 }));
        pivot.rotation.x = Math.PI / 2; s.scene.add(pivot);
        const len = 3.2;
        const arm = new THREE.Mesh(new THREE.BoxGeometry(len, 0.2, 0.2), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
        arm.position.x = len / 2; s.scene.add(arm);
        const theta = 60 * D2R;
        const tip = new THREE.Vector3(len, 0, 0);
        const fLen = 1.8;
        const dir = new THREE.Vector3(Math.cos(theta), Math.sin(theta), 0);
        const origin = tip.clone().sub(dir.clone().multiplyScalar(fLen));
        s.scene.add(arrow(origin, tip, 0xef4444));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagLever = { resize: s.resize };
      }

      // ---- Diagram 2: family of torque-vs-angle sine curves at different r ----
      let diagSine = null;
      function initDiagSine() {
        const c = el('diag-sine'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(4, 2, 0), OPTS);
        const grid = new THREE.GridHelper(16, 16, 0xe2e8f0, 0xeef2f7); grid.position.set(4, 0, 0); s.scene.add(grid);
        const F = 150;
        const radii = [0.15, 0.3, 0.5];
        radii.forEach((r) => {
          const pts = [];
          for (let th = 0; th <= 180; th += 6) {
            const x = (th / 180) * 8;
            const y = r * F * Math.sin(th * D2R) * 0.03;
            pts.push(new THREE.Vector3(x, y, 0));
          }
          const col = r === 0.3 ? 0x4f46e5 : 0x94a3b8;
          const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: col, transparent: r !== 0.3, opacity: r === 0.3 ? 1 : 0.7 }));
          s.scene.add(line);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0035); s.renderer.render(s.scene, s.camera); }
        frame();
        diagSine = { resize: s.resize };
      }

      function boot() {
        try { switchSolve('tau'); update(); } catch (e) { console.error('[torque] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[torque] charts failed', e); }
        if (window.THREE) {
          try { initDiagLever(); } catch (e) { console.error('[torque] lever diagram failed', e); }
          try { initDiagSine(); } catch (e) { console.error('[torque] sine diagram failed', e); }
        }
        mountResize([diagLever, diagSine]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
