---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Time Calculator';
const description =
  'Free time calculator. Add or subtract two durations in hours, minutes and seconds and get ' +
  'the result, plus the total in seconds. Instant and private.';
const intro =
  'Enter two durations and choose add or subtract to get the combined time in hours, minutes and seconds.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'What can I do with this?', a: 'Add up durations (like lap times or task times) or find the difference between two durations. The result is shown as h:m:s and as total seconds.' },
  { q: 'Can the result be negative?', a: 'If you subtract a larger duration from a smaller one, the result is shown as a negative duration.' },
  { q: 'Is it private?', a: 'Yes — everything is calculated in your browser.' },
  { q: 'What happens if I leave fields empty?', a: 'Empty fields are treated as 0, so you only need to fill in the hours, minutes or seconds that apply to your duration.' },
  { q: 'Can I chain multiple additions and subtractions?', a: 'Not in a single operation — but you can add the result of one calculation as Duration 1 and add or subtract another duration.' },
  { q: 'What is the maximum duration I can enter?', a: 'There is no enforced limit, but extremely large values may overflow JavaScript integer precision. For most practical uses (under 100 million seconds), it works perfectly.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="space-y-3">
      <div>
        <p class="mb-1 text-sm font-medium text-slate-700">Duration 1</p>
        <div class="grid grid-cols-3 gap-2">
          <input id="h1" type="number" placeholder="h" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <input id="m1" type="number" placeholder="m" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <input id="s1" type="number" placeholder="s" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
      <div class="text-center">
        <select id="op" class="rounded-xl border border-slate-300 p-2 text-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="+">+ Add</option><option value="-">− Subtract</option></select>
      </div>
      <div>
        <p class="mb-1 text-sm font-medium text-slate-700">Duration 2</p>
        <div class="grid grid-cols-3 gap-2">
          <input id="h2" type="number" placeholder="h" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <input id="m2" type="number" placeholder="m" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <input id="s2" type="number" placeholder="s" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Result</div><div id="r-hms" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Total seconds</div><div id="r-sec" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this time calculator</h2>
    <p class="mt-2 text-slate-600">
      Sometimes you need to add up several durations or find the gap between two — like total video
      length, combined task times or lap times. This calculator adds or subtracts two durations
      and gives a clean h:m:s result plus the total number of seconds. For calculating work hours including breaks, use our <a href="/tools/hours-calculator" class="font-medium text-indigo-600 hover:underline">Hours Calculator</a>.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter the hours, minutes and seconds for the first duration.</li>
      <li>Choose "Add" or "Subtract" and enter the second duration.</li>
      <li>Read the result in h:m:s and total seconds instantly.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Add up total video or audio length for editing projects, calculate combined lap times for sports coaching, find the difference between two durations for time tracking, or simply add up several task times to estimate how long a project will take.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Leave unused fields blank — they default to 0, so you only need to fill in what you have.</li>
      <li>The result can be negative if you subtract a larger duration from a smaller one, shown with a minus sign.</li>
      <li>Use total seconds when you need precise time values for calculations or programming.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const sec = (h, m, s) => (parseInt(el(h).value, 10) || 0) * 3600 + (parseInt(el(m).value, 10) || 0) * 60 + (parseInt(el(s).value, 10) || 0);
    function update() {
      let total = el('op').value === '+' ? sec('h1', 'm1', 's1') + sec('h2', 'm2', 's2') : sec('h1', 'm1', 's1') - sec('h2', 'm2', 's2');
      const neg = total < 0; let t = Math.abs(total);
      const h = Math.floor(t / 3600), m = Math.floor((t % 3600) / 60), s = t % 60;
      el('r-hms').textContent = `${neg ? '−' : ''}${h}h ${m}m ${s}s`;
      el('r-sec').textContent = total.toLocaleString();
    }
    ['h1', 'm1', 's1', 'h2', 'm2', 's2', 'op'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
