---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Natural Selection Simulator';
const description = 'Natural selection simulator with a live 3D allele-frequency diagram and charts. Model how selection against a recessive phenotype shifts allele frequency across generations, using q(t+1) = q(1−sq)/(1−sq²), with worked examples.';
const intro = 'Model how natural selection against a recessive phenotype shifts allele frequency generation by generation, using q(t+1) = q(1−sq)/(1−sq²), where s is the selection coefficient against the recessive homozygote. Two 3D diagrams compare a slowly-declining allele under weak selection to a rapidly-declining one under strong selection, and charts trace allele frequency across many generations.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a selection coefficient?', a: 'The selection coefficient (s) measures how strongly selection acts against a genotype, ranging from 0 (no disadvantage) to 1 (fully lethal or non-reproductive) — a genotype with fitness (1−s) reproduces less successfully than genotypes with full fitness.' },
  { q: 'How does selection against a recessive homozygote change allele frequency each generation?', a: 'Using q(t+1) = q(1−sq) / (1−sq²), where q is the recessive allele frequency this generation and s is the selection coefficient against the recessive (qq) genotype.' },
  { q: 'Why does selection against a rare recessive allele act so slowly?', a: "Once a recessive allele becomes rare, most copies of it are 'hidden' inside heterozygous carriers, who show the dominant phenotype and aren't affected by selection at all — this is exactly why eliminating a rare deleterious recessive allele from a population takes a very long time." },
  { q: 'What happens with complete selection against a lethal recessive (s=1)?', a: "The math simplifies to q(t+1) = q/(1+q), producing a much slower decline than intuition might suggest — even a fully lethal recessive allele can persist in a population for many generations once it becomes rare, since it keeps hiding in heterozygous carriers." },
  { q: 'Does natural selection ever completely eliminate an allele?', a: "Selection against a recessive allele approaches zero asymptotically but technically never reaches exactly zero in this idealized model — in real populations, genetic drift, mutation, or a heterozygote advantage can also keep an allele present indefinitely at low frequency." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Natural Selection Simulator',
  description: 'Model allele frequency change generation by generation under selection against a recessive phenotype.',
  steps: [
    { name: 'Enter starting allele frequency and selection coefficient', text: 'q0 is the recessive allele\'s starting frequency; s is how strongly selection acts against the recessive phenotype.' },
    { name: 'Enter number of generations', text: 'How many generations to simulate forward.' },
    { name: 'Read the resulting allele frequency', text: 'The recessive allele\'s frequency after the chosen number of generations solves instantly.' },
  ],
};

const formulas = [
  { expr: 'q(t+1) = q(1−sq) / (1−sq²)', note: 'recessive allele frequency next generation, under selection against the recessive (qq) genotype' },
  { expr: 's = 0: no selection; s = 1: fully lethal/non-reproductive recessive genotype', note: 'selection coefficient range' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — moderate selection against a recessive trait', tone: 'slate',
    given: 'Starting recessive allele frequency q0 = 0.5, with a selection coefficient s = 0.5 against the recessive genotype.',
    rows: [
      { label: 'Generation 1:', value: 'q1 = 0.5(1−0.25)/(1−0.125) = 0.375/0.875 ≈ 0.429' },
      { label: 'Generation 2:', value: 'q2 ≈ 0.371' },
      { label: 'Trend:', value: 'the recessive allele frequency steadily declines, but more slowly each generation', full: true },
    ],
    note: 'Even with substantial selection pressure (s=0.5), the allele frequency drops noticeably slower each generation as it becomes rarer — selection against homozygotes gets weaker in effect as fewer of them exist to select against.',
  },
  {
    title: 'Worked example 2 — a fully lethal recessive allele (s=1)', tone: 'amber',
    given: 'Starting recessive allele frequency q0 = 0.5, with complete selection (s=1) against the recessive genotype — every aa individual fails to reproduce.',
    rows: [
      { label: 'Simplified formula:', value: 'q(t+1) = q / (1+q), so 1/q(t+1) = 1/q(t) + 1' },
      { label: 'After 10 generations:', value: 'q₁₀ = 1/(1/0.5 + 10) = 1/12 ≈ 0.083' },
      { label: 'Interpretation:', value: 'even a fully lethal recessive allele still persists at over 8% frequency after 10 generations', full: true },
    ],
    note: 'This counterintuitively slow decline is a well-known result in population genetics — it explains why even severe recessive genetic diseases rarely disappear quickly from a population through selection alone.',
  },
];

const comparison = {
  heading: 'Selection coefficient vs. speed of allele frequency decline',
  note: 'Starting from q0=0.5 in all cases, showing frequency after 20 generations.',
  headers: [{ label: 'Selection coefficient (s)' }, { label: 'q after 20 generations' }],
  rows: [
    ['0.1 (weak selection)', '≈0.31'],
    ['0.5 (moderate selection) ★', '≈0.093'],
    ['1.0 (complete/lethal selection)', '≈0.045'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Stronger selection accelerates the decline, but the rate of decline always slows down as the allele becomes rarer, regardless of how strong s is.',
};

const realWorld = [
  { emoji: '🦟', title: 'Pesticide and antibiotic resistance evolution', body: 'The same selection-coefficient math describes how quickly a resistance allele spreads (positive selection) or a susceptibility allele declines when pesticide or antibiotic pressure is applied to a population.' },
  { emoji: '🧬', title: 'Genetic disease population modeling', body: 'Population geneticists use this model to predict how quickly (or how slowly) a harmful recessive allele\'s frequency might change under different selection pressures, informing genetic counseling and public health projections.' },
  { emoji: '🐛', title: 'Industrial melanism (peppered moths)', body: "The classic case of dark-colored peppered moths increasing in frequency during industrial pollution (better camouflage against soot-darkened trees) is a textbook real-world example of selection changing allele frequency over generations." },
  { emoji: '🌾', title: 'Agricultural pest and weed management', body: 'Farmers and agronomists model how quickly a herbicide- or pesticide-resistance allele might decline once a chemical is no longer used, informing crop rotation and resistance management strategies.' },
];

const misconceptions = [
  { claim: '"Natural selection can always eliminate a harmful recessive allele quickly."', truth: "Selection against a recessive allele slows dramatically as the allele becomes rare, since most remaining copies hide inside unaffected heterozygous carriers — even strong, sustained selection can take many, many generations to substantially reduce a rare recessive allele's frequency." },
  { claim: '"A selection coefficient of 1 means the allele disappears in one generation."', truth: 'Even complete selection against the homozygous recessive genotype (s=1) only removes the qq individuals each generation — the allele itself persists in heterozygous carriers and declines gradually rather than vanishing immediately.' },
  { claim: '"Natural selection only acts on rare, harmful alleles."', truth: "Selection can act on alleles at any frequency and can favor as well as disfavor a trait — this model specifically describes selection against a recessive phenotype, but analogous models exist for selection favoring a dominant allele, heterozygote advantage, and other selection patterns." },
  { claim: '"This model perfectly predicts real allele frequency trajectories."', truth: "This is a simplified, idealized model — it doesn't account for genetic drift, migration, mutation, changing environments, or interactions between multiple genes, all of which influence real allele frequency trajectories." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 20, "Evolution" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/20-2-formation-of-new-species" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Hartl &amp; Clark, <em>Principles of Population Genetics</em></strong> — Selection theory chapter.' },
  { html: '<strong>Futuyma &amp; Kirkpatrick, <em>Evolution</em></strong> — Natural selection and allele frequency change chapter.' },
];
const sourcesNote = 'q(t+1)=q(1−sq)/(1−sq²), iterated generation by generation. A discrete-generation, random-mating idealized model. Results are rounded for display.';

const howToUse = [
  { title: 'Enter starting allele frequency', body: "The recessive allele's frequency (q0) at the start of the simulation." },
  { title: 'Enter the selection coefficient', body: 'How strongly selection acts against the recessive genotype, from 0 (none) to 1 (fully lethal).' },
  { title: 'Enter number of generations', body: 'The recessive allele frequency after that many generations solves instantly.' },
];

const related = [
  { href: '/tools/hardy-weinberg-calculator', emoji: '⚖️', title: 'Hardy-Weinberg Allele Frequency Calculator', desc: 'p²+2pq+q²=1 — predicted equilibrium frequencies.' },
  { href: '/tools/hardy-weinberg-equilibrium-checker', emoji: '⚖️', title: 'Hardy-Weinberg Equilibrium Checker', desc: 'Chi-square test comparing observed vs. expected genotypes.' },
  { href: '/tools/speciation-rate-calculator', emoji: '🌿', title: 'Speciation Rate Estimator', desc: "Net diversification rate for a clade's species richness." },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="selection can only act on individuals it can actually see — and a recessive allele hiding inside heterozygous carriers is invisible to selection, which is exactly why a rare harmful recessive trait can survive selection pressure for far longer than intuition suggests."
  howIntro="When selection acts against a recessive phenotype, only homozygous recessive individuals (qq) are actually disadvantaged — heterozygous carriers (Aa) show the normal dominant phenotype and reproduce completely normally despite carrying the recessive allele. The recursive formula q(t+1) = q(1−sq)/(1−sq²) captures this generation by generation: it removes recessive alleles from the qq individuals each generation but leaves every copy hiding in Aa carriers completely untouched. As q shrinks, an ever-larger share of the remaining recessive alleles sit protected inside those carriers, which is exactly why the rate of decline slows dramatically once the allele becomes rare — no matter how strong the selection coefficient against the visible homozygotes actually is."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where natural selection modeling actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Starting frequency (q0)</span>
        <input id="q0" type="number" step="any" value="0.5" min="0" max="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Selection coefficient (s)</span>
        <input id="s" type="number" step="any" value="0.5" min="0" max="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of generations</span>
        <input id="gens" type="number" step="1" min="1" max="200" value="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Recessive allele frequency after N generations</div><div id="r-qfinal" class="mt-1 text-2xl font-bold">—</div></div>
    <p id="ns-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Weak vs. strong selection</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-weak" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Weak selection</h3>
          <p class="mt-1 text-sm text-slate-600">The recessive allele (amber) remains fairly common even after many generations.</p>
        </div>
        <div>
          <div id="diag-strong" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Strong selection</h3>
          <p class="mt-1 text-sm text-slate-600">The recessive allele becomes rare much faster under strong selection pressure.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Allele frequency over time</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">q over generations (your parameters)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-trajectory"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Effect of selection coefficient (q0=0.5)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-scoef"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};

      function nextQ(q, s) {
        const denom = 1 - s * q * q;
        if (denom === 0) return q;
        return (q * (1 - s * q)) / denom;
      }
      function trajectory(q0, s, gens) {
        const arr = [q0];
        let q = q0;
        for (let i = 0; i < gens; i++) { q = nextQ(q, s); arr.push(q); }
        return arr;
      }

      // ---- calculator ----
      function update() {
        el('ns-err').textContent = '';
        el('r-qfinal').textContent = '—';
        const q0 = parseFloat(el('q0').value), s = parseFloat(el('s').value), gens = parseInt(el('gens').value, 10);
        if (isNaN(q0) || isNaN(s) || isNaN(gens)) return;
        if (q0 < 0 || q0 > 1 || s < 0 || s > 1 || gens < 1) { el('ns-err').textContent = 'q0 and s must be between 0 and 1; generations must be at least 1.'; return; }
        const arr = trajectory(q0, s, gens);
        el('r-qfinal').textContent = fmt(arr[arr.length - 1]);
        updateChart(arr);
      }
      ['q0', 's', 'gens'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.traj = new Chart(el('chart-trajectory'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'q', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.1)', fill: true, tension: 0.1, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Generation' } }, y: { min: 0, max: 1, title: { display: true, text: 'Recessive allele frequency (q)' } } }, plugins: { legend: { display: false } } }),
        });
        const gensRange = Array.from({ length: 21 }, (_, i) => i);
        const sVals = [0.1, 0.5, 1.0];
        const colors = ['#94a3b8', '#6366f1', '#ef4444'];
        charts.scoef = new Chart(el('chart-scoef'), {
          type: 'line',
          data: {
            labels: gensRange,
            datasets: sVals.map((s, i) => ({ label: 's=' + s, data: trajectory(0.5, s, 20), borderColor: colors[i], backgroundColor: 'transparent', tension: 0.1, pointRadius: 0 })),
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Generation' } }, y: { min: 0, max: 0.5, title: { display: true, text: 'Recessive allele frequency (q)' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }
      function updateChart(arr) {
        if (!charts.traj) return;
        charts.traj.data.labels = arr.map((_, i) => i);
        charts.traj.data.datasets[0].data = arr;
        charts.traj.update('none');
      }

      function alleleScene(container, recessiveCount) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const total = 30;
        for (let i = 0; i < total; i++) {
          const isRecessive = i < recessiveCount;
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.18, 10, 8), new THREE.MeshStandardMaterial({ color: isRecessive ? 0xf59e0b : 0x6366f1 }));
          const angle = (i / total) * Math.PI * 2, r = 1.8;
          m.position.set(Math.cos(angle) * r, Math.sin(angle) * r * 0.6, (Math.random() - 0.5) * 1.2);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagWeak = null, diagStrong = null;
      function initDiagWeak() { const c = el('diag-weak'); if (!c) throw new Error('no container'); diagWeak = alleleScene(c, 12); }
      function initDiagStrong() { const c = el('diag-strong'); if (!c) throw new Error('no container'); diagStrong = alleleScene(c, 3); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[natural-selection] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagWeak(); } catch (e) { console.error('[natural-selection] weak diagram failed', e); }
          try { initDiagStrong(); } catch (e) { console.error('[natural-selection] strong diagram failed', e); }
        }
        mountResize([diagWeak, diagStrong]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
