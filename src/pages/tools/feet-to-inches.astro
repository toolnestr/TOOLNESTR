---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Feet to Inches"
  emoji="📏"
  fromUnit="feet" toUnit="inches"
  fromTitle="Feet" toTitle="Inches"
  fromSym="ft" toSym="in"
  quantity="length"
  kind="factor" factor={12}
  reverseSlug="inches-to-feet" reverseLabel="Inches to Feet Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="A quick way to break a measurement in feet down into inches for carpentry and tailoring."
/>
