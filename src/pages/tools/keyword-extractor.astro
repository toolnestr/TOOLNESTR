---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Keyword Extractor';
const description = 'Free online keyword extractor. Extract the most frequent words and phrases (bigrams, trigrams) from any text for SEO and content analysis.';
const intro = 'Paste any text to extract single keywords, 2-word phrases, and 3-word phrases sorted by frequency.';
const category = { id: 'seo', name: 'SEO Tools' };
const faqs = [
  { q: 'What is keyword extraction?', a: 'It identifies the most frequently occurring words and phrases in a text, helping you understand the main topics and themes.' },
  { q: 'What are unigrams, bigrams, and trigrams?', a: 'Unigrams are single words, bigrams are two-word phrases, and trigrams are three-word phrases. The extractor finds the most frequent of each.' },
  { q: 'Are stop words removed?', a: 'Yes. Common English stop words like "the", "is", "and", "of" are automatically excluded to show meaningful keywords only.' },
  { q: 'Can I see the frequency count for each keyword?', a: 'Yes. Each keyword shows its occurrence count and a visual frequency bar for easy comparison.' },
  { q: 'Is my text sent to a server?', a: 'No. All extraction happens in your browser. Nothing is uploaded or stored.' },
  { q: 'Does it handle large texts?', a: 'Yes. The extractor can process large texts efficiently, but very large documents may cause brief browser lag.' },
  { q: 'How many keywords does it show?', a: 'It shows the top keywords for each n-gram type. The number depends on the length of your text and frequency distribution.' },
  { q: 'What is keyword extraction used for?', a: 'SEO content optimization, competitor analysis, topic research, academic text analysis, and identifying content gaps.' },
  { q: 'Does it handle non-English text?', a: 'The stop word list is English-specific. For other languages, some common words may not be filtered.' },
  { q: 'Is punctuation removed?', a: 'Yes. Punctuation is stripped so that "SEO," and "SEO" are counted as the same word.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <span class="text-sm font-medium text-slate-700">Text to extract keywords from</span>
    <textarea
      id="text-input"
      rows="8"
      placeholder="Paste your text here..."
      class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-4 text-base leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <button id="extract-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Extract keywords</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
      <span id="stats" class="ml-auto text-sm text-slate-400">0 words, 0 unique</span>
    </div>

    <div id="results" class="mt-4 hidden">
      <div class="border-b border-slate-200">
        <div class="flex gap-4">
          <button data-tab="unigrams" class="tab-btn border-b-2 border-indigo-600 px-4 py-2 text-sm font-medium text-indigo-600">Single words</button>
          <button data-tab="bigrams" class="tab-btn px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-700">2-word phrases</button>
          <button data-tab="trigrams" class="tab-btn px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-700">3-word phrases</button>
        </div>
      </div>
      <div id="unigrams" class="tab-content mt-3"></div>
      <div id="bigrams" class="tab-content mt-3 hidden"></div>
      <div id="trigrams" class="tab-content mt-3 hidden"></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Extraction use cases</h2>
    <p class="mt-2 text-slate-600">How keyword extraction is used across different industries.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">SEO content optimization</span><span class="text-slate-400">40%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:40%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Competitor analysis</span><span class="text-slate-400">25%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:25%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Topic research</span><span class="text-slate-400">20%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Academic</span><span class="text-slate-400">15%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-violet-500" style="width:15%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4f0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">SEO Content Writer</h3>
      <p class="mt-1 text-sm text-slate-600">Identifies target keywords and checks that content covers the right topics and phrases for search visibility.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4cb;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Blog Editor</h3>
      <p class="mt-1 text-sm text-slate-600">Analyzes submitted articles to ensure the main topics match the editorial brief and keyword targets.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f50d;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Market Researcher</h3>
      <p class="mt-1 text-sm text-slate-600">Analyzes competitor content to identify keyword gaps and opportunities for new content creation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Student</h3>
      <p class="mt-1 text-sm text-slate-600">Extracts key terms from academic papers and articles to quickly understand the core topics and themes.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Category</th><th class="p-3">Examples of stop words</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Articles</td><td class="p-3">a, an, the</td></tr>
        <tr><td class="p-3 font-medium">Prepositions</td><td class="p-3">in, on, at, for, by, with, to, from</td></tr>
        <tr><td class="p-3 font-medium">Conjunctions</td><td class="p-3">and, but, or, nor, yet, so</td></tr>
        <tr><td class="p-3 font-medium">Pronouns</td><td class="p-3">I, you, he, she, it, we, they, me, him, her</td></tr>
        <tr><td class="p-3 font-medium">Common verbs</td><td class="p-3">is, are, was, were, be, been, have, has, do, does</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Keyword Extractor</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste text</h3>
        <p class="mt-1 text-sm text-slate-600">Copy and paste the text you want to analyze into the input area. Any length works.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Extract keywords</h3>
        <p class="mt-1 text-sm text-slate-600">Click Extract keywords to process the text and identify the most frequent words and phrases.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Browse by type</h3>
        <p class="mt-1 text-sm text-slate-600">Switch between single words, 2-word phrases, and 3-word phrases to explore different levels of keyword detail.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for keyword extraction</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Check bigrams and trigrams too</h3>
        <p class="mt-1 text-sm text-slate-600">Single words can be misleading. Two-word and three-word phrases often reveal the true topics and context of your content.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use extracted keywords for meta tags</h3>
        <p class="mt-1 text-sm text-slate-600">The most frequent phrases from your content should inform your meta keywords, headings, and page titles.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Compare against competitors</h3>
        <p class="mt-1 text-sm text-slate-600">Run competitor content through the extractor and compare the keyword profile. Missing keywords may be content opportunities.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is keyword extraction</h2>
    <p class="mt-2 text-slate-600">
      Keyword extraction is a text analysis technique that identifies the most important words and phrases in a document. It helps content creators understand the main topics covered, optimize for search engines, and ensure content aligns with target keywords.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Unigrams vs bigrams vs trigrams</h2>
    <p class="mt-2 text-slate-600">
      Unigrams (single words) give a broad overview but can be ambiguous. Bigrams (two-word phrases) add context — "coffee" becomes "coffee shop". Trigrams (three-word phrases) provide even more specificity, like "specialty coffee shop". Using all three gives a complete keyword picture.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Stop words</h2>
    <p class="mt-2 text-slate-600">
      Stop words are common words that carry little meaning, such as "the", "is", "and", and "of". Removing them before analysis ensures that extracted keywords focus on meaningful, content-bearing terms.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Applications in SEO</h2>
    <p class="mt-2 text-slate-600">
      Keyword extraction powers SEO in several ways: identifying primary and secondary keywords, checking keyword density, discovering content gaps, analyzing competitor strategy, and optimizing existing pages for better search performance.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const stopWords = new Set([
      'a','an','the','and','or','but','nor','yet','so','for','of','in','on','at','to','by','with','from','about','into',
      'through','during','before','after','above','below','between','out','off','over','under','again','further','then',
      'once','here','there','when','where','why','how','all','each','every','both','few','more','most','other','some',
      'such','no','nor','not','only','own','same','so','than','too','very','just','because','as','until','while','that',
      'this','these','those','i','me','my','myself','we','our','ours','ourselves','you','your','yours','yourself',
      'yourselves','he','him','his','himself','she','her','hers','herself','it','its','itself','they','them','their',
      'theirs','themselves','what','which','who','whom','is','am','are','was','were','be','been','being','have','has',
      'had','having','do','does','did','doing','would','should','could','might','shall','can','may','will','need',
      'dare','ought','used','to','up','down','in','out','on','off','over','under','again','further','then','once',
      'here','there','when','where','why','how','all','each','every','both','few','more','most','other','some','such',
      'no','nor','not','only','own','same','than','too','very','just','because','as','until','while','about','between',
      'into','through','during','before','after','above','below','between','out','off','over','under','again','further',
      'then','once','here','there','when','where','why','how','any','also','else','ever','get','got','let','make',
      'may','new','now','one','two','see','us','way','was','were','well','back','been','being','call','come','could',
      'day','did','does','done','due','say','still','thing','think','use','used','want','year','years'
    ]);

    function getWords(text) {
      return text.toLowerCase().replace(/[^a-z\s'-]/g, '').split(/\s+/).filter(w => w.length > 1 && !stopWords.has(w));
    }

    function getNgrams(words, n) {
      const counts = {};
      for (let i = 0; i <= words.length - n; i++) {
        const phrase = words.slice(i, i + n).join(' ');
        counts[phrase] = (counts[phrase] || 0) + 1;
      }
      return Object.entries(counts)
        .filter(([phrase]) => !stopWords.has(phrase))
        .sort((a, b) => b[1] - a[1])
        .slice(0, 50);
    }

    function renderList(data, maxCount) {
      if (!data.length) return '<p class="text-sm text-slate-400">No keywords found.</p>';
      return data.map(([word, count]) => {
        const pct = maxCount > 0 ? (count / maxCount) * 100 : 0;
        return `<div class="flex items-center gap-3 py-1.5">
          <span class="w-8 text-right text-xs font-medium text-slate-400">${count}</span>
          <div class="h-5 rounded bg-indigo-200" style="width:${pct}%;min-width:4px"></div>
          <span class="text-sm text-slate-800">${word}</span>
        </div>`;
      }).join('');
    }

    function extract() {
      const text = el('text-input').value.trim();
      if (!text) { el('results').classList.add('hidden'); return; }

      const words = getWords(text);
      const uniqueWords = new Set(words);
      el('stats').textContent = words.length + ' words, ' + uniqueWords.size + ' unique';

      const unigrams = getNgrams(words, 1);
      const bigrams = getNgrams(words, 2);
      const trigrams = getNgrams(words, 3);

      const maxUni = unigrams.length ? unigrams[0][1] : 1;
      const maxBi = bigrams.length ? bigrams[0][1] : 1;
      const maxTri = trigrams.length ? trigrams[0][1] : 1;

      el('unigrams').innerHTML = renderList(unigrams, maxUni);
      el('bigrams').innerHTML = renderList(bigrams, maxBi);
      el('trigrams').innerHTML = renderList(trigrams, maxTri);

      el('results').classList.remove('hidden');
    }

    el('extract-btn').addEventListener('click', extract);
    el('clear-btn').addEventListener('click', () => {
      el('text-input').value = '';
      el('results').classList.add('hidden');
      el('stats').textContent = '0 words, 0 unique';
      el('text-input').focus();
    });

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.className = 'tab-btn px-4 py-2 text-sm font-medium text-slate-500 hover:text-slate-700';
        });
        btn.className = 'tab-btn border-b-2 border-indigo-600 px-4 py-2 text-sm font-medium text-indigo-600';
        document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
        el(btn.dataset.tab).classList.remove('hidden');
      });
    });
  </script>
</ToolLayout>
