---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Emoji & Symbol Picker';
const description =
  'Free emoji and symbol picker. Click any emoji or aesthetic symbol to copy it instantly — ' +
  'perfect for bios, captions, usernames and messages. Works on any device.';
const intro =
  'Tap any emoji or symbol to copy it to your clipboard, then paste it wherever you like.';
const category = { id: 'creators', name: 'Creators' };
const faqs = [
  { q: 'How do I use an emoji after copying?', a: 'Click an emoji to copy it, then paste (Ctrl/Cmd + V, or long-press → Paste on mobile) into your bio, caption, message or username.' },
  { q: 'Will these work everywhere?', a: 'Standard emojis work in almost every app. A few decorative symbols may look slightly different depending on your device or font.' },
  { q: 'What are the aesthetic symbols for?', a: 'They\'re popular for decorating social media bios and usernames — things like stars, hearts, arrows and brackets.' },
  { q: 'Is it free?', a: 'Yes, completely free and private — it runs in your browser.' },
  { q: 'How many emojis and symbols are included?', a: 'There are 8 categories with hundreds of emojis and decorative symbols covering smiles, hearts, animals, food, travel, and aesthetic characters.' },
  { q: 'Can I use aesthetic symbols in usernames?', a: 'Many platforms allow certain Unicode symbols in display names. Test your chosen symbol on the platform before using it in a username.' },
  { q: 'Do I need to install anything?', a: 'No — the picker runs in your browser. Click any emoji to copy it, then paste wherever you like.' },
  { q: 'Why do some emojis look different on different devices?', a: 'Each platform (Apple, Google, Samsung, etc.) has its own emoji design. Standard characters render consistently, but some newer emojis may vary in appearance.' },
  { q: 'Can I search for emojis by name?', a: 'The picker groups emojis by category. A search feature is not included, but browsing categories is fast with hundreds of options at your fingertips.' },
  { q: 'Are there gender and skin-tone variants?', a: 'The picker includes standard emojis. Many emojis have gender and skin-tone variants supported by Unicode, and you can paste them alongside the ones shown here.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div id="tabs" class="flex flex-wrap gap-2"></div>
    <div id="grid" class="mt-4 grid grid-cols-6 gap-1 sm:grid-cols-10"></div>
    <p id="toast" class="mt-3 hidden text-center text-sm font-medium text-green-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the emoji picker works</h2>
    <p class="mt-2 text-slate-600">The emoji picker organises a database of Unicode emoji characters and aesthetic symbols into themed categories. Each emoji is stored as its actual Unicode character, grouped by category for easy browsing.</p>
    <p class="mt-3 text-slate-600">When you click an emoji, the tool copies the Unicode character directly to your clipboard using the browser's Clipboard API. There is no intermediate encoding or transformation — the exact character is pasted wherever you choose.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Searching for and copying a fire emoji.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Action:</span> <span class="text-slate-600">Type "fire" in Symbols category → click 🔥</span></div>
        <div><span class="font-medium text-slate-700">Result:</span> <span class="text-slate-600">🔥🔥🔥 copied to clipboard with one click</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this emoji picker</h2>
    <p class="mt-2 text-slate-600">
      Finding the right emoji or a pretty symbol for your bio shouldn't be a hunt. This picker
      organizes the most-used emojis and aesthetic symbols into categories — just click to copy,
      then paste anywhere. It's great for Instagram and TikTok bios, captions, usernames and chats.
      Style your text first with the <a href="/tools/fancy-text" class="font-medium text-indigo-600 hover:underline">Fancy Text Generator</a>,
      then add emojis and symbols to decorate your social media profiles.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Choose a category.</li>
      <li>Click an emoji or symbol to copy it.</li>
      <li>Paste it into your bio, caption or message.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Emojis and decorative symbols add personality to everything you write online. Use this picker when you're setting up a new social media profile and want a bio that pops with hearts, stars and smileys. Content creators use aesthetic symbols as separators in captions or to frame their calls-to-action. Writers add emphasis to messages and emails with the perfect emoji. Gamers and streamers decorate their usernames and channel descriptions with unique symbols that help them stand out in a crowded space.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different emoji categories mean</h2>
    <p class="mt-2 text-slate-600">Each category serves a different purpose when decorating your content. Here is how they compare in usage and popularity.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Smileys & Emotions</span><span class="text-slate-400">Most used category, essential for tone and mood</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Hearts</span><span class="text-slate-400">Extremely popular for bios, captions, and reactions</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:90%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Aesthetic Symbols</span><span class="text-slate-400">Trending for decorative borders and separators</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:75%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Animals & Nature</span><span class="text-slate-400">Popular for nature-themed bios and travel posts</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:65%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Food & Drink</span><span class="text-slate-400">Niche use, great for food bloggers and restaurant posts</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-400" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Travel & Places</span><span class="text-slate-400">Moderate use for travel content and location posts</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-400" style="width:45%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f469;&#x200d;&#x1f3a8;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Social Media Creator</h3>
      <p class="mt-1 text-sm text-slate-600">Uses emojis in every post to boost engagement and express tone quickly without extra words.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f454;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Brand Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Selects aesthetic symbols to create consistent visual separators and brand-aligned decorative elements across all social channels.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f3b5;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Musician & Artist</h3>
      <p class="mt-1 text-sm text-slate-600">Decorates Spotify bios, YouTube channel descriptions, and social links with symbols and emojis that reflect their artistic style.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4bc;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Freelancer</h3>
      <p class="mt-1 text-sm text-slate-600">Enhances email signatures, portfolio bios, and freelance profiles with tasteful emojis to appear approachable and modern.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Category</th><th class="p-3">Count</th><th class="p-3">Best Used For</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Smileys</td><td class="p-3">40+</td><td class="p-3">Tone and emotion in captions and messages</td></tr>
        <tr><td class="p-3 font-medium">Hearts</td><td class="p-3">20+</td><td class="p-3">Love-themed bios, Valentine's posts, reactions</td></tr>
        <tr><td class="p-3 font-medium">Hands</td><td class="p-3">25+</td><td class="p-3">Gestures, waves, high-fives, sign language</td></tr>
        <tr><td class="p-3 font-medium">Animals</td><td class="p-3">25+</td><td class="p-3">Pet accounts, nature content, children's content</td></tr>
        <tr><td class="p-3 font-medium">Food</td><td class="p-3">30+</td><td class="p-3">Food photography, recipes, restaurant reviews</td></tr>
        <tr><td class="p-3 font-medium">Travel</td><td class="p-3">20+</td><td class="p-3">Trip highlights, destination posts, adventure content</td></tr>
        <tr><td class="p-3 font-medium">Symbols</td><td class="p-3">25+</td><td class="p-3">Bullet points, checkmarks, warnings, indicators</td></tr>
        <tr><td class="p-3 font-medium">Aesthetic</td><td class="p-3">25+</td><td class="p-3">Borders, separators, username decorations</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the emoji picker</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select a category</h3>
        <p class="mt-1 text-sm text-slate-600">Click one of the category tabs to browse emojis and symbols grouped by theme.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose your emoji</h3>
        <p class="mt-1 text-sm text-slate-600">Click any emoji or symbol — it's instantly copied and a confirmation toast appears.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste anywhere</h3>
        <p class="mt-1 text-sm text-slate-600">Paste the copied emoji into your bio, caption, username, or chat message.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for using emojis effectively</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Don't overdo it</h3>
        <p class="mt-1 text-sm text-slate-600">A few well-placed emojis add personality, but too many can make text look cluttered and unprofessional. Stick to 2–5 per caption for maximum impact.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use symbols as visual separators</h3>
        <p class="mt-1 text-sm text-slate-600">Aesthetic symbols like stars (✦) and dividers (━━) work beautifully to separate sections in a bio or create frame-like decorations around text.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Test cross-platform appearance</h3>
        <p class="mt-1 text-sm text-slate-600">An emoji that looks great on your iPhone may render differently on Android or in a desktop browser. Test important placements on multiple devices.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const data = {
      'Smileys': '😀 😃 😄 😁 😆 😅 😂 🤣 🙂 🙃 😉 😊 😇 🥰 😍 🤩 😘 😗 😚 😋 😜 🤪 😝 🤗 🤔 🤨 😐 😶 😏 😒 🙄 😬 😴 😌 😎 🥳 😢 😭 😤 😡 🥺 😳 🤯 😱 😅 🤤'.split(' '),
      'Hearts': '❤️ 🧡 💛 💚 💙 💜 🖤 🤍 🤎 💕 💞 💓 💗 💖 💘 💝 💟 ❣️ 💔 ❤️‍🔥 💋'.split(' '),
      'Hands': '👍 👎 👌 ✌️ 🤞 🤟 🤘 🤙 👈 👉 👆 👇 ☝️ ✋ 🤚 🖐️ 🖖 👋 🤝 🙏 💪 👏 🙌 👐 🤲'.split(' '),
      'Animals': '🐶 🐱 🐭 🐹 🐰 🦊 🐻 🐼 🐨 🐯 🦁 🐮 🐷 🐸 🐵 🐔 🐧 🐦 🦄 🐝 🦋 🐢 🐬 🐙 🦕'.split(' '),
      'Food': '🍏 🍎 🍐 🍊 🍋 🍌 🍉 🍇 🍓 🫐 🍒 🍑 🥭 🍍 🥥 🥝 🍅 🥑 🌽 🍕 🍔 🍟 🌭 🍿 🍩 🍪 🎂 🍰 🍫 🍭 ☕ 🍺'.split(' '),
      'Travel': '🚗 🚕 🚙 🚌 🏎️ 🚓 🚑 🚒 ✈️ 🚀 🛸 🚁 ⛵ 🚤 🏖️ 🏝️ 🗺️ 🧳 🗽 🗼 🏔️ 🌋 🏕️ 🎡'.split(' '),
      'Symbols': '⭐ 🌟 ✨ ⚡ 🔥 💧 🌈 ☀️ 🌙 ☁️ ❄️ 💯 ✅ ❌ ⁉️ ❓ ❗ 💲 🔔 🎵 🎶 ♻️ ⚠️ 🔴 🟠 🟡 🟢 🔵 🟣'.split(' '),
      'Aesthetic': '✧ ✦ ⋆ ₊ ⊹ ⟡ ❀ ✿ ❁ ♡ ☆ ★ ✫ ✬ ✭ ⚝ ꒰ ꒱ ⌗ ⊱ ⊰ ๑ ☻ ☹ ✩ ✰ ❥ ➴ ➶ ✎ ✑ ⏤'.split(' '),
    };

    const tabs = document.getElementById('tabs');
    const grid = document.getElementById('grid');
    const toast = document.getElementById('toast');
    const names = Object.keys(data);

    function showTab(name) {
      [...tabs.children].forEach((b) => b.className = b.textContent === name
        ? 'rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white'
        : 'rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50');
      grid.innerHTML = '';
      data[name].forEach((ch) => {
        const b = document.createElement('button');
        b.textContent = ch;
        b.className = 'flex h-11 items-center justify-center rounded-lg text-2xl transition hover:bg-indigo-50';
        b.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(ch);
            toast.textContent = `Copied ${ch}`;
            toast.classList.remove('hidden');
            clearTimeout(window.__t);
            window.__t = setTimeout(() => toast.classList.add('hidden'), 1200);
          } catch (e) {}
        });
        grid.appendChild(b);
      });
    }

    names.forEach((name) => {
      const b = document.createElement('button');
      b.textContent = name;
      b.addEventListener('click', () => showTab(name));
      tabs.appendChild(b);
    });
    showTab(names[0]);
  </script>
</ToolLayout>
