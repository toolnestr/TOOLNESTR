---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Crypto Profit Calculator';
const description = 'Calculate profit or loss on a crypto or stock trade including fees. See gain/loss in dollars and percent — works for Bitcoin, stocks, any asset.';
const intro = 'Calculate profit or loss on a crypto trade, including fees, in money and percent.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'Does it include exchange fees?', a: 'Yes — the optional fee is applied to both the buy and the sell side.' },
  { q: 'Does it handle taxes?', a: 'No — capital-gains tax varies by country; this shows pre-tax profit.' },
  { q: 'Can I use it for stocks?', a: 'Yes — the math is identical for any buy/sell-with-fees trade.' },
  { q: 'What if I have multiple buys at different prices?', a: 'Use your average buy price — this tool works with one buy and one sell price.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Buy price (per coin)</span>
        <input id="buyPrice" type="number" step="any" placeholder="e.g. 25000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Sell price (per coin)</span>
        <input id="sellPrice" type="number" step="any" placeholder="e.g. 32000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Amount of coins</span>
        <input id="qty" type="number" step="any" placeholder="e.g. 0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Trading fee (%) <span class="text-xs text-slate-400">optional</span></span>
        <input id="fee" type="number" step="any" placeholder="e.g. 0.1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>
    <button id="calcBtn" class="mt-5 w-full rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700 active:scale-[0.98]">Calculate profit</button>

    <div id="results" class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-5 text-center">
        <div class="text-sm text-slate-500">Profit / Loss ($)</div>
        <div id="r-profit" class="mt-1 text-xl font-bold text-slate-800">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-5 text-center">
        <div class="text-sm text-slate-500">Return (%)</div>
        <div id="r-return" class="mt-1 text-xl font-bold text-slate-800">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-5 text-center">
        <div class="text-sm text-slate-500">Total invested</div>
        <div id="r-invested" class="mt-1 text-xl font-bold text-slate-800">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-5 text-center">
        <div class="text-sm text-slate-500">Total received</div>
        <div id="r-received" class="mt-1 text-xl font-bold text-slate-800">—</div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How crypto trade profit is calculated</h2>
    <p class="mt-2 text-slate-600">
      The profit or loss from a trade is determined by the difference between what you paid
      (including fees) and what you received (after fees). The two key formulas are:
    </p>
    <div class="mt-4 space-y-2 rounded-xl bg-slate-50 p-4 font-mono text-sm text-slate-700">
      <div><span class="font-semibold">Invested</span> = buy price &times; quantity &times; (1 + fee%)</div>
      <div><span class="font-semibold">Received</span> = sell price &times; quantity &times; (1 − fee%)</div>
      <div><span class="font-semibold">Profit</span> = received − invested</div>
      <div><span class="font-semibold">Return</span> = (received − invested) / invested &times; 100</div>
    </div>
    <p class="mt-3 text-slate-600">
      Because the fee is applied on both sides of the trade, even a small percentage fee can have a
      meaningful impact on your net result — especially for frequent traders who compound the effect
      of fees over many trades.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="240" viewBox="0 0 800 240" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Crypto trade profit flow diagram">
      <title>Buy → Invest → Sell → Profit / Loss Flow</title>
      <desc>A flow diagram showing money flowing from Buy to Invest, then to Sell and finally to Profit or Loss, with fees deducted at both the buy and sell steps.</desc>
      <rect x="30" y="85" width="130" height="60" rx="10" fill="#6366f1" />
      <text x="95" y="120" text-anchor="middle" fill="#fff" font-size="15" font-weight="bold">Buy</text>
      <text x="95" y="136" text-anchor="middle" fill="#c7d2fe" font-size="11">$25,000 / coin</text>

      <path d="M160 115 L200 115" stroke="#94a3b8" stroke-width="2" marker-end="url(#arrow)" />
      <defs><marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto"><path d="M0,0 L8,4 L0,8Z" fill="#94a3b8" /></marker></defs>

      <rect x="210" y="85" width="130" height="60" rx="10" fill="#4338ca" />
      <text x="275" y="115" text-anchor="middle" fill="#fff" font-size="15" font-weight="bold">Invest</text>
      <text x="275" y="133" text-anchor="middle" fill="#c7d2fe" font-size="11">$12,512.50</text>

      <path d="M340 115 L380 115" stroke="#94a3b8" stroke-width="2" marker-end="url(#arrow)" />

      <rect x="390" y="85" width="130" height="60" rx="10" fill="#6366f1" />
      <text x="455" y="120" text-anchor="middle" fill="#fff" font-size="15" font-weight="bold">Sell</text>
      <text x="455" y="136" text-anchor="middle" fill="#c7d2fe" font-size="11">$32,000 / coin</text>

      <path d="M520 115 L560 115" stroke="#94a3b8" stroke-width="2" marker-end="url(#arrow)" />

      <rect x="570" y="85" width="140" height="60" rx="10" fill="#059669" />
      <text x="640" y="115" text-anchor="middle" fill="#fff" font-size="15" font-weight="bold">Profit</text>
      <text x="640" y="133" text-anchor="middle" fill="#a7f3d0" font-size="11">$3,471.50</text>

      <rect x="215" y="175" width="210" height="40" rx="8" fill="#fef3c7" />
      <text x="320" y="200" text-anchor="middle" fill="#92400e" font-size="12">Fee (0.1%) applies both sides</text>

      <text x="320" y="230" text-anchor="middle" fill="#64748b" font-size="13">Buy 0.5 BTC → Sell at higher price → Profit</text>
    </svg>
    <figcaption class="mt-3 text-center text-sm text-slate-500">Flow from buying to selling, showing how the 0.1% fee is deducted at both ends and the resulting profit</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">Let's walk through a real scenario using the numbers from the diagram above:</p>
      <div class="mt-3 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Buy price:</span> <span class="text-slate-600">$25,000 per BTC</span></div>
        <div><span class="font-medium text-slate-700">Sell price:</span> <span class="text-slate-600">$32,000 per BTC</span></div>
        <div><span class="font-medium text-slate-700">Quantity:</span> <span class="text-slate-600">0.5 BTC</span></div>
        <div><span class="font-medium text-slate-700">Trading fee:</span> <span class="text-slate-600">0.1% (applied on both sides)</span></div>
        <div><span class="font-medium text-slate-700">Invested:</span> <span class="text-slate-600">$25,000 &times; 0.5 &times; 1.001 = $12,512.50</span></div>
        <div><span class="font-medium text-slate-700">Received:</span> <span class="text-slate-600">$32,000 &times; 0.5 &times; 0.999 = $15,984.00</span></div>
        <div><span class="font-medium text-slate-700">Profit:</span> <span class="text-emerald-600 font-medium">$3,471.50</span></div>
        <div><span class="font-medium text-slate-700">Return:</span> <span class="text-emerald-600 font-medium">27.7%</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-2xl">📊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Checking trade profit</h3>
        <p class="mt-1 text-sm text-slate-600">Quickly see whether a completed trade was profitable after accounting for fees, without having to do the math yourself.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-2xl">🎯</span>
        <h3 class="mt-2 font-semibold text-slate-900">Planning target price</h3>
        <p class="mt-1 text-sm text-slate-600">Enter your buy price and desired profit to find the sell price you need to hit your target return.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-2xl">⚖️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Comparing exchanges</h3>
        <p class="mt-1 text-sm text-slate-600">Run the same trade with different fee percentages to see how exchange fees affect your bottom line.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate results</h2>
    <ul class="mt-3 list-disc space-y-1.5 pl-5 text-slate-600">
      <li><strong class="text-slate-800">Fees apply on both sides</strong> — Most exchanges charge a percentage fee when you buy and again when you sell. Our calculator applies the fee to both legs of the trade.</li>
      <li><strong class="text-slate-800">This is pre-tax profit</strong> — Capital gains tax varies by country and holding period. Use this as a gross return estimate, then consult a tax professional for your net figure.</li>
      <li><strong class="text-slate-800">Works for stocks too</strong> — The buy/sell-with-fee math is identical for shares of stock, ETFs, or any other traded asset. Enter the per-share price and quantity the same way.</li>
      <li><strong class="text-slate-800">Average your buys</strong> — If you accumulated coins at multiple prices, calculate your average buy price first and enter that. The tool handles one average buy price and one sell price.</li>
      <li><strong class="text-slate-800">Check for hidden fees</strong> — Some exchanges add network fees, withdrawal fees, or spread markups on top of the stated trading fee. Those are not included here.</li>
    </ul>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📈</span>
      <h3 class="mt-2 font-semibold text-slate-900">Day trader</h3>
      <p class="mt-1 text-sm text-slate-600">Frequent traders often underestimate how much fees eat into small gains. Run a few scenarios with realistic fees to see your true win rate.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💎</span>
      <h3 class="mt-2 font-semibold text-slate-900">Long-term holder</h3>
      <p class="mt-1 text-sm text-slate-600">Even if you hold for years, the fee matters. Enter your buy price from months ago and today's price to check your current position's unrealized P&L.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔁</span>
      <h3 class="mt-2 font-semibold text-slate-900">Arbitrage hunter</h3>
      <p class="mt-1 text-sm text-slate-600">When prices differ across exchanges, use this tool to confirm whether the spread is wide enough to be profitable after both sets of fees.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💰</span>
      <h3 class="mt-2 font-semibold text-slate-900">Portfolio tracker</h3>
      <p class="mt-1 text-sm text-slate-600">Log each trade's buy and sell prices to maintain a running tally of realized gains across your whole portfolio.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Understanding your results</h2>
    <div class="mt-4 space-y-4">
      <div>
        <h3 class="font-semibold text-slate-900">Positive profit (green)</h3>
        <p class="mt-1 text-sm text-slate-600">Your sell price was higher than your buy price by enough to cover the fees on both sides. The larger the percentage return, the better your trade performed relative to the capital at risk.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Negative profit / loss (red)</h3>
        <p class="mt-1 text-sm text-slate-600">Your sell price was lower than your buy price, or the gain was too small to cover the fees. A loss means you would have been better off not trading at all.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Zero profit</h3>
        <p class="mt-1 text-sm text-slate-600">Your sell price exactly offsets your buy price and fees, leaving you with no net gain or loss. This is your break-even price.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-amber-50 p-4 text-sm text-amber-800">
    <strong>⚠️ Disclaimer:</strong> This calculator provides estimates for educational purposes only. It does not account for capital gains tax, withdrawal fees, network fees, slippage, or currency conversion costs. Always verify your numbers with your exchange's trade history.
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/compound-interest" class="block rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="font-semibold text-slate-900">Compound Interest Calculator</span>
        <p class="mt-1 text-sm text-slate-600">See how your crypto or stock investments could grow over time with compounding.</p>
      </a>
      <a href="/tools/discount-calculator" class="block rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="font-semibold text-slate-900">Discount Calculator</span>
        <p class="mt-1 text-sm text-slate-600">Calculate sale prices and savings percentages for any discounted item.</p>
      </a>
      <a href="/tools/inflation-calculator" class="block rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="font-semibold text-slate-900">Inflation Calculator</span>
        <p class="mt-1 text-sm text-slate-600">Adjust dollar values for inflation to understand real purchasing power over time.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);

    function fmtCurrency(n) {
      if (isNaN(n)) return '—';
      const abs = Math.abs(n);
      const formatted = '$' + abs.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      return n < 0 ? '-' + formatted : formatted;
    }

    function fmtPercent(n) {
      if (isNaN(n)) return '—';
      return n.toFixed(1) + '%';
    }

    function update() {
      const buy = parseFloat($('buyPrice').value);
      const sell = parseFloat($('sellPrice').value);
      const qty = parseFloat($('qty').value);
      const feeRaw = parseFloat($('fee').value);
      const fee = isNaN(feeRaw) ? 0 : feeRaw / 100;

      if (isNaN(buy) || isNaN(sell) || isNaN(qty) || qty === 0) {
        ['r-profit', 'r-return', 'r-invested', 'r-received'].forEach((id) => {
          $(id).textContent = '—';
          $(id).className = 'mt-1 text-xl font-bold text-slate-800';
        });
        return;
      }

      const invested = buy * qty * (1 + fee);
      const received = sell * qty * (1 - fee);
      const profit = received - invested;
      const pct = invested !== 0 ? (profit / invested) * 100 : 0;

      $('r-invested').textContent = fmtCurrency(invested);
      $('r-received').textContent = fmtCurrency(received);
      $('r-profit').textContent = fmtCurrency(profit);
      $('r-return').textContent = fmtPercent(pct);

      const profitEl = $('r-profit');
      const returnEl = $('r-return');
      if (profit > 0) {
        profitEl.className = 'mt-1 text-xl font-bold text-emerald-600';
        returnEl.className = 'mt-1 text-xl font-bold text-emerald-600';
      } else if (profit < 0) {
        profitEl.className = 'mt-1 text-xl font-bold text-red-600';
        returnEl.className = 'mt-1 text-xl font-bold text-red-600';
      } else {
        profitEl.className = 'mt-1 text-xl font-bold text-slate-800';
        returnEl.className = 'mt-1 text-xl font-bold text-slate-800';
      }

      $('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    $('calcBtn').addEventListener('click', update);

    ['buyPrice', 'sellPrice', 'qty', 'fee'].forEach((id) => {
      $(id).addEventListener('keydown', (e) => {
        if (e.key === 'Enter') update();
      });
    });
  </script>
</ToolLayout>
