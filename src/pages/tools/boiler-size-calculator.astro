---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Boiler Size Calculator';
const description = 'Estimate the boiler output size (BTU/hr) needed for a home from its square footage and climate zone, for hydronic (hot water/radiator) heating systems.';
const intro = 'Estimate the boiler output size your home needs, from its square footage and climate.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I size a boiler for my house?', a: 'A simplified rule of thumb multiplies square footage by a BTU-per-square-foot factor that varies by climate: about 30-35 BTU/sq ft in mild climates, 40-45 in moderate climates, and 50-60 in cold climates. A 2,000 sq ft home in a moderate climate: 2,000 × 42.5 ≈ 85,000 BTU/hr.' },
  { q: 'Why does climate change the BTU-per-square-foot factor?', a: 'Colder climates lose heat faster through walls, windows, and the roof, so a home there needs more heating capacity per square foot to maintain a comfortable indoor temperature during the coldest expected outdoor conditions.' },
  { q: 'Is this the same as a Manual J load calculation?', a: 'No. ACCA Manual J is a detailed, room-by-room heat loss calculation that accounts for insulation levels, window ratings, orientation, and infiltration. This calculator gives a simplified square-footage estimate for comparison — a full Manual J calculation (or an HVAC professional\'s assessment) is the accurate way to size a real boiler.' },
  { q: 'What happens if a boiler is oversized?', a: 'An oversized boiler short-cycles — turning on and off frequently instead of running steady, efficient cycles — which wastes fuel, increases wear, and can leave rooms unevenly heated. Correct sizing (or slight undersizing with good insulation) generally performs and lasts better than an oversized unit.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Home square footage</span>
        <input id="sqft" type="number" step="any" placeholder="2000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Climate zone</span>
        <select id="climate" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="32">Mild (~30-35 BTU/ft²)</option>
          <option value="42.5" selected>Moderate (~40-45 BTU/ft²)</option>
          <option value="55">Cold (~50-60 BTU/ft²)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated boiler output</div>
        <div id="r-btu" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="bs-title bs-desc">
      <title id="bs-title">Boiler sizing from square footage and climate</title>
      <desc id="bs-desc">A house with a boiler and radiators, with the sizing formula</desc>
      <path d="M80 110 L150 60 L220 110 Z" fill="#fed7aa" stroke="#c2410c" stroke-width="1.5" />
      <rect x="90" y="110" width="120" height="70" fill="#fef3c7" stroke="#c2410c" stroke-width="1.5" />
      <rect x="115" y="130" width="20" height="20" fill="#fca5a5" /><rect x="165" y="130" width="20" height="20" fill="#fca5a5" />
      <text x="150" y="195" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">home square footage</text>
      <rect x="420" y="55" width="330" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Boiler sizing</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">BTU/hr = sq ft &times; climate factor</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">simplified estimate, not Manual J</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Colder climates need more BTU per square foot to hold a comfortable temperature.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the boiler size calculator works</h2>
    <p class="mt-2 text-slate-600">
      A boiler's output rating in BTU per hour needs to roughly match the rate at which a home loses heat on the coldest expected day, so it can keep pace and maintain a comfortable indoor temperature. A simplified square-footage rule scales output with home size and climate severity: multiply the home's square footage by a BTU-per-square-foot factor that rises with how cold the climate is.
    </p>
    <p class="mt-3 text-slate-600">
      Mild climates need roughly 30 to 35 BTU per square foot, moderate climates about 40 to 45, and cold northern climates 50 to 60 or more. The reasoning is straightforward: a colder outdoor design temperature widens the gap between inside and outside, so heat escapes through the walls, windows, and roof faster, and the heating system must replace it faster to keep up.
    </p>
    <p class="mt-3 text-slate-600">
      This estimate is a rough starting point, not a substitute for an ACCA Manual J load calculation, which accounts for a home's actual insulation levels, window performance, air infiltration, orientation, and room-by-room needs. A properly sized boiler — not oversized — runs longer, steadier cycles that are more efficient and put less wear on the equipment; an oversized boiler short-cycles, wasting fuel and heating unevenly. Have an HVAC professional confirm sizing with a full load calculation before installing or replacing a real boiler.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter square footage</h3>
        <p class="mt-1 text-sm text-slate-600">Total conditioned floor area of the home.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick your climate</h3>
        <p class="mt-1 text-sm text-slate-600">Mild, moderate, or cold winter conditions.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Confirm with a pro</h3>
        <p class="mt-1 text-sm text-slate-600">Get a full Manual J calculation before buying.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Boiler output</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= sq ft &times; climate factor</span>. A 2,000 sq ft home, moderate climate: 2,000 × 42.5 = <strong>85,000 BTU/hr</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Mild climate</p>
        <p class="mt-1 text-slate-600">
          Same home: 2,000 × 32 = <strong>64,000 BTU/hr</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Cold climate</p>
        <p class="mt-1 text-slate-600">
          Same home: 2,000 × 55 = <strong>110,000 BTU/hr</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 1,500 sq ft home in a cold climate.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Square footage:</span> <span class="text-slate-600">1,500 ft²</span></div>
        <div><span class="font-medium text-slate-700">Factor:</span> <span class="text-slate-600">55 BTU/ft²</span></div>
        <div><span class="font-medium text-slate-700">Output:</span> <span class="text-slate-600">1,500 × 55 = <strong>82,500 BTU/hr</strong></span></div>
        <div><span class="font-medium text-slate-700">Next step:</span> <span class="text-slate-600">confirm with a Manual J calculation</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/furnace-btu-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Furnace BTU Calculator</a>
      <a href="/tools/heat-loss-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Home Heat Loss Estimator</a>
      <a href="/tools/insulation-r-value-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Insulation R-Value Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const sqft = parseFloat(el('sqft').value);
      const factor = parseFloat(el('climate').value);
      if (!(sqft > 0)) { el('results').classList.add('hidden'); return; }
      const btu = sqft * factor;

      el('r-btu').textContent = Math.round(btu).toLocaleString() + ' BTU/hr';
      el('r-note').textContent = sqft.toLocaleString() + ' sq ft at ' + factor + ' BTU/ft²';
      el('results').classList.remove('hidden');
    }

    el('sqft').addEventListener('input', update);
    el('climate').addEventListener('change', update);
  </script>
</ToolLayout>
