---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Business Days Calculator';
const description = 'Free online business days calculator. Add or subtract business days (weekdays) from any date, or count business days between two dates.';
const intro = 'Calculate a date by adding or subtracting business days, or count the number of business days between two dates.';
const category = { id: 'time-date', name: 'Time & Date' };
const faqs = [
  { q: 'What are business days?', a: 'Business days are weekdays (Monday through Friday), excluding weekends (Saturday and Sunday). They are the days when most businesses operate and stock markets are open.' },
  { q: 'How many business days are in a year?', a: 'There are typically 260-262 business days per year (52 weeks × 5 weekdays = 260, but some years have 261 or 262 depending on the starting day).' },
  { q: 'Does this calculator exclude holidays?', a: 'No, this calculator only excludes Saturdays and Sundays. Public holidays vary by country and region and are not factored in. For holiday-adjusted calculations, you would need a holiday calendar for your specific location.' },
  { q: 'What is the difference between calendar days and business days?', a: 'Calendar days include all days of the week (including weekends and holidays). Business days only include Monday through Friday. For example, 5 calendar days could be just 3 business days if a weekend falls in between.' },
  { q: 'How do I count business days between two dates?', a: 'Count each day from Monday to Friday between the two dates (excluding the start date, including the end date). Weekends are skipped. Our calculator does this automatically.' },
  { q: 'What day is 10 business days from today?', a: '10 business days from today is approximately 2 calendar weeks later (14 days), since 10 weekdays span 2 weeks. Use the calculator to get the exact date.' },
  { q: 'Do business days include the start date?', a: 'When adding or subtracting, the calculation begins from the start date. When counting between dates, the start date is typically excluded and the end date is included.' },
  { q: 'What are business day counting conventions?', a: 'Common conventions include: following weekends only (US, UK standard), following weekends + local holidays, and net settlement days used in finance (T+2, T+3).' },
  { q: 'Why are business days important in finance?', a: 'Stock markets only operate on business days. Settlement periods (like T+2), option expirations, and dividend dates are all calculated using business days.' },
  { q: 'Can I have fractional business days?', a: 'Business days are typically counted as whole days. For fractional calculations (like half a business day), you would need to calculate hours within a business day context.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2 mb-4">
      <button id="bd-mode-add" class="rounded-xl bg-indigo-600 px-4 py-2 text-sm font-medium text-white">Add / Subtract</button>
      <button id="bd-mode-count" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">Count Between</button>
    </div>
    <div id="bd-add-panel">
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-slate-700" for="bd-add-date">Start date</label>
          <input id="bd-add-date" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-slate-700" for="bd-add-days">Business days</label>
            <input id="bd-add-days" type="number" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700" for="bd-add-op">Operation</label>
            <select id="bd-add-op" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
              <option value="add">Add (+)</option>
              <option value="subtract">Subtract (−)</option>
            </select>
          </div>
        </div>
      </div>
      <div class="mt-4 rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Result Date</div>
        <div id="bd-add-result" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
    <div id="bd-count-panel" style="display:none">
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-slate-700" for="bd-count-start">Start date</label>
          <input id="bd-count-start" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700" for="bd-count-end">End date</label>
          <input id="bd-count-end" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Business Days</div><div id="bd-count-result" class="mt-1 text-2xl font-bold">—</div></div>
        <div class="rounded-xl bg-emerald-600 p-4 text-center text-white"><div class="text-xs opacity-80">Calendar Days</div><div id="bd-count-cal" class="mt-1 text-2xl font-bold">—</div></div>
        <div class="rounded-xl bg-violet-600 p-4 text-center text-white"><div class="text-xs opacity-80">Weekends</div><div id="bd-count-weekends" class="mt-1 text-2xl font-bold">—</div></div>
        <div class="rounded-xl bg-amber-600 p-4 text-center text-white"><div class="text-xs opacity-80">% Business</div><div id="bd-count-pct" class="mt-1 text-2xl font-bold">—</div></div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Business days vs calendar days</h2>
    <div class="mt-3 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Business days</span><span id="bd-bar-biz-label" class="text-slate-400">0</span></div>
        <div class="mt-1 h-4 w-full rounded-full bg-slate-100"><div id="bd-bar-biz" class="h-4 rounded-full bg-indigo-500 transition-all" style="width:0%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Calendar days</span><span id="bd-bar-cal-label" class="text-slate-400">0</span></div>
        <div class="mt-1 h-4 w-full rounded-full bg-slate-100"><div id="bd-bar-cal" class="h-4 rounded-full bg-slate-300 transition-all" style="width:0%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📋</span>
      <h3 class="mt-2 font-semibold text-slate-900">Project Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate project timelines by adding business days to start dates. Estimate delivery dates accounting for weekdays only.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📝</span>
      <h3 class="mt-2 font-semibold text-slate-900">Contract Administrator</h3>
      <p class="mt-1 text-sm text-slate-600">Determine contract deadlines and response periods that are specified in business days. Ensure compliance with contractual timelines.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏢</span>
      <h3 class="mt-2 font-semibold text-slate-900">HR Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate notice periods, leave accrual, and onboarding timelines using business days. Standardize HR processes around the work week.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📊</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sales Rep</h3>
      <p class="mt-1 text-sm text-slate-600">Track follow-up schedules and quote expiration dates. Know exactly which business day a prospect will hear back from you.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Business days per year by country</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead><tr class="border-b border-slate-200 text-slate-500"><th class="pb-2 pr-4 font-medium">Country</th><th class="pb-2 pr-4 font-medium">Typical Business Days</th><th class="pb-2 pr-4 font-medium">Weekend</th><th class="pb-2 font-medium">Notes</th></tr></thead>
        <tbody class="text-slate-700">
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">United States</td><td class="py-2 pr-4">260-262</td><td class="py-2 pr-4">Sat-Sun</td><td class="py-2">10 federal holidays vary by year</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">United Kingdom</td><td class="py-2 pr-4">260-262</td><td class="py-2 pr-4">Sat-Sun</td><td class="py-2">8 bank holidays</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">France</td><td class="py-2 pr-4">260-262</td><td class="py-2 pr-4">Sat-Sun</td><td class="py-2">11 public holidays</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">Germany</td><td class="py-2 pr-4">260-262</td><td class="py-2 pr-4">Sat-Sun</td><td class="py-2">9-13 holidays by state</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">India</td><td class="py-2 pr-4">260-262</td><td class="py-2 pr-4">Sat-Sun</td><td class="py-2">3 national holidays, many state</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">Japan</td><td class="py-2 pr-4">260-262</td><td class="py-2 pr-4">Sat-Sun</td><td class="py-2">16 national holidays</td></tr>
          <tr class="border-b border-slate-100"><td class="py-2 pr-4">UAE</td><td class="py-2 pr-4">260-262</td><td class="py-2 pr-4">Sat-Sun</td><td class="py-2">Friday half-day in some sectors</td></tr>
          <tr><td class="py-2 pr-4">Saudi Arabia</td><td class="py-2 pr-4">~260</td><td class="py-2 pr-4">Fri-Sat</td><td class="py-2">Thursday used to be weekend</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How business day calculation works</h2>
    <p class="mt-2 text-slate-600">Business day calculation counts only weekdays (Monday through Friday) while skipping weekends (Saturday and Sunday). When adding business days to a start date, each calendar day is checked: if it is a weekday, it counts toward the total; if it is a weekend, it is skipped. Optional holidays can be excluded for more precise results.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Start date:</span> <span class="text-slate-600">Monday, June 15, 2026</span></div>
        <div><span class="font-medium text-slate-700">Business days:</span> <span class="text-slate-600">10</span></div>
        <div><span class="font-medium text-slate-700">Result date:</span> <span class="text-slate-600">Monday, June 29, 2026</span></div>
        <div><span class="font-medium text-slate-700">Note:</span> <span class="text-slate-600">2 weeks of weekdays, weekends excluded</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the business days calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose a mode</h3>
        <p class="mt-1 text-sm text-slate-600">Select "Add / Subtract" to find a future date, or "Count Between" to count business days.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter dates and days</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in the start date and either business days to add or the end date for counting.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get your results</h3>
        <p class="mt-1 text-sm text-slate-600">See the resulting date or the business day count, calendar days, weekends, and percentages.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Business day tips</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Watch out for holiday weeks</h3>
        <p class="mt-1 text-sm text-slate-600">Weeks with public holidays have fewer business days. Christmas week, for example, often has only 3-4 business days. Plan accordingly for deadlines.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Add buffer for critical deadlines</h3>
        <p class="mt-1 text-sm text-slate-600">If a deadline is specified in business days, add an extra day or two as buffer. Unexpected holidays or company-wide closures can shift timelines.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">International business days vary</h3>
        <p class="mt-1 text-sm text-slate-600">The weekend is Friday-Saturday in many Middle Eastern countries. When working with international partners, confirm which days constitute their business week.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What are business days?</h2>
    <p class="mt-2 text-slate-600">Business days are the days of the week when most commercial enterprises operate. In most Western countries, business days are Monday through Friday, excluding weekends. The concept is fundamental in finance, contract law, logistics, and project management where deadlines are specified in business days rather than calendar days.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">Excluding holidays vs weekends</h2>
    <p class="mt-2 text-slate-600">This calculator excludes weekends only. For full accuracy, public holidays should also be excluded. Holiday calendars are country-specific and region-specific. In the US, federal holidays like Christmas, Thanksgiving, and Independence Day reduce the business day count for many industries.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">Business day counting conventions</h2>
    <p class="mt-2 text-slate-600">Financial markets use conventions like T+2 (trade date plus 2 business days for settlement). Contract law often specifies "business days" to exclude weekends and public holidays. Some agreements use "clear business days" which exclude both the start and end dates. Always verify the specific convention used in your contract or jurisdiction.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">When to use the business days calculator</h2>
    <p class="mt-2 text-slate-600">Business day calculations serve critical functions across numerous professional fields. Project managers rely on them to estimate realistic delivery dates by adding working days to project start dates while excluding weekends. For instance, a software development sprint beginning on a Wednesday with 15 business days of work completes 21 calendar days later, accounting for two full weekends. In contract law, notice periods, response windows, and fulfillment deadlines are frequently expressed in business days. A service agreement specifying a 30-business-day response period gives the responding party approximately six calendar weeks, explicitly excluding weekends from the count. Human resources departments use business day calculations for resignation notice periods, probation review timelines, and leave accrual. A standard two-week notice period equals 10 business days, meaning an employee who submits resignation on a Monday works their final day on Friday of the following week. Financial professionals depend on business day conventions for trade settlement periods, bond coupon payments, and option expiration dates. The industry-standard T+2 settlement means a trade executed on Tuesday settles on Thursday, provided no market holidays fall between. Logistics and e-commerce companies advertise delivery windows in business days, where a 3-to-5 business day shipping estimate accounts for carrier non-operation on weekends. Understanding these applications helps users choose the correct calculation mode and interpret results appropriately in their specific context.</p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-bold text-slate-900">Limitations and considerations</h2>
    <p class="mt-2 text-slate-600">While the business days calculator provides accurate weekday counting, several important limitations warrant attention. The calculator does not account for public holidays, which vary by country, region, and locality. In the United States, 10 federal holidays reduce the annual business day count, but states also observe unique holidays such as Patriots Day in Massachusetts or Casimir Pulaski Day in Illinois. International users face even greater variation, as holiday calendars differ dramatically across countries. The definition of the business week itself varies globally. Most Western countries observe Saturday-Sunday weekends, but many Middle Eastern nations including Saudi Arabia and the United Arab Emirates use Friday-Saturday as the weekend. Some countries historically maintained Thursday-Friday weekends, and others employ a six-day workweek with only Friday off. Partial business days present another challenge; a deadline specified for noon on a business day requires hourly precision that a whole-day calculator cannot provide. Company-specific closures such as inventory audits, team offsites, or industry holidays like bank holidays are not included. Certain legal jurisdictions use "clear business days" conventions that exclude both the start and end dates from the count, a nuance this calculator does not implement. For critical deadlines involving legal or financial consequences, users should verify business day calculations against applicable jurisdiction rules, holiday calendars, and the specific wording of any governing agreement.</p>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);

    function isBizDay(d) {
      const day = d.getDay();
      return day !== 0 && day !== 6;
    }

    function addBizDays(start, n) {
      const d = new Date(start);
      let remaining = Math.abs(n);
      const dir = n >= 0 ? 1 : -1;
      while (remaining > 0) {
        d.setDate(d.getDate() + dir);
        if (isBizDay(d)) remaining--;
      }
      return d;
    }

    function countBizDays(start, end) {
      const s = new Date(start);
      const e = new Date(end);
      s.setHours(12, 0, 0, 0);
      e.setHours(12, 0, 0, 0);
      if (s >= e) return { biz: 0, cal: 0, weekends: 0 };
      let biz = 0, weekends = 0;
      const cur = new Date(s);
      cur.setDate(cur.getDate() + 1);
      while (cur <= e) {
        if (isBizDay(cur)) biz++;
        else weekends++;
        cur.setDate(cur.getDate() + 1);
      }
      const cal = Math.round((e - s) / 86400000);
      return { biz, cal, weekends };
    }

    function formatDate(d) {
      const opts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
      return d.toLocaleDateString('en-US', opts);
    }

    function switchMode(mode) {
      const isAdd = mode === 'add';
      $('bd-add-panel').style.display = isAdd ? 'block' : 'none';
      $('bd-count-panel').style.display = isAdd ? 'none' : 'block';
      $('bd-mode-add').className = isAdd ? 'rounded-xl bg-indigo-600 px-4 py-2 text-sm font-medium text-white' : 'rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50';
      $('bd-mode-count').className = isAdd ? 'rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50' : 'rounded-xl bg-indigo-600 px-4 py-2 text-sm font-medium text-white';
      updateBizDays();
    }

    function updateBizDays() {
      const isAdd = $('bd-add-panel').style.display !== 'none';
      if (isAdd) {
        const dateVal = $('bd-add-date').value;
        if (!dateVal) return;
        const days = parseInt($('bd-add-days').value, 10) || 0;
        const op = $('bd-add-op').value;
        const start = new Date(dateVal + 'T12:00:00');
        const n = op === 'add' ? days : -days;
        const result = addBizDays(start, n);
        $('bd-add-result').textContent = formatDate(result);

        const s = new Date(dateVal + 'T12:00:00');
        const e = new Date(result);
        const diff = Math.abs(Math.round((e - s) / 86400000)) + 1;
        $('bd-bar-biz-label').textContent = Math.abs(days) + ' biz days';
        $('bd-bar-cal-label').textContent = diff + ' cal days';
        const maxD = Math.max(Math.abs(days), diff);
        $('bd-bar-biz').style.width = (Math.abs(days) / maxD * 100) + '%';
        $('bd-bar-cal').style.width = (diff / maxD * 100) + '%';
      } else {
        const sVal = $('bd-count-start').value;
        const eVal = $('bd-count-end').value;
        if (!sVal || !eVal) return;
        const result = countBizDays(new Date(sVal + 'T12:00:00'), new Date(eVal + 'T12:00:00'));
        $('bd-count-result').textContent = result.biz;
        $('bd-count-cal').textContent = result.cal;
        $('bd-count-weekends').textContent = result.weekends;
        $('bd-count-pct').textContent = result.cal > 0 ? Math.round(result.biz / result.cal * 100) + '%' : '0%';

        $('bd-bar-biz-label').textContent = result.biz + ' biz days';
        $('bd-bar-cal-label').textContent = result.cal + ' cal days';
        const maxD2 = Math.max(result.biz, result.cal) || 1;
        $('bd-bar-biz').style.width = (result.biz / maxD2 * 100) + '%';
        $('bd-bar-cal').style.width = (result.cal / maxD2 * 100) + '%';
      }
    }

    $('bd-mode-add').addEventListener('click', () => switchMode('add'));
    $('bd-mode-count').addEventListener('click', () => switchMode('count'));
    $('bd-add-date').addEventListener('change', updateBizDays);
    $('bd-add-days').addEventListener('input', updateBizDays);
    $('bd-add-op').addEventListener('change', updateBizDays);
    $('bd-count-start').addEventListener('change', updateBizDays);
    $('bd-count-end').addEventListener('change', updateBizDays);

    $('bd-add-date').valueAsDate = new Date();
    $('bd-count-start').valueAsDate = new Date();
    const endDate = new Date();
    endDate.setDate(endDate.getDate() + 14);
    $('bd-count-end').valueAsDate = endDate;
    updateBizDays();
  </script>
</ToolLayout>
