---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Fluid Ounces to Ml"
  emoji="🧪"
  fromUnit="US fluid ounces" toUnit="milliliters"
  fromTitle="Fluid Ounces" toTitle="Milliliters"
  fromSym="fl oz" toSym="mL"
  quantity="volume"
  kind="factor" factor={29.5735295625}
  reverseSlug="ml-to-ounces" reverseLabel="Ml to Fluid Ounces Converter"
  hasReverse={true}
  related={[{"slug":"volume-converter","label":"Volume Converter"}]}
  useCase="Turn fluid ounces from US recipes and bottles into the milliliters shown on measuring jugs."
/>
