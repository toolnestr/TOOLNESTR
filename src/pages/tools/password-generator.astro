---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Password Generator';
const description =
  'Free strong password generator. Create random, secure passwords with custom length, ' +
  'numbers and symbols. Generated in your browser — never sent or stored anywhere.';
const intro =
  'Create a strong, random password. Choose the length and character types, then copy it. Passwords are generated securely in your browser and never leave your device.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'Are these passwords safe to use?', a: 'Yes. They’re generated using your browser’s cryptographically secure random generator, and nothing is sent to any server or saved anywhere.' },
  { q: 'What makes a strong password?', a: 'Length matters most. Aim for at least 12–16 characters and mix uppercase, lowercase, numbers and symbols.' },
  { q: 'What does “avoid ambiguous characters” do?', a: 'It removes look-alike characters such as l, 1, I, O and 0, so the password is easier to read and type correctly.' },
  { q: 'Is the password stored anywhere?', a: 'No. Once you leave or refresh the page it’s gone. Save it somewhere safe, ideally a password manager.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="SecurityApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <!-- Output -->
    <div class="flex items-stretch gap-2">
      <input id="pw" readonly class="w-full rounded-xl border border-slate-300 bg-slate-50 p-4 font-mono text-lg outline-none" />
      <button id="copy-btn" class="shrink-0 rounded-xl bg-indigo-600 px-4 text-sm font-medium text-white transition hover:bg-indigo-700">Copy</button>
      <button id="refresh-btn" title="Generate new" class="shrink-0 rounded-xl border border-slate-300 px-4 text-lg transition hover:bg-slate-50">↻</button>
    </div>

    <!-- Strength -->
    <div class="mt-3">
      <div class="h-2 w-full overflow-hidden rounded-full bg-slate-200">
        <div id="strength-bar" class="h-full w-0 rounded-full bg-slate-300 transition-all"></div>
      </div>
      <p id="strength-label" class="mt-1 text-sm text-slate-500">—</p>
    </div>

    <!-- Controls -->
    <div class="mt-5">
      <label class="flex items-center justify-between text-sm font-medium text-slate-700">
        Length <span id="len-val" class="font-mono text-indigo-600">16</span>
      </label>
      <input id="length" type="range" min="4" max="64" value="16" class="mt-1 w-full accent-indigo-600" />
    </div>

    <div class="mt-4 grid grid-cols-2 gap-3 text-sm text-slate-700">
      <label class="flex items-center gap-2"><input id="lower" type="checkbox" checked class="h-4 w-4 rounded border-slate-300" /> Lowercase (a–z)</label>
      <label class="flex items-center gap-2"><input id="upper" type="checkbox" checked class="h-4 w-4 rounded border-slate-300" /> Uppercase (A–Z)</label>
      <label class="flex items-center gap-2"><input id="numbers" type="checkbox" checked class="h-4 w-4 rounded border-slate-300" /> Numbers (0–9)</label>
      <label class="flex items-center gap-2"><input id="symbols" type="checkbox" checked class="h-4 w-4 rounded border-slate-300" /> Symbols (!@#…)</label>
      <label class="flex items-center gap-2"><input id="noamb" type="checkbox" class="h-4 w-4 rounded border-slate-300" /> Avoid ambiguous (l 1 I O 0)</label>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this password generator</h2>
    <p class="mt-2 text-slate-600">
      Reusing simple passwords is one of the biggest security risks online. This generator creates
      strong, unique, random passwords using your browser’s secure random number generator — so
      nothing is ever transmitted or stored. Pick a length, choose which character types to
      include, and copy your new password straight into a password manager.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Set the length (12–16+ is recommended).</li>
      <li>Choose which character types to include.</li>
      <li>Click ↻ for a new password and “Copy” to grab it.</li>
      <li>Store it safely — ideally in a password manager.</li>
    </ol>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Browse more <a href="/#developers" class="font-medium text-indigo-600 hover:underline">developer tools →</a>
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const pw = el('pw'), lengthEl = el('length'), lenVal = el('len-val');
    const sets = {
      lower: 'abcdefghijklmnopqrstuvwxyz',
      upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      numbers: '0123456789',
      symbols: '!@#$%^&*()-_=+[]{};:,.<>?/',
    };
    const ambiguous = /[l1IO0]/g;

    function generate() {
      let pool = '';
      ['lower', 'upper', 'numbers', 'symbols'].forEach((k) => { if (el(k).checked) pool += sets[k]; });
      if (el('noamb').checked) pool = pool.replace(ambiguous, '');
      if (!pool) { pw.value = ''; updateStrength(0, 0); return; }

      const len = parseInt(lengthEl.value, 10);
      const arr = new Uint32Array(len);
      crypto.getRandomValues(arr);
      let out = '';
      for (let i = 0; i < len; i++) out += pool[arr[i] % pool.length];
      pw.value = out;

      const variety = ['lower', 'upper', 'numbers', 'symbols'].filter((k) => el(k).checked).length;
      updateStrength(len, variety);
    }

    function updateStrength(len, variety) {
      const bar = el('strength-bar'), label = el('strength-label');
      let score = 0;
      if (len >= 8) score++;
      if (len >= 12) score++;
      if (len >= 16) score++;
      if (variety >= 3) score++;
      if (variety === 4 && len >= 12) score++;
      const levels = [
        { w: '10%', c: 'bg-red-500', t: 'Very weak' },
        { w: '30%', c: 'bg-orange-500', t: 'Weak' },
        { w: '55%', c: 'bg-yellow-500', t: 'Fair' },
        { w: '80%', c: 'bg-lime-500', t: 'Strong' },
        { w: '100%', c: 'bg-green-600', t: 'Very strong' },
      ];
      const lvl = levels[Math.min(score, 5) - 1] || levels[0];
      bar.className = 'h-full rounded-full transition-all ' + lvl.c;
      bar.style.width = len ? lvl.w : '0';
      label.textContent = len ? lvl.t : '—';
    }

    lengthEl.addEventListener('input', () => { lenVal.textContent = lengthEl.value; generate(); });
    ['lower', 'upper', 'numbers', 'symbols', 'noamb'].forEach((k) => el(k).addEventListener('change', generate));
    el('refresh-btn').addEventListener('click', generate);
    el('copy-btn').addEventListener('click', async () => {
      if (!pw.value) return;
      try {
        await navigator.clipboard.writeText(pw.value);
        const b = el('copy-btn'); const o = b.textContent; b.textContent = '✓'; setTimeout(() => (b.textContent = o), 1200);
      } catch (e) {}
    });

    generate();
  </script>
</ToolLayout>
