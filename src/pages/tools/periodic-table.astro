---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Interactive Periodic Table';
const description = "Interactive periodic table of all 118 elements with a live 3D atom diagram and trend charts.";
const intro = 'Click any of the 118 elements to see its atomic number, standard atomic weight, and category. A 3D diagram compares a small, simple atom to a large, many-electron atom, and charts show two of the periodic table\'s most important trends: atomic radius and electronegativity.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'How is the periodic table organized?', a: 'Elements are arranged by increasing atomic number (proton count), in rows called periods and columns called groups. Elements in the same group share similar chemical behavior because they have the same number of valence electrons.' },
  { q: 'Why are the lanthanides and actinides shown as a separate block?', a: 'They are shown below the main table purely to keep it a manageable width — they actually belong in period 6 (lanthanides, starting after lanthanum) and period 7 (actinides, starting after actinium), pulled out below so the table isn\'t excessively wide.' },
  { q: 'What is atomic weight, and why isn\'t it a whole number?', a: 'Atomic weight is the weighted average mass of all naturally occurring isotopes of an element, so it reflects both each isotope\'s mass and its natural abundance — which is why it\'s essentially never a clean whole number, chlorine\'s 35.45 being a classic example.' },
  { q: 'What do the bracketed atomic weights mean, like [98] for technetium?', a: 'Brackets indicate the element has no stable isotopes — the number shown is the mass number of its longest-lived or most studied radioactive isotope instead of a natural-abundance-weighted average.' },
  { q: 'How many elements are there, and are more being discovered?', a: '118 elements are currently confirmed and named, filling the table through period 7. Elements above 118 have not yet been synthesized, though searches for period 8 elements are an active area of nuclear physics research.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Interactive Periodic Table',
  description: 'Browse all 118 elements and click any one to see its atomic number, atomic weight, and category.',
  steps: [
    { name: 'Click any element tile', text: 'The details panel updates with that element\'s symbol, name, atomic number, and standard atomic weight.' },
    { name: 'Use the category legend', text: 'Colors group elements into families like alkali metals, halogens, and noble gases — hover or click to compare elements in the same family.' },
  ],
};

const formulas = [
  { expr: 'Atomic radius: decreases → across a period, increases ↓ down a group', note: 'more protons pull valence electrons in tighter across a period; extra electron shells push the radius out down a group' },
  { expr: 'Electronegativity: increases → across a period, decreases ↓ down a group', note: 'atoms hold electrons more tightly as nuclear charge increases across a period, but less tightly as electrons sit farther from the nucleus down a group' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — reading chlorine\'s tile', tone: 'slate',
    given: 'Chlorine sits in period 3, group 17 (the halogens), with atomic number 17.',
    rows: [
      { label: 'Protons/electrons:', value: '17 (matches the atomic number for a neutral atom)' },
      { label: 'Standard atomic weight:', value: '35.45 — a weighted average of chlorine-35 (≈76% abundance) and chlorine-37 (≈24% abundance)' },
      { label: 'Category:', value: 'Halogen — highly reactive nonmetal, one electron short of a full outer shell', full: true },
    ],
    note: 'Chlorine\'s non-round atomic weight is one of the clearest classroom examples of why atomic weight is an abundance-weighted average, not a single isotope\'s mass.',
  },
  {
    title: 'Worked example 2 — comparing sodium and potassium (same group)', tone: 'amber',
    given: 'Sodium (Z=11) and potassium (Z=19) are both in group 1, the alkali metals.',
    rows: [
      { label: 'Shared property:', value: 'Both have exactly one valence electron, giving them very similar reactivity' },
      { label: 'Key difference:', value: 'Potassium is one period lower, so its valence electron sits farther from the nucleus' },
      { label: 'Consequence:', value: 'Potassium has a larger atomic radius and lower ionization energy — it reacts even more vigorously with water than sodium does', full: true },
    ],
    note: 'This is the core logic of the periodic table: elements in the same column react similarly, and reactivity trends shift predictably as you move down that column.',
  },
];

const comparison = {
  heading: 'The ten element categories on this table',
  note: 'Every element belongs to one family based on shared chemical behavior.',
  headers: [{ label: 'Category' }, { label: 'Example elements' }],
  rows: [
    ['Alkali metals ★', 'Li, Na, K, Rb, Cs, Fr'],
    ['Alkaline earth metals', 'Be, Mg, Ca, Sr, Ba, Ra'],
    ['Transition metals', 'Fe, Cu, Ag, Au, Zn'],
    ['Post-transition metals', 'Al, Ga, Sn, Pb, Bi'],
    ['Metalloids', 'B, Si, Ge, As, Sb, Te'],
    ['Nonmetals', 'H, C, N, O, P, S, Se'],
    ['Halogens', 'F, Cl, Br, I, At'],
    ['Noble gases', 'He, Ne, Ar, Kr, Xe, Rn'],
    ['Lanthanides', 'La through Lu'],
    ['Actinides', 'Ac through Lr'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row. Category assignment is the single fastest way to predict how an unfamiliar element will behave chemically.',
};

const realWorld = [
  { emoji: '🔋', title: 'Battery and materials chemistry', body: 'Lithium\'s position as the lightest alkali metal with the smallest atomic radius in its group makes it uniquely suited to high energy-density batteries — a direct consequence of trends read straight off the periodic table.' },
  { emoji: '💊', title: 'Pharmaceutical and biochemistry research', body: 'Understanding which elements behave similarly (same group) helps chemists predict how substituting one atom for another in a drug molecule might change its properties, well before running an experiment.' },
  { emoji: '⚛️', title: 'Nuclear medicine and energy', body: 'Radioactive elements like technetium-99m (used in medical imaging) and uranium (used in nuclear power) are identified and handled based on their periodic table position and known isotope behavior.' },
  { emoji: '🏗️', title: 'Materials and alloy design', body: 'Engineers select transition metals for alloys based on periodic trends in hardness, conductivity, and reactivity — for example, chromium and nickel are added to steel because their periodic properties resist corrosion.' },
];

const misconceptions = [
  { claim: '"Atomic weight and atomic number are the same thing."', truth: 'Atomic number is a whole number counting protons (defines the element); atomic weight is the abundance-weighted average mass of all naturally occurring isotopes, and is almost never a whole number.' },
  { claim: '"Elements in the same period (row) are chemically similar."', truth: "It's elements in the same group (column) that share similar chemistry, because they have the same number of valence electrons. Elements in the same period instead show a trend — properties change steadily from one side of the table to the other." },
  { claim: '"The periodic table is a fixed, unchanging list."', truth: "New elements are still being confirmed and named — element 118 (oganesson) wasn't officially named until 2016. Ongoing nuclear physics research continues to search for even heavier, so-far-unconfirmed elements." },
  { claim: '"Metalloids are just weak metals."', truth: 'Metalloids (like silicon and germanium) have properties genuinely intermediate between metals and nonmetals — most famously, they act as semiconductors, conducting electricity under some conditions but not others, which is precisely why they underpin all modern computer chips.' },
];

const sources = [
  { html: '<strong>IUPAC</strong> — Standard Atomic Weights (periodic official reference). <a href="https://iupac.org/what-we-do/periodic-table-of-elements/" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">iupac.org</a>' },
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 6, "Electronic Structure and Periodic Properties" (free, peer-reviewed).' },
  { html: '<strong>CRC Handbook of Chemistry and Physics</strong> — standard reference atomic weights and radii.' },
];
const sourcesNote = 'Atomic weights follow IUPAC standard values (rounded); bracketed values are the mass number of the most stable known isotope for elements with no stable isotopes. Results are rounded for display.';

const howToUse = [
  { title: 'Click any tile', body: 'The details panel shows that element\'s symbol, name, atomic number, and standard atomic weight.' },
  { title: 'Check the category legend', body: 'Colors group elements by chemical family — a fast way to predict likely behavior.' },
  { title: 'Follow a row or column', body: 'Move across a period to see gradual trend shifts, or down a group to compare chemically similar elements.' },
