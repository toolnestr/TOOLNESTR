---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="an element's column tells you how it behaves chemically, and its row tells you how big and reactive it is compared to its neighbors — together, position on the table alone predicts most of an element's chemistry."
  howIntro="The periodic table isn't just a list — it's arranged so that elements sharing a column (group) have the same number of valence electrons, and therefore very similar chemical behavior. Moving left to right across a row (period), protons increase steadily, pulling the outer electrons in tighter — atoms shrink and hold their electrons more strongly. Moving top to bottom down a group, each step adds a whole new electron shell, so atoms get larger and their outermost electrons, now farther from the nucleus, become easier to remove."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the periodic table actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR (element grid + details panel) ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div id="pt-details" class="mb-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
      <p class="text-sm text-slate-500">Click any element below to see its details.</p>
    </div>
    <div id="pt-legend" class="mb-4 flex flex-wrap gap-2 text-xs"></div>
    <div class="overflow-x-auto">
      <div id="pt-grid" class="grid gap-1" style="grid-template-columns: repeat(18, minmax(34px, 1fr)); min-width: 720px;"></div>
    </div>
    <p id="pt-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Small atom vs. large atom</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-small" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Small atom (e.g., helium)</h3>
          <p class="mt-1 text-sm text-slate-600">Few electron shells — a compact atom with electrons held tightly by the nucleus.</p>
        </div>
        <div>
          <div id="diag-large" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Large atom (e.g., caesium)</h3>
          <p class="mt-1 text-sm text-slate-600">Many electron shells — a much larger atom with its outermost electron loosely held.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Periodic trend graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Atomic radius across period 3 (Na→Cl)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-radius"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Electronegativity down group 17 (F→I)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-eneg"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline define:vars={{ elementsJson, catColorsJson, catLabelsJson }}>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const elements = JSON.parse(elementsJson);
      const catColors = JSON.parse(catColorsJson);
      const catLabels = JSON.parse(catLabelsJson);

      // ---- grid + legend + details ----
      function buildLegend() {
        const wrap = el('pt-legend');
        Object.keys(catLabels).forEach((k) => {
          const chip = document.createElement('span');
          chip.className = 'inline-flex items-center gap-1 rounded-full border border-slate-200 px-2 py-1';
          chip.innerHTML = '<span style="display:inline-block;width:10px;height:10px;border-radius:9999px;background:' + catColors[k] + '"></span>' + catLabels[k];
          wrap.appendChild(chip);
        });
      }
      function showDetails(e) {
        el('pt-details').innerHTML =
          '<div class="flex items-center gap-4">' +
          '<div class="flex h-16 w-16 flex-col items-center justify-center rounded-lg text-white" style="background:' + catColors[e[4]] + '">' +
          '<span class="text-[10px] opacity-90">' + e[0] + '</span><span class="text-xl font-bold">' + e[1] + '</span></div>' +
          '<div><h3 class="font-semibold text-slate-900">' + e[2] + ' (' + e[1] + ')</h3>' +
          '<p class="text-sm text-slate-600">Atomic number: ' + e[0] + ' · Atomic weight: ' + e[3] + ' · ' + catLabels[e[4]] + '</p></div></div>';
      }
      function buildGrid() {
        const grid = el('pt-grid');
        elements.forEach((e) => {
          const [z, sym, , weight, cat, col, row] = e;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.setAttribute('aria-label', e[2]);
          btn.className = 'flex aspect-square flex-col items-center justify-center rounded text-white transition hover:scale-105 hover:shadow';
          btn.style.gridColumn = String(col);
          btn.style.gridRow = String(row);
          btn.style.background = catColors[cat];
          btn.style.fontSize = '10px';
          btn.innerHTML = '<span style="font-size:8px;opacity:0.85">' + z + '</span><span style="font-weight:700">' + sym + '</span>';
          btn.addEventListener('click', () => showDetails(e));
          grid.appendChild(btn);
        });
      }

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        new Chart(el('chart-radius'), {
          type: 'bar',
          data: { labels: ['Na', 'Mg', 'Al', 'Si', 'P', 'S', 'Cl'], datasets: [{ label: 'Atomic radius (pm)', data: [186, 160, 143, 117, 110, 104, 99], backgroundColor: '#6366f1' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Atomic radius (pm)' } } }, plugins: { legend: { display: false } } }),
        });
        new Chart(el('chart-eneg'), {
          type: 'bar',
          data: { labels: ['F', 'Cl', 'Br', 'I'], datasets: [{ label: 'Electronegativity (Pauling)', data: [3.98, 3.16, 2.96, 2.66], backgroundColor: '#f59e0b' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Electronegativity (Pauling scale)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function atomScene(container, shellCount) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const nucleus = new THREE.Mesh(new THREE.SphereGeometry(0.35, 16, 12), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
        s.scene.add(nucleus);
        for (let i = 1; i <= shellCount; i++) {
          const r = i * 0.7;
          const curve = new THREE.EllipseCurve(0, 0, r, r * 0.6, 0, Math.PI * 2, false, 0);
          const pts = curve.getPoints(64).map((p) => new THREE.Vector3(p.x, p.y, 0));
          const ring = new THREE.LineLoop(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: 0x94a3b8 }));
          ring.rotation.x = Math.PI / 3;
          s.scene.add(ring);
          const electron = new THREE.Mesh(new THREE.SphereGeometry(0.12, 10, 8), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          electron.position.set(r, 0, 0);
          ring.add(electron);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagSmall = null, diagLarge = null;
      function initDiagSmall() { const c = el('diag-small'); if (!c) throw new Error('no container'); diagSmall = atomScene(c, 1); }
      function initDiagLarge() { const c = el('diag-large'); if (!c) throw new Error('no container'); diagLarge = atomScene(c, 6); }

      function boot() {
        try { buildLegend(); buildGrid(); } catch (e) { console.error('[periodic-table] grid init failed', e); }
        try { initCharts(); } catch (e) { console.error('[periodic-table] charts failed', e); }
        if (window.THREE) {
          try { initDiagSmall(); } catch (e) { console.error('[periodic-table] small atom diagram failed', e); }
          try { initDiagLarge(); } catch (e) { console.error('[periodic-table] large atom diagram failed', e); }
        }
        mountResize([diagSmall, diagLarge]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
