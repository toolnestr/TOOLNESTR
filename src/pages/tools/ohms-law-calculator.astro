---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = "Ohm's Law Calculator";
const description = 'Free Ohm\u2019s Law calculator. Calculate voltage, current, resistance and power using V = IR. Enter any two values to find the other two.';
const intro = 'Enter any two values \u2014 voltage, current, resistance or power \u2014 and the calculator will instantly compute the other two using Ohm\u2019s Law and the power formula.';
const category = { id: 'engineering', name: 'Electrical Engineering' };
const faqs = [
  { q: 'What is Ohm\u2019s Law?', a: 'Ohm\u2019s Law is a fundamental principle in electronics that states the current through a conductor between two points is directly proportional to the voltage across the two points and inversely proportional to the resistance. It is expressed as V = IR, where V is voltage (volts), I is current (amps), and R is resistance (ohms).' },
  { q: 'How do I use the V=IR triangle?', a: 'The Ohm\u2019s Law triangle shows the relationship between voltage (V), current (I) and resistance (R). To find voltage, cover V: V = I \u00d7 R. To find current, cover I: I = V \u00f7 R. To find resistance, cover R: R = V \u00f7 I.' },
  { q: 'What is the power formula in relation to Ohm\u2019s Law?', a: 'The power formula P = VI can be combined with Ohm\u2019s Law to derive P = I\u00b2R and P = V\u00b2/R. These allow you to calculate power dissipation in a circuit from any two known electrical values.' },
  { q: 'Does Ohm\u2019s Law work for AC circuits?', a: 'For purely resistive AC circuits, Ohm\u2019s Law holds true using RMS values. For circuits with reactive components (capacitors, inductors), impedance (\u0398) replaces resistance and the phase angle must be considered.' },
  { q: 'What happens if I apply too much voltage to a resistor?', a: 'Applying excessive voltage causes too much current to flow, which creates heat beyond the resistor\u2019s power rating. The resistor may overheat, change value, or fail catastrophically \u2014 always check power dissipation.' },
  { q: 'What are the units in Ohm\u2019s Law?', a: 'Voltage is measured in volts (V), current in amperes or amps (A), resistance in ohms (\u03a9), and power in watts (W). Kilo-ohms (k\u03a9 = 1000 \u03a9), milliamps (mA = 0.001 A), and milliwatts (mW = 0.001 W) are also common.' },
  { q: 'Can there be current without voltage?', a: 'No \u2014 a voltage difference (potential difference) is required to push current through a circuit. However, superconductors can carry current with zero voltage drop.' },
  { q: 'What is the difference between AC and DC in Ohm\u2019s Law?', a: 'For DC, V, I, and R are constant values. For AC, you must use RMS (root mean square) values for voltage and current. The relationship V = IZ still holds where Z is impedance, the AC equivalent of resistance.' },
  { q: 'How do I calculate power dissipation in a resistor?', a: 'Use P = I\u00b2R or P = V\u00b2/R. For example, a 100\u03a9 resistor with 0.5A flowing through it dissipates 0.5\u00b2 \u00d7 100 = 25W. Choose a resistor with a power rating at least 50\u2013100% higher than this to ensure reliability.' },
  { q: 'Is water a conductor or insulator for Ohm\u2019s Law?', a: 'Pure water is an insulator. However, water with dissolved ions (tap water, salt water) becomes conductive. Ohm\u2019s Law still applies but the resistance depends heavily on ion concentration and temperature.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Voltage (V)</span>
        <input id="v" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current (A)</span>
        <input id="i" type="number" step="any" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Resistance (&Omega;)</span>
        <input id="r" type="number" step="any" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Power (W)</span>
        <input id="p" type="number" step="any" placeholder="24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Voltage</div><div id="r-v" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Current</div><div id="r-i" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Resistance</div><div id="r-r" class="mt-1 text-xl font-bold text-amber-600">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Power</div><div id="r-p" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different voltage ranges mean</h2>
    <p class="mt-2 text-slate-600">Voltage levels across electronics and electrical systems fall into distinct categories, each with different safety and application characteristics.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Signal level</span><span class="text-slate-400">0 \u2013 5 V</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:5%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Low voltage</span><span class="text-slate-400">5 \u2013 50 V</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Mains voltage</span><span class="text-slate-400">110 \u2013 240 V</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">High voltage</span><span class="text-slate-400">240 V+</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:30%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDD0C</span>
      <h3 class="mt-2 font-semibold text-slate-900">Electronics Student</h3>
      <p class="mt-1 text-sm text-slate-600">Learn and verify circuit calculations quickly while studying basic electronics theory and lab assignments.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDD17</span>
      <h3 class="mt-2 font-semibold text-slate-900">Circuit Designer</h3>
      <p class="mt-1 text-sm text-slate-600">Determine resistor values, voltage drops and power dissipation requirements during the design phase of new circuits.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\u26A1</span>
      <h3 class="mt-2 font-semibold text-slate-900">Electrician</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly calculate load currents, wire resistances and power requirements on the job site without carrying reference tables.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDEE0\uFE0F</span>
      <h3 class="mt-2 font-semibold text-slate-900">Hobbyist Maker</h3>
      <p class="mt-1 text-sm text-slate-600">Size resistors for LEDs, choose power supplies, and troubleshoot your DIY electronics projects with confidence.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Resistor value</th><th class="p-3">10 mA drop</th><th class="p-3">50 mA drop</th><th class="p-3">100 mA drop</th><th class="p-3">1 A drop</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">10 &Omega;</td><td class="p-3">0.1 V</td><td class="p-3">0.5 V</td><td class="p-3">1.0 V</td><td class="p-3">10.0 V</td></tr>
        <tr><td class="p-3 font-medium">100 &Omega;</td><td class="p-3">1.0 V</td><td class="p-3">5.0 V</td><td class="p-3">10.0 V</td><td class="p-3">100 V</td></tr>
        <tr><td class="p-3 font-medium">1 k&Omega;</td><td class="p-3">10 V</td><td class="p-3">50 V</td><td class="p-3">100 V</td><td class="p-3">1000 V</td></tr>
        <tr><td class="p-3 font-medium">10 k&Omega;</td><td class="p-3">100 V</td><td class="p-3">500 V</td><td class="p-3">1000 V</td><td class="p-3">\u2014</td></tr>
        <tr><td class="p-3 font-medium">100 k&Omega;</td><td class="p-3">1000 V</td><td class="p-3">\u2014</td><td class="p-3">\u2014</td><td class="p-3">\u2014</td></tr>
        <tr><td class="p-3 font-medium">1 M&Omega;</td><td class="p-3">\u2014</td><td class="p-3">\u2014</td><td class="p-3">\u2014</td><td class="p-3">\u2014</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Ohm\u2019s Law Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter two known values</h3>
        <p class="mt-1 text-sm text-slate-600">Type any two of the four values \u2014 voltage, current, resistance or power. The remaining fields will fill in automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read computed values</h3>
        <p class="mt-1 text-sm text-slate-600">The highlighted result boxes update instantly to show the calculated voltage, current, resistance and power for your circuit.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Apply to your circuit</h3>
        <p class="mt-1 text-sm text-slate-600">Use the calculated values to select the right components, verify your design or troubleshoot an existing circuit safely.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for using Ohm\u2019s Law</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Start with known values</h3>
        <p class="mt-1 text-sm text-slate-600">When troubleshooting a circuit, measure what you can easily access. If you have voltage and resistance, you can always find current and power without additional measurements.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use consistent units</h3>
        <p class="mt-1 text-sm text-slate-600">Mix volts, kilohms and milliamps carefully \u2014 convert everything to base units (V, A, \u03a9, W) before calculating, or use this calculator which does it for you.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Mind power dissipation</h3>
        <p class="mt-1 text-sm text-slate-600">Always calculate the power dissipated by resistors and other components. A resistor rated for \u00bc W will fail quickly if your design makes it dissipate \u00bd W.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Always double-check</h3>
        <p class="mt-1 text-sm text-slate-600">Ohm\u2019s Law calculations should be self-consistent. Verify your results by checking that P = V \u00d7 I and V = I \u00d7 R using the numbers you have.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is Ohm\u2019s Law?</h2>
    <p class="mt-2 text-slate-600">Ohm\u2019s Law is the fundamental relationship that governs all electrical circuits. Discovered by Georg Simon Ohm in 1827, it states that the current through a conductor is directly proportional to the voltage across it and inversely proportional to its resistance. This simple linear relationship is the foundation of circuit analysis, power distribution, and electronics design.</p>
    <p class="mt-3 text-slate-600">In practice, Ohm\u2019s Law lets you determine any one electrical quantity if you know the other two. If you measure 12 V across a 4 \u03a9 resistor, you know 3 A must be flowing. If a 60 W light bulb runs on 120 V, the current is 0.5 A and its hot resistance is 240 \u03a9.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">The power formula (P = VI)</h2>
    <p class="mt-2 text-slate-600">Power in an electrical circuit is the rate at which energy is consumed or delivered. The basic formula P = VI (watts = volts &times; amps) can be combined with Ohm\u2019s Law to produce two additional forms: P = I\u00b2R and P = V\u00b2/R. These are especially useful because you often have voltage or current but not both.</p>
    <p class="mt-3 text-slate-600">For example, a 10 \u03a9 resistor carrying 2 A dissipates P = 2\u00b2 &times; 10 = 40 W. If the same resistor has 20 V across it, P = 20\u00b2 &divide; 10 = 40 W. Both formulas give the same result, confirming consistency.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Practical applications</h2>
    <p class="mt-2 text-slate-600">Ohm\u2019s Law is used everywhere in electrical engineering: sizing wire gauges for safe current capacity, choosing resistor values in voltage dividers, calculating power supply requirements, designing PCB trace widths, and troubleshooting faulty equipment. Every multimeter, power supply, and circuit simulator applies Ohm\u2019s Law internally.</p>
    <p class="mt-3 text-slate-600">In the home, Ohm\u2019s Law explains why a hair dryer draws more current than a phone charger (lower resistance heating element), why long extension cords cause voltage drops, and why fuses blow when too many appliances run on one circuit.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Common mistakes</h2>
    <p class="mt-2 text-slate-600">The most frequent errors include mixing units without converting (e.g., using mA with V to get k\u03a9 instead of \u03a9), forgetting that AC circuits with reactive components need impedance and phase angles, and assuming a component\u2019s cold resistance is the same as its hot operating resistance. Light bulbs and heating elements change resistance dramatically when hot.</p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function fmt(n) { return parseFloat(n.toFixed(4)).toString(); }
    let updating = false;

    function update(source) {
      if (updating) return;
      updating = true;

      const v = parseFloat(el('v').value);
      const i = parseFloat(el('i').value);
      const r = parseFloat(el('r').value);
      const p = parseFloat(el('p').value);

      const hasV = !isNaN(v);
      const hasI = !isNaN(i);
      const hasR = !isNaN(r);
      const hasP = !isNaN(p);

      const count = hasV + hasI + hasR + hasP;

      if (count < 2) {
        ['r-v','r-i','r-r','r-p'].forEach(id => el(id).textContent = '\u2014');
        updating = false;
        return;
      }

      let newV = NaN, newI = NaN, newR = NaN, newP = NaN;

      if (hasV && hasI) { newV = v; newI = i; newR = v / i; newP = v * i; }
      else if (hasV && hasR) { newV = v; newR = r; newI = v / r; newP = v * v / r; }
      else if (hasV && hasP) { newV = v; newP = p; newI = p / v; newR = v * v / p; }
      else if (hasI && hasR) { newR = r; newI = i; newV = i * r; newP = i * i * r; }
      else if (hasI && hasP) { newI = i; newP = p; newV = p / i; newR = p / (i * i); }
      else if (hasR && hasP) { newR = r; newP = p; newV = Math.sqrt(p * r); newI = Math.sqrt(p / r); }
      else {
        updating = false;
        return;
      }

      if (source !== 'v' && !isNaN(newV)) el('v').value = fmt(newV);
      if (source !== 'i' && !isNaN(newI)) el('i').value = fmt(newI);
      if (source !== 'r' && !isNaN(newR)) el('r').value = fmt(newR);
      if (source !== 'p' && !isNaN(newP)) el('p').value = fmt(newP);

      el('r-v').textContent = isNaN(newV) ? '\u2014' : fmt(newV) + ' V';
      el('r-i').textContent = isNaN(newI) ? '\u2014' : fmt(newI) + ' A';
      el('r-r').textContent = isNaN(newR) ? '\u2014' : fmt(newR) + ' \u03a9';
      el('r-p').textContent = isNaN(newP) ? '\u2014' : fmt(newP) + ' W';

      updating = false;
    }

    ['v','i','r','p'].forEach(id => el(id).addEventListener('input', () => update(id)));
  </script>
</ToolLayout>
