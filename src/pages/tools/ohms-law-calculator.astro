---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Ohm's Law Calculator";
const description = "Ohm's law calculator. Solve V=IR, plus all three power formulas, for voltage, current, resistance, or power, with worked examples.";
const intro = "Enter any two of voltage, current, resistance, or power to solve for the rest using Ohm's Law V=IR and the power formulas. Two 3D diagrams compare a low-resistance and high-resistance circuit at the same voltage, and charts show how current and power respond to resistance.";
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: "What is Ohm's law?", a: "Ohm's law states that voltage (V) equals current (I) multiplied by resistance (R): V = I × R. It describes the linear relationship between voltage, current, and resistance for ohmic materials." },
  { q: 'What units should I use?', a: 'Enter volts (V) for voltage, amps (A) for current, ohms (Ω) for resistance, and watts (W) for power. The calculator handles consistent SI units throughout.' },
  { q: 'Can I calculate power too?', a: 'Yes — using P = V×I, P = I²×R, or P = V²/R, depending on which two values you already know. All three formulas are algebraically equivalent.' },
  { q: 'What happens for AC circuits?', a: "Ohm's law for AC circuits generalizes to V = I×Z, where Z is impedance (a complex quantity including resistance and reactance from capacitors and inductors). This calculator handles DC or purely resistive AC circuits only." },
  { q: 'What are ohmic vs non-ohmic materials?', a: "Ohmic materials (most resistors, wires) have constant resistance regardless of voltage. Non-ohmic materials (diodes, transistors, light bulbs) have resistance that changes with voltage, temperature, or current — Ohm's law still applies at each instantaneous operating point, but not with one fixed R value." },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: "How to use the Ohm's Law Calculator",
  description: "Solve for voltage, current, resistance, or power using Ohm's law V=IR and the power formulas.",
  steps: [
    { name: 'Enter any two values', text: 'Provide any two of voltage, current, resistance, or power.' },
    { name: 'Read all four results', text: 'The calculator solves for the other two values instantly, cross-checked for consistency.' },
    { name: 'Verify with the power formulas', text: 'Check the result against P=VI, P=I²R, and P=V²/R — all three should agree.' },
  ],
};

const formulas = [
  { expr: 'V = I × R', note: "Ohm's law — the core relationship between voltage, current, and resistance" },
  { expr: 'I = V / R', note: 'rearranged to solve for current' },
  { expr: 'R = V / I', note: 'rearranged to solve for resistance' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a simple resistive circuit', tone: 'slate',
    given: 'A circuit has a 12 V battery and draws 2 A of current. Find the resistance and power.',
    rows: [
      { label: 'Resistance:', value: 'R = V / I = 12 / 2 = 6 Ω' },
      { label: 'Power:', value: 'P = V × I = 12 × 2 = 24 W' },
      { label: 'Verify with I²R:', value: 'P = 2² × 6 = 24 W ✓', full: true },
    ],
    note: 'The resistance and power both come directly from the same two known values, and the power checks out identically using a different formula — confirming the result.',
  },
  {
    title: 'Worked example 2 — increasing resistance at fixed voltage', tone: 'amber',
    given: 'The same 12 V battery is now connected to a 24 Ω resistor instead (double the resistance).',
    rows: [
      { label: 'Current:', value: 'I = V / R = 12 / 24 = 0.5 A (half the original current)' },
      { label: 'Power:', value: 'P = V × I = 12 × 0.5 = 6 W (a quarter of the original power)', full: true },
    ],
    note: 'Doubling resistance at fixed voltage halves the current but quarters the power — because P=V²/R has resistance in the denominator while V stays fixed and squared.',
  },
];

const comparison = {
  heading: 'Current and power at fixed 12V, across resistances',
  note: 'Higher resistance always means lower current at the same voltage — and power falls off even faster, since P=V²/R.',
  headers: [{ label: 'Resistance' }, { label: 'Current (I=V/R)' }, { label: 'Power (P=V²/R)' }],
  rows: [
    ['3 Ω', '4.00 A', '48.0 W'],
    ['6 Ω ★', '2.00 A', '24.0 W'],
    ['12 Ω', '1.00 A', '12.0 W'],
    ['24 Ω', '0.50 A', '6.0 W'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Doubling resistance from 6Ω to 12Ω halves both the current and the power — but going from 6Ω to 24Ω (4×) cuts power to a quarter, not an eighth, since power depends on 1/R, not 1/R².',
};

const realWorld = [
  { emoji: '🔌', title: 'Circuit design', body: "Determining correct resistor values, wire gauges, and component ratings for a circuit relies directly on Ohm's law — it's the foundation of essentially all circuit design." },
  { emoji: '🔧', title: 'Troubleshooting electrical faults', body: "When a circuit fails, measuring voltage and current and comparing them against Ohm's law helps pinpoint whether the problem is an open connection, a short circuit, or a failed component." },
  { emoji: '🎓', title: 'Electronics education', body: "Students learning electronics almost always start with Ohm's law — this calculator helps verify manual calculations and builds intuition for how V, I, R, and P all relate." },
  { emoji: '⚡', title: 'Power dissipation safety checks', body: "Engineers use Ohm's law and the power formulas to compute power dissipation in resistors and components, ensuring they stay safely within their rated limits." },
];

const misconceptions = [
  { claim: '"Ohm\'s law applies to every electrical component."', truth: "Ohm's law strictly applies to ohmic materials with constant resistance — diodes, transistors, and light bulbs are non-ohmic, meaning their resistance changes with voltage or current, so a single fixed R value doesn't describe them across all conditions." },
  { claim: '"Doubling voltage always doubles power."', truth: 'It depends on what stays fixed — at constant resistance, P=V²/R means doubling voltage actually quadruples power, since voltage is squared in that particular form of the equation.' },
  { claim: '"Higher resistance always means a more dangerous circuit."', truth: "The opposite is often true for a fixed voltage — higher resistance reduces both current and power, generally making a circuit safer, not more dangerous. Very low resistance at high voltage is what typically creates dangerous, high-current conditions." },
  { claim: '"Voltmeters and ammeters can be used interchangeably."', truth: 'They must be connected differently: a voltmeter is connected in parallel across a component (and should have very high internal resistance), while an ammeter is connected in series in the current path (and should have very low resistance) — using the wrong mode can damage the meter or give misleading readings.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — Chapter 9, "Current and Resistance" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/9-3-model-of-conduction-in-metals" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 26, Current and Resistance.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 27, Current and Resistance.' },
];
const sourcesNote = "V=IR, P=VI=I²R=V²/R. This calculator assumes DC or purely resistive AC circuits. Results are rounded for display.";

const howToUse = [
  { title: 'Enter any two values', body: 'Provide voltage, current, resistance, or power — the other two fill in automatically.' },
  { title: 'Read all four results', body: 'All four electrical quantities update instantly, cross-checked against each other.' },
  { title: 'Watch for errors', body: 'Zero values that would require division by zero are caught and explained — try a different pair of values.' },
];

const related = [
  { href: '/tools/power-calculator', emoji: '⚡', title: 'Power Calculator', desc: 'P=VI, P=I²R, P=V²/R — solve for any electrical variable.' },
  { href: '/tools/series-resistor-calculator', emoji: '🔌', title: 'Series Resistor Calculator', desc: 'R_total = R1 + R2 + ... plus current and voltage-divider drops.' },
  { href: '/tools/parallel-resistor-calculator', emoji: '🔋', title: 'Parallel Resistor Calculator', desc: 'Total resistance and branch currents for parallel resistors.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="Ohm's law describes a simple, linear proportionality — for an ohmic material, voltage and current rise and fall together in direct proportion, with resistance acting as the fixed conversion factor between them."
  howIntro="V=IR is an empirical law (not derived from more fundamental principles) that holds precisely for ohmic materials across a wide range of voltages and currents — doubling the voltage across a fixed resistor exactly doubles the current through it. Combining V=IR with the definition of power P=VI lets you substitute out either V or I, producing the equivalent forms P=I²R and P=V²/R, each convenient depending on which two quantities are already known."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Ohm's law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Enter any two values, leave the rest blank.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Voltage (V)</span>
        <input id="v" type="number" step="any" placeholder="Volts" value="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current (I)</span>
        <input id="i" type="number" step="any" placeholder="Amps" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Resistance (R)</span>
        <input id="r" type="number" step="any" placeholder="Ohms" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Power (W)</span>
        <input id="p" type="number" step="any" placeholder="Watts" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="ohms-error" class="mt-3 hidden text-center text-sm font-semibold text-red-500" role="alert"></div>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Low vs high resistance at fixed voltage</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-low" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low resistance (thick resistor)</h3>
          <p class="mt-1 text-sm text-slate-600">A short, thick resistive element lets more current flow at the same voltage — high current, high power.</p>
        </div>
        <div>
          <div id="diag-high" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High resistance (thin resistor)</h3>
          <p class="mt-1 text-sm text-slate-600">A long, thin resistive element restricts current flow at the same voltage — low current, low power.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Ohm's law graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Current vs resistance (fixed V=12V) — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ir"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Power vs resistance (fixed V=12V) — falls off even faster</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pr"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator (preserves original two-of-four solve logic) ----
      const inputs = ['v', 'i', 'r', 'p'].map(el);
      const errorEl = el('ohms-error');
      function compute() {
        const v = parseFloat(el('v').value);
        const i = parseFloat(el('i').value);
        const r = parseFloat(el('r').value);
        const p = parseFloat(el('p').value);
        const filled = [v, i, r, p].map((x) => !isNaN(x));
        const count = filled.filter(Boolean).length;
        errorEl.classList.add('hidden');
        if (count < 2) return;
        let results = [NaN, NaN, NaN, NaN];
        let error = '';
        if (filled[0] && filled[1]) {
          if (i === 0) error = 'Cannot divide by zero (I = 0)';
          else { results[2] = v / i; results[3] = v * i; }
        } else if (filled[0] && filled[2]) {
          if (r === 0) error = 'Cannot divide by zero (R = 0)';
          else { results[1] = v / r; results[3] = (v * v) / r; }
        } else if (filled[0] && filled[3]) {
          if (v === 0) error = 'Cannot divide by zero (V = 0)';
          else { results[1] = p / v; results[2] = (v * v) / p; }
        } else if (filled[1] && filled[2]) {
          results[0] = i * r; results[3] = i * i * r;
        } else if (filled[1] && filled[3]) {
          if (i === 0) error = 'Cannot divide by zero (I = 0)';
          else { results[0] = p / i; results[2] = p / (i * i); }
        } else if (filled[2] && filled[3]) {
          if (r === 0) error = 'Cannot divide by zero (R = 0)';
          else { results[0] = Math.sqrt(p * r); results[1] = Math.sqrt(p / r); }
        }
        if (error) { errorEl.textContent = error; errorEl.classList.remove('hidden'); }
        const labels = ['v', 'i', 'r', 'p'];
        results.forEach((val, idx) => {
          const inp = el(labels[idx]);
          if (!isNaN(val) && !filled[idx] && inp !== document.activeElement) inp.value = parseFloat(val.toPrecision(6));
        });
      }
      inputs.forEach((inp) => inp.addEventListener('input', compute));
      inputs.forEach((inp) => inp.addEventListener('focus', function () {
        if (this.dataset.computed) { this.value = ''; delete this.dataset.computed; }
      }));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsR = [], dataI = [], dataP = [];
        for (let r = 1; r <= 30; r += 2) { labelsR.push(r); dataI.push(+(12 / r).toFixed(3)); dataP.push(+((12 * 12) / r).toFixed(2)); }
        charts.ir = new Chart(el('chart-ir'), {
          type: 'line',
          data: { labels: labelsR, datasets: [{ label: 'I (A)', data: dataI, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Resistance (Ω)' } }, y: { title: { display: true, text: 'Current (A)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.pr = new Chart(el('chart-pr'), {
          type: 'line',
          data: { labels: labelsR, datasets: [{ label: 'P (W)', data: dataP, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Resistance (Ω)' } }, y: { title: { display: true, text: 'Power (W)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function resistorScene(container, length, radius, color) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const res = new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, length, 20), new THREE.MeshStandardMaterial({ color, roughness: 0.5 }));
        res.rotation.z = Math.PI / 2;
        s.scene.add(res);
        const wireMat = new THREE.LineBasicMaterial({ color: 0x94a3b8 });
        s.scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-length / 2 - 2, 0, 0), new THREE.Vector3(-length / 2, 0, 0)]), wireMat));
        s.scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(length / 2, 0, 0), new THREE.Vector3(length / 2 + 2, 0, 0)]), wireMat));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() { const c = el('diag-low'); if (!c) throw new Error('no container'); diagLow = resistorScene(c, 1.5, 0.6, 0x6366f1); }
      function initDiagHigh() { const c = el('diag-high'); if (!c) throw new Error('no container'); diagHigh = resistorScene(c, 3.5, 0.25, 0xef4444); }

      function boot() {
        try { compute(); } catch (e) { console.error('[ohms-law] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[ohms-law] charts failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[ohms-law] low diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[ohms-law] high diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
