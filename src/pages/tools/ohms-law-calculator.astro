---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = "Ohm's Law Calculator";
const description = 'Calculate voltage, current, resistance, or power using Ohm\'s law. Enter any two values to solve for the others instantly.';
const intro = 'Solve for V, I, R, or P given any two values.';
const category = { id: 'engineering', name: 'Engineering' };
const faqs = [
  { q: 'What is Ohm\'s law?', a: 'Ohm\'s law states that voltage (V) equals current (I) multiplied by resistance (R): V = I × R.' },
  { q: 'What units should I use?', a: 'Enter volts (V), amps (A), ohms (Ω), and watts (W). The calculator handles consistent units.' },
  { q: 'Can I calculate power too?', a: 'Yes — using P = V × I, P = I² × R, or P = V² / R, depending on which values you provide.' },
  { q: 'What if I enter zero?', a: 'Entering zero for certain fields will show "Cannot divide by zero" — fill in a different pair.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values, leave the rest blank</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Voltage (V)</span>
        <input id="v" type="number" step="any" placeholder="Volts" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current (I)</span>
        <input id="i" type="number" step="any" placeholder="Amps" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Resistance (R)</span>
        <input id="r" type="number" step="any" placeholder="Ohms" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Power (W)</span>
        <input id="p" type="number" step="any" placeholder="Watts" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="ohms-error" class="mt-3 text-center text-sm font-semibold text-red-500 hidden"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="320" viewBox="0 0 800 320" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ohms-title ohms-desc">
      <title id="ohms-title">Ohm's law triangle and power formulas</title>
      <desc id="ohms-desc">Diagram showing the Ohm's law triangle with V at the top and I × R at the bottom, plus power formula relationships</desc>
      <g transform="translate(40,10)">
        <polygon points="200,30 310,180 90,180" fill="#eef2ff" stroke="#6366f1" stroke-width="2.5"/>
        <text x="200" y="95" text-anchor="middle" fill="#4338ca" font-size="28" font-weight="bold">V</text>
        <text x="130" y="145" text-anchor="middle" fill="#6366f1" font-size="20" font-weight="bold">I</text>
        <text x="270" y="145" text-anchor="middle" fill="#6366f1" font-size="20" font-weight="bold">R</text>
        <line x1="200" y1="115" x2="200" y2="130" stroke="#c7d2fe" stroke-width="1.5"/>
        <text x="200" y="212" text-anchor="middle" fill="#64748b" font-size="13">&times;</text>
        <text x="143" y="200" text-anchor="end" fill="#94a3b8" font-size="11">V = I &times; R</text>
        <text x="257" y="200" text-anchor="start" fill="#94a3b8" font-size="11">I = V / R</text>
        <text x="200" y="230" text-anchor="middle" fill="#94a3b8" font-size="11">R = V / I</text>

        <line x1="370" y1="30" x2="730" y2="30" stroke="#e2e8f0" stroke-width="1.5"/>
        <rect x="370" y="55" width="160" height="95" rx="12" fill="#fef3c7" stroke="#f59e0b" stroke-width="1.5"/>
        <text x="450" y="80" text-anchor="middle" fill="#d97706" font-size="14" font-weight="bold">P = V &times; I</text>
        <text x="450" y="100" text-anchor="middle" fill="#a16207" font-size="12">Power from V and I</text>
        <line x1="450" y1="108" x2="450" y2="115" stroke="#fde68a" stroke-width="1"/>

        <rect x="370" y="158" width="160" height="95" rx="12" fill="#ecfdf5" stroke="#10b981" stroke-width="1.5"/>
        <text x="450" y="183" text-anchor="middle" fill="#059669" font-size="14" font-weight="bold">P = I&sup2; &times; R</text>
        <text x="450" y="203" text-anchor="middle" fill="#047857" font-size="12">Power from I and R</text>

        <rect x="555" y="55" width="160" height="95" rx="12" fill="#fdf2f8" stroke="#ec4899" stroke-width="1.5"/>
        <text x="635" y="80" text-anchor="middle" fill="#db2777" font-size="14" font-weight="bold">P = V&sup2; / R</text>
        <text x="635" y="100" text-anchor="middle" fill="#be185d" font-size="12">Power from V and R</text>

        <line x1="370" y1="268" x2="730" y2="268" stroke="#e2e8f0" stroke-width="1.5"/>
        <text x="550" y="295" text-anchor="middle" fill="#64748b" font-size="13">Six formulas cover every pair of known values</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Ohm's law triangle (left) and power formula relationships (right)</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Ohm's law formulas</h2>
    <p class="mt-2 text-slate-600">Ohm's law describes the relationship between voltage, current, and resistance in an electrical circuit. The fundamental equations are:</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <div class="font-mono text-lg font-bold text-indigo-700">V = I &times; R</div>
        <div class="mt-1 text-xs text-slate-500">Voltage = Current &times; Resistance</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <div class="font-mono text-lg font-bold text-indigo-700">I = V / R</div>
        <div class="mt-1 text-xs text-slate-500">Current = Voltage / Resistance</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <div class="font-mono text-lg font-bold text-indigo-700">R = V / I</div>
        <div class="mt-1 text-xs text-slate-500">Resistance = Voltage / Current</div>
      </div>
    </div>
    <p class="mt-4 text-slate-600">Power formulas derived from Ohm's law let you calculate electrical power when you know any two of the four quantities:</p>
    <div class="mt-3 grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <div class="font-mono text-lg font-bold text-emerald-700">P = V &times; I</div>
        <div class="mt-1 text-xs text-slate-500">Power = Voltage &times; Current</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <div class="font-mono text-lg font-bold text-emerald-700">P = I&sup2; &times; R</div>
        <div class="mt-1 text-xs text-slate-500">Power = Current&sup2; &times; Resistance</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <div class="font-mono text-lg font-bold text-emerald-700">P = V&sup2; / R</div>
        <div class="mt-1 text-xs text-slate-500">Power = Voltage&sup2; / Resistance</div>
      </div>
    </div>

    <h3 class="mt-8 text-lg font-bold text-slate-900">Worked example</h3>
    <p class="mt-2 text-slate-600">A circuit has a 12 V battery and draws 2 A of current. What are the resistance and power?</p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <div class="grid gap-2 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Given:</span> <span class="text-slate-600">V = 12 V, I = 2 A</span></div>
        <div><span class="font-medium text-slate-700">Resistance:</span> <span class="text-slate-600">R = V / I = 12 / 2 = 6 &Omega;</span></div>
        <div><span class="font-medium text-slate-700">Power:</span> <span class="text-slate-600">P = V &times; I = 12 &times; 2 = 24 W</span></div>
        <div><span class="font-medium text-slate-700">Verify:</span> <span class="text-slate-600">P = I&sup2;R = 2&sup2; &times; 6 = 24 W &#x2713;</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F50C;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Circuit Design</h3>
      <p class="mt-1 text-sm text-slate-600">Determine the correct resistor values, wire gauges, and component ratings for your circuits. Ohm's law is the foundation of all modern circuit design.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F527;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Troubleshooting</h3>
      <p class="mt-1 text-sm text-slate-600">When a circuit fails, measuring voltage and current helps you pinpoint whether the problem is an open connection, short circuit, or failed component.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Electronics Education</h3>
      <p class="mt-1 text-sm text-slate-600">Students learning electronics start with Ohm's law. This calculator helps verify manual calculations and builds intuition for how V, I, R, and P relate.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x26A1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Power Analysis</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly compute power dissipation in resistors, LEDs, and other components to ensure they stay within safe operating limits.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for using Ohm's law</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">AC circuits use impedance, not just resistance</h3>
        <p class="mt-1 text-sm text-slate-600">In DC circuits, resistance alone determines the relationship between voltage and current. In AC circuits, the opposition to current flow is called impedance (Z), which includes resistance (R) and reactance (X) from capacitors and inductors. Ohm's law for AC is V = I &times; Z, where Z is a complex quantity. This calculator handles DC or purely resistive AC circuits only.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Power factor matters in AC</h3>
        <p class="mt-1 text-sm text-slate-600">In AC circuits, the real power (P) dissipated is V &times; I &times; cos(&phi;), where cos(&phi;) is the power factor. Reactive components cause the current and voltage waveforms to shift out of phase, reducing the effective power delivered to the load. For resistive loads like heaters and incandescent bulbs, the power factor is 1, so P = V &times; I applies directly.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use consistent units</h3>
        <p class="mt-1 text-sm text-slate-600">Volts, amperes, ohms, and watts form a consistent unit system — no conversion factors needed. If you have millivolts or milliamps, convert to base units first (e.g., 100 mA = 0.1 A, 5 kV = 5000 V). Using mixed prefixes (e.g., volts with milliamps) will give incorrect results.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Power ratings protect components</h3>
        <p class="mt-1 text-sm text-slate-600">Every resistor has a maximum power rating (typically 1/4 W, 1/2 W, or 1 W for through-hole parts). Use P = I&sup2;R to check that the power dissipated stays well below the component's rating — a safety margin of 2x is standard practice. An undersized resistor can overheat and fail.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Understanding Ohm's law</h2>
    <p class="mt-2 text-slate-600">Ohm's law is named after German physicist Georg Simon Ohm, who first published his findings in 1827. The law states that the current through a conductor between two points is directly proportional to the voltage across the two points and inversely proportional to the resistance between them. This relationship is linear for ohmic materials — conductors and resistors that obey Ohm's law across a wide range of voltages and currents.</p>

    <h3 class="mt-6 font-semibold text-slate-900">The water analogy</h3>
    <p class="mt-1 text-slate-600">A common way to understand Ohm's law is the water pipe analogy. Voltage corresponds to water pressure (pushing force), current corresponds to flow rate (how much water moves through the pipe), and resistance corresponds to pipe narrowness or obstruction. A higher voltage is like higher pressure pushing more water through. A higher resistance is like a narrower pipe restricting flow. Increasing resistance while keeping voltage constant reduces current, just as a narrower pipe reduces flow at the same pressure.</p>

    <h3 class="mt-6 font-semibold text-slate-900">Ohmic vs non-ohmic materials</h3>
    <p class="mt-1 text-slate-600">Not all components obey Ohm's law. Diodes, transistors, and incandescent bulbs are non-ohmic — their resistance changes with voltage, temperature, or operating conditions. For example, an LED's current increases exponentially with voltage, not linearly. Ohm's law still applies at each operating point (instantaneous V/I gives the dynamic resistance), but you cannot use a single fixed resistance value across different voltages. This calculator assumes ideal ohmic behavior and is best suited for resistors and purely resistive circuits.</p>

    <h3 class="mt-6 font-semibold text-slate-900">Series and parallel circuits</h3>
    <p class="mt-1 text-slate-600">In series circuits, current is the same through all components and voltages add up: V<sub>total</sub> = V<sub>1</sub> + V<sub>2</sub> + V<sub>3</sub>. The total resistance is the sum of individual resistances: R<sub>total</sub> = R<sub>1</sub> + R<sub>2</sub> + R<sub>3</sub>. In parallel circuits, voltage is the same across all branches and currents add up: I<sub>total</sub> = I<sub>1</sub> + I<sub>2</sub> + I<sub>3</sub>. The total resistance in parallel is given by 1/R<sub>total</sub> = 1/R<sub>1</sub> + 1/R<sub>2</sub> + 1/R<sub>3</sub>. Ohm's law applies to each individual component and to the equivalent circuit as a whole.</p>

    <h3 class="mt-6 font-semibold text-slate-900">Practical measurement considerations</h3>
    <p class="mt-1 text-slate-600">When measuring voltage and current in real circuits, remember that voltmeters are connected in parallel (across a component) and ammeters in series (in the path of current flow). A voltmeter should have very high internal resistance to avoid drawing current that would alter the circuit's behaviour. An ammeter should have very low resistance to avoid adding a voltage drop. Multimeters combine both functions and typically include separate jacks for voltage/resistance and current measurements. Using the wrong mode can damage the meter or give misleading readings.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Ohm's Law Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter any two values</h3>
        <p class="mt-1 text-sm text-slate-600">Type values for any two of the four fields: voltage (V), current (I), resistance (R), or power (W). Leave the other two blank.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Results update live</h3>
        <p class="mt-1 text-sm text-slate-600">The remaining fields fill in automatically as you type. No button needed — the calculation runs on every keystroke.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Watch for errors</h3>
        <p class="mt-1 text-sm text-slate-600">If you enter zero for a field that would require division by zero, the calculator shows a warning. Enter a different pair of values instead.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/resistor-color-code-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F308;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Resistor Color Code Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Decode 4/5/6 band resistor colours to find resistance and tolerance.</p>
      </a>
      <a href="/tools/capacitor-charge-time-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F50B;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Capacitor Charge Time Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate RC time constant and capacitor charge/discharge curves.</p>
      </a>
      <a href="/tools/awg-to-mm-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x26A1;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">AWG to mm Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Convert American Wire Gauge to diameter and cross-sectional area.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const inputs = ['v', 'i', 'r', 'p'].map(el);
    const errorEl = el('ohms-error');

    function compute() {
      const v = parseFloat(el('v').value);
      const i = parseFloat(el('i').value);
      const r = parseFloat(el('r').value);
      const p = parseFloat(el('p').value);

      const filled = [v, i, r, p].map(x => !isNaN(x));
      const count = filled.filter(Boolean).length;

      errorEl.classList.add('hidden');

      if (count < 2) {
        inputs.forEach(inp => { if (inp !== document.activeElement) inp.value = inp.value; });
        return;
      }

      let results = [NaN, NaN, NaN, NaN];
      let error = '';

      if (filled[0] && filled[1]) {
        if (i === 0) error = 'Cannot divide by zero (I = 0)';
        else { results[2] = v / i; results[3] = v * i; }
      } else if (filled[0] && filled[2]) {
        if (r === 0) error = 'Cannot divide by zero (R = 0)';
        else { results[1] = v / r; results[3] = (v * v) / r; }
      } else if (filled[0] && filled[3]) {
        if (v === 0) error = 'Cannot divide by zero (V = 0)';
        else { results[1] = p / v; results[2] = (v * v) / p; }
      } else if (filled[1] && filled[2]) {
        results[0] = i * r;
        results[3] = i * i * r;
      } else if (filled[1] && filled[3]) {
        if (i === 0) error = 'Cannot divide by zero (I = 0)';
        else { results[0] = p / i; results[2] = p / (i * i); }
      } else if (filled[2] && filled[3]) {
        if (r === 0) error = 'Cannot divide by zero (R = 0)';
        else { results[0] = Math.sqrt(p * r); results[1] = Math.sqrt(p / r); }
      }

      if (error) {
        errorEl.textContent = error;
        errorEl.classList.remove('hidden');
      }

      const labels = ['v', 'i', 'r', 'p'];
      results.forEach((val, idx) => {
        const inp = el(labels[idx]);
        if (!isNaN(val) && !filled[idx] && inp !== document.activeElement) {
          inp.value = parseFloat(val.toPrecision(6));
        }
      });
    }

    inputs.forEach(inp => inp.addEventListener('input', compute));
    inputs.forEach(inp => inp.addEventListener('focus', function() {
      if (this.dataset.computed) {
        this.value = '';
        delete this.dataset.computed;
      }
    }));
  </script>
</ToolLayout>
