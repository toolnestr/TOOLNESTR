---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Resistor Color Code Calculator';
const description = 'Free resistor color code calculator. Decode 4-band, 5-band and 6-band resistors to find resistance, tolerance and temperature coefficient.';
const intro = 'Select the number of bands and pick colors to decode any through-hole resistor\u2019s value, tolerance and temperature coefficient instantly.';
const category = { id: 'engineering', name: 'Electrical Engineering' };
const faqs = [
  { q: 'How do I read a 4-band resistor color code?', a: 'The first two bands represent the first two digits of the resistance value. The third band is the multiplier (number of zeros to add). The fourth band is the tolerance: gold = \u00b15%, silver = \u00b110%, no band = \u00b120%.' },
  { q: 'What is the difference between 4-band, 5-band and 6-band resistors?', a: '4-band resistors have 2 digit bands, a multiplier and tolerance. 5-band resistors add a third digit band for higher precision. 6-band resistors add a sixth band for the temperature coefficient (TCR).' },
  { q: 'How do I remember the resistor color code?', a: 'Use the mnemonic: Black (0), Brown (1), Red (2), Orange (3), Yellow (4), Green (5), Blue (6), Violet (7), Grey (8), White (9). A popular phrase is \u201cBad Boys Run Over Yellow Grass But Violet Grey Wins.\u201d' },
  { q: 'What does the tolerance band mean?', a: 'Tolerance indicates how much the actual resistance can vary from the marked value. Gold = \u00b15%, Silver = \u00b110%, Brown = \u00b11%, Red = \u00b12%, Green = \u00b10.5%, Blue = \u00b10.25%.' },
  { q: 'Which end of the resistor do I read from?', a: 'Read from the end closest to the first band, with the tolerance band (gold or silver) on the right. If the resistor is 4-band, the tolerance band is separated by a larger gap from the other bands.' },
  { q: 'What is the temperature coefficient on a 6-band resistor?', a: 'The sixth band indicates the Temperature Coefficient of Resistance (TCR) in parts per million per degree Celsius (ppm/\u00b0C). Common values: Brown = 100 ppm/\u00b0C, Red = 50 ppm/\u00b0C, Orange = 15 ppm/\u00b0C.' },
  { q: 'What resistor values are standard (E12 series)?', a: 'The E12 series uses 12 values per decade: 10, 12, 15, 18, 22, 27, 33, 39, 47, 56, 68, 82. Multiply these by powers of 10 to get all standard values (e.g., 100, 120, 150, 180, 220 \u03a9, etc.).' },
  { q: 'Can I use this calculator for SMD resistors?', a: 'No \u2014 SMD (surface-mount) resistors use a numeric code (e.g., 472 = 4.7 k\u03a9) rather than color bands. This calculator is for through-hole resistors only.' },
  { q: 'What is the zero-ohm resistor?', a: 'A zero-ohm resistor has a single black band. It looks like a resistor but acts as a jumper wire. It is used to simplify PCB manufacturing by allowing a single pick-and-place machine to handle both resistors and jumpers.' },
  { q: 'Why are some resistor tolerances tighter than others?', a: 'Precision resistors (\u00b11% or better) are made with tighter manufacturing controls and cost more. They are used in precision circuits like voltage references, measurement equipment, and audio crossovers where exact values matter.' },
];

const colors = [
  { name: 'Black', value: 0, multiplier: 1, tolerance: '', tcr: '' },
  { name: 'Brown', value: 1, multiplier: 10, tolerance: '\u00b11%', tcr: '100 ppm' },
  { name: 'Red', value: 2, multiplier: 100, tolerance: '\u00b12%', tcr: '50 ppm' },
  { name: 'Orange', value: 3, multiplier: 1000, tolerance: '', tcr: '15 ppm' },
  { name: 'Yellow', value: 4, multiplier: 10000, tolerance: '', tcr: '25 ppm' },
  { name: 'Green', value: 5, multiplier: 100000, tolerance: '\u00b10.5%', tcr: '20 ppm' },
  { name: 'Blue', value: 6, multiplier: 1000000, tolerance: '\u00b10.25%', tcr: '10 ppm' },
  { name: 'Violet', value: 7, multiplier: 10000000, tolerance: '\u00b10.10%', tcr: '5 ppm' },
  { name: 'Grey', value: 8, multiplier: 100000000, tolerance: '\u00b10.05%', tcr: '1 ppm' },
  { name: 'White', value: 9, multiplier: 1000000000, tolerance: '', tcr: '' },
  { name: 'Gold', value: -1, multiplier: 0.1, tolerance: '\u00b15%', tcr: '' },
  { name: 'Silver', value: -1, multiplier: 0.01, tolerance: '\u00b110%', tcr: '' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700">Number of bands</label>
      <div class="mt-1 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
        <button id="b-4" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">4 bands</button>
        <button id="b-5" class="flex-1 rounded-lg py-2 text-slate-500">5 bands</button>
        <button id="b-6" class="flex-1 rounded-lg py-2 text-slate-500">6 bands</button>
      </div>
    </div>

    <div id="band-selectors" class="mt-3 grid gap-3">
      <div class="grid grid-cols-6 gap-2" id="band-row-1">
        <label class="block text-center"><span class="text-xs font-medium text-slate-500">Band 1</span>
          <select id="band1" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400">
            {colors.filter(c => c.value >= 0).map(c => <option value={c.value}>{c.name}</option>)}
          </select></label>
        <label class="block text-center"><span class="text-xs font-medium text-slate-500">Band 2</span>
          <select id="band2" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400">
            {colors.filter(c => c.value >= 0).map(c => <option value={c.value}>{c.name}</option>)}
          </select></label>
        <label class="block text-center" id="band3-wrap"><span class="text-xs font-medium text-slate-500">Band 3</span>
          <select id="band3" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400">
            {colors.filter(c => c.value >= 0).map(c => <option value={c.value}>{c.name}</option>)}
          </select></label>
        <label class="block text-center"><span class="text-xs font-medium text-slate-500">Multiplier</span>
          <select id="mult" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400">
            {colors.map(c => <option value={c.multiplier} data-color={c.name}>{c.name}</option>)}
          </select></label>
        <label class="block text-center"><span class="text-xs font-medium text-slate-500">Tolerance</span>
          <select id="tol" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400">
            {colors.filter(c => c.tolerance).map(c => <option value={c.tolerance}>{c.name} ({c.tolerance})</option>)}
          </select></label>
        <label class="block text-center" id="tcr-wrap"><span class="text-xs font-medium text-slate-500">TCR</span>
          <select id="tcr" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm outline-none focus:border-indigo-400">
            {colors.filter(c => c.tcr).map(c => <option value={c.tcr}>{c.name} ({c.tcr})</option>)}
          </select></label>
      </div>
    </div>

    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Resistance value</div>
      <div id="r-val" class="mt-1 text-2xl font-bold">\u2014</div>
      <div id="r-detail" class="mt-1 text-sm"></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common resistor values decade</h2>
    <p class="mt-2 text-slate-600">Resistor values follow standard decades based on the E-series. Here are the common values across the most used range.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">1 \u03a9 \u2013 10 \u03a9</span><span class="text-slate-400">Low-value precision</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:10%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">10 \u03a9 \u2013 100 \u03a9</span><span class="text-slate-400">Common for LEDs and biasing</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">100 \u03a9 \u2013 1 k\u03a9</span><span class="text-slate-400">Pull-up / pull-down resistors</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">1 k\u03a9 \u2013 10 k\u03a9</span><span class="text-slate-400">Voltage dividers, op-amp circuits</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">10 k\u03a9 \u2013 100 k\u03a9</span><span class="text-slate-400">Timing circuits, filters</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">100 k\u03a9 \u2013 1 M\u03a9</span><span class="text-slate-400">High-impedance circuits</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:25%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">1 M\u03a9 \u2013 10 M\u03a9</span><span class="text-slate-400">High-value, sensor biasing</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-purple-500" style="width:15%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDD0C</span>
      <h3 class="mt-2 font-semibold text-slate-900">Electronics Student</h3>
      <p class="mt-1 text-sm text-slate-600">Practice reading resistor color bands and verify your manual decoding against the calculator during lab work and exams.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDD27</span>
      <h3 class="mt-2 font-semibold text-slate-900">Repair Technician</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly identify unknown resistors in faulty equipment by matching their color bands to exact values during troubleshooting.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDD17</span>
      <h3 class="mt-2 font-semibold text-slate-900">Circuit Designer</h3>
      <p class="mt-1 text-sm text-slate-600">Select the correct resistor specifications for your BOM, ensuring the right tolerance and TCR for critical circuit paths.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDEE0\uFE0F</span>
      <h3 class="mt-2 font-semibold text-slate-900">Maker / Hobbyist</h3>
      <p class="mt-1 text-sm text-slate-600">Decode resistors from your parts bin without memorizing the color chart, and find the right value for your project.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Color</th><th class="p-3">Digit</th><th class="p-3">Multiplier</th><th class="p-3">Tolerance</th><th class="p-3">TCR (ppm/\u00b0C)</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-black align-middle"></span> Black</td><td class="p-3">0</td><td class="p-3">\u00d71 \u03a9</td><td class="p-3">\u2014</td><td class="p-3">\u2014</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-amber-800 align-middle"></span> Brown</td><td class="p-3">1</td><td class="p-3">\u00d710 \u03a9</td><td class="p-3">\u00b11%</td><td class="p-3">100</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-red-600 align-middle"></span> Red</td><td class="p-3">2</td><td class="p-3">\u00d7100 \u03a9</td><td class="p-3">\u00b12%</td><td class="p-3">50</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-orange-500 align-middle"></span> Orange</td><td class="p-3">3</td><td class="p-3">\u00d71 k\u03a9</td><td class="p-3">\u2014</td><td class="p-3">15</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-yellow-400 align-middle"></span> Yellow</td><td class="p-3">4</td><td class="p-3">\u00d710 k\u03a9</td><td class="p-3">\u2014</td><td class="p-3">25</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-green-600 align-middle"></span> Green</td><td class="p-3">5</td><td class="p-3">\u00d7100 k\u03a9</td><td class="p-3">\u00b10.5%</td><td class="p-3">20</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-blue-600 align-middle"></span> Blue</td><td class="p-3">6</td><td class="p-3">\u00d71 M\u03a9</td><td class="p-3">\u00b10.25%</td><td class="p-3">10</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-violet-700 align-middle"></span> Violet</td><td class="p-3">7</td><td class="p-3">\u00d710 M\u03a9</td><td class="p-3">\u00b10.10%</td><td class="p-3">5</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-gray-400 align-middle"></span> Grey</td><td class="p-3">8</td><td class="p-3">\u00d7100 M\u03a9</td><td class="p-3">\u00b10.05%</td><td class="p-3">1</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-white border align-middle"></span> White</td><td class="p-3">9</td><td class="p-3">\u00d71 G\u03a9</td><td class="p-3">\u2014</td><td class="p-3">\u2014</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-yellow-600 align-middle"></span> Gold</td><td class="p-3">\u2014</td><td class="p-3">\u00d70.1</td><td class="p-3">\u00b15%</td><td class="p-3">\u2014</td></tr>
        <tr><td class="p-3"><span class="inline-block h-4 w-4 rounded-full bg-gray-300 align-middle"></span> Silver</td><td class="p-3">\u2014</td><td class="p-3">\u00d70.01</td><td class="p-3">\u00b110%</td><td class="p-3">\u2014</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Resistor Color Code Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Count the bands</h3>
        <p class="mt-1 text-sm text-slate-600">Identify whether your resistor has 4, 5 or 6 color bands. Hold it so the tolerance band (gold/silver) is on the right side.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select the colors</h3>
        <p class="mt-1 text-sm text-slate-600">Pick the number of bands, then choose each color from the dropdown menus. The calculator shows the matching color visually.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the value</h3>
        <p class="mt-1 text-sm text-slate-600">The resistance value, tolerance and temperature coefficient (for 6-band) appear instantly in the highlighted result box.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for reading resistor color codes</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Hold the resistor with tolerance band on the right</h3>
        <p class="mt-1 text-sm text-slate-600">The tolerance band is usually gold or silver and spaced farther from the other bands. Orient it to the right so you read the digit bands from left to right.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Gold and silver are always tolerance or multiplier</h3>
        <p class="mt-1 text-sm text-slate-600">Gold and silver never appear as digit bands. On 4-band resistors, gold means \u00b15% tolerance and silver means \u00b110%. They can also be multipliers (0.1 for gold, 0.01 for silver).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use 5-band resistors for precision circuits</h3>
        <p class="mt-1 text-sm text-slate-600">5-band resistors with three digit bands offer higher precision than 4-band. Use them in voltage dividers, measurement circuits and audio applications where exact values matter.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Check with a multimeter</h3>
        <p class="mt-1 text-sm text-slate-600">When in doubt, measure the resistor with a multimeter. The color code can be hard to read on small resistors or when colors are faded, and the measured value confirms the coded value.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How resistor color codes work</h2>
    <p class="mt-2 text-slate-600">Resistor color codes were standardized in the early 20th century as a simple way to mark resistance values on small components. Each color corresponds to a digit from 0 to 9, with additional colors for multiplier, tolerance and temperature coefficient. The system is defined by the IEC 60062 standard and is universally used for through-hole resistors.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">4-band vs 5-band vs 6-band</h2>
    <p class="mt-2 text-slate-600"><strong>4-band resistors</strong> are the most common. The first two bands are digits, the third is the multiplier, and the fourth is tolerance. A resistor with brown-black-red-gold bands is 1 0 \u00d7 100 = 1000 \u03a9 (1 k\u03a9) at \u00b15%.</p>
    <p class="mt-3 text-slate-600"><strong>5-band resistors</strong> add a third digit for higher precision. The first three bands are digits, the fourth is the multiplier, and the fifth is tolerance. Brown-black-black-brown-brown = 1 0 0 \u00d7 10 = 1000 \u03a9 at \u00b11%.</p>
    <p class="mt-3 text-slate-600"><strong>6-band resistors</strong> include a sixth band indicating the Temperature Coefficient of Resistance (TCR) in ppm/\u00b0C. This tells you how much the resistance changes with temperature, which is critical in precision and temperature-sensitive circuits.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Reading order</h2>
    <p class="mt-2 text-slate-600">Always read from the end closest to the first band. The tolerance band is typically separate from the digit and multiplier bands by a slightly larger gap. When in doubt, measure the resistance with a multimeter to confirm the orientation. The calculator assumes the correct reading order based on the number of bands selected.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Common mistakes</h2>
    <p class="mt-2 text-slate-600">The most frequent errors include reading the resistor backward (starting from the tolerance band), confusing red and orange (similar hues in poor light), misinterpreting gold and silver as digit bands, and forgetting that black as a multiplier means \u00d71 (not \u00d70). Always use good lighting and a magnifying glass for small resistors.</p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const bands4 = ['band1','band2','mult','tol'];
    const bands5 = ['band1','band2','band3','mult','tol'];
    const bands6 = ['band1','band2','band3','mult','tol','tcr'];

    function setBands(n) {
      el('b-4').className = 'flex-1 rounded-lg py-2 ' + (n === 4 ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('b-5').className = 'flex-1 rounded-lg py-2 ' + (n === 5 ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('b-6').className = 'flex-1 rounded-lg py-2 ' + (n === 6 ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('band3-wrap').style.display = n >= 5 ? 'block' : 'none';
      el('tcr-wrap').style.display = n === 6 ? 'block' : 'none';
      update();
    }

    function update() {
      const nBands = el('b-4').classList.contains('bg-white') ? 4 : el('b-5').classList.contains('bg-white') ? 5 : 6;

      let digits = [];
      if (nBands >= 4) {
        digits.push(parseInt(el('band1').value));
        digits.push(parseInt(el('band2').value));
        if (nBands >= 5) digits.push(parseInt(el('band3').value));
      }

      const mult = parseFloat(el('mult').value);
      const tolText = el('tol').value;
      const tcrText = nBands === 6 ? el('tcr').value : '';

      if (digits.some(isNaN)) {
        el('r-val').textContent = '\u2014';
        el('r-detail').textContent = '';
        return;
      }

      const value = parseInt(digits.join('')) * mult;
      let displayVal;
      if (value >= 1000000) displayVal = (value / 1000000).toFixed(1) + ' M\u03a9';
      else if (value >= 1000) displayVal = (value / 1000).toFixed(1) + ' k\u03a9';
      else displayVal = value + ' \u03a9';

      let detail = 'Tolerance: ' + tolText;
      if (tcrText) detail += ' | TCR: ' + tcrText;

      el('r-val').textContent = displayVal;
      el('r-detail').textContent = detail;
    }

    el('b-4').addEventListener('click', () => setBands(4));
    el('b-5').addEventListener('click', () => setBands(5));
    el('b-6').addEventListener('click', () => setBands(6));
    ['band1','band2','band3','mult','tol','tcr'].forEach(id => {
      const els = document.querySelectorAll('#' + id);
      if (els.length) els[0].addEventListener('change', update);
    });
  </script>
</ToolLayout>
