---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'French Drain Calculator';
const description = 'Find the gravel, pipe and fabric needed for a French drain trench from its length, width and depth, plus the trench excavation volume.';
const intro = 'Find the gravel and pipe needed for a French drain, from your trench length, width and depth.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much gravel do I need for a French drain?', a: 'Multiply the trench length, width and depth to get the trench volume, then subtract the space taken by the perforated pipe. A 50 ft trench, 12 in wide, 18 in deep, needs about 55 cubic feet of gravel after subtracting a 4-inch pipe.' },
  { q: 'What size trench does a French drain need?', a: 'A typical residential French drain trench is 12 to 18 inches wide and 18 to 24 inches deep, sloped at a minimum of 1% (about 1/8 inch per foot) toward the drainage outlet. Deeper, wider trenches move more water but cost more to dig and fill.' },
  { q: 'How much perforated pipe do I need?', a: 'Generally one length of perforated pipe equal to the trench length, typically 4-inch diameter for residential use. The calculator also estimates the volume the pipe itself displaces so the gravel estimate is more accurate.' },
  { q: 'Do I need landscape fabric?', a: 'Yes, in most designs. Fabric lines the trench before the gravel and pipe go in, and wraps back over the top, to keep soil and silt from migrating into the gravel and clogging the drain over time. Estimate fabric by the trench length times roughly its wrapped perimeter.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Trench length (ft)</span>
        <input id="len" type="number" step="any" placeholder="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Trench width (in)</span>
        <input id="width" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Trench depth (in)</span>
        <input id="depth" type="number" step="any" placeholder="18" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pipe diameter (in)</span>
        <input id="pipedia" type="number" step="any" placeholder="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Gravel needed</div>
        <div id="r-gravel" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Trench volume</div><div id="r-trench" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Pipe length</div><div id="r-pipe" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Fabric needed</div><div id="r-fabric" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fd-title fd-desc">
      <title id="fd-title">French drain trench cross-section</title>
      <desc id="fd-desc">A trench with fabric, gravel, and a perforated pipe, and the gravel volume formula</desc>
      <rect x="90" y="70" width="140" height="120" fill="#e2e8f0" stroke="#94a3b8" stroke-width="2" stroke-dasharray="5 3" />
      <rect x="100" y="80" width="120" height="100" fill="#d6d3d1" stroke="#78716c" stroke-width="1" />
      <circle cx="160" cy="160" r="22" fill="#94a3b8" stroke="#475569" stroke-width="2" />
      <circle cx="160" cy="160" r="10" fill="#f8fafc" />
      <text x="160" y="205" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">fabric · gravel · perforated pipe</text>
      <rect x="420" y="55" width="330" height="120" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Gravel volume</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">trench = L &times; W &times; D</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">gravel = trench &minus; pipe volume</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Gravel surrounds the perforated pipe so water reaches it from all sides.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the French drain calculator works</h2>
    <p class="mt-2 text-slate-600">
      A French drain moves groundwater away from a wet area through a gravel-filled trench with a perforated pipe running along its bottom. Sizing the materials starts with the trench volume — length times width times depth — then subtracts the volume the pipe itself occupies, since gravel only fills the space around it, not where the pipe sits.
    </p>
    <p class="mt-3 text-slate-600">
      Typical residential trenches run 12 to 18 inches wide and 18 to 24 inches deep, sloped at a minimum of about 1% — roughly 1/8 inch of drop per foot — so water flows by gravity toward an outlet or dry well rather than sitting stagnant. A 4-inch perforated pipe is standard for most home drainage, running the full trench length. The calculator also estimates the fabric needed to line the trench, since fabric wraps around the gravel to keep surrounding soil from washing in and clogging the system over years of use.
    </p>
    <p class="mt-3 text-slate-600">
      This is a materials estimate for a straightforward, gravity-fed residential drain. Sizing for standing water problems, foundation drainage, or anywhere water quantity is significant should follow a site-specific drainage design, since pipe size, slope, and outlet capacity all need to match the actual water volume the drain must handle.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Plan the trench</h3>
        <p class="mt-1 text-sm text-slate-600">Length, width, and depth of the run.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick the pipe size</h3>
        <p class="mt-1 text-sm text-slate-600">Usually 4-inch perforated pipe for homes.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Order materials</h3>
        <p class="mt-1 text-sm text-slate-600">Gravel, pipe length, and fabric.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Trench volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= L &times; (W&frasl;12) &times; (D&frasl;12)</span>. A 50 ft trench, 12×18 in: 50 × 1 × 1.5 = <strong>75 ft³</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Pipe volume (subtract)</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= &pi; &times; (dia&frasl;24)&sup2; &times; L</span>. A 4 in pipe over 50 ft: π × 0.167² × 50 ≈ <strong>4.4 ft³</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Net gravel</p>
        <p class="mt-1 text-slate-600">
          75 − 4.4 = <strong>70.6 ft³</strong>, about 2.6 cubic yards.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 30 ft trench, 12 in wide, 24 in deep, 4 in pipe.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Trench volume:</span> <span class="text-slate-600">30 × 1 × 2 = 60 ft³</span></div>
        <div><span class="font-medium text-slate-700">Pipe volume:</span> <span class="text-slate-600">π × 0.167² × 30 ≈ 2.6 ft³</span></div>
        <div><span class="font-medium text-slate-700">Net gravel:</span> <span class="text-slate-600"><strong>57.4 ft³</strong> (≈2.1 yd³)</span></div>
        <div><span class="font-medium text-slate-700">Pipe length:</span> <span class="text-slate-600">30 ft</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/gravel-sand-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gravel &amp; Sand Calculator</a>
      <a href="/tools/pipe-volume-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Pipe Volume Calculator</a>
      <a href="/tools/grade-slope-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Grade &amp; Slope Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('len').value);
      const W = parseFloat(el('width').value);
      const D = parseFloat(el('depth').value);
      const pipeDia = parseFloat(el('pipedia').value);
      if (!(L > 0 && W > 0 && D > 0 && pipeDia >= 0)) { el('results').classList.add('hidden'); return; }
      const trenchVol = L * (W / 12) * (D / 12);
      const pipeVol = Math.PI * Math.pow(pipeDia / 24, 2) * L;
      const gravelVol = Math.max(trenchVol - pipeVol, 0);
      const gravelCY = gravelVol / 27;
      const fabricSqFt = L * ((W + 2 * D) / 12 + 1); // rough wrap perimeter + overlap

      el('r-gravel').textContent = gravelCY.toFixed(2) + ' yd³';
      el('r-note').textContent = gravelVol.toFixed(1) + ' ft³ around a ' + pipeDia + ' in pipe';
      el('r-trench').textContent = trenchVol.toFixed(1) + ' ft³';
      el('r-pipe').textContent = L.toFixed(0) + ' ft';
      el('r-fabric').textContent = fabricSqFt.toFixed(0) + ' ft²';
      el('results').classList.remove('hidden');
    }

    ['len', 'width', 'depth', 'pipedia'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
