---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Electric Power Calculator';
const description = 'Electric power calculator with a live glowing-bulb 3D scene and charts. Solve P = V×I, convert watts to kWh, and calculate electricity cost.';
const intro = 'Solve electric power with P = V × I (or I²R, V²/R), then convert that power to energy over time and estimate what it costs to run. A live 3D bulb glows brighter as power rises.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is electric power?', a: 'Electric power (P) is the rate at which electrical energy is transferred or converted, measured in watts (W). One watt is one joule per second. It tells you how fast a device consumes energy at any instant — not how much energy it uses in total.' },
  { q: 'How does P = VI relate to the other Ohm’s-law power forms?', a: 'P = VI is the base definition. Substituting Ohm’s law V = IR gives P = I²R (power from current and resistance), and substituting I = V/R gives P = V²/R (power from voltage and resistance). All three are algebraically identical and give the same answer for a resistive load.' },
  { q: 'How do I convert watts to kilowatt-hours?', a: 'Watts measure instantaneous power; kilowatt-hours (kWh) measure energy used over time. Divide power in watts by 1000 to get kilowatts, then multiply by the running time in hours: E (kWh) = P (kW) × t (h). A 1000 W device run for 1 hour uses exactly 1 kWh.' },
  { q: 'How is electricity actually billed?', a: 'Utilities bill for energy (kWh), not power (W). Your bill is Energy (kWh) × price per kWh. A high-power device used briefly can cost less than a low-power device left running for days, because cost tracks total energy, not peak wattage.' },
  { q: 'Why do some appliances draw far more power than others?', a: 'Devices that generate heat directly — kettles, heaters, toasters — convert electrical energy to heat with resistive elements and typically draw 1000–2000 W. Devices that just run electronics or motors (LED bulbs, laptops, refrigerators) draw far less, often under 100 W, because they are not fighting resistance to produce heat.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Electric Power Calculator',
  description: 'Calculate electric power from voltage and current, or calculate energy use and cost from power, time, and electricity price.',
  steps: [
    { name: 'Pick a mode', text: 'Choose "Power" (P = V × I) or "Energy cost" (kWh and price).' },
    { name: 'Enter the values', text: 'In Power mode type any two of V, I, P. In Energy cost mode enter power, time, and price per kWh.' },
    { name: 'Read the result', text: 'The missing value solves instantly, and the 3D bulb brightness tracks the power.' },
  ],
};

const formulas = [
  { expr: 'P = V &times; I', note: 'power from voltage &amp; current' },
  { expr: 'P = I&sup2;R &nbsp;=&nbsp; V&sup2;/R', note: 'equivalent forms via Ohm’s law' },
  { expr: 'E (kWh) = P (kW) &times; t (h)', note: 'energy over time' },
  { expr: 'Cost = E &times; price/kWh', note: 'what the utility actually bills' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — electric kettle', tone: 'slate',
    given: 'A 1500 W kettle runs for 15 minutes (0.25 h). Electricity costs $0.15 per kWh. Find the energy used and the cost.',
    rows: [
      { label: 'Power in kW:', value: 'P = 1500 W ÷ 1000 = 1.5 kW' },
      { label: 'Energy:', value: 'E = P × t = 1.5 × 0.25 = 0.375 kWh' },
      { label: 'Cost:', value: 'Cost = 0.375 × $0.15 = $0.05625 ≈ $0.06', full: true },
    ],
  },
  {
    title: 'Worked example 2 — LED bulb, a full day', tone: 'amber',
    given: 'A 100 W bulb runs 5 hours per day. Electricity costs $0.12 per kWh. Find the daily energy and cost.',
    rows: [
      { label: 'Power in kW:', value: 'P = 100 W ÷ 1000 = 0.1 kW' },
      { label: 'Energy per day:', value: 'E = P × t = 0.1 × 5 = 0.5 kWh' },
      { label: 'Cost per day:', value: 'Cost = 0.5 × $0.12 = $0.06/day', full: true },
    ],
    note: 'Over a 30-day month that is 15 kWh and about $1.80 — a useful way to compare running costs across appliances.',
  },
];

const comparison = {
  heading: 'Typical appliance power draw',
  note: 'Approximate, real devices vary by model — use these as reasonable reference points.',
  headers: [{ label: 'Appliance' }, { label: 'Typical power' }, { label: 'Energy / hour' }],
  rows: [
    ['LED bulb', '10 W', '0.010 kWh'],
    ['Laptop', '65 W', '0.065 kWh'],
    ['Refrigerator', '150 W', '0.150 kWh'],
    ['Microwave', '1000 W', '1.000 kWh'],
    ['Electric kettle', '1500 W', '1.500 kWh'],
    ['Space heater', '1500 W', '1.500 kWh'],
  ],
  highlightIndex: 4,
  footnote: 'Multiply energy/hour by your utility’s price per kWh to estimate running cost.',
};

const realWorld = [
  { emoji: '💰', title: 'Household energy bill estimation', body: 'Multiplying each appliance’s power by its daily hours of use and summing the kWh gives a realistic estimate of a monthly electricity bill — before the bill arrives.' },
  { emoji: '🛒', title: 'Appliance efficiency shopping', body: 'Comparing wattage and expected annual kWh between two similar appliances (e.g. two refrigerator models) shows which one actually costs less to run over its lifetime, not just to buy.' },
  { emoji: '☀️', title: 'Solar panel sizing', body: 'Sizing a solar array starts from total daily energy demand in kWh, built up from the power and run-time of every device the system needs to support.' },
  { emoji: '🔌', title: 'EV charging cost', body: 'An EV charger’s power rating (kW) times charging hours gives the kWh added to the battery, which multiplied by the electricity price gives the cost of a full charge.' },
];

const misconceptions = [
  { claim: '“Watts and watt-hours are the same unit.”', truth: 'They measure different things. Watts (W) measure instantaneous power — the rate of energy use right now. Watt-hours (or kWh) measure energy — power accumulated over time. Your utility bills you for kWh, not W.' },
  { claim: '“A higher-voltage appliance always uses more power.”', truth: 'Power depends on both voltage and current: P = V × I. A high-voltage device drawing little current can use less power than a low-voltage device drawing a lot of current. Voltage alone does not determine power.' },
  { claim: '“Leaving a device plugged in but off costs nothing.”', truth: 'Many electronics draw small standby power even when “off.” It is usually just a few watts, but over months that adds measurable kWh — which is why it is called “phantom load.”' },
  { claim: '“Doubling the voltage doubles the power.”', truth: 'Only true if current stays fixed. For a fixed resistance, P = V²/R — doubling voltage actually quadruples power, because current rises too (Ohm’s law).' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — electric power in circuits (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/9-3-electrical-energy-and-power" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — chapter on current, resistance, and power in circuits.' },
  { html: '<strong>U.S. Energy Information Administration</strong> — electricity use and kWh billing basics.' },
];
const sourcesNote = 'Power = voltage × current (P = VI); energy = power × time; cost = energy × price per kWh. Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '“Power” solves P = V×I for any missing value; “Energy cost” converts watts and run-time into kWh and dollars.' },
  { title: 'Enter your values', body: 'Fill in the known fields — the calculator solves the rest live as you type.' },
  { title: 'Watch the bulb', body: 'Use the sliders to see the 3D bulb glow brighter as V, I, and power increase.' },
];

const related = [
  { href: '/tools/ohms-law-calculator', emoji: '🔌', title: "Ohm's Law Calculator", desc: 'V = IR — solve voltage, current, or resistance.' },
  { href: '/tools/power-calculator', emoji: '⚡', title: 'Power Calculator', desc: 'Full P=VI, P=I²R, P=V²/R with AC power factor.' },
  { href: '/tools/series-resistor-calculator', emoji: '🔌', title: 'Series Resistor Calculator', desc: 'Total resistance and voltage-divider drops.' },
  { href: '/tools/parallel-resistor-calculator', emoji: '🔋', title: 'Parallel Resistor Calculator', desc: 'Total resistance and branch currents.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="power is how fast energy moves (P = VI, in watts); energy is power accumulated over time (kWh) — and energy, not power, is what you pay for."
  howIntro="Once you know power in watts, convert to kilowatts (&divide;1000) and multiply by hours run to get energy: <span class='font-mono'>E = P &times; t</span>. Multiply that energy by your utility's price per kWh to get the cost — the same two-step chain behind every electricity bill line item."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where electric power &amp; energy cost actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-pw" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Power (P = V×I)</button>
      <button id="mode-ec" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Energy cost</button>
    </div>
    <div id="pw-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Voltage (V)</span>
        <input id="V" type="number" step="any" placeholder="volts" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current (I)</span>
        <input id="I" type="number" step="any" placeholder="amps" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Power (P)</span>
        <input id="P" type="number" step="any" placeholder="watts" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="ec-fields" class="hidden gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Power (W)</span>
        <input id="ecP" type="number" step="any" placeholder="watts" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time (hours)</span>
        <input id="ecT" type="number" step="any" placeholder="hours" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Price ($/kWh)</span>
        <input id="ecR" type="number" step="any" placeholder="0.12" value="0.12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Power</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Current</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Voltage</div><div id="r-3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="pw-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D bulb + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D power bulb</h2>
      <p class="mt-1 text-sm text-slate-500">Set voltage and current with the sliders; the bulb glows brighter and the meter needle swings further as power rises. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Voltage <span id="out-bv" class="font-mono text-blue-600">120.0 V</span></span>
          <input id="b-v" type="range" min="0" max="240" step="1" value="120" class="mt-2 w-full accent-blue-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Current <span id="out-bi" class="font-mono text-blue-600">5.00 A</span></span>
          <input id="b-i" type="range" min="0" max="15" step="0.1" value="5" class="mt-2 w-full accent-blue-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-blue-50 p-3 text-center text-sm text-blue-700">Power P = <span id="out-bp" class="font-mono font-bold">600.0 W</span></div>
      <div id="bulb3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:340px;"></div>
      <p id="bulb3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Power graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Power vs voltage (fixed current) — a straight line, P = VI</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pv"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Typical appliance power draw</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-appl"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'pw';
      function switchMode(m) {
        mode = m;
        el('mode-pw').className = m === 'pw' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-ec').className = m === 'ec' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('pw-fields').className = m === 'pw' ? 'grid gap-4 sm:grid-cols-3' : 'hidden';
        el('ec-fields').className = m === 'ec' ? 'grid gap-4 sm:grid-cols-3' : 'hidden gap-4 sm:grid-cols-3';
        el('lab-1').textContent = m === 'pw' ? 'Power' : 'Energy';
        el('lab-2').textContent = m === 'pw' ? 'Current' : 'Cost';
        el('lab-3').textContent = m === 'pw' ? 'Voltage' : 'Price used';
        update();
      }
      function update() {
        el('pw-err').textContent = '';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        if (mode === 'pw') {
          const V = parseFloat(el('V').value), I = parseFloat(el('I').value), P = parseFloat(el('P').value);
          const filled = [!isNaN(V), !isNaN(I), !isNaN(P)];
          if (filled.filter(Boolean).length < 2) return;
          let rV = NaN, rI = NaN, rP = NaN;
          if (filled[0] && filled[1]) { rV = V; rI = I; rP = V * I; }
          else if (filled[0] && filled[2]) { if (V === 0) { el('pw-err').textContent = 'Voltage cannot be zero when solving for current.'; return; } rV = V; rP = P; rI = P / V; }
          else if (filled[1] && filled[2]) { if (I === 0) { el('pw-err').textContent = 'Current cannot be zero when solving for voltage.'; return; } rI = I; rP = P; rV = P / I; }
          if (!isNaN(rP)) el('r-1').textContent = fmt(rP) + ' W';
          if (!isNaN(rI)) el('r-2').textContent = fmt(rI) + ' A';
          if (!isNaN(rV)) el('r-3').textContent = fmt(rV) + ' V';
        } else {
          const P = parseFloat(el('ecP').value), t = parseFloat(el('ecT').value), price = parseFloat(el('ecR').value);
          if (isNaN(P) || isNaN(t) || isNaN(price)) return;
          const E = (P / 1000) * t;
          const cost = E * price;
          el('r-1').textContent = fmt(E) + ' kWh';
          el('r-2').textContent = '$' + fmt(cost);
          el('r-3').textContent = '$' + fmt(price) + '/kWh';
        }
      }
      el('mode-pw').addEventListener('click', () => switchMode('pw'));
      el('mode-ec').addEventListener('click', () => switchMode('ec'));
      ['V', 'I', 'P', 'ecP', 'ecT', 'ecR'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let bulb = null;
      function bState() { const v = parseFloat(el('b-v').value), i = parseFloat(el('b-i').value); return { v, i, p: v * i }; }
      function onB() {
        const s = bState();
        el('out-bv').textContent = s.v.toFixed(1) + ' V';
        el('out-bi').textContent = s.i.toFixed(2) + ' A';
        el('out-bp').textContent = fmt(s.p) + ' W';
        try { if (bulb) bulb.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-v').addEventListener('input', onB);
      el('b-i').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.pv = new Chart(el('chart-pv'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'P', data: [], borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Voltage (V)' } }, y: { title: { display: true, text: 'Power (W)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.appl = new Chart(el('chart-appl'), {
          type: 'bar',
          data: {
            labels: ['LED bulb', 'Laptop', 'Refrigerator', 'Microwave', 'Kettle', 'Space heater'],
            datasets: [{ label: 'Typical power (W)', data: [10, 65, 150, 1000, 1500, 1500], backgroundColor: ['#38bdf8', '#60a5fa', '#818cf8', '#f59e0b', '#f43f5e', '#ef4444'] }],
          },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Power (W)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L = [], D = [];
        for (let vv = 0; vv <= 240.001; vv += 10) { L.push(vv.toFixed(0)); D.push(+(s.i * vv).toFixed(2)); }
        charts.pv.data.labels = L; charts.pv.data.datasets[0].data = D; charts.pv.update();
      }

      // ---- interactive glowing bulb ----
      const MAX_P = 3600; // 240V * 15A
      function initBulb() {
        const c = el('bulb3d'); if (!c) throw new Error('no bulb');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), SCENE_OPTS);

        const baseMat = new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.5, metalness: 0.4 });
        const base = new THREE.Mesh(new THREE.CylinderGeometry(0.9, 1.1, 1.4, 24), baseMat);
        base.position.y = -3.2; s.scene.add(base);

        const glassMat = new THREE.MeshStandardMaterial({ color: 0xfff7d6, transparent: true, opacity: 0.55, roughness: 0.15, emissive: 0x000000, emissiveIntensity: 0 });
        const glass = new THREE.Mesh(new THREE.SphereGeometry(2.4, 32, 32), glassMat);
        glass.position.y = -0.4; s.scene.add(glass);

        const filamentMat = new THREE.MeshStandardMaterial({ color: 0xf59e0b, emissive: 0xf59e0b, emissiveIntensity: 0.3 });
        const filament = new THREE.Mesh(new THREE.TorusKnotGeometry(0.7, 0.12, 64, 8, 2, 3), filamentMat);
        filament.position.y = -0.4; s.scene.add(filament);

        const glowLight = new THREE.PointLight(0xffdd88, 0.5, 12);
        glowLight.position.set(0, -0.4, 0); s.scene.add(glowLight);

        function update(state) {
          const frac = Math.max(0, Math.min(1, state.p / MAX_P));
          glassMat.emissive.setHex(0xffcc55);
          glassMat.emissiveIntensity = frac * 1.6;
          filamentMat.emissiveIntensity = 0.3 + frac * 2.2;
          glowLight.intensity = 0.3 + frac * 3.5;
          const scale = 1 + frac * 0.12;
          filament.scale.setScalar(scale);
        }
        function frame() {
          requestAnimationFrame(frame);
          if (!reduceMotion) { filament.rotation.y += 0.01; s.spin(0.0012); }
          s.renderer.render(s.scene, s.camera);
        }
        frame();
        bulb = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { switchMode('pw'); } catch (e) { console.error('[electric-power] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[electric-power] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[electric-power] charts failed', e); }
        if (window.THREE) {
          try { initBulb(); } catch (e) { console.error('[electric-power] bulb failed', e); el('bulb3d-fallback').classList.remove('hidden'); }
        } else { el('bulb3d-fallback').classList.remove('hidden'); }
        mountResize([bulb]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
