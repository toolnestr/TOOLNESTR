---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Wainscoting Calculator';
const description = 'Find the number of wainscoting panels and the linear feet of cap and base trim needed for a room, from its perimeter and panel width.';
const intro = 'Find how many wainscoting panels and how much trim you need for a room.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How many wainscoting panels do I need?', a: 'Divide the room\'s perimeter (minus door and window widths, if excluding those areas) by the panel width, and round up. A 40-foot perimeter with 16-inch-wide panels: 480 in ÷ 16 = 30 panels.' },
  { q: 'How tall should wainscoting be?', a: 'A traditional height is about one-third of the wall height, commonly 32 to 36 inches for an 8 or 9-foot ceiling, though styles range from a low 30-inch chair-rail height to a taller 48-inch or more for a more formal look.' },
  { q: 'How much cap and base trim do I need?', a: 'Both the cap rail (top edge) and the shoe or base trim (bottom edge) run the full perimeter of the wainscoted wall, so you need roughly one linear foot of each trim type per linear foot of wall — the same length as the perimeter itself, plus a waste allowance for corner cuts.' },
  { q: 'Should I subtract door and window openings from the perimeter?', a: 'Yes, for material efficiency — you don\'t need panels or trim across a door or window opening at that height. Subtract each opening\'s width from the total perimeter before dividing by panel width, though many installers still add a small waste allowance since corner returns and closures around openings use extra trim.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Room perimeter (ft)</span>
        <input id="perim" type="number" step="any" placeholder="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Door/window width to exclude (ft)</span>
        <input id="openings" type="number" step="any" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Panel width (in)</span>
        <input id="panelw" type="number" step="any" placeholder="16" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waste (%)</span>
        <input id="waste" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Panels needed</div>
        <div id="r-panels" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cap trim needed</div><div id="r-cap" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Base trim needed</div><div id="r-base" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="wc-title wc-desc">
      <title id="wc-title">Wainscoting panels with cap and base trim</title>
      <desc id="wc-desc">A wall with wainscoting panels, cap rail, and base trim</desc>
      <rect x="80" y="80" width="220" height="90" fill="#fef3c7" stroke="#a16207" stroke-width="1.5" />
      <rect x="80" y="80" width="220" height="10" fill="#78350f" />
      <rect x="80" y="160" width="220" height="10" fill="#78350f" />
      <g stroke="#a16207" stroke-width="1"><line x1="115" y1="90" x2="115" y2="160" /><line x1="150" y1="90" x2="150" y2="160" /><line x1="185" y1="90" x2="185" y2="160" /><line x1="220" y1="90" x2="220" y2="160" /><line x1="255" y1="90" x2="255" y2="160" /></g>
      <text x="190" y="188" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">cap and base trim run the full perimeter</text>
      <rect x="420" y="55" width="330" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Panels &amp; trim</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">panels = ceil(perimeter &divide; panel width)</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">cap = base = perimeter length</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Panels fill the wall face; cap and base trim wrap the full perimeter above and below.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the wainscoting calculator works</h2>
    <p class="mt-2 text-slate-600">
      Wainscoting covers the lower portion of a wall in panels, capped top and bottom by trim that runs the room's full perimeter. Sizing the panels is a straightforward division: take the room's perimeter, subtract the width of any doors or windows you're not paneling across, and divide by the panel width to get the number of panels needed, rounding up since a partial panel still needs a full one cut down.
    </p>
    <p class="mt-3 text-slate-600">
      Wainscoting height is traditionally about a third of the wall's total height — commonly 32 to 36 inches on an 8 or 9-foot ceiling — though styles range from a low 30-inch chair-rail height to a taller, more formal 48 inches or more. That height decision affects panel material quantity but not the panel count itself, since the count is driven by the perimeter and panel width, not the height.
    </p>
    <p class="mt-3 text-slate-600">
      Both the cap rail along the top of the panels and the base or shoe trim along the bottom run the entire perimeter, so each needs roughly the same linear footage as the perimeter itself. A waste allowance of about 10% covers the corner miters and any small returns around door and window openings, where trim gets cut and rejoined rather than running in one continuous piece.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the perimeter</h3>
        <p class="mt-1 text-sm text-slate-600">Subtract door and window widths you'll skip.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set panel width</h3>
        <p class="mt-1 text-sm text-slate-600">Match your chosen wainscoting profile.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Order trim to match</h3>
        <p class="mt-1 text-sm text-slate-600">Cap and base run the same perimeter length.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Net perimeter</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= perimeter &minus; openings</span>. A 40 ft room, 6 ft of openings: 40 − 6 = <strong>34 ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Panel count</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= ceil((net perimeter &times; 12) &divide; panel width)</span>. At 16 in panels: ceil(408÷16) = <strong>26 panels</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Cap &amp; base trim</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= perimeter &times; 1.10</span> (waste) = 40 × 1.10 = <strong>44 ft</strong> each.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A dining room, 52 ft perimeter, 8 ft of openings, 14 in panels, 10% waste.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Net perimeter:</span> <span class="text-slate-600">52 − 8 = 44 ft (528 in)</span></div>
        <div><span class="font-medium text-slate-700">Panels:</span> <span class="text-slate-600">ceil(528÷14) = <strong>38 panels</strong></span></div>
        <div><span class="font-medium text-slate-700">Cap trim:</span> <span class="text-slate-600">52 × 1.10 = <strong>57.2 ft</strong></span></div>
        <div><span class="font-medium text-slate-700">Base trim:</span> <span class="text-slate-600">same, 57.2 ft</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/board-and-batten-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Board and Batten Calculator</a>
      <a href="/tools/shiplap-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Shiplap Calculator</a>
      <a href="/tools/perimeter-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Perimeter Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const perim = parseFloat(el('perim').value);
      let openings = parseFloat(el('openings').value); if (!(openings >= 0)) openings = 0;
      const panelW = parseFloat(el('panelw').value);
      let waste = parseFloat(el('waste').value); if (!(waste >= 0)) waste = 0;
      if (!(perim > 0 && panelW > 0)) { el('results').classList.add('hidden'); return; }
      const netPerimFt = Math.max(perim - openings, 0);
      const panels = Math.ceil((netPerimFt * 12) / panelW);
      const trim = perim * (1 + waste / 100);

      el('r-panels').textContent = panels;
      el('r-note').textContent = netPerimFt.toFixed(1) + ' ft net perimeter at ' + panelW + ' in panels';
      el('r-cap').textContent = trim.toFixed(1) + ' ft';
      el('r-base').textContent = trim.toFixed(1) + ' ft';
      el('results').classList.remove('hidden');
    }

    ['perim', 'openings', 'panelw', 'waste'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
