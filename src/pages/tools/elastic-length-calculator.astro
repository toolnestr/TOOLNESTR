---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Elastic Length Calculator';
const description = 'Calculate the cut length of elastic for a waistband, cuff, or neckline from a body measurement and reduction percentage.';
const intro = 'Calculate the cut length of elastic from a body measurement and a stretch reduction percentage.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why is elastic cut shorter than the body measurement it covers?', a: 'Elastic needs to be cut shorter than the fabric casing it sits inside so it stretches slightly to hold the garment snugly in place — a piece cut exactly to the body measurement would sit loose and could slip down.' },
  { q: 'What reduction percentage should I use?', a: 'A 10-15% reduction gives a comfortable, secure fit for most waistbands; 15-20% gives a snugger fit for cuffs and necklines, and even more reduction is used for firm-hold sportswear elastic. Test a sample on the actual fabric when precision matters.' },
  { q: 'Does elastic type affect the reduction amount?', a: 'Yes — firmer, less elastic types (like non-roll waistband elastic) generally need a smaller percentage reduction than very stretchy, soft elastic, since firmer elastic already provides more holding power per inch of stretch.' },
  { q: 'Should I measure over clothing or directly on the body?', a: 'Measure directly on the body (or on the specific area the elastic will sit against) for the most accurate fit, since measuring over bulky clothing adds extra circumference that isn\'t part of the true measurement.' },
];
const howTo = {
  name: 'How to calculate elastic length',
  steps: [
    { name: 'Measure the body area', text: 'Measure the waist, wrist, or other area the elastic will encircle.' },
    { name: 'Choose a reduction percentage', text: 'Select how snug you want the elastic to fit.' },
    { name: 'Read the cut length', text: 'The elastic length to cut appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Body measurement (in)</span>
        <input id="measure" type="number" step="any" placeholder="e.g. 30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Reduction (%)</span>
        <input id="reduction" type="number" step="any" value="15" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Elastic to cut</div>
        <div id="r-length" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="elc-title elc-desc">
      <title id="elc-title">Elastic loop shown smaller than the body circle it fits inside</title>
      <desc id="elc-desc">A dashed outer circle representing the body measurement with a smaller solid circle inside representing the cut elastic loop</desc>
      <circle cx="400" cy="90" r="75" fill="none" stroke="#94a3b8" stroke-width="2" stroke-dasharray="6 3" />
      <circle cx="400" cy="90" r="60" fill="none" stroke="#e11d48" stroke-width="3" />
      <text x="400" y="30" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Body measurement</text>
      <text x="400" y="170" text-anchor="middle" font-size="12" fill="#e11d48" font-family="system-ui,sans-serif">Cut elastic (shorter)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Elastic is cut shorter than the body measurement so it stretches to fit snugly</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How elastic length is calculated</h2>
    <p class="mt-2 text-slate-600">
      Elastic needs to stretch to reach the full body circumference once worn, which only works if it starts out shorter than that circumference. This calculator multiplies your body measurement by (1 minus the reduction percentage) to find the cut length — a 30-inch waist with a 15% reduction gives 30 × 0.85 = 25.5 inches of elastic, which then stretches back out to fit the 30-inch waistband casing snugly.
    </p>
    <p class="mt-3 text-slate-600">
      A small seam allowance is needed on top of this cut length to overlap and stitch the elastic into a closed loop — add roughly 0.5-1 inch to the calculated length before cutting to account for that overlap.
    </p>
    <p class="mt-3 text-xs text-slate-400">The percentage-reduction method is the standard approach used across home-sewing references for waistband, cuff, and neckline elastic.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 30-inch waist casing, using a 15% reduction for a comfortable pajama waistband.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Body measurement:</span> <span class="text-slate-600">30 in</span></div>
        <div><span class="font-medium text-slate-700">Reduction:</span> <span class="text-slate-600">15%</span></div>
        <div><span class="font-medium text-slate-700">Cut length:</span> <span class="text-slate-600">30 × 0.85 = <strong>25.5 in</strong></span></div>
        <div><span class="font-medium text-slate-700">Plus overlap:</span> <span class="text-slate-600">+0.75 in ≈ <strong>26.25 in total</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Children's clothing relies heavily on elastic waistbands since kids' proportions and sizes change quickly and elastic accommodates some of that growth — a slightly wrong reduction percentage on adult clothing is a fit annoyance, but on a fast-growing child's garment it can mean the difference between a waistband that lasts a season or one outgrown in weeks.
    </p>
    <p class="mt-3 text-slate-600">
      Swimwear and activewear typically use a higher reduction percentage than everyday loungewear, since these garments need to stay securely in place during movement — using a loungewear-appropriate 10% reduction on swimwear often results in a waistband that doesn't hold up during actual activity.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Elastic should be cut to the exact body measurement." <strong class="text-slate-900">It shouldn't.</strong> Cutting elastic to the exact circumference leaves it sitting loose with no tension, since it isn't being asked to stretch at all — the reduction is what creates the holding tension.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"More reduction is always more comfortable." <strong class="text-slate-900">Too much causes discomfort too.</strong> Excessive reduction creates a waistband that's uncomfortably tight or leaves visible marks after wear — the right amount depends on the garment's purpose, not just maximizing snugness.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/trim-elastic-consumption-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Trim/Elastic Consumption Calculator</a>
      <a href="/tools/knit-stretch-test-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Knit Stretch % Test Calculator</a>
      <a href="/tools/seam-allowance-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Seam Allowance Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const measure = parseFloat(el('measure').value);
      const reduction = parseFloat(el('reduction').value);
      if (!measure || measure <= 0 || reduction === undefined || isNaN(reduction)) { el('results').classList.add('hidden'); return; }
      const cutLength = measure * (1 - reduction / 100);
      el('r-length').textContent = cutLength.toFixed(1) + ' in';
      el('results').classList.remove('hidden');
    }

    el('measure').addEventListener('input', update);
    el('reduction').addEventListener('input', update);
  </script>
</ToolLayout>
