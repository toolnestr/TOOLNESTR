---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Food Thawing Time Calculator';
const description =
  'Free food thawing time calculator. Estimate safe thawing times for meat, poultry ' +
  'and fish based on weight using fridge or cold water methods.';
const intro =
  'Enter the weight of your frozen food to see estimated thawing times for both refrigerator and cold water methods.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'Is it safe to thaw food on the counter?', a: 'No. Thawing food at room temperature allows the outer layers to enter the "danger zone" (4–60°C / 40–140°F) where bacteria multiply rapidly, while the inside remains frozen. The USDA and FDA strongly advise against counter-top thawing. Always use the fridge, cold water (changing water every 30 minutes) or the microwave.' },
  { q: 'How long does it take to thaw meat in the fridge?', a: 'As a general rule, small items (under 0.5 kg / 1 lb) take about 5–6 hours per 500 g (1 lb) in the refrigerator. Larger roasts and whole poultry take much longer — about 4–5 hours per 500 g, meaning a 3 kg (7 lb) chicken needs roughly 24 hours. Always plan ahead for fridge thawing.' },
  { q: 'Can I thaw food in cold water?', a: 'Yes — cold water thawing is faster than fridge thawing and safe when done correctly. Place the food in a leak-proof plastic bag, submerge it in cold tap water, and change the water every 30 minutes. Cook immediately after thawing. This method takes about 30 minutes per 500 g (1 lb).' },
  { q: 'How long does thawed food keep in the fridge?', a: 'Food thawed in the refrigerator can be safely kept for 1–2 days before cooking. Food thawed in cold water or the microwave must be cooked immediately. Never refreeze raw meat or poultry that has been thawed in cold water or the microwave without cooking it first.' },
  { q: 'Can I cook food directly from frozen?', a: 'Yes, for many foods you can cook directly from frozen — just add approximately 50% more cooking time. This works well for smaller cuts like chicken breasts, fish fillets, steaks and vegetables. Large roasts and whole poultry are safer to thaw first for even cooking.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Food type</span>
        <select id="foodType" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="small">Small cuts (steaks, chops, fillets)</option>
          <option value="medium">Medium roasts & joints</option>
          <option value="poultry">Whole poultry & large roasts</option>
          <option value="fish">Fish & seafood</option>
        </select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight</span>
        <input id="weight" type="number" step="any" placeholder="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Weight unit</span>
      <div class="mt-1 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
        <button id="u-kg" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">kg</button>
        <button id="u-lb" class="flex-1 rounded-lg py-2 text-slate-500">lb</button>
      </div></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Refrigerator method</div>
        <div id="r-fridge" class="mt-1 text-3xl font-bold">—</div>
        <div class="text-sm opacity-80">(safe, plan ahead)</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Cold water method</div><div id="r-water" class="mt-1 text-xl font-bold text-indigo-600">—</div><div class="text-xs text-slate-400">change water every 30 min</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Weight entered</div><div id="r-weight" class="mt-1 text-xl font-bold text-slate-700">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter food type and weight to see estimated thawing times.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The Food Thawing Time Calculator estimates safe thawing durations based on the weight of your frozen food and the chosen thawing method. The estimates follow USDA and FDA guidelines for safe food handling. The refrigerator method takes longer but is the safest and most convenient — you can thaw food in the fridge and cook it up to two days later. The cold water method is faster but requires more attention and immediate cooking after thawing.
    </p>
    <p class="mt-3 text-slate-600">
      Thawing times depend on the thickness and density of the food, not just its weight. A thin fish fillet thaws faster than a thick beef roast of the same weight. The calculator accounts for this by using different multipliers for different food types. Whole poultry takes proportionally longer because the cavity insulates the interior, and large roasts have a lower surface-area-to-volume ratio, which slows heat transfer.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="ft-title ft-desc">
      <title id="ft-title">Food thawing timeline comparison</title>
      <desc id="ft-desc">Two parallel timelines showing the relative duration of refrigerator thawing versus cold water thawing for the same weight of food.</desc>
      <!-- Fridge timeline -->
      <text x="60" y="55" text-anchor="middle" font-size="13" font-weight="bold" fill="#6366f1">Fridge</text>
      <rect x="100" y="40" width="600" height="30" rx="15" fill="#e0e7ff" />
      <rect x="100" y="40" width="550" height="30" rx="15" fill="#6366f1" />
      <text x="375" y="60" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">~24 hours (3 kg chicken)</text>
      <text x="100" y="90" font-size="10" fill="#64748b">Place in fridge →</text>
      <text x="700" y="90" font-size="10" fill="#64748b" text-anchor="end">→ Cook within 1–2 days</text>

      <!-- Cold water timeline -->
      <text x="60" y="135" text-anchor="middle" font-size="13" font-weight="bold" fill="#10b981">Water</text>
      <rect x="100" y="120" width="600" height="30" rx="15" fill="#d1fae5" />
      <rect x="100" y="120" width="200" height="30" rx="15" fill="#10b981" />
      <text x="200" y="140" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">~3 hours</text>
      <text x="100" y="170" font-size="10" fill="#64748b">Submerge in cold water →</text>
      <text x="700" y="170" font-size="10" fill="#64748b" text-anchor="end">→ Cook immediately</text>

      <!-- Change water marker -->
      <text x="700" y="140" text-anchor="end" font-size="11" fill="#059669">Change water every 30 min</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Comparison of refrigerator thawing (24 hours) vs cold water thawing (3 hours) for a 3 kg chicken</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the thawing times are estimated</h2>
    <p class="mt-2 text-slate-600">
      The estimates are based on USDA-recommended guidelines: approximately 4–5 hours per 500 g (1 lb) in the refrigerator for large items, and about 30 minutes per 500 g (1 lb) in cold water. Smaller items with higher surface area thaw faster per unit of weight.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">You have a 2.5 kg (5.5 lb) bone-in pork shoulder that you plan to thaw in the refrigerator for a weekend roast. How long will it take?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Food type:</span> <span class="text-slate-600">Medium roast</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">2.5 kg (5.5 lb)</span></div>
        <div><span class="font-medium text-slate-700">Fridge time:</span> <span class="text-slate-600">2.5 × 4 h = <strong>10 hours</strong> (thaw overnight)</span></div>
        <div><span class="font-medium text-slate-700">Cold water time:</span> <span class="text-slate-600">5.5 × 30 min ≈ <strong>2 hours 45 min</strong></span></div>
        <div><span class="font-medium text-slate-700">Cook after:</span> <span class="text-slate-600">Fridge: within 1–2 days; Water: immediately</span></div>
        <div><span class="font-medium text-slate-700">Internal temp check:</span> <span class="text-slate-600">Use a thermometer to verify the centre has reached 4°C (40°F) or above before cooking.</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-600">Home cook planning meals</h3>
      <p class="mt-1 text-sm text-slate-600">Planning a week's worth of dinners and need to know when to move meat from the freezer to the fridge so it is thawed and ready for each night's recipe.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎉</span>
      <h3 class="mt-2 font-semibold text-slate-600">Holiday host</h3>
      <p class="mt-1 text-sm text-slate-600">Thawing a large turkey or ham for Thanksgiving, Christmas or Easter and need precise timing to ensure it is thawed safely and ready for the oven on the day.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍳</span>
      <h3 class="mt-2 font-semibold text-slate-600">Last-minute cook</h3>
      <p class="mt-1 text-sm text-slate-600">Forgot to take meat out of the freezer and need the fastest safe thawing method — cold water with precise timing to get dinner on the table.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🥩</span>
      <h3 class="mt-2 font-semibold text-slate-600">Meal delivery prepper</h3>
      <p class="mt-1 text-sm text-slate-600">Preparing bulk frozen meal components and need to coordinate thawing schedules across multiple items to cook everything on the same day.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Food Thawing Time Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select food type</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the category that best matches your frozen item — small cuts, medium roasts, whole poultry or fish.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the weight</h3>
        <p class="mt-1 text-sm text-slate-600">Type the weight in kilograms or pounds using the toggle. The results update instantly for both thawing methods.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Plan your thawing</h3>
        <p class="mt-1 text-sm text-slate-600">Use the fridge time to plan ahead or the cold water time for faster thawing. Remember: fridge-thawed food keeps for 1–2 days; water-thawed must be cooked immediately.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for safe thawing</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always use a leak-proof bag for water thawing</h3>
        <p class="mt-1 text-sm text-slate-600">When thawing in cold water, seal the food in a waterproof plastic bag to prevent water absorption and bacterial contamination. Squeeze out as much air as possible before sealing.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Change cold water every 30 minutes</h3>
        <p class="mt-1 text-sm text-slate-600">The water must remain cold (below 4°C / 40°F) to keep the outer layers of food at a safe temperature while the inside thaws. Set a timer to remind yourself to change the water regularly.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Cook immediately after water or microwave thawing</h3>
        <p class="mt-1 text-sm text-slate-600">Food thawed by these methods may have reached temperatures conducive to bacterial growth on the outer surface. Cooking immediately kills any bacteria that may have developed during the thawing process.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/meat-roasting-time-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🍖</span>
        <h3 class="mt-2 font-semibold text-slate-900">Meat Roasting Time Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Roasting times by meat type and weight</p>
      </a>
      <a href="/tools/oven-temperature-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🌡️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Oven Temperature Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert °F, °C, gas mark and fan</p>
      </a>
      <a href="/tools/recipe-scaling-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">📝</span>
        <h3 class="mt-2 font-semibold text-slate-900">Recipe Scaling Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Scale recipes up or down by servings</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let isKg = true;

    function setUnit(kg) {
      isKg = kg;
      el('u-kg').className = 'flex-1 rounded-lg py-2 ' + (kg ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-lb').className = 'flex-1 rounded-lg py-2 ' + (!kg ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    const rates = {
      'small': { fridgePerKg: 3.5, waterPerLbMin: 20 },
      'medium': { fridgePerKg: 4.5, waterPerLbMin: 25 },
      'poultry': { fridgePerKg: 5, waterPerLbMin: 30 },
      'fish': { fridgePerKg: 3, waterPerLbMin: 15 },
    };

    function formatTime(hours) {
      if (hours < 1) {
        const mins = Math.round(hours * 60);
        return mins + ' min';
      }
      const h = Math.floor(hours);
      const m = Math.round((hours - h) * 60);
      return h + ' h ' + (m > 0 ? m + ' min' : '');
    }

    function update() {
      const type = el('foodType').value;
      const w = parseFloat(el('weight').value);
      if (!w || w <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      const rate = rates[type];
      let kg, lb;
      if (isKg) { kg = w; lb = w * 2.20462; }
      else { lb = w; kg = w / 2.20462; }

      const fridgeHours = kg * rate.fridgePerKg;
      const waterMin = lb * rate.waterPerLbMin;

      el('r-fridge').textContent = formatTime(fridgeHours);
      el('r-water').textContent = formatTime(waterMin / 60);
      el('r-weight').textContent = (isKg ? kg.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' kg' : lb.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' lb');
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('foodType').addEventListener('input', update);
    el('weight').addEventListener('input', update);
    el('u-kg').addEventListener('click', () => setUnit(true));
    el('u-lb').addEventListener('click', () => setUnit(false));
  </script>
</ToolLayout>
