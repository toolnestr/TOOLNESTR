---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Newton's Law of Gravitation Calculator";
const description = "Newton's law of gravitation calculator with a live 3D diagram and charts. Solve F = Gm1m2/r² for the gravitational force between two masses, with worked examples for Earth, the Moon, and the Sun.";
const intro = 'Solve F = Gm₁m₂/r² for the gravitational force between any two masses. Two 3D diagrams compare a weak, distant attraction to a strong, close one, and charts show how force falls off with distance and how it scales across everyday and astronomical mass pairs.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: "What is Newton's law of universal gravitation?", a: 'Every particle attracts every other particle with a force proportional to the product of their masses and inversely proportional to the square of the distance between them: F = Gm₁m₂/r².' },
  { q: 'What is the gravitational constant G?', a: 'G = 6.67430×10⁻¹¹ N·m²/kg². It is a fundamental constant that sets the overall strength of gravity, first measured by Henry Cavendish in 1798 using a torsion balance.' },
  { q: 'Why does gravity feel so weak in everyday life?', a: 'Gravity is by far the weakest of the four fundamental forces — the electromagnetic force between two protons is about 10³⁶ times stronger. Gravity only dominates at large scales because, unlike charge, mass has no negative version to cancel it out.' },
  { q: 'How does distance affect gravitational force?', a: "Gravitational force follows the inverse square law — doubling the distance cuts the force to one-quarter, tripling the distance cuts it to one-ninth. This is why astronauts feel noticeably lighter even a few hundred kilometres above Earth's surface." },
  { q: 'Can gravitational force ever be repulsive?', a: 'In Newtonian gravity, no — gravity is always attractive. General relativity does allow repulsive effects through dark energy on cosmological scales, but on everyday and planetary scales gravity is always attractive.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: "How to use the Newton's Law of Gravitation Calculator",
  description: 'Solve F = Gm₁m₂/r² for the gravitational attraction between two masses at a given distance.',
  steps: [
    { name: 'Enter both masses', text: 'Type the mass of each object in kilograms, or use a preset for Earth, the Moon, or the Sun.' },
    { name: 'Enter the distance', text: 'Distance between the centres of mass, in metres.' },
    { name: 'Read the force', text: 'The gravitational force solves instantly, shown in newtons and in scientific notation.' },
  ],
};

const formulas = [
  { expr: 'F = G·m₁·m₂ / r²', note: 'gravitational force — G = 6.674×10⁻¹¹ N·m²/kg², m₁ and m₂ = the two masses, r = distance between centres' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a person standing on Earth', tone: 'slate',
    given: 'Earth (m₁ = 5.97×10²⁴ kg) and a 70 kg person (m₂) standing on the surface, r = 6.37×10⁶ m (Earth\'s radius).',
    rows: [
      { label: 'Formula:', value: 'F = Gm₁m₂/r²' },
      { label: 'Substitute:', value: 'F = (6.674×10⁻¹¹)(5.97×10²⁴)(70) / (6.37×10⁶)²' },
      { label: 'Result:', value: 'F ≈ 687 N — matching the familiar weight = mg = 70 × 9.81 N', full: true },
    ],
    note: "This confirms that weight is nothing more than gravitational force applied to Earth's surface — F = mg is just Newton's law of gravitation evaluated at Earth's radius.",
  },
  {
    title: 'Worked example 2 — the Moon\'s pull on Earth vs. the Sun\'s pull on Earth', tone: 'amber',
    given: "Moon: m = 7.35×10²² kg, r = 3.84×10⁸ m from Earth. Sun: m = 1.99×10³⁰ kg, r = 1.496×10¹¹ m from Earth (Earth's mass = 5.97×10²⁴ kg in both cases).",
    rows: [
      { label: 'Moon\'s pull:', value: 'F ≈ 1.98×10²⁰ N' },
      { label: 'Sun\'s pull:', value: 'F ≈ 3.54×10²² N' },
      { label: 'Comparison:', value: "the Sun's total gravitational pull on Earth is about 180× stronger than the Moon's, even though it's about 390× farther away", full: true },
    ],
    note: "The Sun's enormous mass (about 27 million times the Moon's) more than compensates for the inverse-square penalty of being much farther away — this is exactly why Earth orbits the Sun, not the Moon.",
  },
];

const comparison = {
  heading: 'Gravitational force across everyday and astronomical scales',
  note: 'Same formula, an enormous range of results depending on mass and distance.',
  headers: [{ label: 'Pair' }, { label: 'Force' }],
  rows: [
    ['Two 1 kg objects, 1 m apart', '6.67×10⁻¹¹ N'],
    ['70 kg person on Earth\'s surface ★', '≈687 N'],
    ['Moon\'s pull on Earth', '≈1.98×10²⁰ N'],
    ['Sun\'s pull on Earth', '≈3.54×10²² N'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Even a single-kilogram pair produces a force smaller than the weight of a bacterium — gravity between everyday objects is real but utterly negligible next to planetary-scale attraction.',
};

const realWorld = [
  { emoji: '🛰️', title: 'Satellite orbits', body: 'Every satellite orbit is a balance between gravitational pull (pulling inward) and orbital velocity (carrying the satellite forward) — engineers use this exact formula to calculate the orbital speed and altitude needed for stable orbits.' },
  { emoji: '🌊', title: 'Ocean tides', body: "The Moon's gravitational pull is strong enough to noticeably stretch Earth's oceans, creating tidal bulges. The Sun contributes too, and when Sun, Earth, and Moon align (full or new moon), their combined pull produces the especially strong spring tides." },
  { emoji: '🔭', title: 'Astrophysics and orbital mechanics', body: 'Calculating the gravitational force between stars, planets, and moons is the foundation for predicting orbits, detecting exoplanets from their gravitational wobble, and understanding how galaxies hold together.' },
  { emoji: '🚀', title: 'Spacecraft trajectory planning', body: 'Mission planners calculate gravitational forces from multiple bodies at once to design fuel-efficient trajectories, including gravity-assist maneuvers that use a planet\'s gravity to accelerate a spacecraft without using extra fuel.' },
];

const misconceptions = [
  { claim: '"Objects in orbit are weightless because gravity has stopped acting on them."', truth: "Gravity is still fully acting on orbiting objects — an astronaut on the International Space Station experiences about 90% of Earth's surface gravity. The 'weightlessness' is actually continuous free fall: the station and everything in it are falling toward Earth at the same rate, so nothing pushes against anything else." },
  { claim: '"Heavier objects fall faster because gravity pulls harder on them."', truth: "Gravity does pull harder on a more massive object (larger F), but that object also has more inertia resisting acceleration — the two effects cancel exactly, so in the absence of air resistance, all objects fall at the same acceleration regardless of mass." },
  { claim: '"Gravitational force only matters for planets and stars, not everyday objects."', truth: "Every object with mass exerts a gravitational pull, including people and furniture — it's simply too small to notice at everyday masses and distances. Extremely sensitive torsion-balance experiments, like Cavendish's original 1798 measurement, can detect gravity between lab-scale objects." },
  { claim: '"Doubling the distance between two masses halves the gravitational force."', truth: "Gravity follows an inverse-square law, not an inverse law — doubling the distance reduces the force to one-quarter (1/2² = 1/4), not one-half. This is a common and important distinction from simpler inverse relationships." },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 13, "Gravitation" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/13-1-newtons-law-of-universal-gravitation" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 13, Gravitation.' },
  { html: '<strong>NASA/NIST</strong> — standard reference masses for Earth, Moon, and Sun.' },
];
const sourcesNote = 'F = Gm₁m₂/r², G = 6.67430×10⁻¹¹ N·m²/kg² (CODATA value). Results are rounded for display.';

const howToUse = [
  { title: 'Enter both masses', body: 'Type each mass in kilograms, or use the Earth/Moon/Sun preset buttons for common astronomical bodies.' },
  { title: 'Enter the distance', body: 'Distance between the centres of mass, in metres — for surface calculations, use the body\'s radius.' },
  { title: 'Read the force', body: 'Shown in newtons and scientific notation, so both tiny and enormous results stay readable.' },
];

const related = [
  { href: '/tools/density-calculator', emoji: '⚖️', title: 'Density Calculator', desc: 'ρ = m/V — solve density, mass, or volume.' },
  { href: '/tools/potential-energy-calculator', emoji: '📈', title: 'Gravitational Potential Energy Calculator', desc: 'PE = mgh — solve for any variable.' },
  { href: '/tools/free-fall-calculator', emoji: '⬇️', title: 'Free Fall Calculator', desc: 'Time and velocity under gravity.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="every object with mass pulls on every other object with mass, with a strength that grows with both masses but collapses rapidly with distance — which is why gravity only becomes noticeable when at least one of the objects involved is planet-sized."
  howIntro="Newton's law of universal gravitation states that the attractive force between any two masses depends on the product of those masses (bigger masses pull harder) divided by the square of the distance between their centres (farther apart means dramatically weaker). The gravitational constant G fixes the overall scale of this attraction, and its tiny value (6.674×10⁻¹¹) is exactly why gravity between two everyday-sized objects is far too weak to ever feel — it only becomes significant once one of the masses involved is enormous, like a planet or star."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where gravitational force actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter both masses and the distance between them</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass 1 (m₁)</span>
        <input id="m1" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass 2 (m₂)</span>
        <input id="m2" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Distance (r)</span>
        <input id="r" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mb-2 mt-4 flex flex-wrap gap-2">
      <button id="preset-earth" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Earth (5.97×10²⁴ kg)</button>
      <button id="preset-moon" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Moon (7.35×10²² kg)</button>
      <button id="preset-sun" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Sun (1.99×10³⁰ kg)</button>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Gravitational force</div><div id="r-force" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Scientific notation</div><div id="r-sci" class="mt-1 text-lg font-mono text-slate-800">—</div></div>
    </div>
    <p id="grav-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Weak vs. strong attraction</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-far" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Distant masses (weak pull)</h3>
          <p class="mt-1 text-sm text-slate-600">Two masses far apart — the inverse-square law means force drops off fast with distance.</p>
        </div>
        <div>
          <div id="diag-close" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Close masses (strong pull)</h3>
          <p class="mt-1 text-sm text-slate-600">Same two masses, much closer together — force grows dramatically as distance shrinks.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Gravitational force graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Force vs. distance (inverse-square law)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-fr"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Force comparison across mass pairs (log scale)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pairs"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const G = 6.67430e-11;
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function toSci(v) {
        if (v === 0) return '0';
        const exp = Math.floor(Math.log10(Math.abs(v)));
        const mantissa = v / Math.pow(10, exp);
        return mantissa.toFixed(4) + ' × 10^' + exp;
      }

      // ---- calculator ----
      function update() {
        const m1 = parseFloat(el('m1').value);
        const m2 = parseFloat(el('m2').value);
        const r = parseFloat(el('r').value);
        el('grav-err').textContent = '';
        if (isNaN(m1) || isNaN(m2) || isNaN(r)) { el('r-force').textContent = '—'; el('r-sci').textContent = '—'; return; }
        if (m1 <= 0 || m2 <= 0 || r <= 0) { el('grav-err').textContent = 'Masses and distance must be positive.'; el('r-force').textContent = '—'; el('r-sci').textContent = '—'; return; }
        const f = G * m1 * m2 / (r * r);
        el('r-force').textContent = fmt(f) + ' N';
        el('r-sci').textContent = toSci(f) + ' N';
      }
      el('preset-earth').addEventListener('click', () => { el('m1').value = '5.97e24'; update(); });
      el('preset-moon').addEventListener('click', () => { el('m1').value = '7.35e22'; update(); });
      el('preset-sun').addEventListener('click', () => { el('m1').value = '1.99e30'; update(); });
      ['m1', 'm2', 'r'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labels = [], data = [];
        for (let r = 1; r <= 10; r += 0.5) { labels.push(r); data.push(+(G * 1000 * 1000 / (r * r)).toExponential(3)); }
        new Chart(el('chart-fr'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'F (N), two 1000 kg masses', data, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Distance r (m)' } }, y: { type: 'logarithmic', title: { display: true, text: 'Force (N)' } } }, plugins: { legend: { display: false } } }),
        });
        const pairLabels = ['1kg pair @1m', 'Person on Earth', "Moon–Earth", 'Sun–Earth'];
        const pairData = [G * 1 * 1 / 1, 687, 1.98e20, 3.54e22];
        new Chart(el('chart-pairs'), {
          type: 'bar',
          data: { labels: pairLabels, datasets: [{ label: 'Force (N)', data: pairData, backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Force (N, log scale)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function massPairScene(container, separation) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const m1 = new THREE.Mesh(new THREE.SphereGeometry(0.9, 24, 20), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
        m1.position.x = -separation / 2;
        s.scene.add(m1);
        const m2 = new THREE.Mesh(new THREE.SphereGeometry(0.6, 24, 20), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
        m2.position.x = separation / 2;
        s.scene.add(m2);
        const g = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-separation / 2 + 0.9, 0, 0), new THREE.Vector3(separation / 2 - 0.6, 0, 0)]);
        const arrowLine = new THREE.Line(g, new THREE.LineDashedMaterial({ color: 0xf59e0b, dashSize: 0.2, gapSize: 0.1 }));
        arrowLine.computeLineDistances();
        s.scene.add(arrowLine);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagFar = null, diagClose = null;
      function initDiagFar() { const c = el('diag-far'); if (!c) throw new Error('no container'); diagFar = massPairScene(c, 5.5); }
      function initDiagClose() { const c = el('diag-close'); if (!c) throw new Error('no container'); diagClose = massPairScene(c, 2.2); }

      function boot() {
        try { update(); } catch (e) { console.error('[gravitation] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[gravitation] charts failed', e); }
        if (window.THREE) {
          try { initDiagFar(); } catch (e) { console.error('[gravitation] far diagram failed', e); }
          try { initDiagClose(); } catch (e) { console.error('[gravitation] close diagram failed', e); }
        }
        mountResize([diagFar, diagClose]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
