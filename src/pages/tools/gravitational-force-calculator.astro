---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Gravitational Force Calculator';
const description = 'Free online gravitational force calculator. Calculate the force of gravity between two masses using Newton\'s law F = G(m₁m₂)/r².';
const intro = 'Enter the masses of two objects and the distance between them to calculate the gravitational force.';
const category = { id: 'engineering', name: 'Engineering & Science' };
const faqs = [
  { q: 'What is Newton\'s law of universal gravitation?', a: 'Every particle attracts every other particle with a force proportional to the product of their masses and inversely proportional to the square of the distance between them: F = G(m₁m₂)/r².' },
  { q: 'What is the gravitational constant G?', a: 'G = 6.67430 × 10⁻¹¹ N·m²/kg². It is a fundamental constant that determines the strength of gravity. It was first measured by Henry Cavendish in 1798 using a torsion balance.' },
  { q: 'Why does gravity feel so weak?', a: 'Gravity is the weakest of the four fundamental forces. The electromagnetic force between two protons is about 10³⁶ times stronger than gravity. Gravity only dominates at large scales because it always attracts and never cancels out.' },
  { q: 'How does distance affect gravitational force?', a: 'Gravitational force follows the inverse square law — doubling the distance reduces the force to one-quarter. Tripling the distance reduces it to one-ninth. This is why objects feel much lighter on a high mountain.' },
  { q: 'Can gravitational force ever be repulsive?', a: 'In Newtonian gravity, no — gravity is always attractive. General relativity allows for repulsive gravity effects through dark energy (cosmological constant), but on everyday scales gravity is always attractive.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter the masses and distance to calculate the gravitational force</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass 1 (m₁)</span>
        <input id="m1" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass 2 (m₂)</span>
        <input id="m2" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Distance (r)</span>
        <input id="r" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mb-4 mt-4 flex gap-2">
      <button id="preset-earth" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Earth (5.97×10²⁴ kg)</button>
      <button id="preset-moon" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Moon (7.35×10²² kg)</button>
      <button id="preset-sun" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Sun (1.99×10³⁰ kg)</button>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Gravitational force</div><div id="r-force" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Force in scientific notation</div><div id="r-sci" class="mt-1 text-lg font-mono text-slate-800">—</div></div>
    </div>
    <p id="grav-err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="grav-title grav-desc">
      <title id="grav-title">Two masses with gravitational force arrow</title>
      <desc id="grav-desc">Two spherical masses m₁ and m₂ separated by distance r, with a double-headed arrow showing the attractive gravitational force between them</desc>
      <g transform="translate(30,20)">
        <circle cx="180" cy="150" r="70" fill="url(#g1)" stroke="#6366f1" stroke-width="3"/>
        <defs><radialGradient id="g1"><stop offset="0%" stop-color="#c7d2fe"/><stop offset="100%" stop-color="#6366f1"/></radialGradient></defs>
        <text x="180" y="145" text-anchor="middle" fill="white" font-size="20" font-weight="bold">m₁</text>
        <text x="180" y="168" text-anchor="middle" fill="#eef2ff" font-size="12">Mass 1</text>
        <circle cx="560" cy="150" r="50" fill="url(#g2)" stroke="#ef4444" stroke-width="3"/>
        <defs><radialGradient id="g2"><stop offset="0%" stop-color="#fecaca"/><stop offset="100%" stop-color="#ef4444"/></radialGradient></defs>
        <text x="560" y="145" text-anchor="middle" fill="white" font-size="20" font-weight="bold">m₂</text>
        <text x="560" y="168" text-anchor="middle" fill="#fef2f2" font-size="12">Mass 2</text>
        <line x1="250" y1="150" x2="510" y2="150" stroke="#f59e0b" stroke-width="2.5" stroke-dasharray="8 4"/>
        <polygon points="250,150 260,143 260,157" fill="#f59e0b"/>
        <polygon points="510,150 500,143 500,157" fill="#f59e0b"/>
        <text x="380" y="138" text-anchor="middle" fill="#f59e0b" font-size="16" font-weight="bold">r</text>
        <text x="380" y="175" text-anchor="middle" fill="#64748b" font-size="13">Distance</text>
        <text x="380" y="260" text-anchor="middle" fill="#4338ca" font-size="20" font-weight="bold">F = G × m₁ × m₂ / r²</text>
        <text x="380" y="282" text-anchor="middle" fill="#64748b" font-size="13">G = 6.674 × 10⁻¹¹ N·m²/kg²</text>
      </g>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Two masses m₁ and m₂ attract each other with a gravitational force F proportional to the product of their masses and inversely proportional to the square of the distance r between them.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How gravitational force is calculated</h2>
    <p class="mt-2 text-slate-600">Newton's law of universal gravitation states that every object with mass attracts every other object with a force given by <span class="font-mono">F = G × m₁ × m₂ / r²</span>. The gravitational constant G has the extremely small value of 6.67430 × 10⁻¹¹ N·m²/kg², which is why we don't feel the gravitational attraction between everyday objects. The force is always attractive and acts along the line connecting the centres of mass. The inverse square relationship means that the force drops rapidly with distance.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">What is the gravitational force between the Earth (5.97 × 10²⁴ kg) and a 70 kg person standing on the surface (r = 6.37 × 10⁶ m)?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Earth mass:</span> <span class="text-slate-600">5.97 × 10²⁴ kg</span></div>
        <div><span class="font-medium text-slate-700">Person mass:</span> <span class="text-slate-600">70 kg</span></div>
        <div><span class="font-medium text-slate-700">Earth radius:</span> <span class="text-slate-600">6.37 × 10⁶ m</span></div>
        <div><span class="font-medium text-slate-700">Force:</span> <span class="text-slate-600">F ≈ 687 N (about 70 kg × 9.81 m/s²)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F30D;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Astrophysicist</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate gravitational forces between celestial bodies to understand orbits, tidal forces, and the dynamics of star systems and galaxies. Essential for predicting planetary motion.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F6E1;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Aerospace Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Design satellite orbits and interplanetary trajectories. Calculate the gravitational force at different altitudes to determine orbital velocity, transfer orbits, and escape velocity.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F30E;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Geophysicist</h3>
      <p class="mt-1 text-sm text-slate-600">Study the Earth's gravitational field to map subsurface geology, detect mineral deposits, and understand the structure of the Earth's interior from crust to core.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4DA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Physics Educator</h3>
      <p class="mt-1 text-sm text-slate-600">Demonstrate the inverse square law and the universality of gravity. Show that gravity acts between all objects, not just large celestial bodies, using the calculator with everyday masses.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the gravitational force calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the masses</h3>
        <p class="mt-1 text-sm text-slate-600">Type the masses of both objects in kilograms. Use the preset buttons to quickly enter the mass of Earth, the Moon, or the Sun.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the distance</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the distance between the centres of mass in metres. For objects on Earth's surface, use the Earth's radius (6.37 × 10⁶ m).</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The force is shown in newtons and in scientific notation. For very small or very large forces, the scientific notation makes the result easy to read and compare.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for gravitational calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">G is very small</h3>
        <p class="mt-1 text-sm text-slate-600">At 6.674 × 10⁻¹¹, G is tiny. The gravitational force between two 1 kg objects 1 metre apart is only 6.67 × 10⁻¹¹ N — about the weight of a bacterium. This is why we only notice gravity from planet-sized objects.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Distance is from centre to centre</h3>
        <p class="mt-1 text-sm text-slate-600">For spherical objects like planets, the distance r is measured from the centre of one sphere to the centre of the other. For objects on the surface, r is the planet's radius plus any additional height.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Superposition principle</h3>
        <p class="mt-1 text-sm text-slate-600">When multiple masses are involved, the net gravitational force on any object is the vector sum of the forces from each other mass. This is how tidal forces and orbital perturbations are calculated.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/force-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4A5;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Force Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">F = ma — solve for any variable.</p>
      </a>
      <a href="/tools/potential-energy-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4C8;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Potential Energy Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">PE = mgh — gravitational potential energy.</p>
      </a>
      <a href="/tools/free-fall-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2B07;&#xFE0F;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Free Fall Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Time and velocity under gravity.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const G = 6.67430e-11;
    const el = (id) => document.getElementById(id);
    const fmt = (v) => parseFloat(v.toPrecision(4)).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 4 });
    function toSci(v) {
      if (v === 0) return '0';
      const exp = Math.floor(Math.log10(Math.abs(v)));
      const mantissa = v / Math.pow(10, exp);
      return mantissa.toFixed(4) + ' × 10^' + exp;
    }
    function update() {
      const m1 = parseFloat(el('m1').value);
      const m2 = parseFloat(el('m2').value);
      const r = parseFloat(el('r').value);
      el('grav-err').textContent = '';
      if (isNaN(m1) || isNaN(m2) || isNaN(r)) { el('r-force').textContent = '—'; el('r-sci').textContent = '—'; return; }
      if (m1 <= 0 || m2 <= 0 || r <= 0) { el('grav-err').textContent = 'Masses and distance must be positive.'; el('r-force').textContent = '—'; el('r-sci').textContent = '—'; return; }
      const f = G * m1 * m2 / (r * r);
      el('r-force').textContent = fmt(f) + ' N';
      el('r-sci').textContent = toSci(f) + ' N';
    }
    el('preset-earth').addEventListener('click', () => { el('m1').value = '5.97e24'; update(); });
    el('preset-moon').addEventListener('click', () => { el('m1').value = '7.35e22'; update(); });
    el('preset-sun').addEventListener('click', () => { el('m1').value = '1.99e30'; update(); });
    ['m1', 'm2', 'r'].forEach(id => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
