---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'ASCII Code Converter';
const description =
  'Free online ASCII code converter. Convert characters to their ASCII (decimal, hex, binary) codes and back. Supports full ASCII table.';
const intro =
  'Type any character to see its ASCII code in decimal, hex, binary and octal, or enter a code to find the character.';
const category = { id: 'converters', name: 'Converters' };
const faqs = [
  { q: 'What is ASCII?', a: 'ASCII (American Standard Code for Information Interchange) is a character encoding standard that assigns numeric codes to letters, digits, punctuation, and control characters. It uses 7 bits to represent 128 characters (0–127).' },
  { q: 'What is the difference between ASCII and Unicode?', a: 'ASCII is a 7-bit encoding covering 128 characters. Unicode is a much larger standard that can represent over a million characters from all writing systems. The first 128 Unicode code points are identical to ASCII for backward compatibility.' },
  { q: 'What are the ASCII character categories?', a: 'ASCII divides into three groups: control characters (0–31) for non-printable functions, printable characters (32–126) including letters, digits, and punctuation, and DEL (127) which is a special control character.' },
  { q: 'What are control characters used for?', a: 'Control characters (0–31) were designed for teletype and terminal control. Examples include NUL (null), LF (line feed), CR (carriage return), TAB (horizontal tab), and ESC (escape). Many are still used in text protocols today.' },
  { q: 'How do I convert a character to ASCII code?', a: 'Type a single character in the input field and click Convert. The tool shows its ASCII code in decimal, hexadecimal, binary, and octal formats, plus its HTML entity and category.' },
  { q: 'Can I convert multiple characters at once?', a: 'Yes. Enter a string of characters and the tool will show the code for each character. For bulk conversion, each character displays its own set of codes.' },
  { q: 'What is the ASCII code for space?', a: 'The space character has ASCII decimal code 32, hexadecimal 20, binary 00100000, and octal 40. It is classified as a printable character.' },
  { q: 'What is extended ASCII?', a: 'Extended ASCII refers to 8-bit encodings (128–255) that vary by character set. Code page 437 (IBM PC) and ISO 8859-1 (Latin-1) are common extended ASCII variants with different characters in positions 128–255.' },
  { q: 'Why does my converted character show 63?', a: '63 is the ASCII code for a question mark (?). Some characters cannot be represented in ASCII and are converted to a question mark by the browser. Use the character-to-code mode to check if your character has a valid ASCII code.' },
  { q: 'Is ASCII case-sensitive?', a: 'Yes. Uppercase A (65) and lowercase a (97) have different ASCII codes. They differ by exactly 32 in decimal, which is a single bit flip in binary.' },
];

function asciiCategory(code) {
  if (code < 32) return 'Control';
  if (code === 127) return 'Control (DEL)';
  if (code < 128) return 'Printable';
  return 'Extended';
}
---

<ToolLayout {title} {description} {intro} {category} {faqs} appCategory="UtilitiesApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex flex-wrap items-center gap-2">
      <button id="char-to-code-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Char → Code</button>
      <button id="code-to-char-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Code → Char</button>
      <button id="copy-btn" class="ml-auto rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Copy result</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
    </div>

    <div id="status" class="mt-3 hidden rounded-lg px-3 py-2 text-sm font-medium"></div>

    <input
      id="input"
      type="text"
      placeholder="Type a character or ASCII code (0–255)…"
      class="mt-3 w-full rounded-xl border border-slate-300 p-4 font-mono text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    />

    <div id="results" class="mt-4 hidden">
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Decimal</p>
          <p id="res-dec" class="mt-1 text-2xl font-bold text-slate-900 font-mono"></p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Hexadecimal</p>
          <p id="res-hex" class="mt-1 text-2xl font-bold text-slate-900 font-mono"></p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Binary</p>
          <p id="res-bin" class="mt-1 text-2xl font-bold text-slate-900 font-mono"></p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wide">Octal</p>
          <p id="res-oct" class="mt-1 text-2xl font-bold text-slate-900 font-mono"></p>
        </div>
      </div>
      <div class="mt-3 flex flex-wrap gap-3 text-sm">
        <span class="rounded-lg bg-slate-100 px-3 py-1.5 text-slate-700"><strong>Character:</strong> <span id="res-char" class="font-mono"></span></span>
        <span class="rounded-lg bg-slate-100 px-3 py-1.5 text-slate-700"><strong>HTML Entity:</strong> <span id="res-html" class="font-mono"></span></span>
        <span class="rounded-lg bg-slate-100 px-3 py-1.5 text-slate-700"><strong>Category:</strong> <span id="res-cat" class="font-mono"></span></span>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How ASCII code conversion works</h2>
    <p class="mt-2 text-slate-600">ASCII (American Standard Code for Information Interchange) assigns a unique 7-bit numeric code (0&ndash;127) to each character. The converter maps characters to their ASCII decimal values using JavaScript's charCodeAt() method, then converts that decimal value to other common representations — hexadecimal (base-16), binary (base-2), and octal (base-8).</p>
    <p class="mt-3 text-slate-600">For the reverse direction (code to character), the converter accepts a decimal number between 0 and 255 and returns the corresponding character using String.fromCharCode(). The tool also identifies the character's category — control character (0&ndash;31, 127), printable (32&ndash;126), or extended ASCII (128&ndash;255) — and shows its HTML entity and control character name where applicable.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Char "A":</span> <span class="text-slate-600">65 (decimal), 0x41 (hex), 01000001 (binary)</span></div>
        <div><span class="font-medium text-slate-700">Char "Z":</span> <span class="text-slate-600">90, 0x5A, 01011010</span></div>
        <div><span class="font-medium text-slate-700">Char "a":</span> <span class="text-slate-600">97, 0x61, 01100001</span></div>
        <div><span class="font-medium text-slate-700">Char "0":</span> <span class="text-slate-600">48, 0x30, 00110000</span></div>
        <div><span class="font-medium text-slate-700">Space:</span> <span class="text-slate-600">32, 0x20, 00100000</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">ASCII character categories</h2>
    <p class="mt-2 text-slate-600">Distribution of characters across the full ASCII table.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Control (0–31)</span><span class="text-slate-400">12% of ASCII</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:12%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Printable (32–126)</span><span class="text-slate-400">37%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:37%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Extended (127–255)</span><span class="text-slate-400">51%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:51%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F469;&#x200D;&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Priya Nair</h3>
      <p class="mt-1 text-sm text-slate-600">Developer who needs to check ASCII codes when implementing custom serial protocols and debugging character encoding issues in network applications.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Liam O'Brien</h3>
      <p class="mt-1 text-sm text-slate-600">CS student learning about character encoding, binary representation, and how computers store text at the fundamental level.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F527;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Yuki Tanaka</h3>
      <p class="mt-1 text-sm text-slate-600">Embedded engineer who works with microcontrollers that use ASCII for serial communication and needs to convert between characters and hex codes.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F6E1;&#xFE0F;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Alex Rivera</h3>
      <p class="mt-1 text-sm text-slate-600">Cybersecurity analyst who inspects raw packet data and needs to identify control characters and their hex values in network traffic dumps.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
