        <tr><td class="p-3">44</td><td class="p-3">2C</td><td class="p-3">,</td><td class="p-3">76</td><td class="p-3">4C</td><td class="p-3">L</td><td class="p-3">108</td><td class="p-3">6C</td><td class="p-3">l</td></tr>
        <tr><td class="p-3">45</td><td class="p-3">2D</td><td class="p-3">-</td><td class="p-3">77</td><td class="p-3">4D</td><td class="p-3">M</td><td class="p-3">109</td><td class="p-3">6D</td><td class="p-3">m</td></tr>
