---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Ideal Gas Law Calculator';
const description = 'Ideal gas law calculator with a live 3D gas-particle diagram and charts. Solve PV=nRT for pressure, volume, moles, or temperature, with STP presets and worked examples.';
const intro = 'Enter any four of pressure, volume, moles, or temperature to solve for the fifth using PV = nRT. Two 3D diagrams compare gas at low and high temperature, and charts show how pressure and volume respond to changing conditions.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is the ideal gas law?', a: 'The ideal gas law is PV = nRT, where P is pressure, V is volume, n is the number of moles, R is the gas constant, and T is temperature in kelvin.' },
  { q: 'What value of R should I use?', a: 'R = 0.082057 L·atm/(mol·K) when using litres, atmospheres, moles, and kelvin. R = 8.3145 J/(mol·K) applies when using SI units (m³, Pa, mol, K) instead.' },
  { q: 'When does the ideal gas law break down?', a: 'At high pressures and low temperatures, real gases deviate from ideal behavior because intermolecular forces and molecular volume become significant — the van der Waals equation provides corrections for these effects.' },
  { q: 'What is STP?', a: 'STP (Standard Temperature and Pressure) is traditionally 0°C (273.15 K) and 1 atm. At STP, one mole of an ideal gas occupies 22.414 litres — a useful reference volume in stoichiometry problems.' },
  { q: 'Why must temperature be in kelvin?', a: 'The ideal gas law requires an absolute temperature scale where zero truly means zero volume/pressure for an ideal gas — kelvin satisfies this, while Celsius (which allows negative values) does not. Convert from Celsius by adding 273.15.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Ideal Gas Law Calculator',
  description: 'Solve PV=nRT for pressure, volume, moles, or temperature from any four known values.',
  steps: [
    { name: 'Enter four values or use a preset', text: 'Fill in any four of pressure, volume, moles, and temperature, or click STP or room-temperature presets.' },
    { name: 'Read the result', text: 'The fifth value solves instantly using PV=nRT.' },
    { name: 'Double-check units', text: 'Ensure temperature is in kelvin — the calculator uses R = 0.08206 L·atm/(mol·K).' },
  ],
};

const formulas = [
  { expr: 'PV = nRT', note: 'the ideal gas law — R = 0.08206 L·atm/(mol·K)' },
  { expr: 'V = nRT / P', note: 'rearranged to solve for volume' },
  { expr: 'T = PV / (nR)', note: 'rearranged to solve for temperature (must be in kelvin)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — gas volume at room temperature', tone: 'slate',
    given: 'What volume does 2.0 moles of an ideal gas occupy at 25°C and 1.5 atm?',
    rows: [
      { label: 'Convert temperature:', value: 'T = 25°C + 273.15 = 298.15 K' },
      { label: 'Formula:', value: 'V = nRT / P' },
      { label: 'Substitute:', value: 'V = (2.0 × 0.08206 × 298.15) / 1.5' },
      { label: 'Result:', value: 'V ≈ 32.6 L', full: true },
    ],
    note: 'Converting Celsius to kelvin before substituting is essential — using 25 directly instead of 298.15 would give a badly wrong answer.',
  },
  {
    title: 'Worked example 2 — pressure inside a sealed container', tone: 'amber',
    given: 'A rigid 10 L container holds 0.5 mol of gas at 350 K. Find the pressure.',
    rows: [
      { label: 'Formula:', value: 'P = nRT / V' },
      { label: 'Substitute:', value: 'P = (0.5 × 0.08206 × 350) / 10' },
      { label: 'Result:', value: 'P ≈ 1.436 atm', full: true },
    ],
    note: 'This is exactly the kind of calculation engineers use to predict pressure buildup in a sealed vessel as temperature rises.',
  },
];

const comparison = {
  heading: 'Molar volume at different standard conditions',
  note: 'The volume one mole of ideal gas occupies depends on the exact pressure/temperature reference chosen — a common source of confusion between older and IUPAC-current STP definitions.',
  headers: [{ label: 'Condition' }, { label: 'T' }, { label: 'P' }, { label: 'Molar volume' }],
  rows: [
    ['Traditional STP ★', '273.15 K', '1 atm', '22.414 L'],
    ['IUPAC STP (post-1982)', '273.15 K', '1 bar', '22.711 L'],
    ['Room temperature (25°C)', '298.15 K', '1 atm', '24.465 L'],
  ],
  highlightIndex: 0,
  footnote: '★ The traditional definition (0°C, 1 atm) is still the one most commonly used in introductory chemistry courses and this calculator\'s STP preset.',
};

const realWorld = [
  { emoji: '🏭', title: 'Chemical process engineering', body: 'Chemical engineers use the ideal gas law as a first approximation to design reactors, pipelines, and storage tanks, calculating gas volumes under a range of pressures and temperatures.' },
  { emoji: '💨', title: 'Atmospheric science and meteorology', body: 'Understanding how pressure and temperature change with altitude — key to weather forecasting and cloud formation — relies directly on gas law relationships.' },
  { emoji: '🎈', title: 'Scuba diving and pressure vessels', body: 'Divers and engineers designing pressurized tanks must account for how gas volume and pressure trade off as depth (and therefore pressure) changes, following the same PV=nRT relationship.' },
  { emoji: '🧪', title: 'Stoichiometry with gaseous products', body: 'Chemistry students and researchers use the ideal gas law to convert between moles of a gaseous reactant or product and its volume under specific lab conditions.' },
];

const misconceptions = [
  { claim: '"The ideal gas law works perfectly for any gas under any condition."', truth: 'It is an approximation that breaks down at high pressure and low temperature, where intermolecular forces and the actual volume of gas molecules become significant — the van der Waals equation adds correction terms for these effects.' },
  { claim: '"You can use Celsius directly in PV=nRT."', truth: 'Temperature must always be converted to kelvin first — using Celsius directly (which can be negative or zero at physically normal conditions) breaks the proportional relationship the ideal gas law depends on.' },
  { claim: '"STP always means the same fixed pressure and temperature."', truth: 'STP has actually changed definition over time — older textbooks use 0°C and 1 atm (22.414 L/mol), while the modern IUPAC definition uses 0°C and 1 bar (22.711 L/mol), a small but real difference.' },
  { claim: '"Doubling pressure always doubles temperature for a fixed gas sample."', truth: 'Only if volume is held constant — PV=nRT shows that pressure, volume, and temperature are all interrelated, so how one change affects another depends on which variable is actually being held fixed.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 9, "Gases" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/9-3-stoichiometry-of-gaseous-substances-mixtures-and-reactions" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 10, Gases.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — The ideal gas law.' },
];
const sourcesNote = 'PV=nRT, R=0.082057 L·atm/(mol·K). Temperature must be in kelvin. Results are rounded for display.';

const howToUse = [
  { title: 'Enter four values', body: 'Fill in any four of P, V, n, T, or use the STP/room-temperature preset buttons.' },
  { title: 'Read the fifth value', body: 'The unknown variable solves instantly using PV=nRT.' },
  { title: 'Check your units', body: 'Confirm temperature is in kelvin — a common source of calculation errors.' },
];

const related = [
  { href: '/tools/gas-laws-calculator', emoji: '🔄', title: "Boyle's & Charles's Law Calculator", desc: 'Combined gas law with mode switch.' },
  { href: '/tools/density-calculator', emoji: '⚖️', title: 'Density Calculator', desc: 'Solve density, mass, or volume from any two.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'M = mol/L — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="the ideal gas law unifies Boyle's, Charles's, Avogadro's, and Gay-Lussac's laws into one equation, treating a gas as though its molecules take up negligible volume and never interact — an excellent approximation for most gases at ordinary pressures and temperatures."
  howIntro="PV=nRT combines four separate historical gas laws that were each discovered by holding different variables fixed: Boyle's law (PV=constant at fixed T,n), Charles's law (V∝T at fixed P,n), Gay-Lussac's law (P∝T at fixed V,n), and Avogadro's law (V∝n at fixed P,T). R, the universal gas constant, is the proportionality factor that ties all four relationships together into a single equation valid across changing conditions."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the ideal gas law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any four values to solve for the fifth.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Pressure (P)</span>
        <input id="p" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume (V)</span>
        <input id="v" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Moles (n)</span>
        <input id="n" type="number" step="any" placeholder="mol" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature (T)</span>
        <input id="t" type="number" step="any" placeholder="K" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mb-4 mt-4 flex flex-wrap gap-2">
      <button id="preset-stp" type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">STP: 1 atm, 273.15 K, 1 mol</button>
      <button id="preset-rt" type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Room temp: 1 atm, 298 K</button>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Pressure</div><div id="r-p" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Volume</div><div id="r-v" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Moles</div><div id="r-n" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Temperature</div><div id="r-t" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="gas-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Gas particles at low vs high temperature</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-cold" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Gas at low temperature</h3>
          <p class="mt-1 text-sm text-slate-600">Particles move slower and stay closer together in the same container — lower pressure at the same volume.</p>
        </div>
        <div>
          <div id="diag-hot" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Gas at high temperature</h3>
          <p class="mt-1 text-sm text-slate-600">Particles move faster and collide with the container walls more forcefully — higher pressure at the same volume.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Ideal gas law graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pressure vs temperature (fixed n=1 mol, V=10 L)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Volume vs pressure (fixed n=1 mol, T=298 K)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vp"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const R = 0.082057;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator (preserves original four-of-five solve logic) ----
      function update() {
        const p = parseFloat(el('p').value);
        const v = parseFloat(el('v').value);
        const n = parseFloat(el('n').value);
        const t = parseFloat(el('t').value);
        const filled = [!isNaN(p), !isNaN(v), !isNaN(n), !isNaN(t)];
        const count = filled.filter(Boolean).length;
        el('gas-err').textContent = '';
        ['r-p', 'r-v', 'r-n', 'r-t'].forEach((id) => (el(id).textContent = '—'));
        if (count < 4) return;
        let rp = NaN, rv = NaN, rn = NaN, rt = NaN;
        if (!filled[0]) { if (v === 0 || n === 0) { el('gas-err').textContent = 'Volume and moles cannot be zero.'; return; } rp = (n * R * t) / v; rv = v; rn = n; rt = t; }
        else if (!filled[1]) { if (p === 0) { el('gas-err').textContent = 'Pressure cannot be zero.'; return; } rv = (n * R * t) / p; rp = p; rn = n; rt = t; }
        else if (!filled[2]) { if (R * t === 0) { el('gas-err').textContent = 'Temperature cannot be zero.'; return; } rn = (p * v) / (R * t); rp = p; rv = v; rt = t; }
        else if (!filled[3]) { if (n * R === 0) { el('gas-err').textContent = 'Moles cannot be zero.'; return; } rt = (p * v) / (n * R); rp = p; rv = v; rn = n; }
        if (!isNaN(rp)) el('r-p').textContent = fmt(rp) + ' atm';
        if (!isNaN(rv)) el('r-v').textContent = fmt(rv) + ' L';
        if (!isNaN(rn)) el('r-n').textContent = fmt(rn) + ' mol';
        if (!isNaN(rt)) el('r-t').textContent = fmt(rt) + ' K';
      }
      el('preset-stp').addEventListener('click', () => { el('p').value = '1'; el('t').value = '273.15'; el('n').value = '1'; el('v').value = ''; update(); });
      el('preset-rt').addEventListener('click', () => { el('t').value = '298.15'; el('p').value = '1'; el('n').value = '1'; el('v').value = ''; update(); });
      ['p', 'v', 'n', 't'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsT = [], dataP = [];
        for (let t = 200; t <= 500; t += 30) { labelsT.push(t); dataP.push(+((1 * R * t) / 10).toFixed(3)); }
        charts.pt = new Chart(el('chart-pt'), {
          type: 'line',
          data: { labels: labelsT, datasets: [{ label: 'P (atm)', data: dataP, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Temperature (K)' } }, y: { title: { display: true, text: 'Pressure (atm)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsP = [], dataV = [];
        for (let p = 0.5; p <= 5; p += 0.5) { labelsP.push(p.toFixed(1)); dataV.push(+((1 * R * 298) / p).toFixed(2)); }
        charts.vp = new Chart(el('chart-vp'), {
          type: 'line',
          data: { labels: labelsP, datasets: [{ label: 'V (L)', data: dataV, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Pressure (atm)' } }, y: { title: { display: true, text: 'Volume (L)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function gasScene(container, count, speed) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const box = new THREE.Mesh(new THREE.BoxGeometry(4, 3, 3), new THREE.MeshBasicMaterial({ color: 0x94a3b8, wireframe: true }));
        s.scene.add(box);
        const particles = [];
        for (let i = 0; i < count; i++) {
          const p = new THREE.Mesh(new THREE.SphereGeometry(0.15, 10, 8), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
          p.position.set((Math.random() - 0.5) * 3.5, (Math.random() - 0.5) * 2.5, (Math.random() - 0.5) * 2.5);
          s.scene.add(p);
          particles.push(p);
        }
        function frame() {
          requestAnimationFrame(frame);
          if (!reduceMotion) { s.spin(0.002); particles.forEach((p) => { p.position.x += (Math.random() - 0.5) * speed; p.position.y += (Math.random() - 0.5) * speed; }); }
          s.renderer.render(s.scene, s.camera);
        }
        frame();
        return { resize: s.resize };
      }
      let diagCold = null, diagHot = null;
      function initDiagCold() { const c = el('diag-cold'); if (!c) throw new Error('no container'); diagCold = gasScene(c, 12, 0.01); }
      function initDiagHot() { const c = el('diag-hot'); if (!c) throw new Error('no container'); diagHot = gasScene(c, 12, 0.05); }

      function boot() {
        try { update(); } catch (e) { console.error('[ideal-gas-law] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[ideal-gas-law] charts failed', e); }
        if (window.THREE) {
          try { initDiagCold(); } catch (e) { console.error('[ideal-gas-law] cold diagram failed', e); }
          try { initDiagHot(); } catch (e) { console.error('[ideal-gas-law] hot diagram failed', e); }
        }
        mountResize([diagCold, diagHot]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
