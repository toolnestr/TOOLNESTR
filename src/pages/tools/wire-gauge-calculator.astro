    function update() {
      const awgVal = el('awg').value;
      const mat = el('material').value;
      const len = parseFloat(el('length').value);
      const cur = parseFloat(el('current').value);
      const d = data[awgVal];

      const isCu = mat === 'cu';
      const ohmsPerM = isCu ? d.cuOhms : d.alOhms;
      const ampacity = isCu ? d.cuAmp : d.alAmp;

      el('r-dia').textContent = d.dia.toFixed(3) + ' mm';
      el('r-area').textContent = d.area.toFixed(2) + ' mm\u00b2';
      el('r-res').textContent = ohmsPerM.toFixed(5) + ' \u03a9/m';
      el('r-amp').textContent = ampacity + ' A';

      if (!isNaN(len) && !isNaN(cur) && len > 0 && cur > 0) {
        const totalR = ohmsPerM * len;
        const vDrop = cur * totalR;
        const pLoss = cur * cur * totalR;
        el('r-vdrop').textContent = vDrop.toFixed(3) + ' V';
        el('r-ploss').textContent = pLoss.toFixed(2) + ' W';
      } else {
        el('r-vdrop').textContent = '\u2014';
        el('r-ploss').textContent = '\u2014';
      }
    }

    ['awg','material','length','current'].forEach(id => {
      const elm = el(id);
      if (elm) elm.addEventListener('input', update);
    });
    ['awg','material'].forEach(id => el(id).addEventListener('change', update));
  </script>
