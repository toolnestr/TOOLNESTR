---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Base64 Encode / Decode';
const description =
  'Free online Base64 encoder and decoder. Convert text to Base64 and back instantly. ' +
  'Supports emojis and all languages (UTF-8). Runs privately in your browser.';
const intro =
  'Paste text to encode it to Base64, or paste Base64 to decode it back to text. It handles emojis and every language correctly.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'What is Base64?', a: 'Base64 is a way of representing binary data or text using 64 safe characters. It is often used to embed data in URLs, emails, JSON or HTML.' },
  { q: 'Does it support emojis and other languages?', a: 'Yes. The tool uses UTF-8, so emojis, accents and non-Latin scripts encode and decode correctly.' },
  { q: 'Why do I get a "could not decode" message?', a: 'The input isn\'t valid Base64. Check for missing characters, extra spaces, or that you actually pasted Base64 and not plain text.' },
  { q: 'Is my data private?', a: 'Yes. Everything is processed in your browser — nothing is uploaded.' },
  { q: 'What is URL-safe Base64?', a: 'Standard Base64 uses + and / characters which can cause issues in URLs. URL-safe mode replaces them with - and _ and removes padding for safe inclusion in query strings.' },
  { q: 'Can I encode binary files?', a: 'This tool works with text input. For encoding binary files (images, documents), you would typically use a dedicated file-to-Base64 tool or a programming library.' },
  { q: 'What should I do if decoding fails?', a: 'Check that the input hasn\'t been truncated, contains no extra whitespace or line breaks, and is actually Base64-encoded text.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="DeveloperApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea
      id="input"
      rows="6"
      placeholder="Type or paste your text or Base64 here…"
      class="w-full resize-y rounded-xl border border-slate-300 p-4 font-mono text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>

    <div class="mt-3 flex flex-wrap items-center gap-2">
      <button id="encode-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Encode →</button>
      <button id="decode-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">← Decode</button>
      <label class="ml-1 flex items-center gap-1.5 text-sm text-slate-600">
        <input id="urlsafe" type="checkbox" class="h-4 w-4 rounded border-slate-300" /> URL-safe
      </label>
      <button id="copy-btn" class="ml-auto rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Copy result</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
    </div>

    <div id="status" class="mt-3 hidden rounded-lg px-3 py-2 text-sm font-medium"></div>
    <textarea
      id="output"
      rows="6"
      readonly
      placeholder="Result appears here…"
      class="mt-3 w-full resize-y rounded-xl border border-slate-200 bg-slate-50 p-4 font-mono text-sm outline-none"
    ></textarea>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About Base64 encoding</h2>
    <p class="mt-2 text-slate-600">
      Base64 turns text (or any data) into a string of safe characters that can travel through
      systems that only handle plain text — like URLs, email headers, JSON and data URIs.
      Developers use it constantly. This tool encodes and decodes instantly, with full UTF-8
      support so emojis and every language work correctly, all without sending your data anywhere.
      Combine it with the <a href="/tools/json-formatter" class="font-medium text-indigo-600 hover:underline">JSON Formatter</a>
      to decode Base64 payloads from APIs, or use the <a href="/tools/qr-generator" class="font-medium text-indigo-600 hover:underline">QR Code Generator</a>
      to encode text into scannable codes.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Paste your text or Base64 into the top box.</li>
      <li>Click “Encode” to convert to Base64, or “Decode” to convert back.</li>
      <li>Tick “URL-safe” if you need a Base64 string that’s safe inside URLs.</li>
      <li>Copy the result from the bottom box.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Base64 encoding is essential whenever you need to transmit binary or structured data through text-only channels. Web developers embed small images as Base64 data URIs directly in HTML or CSS to reduce HTTP requests. API developers encode binary payloads in JSON responses. Email systems use Base64 to attach files to messages. Authentication systems encode credentials in Basic Auth headers. Even web designers use it to inline fonts or icons in stylesheets for faster page loads.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Enable "URL-safe" mode if the Base64 string will be used in a URL query parameter — this replaces + and / with - and _.</li>
      <li>Make sure to copy the complete encoded or decoded string — partial data will result in corrupted output.</li>
      <li>Use "Clear" to reset both input and output fields quickly when starting a new conversion.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const input = el('input'), output = el('output'), status = el('status'), urlsafe = el('urlsafe');

    function show(msg, ok) {
      status.textContent = msg;
      status.className = 'mt-3 rounded-lg px-3 py-2 text-sm font-medium ' + (ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700');
      status.classList.remove('hidden');
    }

    function encode() {
      const bytes = new TextEncoder().encode(input.value);
      let bin = '';
      bytes.forEach((b) => (bin += String.fromCharCode(b)));
      let b64 = btoa(bin);
      if (urlsafe.checked) b64 = b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
      output.value = b64;
      show('Encoded to Base64 ✓', true);
    }

    function decode() {
      try {
        let str = input.value.trim().replace(/\s/g, '');
        str = str.replace(/-/g, '+').replace(/_/g, '/');
        while (str.length % 4) str += '=';
        const bin = atob(str);
        const bytes = Uint8Array.from(bin, (c) => c.charCodeAt(0));
        output.value = new TextDecoder().decode(bytes);
        show('Decoded from Base64 ✓', true);
      } catch (e) {
        output.value = '';
        show('⚠️ Could not decode — that doesn’t look like valid Base64.', false);
      }
    }

    el('encode-btn').addEventListener('click', encode);
    el('decode-btn').addEventListener('click', decode);
    el('clear-btn').addEventListener('click', () => { input.value = ''; output.value = ''; status.classList.add('hidden'); input.focus(); });
    el('copy-btn').addEventListener('click', async () => {
      if (!output.value) return;
      try {
        await navigator.clipboard.writeText(output.value);
        const b = el('copy-btn'); const o = b.textContent; b.textContent = 'Copied!'; setTimeout(() => (b.textContent = o), 1200);
      } catch (e) {}
    });
  </script>
</ToolLayout>
