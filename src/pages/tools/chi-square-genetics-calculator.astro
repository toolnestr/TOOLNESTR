---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Chi-Square Goodness of Fit Calculator (Genetics)';
const description = "Chi-square genetics calculator: test whether observed offspring counts fit a predicted ratio like 3:1 or 9:3:3:1, with Mendel's pea data as an example.";
const intro = 'Enter observed offspring counts and an expected ratio to compute χ² = Σ(O−E)²/E, testing whether your data statistically matches the predicted Mendelian ratio. Two 3D diagrams compare a close-fitting and a poor-fitting dataset, and charts show observed versus expected counts.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a chi-square goodness of fit test in genetics?', a: 'It is a statistical test that compares observed offspring counts from an actual genetic cross to the counts expected under a hypothesized ratio (like 3:1 or 9:3:3:1), quantifying how well the data fits the Mendelian prediction.' },
  { q: 'How do you calculate chi-square?', a: 'χ² = Σ(O−E)²/E, where O is the observed count and E is the expected count for each phenotype category, summed across all categories.' },
  { q: 'What does a low chi-square value mean?', a: 'A low χ² value means the observed data closely matches the expected ratio — the deviations are small relative to what\'s expected. Famously, Mendel\'s own pea data produced unusually low chi-square values, fitting his predicted ratios almost too perfectly.' },
  { q: 'How do you decide if a chi-square result is significant?', a: 'Compare your calculated χ² to a critical value from a chi-square distribution table, using degrees of freedom (categories−1) and a significance level (typically 0.05). If your χ² exceeds the critical value, the observed data significantly deviates from the expected ratio.' },
  { q: 'What are degrees of freedom in this test?', a: 'Degrees of freedom equal the number of phenotype categories minus 1. A monohybrid cross (2 categories) has 1 degree of freedom; a dihybrid cross (4 categories) has 3.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Chi-Square Goodness of Fit Calculator',
  description: 'Test whether observed offspring counts statistically match a predicted genetic ratio.',
  steps: [
    { name: 'Enter observed counts', text: 'Provide the actual count for each phenotype category from your cross.' },
    { name: 'Enter the expected ratio', text: 'Provide the predicted ratio (like 3:1 or 9:3:3:1) for the same categories.' },
    { name: 'Read the result', text: 'χ², degrees of freedom, and a plain-language fit interpretation solve instantly.' },
  ],
};

const formulas = [
  { expr: 'χ² = Σ(O − E)² / E', note: 'O = observed count, E = expected count, summed across all categories' },
  { expr: 'df = categories − 1', note: 'degrees of freedom for the test' },
  { expr: 'critical value (df=3, p=0.05) = 7.815', note: 'a common threshold for a 4-category test — exceeding it suggests a significant deviation' },
];

const workedExamples = [
  {
    title: "Worked example 1 — Mendel's classic dihybrid pea data", tone: 'slate',
    given: 'Observed: 315 round-yellow, 101 round-green, 108 wrinkled-yellow, 32 wrinkled-green (total 556). Expected ratio: 9:3:3:1.',
    rows: [
      { label: 'Expected counts:', value: '312.75, 104.25, 104.25, 34.75 (from 9:3:3:1 of 556 total)' },
      { label: 'Formula:', value: 'χ² = Σ(O−E)²/E' },
      { label: 'Sum:', value: '(2.25²/312.75) + (3.25²/104.25) + (3.75²/104.25) + (2.75²/34.75)' },
      { label: 'Result:', value: 'χ² ≈ 0.470, df = 3, critical value = 7.815 → good fit (fail to reject 9:3:3:1)', full: true },
    ],
    note: 'This is Mendel\'s own historical dihybrid data — the very low χ² (0.470, far below the 7.815 threshold) shows a remarkably close fit to the predicted ratio.',
  },
  {
    title: 'Worked example 2 — a monohybrid cross with a poor fit', tone: 'amber',
    given: 'Observed: 60 dominant, 40 recessive (total 100). Expected ratio: 3:1 (should be 75:25).',
    rows: [
      { label: 'Expected counts:', value: '75, 25' },
      { label: 'Sum:', value: '(15²/75) + (15²/25) = 3.0 + 9.0' },
      { label: 'Result:', value: 'χ² = 12.0, df = 1, critical value (p=0.05) = 3.841 → poor fit (reject 3:1)', full: true },
    ],
    note: 'Since χ²=12.0 far exceeds the critical value of 3.841, this data significantly deviates from a 3:1 ratio — something other than simple Mendelian inheritance may be occurring.',
  },
];

const comparison = {
  heading: 'Common chi-square critical values (p = 0.05)',
  note: 'Compare your calculated χ² against the value matching your degrees of freedom to judge statistical significance.',
  headers: [{ label: 'Categories' }, { label: 'df' }, { label: 'Critical value (p=0.05)' }],
  rows: [
    ['2 (monohybrid, 3:1)', '1', '3.841'],
    ['3 (1:2:1)', '2', '5.991'],
    ['4 (dihybrid, 9:3:3:1) ★', '3', '7.815'],
    ['5', '4', '9.488'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). A χ² below the critical value means the data is consistent with (fails to reject) the expected ratio.',
};

const realWorld = [
  { emoji: '🌱', title: 'Verifying Mendelian inheritance patterns', body: 'Geneticists use chi-square tests to statistically confirm whether observed offspring ratios genuinely match predicted Mendelian patterns, rather than relying on a "close enough by eye" judgment.' },
  { emoji: '🔬', title: 'Detecting gene linkage', body: 'When a dihybrid cross\'s observed ratio significantly deviates from the expected 9:3:3:1 (a high χ²), it often signals that the two genes are linked rather than assorting independently.' },
  { emoji: '🧬', title: 'Evaluating breeding experiment results', body: 'Agricultural and animal breeding researchers use chi-square tests to confirm whether a cross behaved as predicted before drawing conclusions about a trait\'s inheritance pattern.' },
  { emoji: '📊', title: 'General statistical hypothesis testing', body: 'The chi-square goodness of fit test extends far beyond genetics — it is a general statistical tool for comparing any observed categorical data against a theoretical expected distribution.' },
];

const misconceptions = [
  { claim: '"A high chi-square value proves the cross was done incorrectly."', truth: "A high χ² only indicates the observed data significantly deviates from the hypothesized ratio — this could mean experimental error, but it could equally mean the underlying genetics doesn't follow the assumed simple pattern (e.g. linked genes, or an incorrect number of genes assumed)." },
  { claim: '"A chi-square value of exactly 0 is the best possible, most trustworthy result."', truth: "A chi-square of exactly 0 (a perfect match) is actually somewhat suspicious in a real biological experiment — real data almost always shows some random variation. Historically, some have questioned whether Mendel's remarkably low chi-square values reflect selective reporting, though this remains debated." },
  { claim: '"You can use chi-square to test any sample size, even very small ones."', truth: 'Chi-square tests assume reasonably large expected counts in each category (typically at least 5) — with very small sample sizes, the test becomes unreliable and other statistical methods (like Fisher\'s exact test) are more appropriate.' },
  { claim: '"Failing to reject the expected ratio proves the ratio is definitely correct."', truth: 'A chi-square test that fails to find a significant difference only means the data is consistent with the expected ratio — it does not prove the ratio is true, since a small sample size could fail to detect a real deviation that actually exists.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 12, "Mendel\'s Experiments and Heredity" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/12-3-laws-of-inheritance" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Klug, Cummings &amp; Spencer, <em>Concepts of Genetics</em></strong> — Chapter 3, Chi-Square Analysis.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 14, Mendel and the Gene Idea.' },
];
const sourcesNote = 'χ² = Σ(O−E)²/E, df = categories−1. Critical values are standard chi-square distribution table values (p=0.05). Results are rounded for display.';

const howToUse = [
  { title: 'Enter observed counts', body: 'Type the actual count for each phenotype category (2-4 categories supported).' },
  { title: 'Enter the expected ratio', body: 'Provide the predicted ratio for the same categories, e.g. 3:1 or 9:3:3:1.' },
  { title: 'Read the fit verdict', body: 'χ², degrees of freedom, and a plain-language interpretation solve instantly.' },
];

const related = [
  { href: '/tools/dihybrid-cross-calculator', emoji: '🧬', title: 'Dihybrid Cross Calculator', desc: 'Two-gene cross — the classic 9:3:3:1 phenotype ratio.' },
  { href: '/tools/punnett-square-calculator', emoji: '🧬', title: 'Punnett Square Calculator', desc: 'Monohybrid cross — the classic 3:1 phenotype ratio.' },
  { href: '/tools/recombination-frequency-calculator', emoji: '🔗', title: 'Recombination Frequency Calculator', desc: 'Detect gene linkage from crossover frequency.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="chi-square measures how surprised you should be by your data, given a hypothesized ratio — small, random deviations from the prediction produce a small χ², while large, systematic deviations produce a large one that signals something besides chance is going on."
  howIntro="For each phenotype category, squaring the difference between observed and expected counts removes the sign (so both over- and under-counts count as deviations), and dividing by the expected count scales that squared deviation relative to how large a difference would actually be meaningful for that category's size. Summing this scaled squared-deviation across every category produces χ², which can then be compared against a critical value (from the chi-square distribution, based on degrees of freedom) to judge whether the observed deviation is small enough to attribute to chance, or large enough to reject the hypothesized ratio."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where chi-square goodness of fit actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Enter observed counts and the expected ratio for up to 4 categories.</p>
    <div class="grid gap-3 sm:grid-cols-4">
      <div><label class="block text-xs font-medium text-slate-700">Category 1 obs.</label><input id="o1" type="number" value="315" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Category 2 obs.</label><input id="o2" type="number" value="101" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Category 3 obs.</label><input id="o3" type="number" value="108" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Category 4 obs.</label><input id="o4" type="number" value="32" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Ratio part 1</label><input id="e1" type="number" value="9" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Ratio part 2</label><input id="e2" type="number" value="3" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Ratio part 3</label><input id="e3" type="number" value="3" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
      <div><label class="block text-xs font-medium text-slate-700">Ratio part 4 (0=unused)</label><input id="e4" type="number" value="1" class="mt-1 w-full rounded-lg border border-slate-300 p-2 text-sm" /></div>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">χ²</div><div id="r-chi" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Degrees of freedom</div><div id="r-df" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Verdict (p=0.05)</div><div id="r-verdict" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="chi-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Good fit vs poor fit</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-good" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Close fit (low χ²)</h3>
          <p class="mt-1 text-sm text-slate-600">Observed (amber) and expected (indigo) bars are nearly the same height — small, random deviation.</p>
        </div>
        <div>
          <div id="diag-poor" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Poor fit (high χ²)</h3>
          <p class="mt-1 text-sm text-slate-600">Observed (amber) bars diverge noticeably from expected (indigo) — a systematic deviation, not just chance.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Chi-square graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Observed vs expected — Mendel's dihybrid pea data</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-obs"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Critical χ² values by degrees of freedom (p=0.05)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-critical"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const CRIT = { 1: 3.841, 2: 5.991, 3: 7.815, 4: 9.488 };

      function update() {
        el('chi-err').textContent = '';
        el('r-chi').textContent = '—'; el('r-df').textContent = '—'; el('r-verdict').textContent = '—';
        const obs = [1, 2, 3, 4].map((i) => parseFloat(el('o' + i).value));
        const ratios = [1, 2, 3, 4].map((i) => parseFloat(el('e' + i).value));
        const validIdx = ratios.map((r, i) => (!isNaN(r) && r > 0 ? i : -1)).filter((i) => i >= 0);
        if (validIdx.length < 2) { el('chi-err').textContent = 'Provide at least 2 valid ratio categories.'; return; }
        if (validIdx.some((i) => isNaN(obs[i]) || obs[i] < 0)) { el('chi-err').textContent = 'Provide a non-negative observed count for each used category.'; return; }
        const total = validIdx.reduce((a, i) => a + obs[i], 0);
        const ratioSum = validIdx.reduce((a, i) => a + ratios[i], 0);
        let chi = 0;
        validIdx.forEach((i) => { const E = (ratios[i] / ratioSum) * total; chi += Math.pow(obs[i] - E, 2) / E; });
        const df = validIdx.length - 1;
        el('r-chi').textContent = fmt(chi);
        el('r-df').textContent = df;
        const crit = CRIT[df] || null;
        if (crit) {
          const good = chi < crit;
          el('r-verdict').textContent = good ? 'Good fit (< ' + crit + ')' : 'Poor fit (> ' + crit + ')';
          el('r-verdict').className = 'mt-1 text-lg font-bold ' + (good ? 'text-green-600' : 'text-red-600');
        }
      }
      ['o1', 'o2', 'o3', 'o4', 'e1', 'e2', 'e3', 'e4'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.obs = new Chart(el('chart-obs'), {
          type: 'bar',
          data: { labels: ['Round-Yellow', 'Round-Green', 'Wrinkled-Yellow', 'Wrinkled-Green'], datasets: [
            { label: 'Observed', data: [315, 101, 108, 32], backgroundColor: '#f59e0b' },
            { label: 'Expected (9:3:3:1)', data: [312.75, 104.25, 104.25, 34.75], backgroundColor: '#6366f1' },
          ] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Count' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.critical = new Chart(el('chart-critical'), {
          type: 'bar',
          data: { labels: ['df=1', 'df=2', 'df=3', 'df=4'], datasets: [{ label: 'Critical χ² (p=0.05)', data: [3.841, 5.991, 7.815, 9.488], backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Critical χ² value' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function barScene(container, obsVals, expVals) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 1, 0), OPTS);
        obsVals.forEach((v, i) => {
          const bar = new THREE.Mesh(new THREE.BoxGeometry(0.5, v, 0.5), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5 }));
          bar.position.set(i * 1.3 - 2, v / 2, 0.4);
          s.scene.add(bar);
          const bar2 = new THREE.Mesh(new THREE.BoxGeometry(0.5, expVals[i], 0.5), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.5 }));
          bar2.position.set(i * 1.3 - 2, expVals[i] / 2, -0.4);
          s.scene.add(bar2);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagGood = null, diagPoor = null;
      function initDiagGood() { const c = el('diag-good'); if (!c) throw new Error('no container'); diagGood = barScene(c, [3.1, 1.0, 1.1, 0.3], [3.1, 1.0, 1.0, 0.3]); }
      function initDiagPoor() { const c = el('diag-poor'); if (!c) throw new Error('no container'); diagPoor = barScene(c, [3.6, 0.6, 1.5, 0.3], [3.0, 1.0, 1.0, 0.3]); }

      function boot() {
        try { update(); } catch (e) { console.error('[chi-square-genetics] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[chi-square-genetics] charts failed', e); }
        if (window.THREE) {
          try { initDiagGood(); } catch (e) { console.error('[chi-square-genetics] good diagram failed', e); }
          try { initDiagPoor(); } catch (e) { console.error('[chi-square-genetics] poor diagram failed', e); }
        }
        mountResize([diagGood, diagPoor]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
