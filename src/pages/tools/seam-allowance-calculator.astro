---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Seam Allowance Calculator';
const description = 'Calculate the cut size of a pattern piece from its finished size and seam allowance, or the reverse.';
const intro = 'Add or remove seam allowance to convert between a finished measurement and a cut measurement.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What seam allowance should I use?', a: 'Five-eighths of an inch (1.6 cm) is the standard commercial pattern default in the US, while many independent patterns use three-eighths (1 cm) or a quarter inch. Always check the specific pattern\'s stated seam allowance rather than assuming.' },
  { q: 'Do all edges of a pattern piece get seam allowance?', a: 'Not necessarily — a fold line (like the center front of a piece cut on the fold) does not get seam allowance, so this calculator lets you set how many edges of each dimension are actually seamed.' },
  { q: 'Why would I need to remove seam allowance instead of add it?', a: 'If you have a cut pattern piece (from a garment you\'re copying, or a draft with seam allowance already built in) and want to know the finished, sewn size, you subtract the seam allowance instead of adding it.' },
  { q: 'Does hem allowance work the same way as seam allowance?', a: 'The same add/subtract logic applies, but hem allowances are typically larger (1-2 inches) than seam allowances, and only apply to the bottom edge rather than every seamed edge — calculate it separately using the hem edge count set to 1.' },
];
const howTo = {
  name: 'How to calculate cut size from seam allowance',
  steps: [
    { name: 'Enter finished dimensions', text: 'Enter the finished (sewn) width and height of the pattern piece.' },
    { name: 'Enter seam allowance and edge count', text: 'Enter your seam allowance amount and how many edges of each dimension are seamed.' },
    { name: 'Read the cut size', text: 'The total cut size, including seam allowance, appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Finished width (in)</span>
        <input id="width" type="number" step="any" placeholder="e.g. 20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Finished height (in)</span>
        <input id="height" type="number" step="any" placeholder="e.g. 30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Seam allowance (in)</span>
        <input id="sa" type="number" step="any" value="0.625" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <div>
        <span class="text-sm font-medium text-slate-700">Seamed edges (width / height)</span>
        <div class="mt-1 grid grid-cols-2 gap-2">
          <select id="wEdges" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
            <option value="2" selected>2 edges</option>
            <option value="1">1 edge</option>
            <option value="0">0 edges (fold)</option>
          </select>
          <select id="hEdges" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
            <option value="2" selected>2 edges</option>
            <option value="1">1 edge</option>
            <option value="0">0 edges (fold)</option>
          </select>
        </div>
      </div>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Cut size (with seam allowance)</div>
        <div id="r-size" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sac-title sac-desc">
      <title id="sac-title">Pattern piece with seam allowance border shown</title>
      <desc id="sac-desc">An inner rectangle representing the finished piece, surrounded by a shaded border representing the seam allowance added on each edge</desc>
      <rect x="280" y="30" width="240" height="140" fill="#f0abfc" opacity="0.4" stroke="#c026d3" stroke-width="2" stroke-dasharray="5 3" />
      <rect x="310" y="55" width="180" height="90" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <text x="400" y="105" text-anchor="middle" font-size="13" fill="#86198f" font-family="system-ui,sans-serif">Finished size</text>
      <text x="560" y="45" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Seam allowance</text>
      <text x="560" y="62" font-size="12" fill="#475569" font-family="system-ui,sans-serif">added around edges</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Cut size equals finished size plus seam allowance on each seamed edge</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How seam allowance calculation works</h2>
    <p class="mt-2 text-slate-600">
      Seam allowance is the extra fabric added beyond a pattern piece's finished size so there's something to actually sew when two pieces are joined together — without it, stitching two exact-finished-size pieces together would produce a garment smaller than intended. This calculator adds your seam allowance amount once for each seamed edge on a dimension: if both the left and right edges of the width are seamed, the full seam allowance is added twice (once per edge) to that width.
    </p>
    <p class="mt-3 text-slate-600">
      A folded edge (like a piece cut on the fabric fold, common for center-front or center-back pieces) has no seam there, so setting that dimension's edge count to zero leaves it at the finished measurement with no addition.
    </p>
    <p class="mt-3 text-xs text-slate-400">Five-eighths inch (1.6 cm) is the standard default seam allowance for major US commercial pattern companies; always confirm the specific value stated on your pattern.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A finished 20 × 30 inch panel, cut on the fold along one 30-inch edge, with 5/8-inch seam allowance elsewhere.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Width (2 seamed edges):</span> <span class="text-slate-600">20 + 2×0.625 = 21.25 in</span></div>
        <div><span class="font-medium text-slate-700">Height (1 seamed edge, 1 fold):</span> <span class="text-slate-600">30 + 0.625 = 30.625 in</span></div>
        <div><span class="font-medium text-slate-700">Cut size:</span> <span class="text-slate-600"><strong>21.25 × 30.625 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Drafting an original pattern from scratch, rather than working from a printed commercial pattern, is where this calculation happens constantly — every piece starts as a finished-size shape and needs seam allowance added on paper before it can be cut from fabric, and forgetting even one edge results in a piece that comes out smaller than intended once sewn.
    </p>
    <p class="mt-3 text-slate-600">
      Converting a pattern between two different seam allowance conventions (a European pattern using 1cm against a US pattern using 5/8 inch) also relies on this same add-and-remove logic — subtracting the original allowance to get back to finished size, then adding the new desired allowance.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Seam allowance is added once per pattern piece, not per edge." <strong class="text-slate-900">Not quite.</strong> It's added to every seamed edge individually — a piece seamed on all four sides gets the allowance added twice to each dimension (once per opposing edge), not once total.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All commercial patterns use the same seam allowance." <strong class="text-slate-900">They don't.</strong> While 5/8 inch is common in the US, many independent and international patterns use 3/8 inch, 1cm, or even no seam allowance at all (finished-size-only patterns) — always check before cutting.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/ease-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Ease Calculator</a>
      <a href="/tools/pattern-grading-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Pattern Grading Calculator</a>
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Yardage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const width = parseFloat(el('width').value);
      const height = parseFloat(el('height').value);
      const sa = parseFloat(el('sa').value) || 0;
      const wEdges = parseInt(el('wEdges').value, 10);
      const hEdges = parseInt(el('hEdges').value, 10);
      if (!width || !height || width <= 0 || height <= 0) { el('results').classList.add('hidden'); return; }
      const cutWidth = width + sa * wEdges;
      const cutHeight = height + sa * hEdges;
      el('r-size').textContent = cutWidth.toFixed(3) + ' × ' + cutHeight.toFixed(3) + ' in';
      el('results').classList.remove('hidden');
    }

    ['width', 'height', 'sa'].forEach((id) => el(id).addEventListener('input', update));
    ['wEdges', 'hEdges'].forEach((id) => el(id).addEventListener('change', update));
  </script>
</ToolLayout>
