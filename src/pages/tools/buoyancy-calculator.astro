---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Buoyancy (Archimedes' Principle) Calculator";
const description = "Buoyancy calculator with a live 3D floating/sinking object and charts. Solve F_b = ρ·V·g, find floating vs sinking and the submerged fraction, with worked examples.";
const intro = "Enter fluid density, object volume and mass — the buoyant force, weight, net force and floating/sinking verdict solve instantly, with a live 3D object settling at the correct submerged depth and two charts of buoyant force and submerged fraction.";
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: "What is Archimedes' principle?", a: 'Archimedes’ principle states that any object submerged (fully or partly) in a fluid experiences an upward buoyant force equal to the weight of the fluid it displaces: F_b = ρ_fluid × V_displaced × g. This is why objects feel lighter in water and why some float while others sink.' },
  { q: 'How do I know if an object will float or sink?', a: 'Compare the object’s average density to the fluid’s density. If ρ_object < ρ_fluid, the buoyant force at full submersion exceeds the object’s weight, so it floats and settles at a shallower depth where the two balance. If ρ_object ≥ ρ_fluid, the maximum buoyant force can never match the weight, so it sinks and rests on the bottom.' },
  { q: 'What fraction of a floating object is submerged?', a: 'At equilibrium the buoyant force equals the object’s weight: ρ_fluid × V_submerged × g = ρ_object × V_object × g. Solving gives V_submerged / V_object = ρ_object / ρ_fluid — the submerged fraction is simply the density ratio.' },
  { q: 'Why do heavy ships float?', a: 'Buoyant force depends on the volume of fluid displaced, not on the object’s mass alone. A steel ship’s hull encloses a large volume of air, so its average density (hull + cargo + air space, divided by total hull volume) is far less than water’s, even though the steel itself is much denser than water.' },
  { q: 'Does buoyant force depend on how deep an object is submerged?', a: 'Only through how much fluid volume is displaced, not depth itself. A fully submerged object displaces its full volume no matter how deep it goes (assuming the fluid density stays constant), so the buoyant force stays the same at any depth — it does not grow with depth the way pressure does.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Buoyancy Calculator',
  description: 'Calculate buoyant force, weight, net force and the floating/sinking verdict for an object in a fluid using Archimedes’ principle.',
  steps: [
    { name: 'Pick the fluid', text: 'Choose a preset (fresh water, seawater, air) or enter a custom fluid density.' },
    { name: 'Enter object volume and mass', text: 'Type the object’s total volume in m³ and its mass in kg.' },
    { name: 'Read the result', text: 'Buoyant force, weight, net force and whether it floats or sinks solve instantly, with the submerged fraction if it floats.' },
  ],
};

const formulas = [
  { expr: 'F<sub>b</sub> = ρ<sub>fluid</sub> × V<sub>displaced</sub> × g', note: 'buoyant force = weight of fluid displaced' },
  { expr: 'F<sub>net</sub> = F<sub>b</sub> − mg', note: 'net force: positive means it floats, negative means it sinks' },
  { expr: 'f<sub>submerged</sub> = ρ<sub>object</sub> / ρ<sub>fluid</sub>', note: 'submerged volume fraction of a floating object' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — ice cube floating in water', tone: 'slate',
    given: 'An ice cube has volume V = 0.001 m³ (10 cm side) and density ρ_ice = 917 kg/m³, floating in fresh water (ρ_water = 1000 kg/m³, g = 9.81 m/s²).',
    rows: [
      { label: 'Mass:', value: 'm = ρ_ice × V = 917 × 0.001 = 0.917 kg' },
      { label: 'Weight:', value: 'W = mg = 0.917 × 9.81 ≈ 8.996 N' },
      { label: 'Max buoyant force (fully submerged):', value: 'F_b,max = ρ_water × V × g = 1000 × 0.001 × 9.81 = 9.81 N' },
      { label: 'Verdict:', value: 'F_b,max (9.81 N) &gt; weight (8.996 N) → the ice <strong>floats</strong>', full: true },
      { label: 'Submerged fraction:', value: 'f = ρ_ice / ρ_water = 917 / 1000 = 0.917 = <strong>91.7% submerged</strong>', full: true },
    ],
    note: 'This is the classic "tip of the iceberg" figure — only about 8.3% of floating ice shows above the surface.',
  },
  {
    title: 'Worked example 2 — steel ball sinking in water', tone: 'amber',
    given: 'A solid steel ball of radius r = 0.05 m (V = (4/3)πr³ ≈ 5.236 × 10⁻⁴ m³) and density ρ_steel = 7850 kg/m³, dropped in fresh water (ρ_water = 1000 kg/m³).',
    rows: [
      { label: 'Mass:', value: 'm = ρ_steel × V = 7850 × 5.236 × 10⁻⁴ ≈ 4.110 kg' },
      { label: 'Weight:', value: 'W = mg = 4.110 × 9.81 ≈ 40.32 N' },
      { label: 'Max buoyant force (fully submerged):', value: 'F_b,max = ρ_water × V × g = 1000 × 5.236 × 10⁻⁴ × 9.81 ≈ 5.14 N' },
      { label: 'Verdict:', value: 'F_b,max (5.14 N) &lt; weight (40.32 N) → the ball <strong>sinks</strong>, net downward force ≈ 35.19 N', full: true },
    ],
  },
];

const comparison = {
  heading: 'Submerged fraction for common floating objects (in fresh water)',
  note: 'Submerged fraction = ρ_object / ρ_water — a rough guide, since shape and posture (like lung volume) can shift the real-world figure.',
  headers: [{ label: 'Object' }, { label: 'Typical density', sub: 'kg/m³' }, { label: 'Submerged fraction' }],
  rows: [
    ['Cork', '~240', '~24%'],
    ['Pine wood', '~500', '~50%'],
    ['Human body (average)', '~900–970', '~90–97%'],
    ['Ice ★', '917', '91.7%'],
    ['Steel (solid, any shape)', '7850', 'sinks — 100% submerged, rests on bottom'],
  ],
  highlightIndex: 3,
  footnote: '★ Reference row (see worked example 1). Human submerged fraction varies with lung inflation — a full breath lowers average body density and raises buoyancy.',
};

const realWorld = [
  { emoji: '🚢', title: 'Ship & submarine design', body: 'A steel ship floats because its hull encloses enough air volume to bring its average density below water’s. Submarines flood or empty ballast tanks to fine-tune their average density, letting them float, hover neutrally, or sink on command.' },
  { emoji: '🧊', title: 'Icebergs at sea', body: 'Because ice is about 91.7% as dense as seawater, roughly nine-tenths of an iceberg’s volume lies underwater — the visible tip is a small fraction of the total, which is why icebergs are so hazardous to shipping.' },
  { emoji: '🏊', title: 'Swimming & diving', body: 'A swimmer’s body is close to water density, so buoyancy nearly cancels weight — small changes in lung volume (a deep breath vs a full exhale) are often enough to shift a person from floating to sinking.' },
  { emoji: '🎈', title: 'Hot air balloons', body: 'Heating the air inside the envelope lowers its density below the surrounding cooler air, so the balloon displaces air that weighs more than the balloon system itself — the same F_b = ρ·V·g principle, just with air as the "fluid".' },
];

const misconceptions = [
  { claim: '"Heavy objects always sink."', truth: 'False — floating depends on average density, not total mass. A massive steel ship floats because its shape encloses a large air volume, keeping its overall density below water’s, while a small solid steel ball of the same material sinks.' },
  { claim: '"Buoyant force depends on the object’s mass."', truth: 'It depends on the volume of fluid displaced and the fluid’s density, not on the object’s own mass or density directly: F_b = ρ_fluid × V_displaced × g. The object’s mass only matters when comparing it to F_b to decide float vs sink.' },
  { claim: '"A submerged object feels a growing buoyant force the deeper it goes."', truth: 'For a fully submerged object of fixed volume in a fluid of roughly constant density, the buoyant force stays the same at any depth, because the displaced volume does not change. It is pressure, not buoyant force, that increases with depth.' },
  { claim: '"Objects that float have zero net force acting on them at all times."', truth: 'A floating object at equilibrium has zero net force, but it gets there by settling to whatever submerged depth makes F_b exactly equal its weight — if pushed deeper or lifted, it briefly feels a nonzero net force pulling it back to that equilibrium level.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §14.4, Archimedes’ Principle and Buoyancy (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/14-4-archimedes-principle-and-buoyancy" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 14, Fluids (Archimedes’ Principle).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 14, Fluid Mechanics.' },
];
const sourcesNote = 'Standard g = 9.81 m/s² is used. Fluid density presets: fresh water 1000 kg/m³, seawater 1025 kg/m³, air 1.225 kg/m³. Results are rounded for display.';

const howToUse = [
  { title: 'Choose the fluid', body: 'Pick fresh water, seawater or air from the preset, or type a custom fluid density.' },
  { title: 'Enter volume & mass', body: 'Fill in the object’s total volume (m³) and mass (kg).' },
  { title: 'Read float or sink', body: 'See the buoyant force, weight, net force and — if it floats — the submerged fraction.' },
];

const related = [
  { href: '/tools/density-calculator', emoji: '🧱', title: 'Density Calculator', desc: 'ρ = m/V — solve for any variable.' },
  { href: '/tools/gravitational-force-calculator', emoji: '🌍', title: 'Gravitational Force Calculator', desc: "Newton's law of gravitation between masses." },
  { href: '/tools/terminal-velocity-calculator', emoji: '🪂', title: 'Terminal Velocity Calculator', desc: 'Falling speed with drag in a fluid.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a submerged object is pushed up by a force equal to the weight of the fluid it shoves out of the way — whether it floats or sinks comes down to comparing that force to the object's own weight."
  howIntro="At full submersion, the maximum possible buoyant force is F_b,max = ρ_fluid × V_object × g. If that exceeds the object's weight (mg), the object floats and rises until only enough of it is submerged for F_b to exactly equal mg — giving the submerged fraction ρ_object / ρ_fluid. If F_b,max is less than or equal to the weight, no submerged depth can balance it, so the object sinks."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where buoyancy actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Pick a fluid, enter the object's volume and mass — buoyant force, weight, net force and the float/sink verdict solve instantly.</p>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Fluid preset</span>
      <select id="fluid-preset" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="1000" selected>Fresh water (ρ ≈ 1000 kg/m³)</option>
        <option value="1025">Seawater (ρ ≈ 1025 kg/m³)</option>
        <option value="1.225">Air (ρ ≈ 1.225 kg/m³)</option>
        <option value="custom">Custom…</option>
      </select>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Fluid density (ρ<sub>fluid</sub>) <span class="text-slate-400">kg/m³</span></span>
        <input id="rho-fluid" type="number" step="any" min="0.01" value="1000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Object volume (V) <span class="text-slate-400">m³</span></span>
        <input id="vol" type="number" step="any" min="0" placeholder="e.g. 0.001" value="0.001" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Object mass (m) <span class="text-slate-400">kg</span></span>
        <input id="mass" type="number" step="any" min="0" placeholder="e.g. 0.917" value="0.917" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Buoyant force (max)</div><div id="r-fb" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Weight</div><div id="r-w" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Net force</div><div id="r-net" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-3 rounded-xl bg-blue-50 p-4 text-center">
      <div id="r-verdict" class="text-lg font-bold text-blue-700">—</div>
      <div id="r-frac" class="mt-1 text-sm text-blue-600"></div>
    </div>
    <p id="bo-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D scene + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-buoy-vectors" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Floating vs sinking</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-orange-500">orange</span> block floats mostly above the translucent water line, while the <span class="font-semibold text-red-600">red</span> block is denser and rests fully submerged on the bottom.</p>
        </div>
        <div>
          <div id="diag-buoy-family" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Submerged fraction depends on density ratio</h3>
          <p class="mt-1 text-sm text-slate-600">Four blocks of different density (like cork, wood, ice and steel) crossing the same water line — the denser the block, the more of it sits below the surface.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Buoyancy graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Buoyant force vs object volume (fixed fluid density) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-fv"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Submerged fraction vs density ratio (ρ_object / ρ_fluid) — capped at 1.0</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-frac"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const G = 9.81;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      // ---- calculator ----
      function update() {
        const errEl = el('bo-err'); errEl.textContent = '';
        ['r-fb', 'r-w', 'r-net'].forEach((id) => (el(id).textContent = '—'));
        el('r-verdict').textContent = '—'; el('r-frac').textContent = '';
        const rho = parseFloat(el('rho-fluid').value), V = parseFloat(el('vol').value), m = parseFloat(el('mass').value);
        if (isNaN(rho) || isNaN(V) || isNaN(m)) return;
        if (rho <= 0 || V <= 0 || m < 0) { errEl.textContent = 'Fluid density and volume must be positive; mass cannot be negative.'; return; }
        const Fb = rho * V * G;
        const W = m * G;
        const net = Fb - W;
        el('r-fb').textContent = fmt(Fb) + ' N';
        el('r-w').textContent = fmt(W) + ' N';
        el('r-net').textContent = (net >= 0 ? '+' : '') + fmt(net) + ' N';
        const rhoObj = m / V;
        if (Fb > W) {
          el('r-verdict').textContent = 'Floats';
          el('r-verdict').className = 'text-lg font-bold text-green-700';
          const frac = Math.min(1, rhoObj / rho);
          el('r-frac').textContent = 'Submerged fraction ≈ ' + (frac * 100).toFixed(1) + '% (ρ_object ≈ ' + fmt(rhoObj) + ' kg/m³)';
        } else {
          el('r-verdict').textContent = 'Sinks';
          el('r-verdict').className = 'text-lg font-bold text-red-700';
          el('r-frac').textContent = 'Fully submerged, rests on the bottom (ρ_object ≈ ' + fmt(rhoObj) + ' kg/m³ ≥ ρ_fluid)';
        }
      }
      el('fluid-preset').addEventListener('change', () => {
        const val = el('fluid-preset').value;
        if (val !== 'custom') el('rho-fluid').value = val;
        update();
      });
      ['rho-fluid', 'vol', 'mass'].forEach((id) => el(id).addEventListener('input', () => {
        if (id === 'rho-fluid') el('fluid-preset').value = 'custom';
        update();
      }));

      // ---- charts ----
      const charts = {};

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const RHO_FLUID_FIXED = 1000;
        const vLabels = [], vData = [];
        for (let v = 0; v <= 0.01 + 1e-9; v += 0.0005) { vLabels.push(v.toFixed(4)); vData.push(+(RHO_FLUID_FIXED * v * G).toFixed(3)); }
        charts.fv = new Chart(el('chart-fv'), {
          type: 'line',
          data: { labels: vLabels, datasets: [{ label: 'F_b', data: vData, borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Object volume (m³)' } }, y: { title: { display: true, text: 'Buoyant force (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        const rLabels = [], rData = [];
        for (let r = 0; r <= 2.0 + 1e-9; r += 0.05) { rLabels.push(r.toFixed(2)); rData.push(+Math.min(1, r).toFixed(3)); }
        charts.frac = new Chart(el('chart-frac'), {
          type: 'line',
          data: { labels: rLabels, datasets: [{ label: 'Submerged fraction', data: rData, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Density ratio ρ_object / ρ_fluid' } }, y: { title: { display: true, text: 'Submerged fraction' }, beginAtZero: true, max: 1.05 } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram A: float vs sink, with a water-line plane ----
      let diagV = null, diagF = null;
      function waterPlane(s, y, w) {
        const mat = new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.35, side: THREE.DoubleSide });
        const plane = new THREE.Mesh(new THREE.PlaneGeometry(w, w), mat);
        plane.rotation.x = -Math.PI / 2; plane.position.y = y;
        s.scene.add(plane);
      }
      function initDiagVectors() {
        const c = el('diag-buoy-vectors'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(2, 1.2, 0), OPTS);
        waterPlane(s, 0, 8);
        const floatCube = new THREE.Mesh(new THREE.BoxGeometry(1.2, 1.2, 1.2), new THREE.MeshStandardMaterial({ color: 0xf97316 }));
        floatCube.position.set(-1.6, 0.35, 0); s.scene.add(floatCube); // mostly above water line
        const sinkCube = new THREE.Mesh(new THREE.BoxGeometry(1.2, 1.2, 1.2), new THREE.MeshStandardMaterial({ color: 0xdc2626 }));
        sinkCube.position.set(1.6, -1.2, 0); s.scene.add(sinkCube); // fully submerged, resting low
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0035); s.renderer.render(s.scene, s.camera); }
        frame();
        diagV = { resize: s.resize };
      }

      // ---- Diagram B: family of density ratios crossing the water line ----
      function initDiagFamily() {
        const c = el('diag-buoy-family'); if (!c) throw new Error('no container');
        const s = makeScene(c, 11, new THREE.Vector3(3, 1.5, 0), OPTS);
        waterPlane(s, 0, 12);
        const fracs = [0.24, 0.5, 0.917, 1.0]; // cork, wood, ice, steel(sinks)
        const colors = [0x22c55e, 0x0ea5e9, 0x60a5fa, 0xdc2626];
        const h = 1.6;
        fracs.forEach((f, i) => {
          const bar = new THREE.Mesh(new THREE.BoxGeometry(1, h, 1), new THREE.MeshStandardMaterial({ color: colors[i] }));
          const submergedTop = h / 2 - f * h;
          bar.position.set(i * 1.8, submergedTop, 0);
          s.scene.add(bar);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagF = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[buoyancy] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[buoyancy] charts failed', e); }
        if (window.THREE) {
          try { initDiagVectors(); } catch (e) { console.error('[buoyancy] vector diagram failed', e); }
          try { initDiagFamily(); } catch (e) { console.error('[buoyancy] family diagram failed', e); }
        }
        mountResize([diagV, diagF]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
