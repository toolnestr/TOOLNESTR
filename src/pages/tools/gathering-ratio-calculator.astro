---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Gathering Ratio Calculator';
const description = 'Calculate how much flat fabric to cut for a gathered ruffle or waistband from your fullness ratio, for even, consistent gathers every time.';
const intro = 'Calculate flat fabric needed for gathering, based on your finished length and fullness ratio.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What gathering ratio should I use?', a: 'A ratio of 1.5:1 to 2:1 gives light, subtle gathers; 2:1 to 2.5:1 gives moderate, classic ruffle fullness; 3:1 or higher gives very full, dramatic gathers. Lighter-weight fabrics generally support higher ratios more gracefully than heavy fabrics.' },
  { q: 'Does fabric weight affect the best ratio to use?', a: 'Yes — lightweight, drapey fabrics (voile, chiffon, lightweight cotton) can be gathered at higher ratios and still look soft and full, while heavier fabrics (denim, canvas) become bulky and stiff at high gathering ratios, so a lower ratio usually looks better.' },
  { q: 'Is gathering the same as a pleat?', a: 'No — gathering uses a drawn-up thread (like a running stitch or elastic) to create many small, soft, irregular folds, while a pleat is a specific, pressed, repeatable fold at set intervals. They use different fabric calculations even though both add fullness.' },
  { q: 'How do I gather the fabric evenly to the target ratio?', a: 'Divide both the flat fabric edge and the target finished edge into equal sections (quarters or eighths), mark them, then pull up the gathering stitches within each section until it matches its corresponding target section — this keeps fullness even across the whole seam.' },
];
const howTo = {
  name: 'How to calculate gathering fabric',
  steps: [
    { name: 'Enter finished (gathered) length', text: 'Enter the length the gathered edge needs to be once sewn in.' },
    { name: 'Choose a fullness ratio', text: 'Select how full you want the gathers to look.' },
    { name: 'Read flat fabric length needed', text: 'The flat fabric length to cut before gathering appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Finished (gathered) length (in)</span>
        <input id="finished" type="number" step="any" placeholder="e.g. 28" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fullness ratio</span>
        <input id="ratio" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Flat fabric to cut</div>
        <div id="r-flat" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="grc-title grc-desc">
      <title id="grc-title">Wide flat fabric gathered down to a shorter finished edge</title>
      <desc id="grc-desc">A wide wavy fabric strip on top compressing down to a shorter straight edge below, illustrating gathering ratio</desc>
      <path d="M100 50 Q120 30 140 50 Q160 70 180 50 Q200 30 220 50 Q240 70 260 50 Q280 30 300 50 Q320 70 340 50 Q360 30 380 50 Q400 70 420 50 Q440 30 460 50 Q480 70 500 50 Q520 30 540 50 Q560 70 580 50 Q600 30 620 50 Q640 70 660 50 Q680 30 700 50" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <text x="400" y="25" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Flat fabric (wider)</text>
      <line x1="250" y1="130" x2="550" y2="130" stroke="#c026d3" stroke-width="3" />
      <text x="400" y="155" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Finished gathered edge (shorter)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Fullness ratio determines how much wider the flat fabric is than the finished edge</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How gathering fabric is calculated</h2>
    <p class="mt-2 text-slate-600">
      Gathering compresses a wider piece of flat fabric down into a shorter finished edge using drawn-up stitching, so the flat fabric always needs to be longer than the finished result — the fullness ratio describes exactly how many times longer. This calculator multiplies your target finished length by the fullness ratio to find the flat fabric length to cut before gathering.
    </p>
    <p class="mt-3 text-slate-600">
      A 2:1 ratio, a common default for moderate ruffles, means cutting fabric twice as long as the finished gathered edge; a lighter 1.5:1 ratio gives subtler gathers using less fabric, while a fuller 3:1 ratio uses three times the finished length for a much more voluminous result.
    </p>
    <p class="mt-3 text-xs text-slate-400">Fullness-ratio ranges reflect standard home-sewing conventions for gathered ruffles and waistbands.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A ruffle needs to finish at 28 inches long, gathered at a 2:1 ratio.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Finished length:</span> <span class="text-slate-600">28 in</span></div>
        <div><span class="font-medium text-slate-700">Ratio:</span> <span class="text-slate-600">2:1</span></div>
        <div><span class="font-medium text-slate-700">Flat fabric to cut:</span> <span class="text-slate-600">28 × 2 = <strong>56 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Ruffled skirts, gathered sleeve cuffs, and dust ruffles for bedding all rely on this same ratio math — a common first-time-sewist mistake is cutting fabric equal to the finished length with no extra for gathering at all, which leaves nothing to actually gather and results in a flat, ungathered edge instead of the intended ruffled look.
    </p>
    <p class="mt-3 text-slate-600">
      Gathered waistbands on skirts and dresses without a zipper (pull-on styles) use a similar calculation but typically at a lower ratio than decorative ruffles, since the goal there is a comfortable stretch-to-fit waist rather than maximum visual fullness.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A higher ratio always looks better, regardless of fabric." <strong class="text-slate-900">Not for every fabric.</strong> Heavy or stiff fabrics can look bulky and lumpy at a high gathering ratio, while the same ratio on a lightweight, drapey fabric looks soft and elegant.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Gathering ratio and pleat fabric consumption are calculated the same way." <strong class="text-slate-900">Different math.</strong> Gathering uses a simple multiplier on the finished length, while pleats use a per-pleat depth calculation — the two techniques aren't interchangeable in their fabric planning.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pleat-allowance-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Pleat Allowance Calculator</a>
      <a href="/tools/pleated-skirt-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Pleated Skirt Calculator</a>
      <a href="/tools/elastic-length-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Elastic Length Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const finished = parseFloat(el('finished').value);
      const ratio = parseFloat(el('ratio').value);
      if (!finished || !ratio || finished <= 0 || ratio <= 0) { el('results').classList.add('hidden'); return; }
      const flat = finished * ratio;
      el('r-flat').textContent = flat.toFixed(1) + ' in';
      el('results').classList.remove('hidden');
    }

    el('finished').addEventListener('input', update);
    el('ratio').addEventListener('input', update);
  </script>
</ToolLayout>
