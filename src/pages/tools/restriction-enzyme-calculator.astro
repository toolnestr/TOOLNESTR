---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Restriction Enzyme Cut-Site Finder';
const description = "Restriction enzyme cut-site finder. Scan a DNA sequence for common restriction enzyme recognition sites (EcoRI, BamHI, HindIII, and more), with worked examples.";
const intro = 'Enter a DNA sequence to scan it for recognition sites of common restriction enzymes — EcoRI, BamHI, HindIII, NotI, PstI, SmaI, XhoI, and SalI — showing exactly where each enzyme would cut. Two 3D diagrams compare a blunt cut to a sticky-end (overhang) cut, and charts show how many cut sites each enzyme finds in your sequence.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a restriction enzyme?', a: 'A restriction enzyme (restriction endonuclease) is a protein that recognizes a specific short DNA sequence and cuts the DNA at or near that site — originally a bacterial defense mechanism against viral DNA, now a core tool of molecular biology.' },
  { q: 'Why are restriction sites usually palindromic?', a: "Most restriction enzyme recognition sequences are palindromic, reading the same on both strands when each is read 5' to 3' (like GAATTC, whose complement read 5' to 3' is also GAATTC) — this lets the enzyme, which typically works as a symmetric dimer, cut both strands using the same recognition mechanism." },
  { q: 'What is the difference between sticky ends and blunt ends?', a: "Sticky ends result when an enzyme cuts each strand at a different position within the recognition site, leaving a short single-stranded overhang that can base-pair with a matching sticky end. Blunt ends result when the enzyme cuts both strands at exactly the same position, leaving no overhang." },
  { q: 'Why do molecular biologists use restriction enzymes?', a: 'They\'re essential for cutting DNA at precise, predictable locations — used for cloning genes into plasmids, building recombinant DNA constructs, and in diagnostic techniques like RFLP (restriction fragment length polymorphism) analysis.' },
  { q: 'Can the same restriction enzyme cut a sequence more than once?', a: 'Yes — if its recognition sequence appears at multiple locations in the DNA, the enzyme cuts at every occurrence, producing multiple DNA fragments rather than just two.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Restriction Enzyme Cut-Site Finder',
  description: 'Scan a DNA sequence for recognition sites of common restriction enzymes and see where each one cuts.',
  steps: [
    { name: 'Enter a DNA sequence', text: 'Type a sequence using only A, T, C, and G.' },
    { name: 'Review the matches', text: 'Every recognition site found is listed with its enzyme, position, and cut location.' },
    { name: 'Check sticky vs. blunt', text: 'Each result notes whether that enzyme leaves a sticky-end overhang or a blunt cut.' },
  ],
};

const formulas = [
  { expr: 'Recognition site → search sequence for an exact substring match', note: 'e.g., EcoRI recognizes GAATTC anywhere it occurs' },
  { expr: 'Cut position = match start + enzyme-specific offset', note: 'each enzyme cuts at a fixed position within its own recognition site' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a single EcoRI site', tone: 'slate',
    given: 'Sequence: 5\'-AAGAATTCTT-3\'. Scanning for EcoRI\'s recognition site, GAATTC.',
    rows: [
      { label: 'Match found:', value: 'GAATTC at position 3 (0-indexed): AA[GAATTC]TT' },
      { label: 'Cut position:', value: "EcoRI cuts between G and AATTC (G^AATTC), so the cut falls right after position 3" },
      { label: 'Result:', value: 'Two fragments: AAG and AATTCTT, each with a 4-base sticky-end overhang', full: true },
    ],
    note: 'EcoRI is one of the most widely used restriction enzymes in molecular cloning, prized for its reliable sticky-end overhangs.',
  },
  {
    title: 'Worked example 2 — two BamHI sites in one sequence', tone: 'amber',
    given: 'Sequence: 5\'-GGATCCAAAGGATCC-3\'. Scanning for BamHI\'s recognition site, GGATCC.',
    rows: [
      { label: 'Matches found:', value: 'GGATCC at position 0 and again at position 9' },
      { label: 'Cut positions:', value: 'BamHI cuts after the first G in each site (G^GATCC)' },
      { label: 'Result:', value: 'Three fragments total, since the enzyme cuts at both recognition sites', full: true },
    ],
    note: 'A restriction enzyme cuts at every occurrence of its recognition sequence, not just the first one — this is exactly why longer DNA sequences can be cut into many fragments by a single enzyme.',
  },
];

const comparison = {
  heading: 'Common restriction enzymes and their recognition sites',
  note: 'All are palindromic 6-8 base recognition sequences (except SmaI\'s blunt-cutting 6-base site).',
  headers: [{ label: 'Enzyme' }, { label: 'Recognition site (cut ^)' }, { label: 'End type' }],
  rows: [
    ['EcoRI ★', "G^AATTC", 'Sticky (5\' overhang)'],
    ['BamHI', 'G^GATCC', 'Sticky (5\' overhang)'],
    ['HindIII', 'A^AGCTT', 'Sticky (5\' overhang)'],
    ['SmaI', 'CCC^GGG', 'Blunt'],
    ['NotI', 'GC^GGCCGC', 'Sticky (5\' overhang)'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 1). NotI\'s 8-base recognition site is much rarer statistically than a 6-base site, making it useful for cutting DNA into very large fragments.',
};

const realWorld = [
  { emoji: '🧬', title: 'Molecular cloning', body: 'Restriction enzymes cut both a gene of interest and a plasmid vector with matching sticky ends, allowing the gene to be inserted precisely into the vector for expression or further study.' },
  { emoji: '🔬', title: 'RFLP analysis and DNA fingerprinting', body: 'Restriction Fragment Length Polymorphism analysis cuts DNA samples with a chosen enzyme and compares the resulting fragment size patterns, historically used in forensics and paternity testing before modern sequencing became routine.' },
  { emoji: '🧫', title: 'Verifying plasmid constructs', body: "After cloning a gene into a plasmid, researchers commonly run a restriction digest ('diagnostic digest') and check the resulting fragment sizes on a gel to confirm the insert is present and correctly oriented." },
  { emoji: '🦠', title: 'Bacterial defense systems', body: "Restriction enzymes exist in bacteria specifically to cut and destroy invading viral (phage) DNA, while the bacterium's own DNA is protected from cutting by a matching methylation system — the original biological purpose these enzymes evolved for." },
];

const misconceptions = [
  { claim: '"Every restriction enzyme cuts DNA in exactly the middle of its recognition site."', truth: "Cut position varies by enzyme — some cut symmetrically in the middle (like SmaI, giving blunt ends), while many others cut asymmetrically near one end of the site (like EcoRI and BamHI), producing sticky-end overhangs instead." },
  { claim: '"A restriction enzyme only cuts a sequence once, no matter how long the DNA is."', truth: 'An enzyme cuts at every single occurrence of its recognition sequence in the DNA — a longer sequence with multiple matching sites will be cut into that many more fragments.' },
  { claim: '"Sticky ends from different enzymes can always be joined together."', truth: "Sticky ends can only reliably re-anneal with a complementary overhang of the same sequence and length — an EcoRI sticky end generally can't pair directly with a BamHI sticky end, since their overhangs are different sequences." },
  { claim: '"Restriction enzymes only exist as laboratory tools, not in nature."', truth: 'Restriction enzymes are naturally occurring bacterial proteins, evolved specifically as a defense mechanism against bacteriophage (viral) DNA — their use as laboratory tools came later, after scientists discovered and purified them.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 17, "Biotechnology and Genomics" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/17-1-biotechnology" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>NEB (New England Biolabs)</strong> — standard reference for restriction enzyme recognition sites and cut positions.' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Recombinant DNA technology chapter.' },
];
const sourcesNote = 'Recognition sites and cut positions follow standard published enzyme specifications. Scans the entered strand only, for exact substring matches.';

const howToUse = [
  { title: 'Enter a DNA sequence', body: 'Type a sequence using only the letters A, T, C, and G.' },
  { title: 'Review all matches', body: 'Every recognition site found across 8 common enzymes is listed with its position.' },
  { title: 'Note the cut type', body: 'Each match shows whether that enzyme leaves sticky or blunt ends.' },
];

const related = [
  { href: '/tools/dna-base-pairing-calculator', emoji: '🧬', title: 'DNA/RNA Base-Pairing Calculator', desc: "Watson-Crick pairing rules and hydrogen bond counts." },
  { href: '/tools/reverse-complement-calculator', emoji: '🔄', title: 'Reverse Complement Sequence Tool', desc: "Find the reverse complement of a DNA sequence." },
  { href: '/tools/pcr-annealing-temperature-calculator', emoji: '🧫', title: 'PCR Primer Annealing Temperature Calculator', desc: 'Estimate annealing temperature from primer Tm.' },
];

// Enzyme library: [name, recognition site (5'->3'), cut offset from site start, end type]
const enzymes = [
  ['EcoRI', 'GAATTC', 1, "5' overhang"],
  ['BamHI', 'GGATCC', 1, "5' overhang"],
  ['HindIII', 'AAGCTT', 1, "5' overhang"],
  ['NotI', 'GCGGCCGC', 2, "5' overhang"],
  ['PstI', 'CTGCAG', 5, "3' overhang"],
  ['SmaI', 'CCCGGG', 3, 'Blunt'],
  ['XhoI', 'CTCGAG', 1, "5' overhang"],
  ['SalI', 'GTCGAC', 1, "5' overhang"],
];
const enzymesJson = JSON.stringify(enzymes);
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a restriction enzyme is really just a molecular pattern-matcher — wherever its short recognition sequence appears in the DNA, it cuts at that exact, predictable spot, every single time."
  howIntro="Each restriction enzyme recognizes one specific short DNA sequence, usually 4 to 8 bases long and usually palindromic, and cuts the DNA backbone at a fixed position relative to that sequence whenever it finds a match. Finding all of an enzyme's cut sites in a sequence is as simple as searching for every occurrence of its recognition sequence as an exact substring, then marking the enzyme's known cut offset within each match. Whether the resulting ends are blunt or sticky (with a short single-stranded overhang) depends entirely on whether the enzyme cuts both DNA strands at the same position or at offset positions within the recognition site."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where restriction enzymes actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">DNA sequence (5' → 3')</span>
      <textarea id="seq" rows="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">AAGAATTCTTGGATCCAAAGGATCC</textarea></label>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Total cut sites found</div><div id="r-total" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Enzymes with at least one site</div><div id="r-enzymes" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-4 overflow-x-auto rounded-xl border border-slate-200">
      <table class="w-full text-left text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600"><tr><th class="px-3 py-2">Enzyme</th><th class="px-3 py-2">Site</th><th class="px-3 py-2">Position</th><th class="px-3 py-2">Cut type</th></tr></thead>
        <tbody id="hits-body" class="divide-y divide-slate-100"></tbody>
      </table>
    </div>
    <p id="re-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Blunt cut vs. sticky-end cut</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-blunt" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Blunt cut (e.g., SmaI)</h3>
          <p class="mt-1 text-sm text-slate-600">Both strands cut at the same position — no overhang, a straight break.</p>
        </div>
        <div>
          <div id="diag-sticky" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Sticky-end cut (e.g., EcoRI)</h3>
          <p class="mt-1 text-sm text-slate-600">Strands cut at offset positions — a short single-stranded overhang remains.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Cut-site charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Cut sites found per enzyme</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-hits"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Recognition site length by enzyme</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-length"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline define:vars={{ enzymesJson }}>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const enzymes = JSON.parse(enzymesJson);
      let charts = {};

      function findAll(seq, site) {
        const positions = [];
        let idx = seq.indexOf(site);
        while (idx !== -1) { positions.push(idx); idx = seq.indexOf(site, idx + 1); }
        return positions;
      }

      function update() {
        el('re-err').textContent = '';
        el('r-total').textContent = '—'; el('r-enzymes').textContent = '—';
        el('hits-body').innerHTML = '';
        const seq = (el('seq').value || '').toUpperCase().replace(/\s/g, '');
        if (!seq) return;
        if (!/^[ATCG]+$/.test(seq)) { el('re-err').textContent = 'Sequence must contain only A, T, C, and G.'; return; }
        let totalHits = 0, enzymeCount = 0, rows = '';
        const chartLabels = [], chartData = [];
        enzymes.forEach(([name, site, offset, endType]) => {
          const positions = findAll(seq, site);
          chartLabels.push(name);
          chartData.push(positions.length);
          if (positions.length > 0) {
            enzymeCount++;
            totalHits += positions.length;
            positions.forEach((pos) => {
              rows += '<tr><td class="px-3 py-2 font-medium text-slate-700">' + name + '</td><td class="px-3 py-2 font-mono">' + site + '</td><td class="px-3 py-2">' + pos + ' (cuts after ' + (pos + offset) + ')</td><td class="px-3 py-2">' + endType + '</td></tr>';
            });
          }
        });
        el('r-total').textContent = String(totalHits);
        el('r-enzymes').textContent = String(enzymeCount);
        el('hits-body').innerHTML = rows || '<tr><td class="px-3 py-2 text-slate-400" colspan="4">No recognition sites found in this sequence.</td></tr>';
        if (charts.hits) { charts.hits.data.labels = chartLabels; charts.hits.data.datasets[0].data = chartData; charts.hits.update('none'); }
      }
      el('seq').addEventListener('input', update);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.hits = new Chart(el('chart-hits'), {
          type: 'bar',
          data: { labels: enzymes.map((e) => e[0]), datasets: [{ label: 'Cut sites found', data: enzymes.map(() => 0), backgroundColor: '#6366f1' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Sites found' }, ticks: { stepSize: 1 } } }, plugins: { legend: { display: false } } }),
        });
        charts.length = new Chart(el('chart-length'), {
          type: 'bar',
          data: { labels: enzymes.map((e) => e[0]), datasets: [{ label: 'Recognition site length (bp)', data: enzymes.map((e) => e[1].length), backgroundColor: '#f59e0b' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Site length (bp)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function cutScene(container, sticky) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const offset = sticky ? 0.5 : 0;
        const topLeft = new THREE.Mesh(new THREE.BoxGeometry(2.2, 0.3, 0.3), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
        topLeft.position.set(-1.5 + offset / 2, 0.4, 0);
        s.scene.add(topLeft);
        const topRight = new THREE.Mesh(new THREE.BoxGeometry(2.2, 0.3, 0.3), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
        topRight.position.set(1.5 - offset / 2, 0.4, 0);
        s.scene.add(topRight);
        const botLeft = new THREE.Mesh(new THREE.BoxGeometry(2.2 + offset, 0.3, 0.3), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
        botLeft.position.set(-1.5, -0.4, 0);
        s.scene.add(botLeft);
        const botRight = new THREE.Mesh(new THREE.BoxGeometry(2.2 + offset, 0.3, 0.3), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
        botRight.position.set(1.5, -0.4, 0);
        s.scene.add(botRight);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagBlunt = null, diagSticky = null;
      function initDiagBlunt() { const c = el('diag-blunt'); if (!c) throw new Error('no container'); diagBlunt = cutScene(c, false); }
      function initDiagSticky() { const c = el('diag-sticky'); if (!c) throw new Error('no container'); diagSticky = cutScene(c, true); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[restriction-enzyme] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagBlunt(); } catch (e) { console.error('[restriction-enzyme] blunt diagram failed', e); }
          try { initDiagSticky(); } catch (e) { console.error('[restriction-enzyme] sticky diagram failed', e); }
        }
        mountResize([diagBlunt, diagSticky]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
