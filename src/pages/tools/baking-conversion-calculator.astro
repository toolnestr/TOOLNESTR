---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Baking Conversion Calculator';
const description =
  'Free baking conversion calculator. Convert volume measurements (cups, tbsp, tsp) ' +
  'to weight (grams, ounces) for flour, sugar, butter, milk and common baking ingredients.';
const intro =
  'Select an ingredient and enter a volume amount to see its precise weight in grams and ounces. Perfect for baking where weight accuracy matters.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'Why convert volume to weight for baking?', a: 'Baking is a science — the ratio of flour to sugar to fat determines the structure of your cake, bread or pastry. Weight measurements are far more accurate than volume because the density of flour can vary dramatically depending on how it is scooped. A cup of spooned flour weighs about 120 g, while a cup of scooped flour can weigh 150 g or more, changing the recipe entirely.' },
  { q: 'What densities does this calculator use?', a: 'This calculator uses standard reference densities from the King Arthur Baking Company and the USDA National Nutrient Database. All-purpose flour is 120 g per cup, granulated sugar is 200 g per cup, butter is 227 g per cup, and so on. These are widely accepted values used by professional bakers.' },
  { q: 'Can I convert any ingredient?', a: 'This tool covers the most common baking ingredients: all-purpose flour, bread flour, whole wheat flour, granulated sugar, brown sugar, powdered sugar, butter, milk, honey, cocoa powder and rolled oats. Each has a unique density that the calculator applies automatically.' },
  { q: 'How do I measure flour correctly by volume?', a: 'For the most accurate volume measurement, spoon the flour into your measuring cup and level it off with a straight edge — never scoop directly from the bag, as that compacts the flour. Using the spoon-and-level method gives a consistent 120 g per cup for all-purpose flour.' },
  { q: 'Is it better to bake by weight or volume?', a: 'Weight is always more accurate and repeatable, which is why professional bakeries use scales, not cups. If you own a kitchen scale, use the gram values from this calculator for every ingredient — your baking will be more consistent and your results more predictable.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Ingredient</span>
      <select id="ingredient" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="120">All-purpose flour</option>
        <option value="130">Bread flour</option>
        <option value="130">Whole wheat flour</option>
        <option value="200">Granulated sugar</option>
        <option value="220">Brown sugar (packed)</option>
        <option value="120">Powdered sugar</option>
        <option value="227">Butter</option>
        <option value="240">Milk</option>
        <option value="340">Honey</option>
        <option value="125">Cocoa powder</option>
        <option value="100">Rolled oats</option>
      </select></label>

    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume amount</span>
        <input id="volume" type="number" step="any" placeholder="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume unit</span>
        <select id="volUnit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="1">Cups</option>
          <option value="0.0625">Tablespoons (tbsp)</option>
          <option value="0.0208333">Teaspoons (tsp)</option>
        </select></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Weight</div>
        <div id="r-grams" class="mt-1 text-3xl font-bold">— g</div>
        <div id="r-ounces" class="mt-1 text-sm opacity-80">— oz</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Volume entered</div><div id="r-vol" class="mt-1 text-xl font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Density</div><div id="r-density" class="mt-1 text-xl font-bold text-slate-700">— g/cup</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Select an ingredient and enter a volume to see the weight.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      Every ingredient has a unique density — the weight of a fixed volume. A cup of granulated sugar weighs about 200 g, while a cup of all-purpose flour weighs about 120 g. This calculator stores the density (grams per cup) for each common baking ingredient and multiplies your entered volume by that density to give you the precise weight.
    </p>
    <p class="mt-3 text-slate-600">
      The density values come from established references used by professional bakers and food scientists. They represent the average across multiple measurements and brands. Individual brands can vary slightly, but these figures are accurate enough for virtually all home and commercial baking applications. For the most reliable results, use the spoon-and-level method when measuring flour by volume, or better yet, weigh everything on a digital kitchen scale.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="bc-title bc-desc">
      <title id="bc-title">Volume to weight conversion diagram</title>
      <desc id="bc-desc">A balance scale with a measuring cup on the left pan and gram and ounce weights on the right pan, illustrating the conversion from volume to weight for baking ingredients.</desc>
      <!-- Scale base -->
      <rect x="320" y="150" width="160" height="8" rx="3" fill="#64748b" />
      <rect x="388" y="120" width="24" height="30" rx="3" fill="#94a3b8" />
      <!-- Left arm -->
      <line x1="170" y1="120" x2="400" y2="120" stroke="#64748b" stroke-width="4" />
      <line x1="400" y1="120" x2="630" y2="120" stroke="#64748b" stroke-width="4" />
      <!-- Left pan -->
      <rect x="110" y="55" width="120" height="65" rx="8" fill="#f1f5f9" stroke="#6366f1" stroke-width="2" />
      <path d="M 130 55 L 150 35 L 190 35 L 210 55" fill="#f1f5f9" stroke="#6366f1" stroke-width="2" />
      <text x="170" y="98" text-anchor="middle" font-size="15" font-weight="bold" fill="#6366f1">1 cup</text>
      <text x="170" y="113" text-anchor="middle" font-size="12" fill="#6366f1">flour</text>
      <!-- Right pan -->
      <rect x="550" y="55" width="140" height="65" rx="8" fill="#f1f5f9" stroke="#10b981" stroke-width="2" />
      <line x1="590" y1="55" x2="620" y2="32" stroke="#64748b" stroke-width="2" />
      <line x1="620" y1="32" x2="650" y2="55" stroke="#64748b" stroke-width="2" />
      <text x="620" y="98" text-anchor="middle" font-size="15" font-weight="bold" fill="#10b981">120 g</text>
      <text x="620" y="113" text-anchor="middle" font-size="12" fill="#10b981">4.2 oz</text>
      <!-- Pivot triangle -->
      <polygon points="400,120 390,108 410,108" fill="#6366f1" />
      <!-- Arrow -->
      <text x="400" y="40" text-anchor="middle" font-size="13" fill="#64748b">weight = volume × density</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">A balance scale showing how 1 cup of all-purpose flour equals 120 g (4.2 oz)</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the conversion works</h2>
    <p class="mt-2 text-slate-600">
      The formula is simple: <strong>weight = volume × density</strong>. The density is the grams-per-cup value for the ingredient. The calculator also converts grams to ounces by dividing by 28.35, since 1 ounce = 28.35 grams.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A bread recipe calls for 2.5 cups of bread flour. What is that in grams and ounces?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Ingredient:</span> <span class="text-slate-600">Bread flour</span></div>
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">2.5 cups</span></div>
        <div><span class="font-medium text-slate-700">Density:</span> <span class="text-slate-600">130 g per cup</span></div>
        <div><span class="font-medium text-slate-700">Weight in grams:</span> <span class="text-slate-600">2.5 × 130 = <strong>325 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Weight in ounces:</span> <span class="text-slate-600">325 ÷ 28.35 = <strong>11.5 oz</strong></span></div>
        <div><span class="font-medium text-slate-700">Same for sugar:</span> <span class="text-slate-600">2.5 cups × 200 g/cup = <strong>500 g</strong> (17.6 oz)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍞</span>
      <h3 class="mt-2 font-semibold text-slate-900">Bread baker</h3>
      <p class="mt-1 text-sm text-slate-600">Convert cup-based bread recipes to gram measurements for consistent hydration levels and reliable dough behaviour batch after batch.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧁</span>
      <h3 class="mt-2 font-semibold text-slate-900">Cake decorator</h3>
      <p class="mt-1 text-sm text-slate-600">Precise sugar and flour weights ensure your cake layers are level, your buttercream is consistent and your final product looks professional.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📝</span>
      <h3 class="mt-2 font-semibold text-slate-900">Recipe developer</h3>
      <p class="mt-1 text-sm text-slate-600">Convert your cup-based recipes into weight-based instructions so your readers or clients get reproducible results every time they bake.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌾</span>
      <h3 class="mt-2 font-semibold text-slate-900">Gluten-free baker</h3>
      <p class="mt-1 text-sm text-slate-600">Gluten-free flours (almond, coconut, rice) have different densities. Convert precisely to maintain the delicate structure of gluten-free bakes.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Baking Conversion Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick your ingredient</h3>
        <p class="mt-1 text-sm text-slate-600">Choose from the dropdown list of common baking ingredients. Each has its own stored density value that the calculator uses.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the volume</h3>
        <p class="mt-1 text-sm text-slate-600">Type the volume amount and choose whether it is in cups, tablespoons or teaspoons. All units convert to the same gram weight.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the weight</h3>
        <p class="mt-1 text-sm text-slate-600">See the result in both grams and ounces. Use these figures to weigh your ingredients on a digital kitchen scale for best results.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always use a digital kitchen scale</h3>
        <p class="mt-1 text-sm text-slate-600">A good digital scale costs very little and transforms your baking. Weighing ingredients eliminates the variability of scooping, packing and levelling, giving you consistent results every time.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Adjust for brown sugar packing</h3>
        <p class="mt-1 text-sm text-slate-600">Brown sugar is measured packed unless otherwise specified. The calculator assumes packed brown sugar at 220 g per cup. If your recipe specifies "lightly packed" or "unpacked", reduce the weight by 10–15 percent.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Flour density varies by brand</h3>
        <p class="mt-1 text-sm text-slate-600">Different brands of flour have slightly different densities. The 120 g per cup value is a standard average. If you find your doughs are consistently too wet or too dry, adjust by 5–10 g per cup as needed.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/baking-ingredient-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🧈</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Ingredient Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert butter, flour and sugar between forms</p>
      </a>
      <a href="/tools/cooking-measurement-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🥄</span>
        <h3 class="mt-2 font-semibold text-slate-900">Cooking Measurement Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert cups, tbsp, tsp, ml and fl oz</p>
      </a>
      <a href="/tools/oven-temperature-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🌡️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Oven Temperature Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert °F, °C, gas mark and fan</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    const densities = {
      '120': { name: 'All-purpose flour', cupG: 120 },
      '130': { name: 'Bread flour', cupG: 130 },
      '200': { name: 'Granulated sugar', cupG: 200 },
      '220': { name: 'Brown sugar (packed)', cupG: 220 },
      '227': { name: 'Butter', cupG: 227 },
      '240': { name: 'Milk', cupG: 240 },
      '340': { name: 'Honey', cupG: 340 },
      '125': { name: 'Cocoa powder', cupG: 125 },
      '100': { name: 'Rolled oats', cupG: 100 },
    };

    function update() {
      const sel = el('ingredient');
      const density = parseFloat(sel.value);
      const vol = parseFloat(el('volume').value);
      const volUnit = parseFloat(el('volUnit').value);
      const servings = parseFloat(sel.options[sel.selectedIndex].textContent);

      if (!vol || vol <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      const cups = vol * volUnit;
      const grams = cups * density;
      const ounces = grams / 28.3495;

      el('r-grams').innerHTML = grams.toLocaleString(undefined, { maximumFractionDigits: 1 }) + ' <span class="text-lg opacity-80">g</span>';
      el('r-ounces').textContent = ounces.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' oz';
      el('r-vol').textContent = vol.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' ' + el('volUnit').options[el('volUnit').selectedIndex].textContent;
      el('r-density').textContent = density + ' g/cup';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('ingredient').addEventListener('input', update);
    el('volume').addEventListener('input', update);
    el('volUnit').addEventListener('input', update);
  </script>
</ToolLayout>
