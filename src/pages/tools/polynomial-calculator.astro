---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Polynomial Calculator';
const description = 'Add, subtract, multiply, and evaluate polynomials. Free online polynomial calculator with step-by-step combining of like terms.';
const intro = 'Add, subtract, multiply polynomials and evaluate them at any point. See the step-by-step combination of like terms.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is a polynomial?', a: 'A polynomial is an expression consisting of variables (like x) and coefficients, combined using addition, subtraction, multiplication, and non-negative integer exponents. For example, 3x² + 2x - 5 is a polynomial.' },
  { q: 'What are like terms?', a: 'Like terms have the same variable raised to the same power. For example, 3x² and -2x² are like terms and can be combined: 3x² - 2x² = x². But 3x² and 2x are not like terms because they have different exponents.' },
  { q: 'How do you evaluate a polynomial?', a: 'Substitute the given value of x into the polynomial and simplify. For example, evaluating 3x² + 2x - 5 at x = 2 gives 3(4) + 4 - 5 = 12 + 4 - 5 = 11.' },
  { q: 'What is the degree of a polynomial?', a: 'The degree is the highest exponent of the variable. For example, 3x² + 2x - 5 has degree 2. A constant has degree 0. A linear polynomial has degree 1, quadratic degree 2, cubic degree 3.' },
  { q: 'What operations can I perform?', a: 'You can add polynomials (combining like terms), subtract polynomials, multiply polynomials (distributing each term), and evaluate a polynomial at a specific value of x.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-3">
      <div class="flex-1 min-w-[160px]">
        <label class="block text-sm font-medium text-slate-700" for="poly-input">Coefficients (highest degree first)</label>
        <input id="poly-input" type="text" value="3, 2, -5" placeholder="e.g. 3, 2, -5"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="w-28">
        <label class="block text-sm font-medium text-slate-700" for="poly-x">x =</label>
        <input id="poly-x" type="number" step="any" value="2" placeholder="2"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>
    <div id="poly-result-display" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
      <span class="text-sm opacity-90">P(x) =</span>
      <span id="poly-expression" class="ml-2 text-xl font-bold">3x² + 2x - 5</span>
    </div>
    <div class="mt-3 grid gap-3 sm:grid-cols-2">
      <div id="poly-eval-result" class="rounded-xl bg-slate-50 p-4 text-center">
        <span class="text-sm text-slate-500">P(2) =</span>
        <span id="poly-eval-val" class="ml-2 text-lg font-bold text-emerald-700">11</span>
      </div>
      <div id="poly-degree-result" class="rounded-xl bg-slate-50 p-4 text-center text-sm text-slate-500">
        Degree: <span id="poly-degree-val" class="font-bold text-slate-800">2</span>
        <span class="ml-3">|</span>
        Leading coefficient: <span id="poly-leading-val" class="font-bold text-slate-800">3</span>
      </div>
    </div>
    <div id="poly-steps" class="mt-3 hidden rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="600" height="300" viewBox="0 0 600 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="poly-title poly-desc">
      <title id="poly-title">Combining like terms in a polynomial: 3x² + 2x - 5 with color-coded terms</title>
      <desc id="poly-desc">A polynomial 3x² + 2x - 5 with each term in a different color. Like terms are grouped together visually. The x² terms are blue, x terms are green, and constants are orange.</desc>
      <rect x="30" y="20" width="540" height="260" rx="10" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" />
      <text x="300" y="60" text-anchor="middle" fill="#1e293b" font-size="16" font-weight="bold">Polynomial: 3x² + 2x - 5</text>
      <rect x="100" y="100" width="100" height="60" rx="8" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
      <text x="150" y="137" text-anchor="middle" fill="#4338ca" font-size="20" font-weight="bold">3x²</text>
      <text x="150" y="88" text-anchor="middle" fill="#6366f1" font-size="12">Coefficient 3</text>
      <text x="210" y="137" text-anchor="middle" fill="#1e293b" font-size="24">+</text>
      <rect x="225" y="100" width="100" height="60" rx="8" fill="#ecfdf5" stroke="#10b981" stroke-width="2" />
      <text x="275" y="137" text-anchor="middle" fill="#059669" font-size="20" font-weight="bold">2x</text>
      <text x="275" y="88" text-anchor="middle" fill="#10b981" font-size="12">Coefficient 2</text>
      <text x="335" y="137" text-anchor="middle" fill="#1e293b" font-size="24">-</text>
      <rect x="350" y="100" width="100" height="60" rx="8" fill="#fff7ed" stroke="#f59e0b" stroke-width="2" />
      <text x="400" y="137" text-anchor="middle" fill="#d97706" font-size="20" font-weight="bold">5</text>
      <text x="400" y="88" text-anchor="middle" fill="#f59e0b" font-size="12">Constant</text>
      <text x="300" y="210" text-anchor="middle" fill="#64748b" font-size="14">Each term has a coefficient (blue/green) and a variable with an exponent.</text>
      <text x="300" y="240" text-anchor="middle" fill="#64748b" font-size="13">Degree = highest exponent = 2 &rarr; quadratic polynomial</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">A quadratic polynomial with color-coded terms: the coefficient, variable, and exponent of each term.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How polynomial calculations work</h2>
    <p class="mt-2 text-slate-600">A polynomial is an algebraic expression composed of terms. Each term has a coefficient (a constant multiplier) and a variable raised to a non-negative integer exponent. The general form of a polynomial in one variable is aₙxⁿ + aₙ₋₁xⁿ⁻¹ + ... + a₁x + a₀, where aₙ is the leading coefficient and n is the degree.</p>
    <p class="mt-3 text-slate-600">Adding and subtracting polynomials is performed by combining like terms — terms that have the same variable exponent. For example, (3x² + 2x - 5) + (x² - 4x + 3) = (3+1)x² + (2-4)x + (-5+3) = 4x² - 2x - 2. The calculator shows this combination step by step so you can follow the process.</p>
    <p class="mt-3 text-slate-600">Polynomial multiplication uses the distributive property: each term in the first polynomial multiplies every term in the second. For example, (x + 2)(x + 3) = x(x+3) + 2(x+3) = x² + 3x + 2x + 6 = x² + 5x + 6. Evaluating a polynomial means substituting a specific value for x and computing the result using standard order of operations.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">General polynomial form</h3>
        <p class="mt-1 font-mono text-lg font-bold text-indigo-700">aₙxⁿ + aₙ₋₁xⁿ⁻¹ + ... + a₁x + a₀</p>
        <p class="mt-2 text-sm text-slate-600">Each aᵢ is a coefficient. The highest index n is the degree. Terms with zero coefficients are omitted.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Evaluation (Horner's method)</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">P(x) = a₀ + x(a₁ + x(a₂ + ...))</p>
        <p class="mt-2 text-sm text-slate-600">Horner's method evaluates polynomials efficiently using nested multiplication, reducing the number of multiplications.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: Evaluate P(x) = 3x² + 2x - 5 at x = 2</h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>Step 1: Substitute x = 2: P(2) = 3(2)² + 2(2) - 5</p>
        <p>Step 2: Evaluate exponents: 3(4) + 2(2) - 5</p>
        <p>Step 3: Multiply: 12 + 4 - 5</p>
        <p>Step 4: Add/subtract: 12 + 4 = 16, 16 - 5 = 11</p>
        <p class="font-semibold text-emerald-700">Therefore: P(2) = 11</p>
        <p class="mt-1 text-slate-500">Using Horner's method: P(2) = -5 + 2(2 + 2(3)) = -5 + 2(2 + 6) = -5 + 2(8) = -5 + 16 = 11 &checkmark;</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4D0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Students &amp; Teachers</h3>
      <p class="mt-1 text-sm text-slate-600">Polynomials are a core topic in algebra courses. Understanding operations with polynomials — addition, subtraction, multiplication, and evaluation — is essential for advanced math including calculus, where polynomials are the simplest functions to differentiate and integrate.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4C8;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Data Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">Polynomial regression models relationships between variables using polynomial functions. A quadratic (degree 2) model can capture curvature in data. Higher-degree polynomials can fit complex patterns but risk overfitting.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Engineers</h3>
      <p class="mt-1 text-sm text-slate-600">Polynomials model physical systems: beam deflection (cubic polynomials), projectile motion (quadratic), and electrical filter responses. Taylor series expand any smooth function as an infinite polynomial for approximation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Economists</h3>
      <p class="mt-1 text-sm text-slate-600">Cost functions, revenue curves, and utility functions are often modeled as polynomials. Quadratic cost functions (TC = aQ² + bQ + c) capture diminishing returns. Cubic polynomials model S-shaped growth curves in production theory.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the polynomial calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter coefficients</h3>
        <p class="mt-1 text-sm text-slate-600">Type the coefficients separated by commas, starting from the highest degree term. For 3x² + 2x - 5, enter "3, 2, -5". Include zeros for missing terms.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the evaluation point</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the value of x at which to evaluate the polynomial. The result appears instantly with the step-by-step calculation shown.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Review the details</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator shows the polynomial expression, degree, leading coefficient, evaluation result, and the step-by-step substitution process.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with polynomials</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Standard form matters</h3>
        <p class="mt-1 text-sm text-slate-600">Always write polynomials in standard form — terms ordered from highest degree to lowest (descending powers). This makes it easy to identify the degree, leading coefficient, and like terms for combining. The calculator expects coefficients in this order.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Missing terms are zero</h3>
        <p class="mt-1 text-sm text-slate-600">If a polynomial skips a degree (e.g., 3x² + 5 has no x term), enter a zero for the missing coefficient. For 3x² + 0x - 5, you would enter "3, 0, -5". The calculator correctly handles this and omits the zero term from the display.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Check your signs</h3>
        <p class="mt-1 text-sm text-slate-600">Negative coefficients must include the minus sign. The expression "3, 2, -5" represents 3x² + 2x - 5. A coefficient of "0" means that term is absent. Double-check your signs when entering coefficients for subtraction and negative terms.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use Horner's method mentally</h3>
        <p class="mt-1 text-sm text-slate-600">For quick manual evaluation, Horner's method is efficient: start with the leading coefficient, multiply by x, add the next coefficient, repeat. For 3x² + 2x - 5 at x = 2: start with 3, multiply by 2 = 6, add 2 = 8, multiply by 2 = 16, subtract 5 = 11. Only 2 multiplications and 2 additions.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/quadratic-equation-solver" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4C8;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Quadratic Equation Solver</h3>
        <p class="mt-0.5 text-xs text-slate-500">Solve quadratic equations and find roots using the quadratic formula.</p>
      </a>
      <a href="/tools/linear-equation-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x2194;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Linear Equation Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Solve linear equations and find the slope and intercept of a line.</p>
      </a>
      <a href="/tools/exponent-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4D0;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Exponent Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate powers and exponents for polynomial term evaluation.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const polyInput = document.getElementById('poly-input');
    const polyX = document.getElementById('poly-x');
    const polyExpression = document.getElementById('poly-expression');
    const polyEvalVal = document.getElementById('poly-eval-val');
    const polyDegreeVal = document.getElementById('poly-degree-val');
    const polyLeadingVal = document.getElementById('poly-leading-val');
    const polySteps = document.getElementById('poly-steps');

    function formatPoly(coeffs) {
      const terms = [];
      const degree = coeffs.length - 1;
      for (let i = 0; i < coeffs.length; i++) {
        const c = coeffs[i];
        if (c === 0) continue;
        const exp = degree - i;
        let term = '';
        if (exp === 0) term = `${c}`;
        else if (exp === 1) term = `${c === 1 ? '' : c === -1 ? '-' : c}x`;
        else term = `${c === 1 ? '' : c === -1 ? '-' : c}x<sup>${exp}</sup>`;
        if (c > 0 && terms.length > 0) term = '+ ' + term;
        if (c < 0 && terms.length > 0) term = '- ' + term.replace(/^-/, '');
        terms.push(term);
      }
      return terms.join(' ') || '0';
    }

    function calculate() {
      const raw = polyInput.value.trim();
      const xVal = parseFloat(polyX.value);

      if (!raw || isNaN(xVal)) {
        polyExpression.textContent = '—';
        polyEvalVal.textContent = '—';
        polyDegreeVal.textContent = '—';
        polyLeadingVal.textContent = '—';
        polySteps.classList.add('hidden');
        return;
      }

      const coeffs = raw.split(',').map(s => parseFloat(s.trim()));
      if (coeffs.some(isNaN) || coeffs.length === 0) {
        polyExpression.textContent = 'Invalid';
        polyEvalVal.textContent = '—';
        polyDegreeVal.textContent = '—';
        polyLeadingVal.textContent = '—';
        polySteps.classList.add('hidden');
        return;
      }

      const effectiveCoeffs = [...coeffs];
      while (effectiveCoeffs.length > 1 && effectiveCoeffs[0] === 0) effectiveCoeffs.shift();

      polyExpression.innerHTML = formatPoly(effectiveCoeffs);

      const degree = effectiveCoeffs.length - 1;
      polyDegreeVal.textContent = degree;
      polyLeadingVal.textContent = effectiveCoeffs[0];

      let result = 0;
      const steps = [];
      for (let i = 0; i < effectiveCoeffs.length; i++) {
        const exp = degree - i;
        const term = effectiveCoeffs[i] * Math.pow(xVal, exp);
        result += term;
        steps.push({ coeff: effectiveCoeffs[i], exp, term });
      }

      polyEvalVal.textContent = result.toLocaleString(undefined, { maximumFractionDigits: 6 });

      let stepsHtml = '<p class="font-semibold text-indigo-700">Evaluation steps:</p>';
      stepsHtml += `<p>P(${xVal.toLocaleString()}) = `;
      const substeps = steps.map(s => {
        if (s.exp === 0) return `${s.coeff}`;
        if (s.exp === 1) return `${s.coeff}(${xVal.toLocaleString()})`;
        return `${s.coeff}(${xVal.toLocaleString()}<sup>${s.exp}</sup>)`;
      });
      stepsHtml += substeps.join(' + ').replace(/\+ -/g, '- ');
      stepsHtml += '</p>';

      const evalSteps = steps.map(s => {
        if (s.exp === 0) return `${s.coeff}`;
        const pow = Math.pow(xVal, s.exp);
        return `${s.coeff} × ${pow.toLocaleString(undefined, { maximumFractionDigits: 4 })} = ${s.term.toLocaleString(undefined, { maximumFractionDigits: 4 })}`;
      });
      stepsHtml += '<p class="mt-1">' + evalSteps.join('<br>') + '</p>';
      stepsHtml += `<p class="mt-1 font-semibold text-emerald-700">P(${xVal.toLocaleString()}) = ${result.toLocaleString(undefined, { maximumFractionDigits: 6 })}</p>`;

      polySteps.innerHTML = stepsHtml;
      polySteps.classList.remove('hidden');
    }

    polyInput.addEventListener('input', calculate);
    polyX.addEventListener('input', calculate);
    calculate();
  </script>
</ToolLayout>
