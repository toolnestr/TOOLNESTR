---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Ease Calculator (Wearing & Design Ease)';
const description = 'Calculate the finished garment measurement by adding standard wearing ease to a body measurement.';
const intro = 'Add standard wearing ease to a body measurement to find the correct finished garment measurement.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is the difference between wearing ease and design ease?', a: 'Wearing ease is the minimum extra room a garment needs for the body to move and breathe comfortably. Design ease is any additional room added on top of that for a specific silhouette or style, such as an oversized or A-line cut — this calculator\'s "loose" and "very loose" categories mostly reflect design ease layered on top of basic wearing ease.' },
  { q: 'Why would a garment ever have negative ease?', a: 'Stretch knit fabrics (like a fitted t-shirt or athletic wear) rely on the fabric\'s own stretch to fit close to the body, so the pattern is sometimes cut slightly smaller than the body measurement — the fabric\'s recovery provides the "ease" instead of extra cut fabric.' },
  { q: 'Should I use my exact body measurement or a size chart measurement?', a: 'Use your own measured body measurement for the most accurate result — pattern size charts are a separate approximation of body measurements and may not match your actual body as precisely as measuring yourself directly.' },
  { q: 'Does ease apply the same way to waist and hip as it does to bust?', a: 'The same general principle applies, but the specific ease amount can differ slightly by body area and garment type — a fitted dress might use less ease at the waist than at the bust, so check a specific pattern\'s finished garment measurements when precision matters.' },
];
const howTo = {
  name: 'How to calculate finished garment measurement using ease',
  steps: [
    { name: 'Enter your body measurement', text: 'Measure the relevant body area (usually bust) in inches.' },
    { name: 'Choose a fit category', text: 'Select how fitted or loose you want the finished garment to be.' },
    { name: 'Read the finished measurement', text: 'The calculator adds the standard ease range for that fit category to your body measurement.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Body measurement (in)</span>
      <input id="body" type="number" step="any" placeholder="e.g. 36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Fit category</span>
      <select id="fit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100">
        <option value="0">Very close-fitting (stretch knits, 0-2 7/8 in)</option>
        <option value="1" selected>Close-fitting (3-4 in)</option>
        <option value="2">Fitted (4 1/8-5 in)</option>
        <option value="3">Semi-fitted (5 1/8-8 in)</option>
        <option value="4">Loose-fitting (8 1/8-12 in)</option>
        <option value="5">Very loose-fitting (12+ in)</option>
      </select>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Finished garment measurement</div>
        <div id="r-finished" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Ease range added</div><div id="r-ease" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ec-title ec-desc">
      <title id="ec-title">Body outline inside a larger garment outline</title>
      <desc id="ec-desc">A body silhouette shown inside a larger garment silhouette, with the gap between them labeled as ease</desc>
      <path d="M400 40 Q375 40 372 65 Q370 85 385 95 Q365 105 362 140 Q360 170 385 185 L415 185 Q440 170 438 140 Q435 105 415 95 Q430 85 428 65 Q425 40 400 40Z" fill="#fecdd3" fill-opacity="0.6" stroke="#e11d48" stroke-width="2" />
      <path d="M400 20 Q360 20 356 55 Q353 80 372 92 Q345 105 340 150 Q337 185 372 205 L428 205 Q463 185 460 150 Q455 105 428 92 Q447 80 444 55 Q440 20 400 20Z" fill="none" stroke="#94a3b8" stroke-width="2" stroke-dasharray="6 3" />
      <text x="500" y="60" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Garment outline</text>
      <text x="500" y="80" font-size="13" fill="#94a3b8" font-family="system-ui,sans-serif">(body + ease)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Ease is the gap between the body and the finished garment</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How ease works</h2>
    <p class="mt-2 text-slate-600">
      Ease is the difference between a body measurement and the corresponding finished garment measurement — without it, a garment cut to your exact body size would restrict movement and feel uncomfortably tight. Pattern companies group ease into standard fit categories, each with an established range: very close-fitting (0 to 2 7/8 inches, mostly for stretch fabrics), close-fitting (3-4 inches), fitted (4⅛-5 inches), semi-fitted (5⅛-8 inches), loose-fitting (8⅛-12 inches), and very loose-fitting (12 inches or more).
    </p>
    <p class="mt-3 text-slate-600">
      This calculator adds the midpoint and full range of the selected category to your body measurement, giving the finished measurement a pattern or garment should have at that bust, waist, or hip point. Sewists use this in reverse too — measuring an existing well-fitting garment and subtracting the body measurement reveals how much ease that garment actually has.
    </p>
    <p class="mt-3 text-xs text-slate-400">Ease ranges follow the standard fit-category chart used across major home-sewing pattern companies (Simplicity, McCall's, Butterick, Vogue Patterns).</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A sewist with a 36-inch bust wants a semi-fitted blouse pattern.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Body bust:</span> <span class="text-slate-600">36 in</span></div>
        <div><span class="font-medium text-slate-700">Semi-fitted ease:</span> <span class="text-slate-600">+5⅛ to 8 in</span></div>
        <div><span class="font-medium text-slate-700">Finished measurement:</span> <span class="text-slate-600"><strong>~41.6-44 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Adjusting a purchased sewing pattern to your actual body is the most direct use case — pattern envelopes list a body-measurement size chart, but the tissue pattern itself is already cut with ease built in, so understanding how much ease a "fitted" versus "semi-fitted" pattern includes helps decide whether to size up, down, or leave it as printed.
    </p>
    <p class="mt-3 text-slate-600">
      Ease also explains why ready-to-wear brands can list wildly different "size 8" measurements: a size 8 fitted sheath dress and a size 8 loose tunic from the same brand can have finished bust measurements several inches apart, purely because of how much design ease each style was drafted with.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A pattern's size chart measurement is the finished garment measurement." <strong class="text-slate-900">It usually isn't.</strong> The size chart lists body measurements to help you pick a size; the finished garment measurement (listed separately on most patterns) already has ease added on top.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"More ease always means more comfortable." <strong class="text-slate-900">Not necessarily.</strong> Too much ease can make a garment look shapeless or cause it to shift and bunch during movement — the right amount of ease depends on the intended silhouette, not just maximizing room.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/dress-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Dress Size Calculator</a>
      <a href="/tools/pattern-grading-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Pattern Grading Calculator</a>
      <a href="/tools/seam-allowance-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Seam Allowance Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    // [low, high] ease in inches
    const eases = [
      [0, 2.875], [3, 4], [4.125, 5], [5.125, 8], [8.125, 12], [12, 16],
    ];
    const labels = ['0-2⅞ in', '3-4 in', '4⅛-5 in', '5⅛-8 in', '8⅛-12 in', '12+ in'];

    function update() {
      const body = parseFloat(el('body').value);
      const idx = parseInt(el('fit').value, 10);
      if (!body || body <= 0) { el('results').classList.add('hidden'); return; }
      const [lo, hi] = eases[idx];
      const finishedLo = body + lo;
      const finishedHi = body + hi;
      el('r-finished').textContent = finishedLo.toFixed(1) + ' - ' + finishedHi.toFixed(1) + ' in';
      el('r-ease').textContent = labels[idx];
      el('results').classList.remove('hidden');
    }

    el('body').addEventListener('input', update);
    el('fit').addEventListener('change', update);
  </script>
</ToolLayout>
