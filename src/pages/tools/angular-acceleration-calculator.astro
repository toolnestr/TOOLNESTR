---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Angular Acceleration Calculator';
const description = 'Angular acceleration calculator with a live 3D spinning wheel and charts. Solve α = Δω/Δt, relate it to tangential acceleration α = aₜ/r, with worked examples.';
const intro = 'Find angular acceleration from a change in angular velocity over time, or from tangential acceleration and radius. A live 3D wheel and charts show a spin-up in action.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is angular acceleration?', a: 'Angular acceleration (α) is the rate at which angular velocity changes over time: α = Δω/Δt. It is measured in radians per second squared (rad/s²) and is positive when spin speeds up, negative when it slows down.' },
  { q: 'How is angular acceleration related to tangential acceleration?', a: 'A point at radius r from the rotation axis has tangential (linear) acceleration aₜ = αr. The farther a point is from the axis, the more linear acceleration it feels for the same angular acceleration — this is why the rim of a wheel accelerates faster than a point near the hub.' },
  { q: 'What is the difference between angular velocity and angular acceleration?', a: 'Angular velocity ω (rad/s) is how fast something is spinning right now. Angular acceleration α (rad/s²) is how fast that spin rate itself is changing. A wheel can spin at a constant, large ω with zero α, or spin slowly while α is large if it is speeding up quickly.' },
  { q: 'How does torque relate to angular acceleration?', a: 'Newton\'s second law for rotation is τ = Iα, where τ is net torque and I is the moment of inertia. This is the rotational analogue of F = ma — torque causes angular acceleration, and how much depends on how mass is distributed (I) around the axis.' },
  { q: 'What are typical values of angular acceleration?', a: 'A power drill can reach hundreds of rad/s² spinning up in a fraction of a second. A car engine idling up might see tens of rad/s². A merry-go-round pushed by hand is closer to 0.5–2 rad/s². The number depends entirely on how much torque is applied and how resistant the object is to being spun (its moment of inertia).' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Angular Acceleration Calculator',
  description: 'Calculate angular acceleration from a change in angular velocity over time, or from tangential acceleration and radius.',
  steps: [
    { name: 'Pick a mode', text: 'Choose "From Δω/Δt" (α = Δω/Δt) or "From tangential acceleration" (α = aₜ/r).' },
    { name: 'Enter three of the four values', text: 'Type any values you know in the chosen mode; the calculator solves the missing one.' },
    { name: 'Read the result', text: 'Angular acceleration solves instantly, and the 3D wheel spins up or down to match.' },
  ],
};

const formulas = [
  { expr: 'α = Δω / Δt', note: 'average angular acceleration from change in angular velocity over time' },
  { expr: 'α = a<sub>t</sub> / r', note: 'from tangential acceleration and radius' },
  { expr: 'τ = I × α', note: 'rotational Newton\'s second law — torque and moment of inertia' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a fan spinning up', tone: 'slate',
    given: 'A ceiling fan starts from rest and reaches 15 rad/s in 3.0 s. Find its angular acceleration.',
    rows: [
      { label: 'Change in ω:', value: 'Δω = ω_f − ω_i = 15 − 0 = 15 rad/s' },
      { label: 'Angular acceleration:', value: 'α = Δω ÷ Δt = 15 ÷ 3.0 = 5.0 rad/s²' },
      { label: 'Check:', value: 'ω_f = ω_i + αΔt = 0 + 5.0 × 3.0 = 15 rad/s ✓', full: true },
    ],
  },
  {
    title: 'Worked example 2 — a grinding wheel rim', tone: 'amber',
    given: 'A grinding wheel of radius 0.10 m has a point on its rim with tangential acceleration 2.0 m/s². Find the angular acceleration, then use it to find how long it takes the wheel to go from 20 rad/s to 50 rad/s.',
    rows: [
      { label: 'Angular acceleration:', value: 'α = a_t ÷ r = 2.0 ÷ 0.10 = 20 rad/s²' },
      { label: 'Rearranged for time:', value: 'Δt = Δω ÷ α = (50 − 20) ÷ 20 = 1.5 s' },
    ],
    note: 'The same α links the rim\'s linear acceleration to the wheel\'s change in spin rate.',
  },
];

const comparison = {
  heading: 'Angular acceleration vs its linear analogue',
  note: 'Rotational motion mirrors straight-line motion — same equations, different symbols.',
  headers: [{ label: 'Quantity' }, { label: 'Linear' }, { label: 'Angular' }],
  rows: [
    ['Position', 'x (m)', 'θ (rad)'],
    ['Velocity', 'v = Δx/Δt (m/s)', 'ω = Δθ/Δt (rad/s)'],
    ['Acceleration', 'a = Δv/Δt (m/s²)', 'α = Δω/Δt (rad/s²)'],
    ['Cause of acceleration', 'F = ma', 'τ = Iα'],
    ['Link between them', '—', 'a_t = αr'],
  ],
  highlightIndex: 2,
  footnote: 'Every linear kinematics equation has a rotational twin: x→θ, v→ω, a→α, m→I, F→τ.',
};

const realWorld = [
  { emoji: '🛠️', title: 'Power tools spinning up', body: 'A drill or angle grinder motor applies a large torque to a low-inertia rotor, producing huge angular acceleration — full spin speed in a fraction of a second. Reducing the load (I) or increasing torque both raise α, per τ = Iα.' },
  { emoji: '🌀', title: 'Turbines and engines', body: 'Jet engines and wind turbines are rated partly by how quickly they can change rotor speed. Spooling up a turbine involves controlled, gradual α to avoid mechanical stress; emergency shutdowns use large negative α to stop the blades fast.' },
  { emoji: '⛸️', title: 'Figure skater spins', body: 'Pulling the arms in reduces moment of inertia I. Since angular momentum Iω is conserved, ω jumps up — the skater experiences a burst of angular acceleration without any external torque, purely from redistributing mass.' },
  { emoji: '🚲', title: 'Bicycle wheels braking', body: 'Squeezing the brakes applies a torque that produces negative angular acceleration on the wheel. The tangential deceleration felt at the tire contact patch is α × r, which is why bigger wheels need proportionally less α to stop as fast.' },
];

const misconceptions = [
  { claim: '"Angular acceleration and angular velocity are the same thing."', truth: 'They are different quantities entirely. ω tells you how fast something is spinning right now; α tells you how fast that spin rate is changing. A flywheel spinning at a huge, constant ω has zero angular acceleration.' },
  { claim: '"If α is zero, the object isn\'t moving."', truth: 'Zero angular acceleration just means constant angular velocity — the object can still be spinning steadily and fast. α = 0 describes uniform rotation, not rest.' },
  { claim: '"A bigger radius always means more angular acceleration."', truth: 'Radius relates α to tangential acceleration (a_t = αr), not the other way around. For a fixed torque, a larger radius typically increases moment of inertia, which actually reduces α (since α = τ/I).' },
  { claim: '"Angular acceleration is always constant in real rotating systems."', truth: 'Constant α is a simplifying assumption, just like constant a in linear kinematics. Real motors, engines and turbines apply varying torque, so α often changes throughout a spin-up or spin-down.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Chapter 10, "Fixed-Axis Rotation" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/10-2-relating-angular-and-translational-quantities" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 10, Rotation.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 10, Rotation of a Rigid Object About a Fixed Axis.' },
];
const sourcesNote = 'Angular acceleration is in radians per second squared (rad/s²). Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"From Δω/Δt" for a spin-up/spin-down; "From tangential acceleration" to convert aₜ and r.' },
  { title: 'Enter the known values', body: 'Fill in the fields you know; the remaining one solves live.' },
  { title: 'Watch the wheel', body: 'Use the ω_i, ω_f and Δt sliders to see the 3D wheel visibly speed up or slow down.' },
];

const related = [
  { href: '/tools/uniform-circular-motion-calculator', emoji: '🔄', title: 'Uniform Circular Motion Calculator', desc: 'Angular velocity, period, centripetal force.' },
  { href: '/tools/momentum-calculator', emoji: '🎯', title: 'Momentum & Impulse Calculator', desc: 'p = mv and Δp = FΔt.' },
  { href: '/tools/force-calculator', emoji: '💥', title: 'Force Calculator (F=ma)', desc: 'Solve for force, mass, or acceleration.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="angular acceleration is how quickly spin rate itself is changing — the rotational twin of ordinary acceleration, linked to torque by τ = Iα and to a point's straight-line acceleration by aₜ = αr."
  howIntro="Rearranged, the Δω/Δt form solves any of the three quantities: ω_f = ω_i + αΔt, ω_i = ω_f − αΔt, and Δt = Δω/α. The tangential form α = a_t/r lets you move between a spinning object's angular acceleration and the linear acceleration felt at any point on it."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where angular acceleration actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-dw" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From Δω/Δt</button>
      <button id="mode-at" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From tangential acceleration</button>
    </div>
    <div id="dw-fields" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Angular accel. (α)<span class="text-slate-400"> rad/s²</span></span>
        <input id="alpha" type="number" step="any" placeholder="rad/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial ω (ω<sub>i</sub>)<span class="text-slate-400"> rad/s</span></span>
        <input id="wi" type="number" step="any" placeholder="rad/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Final ω (ω<sub>f</sub>)<span class="text-slate-400"> rad/s</span></span>
        <input id="wf" type="number" step="any" placeholder="rad/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time (Δt)<span class="text-slate-400"> s</span></span>
        <input id="dt" type="number" step="any" placeholder="s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="at-fields" class="hidden gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Angular accel. (α)<span class="text-slate-400"> rad/s²</span></span>
        <input id="alpha2" type="number" step="any" placeholder="rad/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Tangential accel. (a<sub>t</sub>)<span class="text-slate-400"> m/s²</span></span>
        <input id="at" type="number" step="any" placeholder="m/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Radius (r)<span class="text-slate-400"> m</span></span>
        <input id="rad" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="dw-results" class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">α</div><div id="r-alpha" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">ω<sub>i</sub></div><div id="r-wi" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">ω<sub>f</sub></div><div id="r-wf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Δt</div><div id="r-dt" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <div id="at-results" class="mt-6 hidden grid-cols-3 gap-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">α</div><div id="r2-alpha" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">a<sub>t</sub></div><div id="r2-at" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">r</div><div id="r2-r" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="aa-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D spinning wheel + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D spin-up</h2>
      <p class="mt-1 text-sm text-slate-500">Set the initial and final angular velocity and the time to reach it; the wheel visibly speeds up or slows down at the resulting angular acceleration. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-3">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Initial ω <span id="out-bwi" class="font-mono text-indigo-600">0.0 rad/s</span></span>
          <input id="b-wi" type="range" min="-20" max="20" step="0.5" value="0" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Final ω <span id="out-bwf" class="font-mono text-indigo-600">15.0 rad/s</span></span>
          <input id="b-wf" type="range" min="-20" max="20" step="0.5" value="15" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Time Δt <span id="out-bdt" class="font-mono text-indigo-600">3.0 s</span></span>
          <input id="b-dt" type="range" min="0.5" max="10" step="0.1" value="3" class="mt-2 w-full accent-indigo-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">α = Δω/Δt = <span id="out-balpha" class="font-mono font-bold">5.00 rad/s²</span></div>
      <div id="wheel3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="wheel3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Angular acceleration graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ω vs time (constant α) — a straight ramp</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-wt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">α vs Δt (fixed Δω) — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-adt"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.1, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      // ---- calculator ----
      let mode = 'dw';
      function switchMode(m) {
        mode = m;
        el('mode-dw').className = m === 'dw' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-at').className = m === 'at' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('dw-fields').className = m === 'dw' ? 'grid gap-4 sm:grid-cols-2 lg:grid-cols-4' : 'hidden';
        el('at-fields').className = m === 'at' ? 'grid gap-4 sm:grid-cols-3' : 'hidden gap-4 sm:grid-cols-3';
        el('dw-results').className = m === 'dw' ? 'mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4' : 'hidden mt-6 grid-cols-2 gap-3 sm:grid-cols-4';
        el('at-results').className = m === 'at' ? 'mt-6 grid grid-cols-3 gap-3' : 'mt-6 hidden grid-cols-3 gap-3';
        el('aa-err').textContent = '';
        update();
      }
      function update() {
        el('aa-err').textContent = '';
        if (mode === 'dw') {
          ['r-alpha', 'r-wi', 'r-wf', 'r-dt'].forEach((id) => (el(id).textContent = '—'));
          const a = parseFloat(el('alpha').value), wi = parseFloat(el('wi').value), wf = parseFloat(el('wf').value), dt = parseFloat(el('dt').value);
          const filled = [!isNaN(a), !isNaN(wi), !isNaN(wf), !isNaN(dt)];
          if (filled.filter(Boolean).length < 3) return;
          let rA = a, rWi = wi, rWf = wf, rDt = dt;
          if (!filled[0]) { // solve alpha
            if (dt === 0) { el('aa-err').textContent = 'Time cannot be zero.'; return; }
            rA = (wf - wi) / dt;
          } else if (!filled[1]) { // solve wi
            rWi = wf - a * dt;
          } else if (!filled[2]) { // solve wf
            rWf = wi + a * dt;
          } else if (!filled[3]) { // solve dt
            if (a === 0) { el('aa-err').textContent = 'Angular acceleration cannot be zero when solving for time.'; return; }
            rDt = (wf - wi) / a;
            if (rDt < 0) { el('aa-err').textContent = 'These values give a negative time — check signs of ω and α.'; return; }
          }
          el('r-alpha').textContent = fmt(rA) + ' rad/s²';
          el('r-wi').textContent = fmt(rWi) + ' rad/s';
          el('r-wf').textContent = fmt(rWf) + ' rad/s';
          el('r-dt').textContent = fmt(rDt) + ' s';
        } else {
          ['r2-alpha', 'r2-at', 'r2-r'].forEach((id) => (el(id).textContent = '—'));
          const a = parseFloat(el('alpha2').value), at = parseFloat(el('at').value), r = parseFloat(el('rad').value);
          const filled = [!isNaN(a), !isNaN(at), !isNaN(r)];
          if (filled.filter(Boolean).length < 2) return;
          let rA = a, rAt = at, rR = r;
          if (!filled[0]) { if (r === 0) { el('aa-err').textContent = 'Radius cannot be zero.'; return; } rA = at / r; }
          else if (!filled[1]) { rAt = a * r; }
          else if (!filled[2]) { if (a === 0) { el('aa-err').textContent = 'Angular acceleration cannot be zero when solving for radius.'; return; } rR = at / a; }
          el('r2-alpha').textContent = fmt(rA) + ' rad/s²';
          el('r2-at').textContent = fmt(rAt) + ' m/s²';
          el('r2-r').textContent = fmt(rR) + ' m';
        }
      }
      el('mode-dw').addEventListener('click', () => switchMode('dw'));
      el('mode-at').addEventListener('click', () => switchMode('at'));
      ['alpha', 'wi', 'wf', 'dt', 'alpha2', 'at', 'rad'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let wheel = null;
      function bState() {
        const wi = parseFloat(el('b-wi').value), wf = parseFloat(el('b-wf').value), dt = parseFloat(el('b-dt').value);
        return { wi, wf, dt, alpha: dt > 0 ? (wf - wi) / dt : 0 };
      }
      function onB() {
        const s = bState();
        el('out-bwi').textContent = s.wi.toFixed(1) + ' rad/s';
        el('out-bwf').textContent = s.wf.toFixed(1) + ' rad/s';
        el('out-bdt').textContent = s.dt.toFixed(1) + ' s';
        el('out-balpha').textContent = fmt(s.alpha) + ' rad/s²';
        try { if (wheel) wheel.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-wi').addEventListener('input', onB);
      el('b-wf').addEventListener('input', onB);
      el('b-dt').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.wt = new Chart(el('chart-wt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'ω', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'ω (rad/s)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.adt = new Chart(el('chart-adt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'α', data: [], borderColor: '#0ea5e9', backgroundColor: 'rgba(14,165,233,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Δt (s)' } }, y: { title: { display: true, text: 'α (rad/s²)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L = [], D = [];
        const steps = 20;
        for (let i = 0; i <= steps; i++) {
          const t = (s.dt * i) / steps;
          L.push(t.toFixed(2));
          D.push(+(s.wi + s.alpha * t).toFixed(3));
        }
        charts.wt.data.labels = L; charts.wt.data.datasets[0].data = D; charts.wt.update();

        const dw = s.wf - s.wi;
        const L2 = [], D2 = [];
        for (let dt = 0.2; dt <= 10.001; dt += 0.4) { L2.push(dt.toFixed(1)); D2.push(+(dw / dt).toFixed(3)); }
        charts.adt.data.labels = L2; charts.adt.data.datasets[0].data = D2; charts.adt.update();
      }

      // ---- interactive spinning wheel ----
      function wheelMesh(THREE) {
        const g = new THREE.Group();
        const rimMat = new THREE.MeshStandardMaterial({ color: 0x6366f1, metalness: 0.3, roughness: 0.5 });
        const rim = new THREE.Mesh(new THREE.TorusGeometry(2.4, 0.18, 16, 48), rimMat);
        g.add(rim);
        const hubMat = new THREE.MeshStandardMaterial({ color: 0x334155 });
        const hub = new THREE.Mesh(new THREE.CylinderGeometry(0.28, 0.28, 0.3, 24), hubMat);
        hub.rotation.x = Math.PI / 2; g.add(hub);
        const spokeMat = new THREE.MeshStandardMaterial({ color: 0x94a3b8 });
        for (let i = 0; i < 6; i++) {
          const a = (i / 6) * Math.PI * 2;
          const spoke = new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.05, 2.3, 8), spokeMat);
          spoke.rotation.z = Math.PI / 2;
          spoke.position.set(Math.cos(a) * 1.15, Math.sin(a) * 1.15, 0);
          spoke.rotation.z = a + Math.PI / 2;
          g.add(spoke);
        }
        // marker dot on rim to show rotation visually
        const marker = new THREE.Mesh(new THREE.SphereGeometry(0.16, 16, 16), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
        marker.position.set(2.4, 0, 0.2);
        g.add(marker);
        return g;
      }
      function initWheel() {
        const c = el('wheel3d'); if (!c) throw new Error('no wheel container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const g = wheelMesh(THREE);
        s.scene.add(g);
        let st = { wi: 0, wf: 15, dt: 3, alpha: 5, t: 0, ang: 0 };
        function update(state) {
          st.wi = state.wi; st.wf = state.wf; st.dt = state.dt; st.alpha = state.alpha;
          st.t = 0; // restart the spin-up demo whenever sliders change
        }
        function frame() {
          requestAnimationFrame(frame);
          if (!reduceMotion) {
            s.spin(0.0012);
            const dtStep = 0.016;
            st.t += dtStep;
            const tClamped = st.t % (st.dt + 1.0); // loop: run for dt, pause briefly, restart
            const tEff = Math.min(tClamped, st.dt);
            const w = st.wi + st.alpha * tEff;
            st.ang += w * dtStep;
            g.rotation.z = st.ang;
          }
          s.renderer.render(s.scene, s.camera);
        }
        frame();
        wheel = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { switchMode('dw'); } catch (e) { console.error('[angular-accel] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[angular-accel] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[angular-accel] charts failed', e); }
        if (window.THREE) {
          try { initWheel(); } catch (e) { console.error('[angular-accel] wheel failed', e); el('wheel3d-fallback').classList.remove('hidden'); }
        } else { el('wheel3d-fallback').classList.remove('hidden'); }
        mountResize([wheel]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
