---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Hat Size Calculator';
const description = 'Find your hat size in US fitted sizing, alpha (S/M/L/XL), and centimeters from head circumference.';
const intro = 'Convert head circumference into US fitted hat size, alpha size, and centimeters.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I measure my head for a hat?', a: 'Wrap a soft tape measure around your head about 1/8 inch (roughly one finger width) above your eyebrows and ears, at the widest point. Keep the tape snug but not tight, and take the measurement in inches or centimeters.' },
  { q: 'Why is US hat sizing a fraction like 7 1/8 instead of a whole number?', a: 'US fitted hat size is literally the head circumference in inches divided by pi (the diameter of a circle with that circumference), rounded to the nearest eighth of an inch, which is why sizes land on fractions rather than whole numbers.' },
  { q: 'What if I am between two sizes?', a: 'Sizing up is usually more comfortable for structured hats, since a hat that is slightly loose can be adjusted with a sizing tape inside the band, while one that is too tight cannot be stretched safely on most materials.' },
  { q: 'Do adjustable caps use the same sizing?', a: 'Adjustable caps (snapback, strapback) typically use alpha sizing (S/M/L or one-size-fits-most) rather than fitted fractional sizing, since the strap covers a circumference range rather than one exact measurement.' },
];
const howTo = {
  name: 'How to find your hat size',
  steps: [
    { name: 'Measure your head', text: 'Wrap a tape measure around your head just above the eyebrows and ears.' },
    { name: 'Enter the circumference', text: 'Type the measurement in inches or centimeters into the calculator.' },
    { name: 'Read your size', text: 'US fitted size, alpha size, and centimeters appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Inches', 'Centimeters'].map((d) => (
        <button data-unit={d} class="unit-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Head circumference</span>
      <input id="circ" type="number" step="any" placeholder="e.g. 22.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">US fitted</div><div id="r-us" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Alpha</div><div id="r-alpha" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Centimeters</div><div id="r-cm" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="hsc-title hsc-desc">
      <title id="hsc-title">Head circumference measurement diagram</title>
      <desc id="hsc-desc">An oval representing a head from above, with a dashed line showing where to measure circumference above the eyebrows</desc>
      <ellipse cx="400" cy="110" rx="120" ry="85" fill="#f5d0fe" stroke="#c026d3" stroke-width="3" stroke-dasharray="8 4" />
      <text x="400" y="115" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Measure here —</text>
      <text x="400" y="132" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">above eyebrows &amp; ears</text>
      <text x="400" y="205" text-anchor="middle" font-size="13" fill="#94a3b8" font-family="system-ui,sans-serif">US size = circumference (in) ÷ π</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Head circumference is measured at its widest point, just above the eyebrows</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How hat sizing works</h2>
    <p class="mt-2 text-slate-600">
      US fitted hat sizes are calculated directly from head circumference using simple geometry: since circumference equals π times diameter, dividing the measured circumference in inches by π gives the "diameter" number used as the hat size, rounded to the nearest eighth of an inch. A 22-inch head circumference divided by π (about 3.14159) gives approximately 7 — a common average adult size.
    </p>
    <p class="mt-3 text-slate-600">
      Alpha sizing (S/M/L/XL) is used mainly for adjustable caps and simplifies the fractional US scale into broader bands, typically S for roughly 54-56 cm, M for 57-58 cm, L for 59-60 cm, and XL for 61 cm and above, though exact cutoffs vary by brand.
    </p>
    <p class="mt-3 text-xs text-slate-400">Sizing follows the standard millinery conversion of circumference ÷ π used across the US hat industry, cross-checked against common centimeter equivalents published by major hatmakers.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A tape measure around the head reads 23.25 inches.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Circumference:</span> <span class="text-slate-600">23.25 in</span></div>
        <div><span class="font-medium text-slate-700">US size:</span> <span class="text-slate-600">23.25 ÷ π ≈ <strong>7 3/8</strong></span></div>
        <div><span class="font-medium text-slate-700">Alpha size:</span> <span class="text-slate-600"><strong>L</strong></span></div>
        <div><span class="font-medium text-slate-700">Centimeters:</span> <span class="text-slate-600">23.25 × 2.54 ≈ <strong>59.1 cm</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Buying a structured hat online — a fedora, flat cap, or fitted baseball cap — is the main reason people measure their head at all, since these hats don't have the same forgiving adjustment straps as a snapback. Getting the fitted size wrong by even one eighth-inch increment can mean a hat that visibly sits too high or presses uncomfortably after an hour of wear.
    </p>
    <p class="mt-3 text-slate-600">
      Costume and uniform sizing (military caps, chef hats, graduation caps) frequently uses this same circumference-based system, and because these are often one-time purchases for an event, there's no chance to try several sizes in person first — making an accurate at-home measurement the only real safeguard.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Hat size correlates with clothing or shoe size." <strong class="text-slate-900">No relationship exists.</strong> Head circumference is an entirely independent measurement from height, shoe length, or torso size — there is no reliable shortcut from one to the other.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"One-size-fits-most caps fit everyone comfortably." <strong class="text-slate-900">Not quite.</strong> Most one-size adjustable straps only cover roughly 21-24 inches (53-61 cm); heads outside that range, particularly larger heads, often find these genuinely too tight even at the strap's loosest setting.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/sunglasses-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Sunglasses Size Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
      <a href="/tools/glove-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Glove Size Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let unit = 'Inches';

    function toFraction(size) {
      const whole = Math.floor(size);
      const frac = size - whole;
      const eighths = Math.round(frac * 8);
      const fracLabels = { 0: '', 1: ' 1/8', 2: ' 1/4', 3: ' 3/8', 4: ' 1/2', 5: ' 5/8', 6: ' 3/4', 7: ' 7/8', 8: '' };
      const carry = eighths === 8 ? 1 : 0;
      return (whole + carry) + fracLabels[eighths === 8 ? 0 : eighths];
    }

    function alphaFor(cm) {
      if (cm < 55) return 'XS';
      if (cm < 57) return 'S';
      if (cm < 59) return 'M';
      if (cm < 61) return 'L';
      return 'XL';
    }

    function update() {
      const v = parseFloat(el('circ').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const inches = unit === 'Centimeters' ? v / 2.54 : v;
      const cm = unit === 'Centimeters' ? v : v * 2.54;
      const usSize = inches / Math.PI;
      el('r-us').textContent = toFraction(usSize);
      el('r-alpha').textContent = alphaFor(cm);
      el('r-cm').textContent = cm.toFixed(1) + ' cm';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.unit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.unit-btn').forEach((b) => {
          b.className = 'unit-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'unit-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        unit = btn.dataset.unit;
        update();
      });
    });

    el('circ').addEventListener('input', update);
    document.querySelector('.unit-btn').click();
  </script>
</ToolLayout>
