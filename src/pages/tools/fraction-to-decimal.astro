---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fraction to Decimal Converter';
const description = 'Convert a fraction to a decimal instantly — turn 3/4 into 0.75. Supports mixed numbers and shows repeating decimals.';
const intro = 'Enter a fraction (or mixed number) to convert it into a decimal.';
const category = { id: 'converters', name: 'Converters', emoji: '🔄' };
const faqs = [
  { q: 'How do I convert a fraction to a decimal?', a: 'Divide the numerator (top) by the denominator (bottom). For example, 3/4 = 3 ÷ 4 = 0.75. The converter does the division for you and shows the full decimal.' },
  { q: 'Can it handle mixed numbers?', a: 'Yes. Enter a mixed number like “2 1/4” and it adds the whole part to the fraction, giving 2.25.' },
  { q: 'What about repeating decimals?', a: 'Some fractions, such as 1/3, produce repeating decimals (0.3333…). The converter shows the digits to high precision so you can see the pattern.' },
  { q: 'How do I convert a decimal back to a fraction?', a: 'Use our Decimal to Fraction converter, which writes the decimal over a power of ten and simplifies it.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-3 sm:grid-cols-3 sm:items-end">
      <label class="block"><span class="text-sm font-medium text-slate-700">Whole (optional)</span>
        <input id="whole" type="number" step="1" placeholder="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Numerator</span>
        <input id="numer" type="number" step="any" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Denominator</span>
        <input id="denom" type="number" step="any" placeholder="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Decimal</div><div id="out" class="mt-1 text-3xl font-bold tabular-nums">—</div><div id="pct" class="text-sm opacity-90"></div></div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="150" viewBox="0 0 800 150" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fd-title fd-desc">
      <title id="fd-title">Fraction divided to a decimal</title>
      <desc id="fd-desc">The fraction 3 over 4 equals 3 divided by 4 equals 0.75.</desc>
      <text x="180" y="65" text-anchor="middle" font-size="26" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">3</text><line x1="140" y1="78" x2="220" y2="78" stroke="#3730a3" stroke-width="2" /><text x="180" y="108" text-anchor="middle" font-size="26" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">4</text>
      <text x="290" y="88" text-anchor="middle" font-size="22" fill="#475569" font-family="system-ui,sans-serif">=  3 ÷ 4  =</text>
      <rect x="430" y="58" width="160" height="44" rx="8" fill="#f8fafc" stroke="#cbd5e1" /><text x="510" y="88" text-anchor="middle" font-size="22" fill="#1e293b" font-family="system-ui,sans-serif" font-weight="bold">0.75</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Dividing the numerator by the denominator gives the decimal value.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the fraction-to-decimal converter works</h2>
    <p class="mt-2 text-slate-600">A fraction is simply a division waiting to happen: the line between the numerator and denominator means “divided by”. To turn any fraction into a decimal, you divide the top number by the bottom number. This converter performs that division precisely and displays the decimal result, along with the equivalent percentage, so you can read the value in whichever form suits your task.</p>
    <p class="mt-3 text-slate-600">If you are working with a mixed number — a whole number plus a fraction, like 2 1/4 — enter the whole part in its own box. The tool converts the fractional part to a decimal and adds the whole number, giving 2.25. When the division does not end neatly, as with 1/3, the result is a repeating decimal; the converter shows many digits so the repeating pattern is clear.</p>
    <p class="mt-3 text-slate-600">Converting fractions to decimals makes numbers easier to compare, add on a calculator, or enter into a spreadsheet. It is common in measurements, finance, statistics and everyday maths. The calculation happens instantly in your browser, and the Decimal to Fraction converter handles the reverse direction whenever you need a fraction back.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related converters</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/decimal-to-fraction" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Decimal to Fraction</a>
      <a href="/tools/fraction-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fraction Calculator</a>
      <a href="/tools/number-to-words" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Number to Words</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function convert() {
      const w = parseFloat(el('whole').value) || 0;
      const n = parseFloat(el('numer').value);
      const d = parseFloat(el('denom').value);
      if (!isFinite(n) || !isFinite(d)) { el('out').textContent = '—'; el('pct').textContent = ''; return; }
      if (d === 0) { el('out').textContent = 'Cannot divide by zero'; el('pct').textContent = ''; return; }
      const sign = w < 0 ? -1 : 1;
      const val = w + sign * (n / d);
      const rounded = Math.round(val * 1e10) / 1e10;
      el('out').textContent = rounded.toLocaleString(undefined, { maximumFractionDigits: 10 });
      el('pct').textContent = '= ' + (Math.round(val * 1e6) / 1e4).toLocaleString(undefined, { maximumFractionDigits: 4 }) + '%';
    }
    ['whole', 'numer', 'denom'].forEach((id) => el(id).addEventListener('input', convert));
  </script>
</ToolLayout>
