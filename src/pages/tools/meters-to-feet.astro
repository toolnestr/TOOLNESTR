---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Meters to Feet"
  emoji="📏"
  fromUnit="meters" toUnit="feet"
  fromTitle="Meters" toTitle="Feet"
  fromSym="m" toSym="ft"
  quantity="length"
  kind="factor" factor={3.280839895}
  reverseSlug="feet-to-meters" reverseLabel="Feet to Meters Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Useful for room sizes, sports fields and altitude when a metric length needs to be expressed in feet."
/>
