---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Body Surface Area (BSA) Calculator';
const description =
  'Free BSA calculator. Estimate your body surface area using the Mosteller, Du Bois and Haycock formulas. Metric or imperial units.';
const intro =
  'Enter your height and weight to estimate your body surface area (BSA) using multiple validated formulas.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is body surface area?', a: 'Body surface area (BSA) is the total external surface area of the human body, measured in square metres (m²). It is used in medicine for drug dosing, burn assessment and calculating cardiac output and renal function.' },
  { q: 'Which BSA formula is most accurate?', a: 'The Mosteller formula is the most widely used in clinical practice due to its simplicity and good accuracy for most adults. The Du Bois formula was the original standard. Haycock is preferred for children.' },
  { q: 'Why is BSA used for chemotherapy dosing?', a: 'Many chemotherapy drugs have a narrow therapeutic index — too little is ineffective, too much is toxic. BSA correlates better with metabolic processes than weight alone, making it a safer basis for dosing.' },
  { q: 'What is a normal BSA?', a: 'The average adult BSA is about 1.73 m² (range 1.5–2.0 m² for most adults). It varies with height, weight and body composition. Men typically have a higher BSA than women of the same height and weight.' },
  { q: 'Can I calculate BSA for children?', a: 'Yes — the Haycock formula is validated for children and infants. The Mosteller formula also works well for older children. For accurate paediatric dosing, always consult a healthcare provider.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <div id="metric" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-3" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Body surface area (Mosteller)</div>
        <div id="r-bsa" class="mt-1 text-3xl font-bold">—</div>
        <div class="mt-1 text-sm opacity-80">square metres (m²)</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Du Bois formula</div><div id="r-dubois" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Haycock formula</div><div id="r-haycock" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your height and weight to estimate BSA.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About body surface area</h2>
    <p class="mt-2 text-slate-600">
      Body surface area is a critical metric in clinical medicine. Unlike weight alone, BSA accounts for both height and weight, making it a better indicator of metabolic mass. It is used to calculate chemotherapy dosages, glucocorticoid doses, cardiac output (as the cardiac index), glomerular filtration rate (kidney function), and burn surface area for fluid resuscitation. The <a href="https://pubmed.ncbi.nlm.nih.gov/706676/" rel="noopener">Mosteller formula</a> is the most widely used today because of its simplicity — it is simply the square root of height × weight divided by 3600 (or 3131 for imperial). This calculator provides three major formulas for comparison. For other body composition metrics, see the <a href="/tools/bmi-calculator/" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a> and <a href="/tools/lean-body-mass-calculator/" class="font-medium text-indigo-600 hover:underline">Lean Body Mass Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">BSA estimates are for informational purposes. Medical decisions should be made by qualified healthcare professionals.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" role="img" aria-labelledby="bsa-title bsa-desc">
      <title id="bsa-title">Body surface area visualisation</title>
      <desc id="bsa-desc">A human silhouette with a wrapping grid overlay representing the external surface area measured in square metres.</desc>
      <ellipse cx="400" cy="110" rx="50" ry="90" fill="none" stroke="#6366f1" stroke-width="3" />
      <circle cx="400" cy="40" r="25" fill="none" stroke="#6366f1" stroke-width="3" />
      <line x1="350" y1="110" x2="340" y2="170" stroke="#6366f1" stroke-width="2" />
      <line x1="450" y1="110" x2="460" y2="170" stroke="#6366f1" stroke-width="2" />
      <line x1="340" y1="170" x2="460" y2="170" stroke="#6366f1" stroke-width="2" />
      <line x1="350" y1="40" x2="340" y2="20" stroke="#6366f1" stroke-width="2" />
      <line x1="450" y1="40" x2="460" y2="20" stroke="#6366f1" stroke-width="2" />
      <line x1="340" y1="20" x2="460" y2="20" stroke="#6366f1" stroke-width="2" />
      <!-- Surface grid wrap lines -->
      <line x1="355" y1="50" x2="355" y2="170" stroke="#a5b4fc" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="370" y1="30" x2="370" y2="185" stroke="#a5b4fc" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="385" y1="25" x2="385" y2="195" stroke="#a5b4fc" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="415" y1="25" x2="415" y2="195" stroke="#a5b4fc" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="430" y1="30" x2="430" y2="185" stroke="#a5b4fc" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="445" y1="50" x2="445" y2="170" stroke="#a5b4fc" stroke-width="1" stroke-dasharray="4,4" />
      <text x="400" y="210" text-anchor="middle" font-size="11" fill="#94a3b8">Body surface area is the total external area of the body, used in medical dosing and burn assessment</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Body silhouette with surface grid overlay representing the external surface area</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      BSA formulas are all derived from height and weight using different mathematical relationships. The Mosteller formula uses a simple geometric mean (square root of height × weight divided by a constant). The Du Bois formula uses an exponential equation developed from direct measurements of nine subjects in 1916 — remarkably, it remained the standard for decades. The Haycock formula was developed in 1978 specifically to improve accuracy for children and infants. All three are shown for comparison; they typically agree within 5–10% for most adults.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formulas explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Mosteller (1987):</strong> BSA (m²) = √(height_cm × weight_kg / 3600)<br>
      <strong>Du Bois (1916):</strong> BSA = 0.007184 × weight^0.425 × height^0.725<br>
      <strong>Haycock (1978):</strong> BSA = 0.024265 × weight^0.5378 × height^0.3964
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A person measuring 175 cm tall and weighing 80 kg wants to know their BSA.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Height:</span> <span class="text-slate-600">175 cm</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">80 kg</span></div>
        <div><span class="font-medium text-slate-700">Mosteller:</span> <span class="text-slate-600">√(175 × 80 / 3600) = √(3.889) = <strong>1.97 m²</strong></span></div>
        <div><span class="font-medium text-slate-700">Du Bois:</span> <span class="text-slate-600">0.007184 × 80^0.425 × 175^0.725 = <strong>1.97 m²</strong></span></div>
        <div><span class="font-medium text-slate-700">Haycock:</span> <span class="text-slate-600">0.024265 × 80^0.5378 × 175^0.3964 = <strong>1.98 m²</strong></span></div>
        <div><span class="font-medium text-slate-700">Interpretation:</span> <span class="text-slate-600">All three formulas give ~1.97 m², which is slightly above the adult average (1.73 m²). The agreement between formulas increases confidence.</span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💊</span>
      <h3 class="mt-2 font-semibold text-slate-900">Oncology patient</h3>
      <p class="mt-1 text-sm text-slate-600">Understand how BSA is used to calculate your chemotherapy dose. Knowing your BSA helps you have informed conversations with your oncologist.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🩺</span>
      <h3 class="mt-2 font-semibold text-slate-900">Medical student</h3>
      <p class="mt-1 text-sm text-slate-600">Compare the three major BSA formulas and understand why Mosteller is preferred in modern clinical practice for its simplicity.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔥</span>
      <h3 class="mt-2 font-semibold text-slate-900">Burn clinician</h3>
      <p class="mt-1 text-sm text-slate-900">Use BSA to calculate the percentage of body surface area affected by burns — the basis for fluid resuscitation and transfer decisions.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍🔬</span>
      <h3 class="mt-2 font-semibold text-slate-900">Research scientist</h3>
      <p class="mt-1 text-sm text-slate-600">Normalise physiological measurements (cardiac output, GFR) to BSA for accurate cross-subject comparisons in clinical research.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your height</h3>
        <p class="mt-1 text-sm text-slate-600">Measure your height accurately using a wall-mounted stadiometer if possible. Metric or imperial both work.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your weight</h3>
        <p class="mt-1 text-sm text-slate-600">Use your current body weight. For medical purposes, use a calibrated scale with minimal clothing.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Compare formulas</h3>
        <p class="mt-1 text-sm text-slate-600">See your BSA from three major formulas. The Mosteller result is the highlighted one, as it is most commonly used in clinical practice today.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for BSA interpretation</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">BSA changes slowly</h3>
        <p class="mt-1 text-sm text-slate-600">Unlike weight, BSA changes slowly because height is fixed and weight changes must be significant to alter BSA substantially. A 5 kg weight change shifts BSA by only about 3–4%.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Formulas agree for most people</h3>
        <p class="mt-1 text-sm text-slate-600">For adults of average height and weight, all three formulas give nearly identical results. Differences become more noticeable for very tall, short, heavy or very lean individuals.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">BSA is not body fat</h3>
        <p class="mt-1 text-sm text-slate-600">BSA does not measure body composition. Two people with the same height and weight have the same BSA regardless of their body fat percentage. Use the Body Fat Calculator for composition.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/bmi-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">BMI Calculator</a>
      <a href="/tools/lean-body-mass-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Lean Body Mass Calculator</a>
      <a href="/tools/waist-to-hip-ratio-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Waist-to-Hip Ratio Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      let cm, kg;
      if (metric) { cm = parseFloat(el('m-h').value); kg = parseFloat(el('m-w').value); }
      else {
        const ft = parseFloat(el('i-ft').value) || 0, inch = parseFloat(el('i-in').value) || 0;
        cm = (ft * 12 + inch) * 2.54; kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      if (!cm || !kg || cm <= 0 || kg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const mosteller = Math.sqrt(cm * kg / 3600);
      const dubois = 0.007184 * Math.pow(kg, 0.425) * Math.pow(cm, 0.725);
      const haycock = 0.024265 * Math.pow(kg, 0.5378) * Math.pow(cm, 0.3964);
      el('r-bsa').textContent = mosteller.toFixed(2) + ' m²';
      el('r-dubois').textContent = dubois.toFixed(2) + ' m²';
      el('r-haycock').textContent = haycock.toFixed(2) + ' m²';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['m-h', 'm-w', 'i-ft', 'i-in', 'i-w'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
