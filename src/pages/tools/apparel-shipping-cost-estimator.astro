---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Apparel Packaging & Shipping Cost Estimator';
const description = 'Estimate the per-unit packaging and freight cost for an apparel order from total shipment cost, packaging cost, and order quantity.';
const intro = 'Estimate per-unit packaging and shipping cost to add into your total landed garment cost.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What counts as packaging cost in apparel costing?', a: 'Polybags, hang tags, care labels, tissue paper, branded boxes, and any other per-unit packaging materials the factory or brand applies before shipment. It\'s a real per-unit cost, separate from the freight cost of moving the shipment itself.' },
  { q: 'How is freight cost allocated per unit?', a: 'Total freight cost (ocean, air, or courier) for a shipment is divided by the number of units in that shipment to get a per-unit freight cost. Larger orders spread the fixed portion of freight cost — customs brokerage, documentation, minimum charges — across more units, lowering the per-unit figure.' },
  { q: 'Is air freight always faster and more expensive than ocean freight?', a: 'Generally yes on both counts — air freight typically costs several times more per unit than ocean freight but delivers in days rather than weeks, making it common for urgent replenishment or sample shipments rather than full bulk orders.' },
  { q: 'Does this include customs duties?', a: 'No — this calculator covers packaging and freight only. Import duties and taxes vary by destination country and product category and should be added as a separate line to reach a full landed cost.' },
];
const howTo = {
  name: 'How to estimate per-unit packaging and shipping cost',
  steps: [
    { name: 'Enter packaging cost per unit', text: 'Polybags, tags, labels, and any branded packaging materials.' },
    { name: 'Enter total freight cost', text: 'The full cost to ship the entire order.' },
    { name: 'Enter order quantity', text: 'The number of units in the shipment.' },
    { name: 'Read the per-unit cost', text: 'Packaging plus freight allocated across the order size.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Packaging cost per unit ($)</span>
        <input id="pack" type="number" step="any" placeholder="e.g. 0.35" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Total freight cost ($)</span>
        <input id="freight" type="number" step="any" placeholder="e.g. 3500" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block sm:col-span-2"><span class="text-sm font-medium text-slate-700">Order quantity (units)</span>
        <input id="qty" type="number" step="1" placeholder="e.g. 5000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Per-unit packaging + shipping cost</div>
        <div id="r-unit" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Freight per unit</div><div id="r-freight-unit" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Packaging per unit</div><div id="r-pack-unit" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How packaging and shipping cost per unit is calculated</h2>
    <p class="mt-2 text-slate-600">
      Per-unit packaging cost is usually a fixed, known figure — the cost of the polybag, hang tag, and label applied to each individual garment. Freight cost works differently: the total shipment cost (ocean container rate, air freight rate, or courier charge) is fixed for the whole shipment regardless of exactly how many units are in it, so it's divided across the order quantity to get a per-unit share.
    </p>
    <p class="mt-3 text-slate-600">
      This is why order quantity has such a direct effect on landed cost per unit: a shipment with a $3,500 total freight cost spread across 5,000 units adds $0.70 per unit, but the same $3,500 freight cost spread across 1,000 units adds $3.50 per unit — a meaningful difference that makes minimum order quantities and consolidated shipments an important lever in apparel sourcing economics.
    </p>
    <p class="mt-3 text-xs text-slate-400">Per-unit freight allocation (total shipment cost ÷ order quantity) is standard apparel landed-cost methodology.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">5,000 units, $0.35 packaging per unit, $3,500 total ocean freight.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Freight per unit:</span> <span class="text-slate-600">3500 ÷ 5000 = $0.70</span></div>
        <div><span class="font-medium text-slate-700">Packaging per unit:</span> <span class="text-slate-600">$0.35</span></div>
        <div><span class="font-medium text-slate-700">Total per unit:</span> <span class="text-slate-600">0.70 + 0.35 = <strong>$1.05</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      During major ocean-freight rate spikes (as happened globally in 2021 and periodically since), per-unit freight cost for apparel imports has swung dramatically even with identical order quantities and product mix, sometimes multiplying several-fold — a stark reminder that freight is a genuinely variable, market-driven cost that needs re-checking each order cycle, not a fixed assumption carried forward from a prior quote.
    </p>
    <p class="mt-3 text-slate-600">
      Small independent brands ordering in low volumes often see freight cost per unit that rivals or exceeds their CM labor cost, simply because they can't spread the shipment's fixed costs across enough units — this is one of the strongest financial arguments for consolidating orders across suppliers or working with a freight forwarder who can combine LCL (less-than-container-load) shipments from multiple small brands.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Shipping cost per unit is basically fixed regardless of order size." <strong class="text-slate-900">It scales inversely with order size.</strong> Since total freight cost is largely fixed per shipment, a bigger order dramatically lowers the per-unit freight share.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"This figure is the full landed cost." <strong class="text-slate-900">It's missing duties and customs fees.</strong> Import duties and any customs brokerage fees are separate and vary by destination country and product classification — add them to reach a true landed cost.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/cbm-container-loading-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">CBM & Container Loading Estimator</a>
      <a href="/tools/garment-costing-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Garment Costing Calculator</a>
      <a href="/tools/garment-cost-sheet-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Quick Cost Sheet Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const pack = parseFloat(el('pack').value) || 0;
      const freight = parseFloat(el('freight').value);
      const qty = parseFloat(el('qty').value);
      if (!(qty > 0 && freight >= 0)) { el('results').classList.add('hidden'); return; }
      const freightUnit = freight / qty;
      const total = pack + freightUnit;

      el('r-freight-unit').textContent = '$' + freightUnit.toFixed(3);
      el('r-pack-unit').textContent = '$' + pack.toFixed(3);
      el('r-unit').textContent = '$' + total.toFixed(3);
      el('results').classList.remove('hidden');
    }

    ['pack', 'freight', 'qty'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
