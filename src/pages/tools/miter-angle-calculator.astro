---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Miter Angle Calculator';
const description = 'Find the exact miter saw angle to cut trim, molding and baseboard for any corner — from a measured corner angle or an equal-sided frame with N sides.';
const intro = 'Find the exact miter saw setting to join trim at any corner or around an equal-sided frame.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate a miter angle for a corner?', a: 'Measure the corner angle where the two walls meet, then set each piece to a miter of (180 − corner) ÷ 2. A square 90° corner needs a 45° miter on each piece; a 135° corner needs 22.5°.' },
  { q: 'What miter angle do I cut for a picture frame?', a: 'A four-sided frame is cut at 45° on every joint. For an equal-sided frame with any number of sides, each miter is 180 ÷ N degrees — 30° for a hexagon (6 sides), 22.5° for an octagon (8 sides).' },
  { q: 'Why do the two pieces split the angle?', a: 'The joint between two pieces of trim must add up to the full corner. When both pieces are cut to the same angle, each one carries half the turn, so the cuts meet cleanly in the middle of the corner without a gap.' },
  { q: 'Does an inside corner differ from an outside corner?', a: 'The miter angle is the same for a given corner angle — what changes is which face of the trim is longer. For an inside corner the back of the trim is longer; for an outside corner the front is longer. The saw angle setting itself does not change.' },
];
const howTo = {
  name: 'How to calculate a miter angle',
  steps: [
    { name: 'Measure or count', text: 'Measure the real corner angle, or count the number of sides on an equal-sided frame.' },
    { name: 'Read the miter', text: 'The calculator returns the angle each piece is cut to.' },
    { name: 'Set the saw', text: 'Dial that value from the square (90°) position on the miter saw.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Method</span>
      <select id="mode" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="corner" selected>Measured corner angle</option>
        <option value="poly">Equal-sided frame (N sides)</option>
      </select></label>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label id="w-corner" class="block"><span class="text-sm font-medium text-slate-700">Corner angle (°)</span>
        <input id="corner" type="number" step="any" placeholder="90" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-sides" class="hidden"><span class="text-sm font-medium text-slate-700">Number of sides</span>
        <input id="sides" type="number" step="1" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Miter angle per piece</div>
        <div id="r-miter" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Corner angle</div><div id="r-corner" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Saw setting (from 90°)</div><div id="r-saw" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="mi-title mi-desc">
      <title id="mi-title">Mitered corner joint and the angle formula</title>
      <desc id="mi-desc">Two pieces of trim meeting at a corner with the miter-angle formula</desc>
      <path d="M60 60 L200 60 L200 90 L90 90 Z" fill="#e0e7ff" stroke="#6366f1" stroke-width="1.5" />
      <path d="M200 60 L200 200 L170 200 L170 90 Z" fill="#c7d2fe" stroke="#6366f1" stroke-width="1.5" />
      <line x1="200" y1="60" x2="170" y2="90" stroke="#4338ca" stroke-width="2" stroke-dasharray="4 3" />
      <text x="120" y="130" font-size="12" fill="#475569" font-family="system-ui,sans-serif">joint splits the corner</text>
      <rect x="360" y="55" width="390" height="110" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="380" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Miter angle</text>
      <text x="380" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">corner mode: (180 &minus; corner) &divide; 2</text>
      <text x="380" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">frame mode: 180 &divide; number of sides</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Each of the two pieces carries half the corner, so both are cut to the same miter.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the miter angle calculator works</h2>
    <p class="mt-2 text-slate-600">
      A mitered joint hides the end grain of trim by splitting a corner between two pieces. Because the two cuts must together turn through the whole corner, each piece is cut to exactly half of the turn. If you measure the angle where the walls actually meet, the miter on each piece is (180 − corner angle) ÷ 2 — a 90° corner gives 45°, a wider 135° corner gives 22.5°.
    </p>
    <p class="mt-3 text-slate-600">
      For a closed frame with equal sides — a picture frame, an octagon window casing, a planter box — there is an even simpler rule. Each miter equals 180 divided by the number of sides. Four sides give 45°, six give 30°, eight give 22.5°. This works because the exterior turns of a closed polygon always add up to 360°, shared equally across its joints, and each joint splits its turn between two pieces.
    </p>
    <p class="mt-3 text-slate-600">
      Most miter saws read zero when the blade is square to the fence, so the number you dial in is the miter measured from 90°, which is exactly the value this calculator gives. The same setting works for inside and outside corners; only which face of the trim ends up longer changes. Real corners are rarely perfectly square, so measuring the actual corner angle beats assuming 90° when a tight joint matters.
    </p>
    <p class="mt-3 text-xs text-slate-400">Miter geometry and joint layout conventions follow guidance published by the Architectural Woodwork Institute (AWI) Quality Standards for finish trim and casework.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure or count</h3>
        <p class="mt-1 text-sm text-slate-600">The real corner angle, or the number of sides.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the miter</h3>
        <p class="mt-1 text-sm text-slate-600">The angle each piece is cut to.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the saw</h3>
        <p class="mt-1 text-sm text-slate-600">Dial that value from the square (90°) position.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Corner-angle mode</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">miter = (180 &minus; corner) &divide; 2</span>. A 90° corner: (180 − 90) ÷ 2 = <strong>45°</strong> on each piece.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Frame mode</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">miter = 180 &divide; N</span>. An octagon (8 sides): 180 ÷ 8 = <strong>22.5°</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Saw setting</p>
        <p class="mt-1 text-slate-600">
          The saw reads the miter from square, so the displayed miter is the number to dial in directly.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Baseboard around an out-of-square corner measured at 96°.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Corner:</span> <span class="text-slate-600">96°</span></div>
        <div><span class="font-medium text-slate-700">Miter:</span> <span class="text-slate-600">(180 − 96) ÷ 2 = <strong>42°</strong></span></div>
        <div><span class="font-medium text-slate-700">Each piece:</span> <span class="text-slate-600">cut at 42° from square</span></div>
        <div><span class="font-medium text-slate-700">Joint total:</span> <span class="text-slate-600">42° + 42° = 84° of trim removed</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for a tight miter joint</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Measure, don't assume</h3>
        <p class="mt-1 text-sm text-slate-600">A cheap angle finder or a simple bevel gauge held against both walls takes thirty seconds and often reveals a corner is off by two or three degrees. That small difference is the whole reason a "45° everywhere" approach produces visible gaps on real trim work.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Cut a scrap test piece first</h3>
        <p class="mt-1 text-sm text-slate-600">Dial in the calculated miter, cut two short offcuts, and dry-fit them before touching the actual trim. It costs a few inches of scrap and confirms the saw's angle indicator is accurate — miter saw scales can drift out of calibration over years of use.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Picture-frame and cabinet-door work is where the frame-mode formula gets used most. A five-sided arched window casing needs 180 ÷ 5 = <strong>36° per miter</strong>, while a hexagonal planter box comes out to 180 ÷ 6 = <strong>30° per miter</strong> — both far from the 45° most people assume every miter should be, which is exactly why counting sides first matters before setting the saw.
    </p>
    <p class="mt-3 text-slate-600">
      Real rooms rarely give you an honest 90°. A bay window nook measured with a protractor at 112° needs (180 − 112) ÷ 2 = <strong>34° per piece</strong>, noticeably shallower than the default 45° a carpenter might dial in out of habit. Skipping the measurement step on an out-of-square wall is one of the most common causes of a visible gap at the joint.
    </p>
    <p class="mt-3 text-slate-600">
      Older homes settle unevenly, and closet or hallway corners often drift a few degrees from square. A corner measured at 87° needs (180 − 87) ÷ 2 = <strong>46.5° per piece</strong> — just over a degree past 45°, but enough that an unmeasured 45° cut would leave a visible sliver of a gap once both pieces are nailed up.
    </p>
    <p class="mt-3 text-slate-600">
      Multi-sided frames come up often in built-in cabinetry and window casings too, not just picture frames. A ten-sided decorative surround, for instance, needs 180 ÷ 10 = 18° per miter — the frame-mode formula scales cleanly to any number of equal sides, which is why it is worth confirming the side count before cutting rather than guessing from a rough sketch.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Every inside corner is 90°, so every miter is 45°." <strong class="text-slate-900">Only on paper.</strong> Framing, drywall, and settling routinely push real corners a few degrees off square. Measuring the actual corner and halving it — rather than assuming 45° — is what closes the gap on a finished joint.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"The miter angle changes between an inside and an outside corner." <strong class="text-slate-900">The angle is identical.</strong> What differs is which face of the trim — the back or the front — ends up longer once the piece is cut and installed. The saw setting itself comes from the same (180 − corner) ÷ 2 formula either way.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/compound-angle-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Compound Angle Calculator</a>
      <a href="/tools/roof-pitch-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Roof Pitch Calculator</a>
      <a href="/tools/board-foot-lumber-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Board Foot Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function sync() {
      const poly = el('mode').value === 'poly';
      el('w-corner').classList.toggle('hidden', poly);
      el('w-sides').classList.toggle('hidden', !poly);
      update();
    }

    function update() {
      let miter, cornerVal, note;
      if (el('mode').value === 'poly') {
        const n = parseInt(el('sides').value, 10);
        if (!(n >= 3)) return hide();
        miter = 180 / n;
        cornerVal = (n - 2) * 180 / n;
        note = 'equal-sided frame, ' + n + ' sides';
      } else {
        const c = parseFloat(el('corner').value);
        if (!(c > 0 && c < 180)) return hide();
        miter = (180 - c) / 2;
        cornerVal = c;
        note = 'each piece, splitting a ' + c + '° corner';
      }
      el('r-miter').textContent = miter.toFixed(1) + '°';
      el('r-note').textContent = note;
      el('r-corner').textContent = cornerVal.toFixed(1) + '°';
      el('r-saw').textContent = miter.toFixed(1) + '°';
      el('results').classList.remove('hidden');
    }
    function hide() { el('results').classList.add('hidden'); }

    el('mode').addEventListener('change', sync);
    ['corner', 'sides'].forEach((id) => el(id).addEventListener('input', update));
    sync();
  </script>
</ToolLayout>
