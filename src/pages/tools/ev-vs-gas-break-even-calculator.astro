---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'EV vs Gas Break-Even Calculator — Should You Switch?';
const description = 'Compare total cost of EV vs gas car including purchase price, fuel, and maintenance. Find your break-even mileage.';
const intro = 'Compare EV and gas car costs to find your break-even mileage.';
const category = { id: 'automotive', name: 'Automotive' };
const faqs = [
  { q: 'What costs are included?', a: 'Purchase price, fuel/electricity cost, maintenance, and annual mileage. Tax incentives optional.' },
  { q: 'What is the break-even point?', a: 'The mileage at which the total cost of ownership for the EV equals that of the gas car.' },
  { q: 'Does it include tax credits?', a: 'Yes — you can add a federal or state tax credit/rebate for the EV.' },
  { q: 'What about resale value?', a: 'Resale value is not included but you can adjust the purchase price difference to account for it.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <h3 class="mb-3 text-sm font-bold text-slate-800">Gas Car</h3>
        <label class="block"><span class="text-sm font-medium text-slate-700">Purchase price ($)</span>
          <input id="gp" type="number" step="1" placeholder="30000" value="30000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-3 block"><span class="text-sm font-medium text-slate-700">Fuel economy (MPG)</span>
          <input id="mpg" type="number" step="0.1" placeholder="30" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-3 block"><span class="text-sm font-medium text-slate-700">Maintenance /10k mi ($)</span>
          <input id="gm" type="number" step="1" placeholder="800" value="800" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-3 block"><span class="text-sm font-medium text-slate-700">Gas price ($/gal)</span>
          <input id="gpr" type="number" step="0.01" placeholder="3.50" value="3.50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-bold text-slate-800">EV</h3>
        <label class="block"><span class="text-sm font-medium text-slate-700">Purchase price ($)</span>
          <input id="ep" type="number" step="1" placeholder="45000" value="45000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-3 block"><span class="text-sm font-medium text-slate-700">Efficiency (mi/kWh)</span>
          <input id="eff" type="number" step="0.1" placeholder="3.5" value="3.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-3 block"><span class="text-sm font-medium text-slate-700">Maintenance /10k mi ($)</span>
          <input id="em" type="number" step="1" placeholder="300" value="300" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-3 block"><span class="text-sm font-medium text-slate-700">Electricity price ($/kWh)</span>
          <input id="epr" type="number" step="0.001" placeholder="0.14" value="0.14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-bold text-slate-800">Usage</h3>
        <label class="block"><span class="text-sm font-medium text-slate-700">Annual miles</span>
          <input id="am" type="number" step="1" placeholder="12000" value="12000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-3 block"><span class="text-sm font-medium text-slate-700">Years to compare</span>
          <input id="yr" type="number" step="1" placeholder="10" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-3 block"><span class="text-sm font-medium text-slate-700">EV tax credit ($)</span>
          <input id="tax" type="number" step="1" placeholder="7500" value="7500" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
    </div>

    <button id="calc" class="mt-6 w-full rounded-xl bg-indigo-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-300">Calculate</button>

    <div id="result" class="mt-6 hidden">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-xl bg-indigo-600 p-4 text-center text-white">
          <div class="text-xs opacity-80">Break-even mileage</div>
          <div id="r-be-miles" class="mt-1 text-xl font-bold">—</div>
        </div>
        <div class="rounded-xl bg-slate-50 p-4 text-center">
          <div class="text-xs text-slate-500">Break-even years</div>
          <div id="r-be-yrs" class="mt-1 text-xl font-bold text-slate-800">—</div>
        </div>
        <div class="rounded-xl bg-slate-50 p-4 text-center">
          <div class="text-xs text-slate-500">Annual savings after break-even</div>
          <div id="r-annual-save" class="mt-1 text-xl font-bold text-emerald-600">—</div>
        </div>
      </div>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center">
          <div class="text-xs text-slate-500">Gas total cost over period</div>
          <div id="r-gas-total" class="mt-1 text-lg font-bold text-slate-800">—</div>
        </div>
        <div class="rounded-xl bg-slate-50 p-4 text-center">
          <div class="text-xs text-slate-500">EV total cost over period</div>
          <div id="r-ev-total" class="mt-1 text-lg font-bold text-slate-800">—</div>
        </div>
        <div class="rounded-xl bg-slate-50 p-4 text-center">
          <div class="text-xs text-slate-500">Net savings over period</div>
          <div id="r-net" class="mt-1 text-lg font-bold text-emerald-600">—</div>
        </div>
      </div>
      <div id="r-msg" class="mt-4 text-center text-sm font-medium text-slate-700"></div>
    </div>

    <div id="warn" class="mt-3 hidden rounded-xl bg-amber-50 p-3 text-sm text-amber-800"></div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Cost curve comparison</h2>
    <p class="mt-2 text-slate-600">The EV starts with a higher upfront cost but accrues operating costs more slowly. The break-even point is where the two lines cross.</p>
    <figure class="mt-5 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
      <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="be-title be-desc">
        <title id="be-title">EV vs Gas break-even cost curves</title>
        <desc id="be-desc">Two lines on a chart. The gas car line (red) starts lower but rises steeply. The EV line (blue) starts higher but rises gently. They cross at the break-even point.</desc>
        <rect x="60" y="20" width="720" height="240" rx="4" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1"/>
        <line x1="60" y1="260" x2="780" y2="260" stroke="#cbd5e1" stroke-width="1"/>
        <line x1="60" y1="260" x2="60" y2="20" stroke="#cbd5e1" stroke-width="1"/>
        <text x="50" y="265" text-anchor="end" fill="#94a3b8" font-size="11">0</text>
        <text x="50" y="50" text-anchor="end" fill="#94a3b8" font-size="11">$</text>
        <text x="420" y="290" text-anchor="middle" fill="#64748b" font-size="12">Miles driven</text>
        <text x="30" y="150" text-anchor="middle" fill="#64748b" font-size="12" transform="rotate(-90,30,150)">Total cost</text>
        <polyline points="120,230 240,190 360,150 480,110 600,70 720,30" fill="none" stroke="#ef4444" stroke-width="3" stroke-linejoin="round"/>
        <polyline points="120,200 240,175 360,150 480,125 600,100 720,75" fill="none" stroke="#6366f1" stroke-width="3" stroke-linejoin="round"/>
        <circle cx="360" cy="150" r="5" fill="#10b981" stroke="white" stroke-width="2"/>
        <text x="360" y="140" text-anchor="middle" fill="#10b981" font-size="11" font-weight="bold">Break-even</text>
        <rect x="80" y="30" width="14" height="14" rx="2" fill="#ef4444"/>
        <text x="100" y="42" fill="#475569" font-size="12">Gas car</text>
        <rect x="180" y="30" width="14" height="14" rx="2" fill="#6366f1"/>
        <text x="200" y="42" fill="#475569" font-size="12">EV</text>
      </svg>
      <figcaption class="mt-2 text-center text-xs text-slate-400">Cost curves: the EV has a higher starting cost but lower operating cost, crossing at the break-even point</figcaption>
    </figure>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Total cost over time</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm" id="cost-table">
        <thead class="bg-slate-50 text-slate-500">
          <tr><th class="p-3">Year</th><th class="p-3">Miles driven</th><th class="p-3">Gas cumulative cost</th><th class="p-3">EV cumulative cost</th><th class="p-3">EV advantage</th></tr>
        </thead>
        <tbody id="cost-tbody" class="divide-y divide-slate-100 text-slate-700">
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">How the break-even calculation works</h2>
    <p class="mt-2 text-slate-600">This calculator models the total cost of ownership for both vehicles over time and finds the point where the cumulative costs are equal.</p>
    <div class="mt-5 space-y-4">
      <div class="rounded-xl border border-slate-100 bg-slate-50 p-4">
        <h3 class="font-semibold text-slate-900">Per-mile operating cost</h3>
        <p class="mt-1 font-mono text-sm text-slate-600">gas cost/mi = gas_price ÷ MPG</p>
        <p class="mt-1 font-mono text-sm text-slate-600">EV cost/mi = electricity_price ÷ efficiency</p>
        <p class="mt-2 text-xs text-slate-400">Example: $3.50/gal ÷ 30 MPG = $0.117/mi for gas. $0.14/kWh ÷ 3.5 mi/kWh = $0.04/mi for the EV.</p>
      </div>
      <div class="rounded-xl border border-slate-100 bg-slate-50 p-4">
        <h3 class="font-semibold text-slate-900">Annual operating cost</h3>
        <p class="mt-1 font-mono text-sm text-slate-600">annual cost = per-mile cost × annual_miles + maintenance</p>
        <p class="mt-2 text-xs text-slate-400">Maintenance is scaled proportionally to annual mileage (maintenance_per_10k ÷ 10,000 × annual_miles).</p>
      </div>
      <div class="rounded-xl border border-slate-100 bg-slate-50 p-4">
        <h3 class="font-semibold text-slate-900">Break-even calculation</h3>
        <p class="mt-1 font-mono text-sm text-slate-600">break-even miles = price_diff ÷ (gas_op_cost_per_mi − EV_op_cost_per_mi)</p>
        <p class="mt-2 text-xs text-slate-400">The price difference (EV price − gas price − tax credit) is divided by the per-mile operating cost savings to find the number of miles needed to recoup the higher upfront cost.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Variables that affect your break-even point</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">Electricity vs gas prices</h3>
        <p class="mt-1 text-sm text-slate-600">Both fluctuate regionally and over time. Locking in a fixed electricity rate or time-of-use plan can improve EV savings. Gas prices are more volatile and tend to rise over the long term, making the EV break-even happen faster with each gas price increase. Use real local prices for the most accurate comparison.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">Maintenance costs</h3>
        <p class="mt-1 text-sm text-slate-600">EVs have far fewer moving parts — no oil changes, timing belts, exhaust systems, or transmission fluid. Brake wear is also reduced by regenerative braking. Typical EV maintenance is $300-500 per 10,000 miles vs $800-1,200 for gas cars. Over 150,000 miles, that difference alone can exceed $5,000.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">Purchase price and incentives</h3>
        <p class="mt-1 text-sm text-slate-600">EVs generally have a higher MSRP, but federal tax credits ($3,750-7,500), state rebates, and manufacturer incentives can shrink or eliminate the gap. Some states offer additional perks like HOV lane access, reduced registration fees, or home charger installation rebates.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">Driving habits</h3>
        <p class="mt-1 text-sm text-slate-600">Higher annual mileage accelerates the break-even point because operating cost savings accumulate faster. A driver doing 20,000 mi/year will break even much sooner than one driving 8,000 mi/year. City driving also favors EVs more because regenerative braking recaptures energy and gas cars get worse MPG in stop-and-go traffic.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚗</span>
      <h3 class="mt-2 font-semibold text-slate-900">Car buying decision</h3>
      <p class="mt-1 text-sm text-slate-600">Compare specific models you are considering. Enter the real out-the-door prices after negotiation and incentives. Use the actual fuel economy and efficiency ratings from fueleconomy.gov. The break-even analysis tells you whether the EV premium makes financial sense for your annual mileage.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Fleet analysis</h3>
      <p class="mt-1 text-sm text-slate-600">Fleet operators can model total cost of ownership across multiple vehicles. High-mileage routes benefit most from EV conversion. Consider bulk charging rates, fleet maintenance contracts, and volume purchase discounts. The break-even analysis helps prioritize which vehicles to replace first.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌿</span>
      <h3 class="mt-2 font-semibold text-slate-900">Environmental cost comparison</h3>
      <p class="mt-1 text-sm text-slate-600">Beyond financial cost, consider the carbon cost. Even before the financial break-even, EVs typically have lower well-to-wheel CO₂ emissions. Combining this calculator with the EV CO₂ Savings Calculator gives you a complete financial and environmental picture of the switch.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📊</span>
      <h3 class="mt-2 font-semibold text-slate-900">Total cost of ownership analysis</h3>
      <p class="mt-1 text-sm text-slate-600">True cost of ownership includes insurance, registration, financing, tires, and depreciation. While this calculator focuses on the biggest variable costs (purchase, fuel, maintenance), you can adjust the purchase price gap to roughly account for depreciation differences or add insurance costs manually.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use real local prices</h3>
        <p class="mt-1 text-sm text-slate-600">Gas prices and electricity rates vary significantly by region. Check your local gas station prices and look at your utility bill for your actual per-kWh rate including all fees and taxes. Time-of-use plans can lower effective electricity rates to $0.08-0.12/kWh for overnight charging.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Check available incentives</h3>
        <p class="mt-1 text-sm text-slate-600">The federal EV tax credit is up to $7,500 for new EVs, but not all models qualify. Many states add their own rebates ($1,500-5,000). Some utilities offer additional rebates for EV purchases or home charger installation. Check the DOE's Alternative Fuels Data Center for a complete list of incentives in your area.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Consider charging availability</h3>
        <p class="mt-1 text-sm text-slate-600">If you cannot charge at home or at work and rely on public DC fast charging, your effective electricity cost can be 3-4 times higher than home rates ($0.35-0.60/kWh). This significantly impacts the break-even calculation. Factor in your actual charging mix for a realistic comparison.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Don't forget winter efficiency</h3>
        <p class="mt-1 text-sm text-slate-600">EV efficiency drops 15-30% in cold weather due to battery chemistry and cabin heating. If you live in a cold climate, use a lower efficiency estimate (e.g., 2.5-3.0 mi/kWh instead of 3.5-4.0) for winter months or average across the year. Gas cars also lose some MPG in winter, but the effect is smaller.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Typical break-even scenarios</h2>
    <p class="mt-2 text-slate-600">Here are some common scenarios to give you a sense of typical break-even ranges:</p>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-slate-500">
          <tr><th class="p-3">Scenario</th><th class="p-3">EV price</th><th class="p-3">Gas price</th><th class="p-3">Annual miles</th><th class="p-3">Break-even</th></tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700">
          <tr><td class="p-3 font-medium">Compact car comparison</td><td class="p-3">$28,000</td><td class="p-3">$22,000</td><td class="p-3">12,000</td><td class="p-3 text-emerald-600 font-medium">~4.2 years</td></tr>
          <tr><td class="p-3 font-medium">Mid-size sedan</td><td class="p-3">$40,000</td><td class="p-3">$30,000</td><td class="p-3">15,000</td><td class="p-3 text-emerald-600 font-medium">~4.8 years</td></tr>
          <tr><td class="p-3 font-medium">SUV / Crossover</td><td class="p-3">$52,000</td><td class="p-3">$38,000</td><td class="p-3">12,000</td><td class="p-3 text-emerald-600 font-medium">~6.5 years</td></tr>
          <tr><td class="p-3 font-medium">Luxury / Performance</td><td class="p-3">$75,000</td><td class="p-3">$55,000</td><td class="p-3">10,000</td><td class="p-3 text-emerald-600 font-medium">~8.1 years</td></tr>
          <tr><td class="p-3 font-medium">High-mileage driver</td><td class="p-3">$40,000</td><td class="p-3">$30,000</td><td class="p-3">25,000</td><td class="p-3 text-emerald-600 font-medium">~2.9 years</td></tr>
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-xs text-slate-400">Assumes $3.50/gal gas, $0.14/kWh electricity, 30 MPG gas car, 3.5 mi/kWh EV, $7,500 EV tax credit, gas maintenance $800/10k mi, EV maintenance $300/10k mi.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/tire-size-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🛞</span>
        <h3 class="mt-2 font-semibold text-slate-900">Tire Size Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Compare tire sizes and see diameter, circumference, and speedometer error.</p>
      </a>
      <a href="/tools/car-depreciation-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">📉</span>
        <h3 class="mt-2 font-semibold text-slate-900">Car Depreciation Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Project a vehicle value over time with a standard depreciation curve.</p>
      </a>
      <a href="/tools/towing-capacity-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🚛</span>
        <h3 class="mt-2 font-semibold text-slate-900">Towing Capacity Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Compare trailer weight against towing and payload capacity limits.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);

    function fmtCurrency(n) {
      return '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    function fmtMiles(n) {
      return n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    function calculate() {
      $('warn').classList.add('hidden');
      $('result').classList.add('hidden');

      const gasPrice = parseFloat($('gp').value);
      const mpg = parseFloat($('mpg').value);
      const gasMaint = parseFloat($('gm').value);
      const gasPerGal = parseFloat($('gpr').value);
      const evPrice = parseFloat($('ep').value);
      const eff = parseFloat($('eff').value);
      const evMaint = parseFloat($('em').value);
      const elecPrice = parseFloat($('epr').value);
      const annualMiles = parseFloat($('am').value);
      const years = parseFloat($('yr').value);
      const taxCredit = parseFloat($('tax').value) || 0;

      const inputs = [gasPrice, mpg, gasMaint, gasPerGal, evPrice, eff, evMaint, elecPrice, annualMiles, years];
      if (inputs.some(v => isNaN(v) || v <= 0)) {
        $('warn').textContent = 'Please enter valid positive numbers in all fields.';
        $('warn').classList.remove('hidden');
        return;
      }

      const effectiveEvPrice = evPrice - taxCredit;
      const priceDiff = effectiveEvPrice - gasPrice;

      const gasCostPerMi = gasPerGal / mpg;
      const evCostPerMi = elecPrice / eff;

      const gasOpCostPerYear = gasCostPerMi * annualMiles + (gasMaint / 10000) * annualMiles;
      const evOpCostPerYear = evCostPerMi * annualMiles + (evMaint / 10000) * annualMiles;

      const annualSavings = gasOpCostPerYear - evOpCostPerYear;
      const savingPerMi = gasCostPerMi - evCostPerMi + (gasMaint - evMaint) / 10000;

      let breakEvenMiles, breakEvenYears;
      if (savingPerMi <= 0) {
        breakEvenMiles = Infinity;
        breakEvenYears = Infinity;
      } else {
        breakEvenMiles = priceDiff / savingPerMi;
        breakEvenYears = breakEvenMiles / annualMiles;
      }

      // Cumulative cost table
      const tbody = $('cost-tbody');
      tbody.innerHTML = '';
      let gasCumulative = gasPrice;
      let evCumulative = effectiveEvPrice;

      for (let y = 1; y <= Math.min(years, 15); y++) {
        const milesThisYear = annualMiles * y;
        gasCumulative += gasOpCostPerYear;
        evCumulative += evOpCostPerYear;
        const advantage = gasCumulative - evCumulative;
        const row = document.createElement('tr');
        row.className = y % 2 === 0 ? 'bg-slate-50' : '';
        const advClass = advantage >= 0 ? 'text-emerald-600 font-medium' : 'text-red-500';
        row.innerHTML =
          '<td class="p-3">' + y + '</td>' +
          '<td class="p-3">' + fmtMiles(milesThisYear) + '</td>' +
          '<td class="p-3">' + fmtCurrency(gasCumulative) + '</td>' +
          '<td class="p-3">' + fmtCurrency(evCumulative) + '</td>' +
          '<td class="p-3 ' + advClass + '">' + (advantage >= 0 ? '+' : '') + fmtCurrency(advantage) + '</td>';
        tbody.appendChild(row);
      }

      if (!isFinite(breakEvenMiles) || breakEvenMiles < 0) {
        $('result').classList.remove('hidden');
        $('r-be-miles').textContent = 'N/A';
        $('r-be-yrs').textContent = 'N/A';
        $('r-annual-save').textContent = savingPerMi > 0 ? fmtCurrency(annualSavings) : '—';
        $('r-gas-total').textContent = fmtCurrency(gasCumulative);
        $('r-ev-total').textContent = fmtCurrency(evCumulative);
        $('r-net').textContent = fmtCurrency(gasCumulative - evCumulative);
        $('r-msg').textContent = savingPerMi <= 0
          ? 'The EV does not have lower operating costs per mile than the gas car. Check your efficiency or electricity price values.'
          : 'The EV purchase price is already lower than the gas car after incentives. It is cheaper from day one.';
        return;
      }

      const totalGas = gasPrice + gasOpCostPerYear * years;
      const totalEV = effectiveEvPrice + evOpCostPerYear * years;

      $('r-be-miles').textContent = fmtMiles(Math.round(breakEvenMiles));
      $('r-be-yrs').textContent = breakEvenYears.toFixed(1);
      $('r-annual-save').textContent = fmtCurrency(annualSavings);
      $('r-gas-total').textContent = fmtCurrency(totalGas);
      $('r-ev-total').textContent = fmtCurrency(totalEV);
      $('r-net').textContent = fmtCurrency(totalGas - totalEV);

      if (breakEvenYears <= years) {
        $('r-msg').textContent = 'It will take about ' + breakEvenYears.toFixed(1) + ' years (' + fmtMiles(Math.round(breakEvenMiles)) + ' miles) to break even. After that, you save ' + fmtCurrency(annualSavings) + ' per year.';
      } else {
        $('r-msg').textContent = 'The break-even point (' + breakEvenYears.toFixed(1) + ' years, ' + fmtMiles(Math.round(breakEvenMiles)) + ' miles) is beyond your ' + years + '-year comparison window. The EV does not pay back within this timeframe.';
      }

      $('result').classList.remove('hidden');
    }

    $('calc').addEventListener('click', calculate);
  </script>
</ToolLayout>
