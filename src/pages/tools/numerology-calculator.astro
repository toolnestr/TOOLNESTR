---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Numerology Calculator';
const description =
  'Calculate your Life Path and Destiny numbers from your birth date and full name using Pythagorean numerology.';
const intro =
  'Calculate your Life Path number from your birth date and Destiny number from your full name using the Pythagorean system.';
const category = { id: 'creators', name: 'Creators' };
const faqs = [
  { q: 'What is a Life Path number?', a: 'Your Life Path number is derived from your birth date and represents the core of who you are and the path you are meant to walk in life.' },
  { q: 'What is a Destiny number?', a: 'Your Destiny number is derived from your full birth name and reveals your natural talents, abilities, and ultimate goals in life.' },
  { q: 'How are the numbers calculated?', a: 'Each letter maps to a number 1-9 using the Pythagorean system. Birth date digits are summed and reduced to a single digit (or master number 11, 22, 33).' },
  { q: 'What are master numbers?', a: '11, 22, and 33 are master numbers and are not reduced further. They represent higher spiritual potential and greater challenges.' },
  { q: 'Is numerology scientifically proven?', a: 'Numerology is a metaphysical belief system, not a science. Many people find personal meaning in it, similar to astrology or the Enneagram.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Full name (as on birth certificate)</span>
      <input id="name" type="text" value="John Doe"
        class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    </label>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Birth month</span>
        <input id="bmonth" type="number" min="1" max="12" value="12"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Birth day</span>
        <input id="bday" type="number" min="1" max="31" value="25"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Birth year</span>
        <input id="byear" type="number" min="1900" max="2100" value="1990"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>
    <div class="mt-6 grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-50 p-4 text-center">
        <div class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Life Path</div>
        <div id="r-life" class="mt-1 text-3xl font-bold text-indigo-700">—</div>
        <div id="r-life-desc" class="mt-1 text-xs text-indigo-500">—</div>
      </div>
      <div class="rounded-xl bg-amber-50 p-4 text-center">
        <div class="text-xs font-semibold uppercase tracking-wide text-amber-600">Destiny</div>
        <div id="r-destiny" class="mt-1 text-3xl font-bold text-amber-700">—</div>
        <div id="r-destiny-desc" class="mt-1 text-xs text-amber-500">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="240" viewBox="0 0 800 240" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="numerology-title numerology-desc">
      <title id="numerology-title">Pythagorean numerology grid</title>
      <desc id="numerology-desc">A 3x3 grid showing the Pythagorean letter-to-number mapping with highlighted letters for an example calculation</desc>
      <rect x="60" y="20" width="680" height="200" rx="12" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2" />
      <text x="400" y="48" text-anchor="middle" fill="#475569" font-size="14" font-weight="bold">Pythagorean Letter Map</text>
      <rect x="80" y="60" width="200" height="40" rx="6" fill="#eef2ff" stroke="#c7d2fe" />
      <text x="180" y="86" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">1: A J S</text>
      <rect x="300" y="60" width="200" height="40" rx="6" fill="#eef2ff" stroke="#c7d2fe" />
      <text x="400" y="86" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">2: B K T</text>
      <rect x="520" y="60" width="200" height="40" rx="6" fill="#eef2ff" stroke="#c7d2fe" />
      <text x="620" y="86" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">3: C L U</text>
      <rect x="80" y="110" width="200" height="40" rx="6" fill="#eef2ff" stroke="#c7d2fe" />
      <text x="180" y="136" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">4: D M V</text>
      <rect x="300" y="110" width="200" height="40" rx="6" fill="#eef2ff" stroke="#c7d2fe" />
      <text x="400" y="136" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">5: E N W</text>
      <rect x="520" y="110" width="200" height="40" rx="6" fill="#eef2ff" stroke="#c7d2fe" />
      <text x="620" y="136" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">6: F O X</text>
      <rect x="180" y="160" width="200" height="40" rx="6" fill="#eef2ff" stroke="#c7d2fe" />
      <text x="280" y="186" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">7: G P Y</text>
      <rect x="400" y="160" width="200" height="40" rx="6" fill="#fef3c7" stroke="#f59e0b" />
      <text x="500" y="186" text-anchor="middle" fill="#d97706" font-size="14" font-weight="bold">8: H Q Z</text>
      <rect x="80" y="160" width="80" height="40" rx="6" fill="#eef2ff" stroke="#c7d2fe" />
      <text x="120" y="186" text-anchor="middle" fill="#4f46e5" font-size="14" font-weight="bold">9: I R</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">Each letter A–Z maps to a number 1–9 in the Pythagorean system</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How numerology numbers are calculated</h2>
    <p class="mt-2 text-slate-600">
      The Pythagorean system of numerology assigns a numeric value (1–9) to each letter of the alphabet in sequence. Your Life Path number comes from your birth date: the day, month, and year are each reduced to a single digit, then summed and reduced again. The Destiny number comes from your full birth name: each letter's numeric value is summed and reduced.
    </p>
    <p class="mt-3 text-slate-600">
      The reduction process repeatedly sums the digits of a number until a single digit (1–9) or master number (11, 22, 33) remains. Master numbers are considered more powerful and are not reduced further. For example, 1990 reduces as 1+9+9+0 = 19, then 1+9 = 10, then 1+0 = 1.
    </p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-1 rounded-xl bg-white p-4 font-mono text-sm text-slate-700">
      <div><span class="font-semibold">Life Path:</span> reduce(month) + reduce(day) + reduce(year) → reduced to single digit</div>
      <div><span class="font-semibold">Destiny:</span> sum of letter values from full name → reduced</div>
      <div><span class="font-semibold">Reduce:</span> sum digits until 1–9 (or 11, 22, 33)</div>
    </div>
    <h3 class="mt-4 font-semibold text-slate-900">Worked example</h3>
    <p class="mt-1 text-sm text-slate-600"><strong>Birth date:</strong> December 25, 1990 &mdash; <strong>Name:</strong> John Doe</p>
    <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
      <div><span class="font-medium text-slate-700">Month (12):</span> <span class="text-slate-600">1+2 = 3</span></div>
      <div><span class="font-medium text-slate-700">Day (25):</span> <span class="text-slate-600">2+5 = 7</span></div>
      <div><span class="font-medium text-slate-700">Year (1990):</span> <span class="text-slate-600">1+9+9+0 = 19 → 1+9 = 10 → 1+0 = 1</span></div>
      <div><span class="font-medium text-slate-700">Life Path:</span> <span class="text-slate-600">3 + 7 + 1 = 11 (master number)</span></div>
      <div><span class="font-medium text-slate-700">J(1)+O(6)+H(8)+N(5):</span> <span class="text-slate-600">1+6+8+5 = 20 → 2+0 = 2</span></div>
      <div><span class="font-medium text-slate-700">D(4)+O(6)+E(5):</span> <span class="text-slate-600">4+6+5 = 15 → 1+5 = 6</span></div>
      <div><span class="font-medium text-slate-700">Destiny:</span> <span class="text-slate-600">2 + 6 = 8</span></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔮</span>
      <h3 class="mt-2 font-semibold text-slate-900">Self Discovery</h3>
      <p class="mt-1 text-sm text-slate-600">Learn more about your core personality traits, strengths, and life challenges through the lens of numerology.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👶</span>
      <h3 class="mt-2 font-semibold text-slate-900">Baby Name Selection</h3>
      <p class="mt-1 text-sm text-slate-600">Some parents use numerology to choose a baby name that produces a favourable Destiny or Life Path number for their child.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🤝</span>
      <h3 class="mt-2 font-semibold text-slate-900">Compatibility Analysis</h3>
      <p class="mt-1 text-sm text-slate-600">Compare Life Path numbers with a partner, friend, or business associate to understand relationship dynamics based on numerological traditions.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💼</span>
      <h3 class="mt-2 font-semibold text-slate-900">Career Guidance</h3>
      <p class="mt-1 text-sm text-slate-600">Certain Life Path numbers are believed to align better with specific careers. Use your numbers as one input when considering professional paths.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the numerology calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your name</h3>
        <p class="mt-1 text-sm text-slate-600">Type your full birth name as it appears on your birth certificate for the most accurate Destiny number.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your birth date</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in the month, day, and year of birth. These are used to calculate the Life Path number.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your numbers</h3>
        <p class="mt-1 text-sm text-slate-600">Your Life Path and Destiny numbers appear instantly with brief descriptions of their meanings.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for numerology</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use your full birth name</h3>
        <p class="mt-1 text-sm text-slate-600">The Destiny number should be calculated from your full legal name at birth, not a nickname or married name. This is considered the most accurate in Pythagorean numerology.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Master numbers are special</h3>
        <p class="mt-1 text-sm text-slate-600">If your calculation produces 11, 22, or 33, those are master numbers with their own distinct meanings. They are not reduced to 2, 4, or 6.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Meaning of numbers</h3>
        <p class="mt-1 text-sm text-slate-600">1: Leader, 2: Diplomat, 3: Creator, 4: Builder, 5: Adventurer, 6: Nurturer, 7: Seeker, 8: Achiever, 9: Humanitarian, 11: Visionary, 22: Master Builder, 33: Master Teacher.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/random-color-generator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">🎨</span>
        <h3 class="mt-1 font-semibold text-slate-900">Random Color Generator</h3>
        <p class="text-sm text-slate-600">Your lucky colour based on today's random pick.</p>
      </a>
      <a href="/tools/zodiac-sign-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">♈</span>
        <h3 class="mt-1 font-semibold text-slate-900">Zodiac Sign Calculator</h3>
        <p class="text-sm text-slate-600">Find your astrological sign from your birth date.</p>
      </a>
      <a href="/tools/love-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">💕</span>
        <h3 class="mt-1 font-semibold text-slate-900">Love Calculator</h3>
        <p class="text-sm text-slate-600">Calculate compatibility between two names.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const letterMap = {A:1,B:2,C:3,D:4,E:5,F:6,G:7,H:8,I:9,J:1,K:2,L:3,M:4,N:5,O:6,P:7,Q:8,R:9,S:1,T:2,U:3,V:4,W:5,X:6,Y:7,Z:8};
    const meanings = {1:'Leader',2:'Diplomat',3:'Creator',4:'Builder',5:'Adventurer',6:'Nurturer',7:'Seeker',8:'Achiever',9:'Humanitarian',11:'Visionary',22:'Master Builder',33:'Master Teacher'};
    function reduce(n) {
      while (n > 9 && n !== 11 && n !== 22 && n !== 33) {
        n = String(n).split('').reduce((a, c) => a + parseInt(c, 10), 0);
      }
      return n;
    }
    function calcLifePath(m, d, y) {
      const rm = reduce(m), rd = reduce(d), ry = reduce(y);
      return reduce(rm + rd + ry);
    }
    function calcDestiny(name) {
      const sum = name.toUpperCase().split('').filter(c => c >= 'A' && c <= 'Z').reduce((a, c) => a + (letterMap[c] || 0), 0);
      return reduce(sum);
    }
    function update() {
      const name = document.getElementById('name').value.trim() || 'Unknown';
      const m = parseInt(document.getElementById('bmonth').value, 10) || 1;
      const d = parseInt(document.getElementById('bday').value, 10) || 1;
      const y = parseInt(document.getElementById('byear').value, 10) || 2000;
      const life = calcLifePath(m, d, y);
      const destiny = calcDestiny(name);
      document.getElementById('r-life').textContent = life;
      document.getElementById('r-life-desc').textContent = meanings[life] || '—';
      document.getElementById('r-destiny').textContent = destiny;
      document.getElementById('r-destiny-desc').textContent = meanings[destiny] || '—';
    }
    ['name','bmonth','bday','byear'].forEach(id => {
      const el = document.getElementById(id);
      el.addEventListener('input', update);
      el.addEventListener('change', update);
    });
    update();
  </script>
</ToolLayout>
