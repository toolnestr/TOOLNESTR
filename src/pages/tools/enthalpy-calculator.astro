---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Enthalpy Calculator';
const description = 'Calculate reaction enthalpy ΔH_rxn from standard enthalpies of formation with a live 3D energy-level scene and charts. Up to 2 reactants and 2 products, with worked examples.';
const intro = 'Enter coefficients and standard enthalpies of formation (ΔHf°) for up to two reactants and two products to compute ΔH_rxn, and see whether the reaction is exothermic or endothermic.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is enthalpy?', a: 'Enthalpy (H) is a measure of the total heat content of a system at constant pressure. Chemists usually care about the change in enthalpy, ΔH, during a reaction — the heat absorbed or released as reactants turn into products. It is measured in kJ or kJ/mol.' },
  { q: 'What does a negative or positive ΔH mean?', a: 'ΔH < 0 (negative) means the reaction is exothermic — it releases heat to the surroundings, and the products end up lower in enthalpy than the reactants. ΔH > 0 (positive) means the reaction is endothermic — it absorbs heat from the surroundings, and the products end up higher in enthalpy than the reactants.' },
  { q: 'Why is the standard enthalpy of formation of an element zero?', a: 'By convention, the standard enthalpy of formation (ΔHf°) of any element in its most stable form at standard conditions (25°C, 1 atm) — such as O2(g), N2(g), H2(g), or graphite for carbon — is defined as exactly zero. This gives every other ΔHf° value a consistent, comparable reference point, the same way sea level is the zero point for elevation.' },
  { q: 'How does ΔH relate to bond energies?', a: 'Breaking bonds always requires energy input (endothermic), while forming bonds always releases energy (exothermic). The overall ΔH of a reaction is approximately the energy needed to break the reactant bonds minus the energy released forming the product bonds. This bond-energy approach and the ΔHf°-based approach here are two ways to estimate the same ΔH_rxn.' },
  { q: 'Does ΔH tell you how fast a reaction happens?', a: 'No. ΔH is a thermodynamic quantity — it tells you the net heat exchanged and the relative stability of products versus reactants, not how quickly the reaction proceeds. Reaction rate is governed by kinetics (activation energy, temperature, catalysts), which is an entirely separate question from the sign or size of ΔH.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Enthalpy Calculator',
  description: 'Compute the reaction enthalpy ΔH_rxn from standard enthalpies of formation and stoichiometric coefficients.',
  steps: [
    { name: 'Enter reactants', text: 'Type the coefficient and ΔHf° for reactant 1, and optionally reactant 2.' },
    { name: 'Enter products', text: 'Type the coefficient and ΔHf° for product 1, and optionally product 2.' },
    { name: 'Read ΔH_rxn', text: 'The calculator computes ΔH_rxn live and tells you whether the reaction is exothermic or endothermic.' },
  ],
};

const formulas = [
  { expr: 'ΔH<sub>rxn</sub> = ΣΔH<sub>f</sub>°(products) − ΣΔH<sub>f</sub>°(reactants)', note: 'each ΔHf° weighted by its stoichiometric coefficient' },
  { expr: 'ΔH &lt; 0 → exothermic', note: 'ΔH &gt; 0 → endothermic' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — combustion of methane', tone: 'slate',
    given: 'CH₄(g) + 2 O₂(g) → CO₂(g) + 2 H₂O(l). ΔHf°: CH₄ = −74.8, O₂ = 0 (element), CO₂ = −393.5, H₂O(l) = −285.8 kJ/mol.',
    rows: [
      { label: 'Products:', value: 'ΔHf°(CO₂) + 2×ΔHf°(H₂O) = (−393.5) + 2×(−285.8) = −393.5 − 571.6 = −965.1 kJ' },
      { label: 'Reactants:', value: 'ΔHf°(CH₄) + 2×ΔHf°(O₂) = (−74.8) + 2×0 = −74.8 kJ' },
      { label: 'ΔH_rxn:', value: '−965.1 − (−74.8) = −890.3 kJ', full: true },
    ],
    note: 'ΔH_rxn ≈ −890.3 kJ — strongly exothermic, matching the standard textbook value for methane combustion.',
  },
  {
    title: 'Worked example 2 — simple A → B reaction', tone: 'amber',
    given: 'A → B. ΔHf°(A) = −20 kJ/mol, ΔHf°(B) = +15 kJ/mol, both with coefficient 1, no second reactant or product.',
    rows: [
      { label: 'ΔH_rxn:', value: 'ΔHf°(B) − ΔHf°(A) = 15 − (−20) = +35 kJ' },
    ],
    note: 'ΔH_rxn = +35 kJ > 0, so this reaction is endothermic — it absorbs heat as A converts to B.',
  },
];

const comparison = {
  heading: 'Standard enthalpies of formation (ΔHf°) for common substances',
  note: 'Reference values at 25°C, 1 atm, used in the worked examples above. Elements in their standard state are exactly zero by convention.',
  headers: [{ label: 'Substance' }, { label: 'ΔHf° (kJ/mol)' }],
  rows: [
    ['CO₂(g)', '−393.5'],
    ['H₂O(l)', '−285.8'],
    ['H₂O(g)', '−241.8'],
    ['CH₄(g)', '−74.8'],
    ['NH₃(g)', '−46.1'],
    ['O₂(g), N₂(g), H₂(g)', '0 (elements)'],
  ],
  highlightIndex: 3,
  footnote: 'Values are standard reference data (approximate, rounded to one decimal) — always confirm against a current data table for precision work.',
};

const realWorld = [
  { emoji: '🔥', title: 'Fuel combustion energy content', body: 'The enthalpy of combustion tells engineers how much heat a fuel releases per mole or per kilogram — the basis for comparing natural gas, gasoline, and hydrogen as energy sources, and for sizing burners and engines.' },
  { emoji: '🏭', title: 'Industrial process heat management', body: 'Chemical plants use ΔH_rxn to predict whether a reactor needs active cooling (strongly exothermic reactions) or heating (endothermic reactions) to stay at a safe, efficient operating temperature.' },
  { emoji: '🍎', title: 'Food calorie content', body: 'Nutritional Calories are essentially the enthalpy released when food is fully oxidized (a related but distinct measurement, done via bomb calorimetry) — the same underlying idea of heat released per mole of reaction.' },
  { emoji: '❄️', title: 'Refrigerant &amp; HVAC thermodynamics', body: 'Refrigeration cycles rely on the enthalpy change of a refrigerant as it evaporates and condenses, absorbing heat from inside a fridge or room and releasing it outside — engineers select refrigerants partly by their enthalpy of vaporization.' },
];

const misconceptions = [
  { claim: '"Exothermic reactions always happen spontaneously and quickly."', truth: 'ΔH says nothing about reaction rate (kinetics) or spontaneity. A reaction can be strongly exothermic yet extremely slow without a catalyst (e.g. rusting), or need an initial energy input (activation energy) before it proceeds. True spontaneity requires ΔG (Gibbs free energy), which also accounts for entropy and temperature.' },
  { claim: '"The ΔHf° of any pure element is always some large number."', truth: 'It is defined as exactly zero for an element in its standard state (e.g. O2(g), N2(g), graphite), by convention — this is the reference point every other ΔHf° is measured against, not a coincidence or a measured-to-be-small value.' },
  { claim: '"A positive ΔH means the reaction cannot happen."', truth: 'Endothermic reactions (ΔH > 0) happen all the time — melting ice, photosynthesis, many dissolution processes. They simply require a net heat input from the surroundings rather than releasing heat.' },
  { claim: '"ΔH and ΔHf° are always the same value."', truth: 'ΔHf° is the enthalpy of formation of one specific compound from its elements. ΔH_rxn is the overall enthalpy change of a full reaction, calculated by combining the ΔHf° values of every reactant and product weighted by their coefficients.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 5, Thermochemistry (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/5-3-enthalpy" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 5, Thermochemistry.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — standard enthalpies of formation and Hess\'s law.' },
];
const sourcesNote = 'ΔH_rxn = Σ(coefficient × ΔHf°)products − Σ(coefficient × ΔHf°)reactants. Results are rounded for display.';

const howToUse = [
  { title: 'Enter reactants', body: 'Coefficient and ΔHf° for reactant 1; optionally reactant 2. Leave ΔHf° at 0 for elements in their standard state.' },
  { title: 'Enter products', body: 'Coefficient and ΔHf° for product 1; optionally product 2.' },
  { title: 'Read the result', body: 'ΔH_rxn solves live, with an exothermic/endothermic label and the 3D energy-level scene.' },
];

const related = [
  { href: '/tools/chemical-equation-balancer', emoji: '🧮', title: 'Chemical Equation Balancer', desc: 'Balance equations up to 4 species instantly.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'M = mol/L — solve for any variable.' },
  { href: '/tools/equilibrium-constant-calculator', emoji: '🔁', title: 'Equilibrium Constant (Keq) Calculator', desc: 'Kc = [C]^c[D]^d / [A]^a[B]^b.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="reaction enthalpy is just bookkeeping — add up the formation enthalpies of everything you end with, subtract the formation enthalpies of everything you started with."
  howIntro="Each ΔHf° is weighted by its stoichiometric coefficient before summing. A negative ΔH_rxn means the products sit lower in enthalpy than the reactants — the excess energy is released as heat (exothermic). A positive ΔH_rxn means the products sit higher — the reaction must absorb heat to proceed (endothermic)."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where reaction enthalpy actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-xs text-slate-500">Leave a species' ΔHf° blank to exclude it (useful for single-reactant or single-product reactions). Elements in their standard state have ΔHf° = 0.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 p-4">
        <h3 class="text-sm font-bold text-red-700">Reactants</h3>
        <div class="mt-2 grid grid-cols-2 gap-2">
          <label class="block"><span class="text-xs font-medium text-slate-700">Coeff. (reactant 1)</span>
            <input id="r1-coeff" type="number" step="1" min="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">ΔHf° (kJ/mol)</span>
            <input id="r1-dhf" type="number" step="any" placeholder="kJ/mol" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">Coeff. (reactant 2)</span>
            <input id="r2-coeff" type="number" step="1" min="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">ΔHf° (kJ/mol, optional)</span>
            <input id="r2-dhf" type="number" step="any" placeholder="blank = absent" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        </div>
      </div>
      <div class="rounded-xl border border-slate-200 p-4">
        <h3 class="text-sm font-bold text-green-700">Products</h3>
        <div class="mt-2 grid grid-cols-2 gap-2">
          <label class="block"><span class="text-xs font-medium text-slate-700">Coeff. (product 1)</span>
            <input id="p1-coeff" type="number" step="1" min="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">ΔHf° (kJ/mol)</span>
            <input id="p1-dhf" type="number" step="any" placeholder="kJ/mol" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">Coeff. (product 2)</span>
            <input id="p2-coeff" type="number" step="1" min="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
          <label class="block"><span class="text-xs font-medium text-slate-700">ΔHf° (kJ/mol, optional)</span>
            <input id="p2-dhf" type="number" step="any" placeholder="blank = absent" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        </div>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Reaction enthalpy ΔH_rxn</div><div id="r-dh" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Classification</div><div id="r-class" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="dh-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: 3D energy-level platforms + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D energy levels</h2>
      <p class="mt-1 text-sm text-slate-500">Reactants sit on one platform, products on the other, at heights set by their ΔHf°. A drop from reactants to products means an exothermic reaction; a rise means endothermic. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Reactants ΔHf° <span id="out-vreact" class="font-mono text-green-600">−75.0 kJ/mol</span></span>
          <input id="v-react" type="range" min="-400" max="100" step="1" value="-75" class="mt-2 w-full accent-green-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Products ΔHf° <span id="out-vprod" class="font-mono text-green-600">−965.1 kJ/mol</span></span>
          <input id="v-prod" type="range" min="-1200" max="100" step="1" value="-965" class="mt-2 w-full accent-green-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-green-50 p-3 text-center text-sm text-green-700">Live ΔH_rxn = <span id="out-vdh" class="font-mono font-bold">−890.0 kJ</span> · <span id="out-vlabel" class="font-semibold">Exothermic</span></div>
      <div id="enthalpy3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="enthalpy3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Enthalpy graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Reaction energy diagram — reactants vs products level</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-diagram"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ΔH magnitude for illustrative example reactions (kJ/mol)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-examples"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('dh-err').textContent = '';
        el('r-dh').textContent = '—';
        el('r-class').textContent = '—';
        const r1c = parseFloat(el('r1-coeff').value), r1h = parseFloat(el('r1-dhf').value);
        const r2c = parseFloat(el('r2-coeff').value), r2h = parseFloat(el('r2-dhf').value);
        const p1c = parseFloat(el('p1-coeff').value), p1h = parseFloat(el('p1-dhf').value);
        const p2c = parseFloat(el('p2-coeff').value), p2h = parseFloat(el('p2-dhf').value);
        if (isNaN(r1h) || isNaN(p1h)) return;
        if (!isNaN(r2h) && (isNaN(r2c) || r2c <= 0)) { el('dh-err').textContent = 'Reactant 2 coefficient must be a positive number.'; return; }
        if (!isNaN(p2h) && (isNaN(p2c) || p2c <= 0)) { el('dh-err').textContent = 'Product 2 coefficient must be a positive number.'; return; }
        if (isNaN(r1c) || r1c <= 0 || isNaN(p1c) || p1c <= 0) { el('dh-err').textContent = 'Coefficients must be positive numbers.'; return; }
        let reactants = r1c * r1h;
        if (!isNaN(r2h)) reactants += r2c * r2h;
        let products = p1c * p1h;
        if (!isNaN(p2h)) products += p2c * p2h;
        const dh = products - reactants;
        el('r-dh').textContent = fmt(dh) + ' kJ';
        if (dh < 0) el('r-class').textContent = 'Exothermic (releases heat)';
        else if (dh > 0) el('r-class').textContent = 'Endothermic (absorbs heat)';
        else el('r-class').textContent = 'Thermoneutral (ΔH = 0)';
      }
      ['r1-coeff', 'r1-dhf', 'r2-coeff', 'r2-dhf', 'p1-coeff', 'p1-dhf', 'p2-coeff', 'p2-dhf'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let scene3d = null;
      function vState() {
        const react = parseFloat(el('v-react').value), prod = parseFloat(el('v-prod').value);
        return { react, prod, dh: prod - react };
      }
      function onV() {
        const s = vState();
        el('out-vreact').textContent = s.react.toFixed(1) + ' kJ/mol';
        el('out-vprod').textContent = s.prod.toFixed(1) + ' kJ/mol';
        el('out-vdh').textContent = fmt(s.dh) + ' kJ';
        el('out-vlabel').textContent = s.dh < 0 ? 'Exothermic' : (s.dh > 0 ? 'Endothermic' : 'Thermoneutral');
        try { if (scene3d) scene3d.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('v-react').addEventListener('input', onV);
      el('v-prod').addEventListener('input', onV);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.diagram = new Chart(el('chart-diagram'), {
          type: 'line',
          data: { labels: ['Start', 'Reactants', '', 'Products', 'End'], datasets: [{
            label: 'Enthalpy (kJ/mol)', data: [null, 0, null, 0, null],
            borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', stepped: false, tension: 0, pointRadius: [0, 5, 0, 5, 0], fill: false,
          }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Reaction progress' } }, y: { title: { display: true, text: 'Enthalpy (kJ/mol)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.examples = new Chart(el('chart-examples'), {
          type: 'bar',
          data: {
            labels: ['Methane combustion\n(exothermic, illustrative)', 'Current reaction', 'Endothermic decomposition\n(illustrative)'],
            datasets: [{ label: 'ΔH (kJ/mol)', data: [-890.3, 0, 178], backgroundColor: ['#ef4444', '#6366f1', '#10b981'] }],
          },
          options: Object.assign({}, base, { indexAxis: 'y', scales: { x: { title: { display: true, text: 'ΔH (kJ/mol)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(vState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        charts.diagram.data.datasets[0].data = [null, s.react, null, s.prod, null];
        charts.diagram.update();
        charts.examples.data.datasets[0].data = [-890.3, +s.dh.toFixed(1), 178];
        charts.examples.update();
      }

      // ---- interactive energy-level scene ----
      function initScene() {
        const c = el('enthalpy3d'); if (!c) throw new Error('no enthalpy3d');
        const s = makeScene(c, 14, new THREE.Vector3(0, 0, 0), SCENE_OPTS);

        const reactMat = new THREE.MeshStandardMaterial({ color: 0xef4444, roughness: 0.4 });
        const prodMat = new THREE.MeshStandardMaterial({ color: 0x10b981, roughness: 0.4 });
        const connectMat = new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.6, transparent: true, opacity: 0.6 });
        let reactPlat = null, prodPlat = null, connector = null;

        function scaleH(v) { return v / 60; } // kJ/mol -> scene units, roughly ±20 units for ±1200 kJ/mol range

        function update(state) {
          const yReact = scaleH(state.react);
          const yProd = scaleH(state.prod);
          if (reactPlat) { s.scene.remove(reactPlat); reactPlat.geometry.dispose(); }
          if (prodPlat) { s.scene.remove(prodPlat); prodPlat.geometry.dispose(); }
          if (connector) { s.scene.remove(connector); connector.geometry.dispose(); }

          reactPlat = new THREE.Mesh(new THREE.BoxGeometry(3, 0.4, 3), reactMat);
          reactPlat.position.set(-3, yReact, 0);
          s.scene.add(reactPlat);

          prodPlat = new THREE.Mesh(new THREE.BoxGeometry(3, 0.4, 3), prodMat);
          prodPlat.position.set(3, yProd, 0);
          s.scene.add(prodPlat);

          const dy = yProd - yReact;
          const len = Math.sqrt(36 + dy * dy);
          connector = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, len, 12), connectMat);
          connector.position.set(0, (yReact + yProd) / 2, 0);
          connector.rotation.z = Math.atan2(dy, 6) + Math.PI / 2;
          s.scene.add(connector);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        scene3d = { update, resize: s.resize };
        update(vState());
      }

      function boot() {
        try { update(); } catch (e) { console.error('[enthalpy] calc init failed', e); }
        try { onV(); } catch (e) { console.error('[enthalpy] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[enthalpy] charts failed', e); }
        if (window.THREE) {
          try { initScene(); } catch (e) { console.error('[enthalpy] scene failed', e); el('enthalpy3d-fallback').classList.remove('hidden'); }
        } else { el('enthalpy3d-fallback').classList.remove('hidden'); }
        mountResize([scene3d]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
