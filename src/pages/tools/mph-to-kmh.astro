---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Mph to Km/h"
  emoji="🏎️"
  fromUnit="miles per hour" toUnit="kilometers per hour"
  fromTitle="Miles per Hour" toTitle="Kilometers per Hour"
  fromSym="mph" toSym="km/h"
  quantity="speed"
  kind="factor" factor={1.609344}
  reverseSlug="kmh-to-mph" reverseLabel="Km/h to Mph Converter"
  hasReverse={true}
  related={[{"slug":"speed-converter","label":"Speed Converter"}]}
  useCase="Translate a US or UK speed limit into the km/h shown on most car dashboards worldwide."
/>
