---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Logarithm Calculator';
const description = 'Calculate log base b of x, natural log (ln), and log base 10. Shows the change-of-base formula step by step.';
const intro = 'Calculate log base b of x, natural log, and see the change-of-base formula.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is a logarithm?', a: 'log_b(x) = y means b^y = x. It answers "to what power must b be raised to get x?"' },
  { q: 'What is the natural log?', a: 'ln(x) = log_e(x), where e ≈ 2.71828. It is used extensively in calculus and science.' },
  { q: 'What is the change of base formula?', a: 'log_b(x) = log_c(x) / log_c(b). This lets you compute any log using log_10 or ln.' },
  { q: 'What is log(0)?', a: 'Log(0) is undefined — there is no power that gives 0. As x → 0+, log(x) → −∞.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Base (b)</span>
        <input id="in-base" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Argument (x)</span>
        <input id="in-x" type="number" step="any" value="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-3 flex flex-wrap gap-2">
      <button data-base="2.718281828459045" data-label="ln" class="preset-btn rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700">ln</button>
      <button data-base="10" data-label="log₁₀" class="preset-btn rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700">log₁₀</button>
      <button data-base="2" data-label="log₂" class="preset-btn rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700">log₂</button>
    </div>

    <button id="calc-btn" class="mt-4 w-full rounded-xl bg-indigo-600 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700">Calculate</button>

    <div id="result" class="mt-6 hidden space-y-3 rounded-xl bg-slate-50 p-5">
      <div class="text-center">
        <div class="text-lg font-bold text-slate-900" id="result-display">log₁₀(100) = 2</div>
        <div class="mt-1 text-sm text-slate-500" id="verification-display">10² = 100</div>
      </div>
      <hr class="border-slate-200" />
      <div class="text-sm font-semibold text-slate-700">Change-of-base formula</div>
      <div class="space-y-1 text-sm text-slate-600" id="steps-display">
        <div>log₁₀(100) = log(100) / log(10)</div>
        <div>= 2 / 1</div>
        <div><strong>= 2</strong></div>
      </div>
    </div>

    <div id="error" class="mt-4 hidden rounded-xl bg-red-50 p-4 text-center text-sm font-semibold text-red-600"></div>

    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter base b and argument x, then click Calculate.</p>
  </div>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 350" width="800" height="350" role="img" aria-labelledby="log-title log-desc">
      <title id="log-title">Logarithmic curve y = log(x)</title>
      <desc id="log-desc">Graph of the logarithmic function y = log(x) showing the curve passing through (1,0), (2,0.301), (10,1), with a vertical asymptote at x=0. Axes are labelled x and y.</desc>
      <rect width="800" height="350" fill="#f8fafc" rx="8" />
      <!-- Axes -->
      <line x1="60" y1="300" x2="760" y2="300" stroke="#94a3b8" stroke-width="1.5" />
      <line x1="60" y1="20" x2="60" y2="300" stroke="#94a3b8" stroke-width="1.5" />
      <text x="755" y="295" font-size="13" fill="#64748b" font-family="system-ui">x</text>
      <text x="65" y="25" font-size="13" fill="#64748b" font-family="system-ui">y</text>
      <!-- Arrow heads -->
      <polygon points="755,300 745,295 745,305" fill="#94a3b8" />
      <polygon points="60,25 55,35 65,35" fill="#94a3b8" />
      <!-- Grid lines -->
      <line x1="200" y1="20" x2="200" y2="300" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="400" y1="20" x2="400" y2="300" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="600" y1="20" x2="600" y2="300" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="60" y1="220" x2="760" y2="220" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="60" y1="140" x2="760" y2="140" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4" />
      <line x1="60" y1="60" x2="760" y2="60" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4" />
      <!-- Tick labels: scale x: 1 unit = 70px, origin at (60,300), y inverted -->
      <!-- x ticks: 1→130, 2→200, 4→340, 6→480, 8→620, 10→760 -->
      <text x="130" y="315" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="middle">1</text>
      <text x="200" y="315" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="middle">2</text>
      <text x="340" y="315" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="middle">4</text>
      <text x="480" y="315" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="middle">6</text>
      <text x="620" y="315" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="middle">8</text>
      <text x="760" y="315" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="middle">10</text>
      <!-- y ticks: -1→380, -0.5→340, 0→300, 0.5→260, 1→220, 1.5→180, 2→140 -->
      <text x="50" y="305" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="end">0</text>
      <text x="50" y="225" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="end">1</text>
      <text x="50" y="145" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="end">2</text>
      <text x="50" y="65" font-size="11" fill="#64748b" font-family="system-ui" text-anchor="end">3</text>
      <!-- smooth log curve: y = log10(x) → pixel y = 300 - log10(x)*80 -->
      <!-- points computed: (1,300), (2,276), (4,252), (6,238), (8,228), (10,220), (20,196), (40,172), (60,158), (80,148), (100,140) -->
      <!-- map t to x: x = 1 + t*(9/10) → actual_x = 1 + t*9/10 | pixel_x = 60 + (actual_x/10)*700 -->
      <!-- simplified smooth path using cubic beziers -->
      <path d="M 62 300 Q 80 290 130 276 Q 200 252 300 234 Q 400 220 500 208 Q 600 198 700 188 Q 740 184 760 182"
        fill="none" stroke="#6366f1" stroke-width="3" stroke-linecap="round" />
      <!-- Asymptote dashed line at x=0 -->
      <line x1="60" y1="20" x2="60" y2="300" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="6,4" />
      <text x="70" y="45" font-size="11" fill="#ef4444" font-family="system-ui">x = 0 asymptote</text>
      <!-- Marked points -->
      <circle cx="130" cy="300" r="5" fill="#ef4444" />
      <text x="140" y="310" font-size="11" fill="#ef4444" font-family="system-ui" font-weight="600">(1, 0)</text>
      <circle cx="200" cy="276" r="4" fill="#818cf8" />
      <text x="210" y="280" font-size="11" fill="#818cf8" font-family="system-ui" font-weight="600">(2, 0.30)</text>
      <circle cx="760" cy="182" r="4" fill="#818cf8" />
      <text x="720" y="175" font-size="11" fill="#818cf8" font-family="system-ui" font-weight="600">(10, 1)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The logarithmic curve y = log₁₀(x) showing its characteristic slow growth. The curve passes through (1, 0) and has a vertical asymptote at x = 0.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is a logarithm?</h2>
    <p class="mt-2 text-slate-600">
      A logarithm answers the question: <em>to what exponent must a given base be raised to produce a specific number?</em> If b<sup>y</sup> = x, then log<sub>b</sub>(x) = y. The base b must be positive and not equal to 1, and the argument x must be positive. Logarithms are the inverse operation of exponentiation, just as subtraction is the inverse of addition and division is the inverse of multiplication.
    </p>
    <div class="mx-auto my-6 max-w-sm rounded-xl bg-indigo-50 p-5 text-center">
      <p class="text-xl font-bold text-indigo-800">log<sub>b</sub>(x) = y &hArr; b<sup>y</sup> = x</p>
    </div>
    <p class="text-slate-600">
      For example, log₁₀(1000) = 3 because 10³ = 10 × 10 × 10 = 1000. Similarly, log₂(32) = 5 because 2⁵ = 32. The number 2 raised to the power of 5 equals 32, so the logarithm (the exponent we need) is 5.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common bases</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-amber-100 text-lg font-bold text-amber-700">10</span>
        <h3 class="mt-3 font-semibold text-slate-900">Base 10 (common log)</h3>
        <p class="mt-1 text-sm text-slate-600">log₁₀ or simply log. Used in pH chemistry, the Richter scale for earthquakes, decibels for sound intensity, and the belief network in astronomy. It is the default base in many scientific fields and on most standard calculators.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 text-lg font-bold text-emerald-700">e</span>
        <h3 class="mt-3 font-semibold text-slate-900">Base e (natural log)</h3>
        <p class="mt-1 text-sm text-slate-600">ln(x) = log<sub>e</sub>(x) where e ≈ 2.71828. The natural log is fundamental in calculus — the derivative of ln(x) is 1/x, and it appears in formulas for compound interest, population growth, radioactive decay, and many differential equations describing natural phenomena.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-purple-100 text-lg font-bold text-purple-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Base 2 (binary log)</h3>
        <p class="mt-1 text-sm text-slate-600">log₂ is central to computer science — the number of bits needed to represent n values is ⌈log₂(n)⌉. It also describes doubling time in exponential growth, the binary search algorithm's efficiency (log₂(n) comparisons), and information entropy in communication theory.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The change-of-base formula</h2>
    <p class="mt-2 text-slate-600">
      Most calculators only have keys for log₁₀ (log) and ln (natural log). To compute logarithms with an arbitrary base, use the change-of-base formula:
    </p>
    <div class="mx-auto my-6 max-w-sm rounded-xl bg-indigo-50 p-5 text-center">
      <p class="text-xl font-bold text-indigo-800">log<sub>b</sub>(x) = log<sub>c</sub>(x) / log<sub>c</sub>(b)</p>
    </div>
    <p class="text-slate-600">
      The formula works for any positive base c ≠ 1, but we typically choose c = 10 or c = e since those are available on every calculator. This tool uses the natural log internally: log<sub>b</sub>(x) = ln(x) / ln(b). The result is the same regardless of which intermediate base c you pick.
    </p>
    <p class="mt-3 text-slate-600">
      For example, to compute log₂(32): log₂(32) = ln(32) / ln(2) = 3.4657 / 0.6931 = 5.000. And indeed 2⁵ = 32. The formula is derived from the relationship b<sup>y</sup> = x. Take log<sub>c</sub> of both sides: y · log<sub>c</sub>(b) = log<sub>c</sub>(x), then solve for y to get y = log<sub>c</sub>(x) / log<sub>c</sub>(b).
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked examples</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">Example 1: log₂(32)</h3>
        <p class="mt-1 text-sm text-slate-600">Since 2⁵ = 32, the exponent needed is 5. Therefore log₂(32) = 5. Using the change-of-base formula: ln(32) ÷ ln(2) = 3.4657 ÷ 0.6931 = 5.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">Example 2: log₁₀(1000)</h3>
        <p class="mt-1 text-sm text-slate-600">10³ = 1000, so log₁₀(1000) = 3. The common log of 1000 is exactly 3 because the base and argument share a convenient power relationship. This is why log₁₀ is intuitive — each integer increase corresponds to multiplying by 10.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">Example 3: log₃(81)</h3>
        <p class="mt-1 text-sm text-slate-600">3⁴ = 81, so log₃(81) = 4. Using the change-of-base formula with natural logs: ln(81) ÷ ln(3) = 4.3944 ÷ 1.0986 = 4. Notice that 81 = 3⁴, so the logarithm is simply 4.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world use cases</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">&#x1F9EA;</span>
        <h3 class="mt-2 font-semibold text-slate-900">pH chemistry</h3>
        <p class="mt-1 text-sm text-slate-600">The pH of a solution is defined as pH = −log₁₀[H⁺], where [H⁺] is the concentration of hydrogen ions in moles per litre. A pH of 3 has ten times the hydrogen ion concentration of pH 4. The logarithmic scale compresses a huge range of concentrations (10⁻¹ to 10⁻¹⁴ M) into a simple 0–14 scale.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">&#x1F4C8;</span>
        <h3 class="mt-2 font-semibold text-slate-900">Doubling time</h3>
        <p class="mt-1 text-sm text-slate-600">If a population grows at rate r per period, the doubling time is t = ln(2) / ln(1 + r). Base-2 logs naturally express how many doublings have occurred. For example, if bacteria double every hour, after t hours the population is 2<sup>t</sup> times the original; log₂ tells you the exponent directly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">&#x1F50A;</span>
        <h3 class="mt-2 font-semibold text-slate-900">Decibels</h3>
        <p class="mt-1 text-sm text-slate-600">Sound intensity level in decibels is L = 10 · log₁₀(I / I₀), where I₀ is the reference threshold of hearing. A 20 dB increase represents 100× more intense sound (since 10·log₁₀(100) = 20). The logarithmic ear perceives ratios, not linear differences.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">&#x1F30D;</span>
        <h3 class="mt-2 font-semibold text-slate-900">Richter scale</h3>
        <p class="mt-1 text-sm text-slate-600">Each whole number on the Richter scale represents a tenfold increase in measured amplitude and roughly 31.6 times more energy release. A magnitude 6 earthquake releases about 1000× the energy of a magnitude 4 (since 31.6² ≈ 1000). The logarithmic scale condenses a vast energy range.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with logarithms</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">The argument must be positive</h3>
        <p class="mt-1 text-sm text-slate-600">Logarithms are only defined for positive arguments. You cannot take the log of zero or a negative number. As x approaches 0 from the positive side, log(x) approaches negative infinity. The domain of log<sub>b</sub>(x) is x &gt; 0.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">The base must be positive and not equal to 1</h3>
        <p class="mt-1 text-sm text-slate-600">If the base is 1, then 1<sup>y</sup> = 1 for all y, so log₁(x) is undefined for any x ≠ 1. If the base is less than or equal to 0, the function becomes discontinuous and non-real for most inputs. Valid bases are in the range (0, 1) ∪ (1, ∞).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Logarithms turn multiplication into addition</h3>
        <p class="mt-1 text-sm text-slate-600">The fundamental property log<sub>b</sub>(x · y) = log<sub>b</sub>(x) + log<sub>b</sub>(y) made logarithms invaluable before electronic calculators — slide rules and logarithm tables let engineers multiply large numbers by adding their logarithms. This property also underlies logarithmic scale graphs.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Power and root rules</h3>
        <p class="mt-1 text-sm text-slate-600">log<sub>b</sub>(x<sup>p</sup>) = p · log<sub>b</sub>(x) and log<sub>b</sub>(ⁿ√x) = (1/n) · log<sub>b</sub>(x). These are useful for simplifying equations involving exponents and roots. For example, log₂(√8) = (1/2) · log₂(8) = (1/2) · 3 = 1.5, which checks out since √8 ≈ 2.828 and 2<sup>1.5</sup> ≈ 2.828.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li><a href="/tools/quadratic-equation-solver" class="font-medium text-indigo-600 hover:underline">Quadratic Equation Solver</a> — solve ax² + bx + c = 0 with step-by-step work.</li>
      <li><a href="/tools/gcd-lcm-calculator" class="font-medium text-indigo-600 hover:underline">GCD and LCM Calculator</a> — find greatest common divisor and least common multiple of two numbers.</li>
      <li><a href="/tools/scientific-calculator" class="font-medium text-indigo-600 hover:underline">Scientific Calculator</a> — perform advanced mathematical operations.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function fmt(n) {
      if (!Number.isFinite(n)) return 'Undefined';
      if (Number.isInteger(n)) return n.toString();
      const s = n.toPrecision(8);
      const parsed = parseFloat(s);
      return parsed.toString();
    }

    function compute() {
      const base = parseFloat(el('in-base').value);
      const x = parseFloat(el('in-x').value);
      const resultEl = el('result');
      const errorEl = el('error');
      const hintEl = el('hint');

      resultEl.classList.add('hidden');
      errorEl.classList.add('hidden');
      hintEl.classList.add('hidden');

      if (isNaN(base) || isNaN(x)) {
        hintEl.textContent = 'Please enter valid numbers for base and argument.';
        hintEl.classList.remove('hidden');
        return;
      }

      if (base <= 0 || base === 1) {
        errorEl.textContent = 'Base must be positive and not equal to 1 (b > 0, b ≠ 1).';
        errorEl.classList.remove('hidden');
        return;
      }

      if (x <= 0) {
        errorEl.textContent = 'Argument must be positive (x > 0). Logarithm of zero or a negative number is undefined.';
        errorEl.classList.remove('hidden');
        return;
      }

      const result = Math.log(x) / Math.log(base);

      el('result-display').innerHTML = 'log<sub>' + fmt(base) + '</sub>(' + fmt(x) + ') = <strong>' + fmt(result) + '</strong>';

      const verification = Math.pow(base, result);
      el('verification-display').innerHTML = fmt(base) + '<sup>' + fmt(result) + '</sup> = ' + fmt(verification);

      const lnX = Math.log(x);
      const lnB = Math.log(base);
      el('steps-display').innerHTML =
        '<div>log<sub>' + fmt(base) + '</sub>(' + fmt(x) + ') = ln(' + fmt(x) + ') / ln(' + fmt(base) + ')</div>' +
        '<div>= ' + fmt(lnX) + ' / ' + fmt(lnB) + '</div>' +
        '<div><strong>= ' + fmt(result) + '</strong></div>';

      resultEl.classList.remove('hidden');
    }

    el('calc-btn').addEventListener('click', compute);
    ['in-base', 'in-x'].forEach((id) => el(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') compute(); }));

    document.querySelectorAll('.preset-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        el('in-base').value = btn.dataset.base;
        compute();
      });
    });

    compute();
  </script>
</ToolLayout>
