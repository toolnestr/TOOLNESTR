---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Knots to Mph"
  emoji="🏎️"
  fromUnit="knots" toUnit="miles per hour"
  fromTitle="Knots" toTitle="Miles per Hour"
  fromSym="kn" toSym="mph"
  quantity="speed"
  kind="factor" factor={1.150779}
  reverseSlug="mph-to-kmh" reverseLabel="Mph to Km/h Converter"
  hasReverse={false}
  related={[{"slug":"speed-converter","label":"Speed Converter"}]}
  useCase="Pilots and sailors use it to express wind and vessel speed in knots as everyday miles per hour."
/>
