---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Pascals", sym: "Pa", toBase: 1 }, { name: "Kilopascals", sym: "kPa", toBase: 1000 }, { name: "Bar", sym: "bar", toBase: 100000 }, { name: "Pounds per square inch", sym: "psi", toBase: 6894.757293 }, { name: "Atmospheres", sym: "atm", toBase: 101325 }, { name: "Millimeters of mercury", sym: "mmHg", toBase: 133.322387 }, { name: "Inches of mercury", sym: "inHg", toBase: 3386.389 }];
---
<MultiUnitConverter
  title="Pressure Converter"
  emoji="🔧"
  quantity="pressure"
  baseName="pascal"
  units={units}
  defaultFrom={2} defaultTo={3}
  intro="Convert between pressure units — pascals, kilopascals, bar, pounds per square inch, atmospheres and more."
  blurb="Pressure measures force over an area, used for tyres, weather and industrial systems."
  related={[{"slug":"psi-to-bar","label":"Psi to Bar Converter"},{"slug":"bar-to-psi","label":"Bar to Psi Converter"}]}
/>
