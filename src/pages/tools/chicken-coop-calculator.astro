---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Chicken Coop Size Calculator';
const description = 'Find the recommended coop floor space, run space, nesting boxes and roosting bar length for your flock size, based on common poultry-keeping guidelines.';
const intro = 'Find the recommended coop space, run space, nesting boxes, and roosting bar length for your flock, based on common poultry-keeping guidelines.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much space does a chicken need in a coop?', a: 'A widely used guideline from poultry extension programs is about 2 to 3 square feet of coop floor space per standard-size chicken if they also have outdoor run access, and 4 or more square feet per bird if they are confined to the coop most of the time.' },
  { q: 'How much run space does a flock need?', a: 'Outdoor run space is commonly recommended at 8 to 10 square feet per bird for a basic run, and considerably more for a free-range or pasture setup. More run space reduces pecking and stress in the flock.' },
  { q: 'How many nesting boxes do I need?', a: 'One nesting box per 3 to 4 hens is the common guideline, since hens will happily share and take turns rather than each needing its own box.' },
  { q: 'How much roosting bar length do chickens need?', a: 'Standard-size chickens are usually given about 8 to 10 inches of roosting bar length each so they can perch comfortably shoulder to shoulder overnight.' },
];
const howTo = {
  name: 'How to size a chicken coop and run',
  steps: [
    { name: 'Enter flock size', text: 'Enter the number of standard-size chickens you are keeping.' },
    { name: 'Note run access', text: 'Birds with outdoor access need less coop floor space than fully confined birds.' },
    { name: 'Read the sizes', text: 'Get coop area, run area, nesting boxes, and roost length.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of chickens</span>
        <input id="birds" type="number" step="1" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Access to outdoor run?</span>
        <select id="access" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="2.5">Yes, has a run (2.5 ft²/bird coop)</option>
          <option value="4">No, mostly confined (4 ft²/bird coop)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Minimum coop floor space</div>
        <div id="r-coop" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-run" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Nesting boxes</div><div id="r-boxes" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Roost bar length</div><div id="r-roost" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Run space</div><div id="r-runspace" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="280" viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="cc-title cc-desc">
      <title id="cc-title">Chicken coop and run layout</title>
      <desc id="cc-desc">A small coop building next to a larger fenced run, showing the space-per-bird guidelines</desc>
      <rect x="90" y="110" width="150" height="110" fill="#fde68a" stroke="#d97706" stroke-width="2" />
      <polygon points="90,110 165,70 240,110" fill="#d97706" />
      <text x="165" y="170" text-anchor="middle" font-size="12" fill="#78350f" font-family="system-ui,sans-serif">coop</text>
      <rect x="260" y="130" width="280" height="90" fill="#dcfce7" stroke="#16a34a" stroke-width="2" stroke-dasharray="6 3" />
      <text x="400" y="180" text-anchor="middle" font-size="12" fill="#166534" font-family="system-ui,sans-serif">run</text>
      <rect x="580" y="90" width="200" height="140" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="600" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Guidelines</text>
      <text x="600" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">coop: 2.5-4 ft&sup2;/bird</text>
      <text x="600" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">run: 8-10 ft&sup2;/bird</text>
      <text x="600" y="188" font-size="12" fill="#475569" font-family="system-ui,sans-serif">1 box per 3-4 hens</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A coop is the sheltered sleeping and laying space; the run is the fenced outdoor area.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the chicken coop calculator works</h2>
    <p class="mt-2 text-slate-600">
      Backyard poultry guidelines from agricultural extension programs give space recommendations per standard-size bird, and this calculator simply multiplies your flock size by those figures. Coop floor space — the sheltered building where birds sleep and lay — is commonly recommended at 2.5 to 4 square feet per bird, with the lower figure for flocks that also have outdoor run access and the higher figure for birds kept mostly confined indoors.
    </p>
    <p class="mt-3 text-slate-600">
      Run space, the fenced outdoor area, is commonly recommended at 8 to 10 square feet per bird for a basic setup; free-range or pasture-based flocks benefit from considerably more. Nesting boxes follow a sharing ratio, since hens happily take turns rather than each needing an individual box — one box per 3 to 4 hens is standard. Roosting bar length is given per bird because chickens perch side by side overnight, typically needing 8 to 10 inches of bar each.
    </p>
    <p class="mt-3 text-slate-600">
      These figures come from agricultural extension and backyard-poultry guidelines rather than a formal building code — there is no equivalent to a structural or electrical code for coop sizing. Breed size, climate, and how much time birds spend outdoors all shift the ideal numbers, so treat this as a solid starting point rather than an exact requirement.
    </p>
    <p class="mt-3 text-xs text-slate-400">Space, box, and roost guidelines are drawn from state university agricultural extension backyard-poultry publications (e.g. University of Kentucky and Penn State Extension small-flock housing guides).</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter flock size</h3>
        <p class="mt-1 text-sm text-slate-600">The number of standard-size chickens you are keeping.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Note run access</h3>
        <p class="mt-1 text-sm text-slate-600">Birds with outdoor access need less coop floor space than fully confined birds.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the sizes</h3>
        <p class="mt-1 text-sm text-slate-600">Get coop area, run area, nesting boxes, and roost length.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Coop floor space</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= birds &times; ft&sup2;/bird</span>. 6 birds with run access: 6 &times; 2.5 = <strong>15 ft&sup2;</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Run space</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= birds &times; 9 ft&sup2;</span> (midpoint of 8-10). 6 &times; 9 = <strong>54 ft&sup2;</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Boxes and roost</p>
        <p class="mt-1 text-slate-600">
          Boxes = ceil(6&frasl;3.5) = <strong>2 boxes</strong>; roost = 6 &times; 9&Prime; = <strong>54&Prime; (4.5 ft) of bar</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A backyard flock of 10 hens, kept mostly confined with only occasional run time.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Coop:</span> <span class="text-slate-600">10 &times; 4 = <strong>40 ft²</strong></span></div>
        <div><span class="font-medium text-slate-700">Run:</span> <span class="text-slate-600">10 &times; 9 = 90 ft²</span></div>
        <div><span class="font-medium text-slate-700">Boxes:</span> <span class="text-slate-600">ceil(10/3.5) = 3</span></div>
        <div><span class="font-medium text-slate-700">Roost:</span> <span class="text-slate-600">10 &times; 9 = 90in (7.5 ft)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Keeping a healthy flock</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌬️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Ventilation matters as much as space</h3>
        <p class="mt-1 text-sm text-slate-600">A coop needs good airflow near the roof to clear moisture and ammonia without creating a direct draft on roosting birds. Crowded, poorly ventilated coops breed respiratory illness fast.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🦊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Predator-proof the run</h3>
        <p class="mt-1 text-sm text-slate-600">Bury fencing a foot or more underground or add an apron, and cover open runs, since digging and climbing predators are the most common cause of flock losses.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🥚</span>
        <h3 class="mt-2 font-semibold text-slate-900">Keep nesting boxes dim and low</h3>
        <p class="mt-1 text-sm text-slate-600">Boxes placed lower than the roosting bars and away from bright light encourage hens to lay in the box rather than on the coop floor.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📈</span>
        <h3 class="mt-2 font-semibold text-slate-900">Plan for flock growth</h3>
        <p class="mt-1 text-sm text-slate-600">Chicken math is famous for flocks that grow. Building a little larger than today's headcount, or designing walls and roofing that can be extended later, saves a full coop expansion project down the road once the "just one more chick" habit sets in.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A small backyard starter flock is the most common case this calculator sees. Four hens kept mostly confined, without daily run access, need 4 &times; 4 = 16 square feet of coop floor plus 4 &times; 9 = 36 square feet of run — small enough that many first-time keepers build a single combined coop-and-run structure rather than two separate spaces, using 2 nesting boxes and 3 feet of roosting bar.
    </p>
    <p class="mt-3 text-slate-600">
      A larger flock with daily outdoor access changes the proportions. Twenty hens with run access need only 20 &times; 2.5 = 50 square feet of coop floor, but 20 &times; 9 = 180 square feet of run — six 6-hen flocks' worth of space, requiring 6 nesting boxes and 15 feet of roosting bar split across multiple perches, since a single 15-foot bar rarely fits inside a coop that size.
    </p>
    <p class="mt-3 text-slate-600">
      A tiny urban flock of 3 hens with run access, common under many city backyard-chicken ordinances that cap flock size, needs just 3 &times; 2.5 = 7.5 square feet of coop and 3 &times; 9 = 27 square feet of run, with only 1 nesting box (ceil(3&frasl;3.5) = 1) since three hens comfortably share a single box.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Each hen needs her own nesting box." <strong class="text-slate-900">Hens share readily and even prefer it.</strong> One box per 3 to 4 hens is the standard guideline — hens often pile into the same "favorite" box even when others sit empty, so extra boxes rarely get used and just take up space.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"More coop space always means a healthier flock." <strong class="text-slate-900">Ventilation and predator-proofing matter more than raw square footage.</strong> A spacious but poorly ventilated or poorly secured coop can be more dangerous to a flock than a smaller, well-ventilated, predator-proof one — space per bird is a starting point, not a substitute for good design.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fence-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Fence Calculator</a>
      <a href="/tools/square-footage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
      <a href="/tools/board-foot-lumber-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Board Foot Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const birds = parseInt(el('birds').value, 10);
      const perBird = parseFloat(el('access').value);
      if (!birds || birds < 1) {
        el('results').classList.add('hidden');
        return;
      }
      const coop = birds * perBird;
      const run = birds * 9;
      const boxes = Math.ceil(birds / 3.5);
      const roostIn = birds * 9;

      el('r-coop').textContent = coop.toFixed(1) + ' ft²';
      el('r-run').textContent = 'plus ' + run.toFixed(0) + ' ft² of outdoor run';
      el('r-boxes').textContent = boxes.toLocaleString();
      el('r-roost').textContent = (roostIn / 12).toFixed(1) + ' ft';
      el('r-runspace').textContent = run.toFixed(0) + ' ft²';
      el('results').classList.remove('hidden');
    }

    el('birds').addEventListener('input', update);
    el('access').addEventListener('change', update);
  </script>
</ToolLayout>
