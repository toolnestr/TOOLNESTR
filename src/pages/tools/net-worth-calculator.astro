---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Net Worth Calculator';
const description =
  'Free net worth calculator. Calculate your net worth by adding up all your assets and subtracting all your liabilities. Track your financial progress over time.';
const intro =
  'Enter itemized lists of your assets (what you own) and liabilities (what you owe) to calculate your net worth. See a breakdown of each category.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'What is net worth?', a: 'Net worth is the total value of everything you own (assets) minus everything you owe (liabilities). It is the single best measure of your overall financial health. A positive net worth means you have more assets than debts.' },
  { q: 'How is net worth calculated?', a: 'Net worth = Total Assets - Total Liabilities. Assets include cash, investments, real estate, vehicles, and personal property. Liabilities include mortgages, car loans, student loans, credit card debt, and any other debts.' },
  { q: 'What is a good net worth?', a: 'A good net worth depends on your age, income, and financial goals. A common benchmark is to have a net worth equal to your annual income by age 30, 3-6× income by 45, and 6-10× income by 60. However, the most important thing is that your net worth is trending upward over time.' },
  { q: 'How often should I track my net worth?', a: 'Most people track net worth monthly or quarterly. Monthly tracking helps you see the impact of your financial decisions in real time. Quarterly or annual tracking is sufficient if you prefer a less frequent review. The key is to track consistently so you can spot trends.' },
  { q: 'Should I include my home equity?', a: "Yes, include your home's estimated market value as an asset and the remaining mortgage balance as a liability. The difference is your home equity. Be realistic about your home's value — use comparable sales or a recent appraisal rather than your purchase price." },
  { q: 'Should I include my 401(k) and IRA?', a: 'Yes, include the current balance of all retirement accounts. While you may not be able to access these funds without penalty before retirement, they are still part of your total wealth. Track them to see your long-term progress.' },
  { q: 'Should I include my car?', a: "Include your vehicle's current market value (what you could sell it for) as an asset and any remaining auto loan balance as a liability. Use Kelley Blue Book or similar resources for accurate vehicle values." },
  { q: 'What about personal belongings?', a: 'You can include personal property like jewelry, art, electronics, and furniture, but be realistic about their resale value. Most personal items depreciate significantly. Many people exclude them from net worth calculations to keep things simple.' },
  { q: 'Does net worth include future income?', a: 'No, net worth is a snapshot of what you currently own minus what you owe. Future income is not included because it has not been earned yet. However, you can project future net worth by estimating savings and investment growth.' },
  { q: 'What if my net worth is negative?', a: 'A negative net worth is common early in life, especially for recent graduates with student loans or young families with mortgages. The goal is to steadily increase net worth over time by saving more, paying down debt, and letting investments grow.' },
];
const sources = [
  { html: "<strong>IRS</strong> — federal tax brackets, standard deduction and instructions for the tax year. <a href=\"https://www.irs.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">irs.gov</a>" },
  { html: "<strong>U.S. SEC — Investor.gov</strong>, compound interest and investment reference material. <a href=\"https://www.investor.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">investor.gov</a>" },
  { html: "<strong>Official national tax authority</strong> for the relevant country — link the exact rate schedule used." },
];
const sourcesNote = "Estimates only, not tax or financial advice. Confirm current figures with the official source or a qualified professional.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="space-y-4">
        <h3 class="font-semibold text-slate-900">Assets</h3>
        <label class="block"><span class="text-sm font-medium text-slate-700">Cash & savings ($)</span>
          <input id="cash" type="number" step="any" placeholder="15000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Investments (stocks, bonds, 401k, IRA) ($)</span>
          <input id="investments" type="number" step="any" placeholder="85000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Home value ($)</span>
          <input id="home" type="number" step="any" placeholder="350000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Vehicles ($)</span>
          <input id="vehicles" type="number" step="any" placeholder="25000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Other assets ($)</span>
          <input id="otherAssets" type="number" step="any" placeholder="10000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div class="space-y-4">
        <h3 class="font-semibold text-slate-900">Liabilities</h3>
        <label class="block"><span class="text-sm font-medium text-slate-700">Mortgage balance ($)</span>
          <input id="mortgage" type="number" step="any" placeholder="280000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Car loans ($)</span>
          <input id="carLoan" type="number" step="any" placeholder="15000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Student loans ($)</span>
          <input id="studentLoans" type="number" step="any" placeholder="20000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Credit card debt ($)</span>
          <input id="creditCards" type="number" step="any" placeholder="3000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Other debts ($)</span>
          <input id="otherLiabilities" type="number" step="any" placeholder="5000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Net Worth</div><div id="r-networth" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Total Assets</div><div id="r-assets" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Total Liabilities</div><div id="r-liabilities" class="mt-1 text-2xl font-bold text-emerald-600">—</div></div>
    </div>
    <p id="err" class="mt-3 text-center text-sm text-red-600"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How net worth is calculated</h2>
    <p class="mt-2 text-slate-600">
      Net worth is deceptively simple:
      <span class="font-mono">Net Worth = Total Assets - Total Liabilities</span>.
      Assets include everything you own that has monetary value: cash, investments, real estate,
      vehicles, and valuable personal property. Liabilities include all your debts: mortgages, auto
      loans, student loans, credit card balances, medical debt, and personal loans. The result is a
      single number that captures your entire financial position at a point in time.
    </p>
    <p class="mt-3 text-slate-600">
      Tracking net worth over time is the best way to measure your financial progress. A rising net
      worth means you are building wealth — saving more than you spend, paying down debt, and letting
      investments grow. A declining net worth is an early warning sign that spending is outpacing
      savings or that investment values have dropped. The goal is not necessarily a high net worth
      overnight, but consistent upward momentum over the long term.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A typical family's financial snapshot:</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Cash & savings:</span> <span class="text-slate-600">$15,000</span></div>
        <div><span class="font-medium text-slate-700">Investments:</span> <span class="text-slate-600">$85,000</span></div>
        <div><span class="font-medium text-slate-700">Home value:</span> <span class="text-slate-600">$350,000</span></div>
        <div><span class="font-medium text-slate-700">Vehicles and other:</span> <span class="text-slate-600">$35,000</span></div>
        <div><span class="font-medium text-slate-700">Total assets:</span> <span class="text-slate-600">$485,000</span></div>
        <div><span class="font-medium text-slate-700">Total liabilities:</span> <span class="text-slate-600">$323,000</span></div>
        <div><span class="font-medium text-slate-700">Net worth:</span> <span class="text-slate-600">$162,000</span></div>
      </div>
    </div>
  </section>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Balance scale showing assets versus liabilities">
      <title>Net Worth Balance Scale</title>
      <desc>A balance scale with assets on the left side weighing more than liabilities on the right side, with the net worth amount shown as the difference.</desc>
      <line x1="400" y1="30" x2="400" y2="70" stroke="#64748b" stroke-width="3"/>
      <polygon points="400,70 385,85 415,85" fill="#64748b"/>
      <line x1="140" y1="120" x2="400" y2="85" stroke="#6366f1" stroke-width="4"/>
      <line x1="660" y1="120" x2="400" y2="85" stroke="#94a3b8" stroke-width="4"/>
      <rect x="80" y="120" width="120" height="60" rx="8" fill="#eef2ff" stroke="#6366f1" stroke-width="2"/>
      <text x="140" y="150" text-anchor="middle" fill="#6366f1" font-size="16" font-weight="bold">Assets</text>
      <text x="140" y="168" text-anchor="middle" fill="#6366f1" font-size="12">$485,000</text>
      <rect x="600" y="120" width="120" height="60" rx="8" fill="#f1f5f9" stroke="#94a3b8" stroke-width="2"/>
      <text x="660" y="150" text-anchor="middle" fill="#94a3b8" font-size="16" font-weight="bold">Liabilities</text>
      <text x="660" y="168" text-anchor="middle" fill="#94a3b8" font-size="12">$323,000</text>
      <rect x="300" y="140" width="200" height="40" rx="20" fill="#f0fdf4" stroke="#22c55e" stroke-width="2"/>
      <text x="400" y="165" text-anchor="middle" fill="#22c55e" font-size="14" font-weight="bold">Net Worth: $162,000</text>
      <text x="400" y="205" text-anchor="middle" fill="#64748b" font-size="13">Assets — Liabilities = Net Worth</text>
    </svg>
    <figcaption class="mt-3 text-center text-sm text-slate-500">Your net worth is the balance of what you own minus what you owe — the scale tips toward assets when you are building wealth</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About net worth</h2>
    <p class="mt-2 text-slate-600">
      Net worth is the most comprehensive measure of your financial health. While your income tells
      you how much money comes in each month, and your credit score tells you how well you manage
      debt, your net worth tells you the bottom line — are you building wealth or going backward?
      Tracking net worth regularly helps you make better financial decisions. Use the
      <a href="/tools/emergency-fund-calculator" class="font-medium text-indigo-600 hover:underline">Emergency Fund Calculator</a>
      to ensure you have adequate cash reserves, and the
      <a href="/tools/budget-calculator" class="font-medium text-indigo-600 hover:underline">Budget Calculator</a>
      to find more money to save and invest for growing your net worth.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter the value of each asset category — include all cash, investments, property, and valuables.</li>
      <li>Enter each liability type — include all mortgages, loans, credit cards, and other debts.</li>
      <li>See your net worth, total assets, and total liabilities instantly calculated.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use it at the beginning of each month as part of your financial checkup, when making major
      financial decisions (buying a home, taking out a loan), at the start of each year to set
      net worth goals, or whenever you want to track your progress toward financial independence.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for growing net worth</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Focus on increasing assets (saving and investing more) AND reducing liabilities (paying down high-interest debt).</li>
      <li>Dont be discouraged by a low or negative net worth early in life — consistency over time is what matters.</li>
      <li>Use realistic values for assets like homes and cars — overvaluing them gives a false sense of financial health.</li>
    </ul>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍💻</span>
      <h3 class="mt-2 font-semibold text-slate-900">Young Professional</h3>
      <p class="mt-1 text-sm text-slate-600">Track your net worth from the start of your career. Watch it grow as you save, invest, and pay down student loans. Stay motivated by seeing the positive trend over time.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏠</span>
      <h3 class="mt-2 font-semibold text-slate-900">Homeowner</h3>
      <p class="mt-1 text-sm text-slate-600">Track how your home equity builds over time as you pay down the mortgage and your property appreciates. Home equity is often the largest component of household net worth.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔄</span>
      <h3 class="mt-2 font-semibold text-slate-900">Debt Repayer</h3>
      <p class="mt-1 text-sm text-slate-600">Use the calculator to stay motivated while paying off debt. Watch your net worth climb as each liability decreases. Celebrate every time the number goes up.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💼</span>
      <h3 class="mt-2 font-semibold text-slate-900">Financial Advisor</h3>
      <p class="mt-1 text-sm text-slate-600">Track client net worth across all accounts in one place. Use the snapshot to identify areas for improvement, set goals, and measure progress during regular reviews.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the net worth calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">List your assets</h3>
        <p class="mt-1 text-sm text-slate-600">Add up everything you own — cash accounts, investment accounts, retirement funds, home equity, vehicle values, and other valuable property. Use current market values.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">List your liabilities</h3>
        <p class="mt-1 text-sm text-slate-600">Enter all your debts — mortgage balance, auto loans, student loans, credit card balances, personal loans, medical debt, and any other money you owe.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">See your financial snapshot</h3>
        <p class="mt-1 text-sm text-slate-600">Review your total assets, total liabilities, and net worth. Use this snapshot to set goals, track progress, and make informed financial decisions going forward.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for tracking and growing net worth</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Track consistently, not obsessively</h3>
        <p class="mt-1 text-sm text-slate-600">Checking your net worth weekly can lead to unnecessary stress from market fluctuations. Monthly or quarterly tracking is ideal — frequent enough to spot trends, rare enough to avoid reacting to short-term volatility. Set a recurring calendar reminder to update your numbers.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Focus on what you can control</h3>
        <p class="mt-1 text-sm text-slate-600">You cannot control stock market returns or home values, but you can control your savings rate, spending habits, and debt payments. Increasing your savings rate and paying off high-interest debt are the two most reliable ways to grow net worth regardless of market conditions.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Set net worth milestones</h3>
        <p class="mt-1 text-sm text-slate-900">Set concrete net worth goals — $100,000, $500,000, $1 million — and celebrate when you hit each one. Visualizing progress toward these milestones keeps you motivated during the long journey to financial independence.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li><a href="/tools/emergency-fund-calculator" class="font-medium text-indigo-600 hover:underline">Emergency Fund Calculator</a> — Make sure you have adequate cash reserves as part of your total financial picture.</li>
      <li><a href="/tools/budget-calculator" class="font-medium text-indigo-600 hover:underline">Budget Calculator</a> — Find opportunities to save more and accelerate your net worth growth.</li>
      <li><a href="/tools/retirement-calculator" class="font-medium text-indigo-600 hover:underline">Retirement Calculator</a> — See if your current net worth trajectory will support your retirement goals.</li>
      <li><a href="/tools/investment-calculator" class="font-medium text-indigo-600 hover:underline">Investment Calculator</a> — Project how your investments will grow and contribute to future net worth.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const fmt = (n) => (n < 0 ? '-$' : '$') + Math.abs(n).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    function update() {
      const assetIds = ['cash', 'investments', 'home', 'vehicles', 'otherAssets'];
      const liabilityIds = ['mortgage', 'carLoan', 'studentLoans', 'creditCards', 'otherLiabilities'];
      let totalAssets = 0, totalLiabilities = 0;
      for (const id of assetIds) {
        const v = parseFloat(el(id).value);
        if (!isNaN(v)) totalAssets += v;
      }
      for (const id of liabilityIds) {
        const v = parseFloat(el(id).value);
        if (!isNaN(v)) totalLiabilities += v;
      }
      const networth = totalAssets - totalLiabilities;
      el('r-assets').textContent = fmt(totalAssets);
      el('r-liabilities').textContent = fmt(totalLiabilities);
      el('r-networth').textContent = fmt(networth);
      el('r-networth').style.color = networth >= 0 ? '#ffffff' : '#dc2626';
    }
    ['cash', 'investments', 'home', 'vehicles', 'otherAssets', 'mortgage', 'carLoan', 'studentLoans', 'creditCards', 'otherLiabilities'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
