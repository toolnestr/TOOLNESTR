---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Board and Batten Calculator';
const description = 'Calculate how many boards and battens you need to cover a wall in board-and-batten siding or paneling, from wall size and board/batten width.';
const intro = 'Find how many boards and battens you need for a board-and-batten wall, from its size and spacing.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate board and batten spacing?', a: 'Divide the wall width by your chosen board spacing (board width plus gap) to get the number of boards, then subtract one board width per gap to add a thin batten strip over each seam. For a 12 ft wall with 12-inch spacing, that is 12 boards across.' },
  { q: 'What is the difference between board and batten siding vs. interior paneling?', a: 'Both use the same layout math — wide boards or panel sections with a narrower strip (batten) covering the seams between them — but exterior siding uses weather-rated lumber or fiber cement, while interior board and batten wainscoting typically uses MDF or pine and is purely decorative.' },
  { q: 'How wide should the spacing between battens be?', a: 'A common residential look uses battens spaced 12 to 16 inches apart on center, similar to stud spacing, though wider 16-24 inch spacing gives a bolder, more modern look. Spacing is primarily an aesthetic choice rather than a structural one.' },
  { q: 'How many linear feet of batten do I need?', a: 'Multiply the number of battens by the wall height (for a full-height batten run). This calculator gives that total directly, in linear feet, so you can convert to board lengths for your specific lumber.' },
];
const howTo = {
  name: 'How to calculate board and batten materials',
  steps: [
    { name: 'Measure the wall', text: 'Width and height in feet.' },
    { name: 'Pick a spacing', text: 'On-center distance between battens.' },
    { name: 'Order materials', text: 'Battens, linear feet, and backing sheets.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall width (ft)</span>
        <input id="width" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Wall height (ft)</span>
        <input id="height" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Batten spacing on-center (in)</span>
        <input id="spacing" type="number" step="any" placeholder="16" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Battens needed</div>
        <div id="r-battens" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Wall area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Batten linear feet</div><div id="r-linft" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Board sheets (4×8)</div><div id="r-sheets" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="bb-title bb-desc">
      <title id="bb-title">Board and batten wall layout</title>
      <desc id="bb-desc">A wall with vertical battens evenly spaced over board seams</desc>
      <rect x="70" y="50" width="280" height="120" fill="#fef3c7" stroke="#d97706" stroke-width="1" />
      <g stroke="#b45309" stroke-width="6"><line x1="105" y1="50" x2="105" y2="170" /><line x1="140" y1="50" x2="140" y2="170" /><line x1="175" y1="50" x2="175" y2="170" /><line x1="210" y1="50" x2="210" y2="170" /><line x1="245" y1="50" x2="245" y2="170" /><line x1="280" y1="50" x2="280" y2="170" /><line x1="315" y1="50" x2="315" y2="170" /></g>
      <text x="210" y="188" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">battens on-center spacing</text>
      <rect x="420" y="55" width="330" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Battens needed</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">= ceil( wall width(in) &divide; spacing ) + 1</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">+1 for the starting edge batten</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Battens run vertically over the wide board seams at an even on-center spacing.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the board and batten calculator works</h2>
    <p class="mt-2 text-slate-600">
      Board and batten is a siding and paneling style made from wide boards or panel sheets with narrower strips — the battens — covering the seams between them. Laying it out is a spacing problem: convert the wall width to inches, divide by your chosen on-center spacing, and round up to get the number of gaps, then add one more batten for the starting edge, since a wall with N gaps needs N+1 vertical strips running the full height.
    </p>
    <p class="mt-3 text-slate-600">
      Spacing is mostly an aesthetic decision rather than a structural one. A traditional residential look uses battens spaced 12 to 16 inches on center, echoing standard stud spacing, while a bolder, more contemporary look spreads them 16 to 24 inches apart. Once the batten count is set, multiplying by wall height gives the total linear footage of batten stock to buy, and the wall area (width times height) tells you how many 4×8 sheet goods you need for the board backing beneath the battens.
    </p>
    <p class="mt-3 text-slate-600">
      The same layout math works whether you are doing exterior siding with weather-rated lumber or fiber cement, or interior board-and-batten wainscoting with MDF or pine trim — only the material changes, not the spacing formula. Always add a small waste allowance (5 to 10%) for cuts around windows, doors, and corners.
    </p>
    <p class="mt-3 text-xs text-slate-400">Stud-spacing and wall-covering conventions referenced here follow the International Residential Code (IRC) framing and exterior wall covering provisions.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the wall</h3>
        <p class="mt-1 text-sm text-slate-600">Width and height in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a spacing</h3>
        <p class="mt-1 text-sm text-slate-600">On-center distance between battens.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Order materials</h3>
        <p class="mt-1 text-sm text-slate-600">Battens, linear feet, and backing sheets.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Batten count</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= ceil(width(in) &divide; spacing) + 1</span>. A 12 ft (144 in) wall at 16 in spacing: ceil(144 ÷ 16) + 1 = 9 + 1 = <strong>10 battens</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Linear feet</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= battens &times; height</span> = 10 × 8 = <strong>80 linear ft</strong> of batten stock.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Backing sheets</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= wall area &divide; 32 ft&sup2;</span> (one 4×8 sheet), rounded up.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 16 ft × 9 ft accent wall, battens at 12 in on-center.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Width in inches:</span> <span class="text-slate-600">16 × 12 = 192 in</span></div>
        <div><span class="font-medium text-slate-700">Battens:</span> <span class="text-slate-600">ceil(192 ÷ 12) + 1 = <strong>17</strong></span></div>
        <div><span class="font-medium text-slate-700">Linear feet:</span> <span class="text-slate-600">17 × 9 = 153 ft</span></div>
        <div><span class="font-medium text-slate-700">Backing sheets:</span> <span class="text-slate-600">144 ÷ 32 = 4.5 → 5 sheets</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the board and batten calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Exterior siding</h3>
        <p class="mt-1 text-sm text-slate-600">Board and batten siding is a classic farmhouse and cottage look. Use weather-rated lumber, fiber cement, or engineered wood panels, and budget for house-wrap and flashing details around windows and doors in addition to the boards and battens themselves.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🛋️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Interior accent walls</h3>
        <p class="mt-1 text-sm text-slate-600">Living rooms, bedrooms, and hallways often get a single board-and-batten accent wall. MDF battens with a painted finish are the most common and budget-friendly interior choice, and the calculator's linear footage total converts directly to a cut list.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚿</span>
        <h3 class="mt-2 font-semibold text-slate-900">Wainscoting and half-walls</h3>
        <p class="mt-1 text-sm text-slate-600">Bathrooms, dining rooms, and entryways frequently use board and batten as wainscoting up to chair-rail height (roughly 32-36 inches) rather than full wall height. Enter that shorter height to get an accurate linear footage and sheet count for a half-wall installation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏢</span>
        <h3 class="mt-2 font-semibold text-slate-900">Commercial and rental upgrades</h3>
        <p class="mt-1 text-sm text-slate-600">Property managers use board and batten to modernize rental units and small commercial spaces at a lower cost than shiplap or full paneling. The calculator's sheet count helps compare bulk material costs across multiple units.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A garage-front accent wall is a common weekend project. At 10 ft wide and 8 ft tall with battens spaced 16 inches on center, the width converts to 120 inches, and ceil(120 ÷ 16) + 1 = 8 + 1 = 9 battens. At 8 ft tall each, that is 72 linear feet of batten stock over an 80 sq ft wall, needing 3 sheets of 4×8 backing — a project size that fits comfortably in a single lumberyard run.
    </p>
    <p class="mt-3 text-slate-600">
      A larger living room feature wall pushes the numbers up. A 22 ft by 9 ft wall with a bolder, more modern 24-inch on-center spacing converts to 264 inches wide, giving ceil(264 ÷ 24) + 1 = 11 + 1 = 12 battens, or 108 linear feet over a 198 sq ft wall requiring 7 backing sheets — nearly triple the material of the garage example despite less than double the wall area, since a wider wall crosses more spacing intervals per square foot at any given height.
    </p>
    <p class="mt-3 text-slate-600">
      A small bathroom wainscot tells the opposite story. Running board and batten only to a 4 ft chair-rail height on a 6 ft wide wall with tight 12-inch spacing gives ceil(72 ÷ 12) + 1 = 6 + 1 = 7 battens, but only 28 linear feet and a single backing sheet, since the short height keeps total material low even with dense spacing — a reminder that spacing drives batten count while height drives linear footage.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Battens have to be evenly spaced across the whole wall with no adjustment." <strong class="text-slate-900">Not in practice.</strong> Most installers set a target on-center spacing but nudge the final gap at each end of the wall so it comes out even, rather than leaving an oddly narrow sliver of a bay next to a corner or window trim. The calculator gives you the target count; final layout still takes a tape measure and a little judgment.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Board and batten is purely decorative, so any board thickness works." <strong class="text-slate-900">Only true indoors.</strong> Interior wainscoting can use thin MDF strips since it carries no structural or weather-sealing role. Exterior board and batten siding, however, is a weather barrier over the house wrap, so board and batten thickness, fastening, and flashing details need to meet code requirements for exterior wall coverings, not just aesthetic preference.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/vinyl-siding-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Vinyl Siding Calculator</a>
      <a href="/tools/framing-stud-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Framing Stud Calculator</a>
      <a href="/tools/drywall-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Drywall Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const W = parseFloat(el('width').value);
      const H = parseFloat(el('height').value);
      const spacing = parseFloat(el('spacing').value);
      if (!(W > 0 && H > 0 && spacing > 0)) { el('results').classList.add('hidden'); return; }
      const widthIn = W * 12;
      const battens = Math.ceil(widthIn / spacing) + 1;
      const linft = battens * H;
      const area = W * H;
      const sheets = Math.ceil(area / 32);

      el('r-battens').textContent = battens;
      el('r-note').textContent = spacing + ' in on-center over a ' + W + ' ft wall';
      el('r-area').textContent = area.toFixed(0) + ' ft²';
      el('r-linft').textContent = linft.toFixed(0) + ' ft';
      el('r-sheets').textContent = sheets;
      el('results').classList.remove('hidden');
    }

    ['width', 'height', 'spacing'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
