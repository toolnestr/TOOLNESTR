---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Mechanical Efficiency Calculator';
const description = 'Mechanical efficiency calculator with a live 3D machine and charts. Solve η = (output ÷ input) × 100%, from work or power, with worked examples.';
const intro = 'Find the efficiency of a machine from useful output and total input — either as work/energy or as power. A live 3D scene and charts show where the lost energy goes.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is mechanical efficiency?', a: 'Mechanical efficiency (η) is the ratio of useful output (work, energy, or power) a machine delivers to the total input it receives, expressed as a percentage: η = (output ÷ input) × 100%. No real machine reaches 100% because some input is always lost, usually to friction and heat.' },
  { q: 'How is efficiency calculated from work?', a: 'η = (W_out ÷ W_in) × 100%, where W_out is the useful work delivered (e.g. lifting a load) and W_in is the total work put in (e.g. the effort force times the distance you pushed). The difference, W_in − W_out, is wasted as heat, sound, or deformation.' },
  { q: 'How is efficiency calculated from power?', a: 'η = (P_out ÷ P_in) × 100%, the power version of the same ratio. This is common for motors and engines, where input and output are measured as rates (watts) rather than one-off amounts of work.' },
  { q: 'Why is mechanical efficiency always less than 100%?', a: 'The second law of thermodynamics guarantees some energy converts to non-useful forms — usually heat from friction — in every real machine. Only an idealised, frictionless machine could reach 100%, and even then only in principle.' },
  { q: 'How does efficiency relate to mechanical advantage?', a: 'For simple machines, η = (actual mechanical advantage ÷ ideal mechanical advantage) × 100%. Ideal mechanical advantage assumes no friction; actual mechanical advantage is measured from real force inputs and outputs, so their ratio captures the same energy loss as the work-based formula.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Mechanical Efficiency Calculator',
  description: 'Calculate the efficiency of a machine from useful output and total input, using work or power.',
  steps: [
    { name: 'Pick a mode', text: 'Choose "From work" (η = W_out/W_in) or "From power" (η = P_out/P_in).' },
    { name: 'Enter two values', text: 'Type any two of the three quantities in the chosen mode.' },
    { name: 'Read the result', text: 'Efficiency solves instantly, and the 3D machine scene shows the energy split.' },
  ],
};

const formulas = [
  { expr: 'η = (W<sub>out</sub> / W<sub>in</sub>) × 100%', note: 'from useful vs total work' },
  { expr: 'η = (P<sub>out</sub> / P<sub>in</sub>) × 100%', note: 'from useful vs total power' },
  { expr: 'η = (AMA / IMA) × 100%', note: 'actual vs ideal mechanical advantage' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — pulley system', tone: 'slate',
    given: 'You do 500 J of work pulling a rope to lift a load, and the load gains 400 J of gravitational potential energy. Find the efficiency.',
    rows: [
      { label: 'Useful output:', value: 'W_out = 400 J' },
      { label: 'Total input:', value: 'W_in = 500 J' },
      { label: 'Efficiency:', value: 'η = (400 ÷ 500) × 100% = 80%', full: true },
    ],
  },
  {
    title: 'Worked example 2 — electric motor', tone: 'amber',
    given: 'A motor draws 250 W of electrical power and delivers 210 W of mechanical power at its shaft. Find the efficiency and the power lost as heat.',
    rows: [
      { label: 'Efficiency:', value: 'η = (210 ÷ 250) × 100% = 84%' },
      { label: 'Power lost:', value: '250 − 210 = 40 W (as heat/friction)' },
    ],
    note: 'The 40 W difference does not vanish — it converts to heat in the windings and bearings.',
  },
];

const comparison = {
  heading: 'Typical efficiency of common machines',
  note: 'Real machines lose energy to friction, air resistance, and heat — the more moving parts, the more loss.',
  headers: [{ label: 'Machine' }, { label: 'Typical η' }, { label: 'Main energy loss' }],
  rows: [
    ['Electric motor', '85–95%', 'Winding resistance, bearing friction'],
    ['Bicycle drivetrain', '95–98%', 'Chain friction'],
    ['Pulley system (with friction)', '70–90%', 'Rope/pulley friction'],
    ['Internal combustion engine', '20–35%', 'Heat, exhaust, friction'],
    ['Incandescent light bulb', '~5%', 'Heat (only ~5% becomes light)'],
  ],
  highlightIndex: 0,
  footnote: 'η = (useful output ÷ total input) × 100%. No real machine reaches 100% because some input always converts to heat.',
};

const realWorld = [
  { emoji: '🔧', title: 'Engine and motor design', body: 'Engineers compare engine and motor efficiency to choose the most cost-effective option per watt delivered, and to meet fuel-economy or energy-rating standards.' },
  { emoji: '🚲', title: 'Simple machines', body: 'Pulleys, levers, and inclined planes are rated by efficiency to show how much of your effort actually goes into moving the load, versus fighting friction in the mechanism itself.' },
  { emoji: '💡', title: 'Energy ratings', body: 'Appliance efficiency ratings (motors, lighting, HVAC) are built on this same input/output ratio, guiding consumers and regulators toward lower energy waste.' },
];

const misconceptions = [
  { claim: '"A well-built machine can reach 100% efficiency."', truth: 'Never in practice — the second law of thermodynamics guarantees some energy converts to heat via friction or resistance in every real mechanism. Only an idealised, frictionless machine reaches 100%, and only on paper.' },
  { claim: '"Efficiency and mechanical advantage are the same thing."', truth: 'Mechanical advantage compares output force to input force; efficiency compares output energy/work to input energy/work. A machine can have a large mechanical advantage and still be inefficient if friction wastes a lot of the input work.' },
  { claim: '"Lost energy just disappears."', truth: 'Energy is conserved — the input that does not become useful output converts to another form, almost always heat (and sometimes sound or deformation), not nothing.' },
  { claim: '"Efficiency can be negative or over 100%."', truth: 'For a passive machine, output can never exceed input, so η is always between 0% and 100%. A figure above 100% signals a measurement error or an external energy source not accounted for.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — work, energy, and the conservation of energy. <a href="https://openstax.org/books/university-physics-volume-1/pages/7-3-conservation-of-energy" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — work, energy, and power.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — energy methods and efficiency of machines.' },
];
const sourcesNote = 'η = (useful output ÷ total input) × 100%, using matching units (work-to-work or power-to-power). Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"From work" for one-off energy transfers; "From power" for continuous machines like motors.' },
  { title: 'Enter two values', body: 'Fill any two of the three fields; the third solves live.' },
  { title: 'See the energy split', body: 'Use the sliders to watch the 3D scene show useful output vs wasted input.' },
];

const related = [
  { href: '/tools/kinetic-energy-calculator', emoji: '⚡', title: 'Kinetic Energy Calculator', desc: 'KE=½mv² — solve for any variable.' },
  { href: '/tools/potential-energy-calculator', emoji: '📈', title: 'Potential Energy Calculator', desc: 'PE=mgh — gravitational potential energy.' },
  { href: '/tools/torque-calculator', emoji: '🔩', title: 'Torque Calculator', desc: 'τ = rFsinθ — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="mechanical efficiency is the fraction of input work or power a machine actually delivers as useful output — the rest is lost, almost always to friction as heat."
  howIntro="Rearranged, the work form solves any variable: W_out = η × W_in and W_in = W_out / η. The power form works the same way with P_out and P_in. Because output can never exceed input for a passive machine, η is always between 0% and 100%."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where mechanical efficiency actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-w" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From work (η = W<sub>out</sub>/W<sub>in</sub>)</button>
      <button id="mode-p" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From power (η = P<sub>out</sub>/P<sub>in</sub>)</button>
    </div>
    <div id="w-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Efficiency (η)</span>
        <input id="eta-w" type="number" step="any" placeholder="%" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Output work (W<sub>out</sub>)</span>
        <input id="wout" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Input work (W<sub>in</sub>)</span>
        <input id="win" type="number" step="any" placeholder="J" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="p-fields" class="hidden gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Efficiency (η)</span>
        <input id="eta-p" type="number" step="any" placeholder="%" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Output power (P<sub>out</sub>)</span>
        <input id="pout" type="number" step="any" placeholder="W" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Input power (P<sub>in</sub>)</span>
        <input id="pin" type="number" step="any" placeholder="W" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Efficiency</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Output</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Input</div><div id="r-3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="me-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-split" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Input energy splits into two paths</h3>
          <p class="mt-1 text-sm text-slate-600">All input energy (left box) goes somewhere: most becomes <span class="font-semibold text-emerald-600">useful output</span> (larger box), the rest is <span class="font-semibold text-red-500">wasted as heat</span> (smaller box) — at 80% efficiency, an 80/20 split.</p>
        </div>
        <div>
          <div id="diag-machine-bars" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Efficiency across machine types</h3>
          <p class="mt-1 text-sm text-slate-600">Bar heights compare typical efficiency for an electric motor (~90%), a pulley system (~80%) and a combustion engine (~35%) — more moving parts and heat losses mean lower efficiency.</p>
        </div>
      </div>
      <p id="machine3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D diagrams unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Efficiency graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Output work vs input work (fixed efficiency) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-wio"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Input energy split at the current efficiency</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-split"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'w';
      function switchMode(m) {
        mode = m;
        el('mode-w').className = m === 'w' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-p').className = m === 'p' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('w-fields').className = m === 'w' ? 'grid gap-4 sm:grid-cols-3' : 'hidden gap-4 sm:grid-cols-3';
        el('p-fields').className = m === 'p' ? 'grid gap-4 sm:grid-cols-3' : 'hidden gap-4 sm:grid-cols-3';
        el('lab-1').textContent = 'Efficiency';
        el('lab-2').textContent = m === 'w' ? 'Output work' : 'Output power';
        el('lab-3').textContent = m === 'w' ? 'Input work' : 'Input power';
        update();
      }
      function solve(etaId, outId, inId, outUnit, inUnit) {
        el('me-err').textContent = '';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        const eta = parseFloat(el(etaId).value), out = parseFloat(el(outId).value), inp = parseFloat(el(inId).value);
        const filled = [!isNaN(eta), !isNaN(out), !isNaN(inp)];
        if (filled.filter(Boolean).length < 2) return;
        let rEta = NaN, rOut = NaN, rIn = NaN;
        if (filled[1] && filled[2]) {
          if (inp === 0) { el('me-err').textContent = 'Input cannot be zero.'; return; }
          if (out > inp) { el('me-err').textContent = 'Output cannot exceed input for a passive machine.'; return; }
          rEta = (out / inp) * 100; rOut = out; rIn = inp;
        } else if (filled[0] && filled[2]) {
          if (eta < 0 || eta > 100) { el('me-err').textContent = 'Efficiency must be between 0% and 100%.'; return; }
          rOut = (eta / 100) * inp; rEta = eta; rIn = inp;
        } else if (filled[0] && filled[1]) {
          if (eta <= 0 || eta > 100) { el('me-err').textContent = 'Efficiency must be greater than 0% and at most 100%.'; return; }
          rIn = out / (eta / 100); rEta = eta; rOut = out;
        }
        if (!isNaN(rEta)) el('r-1').textContent = fmt(rEta) + '%';
        if (!isNaN(rOut)) el('r-2').textContent = fmt(rOut) + ' ' + outUnit;
        if (!isNaN(rIn)) el('r-3').textContent = fmt(rIn) + ' ' + inUnit;
      }
      function update() {
        if (mode === 'w') solve('eta-w', 'wout', 'win', 'J', 'J');
        else solve('eta-p', 'pout', 'pin', 'W', 'W');
      }
      el('mode-w').addEventListener('click', () => switchMode('w'));
      el('mode-p').addEventListener('click', () => switchMode('p'));
      ['eta-w', 'wout', 'win', 'eta-p', 'pout', 'pin'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      const DEMO = { inp: 100, eta: 80, out: 80, loss: 20 };

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.wio = new Chart(el('chart-wio'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'W_out', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Input work W_in (J)' } }, y: { title: { display: true, text: 'Output work W_out (J)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.split = new Chart(el('chart-split'), {
          type: 'bar',
          data: { labels: ['Input energy'], datasets: [
            { label: 'Useful output', data: [0], backgroundColor: '#10b981' },
            { label: 'Wasted as heat', data: [0], backgroundColor: '#ef4444' },
          ] },
          options: Object.assign({}, base, { indexAxis: 'y', scales: { x: { stacked: true, title: { display: true, text: 'Energy (J)' } }, y: { stacked: true } }, plugins: { legend: { position: 'bottom' } } }),
        });
        charts.ready = true;
        updateCharts(DEMO);
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L = [], D = [];
        for (let wi = 0; wi <= 500; wi += 25) { L.push(wi); D.push(+(wi * (s.eta / 100)).toFixed(2)); }
        charts.wio.data.labels = L; charts.wio.data.datasets[0].data = D; charts.wio.update();
        charts.split.data.datasets[0].data = [+s.out.toFixed(2)];
        charts.split.data.datasets[1].data = [+s.loss.toFixed(2)];
        charts.split.update();
      }

      // ---- standalone 3D diagrams (auto-rotating, static geometry) ----
      let diagSplit = null, diagMachineBars = null;

      function initDiagSplit() {
        const c = el('diag-split'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), SCENE_OPTS);

        const inMat = new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.4 });
        const outMat = new THREE.MeshStandardMaterial({ color: 0x10b981, roughness: 0.35 });
        const lossMat = new THREE.MeshStandardMaterial({ color: 0xef4444, roughness: 0.35 });

        const inBox = new THREE.Mesh(new THREE.BoxGeometry(1.4, 2.6, 1.4), inMat);
        inBox.position.set(-3.5, -1.3 + 1.3, 0); s.scene.add(inBox);

        const outBox = new THREE.Mesh(new THREE.BoxGeometry(1.4, 2.2, 1.4), outMat);
        outBox.position.set(1.5, -1.3 + 1.1, 0); s.scene.add(outBox);

        const lossBox = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.6, 1.4), lossMat);
        lossBox.position.set(4.5, -1.3 + 0.3, 0); s.scene.add(lossBox);

        s.scene.add(arrow(new THREE.Vector3(-2.8, 0, 0), new THREE.Vector3(0.8, 0, 0), 0x94a3b8));
        s.scene.add(arrow(new THREE.Vector3(-2.8, -0.8, 0), new THREE.Vector3(3.8, -0.9, 0), 0x94a3b8));

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagSplit = { resize: s.resize };
      }

      function initDiagMachineBars() {
        const c = el('diag-machine-bars'); if (!c) throw new Error('no container');
        const s = makeScene(c, 15, new THREE.Vector3(5, 3, 0), SCENE_OPTS);
        const grid = new THREE.GridHelper(16, 16, 0xe2e8f0, 0xeef2f7); grid.position.set(6, 0, 0); s.scene.add(grid);
        const machines = [
          { name: 'Electric motor', eta: 90, color: 0x10b981 },
          { name: 'Pulley system', eta: 80, color: 0x2563eb },
          { name: 'Combustion engine', eta: 35, color: 0xef4444 },
        ];
        machines.forEach((mA, i) => {
          const h = Math.max(0.5, (mA.eta / 100) * 8);
          const bar = new THREE.Mesh(new THREE.BoxGeometry(1.2, h, 1.2), new THREE.MeshStandardMaterial({ color: mA.color }));
          bar.position.set(i * 3, h / 2, 0);
          s.scene.add(bar);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagMachineBars = { resize: s.resize };
      }

      function boot() {
        try { switchMode('w'); } catch (e) { console.error('[mech-eff] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[mech-eff] charts failed', e); }
        if (window.THREE) {
          try { initDiagSplit(); } catch (e) { console.error('[mech-eff] diagSplit failed', e); }
          try { initDiagMachineBars(); } catch (e) { console.error('[mech-eff] diagMachineBars failed', e); }
        } else { el('machine3d-fallback').classList.remove('hidden'); }
        mountResize([diagSplit, diagMachineBars]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
