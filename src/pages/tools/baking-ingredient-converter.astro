---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Baking Ingredient Converter';
const description =
  'Free baking ingredient converter. Convert butter between sticks, cups and grams. ' +
  'Convert flour and sugar between cups and grams. Accurate baking starts here.';
const intro =
  'Select an ingredient and enter the amount you have to see its equivalent in all common forms — sticks, cups, grams and ounces for butter, flour and sugar.';
const category = { id: 'cooking', name: 'Cooking & Baking' };
const faqs = [
  { q: 'How much does one stick of butter weigh?', a: 'In the United States, one stick of butter weighs 113 g (4 oz) and measures ½ cup (8 tablespoons). Two sticks equal 1 cup (227 g / 8 oz). This is the standard US butter packaging format. European butter is often sold in 250 g blocks, which is slightly more than two sticks.' },
  { q: 'How many cups of flour are in 500 grams?', a: 'Using the standard density of 120 g per cup for all-purpose flour, 500 g ÷ 120 g/cup = 4.17 cups. Bread flour at 130 g per cup would be 500 ÷ 130 = 3.85 cups. Always check which flour type your recipe uses for accurate conversion.' },
  { q: 'Is brown sugar measured the same as white sugar?', a: 'No. Brown sugar is typically measured packed (pressed firmly into the cup), which gives a higher density of about 220 g per cup compared to 200 g per cup for granulated white sugar. Your recipe should specify "packed brown sugar" if that is the intended measure.' },
  { q: 'Can I substitute butter for margarine by weight?', a: 'Yes — butter and margarine have similar densities and can be substituted 1:1 by weight (grams) in most baking recipes. The texture and flavour will differ slightly, but the structural result will be comparable.' },
  { q: 'Why do some recipes give both cups and grams?', a: 'Thoughtful recipe developers provide both volume and weight measurements so that users with kitchen scales can achieve more consistent results while users without scales can still follow the recipe. Weight measurements eliminate the variability of scooping and packing.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Ingredient</span>
      <select id="ingredient" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="butter">Butter</option>
        <option value="flour">All-purpose flour</option>
        <option value="sugar">Granulated sugar</option>
        <option value="brown-sugar">Brown sugar (packed)</option>
      </select></label>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Amount</span>
      <input id="amount" type="number" step="any" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">From unit</span>
      <select id="fromUnit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="cups">Cups</option>
        <option value="grams">Grams</option>
        <option value="ounces">Ounces</option>
        <option value="sticks">Sticks (butter only)</option>
        <option value="tbsp">Tablespoons</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Equivalent values</div>
        <div id="r-primary" class="mt-1 text-3xl font-bold">—</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Cups</div><div id="r-cups" class="mt-1 text-lg font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Grams</div><div id="r-grams" class="mt-1 text-lg font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Ounces</div><div id="r-ounces" class="mt-1 text-lg font-bold text-slate-700">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Sticks / tbsp</div><div id="r-extra" class="mt-1 text-lg font-bold text-slate-700">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Select an ingredient, enter an amount and choose its unit to see conversions.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      Each baking ingredient has a specific density that determines how much it weighs per cup. This calculator stores those densities and uses them to convert between cups, grams, ounces, tablespoons and butter sticks. The densities are derived from the USDA National Nutrient Database and verified against common baking references from King Arthur Baking, Betty Crocker and the Joy of Cooking.
    </p>
    <p class="mt-3 text-slate-600">
      For butter, the calculator also supports the US stick format. One standard US butter stick equals 113 g (4 oz) or ½ cup. If you buy butter in blocks (common in Europe and Australia), 250 g is roughly 2.2 sticks or 1.1 cups. The calculator handles all these conversions so you can adapt any recipe to the butter format available in your country.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" role="img" aria-labelledby="bi-title bi-desc">
      <title id="bi-title">Baking ingredient converter diagram</title>
      <desc id="bi-desc">Three connected converter icons showing butter (stick), flour (bag) and sugar (bowl) with arrows pointing to their metric and imperial equivalents.</desc>
      <!-- Butter icon -->
      <rect x="40" y="20" width="200" height="80" rx="12" fill="#fef3c7" stroke="#f59e0b" stroke-width="2" />
      <rect x="60" y="30" width="80" height="25" rx="3" fill="#fbbf24" />
      <text x="100" y="47" text-anchor="middle" font-size="12" font-weight="bold" fill="#92400e">BUTTER</text>
      <text x="100" y="65" text-anchor="middle" font-size="11" fill="#92400e">1 stick</text>
      <text x="100" y="80" text-anchor="middle" font-size="11" fill="#92400e">= ½ cup</text>
      <!-- Butter arrow -->
      <line x1="240" y1="60" x2="290" y2="60" stroke="#f59e0b" stroke-width="2.5" marker-end="url(#b-arr)" />
      <defs><marker id="b-arr" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><path d="M 0 0 L 8 3 L 0 6 Z" fill="#f59e0b" /></marker></defs>
      <!-- Butter result -->
      <rect x="295" y="20" width="180" height="80" rx="12" fill="#fffbeb" stroke="#f59e0b" stroke-width="1.5" />
      <text x="385" y="47" text-anchor="middle" font-size="12" font-weight="bold" fill="#92400e">EQUIVALENTS</text>
      <text x="385" y="65" text-anchor="middle" font-size="11" fill="#92400e">113 g &nbsp;|&nbsp; 4 oz</text>
      <text x="385" y="80" text-anchor="middle" font-size="11" fill="#92400e">8 tbsp &nbsp;|&nbsp; ¼ lb</text>

      <!-- Flour icon -->
      <rect x="40" y="120" width="200" height="80" rx="12" fill="#f0fdf4" stroke="#22c55e" stroke-width="2" />
      <rect x="60" y="130" width="80" height="25" rx="3" fill="#4ade80" />
      <text x="100" y="147" text-anchor="middle" font-size="12" font-weight="bold" fill="#166534">FLOUR</text>
      <text x="100" y="165" text-anchor="middle" font-size="11" fill="#166534">1 cup (AP)</text>
      <text x="100" y="180" text-anchor="middle" font-size="11" fill="#166534">spoon & level</text>
      <!-- Flour arrow -->
      <line x1="240" y1="160" x2="290" y2="160" stroke="#22c55e" stroke-width="2.5" marker-end="url(#f-arr)" />
      <defs><marker id="f-arr" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><path d="M 0 0 L 8 3 L 0 6 Z" fill="#22c55e" /></marker></defs>
      <!-- Flour result -->
      <rect x="295" y="120" width="180" height="80" rx="12" fill="#f0fdf4" stroke="#22c55e" stroke-width="1.5" />
      <text x="385" y="147" text-anchor="middle" font-size="12" font-weight="bold" fill="#166534">EQUIVALENTS</text>
      <text x="385" y="165" text-anchor="middle" font-size="11" fill="#166534">120 g &nbsp;|&nbsp; 4.2 oz</text>
      <text x="385" y="180" text-anchor="middle" font-size="11" fill="#166534">16 tbsp</text>

      <!-- Sugar icon -->
      <rect x="40" y="220" width="200" height="80" rx="12" fill="#fdf2f8" stroke="#ec4899" stroke-width="2" />
      <rect x="60" y="230" width="80" height="25" rx="3" fill="#f472b6" />
      <text x="100" y="247" text-anchor="middle" font-size="12" font-weight="bold" fill="#9d174d">SUGAR</text>
      <text x="100" y="265" text-anchor="middle" font-size="11" fill="#9d174d">1 cup</text>
      <text x="100" y="280" text-anchor="middle" font-size="11" fill="#9d174d">granulated</text>
      <!-- Sugar arrow -->
      <line x1="240" y1="260" x2="290" y2="260" stroke="#ec4899" stroke-width="2.5" marker-end="url(#s-arr)" />
      <defs><marker id="s-arr" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto"><path d="M 0 0 L 8 3 L 0 6 Z" fill="#ec4899" /></marker></defs>
      <!-- Sugar result -->
      <rect x="295" y="220" width="180" height="80" rx="12" fill="#fdf2f8" stroke="#ec4899" stroke-width="1.5" />
      <text x="385" y="247" text-anchor="middle" font-size="12" font-weight="bold" fill="#9d174d">EQUIVALENTS</text>
      <text x="385" y="265" text-anchor="middle" font-size="11" fill="#9d174d">200 g &nbsp;|&nbsp; 7 oz</text>
      <text x="385" y="280" text-anchor="middle" font-size="11" fill="#9d174d">16 tbsp</text>

      <!-- Labels -->
      <text x="540" y="50" font-size="13" font-weight="bold" fill="#475569">Butter</text>
      <text x="540" y="70" font-size="11" fill="#64748b">1 stick = 113 g = ½ cup</text>
      <text x="540" y="150" font-size="13" font-weight="bold" fill="#475569">All-purpose flour</text>
      <text x="540" y="170" font-size="11" fill="#64748b">1 cup = 120 g = 4.2 oz</text>
      <text x="540" y="250" font-size="13" font-weight="bold" fill="#475569">Granulated sugar</text>
      <text x="540" y="270" font-size="11" fill="#64748b">1 cup = 200 g = 7 oz</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Quick reference: butter, flour and sugar conversions between cups, grams and ounces</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the conversion works</h2>
    <p class="mt-2 text-slate-600">
      Each ingredient has a fixed grams-per-cup density. The calculator converts your input to grams first, then from grams to every other unit. The key densities are: butter 227 g/cup (113 g/stick), all-purpose flour 120 g/cup, granulated sugar 200 g/cup and packed brown sugar 220 g/cup.
    </p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A recipe calls for 3 sticks of butter, but your butter is sold in 250 g blocks. How much do you need?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Input:</span> <span class="text-slate-600">3 sticks of butter</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">3 × 113 g = <strong>339 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Cups:</span> <span class="text-slate-600">339 ÷ 227 = <strong>1.49 cups</strong> (about 1½ cups)</span></div>
        <div><span class="font-medium text-slate-700">Ounces:</span> <span class="text-slate-600">339 ÷ 28.35 = <strong>12 oz</strong></span></div>
        <div><span class="font-medium text-slate-700">In 250 g blocks:</span> <span class="text-slate-600">339 ÷ 250 = <strong>1.36 blocks</strong></span></div>
        <div><span class="font-medium text-slate-700">Verification:</span> <span class="text-slate-600">1½ cups of butter = 3 sticks = 339 g = 12 oz</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🇺🇸</span>
      <h3 class="mt-2 font-semibold text-slate-900">US recipe user abroad</h3>
      <p class="mt-1 text-sm text-slate-600">American recipes often use sticks of butter and cups, which can be confusing when you are shopping in a country that sells butter in 250 g blocks and measures in grams.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧑‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Precision baker</h3>
      <p class="mt-1 text-sm text-slate-600">You prefer to weigh everything in grams for consistency but your recipes are written in cups. Convert precisely to maintain your high baking standards.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🛒</span>
      <h3 class="mt-2 font-semibold text-slate-900">Ingredient substitution researcher</h3>
      <p class="mt-1 text-sm text-slate-600">Comparing prices across butter formats (sticks vs blocks vs tubs) by converting everything to a common weight unit to find the best value.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📱</span>
      <h3 class="mt-2 font-semibold text-slate-900">Digital recipe collector</h3>
      <p class="mt-1 text-sm text-slate-600">Building a personal recipe database and standardising all your collected recipes into a single measurement system for easy reference.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Baking Ingredient Converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick your ingredient</h3>
        <p class="mt-1 text-sm text-slate-600">Choose butter, flour or sugar from the dropdown. Each ingredient has its own density value for accurate conversion.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter amount and unit</h3>
        <p class="mt-1 text-sm text-slate-600">Type the quantity and select whether it is in cups, grams, ounces, sticks or tablespoons. Results update instantly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the equivalents</h3>
        <p class="mt-1 text-sm text-slate-600">See the amount converted to cups, grams, ounces and sticks or tablespoons at a glance. Use the unit that matches your kitchen tools.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Flour should always be spooned and levelled</h3>
        <p class="mt-1 text-sm text-slate-600">Scooping flour directly from the bag with your measuring cup can add 20–30% more flour than intended. Always spoon flour into the cup and level it off with a straight edge.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Butter wrappers have measurement marks</h3>
        <p class="mt-1 text-sm text-slate-600">US butter sticks have tablespoon markings printed on the wrapper. One stick = 8 tbsp. If you need half a stick, simply cut at the 4 tbsp line. No need to guess.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use grams for brown sugar accuracy</h3>
        <p class="mt-1 text-sm text-slate-600">Brown sugar density varies hugely depending on how firmly it is packed. Weighing in grams eliminates this variable and gives you exactly the amount the recipe developer intended.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/baking-conversion-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">⚖️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Baking Conversion Calculator</h3>
        <p class="mt-1 text-xs text-slate-500">Volume to weight for all baking ingredients</p>
      </a>
      <a href="/tools/cooking-measurement-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🥄</span>
        <h3 class="mt-2 font-semibold text-slate-900">Cooking Measurement Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Cups, tbsp, tsp, ml and fl oz conversions</p>
      </a>
      <a href="/tools/yeast-converter" class="rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-2xl">🧫</span>
        <h3 class="mt-2 font-semibold text-slate-900">Yeast Converter</h3>
        <p class="mt-1 text-xs text-slate-500">Convert between active dry, instant and fresh yeast</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    const densities = {
      'butter': { cupG: 227, stickG: 113, name: 'Butter' },
      'flour': { cupG: 120, stickG: null, name: 'All-purpose flour' },
      'sugar': { cupG: 200, stickG: null, name: 'Granulated sugar' },
      'brown-sugar': { cupG: 220, stickG: null, name: 'Brown sugar (packed)' },
    };

    function update() {
      const ing = el('ingredient').value;
      const amount = parseFloat(el('amount').value);
      const from = el('fromUnit').value;
      const d = densities[ing];

      if (!amount || amount <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }

      let grams;
      switch (from) {
        case 'cups': grams = amount * d.cupG; break;
        case 'grams': grams = amount; break;
        case 'ounces': grams = amount * 28.3495; break;
        case 'sticks': grams = d.stickG ? amount * d.stickG : amount * (d.cupG / 2); break;
        case 'tbsp': grams = amount * (d.cupG / 16); break;
        default: grams = 0;
      }

      const cups = grams / d.cupG;
      const ounces = grams / 28.3495;
      const sticks = d.stickG ? grams / d.stickG : null;
      const tbsp = grams / (d.cupG / 16);

      el('r-primary').innerHTML = grams.toLocaleString(undefined, { maximumFractionDigits: 1 }) + ' <span class="text-lg opacity-80">g</span>';
      el('r-cups').textContent = cups.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' cups';
      el('r-grams').textContent = grams.toLocaleString(undefined, { maximumFractionDigits: 1 }) + ' g';
      el('r-ounces').textContent = ounces.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' oz';
      el('r-extra').textContent = sticks !== null ? sticks.toLocaleString(undefined, { maximumFractionDigits: 2 }) + ' sticks' : tbsp.toLocaleString(undefined, { maximumFractionDigits: 1 }) + ' tbsp';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    ['ingredient', 'amount', 'fromUnit'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
