---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Day of the Week Calculator';
const description =
  'Find the day of the week for any date using Zeller\'s congruence, supporting dates from 1752 onwards for historical and future date lookups.';
const intro =
  'Find the exact day of the week for any date in history or the future using Zeller\'s congruence.';
const category = { id: 'time-date', name: 'Time & Date' };
const faqs = [
  { q: 'How far back does the calculator work?', a: 'Zeller\'s congruence works for the Gregorian calendar, which started in 1752. Dates before that use the Julian calendar and may be off by several days.' },
  { q: 'What about dates in the distant future?', a: 'The formula works for any Gregorian date. However, calendar reforms could theoretically change future reckoning.' },
  { q: 'Why do I get a different result from some other calculators?', a: 'Some tools use the Julian calendar for old dates or treat the year differently. This tool uses the standard Gregorian Zeller\'s congruence.' },
  { q: 'Is Zeller\'s congruence accurate?', a: 'Yes — it is a well-known mathematical formula that has been used for over a century. It is accurate for all Gregorian calendar dates.' },
  { q: 'What day of the week was I born on?', a: 'Enter your birth date in the calculator and it will tell you. This is one of the most common uses for this tool.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Day</span>
        <input id="day" type="number" min="1" max="31" value="15"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Month</span>
        <select id="month"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="1">January</option><option value="2">February</option><option value="3">March</option>
          <option value="4">April</option><option value="5">May</option><option value="6">June</option>
          <option value="7">July</option><option value="8" selected>August</option><option value="9">September</option>
          <option value="10">October</option><option value="11">November</option><option value="12">December</option>
        </select>
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Year</span>
        <input id="year" type="number" min="1752" value="1990"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>
    <div class="mt-6 rounded-xl bg-indigo-50 p-6 text-center">
      <div class="text-xs font-semibold uppercase tracking-wide text-indigo-500">Day of the week</div>
      <div id="r-dayname" class="mt-2 text-3xl font-bold text-indigo-700">—</div>
      <div id="r-formatted" class="mt-1 text-sm text-indigo-500">—</div>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="260" viewBox="0 0 800 260" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="cal-title cal-desc">
      <title id="cal-title">Calendar grid with highlighted day</title>
      <desc id="cal-desc">A calendar month grid showing days of the week with one day highlighted to indicate the calculator result</desc>
      <rect x="100" y="20" width="600" height="220" rx="12" fill="#fff" stroke="#e2e8f0" stroke-width="2" />
      <text x="400" y="50" text-anchor="middle" fill="#1e293b" font-size="16" font-weight="bold">August 1990</text>
      <text x="110" y="80" fill="#64748b" font-size="11" font-weight="bold" text-anchor="middle" width="80">Mon</text>
      <text x="195" y="80" fill="#64748b" font-size="11" font-weight="bold" text-anchor="middle">Tue</text>
      <text x="280" y="80" fill="#64748b" font-size="11" font-weight="bold" text-anchor="middle">Wed</text>
      <text x="365" y="80" fill="#64748b" font-size="11" font-weight="bold" text-anchor="middle">Thu</text>
      <text x="450" y="80" fill="#64748b" font-size="11" font-weight="bold" text-anchor="middle">Fri</text>
      <text x="535" y="80" fill="#64748b" font-size="11" font-weight="bold" text-anchor="middle">Sat</text>
      <text x="620" y="80" fill="#ef4444" font-size="11" font-weight="bold" text-anchor="middle">Sun</text>
      <line x1="100" y1="85" x2="700" y2="85" stroke="#e2e8f0" stroke-width="1" />
      <text x="195" y="110" text-anchor="middle" fill="#64748b" font-size="14">1</text>
      <text x="280" y="110" text-anchor="middle" fill="#64748b" font-size="14">2</text>
      <text x="365" y="110" text-anchor="middle" fill="#64748b" font-size="14">3</text>
      <text x="450" y="110" text-anchor="middle" fill="#64748b" font-size="14">4</text>
      <text x="535" y="110" text-anchor="middle" fill="#64748b" font-size="14">5</text>
      <text x="620" y="110" text-anchor="middle" fill="#ef4444" font-size="14">6</text>
      <text x="110" y="140" text-anchor="middle" fill="#64748b" font-size="14">7</text>
      <text x="195" y="140" text-anchor="middle" fill="#64748b" font-size="14">8</text>
      <text x="280" y="140" text-anchor="middle" fill="#64748b" font-size="14">9</text>
      <text x="365" y="140" text-anchor="middle" fill="#64748b" font-size="14">10</text>
      <text x="450" y="140" text-anchor="middle" fill="#64748b" font-size="14">11</text>
      <text x="535" y="140" text-anchor="middle" fill="#64748b" font-size="14">12</text>
      <text x="620" y="140" text-anchor="middle" fill="#ef4444" font-size="14">13</text>
      <text x="110" y="170" text-anchor="middle" fill="#64748b" font-size="14">14</text>
      <rect x="182" y="152" width="28" height="28" rx="6" fill="#6366f1" />
      <text x="195" y="170" text-anchor="middle" fill="#fff" font-size="14" font-weight="bold">15</text>
      <text x="280" y="170" text-anchor="middle" fill="#64748b" font-size="14">16</text>
      <text x="365" y="170" text-anchor="middle" fill="#64748b" font-size="14">17</text>
      <text x="450" y="170" text-anchor="middle" fill="#64748b" font-size="14">18</text>
      <text x="535" y="170" text-anchor="middle" fill="#64748b" font-size="14">19</text>
      <text x="620" y="170" text-anchor="middle" fill="#ef4444" font-size="14">20</text>
      <text x="110" y="200" text-anchor="middle" fill="#64748b" font-size="14">21</text>
      <text x="195" y="200" text-anchor="middle" fill="#64748b" font-size="14">22</text>
      <text x="280" y="200" text-anchor="middle" fill="#64748b" font-size="14">23</text>
      <text x="365" y="200" text-anchor="middle" fill="#64748b" font-size="14">24</text>
      <text x="450" y="200" text-anchor="middle" fill="#64748b" font-size="14">25</text>
      <text x="535" y="200" text-anchor="middle" fill="#64748b" font-size="14">26</text>
      <text x="620" y="200" text-anchor="middle" fill="#ef4444" font-size="14">27</text>
      <text x="110" y="230" text-anchor="middle" fill="#64748b" font-size="14">28</text>
      <text x="195" y="230" text-anchor="middle" fill="#64748b" font-size="14">29</text>
      <text x="280" y="230" text-anchor="middle" fill="#64748b" font-size="14">30</text>
      <text x="365" y="230" text-anchor="middle" fill="#64748b" font-size="14">31</text>
      <path d="M100 235 L700 235" stroke="#e2e8f0" stroke-width="1" />
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">August 15, 1990 was a Wednesday</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How Zeller's congruence works</h2>
    <p class="mt-2 text-slate-600">
      Zeller's congruence is an algorithm devised by German mathematician Julius Christian Zeller in 1882. It calculates the day of the week for any date in the Gregorian calendar using modular arithmetic. The formula takes the day, month, and year as inputs and produces a number from 0 to 6, where each number corresponds to a day of the week.
    </p>
    <p class="mt-3 text-slate-600">
      The algorithm treats January and February as months 13 and 14 of the previous year to account for the leap year irregularity. It then performs a series of divisions and modulo operations to account for the year cycle, century cycle, and month offsets. The formula is remarkably compact for how accurately it captures the full Gregorian calendar pattern including leap years.
    </p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-1 rounded-xl bg-white p-4 font-mono text-sm text-slate-700">
      <div>Treat Jan/Feb as months 13/14 of prior year, then:</div>
      <div>h = (q + floor(13(m+1)/5) + K + floor(K/4) + floor(J/4) − 2J) mod 7</div>
      <div>Where q = day, m = month, K = year mod 100, J = century</div>
    </div>
    <h3 class="mt-4 font-semibold text-slate-900">Worked example</h3>
    <p class="mt-1 text-sm text-slate-600"><strong>August 15, 1990</strong></p>
    <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
      <div><span class="font-medium text-slate-700">q (day):</span> <span class="text-slate-600">15</span></div>
      <div><span class="font-medium text-slate-700">m (month):</span> <span class="text-slate-600">8</span></div>
      <div><span class="font-medium text-slate-700">K (year % 100):</span> <span class="text-slate-600">90</span></div>
      <div><span class="font-medium text-slate-700">J (century):</span> <span class="text-slate-600">19</span></div>
      <div><span class="font-medium text-slate-700">h:</span> <span class="text-slate-600">(15 + floor(13×9/5) + 90 + floor(90/4) + floor(19/4) − 2×19) mod 7</span></div>
      <div><span class="font-medium text-slate-700">Result:</span> <span class="text-slate-600">h = 4 → Wednesday (Zeller: 0 = Saturday)</span></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎂</span>
      <h3 class="mt-2 font-semibold text-slate-900">Birthday Discovery</h3>
      <p class="mt-1 text-sm text-slate-600">Find out what day of the week you or someone else was born on. A fun fact for parties or genealogy research.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📅</span>
      <h3 class="mt-2 font-semibold text-slate-900">Historical Dates</h3>
      <p class="mt-1 text-sm text-slate-600">Check what day of the week historical events fell on — the signing of a treaty, a famous battle, or a significant discovery.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎉</span>
      <h3 class="mt-2 font-semibold text-slate-900">Event Planning</h3>
      <p class="mt-1 text-sm text-slate-600">When planning a wedding or event, check what day a specific date falls on in a future year before booking the venue.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📆</span>
      <h3 class="mt-2 font-semibold text-slate-900">Calendar Creation</h3>
      <p class="mt-1 text-sm text-slate-600">Generate accurate calendars for any year. Verify that important dates fall on the expected weekdays before printing.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the day of the week calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the day</h3>
        <p class="mt-1 text-sm text-slate-600">Type the day number (1–31). The calculator validates it against the selected month.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select month and year</h3>
        <p class="mt-1 text-sm text-slate-600">Pick the month and type the year. The year can be any Gregorian year from 1752 onwards.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get the result</h3>
        <p class="mt-1 text-sm text-slate-600">The calculator shows the day name and full formatted date instantly.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for date calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Remember leap years</h3>
        <p class="mt-1 text-sm text-slate-600">Years divisible by 4 are leap years, except centuries not divisible by 400. The year 2000 was a leap year; 1900 was not. Zeller's handles this automatically.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Gregorian vs Julian</h3>
        <p class="mt-1 text-sm text-slate-600">The Gregorian calendar was adopted at different times across countries. Britain and its colonies adopted it in 1752. Dates before adoption follow the Julian calendar, which is 11 days behind by that time.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">January and February adjustment</h3>
        <p class="mt-1 text-sm text-slate-600">In Zeller's congruence, January and February are counted as months 13 and 14 of the previous year. This is why the formula treats the year differently for these months.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/date-difference" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📅</span>
        <h3 class="mt-1 font-semibold text-slate-900">Date Difference Calculator</h3>
        <p class="text-sm text-slate-600">Calculate days between two dates.</p>
      </a>
      <a href="/tools/age-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">🎂</span>
        <h3 class="mt-1 font-semibold text-slate-900">Age Calculator</h3>
        <p class="text-sm text-slate-600">Find your exact age from birth date.</p>
      </a>
      <a href="/tools/week-number-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">📆</span>
        <h3 class="mt-1 font-semibold text-slate-900">Week Number Calculator</h3>
        <p class="text-sm text-slate-600">Find the ISO week number for any date.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    function zeller(day, month, year) {
      if (month < 3) { month += 12; year--; }
      const K = year % 100;
      const J = Math.floor(year / 100);
      // ((x % 7) + 7) % 7 keeps h positive (the -2J term can make JS % negative).
      const h = (((day + Math.floor(13 * (month + 1) / 5) + K + Math.floor(K / 4) + Math.floor(J / 4) - 2 * J) % 7) + 7) % 7;
      // Zeller: h=0 is SATURDAY. dayNames is [Mon..Sun], so Saturday is index 5 -> offset +5.
      // The previous +6 offset shifted EVERY result one day forward (Jan 1 2000 showed Sunday, not Saturday).
      return ((h + 5) % 7);
    }
    const dayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
    function update() {
      const d = parseInt(document.getElementById('day').value, 10) || 1;
      const m = parseInt(document.getElementById('month').value, 10);
      const y = parseInt(document.getElementById('year').value, 10) || 2000;
      const idx = zeller(d, m, y);
      const name = dayNames[idx];
      const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      document.getElementById('r-dayname').textContent = name;
      document.getElementById('r-formatted').textContent = months[m - 1] + ' ' + d + ', ' + y;
    }
    document.getElementById('day').addEventListener('input', update);
    document.getElementById('month').addEventListener('change', update);
    document.getElementById('year').addEventListener('input', update);
    update();
  </script>
</ToolLayout>
