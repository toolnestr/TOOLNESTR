---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Terminal Velocity Calculator';
const description = 'Terminal velocity calculator with a live 3D falling-object scene and charts. Solve v_t = √(2mg / (ρ·A·Cd)) for skydivers, raindrops and more, with worked examples.';
const intro = 'Enter mass, cross-sectional area, drag coefficient and fluid density — the terminal velocity solves instantly, with a live 3D scene showing the drag force catching up to weight and two charts of how v_t depends on mass and shape.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is terminal velocity?', a: 'Terminal velocity is the constant maximum speed a falling object reaches when air resistance (drag) grows large enough to exactly balance its weight. Once drag equals gravity the net force is zero, so acceleration stops and the object falls at a steady speed.' },
  { q: 'What is the formula for terminal velocity?', a: 'v_t = √(2mg / (ρ·A·Cd)), where m is mass, g is gravitational acceleration (9.81 m/s² on Earth), ρ is the fluid density (1.225 kg/m³ for sea-level air), A is the cross-sectional area facing the flow, and Cd is the dimensionless drag coefficient of the shape.' },
  { q: 'Why do a feather and a bowling ball fall at different speeds in air?', a: 'In a vacuum they would not — but in air, terminal velocity depends on mass, area and shape. A feather has huge area relative to its tiny mass, so drag balances its weight almost immediately at a low speed. A bowling ball is dense and compact, so it needs a much higher speed before drag catches up.' },
  { q: 'What is a typical human skydiving terminal velocity?', a: 'A skydiver in the standard belly-to-earth position reaches roughly 190–200 km/h (about 53–56 m/s). Falling head-down in a streamlined position sharply reduces the cross-sectional area and can push terminal velocity above 240 km/h (about 67–90 m/s or more).' },
  { q: 'Does terminal velocity depend on the height of the fall?', a: 'Not directly — it depends only on mass, shape, drag coefficient and fluid density, not on how far the object has fallen. Height only determines whether the object has had enough time and distance to actually reach that speed before landing.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Terminal Velocity Calculator',
  description: 'Calculate the terminal velocity of a falling object from its mass, cross-sectional area, drag coefficient and the fluid density it falls through.',
  steps: [
    { name: 'Enter the mass and area', text: 'Type the object’s mass in kilograms and its cross-sectional area facing the airflow in square metres.' },
    { name: 'Pick a drag coefficient', text: 'Choose a preset shape (skydiver, sphere, parachute...) or type a custom Cd.' },
    { name: 'Read the terminal velocity', text: 'v_t solves instantly, and the 3D scene and charts update to match.' },
  ],
};

const formulas = [
  { expr: 'v<sub>t</sub> = √(2mg / (ρ·A·C<sub>d</sub>))', note: 'terminal velocity from mass, area, drag coefficient &amp; fluid density' },
  { expr: 'F<sub>drag</sub> = ½·ρ·v²·A·C<sub>d</sub>', note: 'drag force at speed v — equals weight (mg) at v<sub>t</sub>' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — skydiver, belly-down', tone: 'slate',
    given: 'A 75 kg skydiver falls belly-to-earth with cross-sectional area A = 0.6 m², drag coefficient Cd = 0.7, through sea-level air (ρ = 1.225 kg/m³, g = 9.81 m/s²).',
    rows: [
      { label: 'Formula:', value: 'v<sub>t</sub> = √(2·m·g / (ρ·A·C<sub>d</sub>))' },
      { label: 'Substitute:', value: 'v<sub>t</sub> = √((2 × 75 × 9.81) / (1.225 × 0.6 × 0.7))' },
      { label: 'Result:', value: 'v<sub>t</sub> = √(1471.5 / 0.5145) = √2860.06 ≈ <strong>53.48 m/s</strong> (≈ 192.5 km/h)', full: true },
    ],
    note: 'This matches the well-known belly-down skydiving terminal velocity of roughly 190–200 km/h.',
  },
  {
    title: 'Worked example 2 — a falling raindrop', tone: 'amber',
    given: 'A spherical raindrop of radius r = 1.5 mm (water density 1000 kg/m³), drag coefficient Cd = 0.5, falling through air (ρ = 1.225 kg/m³).',
    rows: [
      { label: 'Mass:', value: 'm = (4/3)·π·r³·ρ<sub>water</sub> = (4/3)·π·(0.0015)³·1000 ≈ 1.414 × 10⁻⁵ kg' },
      { label: 'Area:', value: 'A = π·r² = π·(0.0015)² ≈ 7.07 × 10⁻⁶ m²' },
      { label: 'Terminal velocity:', value: 'v<sub>t</sub> = √(2mg / (ρ·A·C<sub>d</sub>)) ≈ <strong>8.00 m/s</strong>', full: true },
    ],
    note: 'Real raindrops of this size fall at roughly 6–9 m/s, which is why rain does not accelerate indefinitely on its way down.',
  },
];

const comparison = {
  heading: 'Terminal velocity for different falling objects',
  note: 'Same air (ρ = 1.225 kg/m³) — mass, area and shape are what set the speed.',
  headers: [{ label: 'Object' }, { label: 'Mass', sub: 'kg' }, { label: 'Area', sub: 'm²' }, { label: 'Cd' }, { label: 'v_t', sub: 'm/s' }],
  rows: [
    ['Raindrop (3 mm)', '1.4 × 10⁻⁵', '7.1 × 10⁻⁶', '0.5', '8.0'],
    ['Ping-pong ball', '0.0027', '0.00126', '0.5', '8.3'],
    ['Baseball', '0.145', '0.0043', '0.3', '42.4'],
    ['Skydiver, belly-down ★', '75', '0.6', '0.7', '53.5'],
    ['Skydiver, head-down', '75', '0.18', '0.7', '97.6'],
  ],
  highlightIndex: 3,
  footnote: '★ Reference row. v_t ∝ √(m/(A·Cd)), so a denser, more streamlined object needs a much higher speed before drag balances its weight.',
};

const realWorld = [
  { emoji: '🪂', title: 'Skydiving & parachutes', body: 'Skydivers control their fall speed by changing body position: spreading out increases A and slows the fall, tucking in reduces A and speeds it up. Opening a parachute suddenly multiplies A by 30–40×, collapsing terminal velocity from ~55 m/s to a safe landing speed of a few metres per second.' },
  { emoji: '🌧️', title: 'Raindrop size and rainfall', body: 'Because v_t depends on mass and area in different ways, larger raindrops fall faster than smaller ones — meteorologists use terminal velocity to model how rain intensity and drop-size distribution relate to radar reflectivity.' },
  { emoji: '🚗', title: 'Vehicle & equipment drop testing', body: 'Engineers computing the impact speed of a dropped tool, a cargo pallet under a drogue chute, or a re-entry capsule all start from the same drag-balance equation to size the required deceleration surface.' },
];

const misconceptions = [
  { claim: '"Terminal velocity is the same for all objects."', truth: 'False — it depends on mass, cross-sectional area, drag coefficient and the fluid’s density. A feather and a hammer have very different terminal velocities in air, even though they would fall together in a vacuum.' },
  { claim: '"Once an object reaches terminal velocity it stays exactly that speed forever."', truth: 'It stays constant only while the conditions (mass, orientation, air density) stay constant. Change body position, altitude (air gets thinner), or deploy a parachute, and the object accelerates or decelerates toward a new terminal velocity.' },
  { claim: '"A heavier object always has a higher terminal velocity."', truth: 'Not necessarily — v_t depends on the ratio m/(A·Cd), not mass alone. A heavy but very spread-out object (like a parachute canopy) can have a lower terminal velocity than a lighter, denser, more compact one.' },
  { claim: '"Terminal velocity means the object stops accelerating because gravity switches off."', truth: 'Gravity keeps acting the whole time. Acceleration reaches zero because the upward drag force has grown to exactly cancel the downward weight — it is a balance of forces, not an absence of gravity.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §14.7, Drag Force and Terminal Speed (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/14-7-drag-force-and-terminal-speed" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 6, Drag Force and Terminal Speed.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 6, Motion in Two Dimensions (resistive forces).' },
];
const sourcesNote = 'Standard sea-level air density ρ = 1.225 kg/m³ and g = 9.81 m/s² are used unless changed. Results are rounded for display.';

const howToUse = [
  { title: 'Enter mass & area', body: 'Fill in the object’s mass (kg) and the cross-sectional area (m²) it presents to the airflow.' },
  { title: 'Choose a drag coefficient', body: 'Pick a preset shape or type a custom Cd; adjust fluid density if not falling through sea-level air.' },
  { title: 'Watch it settle', body: 'Use the 3D scene and charts to see the drag force grow until it matches weight at v_t.' },
];

const related = [
  { href: '/tools/free-fall-calculator', emoji: '⬇️', title: 'Free Fall Calculator', desc: 'Time and velocity under gravity (no drag).' },
  { href: '/tools/gravitational-force-calculator', emoji: '🌍', title: 'Gravitational Force Calculator', desc: "Newton's law of gravitation between masses." },
  { href: '/tools/projectile-motion-calculator', emoji: '🎯', title: 'Projectile Motion Calculator', desc: 'Range, height and time from launch speed.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a falling object speeds up only until drag grows large enough to exactly cancel its weight — after that, it falls at a constant terminal velocity set by its mass, shape and the fluid it moves through."
  howIntro="Terminal velocity comes from setting drag force equal to weight: ½·ρ·v²·A·C<sub>d</sub> = m·g. Solving for v gives the formula above. Because v_t ∝ √m, quadrupling the mass only increases terminal velocity by 2×; because v_t ∝ 1/√(A·C<sub>d</sub>), a more streamlined or smaller-area shape falls proportionally faster."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where terminal velocity actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter mass, area and drag coefficient (or pick a preset) — terminal velocity solves instantly.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (m) <span class="text-slate-400">kg</span></span>
        <input id="mass" type="number" step="any" placeholder="e.g. 75" value="75" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Cross-sectional area (A) <span class="text-slate-400">m²</span></span>
        <input id="area" type="number" step="any" placeholder="e.g. 0.6" value="0.6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Shape preset (sets drag coefficient)</span>
      <select id="preset" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="0.7" selected>Skydiver, belly-down (Cd ≈ 0.7)</option>
        <option value="1.0">Skydiver, spread-eagle max drag (Cd ≈ 1.0)</option>
        <option value="0.4">Skydiver, head-down streamlined (Cd ≈ 0.4)</option>
        <option value="0.5">Sphere / raindrop / ball (Cd ≈ 0.5)</option>
        <option value="1.3">Open parachute canopy (Cd ≈ 1.3)</option>
        <option value="1.05">Flat plate broadside (Cd ≈ 1.05)</option>
        <option value="custom">Custom…</option>
      </select>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Drag coefficient (C<sub>d</sub>)</span>
        <input id="cd" type="number" step="any" min="0.01" value="0.7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fluid density (ρ) <span class="text-slate-400">kg/m³</span></span>
        <input id="rho" type="number" step="any" value="1.225" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span class="mt-1 block text-xs text-slate-400">Default 1.225 = sea-level air. Water ≈ 1000.</span></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Terminal velocity</div><div id="r-vt" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">In km/h</div><div id="r-kmh" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="tv-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D scene + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D falling object</h2>
      <p class="mt-1 text-sm text-slate-500">Drag the sliders for mass and drag coefficient — the arrow shows the drag force growing toward weight, and the readout shows the resulting terminal velocity. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Mass <span id="out-bm" class="font-mono text-blue-600">75.0 kg</span></span>
          <input id="b-mass" type="range" min="1" max="150" step="1" value="75" class="mt-2 w-full accent-blue-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Drag coefficient <span id="out-bcd" class="font-mono text-blue-600">0.70</span></span>
          <input id="b-cd" type="range" min="0.1" max="1.5" step="0.01" value="0.7" class="mt-2 w-full accent-blue-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-blue-50 p-3 text-center text-sm text-blue-700">Terminal velocity v<sub>t</sub> = <span id="out-bvt" class="font-mono font-bold">—</span></div>
      <div id="scene3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="scene3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Terminal velocity graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Terminal velocity vs mass (fixed A, Cd) — a square-root curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vm"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Terminal velocity vs drag coefficient (fixed m, A) — an inverse square-root curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vcd"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const G = 9.81;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      function vt(m, A, Cd, rho) { return Math.sqrt((2 * m * G) / (rho * A * Cd)); }

      // ---- calculator ----
      function update() {
        const errEl = el('tv-err'); errEl.textContent = '';
        el('r-vt').textContent = '—'; el('r-kmh').textContent = '—';
        const m = parseFloat(el('mass').value), A = parseFloat(el('area').value);
        const Cd = parseFloat(el('cd').value), rho = parseFloat(el('rho').value);
        if (isNaN(m) || isNaN(A) || isNaN(Cd) || isNaN(rho)) return;
        if (m <= 0 || A <= 0 || Cd <= 0 || rho <= 0) { errEl.textContent = 'Mass, area, drag coefficient and density must all be positive.'; return; }
        const v = vt(m, A, Cd, rho);
        el('r-vt').textContent = fmt(v) + ' m/s';
        el('r-kmh').textContent = fmt(v * 3.6) + ' km/h';
      }
      el('preset').addEventListener('change', () => {
        const val = el('preset').value;
        if (val !== 'custom') el('cd').value = val;
        update();
      });
      ['mass', 'area', 'cd', 'rho'].forEach((id) => el(id).addEventListener('input', () => {
        if (id === 'cd') el('preset').value = 'custom';
        update();
      }));

      // ---- 3D + charts ----
      const charts = {};
      let scene3d = null;
      const RHO_AIR = 1.225, FIXED_A = 0.6;
      function bState() {
        const m = parseFloat(el('b-mass').value), Cd = parseFloat(el('b-cd').value);
        return { m, Cd, A: FIXED_A, rho: RHO_AIR, v: vt(m, FIXED_A, Cd, RHO_AIR) };
      }
      function onB() {
        const s = bState();
        el('out-bm').textContent = s.m.toFixed(1) + ' kg';
        el('out-bcd').textContent = s.Cd.toFixed(2);
        el('out-bvt').textContent = fmt(s.v) + ' m/s';
        try { if (scene3d) scene3d.update(s); } catch (e) {}
      }
      el('b-mass').addEventListener('input', onB);
      el('b-cd').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const massLabels = [], massData = [];
        for (let m = 5; m <= 150; m += 5) { massLabels.push(m + ''); massData.push(+vt(m, FIXED_A, 0.7, RHO_AIR).toFixed(2)); }
        charts.vm = new Chart(el('chart-vm'), {
          type: 'line',
          data: { labels: massLabels, datasets: [{ label: 'v_t', data: massData, borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Mass (kg)' } }, y: { title: { display: true, text: 'Terminal velocity (m/s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        const cdLabels = [], cdData = [];
        for (let c = 0.1; c <= 1.5; c += 0.05) { cdLabels.push(c.toFixed(2)); cdData.push(+vt(75, FIXED_A, c, RHO_AIR).toFixed(2)); }
        charts.vcd = new Chart(el('chart-vcd'), {
          type: 'line',
          data: { labels: cdLabels, datasets: [{ label: 'v_t', data: cdData, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Drag coefficient (Cd)' } }, y: { title: { display: true, text: 'Terminal velocity (m/s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- interactive 3D scene ----
      function initScene3d() {
        const c = el('scene3d'); if (!c) throw new Error('no container');
        const s = makeScene(c, 13, new THREE.Vector3(0, 1, 0), OPTS);
        const grid = new THREE.GridHelper(14, 14, 0xcbd5e1, 0xe2e8f0); s.scene.add(grid);
        const body = new THREE.Mesh(new THREE.SphereGeometry(0.55, 24, 24), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
        body.position.y = 3.2; s.scene.add(body);
        let dragArrow = null, weightArrow = null;
        const MAX_V = 100; // m/s reference for arrow scaling
        function update(state) {
          const scaleV = Math.min(1, state.v / MAX_V);
          const bodyScale = Math.max(0.6, Math.min(1.6, Math.cbrt(state.m / 75)));
          body.scale.setScalar(bodyScale);
          if (dragArrow) { s.scene.remove(dragArrow); dragArrow = null; }
          if (weightArrow) { s.scene.remove(weightArrow); weightArrow = null; }
          const base = new THREE.Vector3(0, 3.2, 0);
          const dragLen = 1 + scaleV * 4;
          const weightLen = 3;
          dragArrow = arrow(base, new THREE.Vector3(0, base.y + dragLen, 0), 0x2563eb);
          weightArrow = arrow(base, new THREE.Vector3(0, base.y - weightLen, 0), 0x64748b);
          s.scene.add(dragArrow); s.scene.add(weightArrow);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        scene3d = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { update(); } catch (e) { console.error('[terminal-velocity] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[terminal-velocity] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[terminal-velocity] charts failed', e); }
        if (window.THREE) {
          try { initScene3d(); } catch (e) { console.error('[terminal-velocity] scene failed', e); el('scene3d-fallback').classList.remove('hidden'); }
        } else { el('scene3d-fallback').classList.remove('hidden'); }
        mountResize([scene3d]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
