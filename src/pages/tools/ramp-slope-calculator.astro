---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'ADA Ramp Slope Calculator';
const description = 'Find the minimum ramp length, slope ratio and number of landings for a wheelchair ramp that meets the ADA 1:12 maximum slope, from the rise in height.';
const intro = 'Find the minimum ramp length and landing requirements for an ADA-compliant wheelchair ramp, from the height it needs to rise.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'What is the maximum slope for a wheelchair ramp?', a: 'The ADA Standards for Accessible Design set a maximum running slope of 1:12, meaning 1 inch of rise for every 12 inches of ramp length, for any ramp rising more than a small amount. A gentler slope is always allowed and often preferred.' },
  { q: 'How long does a wheelchair ramp need to be?', a: 'At the 1:12 maximum, a ramp needs 12 inches of length for every 1 inch of rise. A ramp climbing 24 inches needs a minimum of 24 feet of ramp length, before accounting for any landings.' },
  { q: 'Do ramps need landings?', a: 'Yes. The ADA requires a level landing at least as wide as the ramp and 60 inches long at the top and bottom of every ramp run, and after every 30 inches of rise within a single run, so long ramps break into shorter runs connected by landings.' },
  { q: 'What is the maximum rise for a single ramp run?', a: 'The ADA limits a single ramp run to a maximum rise of 30 inches before a landing is required. This calculator splits taller total rises into multiple runs at that limit and adds a landing between each.' },
];
const howTo = {
  name: 'How to calculate ADA-compliant ramp length',
  steps: [
    { name: 'Enter the rise', text: 'Enter the total height the ramp needs to climb, in inches.' },
    { name: 'Pick the slope', text: '1:12 is the ADA maximum; gentler slopes like 1:16 or 1:20 are easier to use.' },
    { name: 'Read the layout', text: 'See the minimum length, number of runs, and landings needed.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Total rise (in)</span>
        <input id="rise" type="number" step="any" placeholder="24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Ramp width (in)</span>
        <input id="width" type="number" step="any" placeholder="36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Target slope</span>
      <div class="mt-1 flex flex-wrap gap-2">
        {['1:12 (ADA max)', '1:16 (gentler)', '1:20 (no landing rules apply)'].map((s) => (
          <button data-slope={s} class="slope-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{s}</button>
        ))}
      </div>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Minimum ramp length</div>
        <div id="r-len" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Ramp runs</div><div id="r-runs" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Landings needed</div><div id="r-landings" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Slope angle</div><div id="r-angle" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rp-title rp-desc">
      <title id="rp-title">ADA ramp slope and landing diagram</title>
      <desc id="rp-desc">A ramp rising at a 1 to 12 slope with a landing, and the length formula</desc>
      <line x1="80" y1="230" x2="500" y2="230" stroke="#94a3b8" stroke-width="1.5" />
      <path d="M80 230 L380 230 L380 130 L440 130" fill="none" stroke="#6366f1" stroke-width="3" />
      <rect x="380" y="130" width="60" height="6" fill="#a5b4fc" />
      <line x1="380" y1="230" x2="380" y2="130" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="4 3" />
      <text x="390" y="185" font-size="12" fill="#475569" font-family="system-ui,sans-serif">rise</text>
      <text x="220" y="250" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">ramp run (1:12 slope)</text>
      <text x="410" y="118" text-anchor="middle" font-size="11" fill="#4f46e5" font-family="system-ui,sans-serif">landing</text>
      <rect x="540" y="90" width="220" height="150" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="560" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">ADA rules</text>
      <text x="560" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">length = rise &times; slope ratio</text>
      <text x="560" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">max rise per run: 30 in</text>
      <text x="560" y="188" font-size="12" fill="#475569" font-family="system-ui,sans-serif">landing: &ge; ramp width, 60 in long</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A ramp needs 12 inches of length for every inch of rise at the ADA maximum slope, with a landing every 30 inches of rise.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the ADA ramp slope calculator works</h2>
    <p class="mt-2 text-slate-600">
      A ramp's slope is expressed as a ratio, like 1:12, meaning 1 unit of rise for every 12 units of horizontal run. The ADA Standards for Accessible Design set 1:12 as the maximum running slope for a ramp serving an accessible route, so the minimum ramp length is simply the total rise multiplied by that ratio.
    </p>
    <p class="mt-3 text-slate-600">
      The calculator also applies the ADA's landing rule: no single ramp run may rise more than 30 inches before a level landing is required. For a total rise taller than that, it splits the climb into multiple 30-inch-or-less runs and inserts a landing between each one, since a landing lets a wheelchair user rest and change direction on a flat, no-slope surface.
    </p>
    <p class="mt-3 text-slate-600">
      Landings themselves must be at least as wide as the ramp and at least 60 inches long, per the ADA standard, at the top and bottom of every run. This tool estimates ramp length and landing count for planning; final ramp width, handrail requirements, edge protection, and landing placement should be confirmed against the full ADA standard and your local accessibility code.
    </p>
    <p class="mt-3 text-xs text-slate-400">Slope, rise, and landing figures follow the 2010 ADA Standards for Accessible Design, section 405 (Ramps).</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the rise</h3>
        <p class="mt-1 text-sm text-slate-600">The total height the ramp needs to climb, in inches.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick the slope</h3>
        <p class="mt-1 text-sm text-slate-600">1:12 is the ADA maximum; gentler slopes like 1:16 or 1:20 are easier to use.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the layout</h3>
        <p class="mt-1 text-sm text-slate-600">See the minimum length, number of runs, and landings needed.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Minimum length at 1:12</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">length = rise &times; 12</span>. A 24&Prime; rise: 24 &times; 12 = 288&Prime; = <strong>24 ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Runs and landings</p>
        <p class="mt-1 text-slate-600">
          Max 30&Prime; rise per run: ceil(24&frasl;30) = <strong>1 run</strong>, so no intermediate landing is required for this rise.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Slope angle</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">angle = atan(1&frasl;12)</span> = <strong>4.76&deg;</strong> — the maximum angle allowed on an ADA ramp.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A porch with a 42&Prime; rise, at the ADA 1:12 maximum slope.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Length:</span> <span class="text-slate-600">42 &times; 12 = 504&Prime; = 42 ft</span></div>
        <div><span class="font-medium text-slate-700">Runs:</span> <span class="text-slate-600">ceil(42&frasl;30) = <strong>2 runs</strong></span></div>
        <div><span class="font-medium text-slate-700">Landings:</span> <span class="text-slate-600">1 intermediate landing</span></div>
        <div><span class="font-medium text-slate-700">Angle:</span> <span class="text-slate-600">4.76&deg;</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Designing an accessible ramp</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📐</span>
        <h3 class="mt-2 font-semibold text-slate-900">Gentler is better where space allows</h3>
        <p class="mt-1 text-sm text-slate-600">1:12 is the maximum, not the target. A 1:16 or 1:20 slope is easier to push a wheelchair up and safer on ice or rain, if you have the extra length to spare.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🛑</span>
        <h3 class="mt-2 font-semibold text-slate-900">Plan landings early</h3>
        <p class="mt-1 text-sm text-slate-600">Landings take real floor space at the top, bottom, and any turn. Account for them in your site plan before committing to a ramp path.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🖐️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Handrails and edge protection</h3>
        <p class="mt-1 text-sm text-slate-600">Ramps rising more than a few inches typically need handrails on both sides and edge protection to keep a wheel or cane tip from sliding off — details this length estimate does not cover.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📋</span>
        <h3 class="mt-2 font-semibold text-slate-900">Confirm local code</h3>
        <p class="mt-1 text-sm text-slate-600">State and local accessibility codes sometimes add requirements beyond the federal ADA standard. Check with your building department before finalizing the design.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A single-step threshold ramp is one of the most common small jobs. A 7-inch rise over a door threshold at the ADA 1:12 maximum needs 7 &times; 12 = 84 inches, or exactly 7 feet of ramp, with no landing required since it falls well under the 30-inch single-run limit — a length that fits in most entryways without redesigning the approach.
    </p>
    <p class="mt-3 text-slate-600">
      A full-story rise tells a different story. Climbing a 60-inch porch or deck height at 1:12 needs 60 &times; 12 = 720 inches, or 60 feet of ramp, split into ceil(60&frasl;30) = 2 runs with 1 intermediate landing — enough total length that many homeowners switch to a switchback layout with a turning landing to fit the ramp on the available lot, rather than running it straight out from the house.
    </p>
    <p class="mt-3 text-slate-600">
      Choosing a gentler slope changes the math directly. An 18-inch rise at the ADA maximum 1:12 needs 18 feet of ramp, but the same rise at a gentler 1:16 slope needs 18 &times; 16 = 288 inches, or 24 feet — 6 feet longer, but noticeably easier to self-propel for a wheelchair user, which is why many accessibility consultants recommend 1:16 or 1:20 whenever the site has the extra room.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"1:12 is a good, comfortable slope to build to." <strong class="text-slate-900">It's the legal ceiling, not a design target.</strong> A ramp at exactly 1:12 is the steepest slope the ADA permits, and it can still be tiring to self-propel up, especially over long runs. Building at 1:16 or 1:20 whenever space allows makes the ramp noticeably easier and safer to use.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A short ramp does not need landings." <strong class="text-slate-900">Landings are required at the top and bottom of every ramp, regardless of length.</strong> The 30-inch rule only governs whether an intermediate landing is needed partway up a run — even a single-run ramp with no intermediate landing still needs a compliant landing at each end.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/stair-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Stair Calculator</a>
      <a href="/tools/deck-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Deck Calculator</a>
      <a href="/tools/perimeter-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Perimeter Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let slopeRatio = 12;

    function update() {
      const rise = parseFloat(el('rise').value);
      if (!rise || rise <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const lengthIn = rise * slopeRatio;
      const lengthFt = lengthIn / 12;
      const maxRisePerRun = 30;
      const runs = Math.ceil(rise / maxRisePerRun);
      const landings = Math.max(runs - 1, 0);
      const angleDeg = Math.atan(1 / slopeRatio) * (180 / Math.PI);

      el('r-len').textContent = lengthFt.toFixed(1) + ' ft';
      el('r-note').textContent = lengthIn.toFixed(0) + ' in of ramp at 1:' + slopeRatio;
      el('r-runs').textContent = runs.toLocaleString();
      el('r-landings').textContent = landings.toLocaleString() + ' intermediate';
      el('r-angle').textContent = angleDeg.toFixed(2) + '°';
      el('results').classList.remove('hidden');
    }

    const idle = 'slope-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50';
    const active = 'slope-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
    const ratios = { '1:12 (ADA max)': 12, '1:16 (gentler)': 16, '1:20 (no landing rules apply)': 20 };
    document.querySelectorAll('.slope-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.slope-btn').forEach((b) => { b.className = idle; });
        btn.className = active;
        slopeRatio = ratios[btn.dataset.slope];
        update();
      });
    });
    el('rise').addEventListener('input', update);
    document.querySelector('.slope-btn[data-slope="1:12 (ADA max)"]').click();
  </script>
</ToolLayout>
