---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Citation Generator';
const description =
  'Generate formatted citations in APA, MLA, and Chicago styles for books, ' +
  'websites, and articles. All processing happens in your browser.';
const intro =
  'Generate formatted citations in APA, MLA, and Chicago styles for books, ' +
  'websites, journal articles, and videos.';
const category = { id: 'text', name: 'Text Tools' };
const faqs = [
  {
    q: 'What citation styles are supported?',
    a: 'APA 7th edition, MLA 9th edition, and Chicago Manual of Style (author-date).',
  },
  {
    q: 'What source types are supported?',
    a: 'Books, websites, journal articles, and YouTube videos.',
  },
  {
    q: 'How accurate are the citations?',
    a: "They follow the official style guides, but always verify with your institution's requirements.",
  },
  {
    q: 'Can I export the bibliography?',
    a: 'Yes — copy citations individually or copy the full bibliography as plain text.',
  },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="space-y-5">
      <!-- Source Type -->
      <div>
        <label class="text-sm font-medium text-slate-700" for="source-type">Source Type</label>
        <select id="source-type" class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="book">Book</option>
          <option value="website">Website</option>
          <option value="article">Journal Article</option>
          <option value="video">Video</option>
        </select>
      </div>

      <!-- Citation Style -->
      <div>
        <label class="text-sm font-medium text-slate-700" for="citation-style">Citation Style</label>
        <select id="citation-style" class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="apa">APA 7th Edition</option>
          <option value="mla">MLA 9th Edition</option>
          <option value="chicago">Chicago (Author-Date)</option>
        </select>
      </div>

      <!-- Form Fields: Book -->
      <div id="fields-book" class="source-fields space-y-4">
        <div>
          <label class="text-sm font-medium text-slate-700" for="book-authors">Author(s)</label>
          <textarea id="book-authors" rows="2" placeholder="Smith, John D.&#10;Johnson, Mary L." class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></textarea>
          <p class="mt-1 text-xs text-slate-400">One author per line &mdash; Last, First Middle</p>
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="book-title">Title</label>
          <input id="book-title" type="text" placeholder="Book Title" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-sm font-medium text-slate-700" for="book-year">Year</label>
            <input id="book-year" type="number" placeholder="2024" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700" for="book-edition">Edition</label>
            <input id="book-edition" type="text" placeholder="2nd (optional)" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="book-publisher">Publisher</label>
          <input id="book-publisher" type="text" placeholder="Publisher Name" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>

      <!-- Form Fields: Website -->
      <div id="fields-website" class="source-fields hidden space-y-4">
        <div>
          <label class="text-sm font-medium text-slate-700" for="web-author">Author</label>
          <input id="web-author" type="text" placeholder="Smith, John D." class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="web-title">Page Title</label>
          <input id="web-title" type="text" placeholder="Page Title" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="web-site-name">Site Name</label>
          <input id="web-site-name" type="text" placeholder="Website Name" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="web-url">URL</label>
          <input id="web-url" type="url" placeholder="https://example.com/page" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-sm font-medium text-slate-700" for="web-date-published">Published Date</label>
            <input id="web-date-published" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700" for="web-date-accessed">Accessed Date</label>
            <input id="web-date-accessed" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
        </div>
      </div>

      <!-- Form Fields: Journal Article -->
      <div id="fields-article" class="source-fields hidden space-y-4">
        <div>
          <label class="text-sm font-medium text-slate-700" for="article-authors">Author(s)</label>
          <textarea id="article-authors" rows="2" placeholder="Smith, John D.&#10;Johnson, Mary L." class="mt-1 w-full resize-y rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></textarea>
          <p class="mt-1 text-xs text-slate-400">One author per line &mdash; Last, First Middle</p>
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="article-title">Article Title</label>
          <input id="article-title" type="text" placeholder="Article Title" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="article-journal">Journal Name</label>
          <input id="article-journal" type="text" placeholder="Journal Name" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div class="grid grid-cols-4 gap-4">
          <div>
            <label class="text-sm font-medium text-slate-700" for="article-volume">Volume</label>
            <input id="article-volume" type="text" placeholder="42" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700" for="article-issue">Issue</label>
            <input id="article-issue" type="text" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700" for="article-year">Year</label>
            <input id="article-year" type="number" placeholder="2024" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700" for="article-pages">Pages</label>
            <input id="article-pages" type="text" placeholder="12--25" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          </div>
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="article-doi">DOI</label>
          <input id="article-doi" type="text" placeholder="10.xxxx/xxxxx" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>

      <!-- Form Fields: Video -->
      <div id="fields-video" class="source-fields hidden space-y-4">
        <div>
          <label class="text-sm font-medium text-slate-700" for="video-creator">Creator</label>
          <input id="video-creator" type="text" placeholder="Smith, John D." class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="video-title">Video Title</label>
          <input id="video-title" type="text" placeholder="Video Title" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="video-platform">Platform</label>
          <input id="video-platform" type="text" placeholder="YouTube, Vimeo, etc." class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="video-url">URL</label>
          <input id="video-url" type="url" placeholder="https://youtube.com/watch?v=..." class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div>
          <label class="text-sm font-medium text-slate-700" for="video-date">Upload Date</label>
          <input id="video-date" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>

      <!-- Generate -->
      <button id="generate-btn" class="w-full rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700">Generate Citation</button>

      <!-- Error -->
      <div id="error-msg" class="hidden rounded-lg bg-red-50 px-4 py-3 text-sm font-medium text-red-700"></div>

      <!-- Citation Output -->
      <div id="output-area" class="hidden space-y-3">
        <label class="text-sm font-medium text-slate-700">Formatted Citation</label>
        <div class="flex items-stretch gap-2">
          <div id="citation-text" class="flex-1 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm leading-relaxed text-slate-800"></div>
          <button id="copy-citation-btn" class="shrink-0 rounded-xl bg-indigo-600 px-4 text-sm font-medium text-white transition hover:bg-indigo-700">Copy</button>
        </div>
        <button id="add-to-bib-btn" class="rounded-lg border border-indigo-300 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-50">Add to Bibliography</button>
      </div>

      <!-- Bibliography -->
      <div id="bib-section" class="hidden space-y-3 border-t border-slate-200 pt-4">
        <h3 class="text-base font-bold text-slate-900">Bibliography</h3>
        <ol id="bib-list" class="space-y-2"></ol>
        <div class="flex flex-wrap gap-2">
          <button id="copy-bib-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Copy Full Bibliography</button>
          <button id="clear-bib-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
        </div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" width="800" height="200" viewBox="0 0 800 200" role="img" aria-label="Citation generation flow diagram">
      <title>How citation generation works</title>
      <desc>Flow diagram showing four steps: Source Type, Form Fields, Citation Style, and Formatted Reference. Arrows connect each step in sequence.</desc>
      <defs>
        <marker id="cg-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="#94a3b8" />
        </marker>
      </defs>
      <rect width="800" height="200" fill="#f8fafc" rx="12" />
      <text x="400" y="28" text-anchor="middle" font-family="sans-serif" font-size="14" font-weight="bold" fill="#1e293b">Citation generation flow</text>
      <rect x="20" y="55" width="150" height="95" fill="#e0e7ff" rx="8" stroke="#6366f1" stroke-width="1.5" />
      <text x="95" y="82" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="bold" fill="#4338ca">Source Type</text>
      <text x="95" y="102" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#6366f1">Book / Website</text>
      <text x="95" y="117" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#6366f1">Article / Video</text>
      <text x="95" y="135" text-anchor="middle" font-family="sans-serif" font-size="9" fill="#a5b4fc">Choose what to cite</text>
      <line x1="170" y1="102" x2="220" y2="102" stroke="#94a3b8" stroke-width="2" marker-end="url(#cg-arrow)" />
      <rect x="220" y="55" width="150" height="95" fill="#fef3c7" rx="8" stroke="#f59e0b" stroke-width="1.5" />
      <text x="295" y="82" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="bold" fill="#b45309">Form Fields</text>
      <text x="295" y="102" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#d97706">Author, Title</text>
      <text x="295" y="117" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#d97706">Year, Publisher</text>
      <text x="295" y="135" text-anchor="middle" font-family="sans-serif" font-size="9" fill="#fbbf24">Fill in source details</text>
      <line x1="370" y1="102" x2="420" y2="102" stroke="#94a3b8" stroke-width="2" marker-end="url(#cg-arrow)" />
      <rect x="420" y="55" width="150" height="95" fill="#dcfce7" rx="8" stroke="#22c55e" stroke-width="1.5" />
      <text x="495" y="82" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="bold" fill="#15803d">Citation Style</text>
      <text x="495" y="102" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#16a34a">APA / MLA</text>
      <text x="495" y="117" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#16a34a">/ Chicago</text>
      <text x="495" y="135" text-anchor="middle" font-family="sans-serif" font-size="9" fill="#86efac">Select style rules</text>
      <line x1="570" y1="102" x2="620" y2="102" stroke="#94a3b8" stroke-width="2" marker-end="url(#cg-arrow)" />
      <rect x="620" y="55" width="160" height="95" fill="#f3e8ff" rx="8" stroke="#a855f7" stroke-width="1.5" />
      <text x="700" y="82" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="bold" fill="#7e22ce">Formatted Ref</text>
      <text x="700" y="102" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#9333ea">Author. (Year).</text>
      <text x="700" y="117" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#9333ea">Title. Publisher.</text>
      <text x="700" y="135" text-anchor="middle" font-family="sans-serif" font-size="9" fill="#c084fc">Copy &amp; use</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The citation generator processes source details through your chosen style's formatting rules to produce a ready-to-use reference entry.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How citation styles work</h2>
    <p class="mt-2 text-slate-600">
      Each style follows a specific set of rules for ordering and formatting source elements. <strong>APA</strong> (American Psychological Association, 7th ed.) uses an author-date system where the publication year immediately follows the author's name. Titles are written in sentence case and italicised for standalone works. <strong>MLA</strong> (Modern Language Association, 9th ed.) places the year at the end of the citation, uses title case for all titles, and abbreviates months. <strong>Chicago</strong> (author-date system) resembles APA in placing the year after the author but uses title case and differs in punctuation conventions.
    </p>
    <p class="mt-3 text-slate-600">
      The three styles differ most visibly in how they handle author formatting, date placement, and title capitalisation:
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-indigo-700">APA 7th Edition</h3>
        <p class="mt-1 text-sm text-slate-600">Author names inverted (Last, F. M.). Year in parentheses after authors. Sentence case for titles. Italic for book and journal titles. DOI preferred over URL.</p>
        <p class="mt-2 text-xs italic text-slate-400">Smith, J. D. (2024). <em>Title</em>. Publisher.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-emerald-700">MLA 9th Edition</h3>
        <p class="mt-1 text-sm text-slate-600">First author inverted (Last, First). Subsequent authors normal order. Year at end. Title case for all titles. "vol." and "no." for journal details. Medium optional.</p>
        <p class="mt-2 text-xs italic text-slate-400">Smith, John D. <em>Title</em>. Publisher, 2024.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-amber-700">Chicago (Author-Date)</h3>
        <p class="mt-1 text-sm text-slate-600">Author names inverted with "and". Year after authors. Title case for titles. Journal volume in italics without "vol." Issue in parentheses. DOI at end.</p>
        <p class="mt-2 text-xs italic text-slate-400">Smith, John D. 2024. <em>Title</em>. Publisher.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <p class="mt-2 text-slate-600">
      The same book cited in all three styles, using a single author named John D. Smith, the title "Cognitive Psychology" published by Oxford University Press in 2024:
    </p>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-xs font-bold uppercase tracking-wide text-indigo-600">APA</span>
        <p class="mt-1 text-sm text-slate-700">Smith, J. D. (2024). <em>Cognitive psychology</em>. Oxford University Press.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-xs font-bold uppercase tracking-wide text-emerald-600">MLA</span>
        <p class="mt-1 text-sm text-slate-700">Smith, John D. <em>Cognitive Psychology</em>. Oxford University Press, 2024.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <span class="text-xs font-bold uppercase tracking-wide text-amber-600">Chicago</span>
        <p class="mt-1 text-sm text-slate-700">Smith, John D. 2024. <em>Cognitive Psychology</em>. Oxford University Press.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Academic Papers</h3>
      <p class="mt-1 text-sm text-slate-600">Journal articles, dissertations, and conference papers require precise reference lists. A single formatting error can lose marks. Generate citations as you research and assemble the bibliography at the end.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔬</span>
      <h3 class="mt-2 font-semibold text-slate-900">Research Projects</h3>
      <p class="mt-1 text-sm text-slate-600">Literature reviews and meta-analyses involve dozens of sources. Keep a running bibliography to track what you have cited and avoid missing references when submitting the final manuscript.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📝</span>
      <h3 class="mt-2 font-semibold text-slate-900">Student Assignments</h3>
      <p class="mt-1 text-sm text-slate-600">Essays and reports must follow specific style guides. Generate citations as you write to ensure every quote and paraphrase has a corresponding reference entry by the deadline.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌐</span>
      <h3 class="mt-2 font-semibold text-slate-900">Web Content</h3>
      <p class="mt-1 text-sm text-slate-600">Blog posts, online articles, and social media are increasingly common in academic writing. The website source type handles the access date and URL formatting that each style requires.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate citations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Author names matter</h3>
        <p class="mt-1 text-sm text-slate-600">Always copy the author's name exactly as it appears on the source. Check for middle initials, hyphenated surnames (e.g., "Martinez-Lopez"), and institutional authors. APA requires up to 20 authors to be listed before using ellipsis and the final author, while MLA lists the first author and "et al." for sources with three or more contributors.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Always check DOI and URL validity</h3>
        <p class="mt-1 text-sm text-slate-600">A DOI (Digital Object Identifier) is the most stable link to a scholarly article. Test the DOI at doi.org before including it. For URLs, ensure the link resolves and note the access date — APA and MLA require it for web sources, and a broken URL undermines the citation's usefulness for readers.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Keep track of your sources</h3>
        <p class="mt-1 text-sm text-slate-600">Use the bibliography feature to build a running list as you research. This prevents last-minute scrambling to find a missing page number or publication year. Each entry in your bibliography should correspond to an in-text citation in your document. Cross-check before submission.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Verify against the official style guide</h3>
        <p class="mt-1 text-sm text-slate-600">Automated tools are a starting point, not a final authority. Style guides are updated, and edge cases (government reports, multivolume works, translated books) may not follow the standard template. Compare generated citations against the latest edition of the APA Manual, MLA Handbook, or Chicago Manual of Style.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this citation generator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select source type</h3>
        <p class="mt-1 text-sm text-slate-600">Choose between Book, Website, Journal Article, or Video. The form fields update to match the chosen source.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Fill in the details</h3>
        <p class="mt-1 text-sm text-slate-600">Enter author name(s), title, year, and source-specific fields. One author per line in the Last, First format.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Generate & collect</h3>
        <p class="mt-1 text-sm text-slate-600">Click generate, then add to the running bibliography. Copy individual citations or the full list when done.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 flex flex-wrap gap-3">
      <a href="/tools/text-to-slug-generator" class="rounded-lg bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-100">Text to Slug Generator</a>
      <a href="/tools/grammar-readability-checker" class="rounded-lg bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-100">Grammar &amp; Readability Checker</a>
      <a href="/tools/reading-time-calculator" class="rounded-lg bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-100">Reading Time Calculator</a>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var bibliography = [];

      var sourceType = document.getElementById('source-type');
      var citationStyle = document.getElementById('citation-style');
      var generateBtn = document.getElementById('generate-btn');
      var errorMsg = document.getElementById('error-msg');
      var outputArea = document.getElementById('output-area');
      var citationText = document.getElementById('citation-text');
      var copyCitationBtn = document.getElementById('copy-citation-btn');
      var addToBibBtn = document.getElementById('add-to-bib-btn');
      var bibSection = document.getElementById('bib-section');
      var bibList = document.getElementById('bib-list');
      var copyBibBtn = document.getElementById('copy-bib-btn');
      var clearBibBtn = document.getElementById('clear-bib-btn');

      function switchFields(type) {
        document.querySelectorAll('.source-fields').forEach(function (el) {
          el.classList.add('hidden');
        });
        var target = document.getElementById('fields-' + type);
        if (target) target.classList.remove('hidden');
      }

      sourceType.addEventListener('change', function () {
        switchFields(this.value);
        errorMsg.classList.add('hidden');
        outputArea.classList.add('hidden');
      });

      function parseAuthors(str) {
        if (!str.trim()) return [];
        return str.split(/[;\n]+/).map(function (line) {
          line = line.trim();
          if (!line) return null;
          var commaIdx = line.indexOf(',');
          if (commaIdx > -1) {
            var last = line.substring(0, commaIdx).trim();
            var rest = line.substring(commaIdx + 1).trim().split(/\s+/);
            var first = rest[0] || '';
            var middle = rest.slice(1).join(' ') || '';
            return { last: last, first: first, middle: middle };
          }
          return { last: line, first: '', middle: '' };
        }).filter(Boolean);
      }

      function getAuthorInitials(name) {
        var parts = [];
        if (name.first) parts.push(name.first.charAt(0) + '.');
        if (name.middle) {
          name.middle.split(/\s+/).forEach(function (m) {
            if (m) parts.push(m.charAt(0) + '.');
          });
        }
        return parts.join(' ');
      }

      function formatAPA(authors) {
        if (!authors.length) return '';
        return authors.map(function (a, i) {
          var name = a.last;
          var initials = getAuthorInitials(a);
          if (initials) name += ', ' + initials;
          if (i === authors.length - 2) return name + ', &';
          if (i < authors.length - 1) return name + ',';
          return name;
        }).join(' ');
      }

      function formatMLAFirst(a) {
        var name = a.last + ', ' + a.first;
        if (a.middle) name += ' ' + a.middle;
        return name;
      }

      function formatMLASubsequent(a) {
        var name = a.first;
        if (a.middle) name += ' ' + a.middle;
        name += ' ' + a.last;
        return name;
      }

      function formatMLA(authors) {
        if (!authors.length) return '';
        return authors.map(function (a, i) {
          if (i === 0) return formatMLAFirst(a);
          var name = formatMLASubsequent(a);
          if (i === authors.length - 1) return 'and ' + name;
          return name;
        }).join(', ');
      }

      function formatChicago(authors) {
        if (!authors.length) return '';
        return authors.map(function (a, i) {
          var name;
          if (i === 0) {
            name = a.last + ', ' + a.first;
            if (a.middle) name += ' ' + a.middle;
          } else {
            name = a.first;
            if (a.middle) name += ' ' + a.middle;
            name += ' ' + a.last;
          }
          if (i === authors.length - 2) return name + ' and';
          if (i < authors.length - 1) return name + ',';
          return name;
        }).join(' ');
      }

      function formatDateAPA(dateStr) {
        if (!dateStr) return '';
        var d = new Date(dateStr + 'T12:00:00');
        if (isNaN(d.getTime())) return '';
        var months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
        return months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
      }

      function formatDateMLA(dateStr) {
        if (!dateStr) return '';
        var d = new Date(dateStr + 'T12:00:00');
        if (isNaN(d.getTime())) return '';
        var months = ['Jan.', 'Feb.', 'Mar.', 'Apr.', 'May', 'June', 'July', 'Aug.', 'Sept.', 'Oct.', 'Nov.', 'Dec.'];
        return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
      }

      function formatDateChicago(dateStr) {
        if (!dateStr) return '';
        var d = new Date(dateStr + 'T12:00:00');
        if (isNaN(d.getTime())) return '';
        var months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
        return months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
      }

      function generateCitation() {
        var type = sourceType.value;
        var style = citationStyle.value;
        var html = '';
        var plain = '';

        if (type === 'book') {
          var authorsStr = document.getElementById('book-authors').value;
          var title = document.getElementById('book-title').value.trim();
          var year = document.getElementById('book-year').value.trim();
          var publisher = document.getElementById('book-publisher').value.trim();
          var edition = document.getElementById('book-edition').value.trim();

          if (!title || !year || !publisher) {
            showError('Please fill in Title, Year, and Publisher.');
            return;
          }

          var authors = parseAuthors(authorsStr);
          var editionText = edition ? ' (' + edition + ' ed.)' : '';

          if (style === 'apa') {
            var authorPart = authors.length ? formatAPA(authors) : '';
            if (!authorPart && authorsStr.trim()) authorPart = authorsStr.trim();
            if (!authorPart) authorPart = authorsStr.trim() || '[Anonymous]';
            html = authorPart + ' (' + year + '). <em>' + title + '</em>' + editionText + '. ' + publisher + '.';
            plain = authorPart + ' (' + year + '). ' + title + editionText + '. ' + publisher + '.';
          } else if (style === 'mla') {
            var authorPart = authors.length ? formatMLA(authors) : '';
            if (!authorPart && authorsStr.trim()) authorPart = authorsStr.trim();
            if (!authorPart) authorPart = authorsStr.trim() || '[Anonymous]';
            html = authorPart + '. <em>' + title + '</em>' + editionText + '. ' + publisher + ', ' + year + '.';
            plain = authorPart + '. ' + title + editionText + '. ' + publisher + ', ' + year + '.';
          } else {
            var authorPart = authors.length ? formatChicago(authors) : '';
            if (!authorPart && authorsStr.trim()) authorPart = authorsStr.trim();
            if (!authorPart) authorPart = authorsStr.trim() || '[Anonymous]';
            html = authorPart + '. ' + year + '. <em>' + title + '</em>' + editionText + '. ' + publisher + '.';
            plain = authorPart + '. ' + year + '. ' + title + editionText + '. ' + publisher + '.';
          }
        } else if (type === 'website') {
          var authorStr = document.getElementById('web-author').value.trim();
          var title = document.getElementById('web-title').value.trim();
          var siteName = document.getElementById('web-site-name').value.trim();
          var url = document.getElementById('web-url').value.trim();
          var datePub = document.getElementById('web-date-published').value;
          var dateAcc = document.getElementById('web-date-accessed').value;

          if (!title || !url) {
            showError('Please fill in Title and URL.');
            return;
          }

          var authors = parseAuthors(authorStr);

          if (style === 'apa') {
            var authorPart = authors.length ? formatAPA(authors) : '';
            if (!authorPart && authorStr) authorPart = authorStr;
            var datePart = formatDateAPA(datePub);
            if (datePart) datePart = '(' + datePart + ')';
            var accessedPart = dateAcc ? ' Retrieved ' + formatDateAPA(dateAcc) + ', from ' : ' Retrieved from ';
            html = (authorPart ? authorPart + ' ' : '') + (datePart ? datePart + '. ' : '') + '<em>' + title + '</em>. ' + (siteName ? siteName + '. ' : '') + accessedPart + url + '.';
            plain = (authorPart ? authorPart + ' ' : '') + (datePart ? datePart + '. ' : '') + title + '. ' + (siteName ? siteName + '. ' : '') + accessedPart + url + '.';
          } else if (style === 'mla') {
            var authorPart = authors.length ? formatMLA(authors) : '';
            if (!authorPart && authorStr) authorPart = authorStr;
            var datePart = formatDateMLA(datePub);
            html = (authorPart ? authorPart + '. ' : '') + '"' + title + '." <em>' + (siteName || 'Website') + '</em>' + (datePart ? ', ' + datePart : '') + ', ' + url + '.';
            plain = (authorPart ? authorPart + '. ' : '') + '"' + title + '." ' + (siteName || 'Website') + (datePart ? ', ' + datePart : '') + ', ' + url + '.';
          } else {
            var authorPart = authors.length ? formatChicago(authors) : '';
            if (!authorPart && authorStr) authorPart = authorStr;
            var datePart = formatDateChicago(datePub);
            var yearOnly = datePub ? new Date(datePub + 'T12:00:00').getFullYear() : '';
            html = (authorPart ? authorPart + '. ' : '') + (yearOnly ? yearOnly + '. ' : '') + '"' + title + '." ' + (siteName || 'Website') + (datePart ? '. ' + datePart : '') + '. ' + url + '.';
            plain = (authorPart ? authorPart + '. ' : '') + (yearOnly ? yearOnly + '. ' : '') + '"' + title + '." ' + (siteName || 'Website') + (datePart ? '. ' + datePart : '') + '. ' + url + '.';
          }
        } else if (type === 'article') {
          var authorsStr = document.getElementById('article-authors').value;
          var title = document.getElementById('article-title').value.trim();
          var journal = document.getElementById('article-journal').value.trim();
          var volume = document.getElementById('article-volume').value.trim();
          var issue = document.getElementById('article-issue').value.trim();
          var year = document.getElementById('article-year').value.trim();
          var pages = document.getElementById('article-pages').value.trim();
          var doi = document.getElementById('article-doi').value.trim();

          if (!title || !journal || !year) {
            showError('Please fill in Title, Journal, and Year.');
            return;
          }

          var authors = parseAuthors(authorsStr);

          if (style === 'apa') {
            var authorPart = authors.length ? formatAPA(authors) : '';
            if (!authorPart && authorsStr.trim()) authorPart = authorsStr.trim();
            if (!authorPart) authorPart = '[Anonymous]';
            var volIssue = volume;
            if (issue) volIssue += '(' + issue + ')';
            var pagePart = pages ? ', ' + pages : '';
            var doiPart = doi ? ' https://doi.org/' + doi : '';
            html = authorPart + ' (' + year + '). ' + title + '. <em>' + journal + '</em>, <em>' + volIssue + '</em>' + pagePart + '.' + doiPart;
            plain = authorPart + ' (' + year + '). ' + title + '. ' + journal + ', ' + volIssue + pagePart + '.' + doiPart;
          } else if (style === 'mla') {
            var authorPart = authors.length ? formatMLA(authors) : '';
            if (!authorPart && authorsStr.trim()) authorPart = authorsStr.trim();
            if (!authorPart) authorPart = '[Anonymous]';
            var volPart = volume ? 'vol. ' + volume : '';
            var issuePart = issue ? ', no. ' + issue : '';
            var pagePart = pages ? ', pp. ' + pages : '';
            var doiPart = doi ? ', doi:' + doi : '';
            html = authorPart + '. "' + title + '." <em>' + journal + '</em>' + (volPart ? ', ' + volPart : '') + issuePart + ', ' + year + pagePart + '.' + doiPart + '.';
            plain = authorPart + '. "' + title + '." ' + journal + (volPart ? ', ' + volPart : '') + issuePart + ', ' + year + pagePart + '.' + doiPart + '.';
          } else {
            var authorPart = authors.length ? formatChicago(authors) : '';
            if (!authorPart && authorsStr.trim()) authorPart = authorsStr.trim();
            if (!authorPart) authorPart = '[Anonymous]';
            var volPart = volume ? '<em>' + volume + '</em>' : '';
            var issuePart = issue ? ', no. ' + issue : '';
            var pagePart = pages ? ': ' + pages : '';
            var doiPart = doi ? '. https://doi.org/' + doi : '';
            html = authorPart + '. ' + year + '. "' + title + '." <em>' + journal + '</em> ' + volPart + issuePart + pagePart + '.' + doiPart;
            plain = authorPart + '. ' + year + '. "' + title + '." ' + journal + ' ' + volPart + issuePart + pagePart + '.' + doiPart;
          }
        } else if (type === 'video') {
          var creatorStr = document.getElementById('video-creator').value.trim();
          var title = document.getElementById('video-title').value.trim();
          var platform = document.getElementById('video-platform').value.trim();
          var url = document.getElementById('video-url').value.trim();
          var uploadDate = document.getElementById('video-date').value;

          if (!title || !url) {
            showError('Please fill in Title and URL.');
            return;
          }

          var authors = parseAuthors(creatorStr);

          if (style === 'apa') {
            var authorPart = authors.length ? formatAPA(authors) : '';
            if (!authorPart && creatorStr) authorPart = creatorStr;
            var datePart = formatDateAPA(uploadDate);
            if (datePart) datePart = '(' + datePart + ')';
            html = (authorPart ? authorPart + ' ' : '') + (datePart ? datePart + '. ' : '') + '<em>' + title + '</em> [Video]. ' + (platform || 'Video') + '. ' + url;
            plain = (authorPart ? authorPart + ' ' : '') + (datePart ? datePart + '. ' : '') + title + ' [Video]. ' + (platform || 'Video') + '. ' + url;
          } else if (style === 'mla') {
            var authorPart = authors.length ? formatMLA(authors) : '';
            if (!authorPart && creatorStr) authorPart = creatorStr;
            var datePart = formatDateMLA(uploadDate);
            html = (authorPart ? authorPart + '. ' : '') + '"' + title + '." <em>' + (platform || 'Online Video') + '</em>' + (datePart ? ', ' + datePart : '') + ', ' + url + '.';
            plain = (authorPart ? authorPart + '. ' : '') + '"' + title + '." ' + (platform || 'Online Video') + (datePart ? ', ' + datePart : '') + ', ' + url + '.';
          } else {
            var authorPart = authors.length ? formatChicago(authors) : '';
            if (!authorPart && creatorStr) authorPart = creatorStr;
            var datePart = formatDateChicago(uploadDate);
            var yearOnly = uploadDate ? new Date(uploadDate + 'T12:00:00').getFullYear() : '';
            html = (authorPart ? authorPart + '. ' : '') + (yearOnly ? yearOnly + '. ' : '') + '"' + title + '." ' + (platform || 'Online Video') + (datePart ? '. Uploaded ' + datePart : '') + '. ' + url + '.';
            plain = (authorPart ? authorPart + '. ' : '') + (yearOnly ? yearOnly + '. ' : '') + '"' + title + '." ' + (platform || 'Online Video') + (datePart ? '. Uploaded ' + datePart : '') + '. ' + url + '.';
          }
        }

        showResult(html, plain);
      }

      function showError(msg) {
        errorMsg.textContent = msg;
        errorMsg.classList.remove('hidden');
        outputArea.classList.add('hidden');
      }

      var currentPlain = '';

      function showResult(html, plain) {
        errorMsg.classList.add('hidden');
        citationText.innerHTML = html;
        currentPlain = plain;
        outputArea.classList.remove('hidden');
      }

      generateBtn.addEventListener('click', generateCitation);

      copyCitationBtn.addEventListener('click', function () {
        if (!currentPlain) return;
        navigator.clipboard.writeText(currentPlain).then(function () {
          var orig = copyCitationBtn.textContent;
          copyCitationBtn.textContent = 'Copied!';
          setTimeout(function () { copyCitationBtn.textContent = orig; }, 1500);
        }).catch(function () {});
      });

      addToBibBtn.addEventListener('click', function () {
        if (!currentPlain) return;
        bibliography.push(currentPlain);
        renderBibliography();
      });

      function renderBibliography() {
        if (!bibliography.length) {
          bibSection.classList.add('hidden');
          return;
        }
        bibSection.classList.remove('hidden');
        bibList.innerHTML = '';
        bibliography.forEach(function (entry, i) {
          var li = document.createElement('li');
          li.className = 'flex items-start gap-2 rounded-lg border border-slate-200 bg-white p-3 text-sm text-slate-700';
          var span = document.createElement('span');
          span.className = 'font-medium text-indigo-600 shrink-0';
          span.textContent = (i + 1) + '.';
          var textDiv = document.createElement('div');
          textDiv.className = 'flex-1';
          textDiv.textContent = entry;
          var rmBtn = document.createElement('button');
          rmBtn.className = 'shrink-0 rounded-md border border-slate-300 px-2 py-1 text-xs font-medium text-slate-500 transition hover:bg-red-50 hover:text-red-600';
          rmBtn.textContent = 'Remove';
          rmBtn.addEventListener('click', function () {
            bibliography.splice(i, 1);
            renderBibliography();
          });
          li.appendChild(span);
          li.appendChild(textDiv);
          li.appendChild(rmBtn);
          bibList.appendChild(li);
        });
      }

      copyBibBtn.addEventListener('click', function () {
        if (!bibliography.length) return;
        var text = bibliography.map(function (e, i) { return (i + 1) + '. ' + e; }).join('\n');
        navigator.clipboard.writeText(text).then(function () {
          var orig = copyBibBtn.textContent;
          copyBibBtn.textContent = 'Copied!';
          setTimeout(function () { copyBibBtn.textContent = orig; }, 1500);
        }).catch(function () {});
      });

      clearBibBtn.addEventListener('click', function () {
        bibliography = [];
        renderBibliography();
      });

      switchFields(sourceType.value);
    });
  </script>
</ToolLayout>
