---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Weight Loss Goal Calculator';
const description =
  'Free weight loss goal calculator. Project how long it will take to reach your target weight based on your current stats and daily calorie deficit.';
const intro =
  'Enter your current weight, target weight, age, sex, height and daily calorie deficit to see how long it will take to reach your goal.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How accurate is the time projection?', a: 'It is a mathematical projection based on the 3,500-calorie-per-pound rule. Individual results vary with metabolism, adherence, water retention and body composition changes. Treat it as a rough timeline, not a guarantee.' },
  { q: 'What deficit should I use?', a: 'A deficit of 300–500 calories per day is considered safe and sustainable, producing about 0.25–0.5 kg (0.5–1 lb) of weight loss per week. Deficits larger than 750 calories should be medically supervised.' },
  { q: 'Will weight loss be linear?', a: 'No — weight loss tends to be faster in the first week (water loss), then slow down as your body adapts. You may experience plateaus lasting days or weeks. This tool shows the mathematical average over time.' },
  { q: 'Why does my TDEE change as I lose weight?', a: 'As you get lighter, your body needs fewer calories to move and maintain itself. That is why the calculator recalculates your TDEE at each milestone — your deficit naturally shrinks as you progress.' },
  { q: 'What happens if I lose weight too fast?', a: 'Losing more than 1 kg (2 lb) per week for several weeks can lead to muscle loss, gallstones, nutrient deficiencies and metabolic slowdown. A steady pace of 0.5–1 kg per week is safer and more sustainable.' },
];
const sources = [
  { html: "<strong>NIH / National Institutes of Health</strong> and <strong>CDC</strong> reference values and formulas. <a href=\"https://www.nih.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nih.gov</a>" },
  { html: "<strong>Peer-reviewed equations</strong> (e.g. Mifflin-St Jeor, Harris-Benedict) as originally published." },
  { html: "<strong>ACOG</strong> for pregnancy, ovulation and due-date methodology. <a href=\"https://www.acog.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">acog.org</a>" },
];
const sourcesNote = "Not medical advice. Estimates only — consult a qualified healthcare professional for any personal health decision.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
        <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Age</span>
        <input id="age" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="metric" class="mt-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-2" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="m-weights" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Current weight (kg)</span>
        <input id="m-cur" type="number" step="any" placeholder="80" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Target weight (kg)</span>
        <input id="m-tgt" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Daily calorie deficit</span>
      <select id="deficit" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="300">300 cal/day (slow & sustainable)</option>
        <option value="500" selected>500 cal/day (moderate ~0.45 kg/week)</option>
        <option value="750">750 cal/day (aggressive)</option>
        <option value="1000">1,000 cal/day (aggressive ~0.9 kg/week)</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated time to goal</div>
        <div id="r-time" class="mt-1 text-3xl font-bold">—</div>
        <div class="mt-1 text-sm opacity-80">at your current deficit</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Weekly loss rate</div><div id="r-rate" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Total to lose</div><div id="r-total" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your details to see your projected timeline.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About weight loss goal planning</h2>
    <p class="mt-2 text-slate-600">
      Setting a realistic timeline is one of the most important factors in successful weight loss. Many people give up because they expect faster results than biology allows. This calculator uses the well-established 3,500-calorie rule — one pound (0.45 kg) of body fat contains roughly 3,500 calories — to project how long your journey will take at a given daily deficit. It also accounts for the fact that your <a href="/tools/bmr-calculator/" class="font-medium text-indigo-600 hover:underline">BMR</a> and <a href="/tools/tdee-calculator/" class="font-medium text-indigo-600 hover:underline">TDEE</a> decrease as you lose weight, meaning your deficit naturally narrows over time if you keep eating the same number of calories. Pair this with the <a href="/tools/calorie-calculator/" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> to set your daily intake.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical advice. Consult a professional before starting any weight loss programme.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="wlg-title wlg-desc">
      <title id="wlg-title">Weight loss projection curve</title>
      <desc id="wlg-desc">Line chart showing a declining weight trajectory from current weight to goal weight over time, with weekly milestones marked.</desc>
      <!-- Grid lines -->
      <line x1="80" y1="40" x2="80" y2="170" stroke="#e2e8f0" />
      <line x1="80" y1="170" x2="720" y2="170" stroke="#e2e8f0" />
      <!-- Declining line -->
      <polyline points="100,60 250,75 400,92 550,112 700,135" fill="none" stroke="#6366f1" stroke-width="3" />
      <!-- Start and end points -->
      <circle cx="100" cy="60" r="5" fill="#6366f1" />
      <circle cx="700" cy="135" r="5" fill="#22c55e" />
      <text x="100" y="55" text-anchor="middle" font-size="12" fill="#6366f1" font-weight="bold">Start</text>
      <text x="700" y="145" text-anchor="middle" font-size="12" fill="#16a34a" font-weight="bold">Goal</text>
      <text x="400" y="195" text-anchor="middle" font-size="11" fill="#94a3b8">Time (weeks)</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Projected weight loss trajectory from current weight to goal weight over time</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The calculator first estimates your current TDEE using the Mifflin-St Jeor BMR equation multiplied by a moderate activity factor (1.55). Your daily deficit is then applied to compute a theoretical weekly fat loss rate. The total time is calculated by dividing the total weight to lose by the weekly rate, then adjusting for the gradual reduction in TDEE as your weight drops. At each 5% milestone, the calculator recalculates your TDEE at the new weight, giving a more realistic projection than a simple linear estimate.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      The core equation is straightforward:
    </p>
    <p class="mt-3 text-slate-600">
      <strong>Weekly fat loss</strong> = daily deficit × 7 ÷ 3,500 (lb) or ÷ 7,700 (kg)<br>
      <strong>Total weeks</strong> = total weight to lose ÷ weekly loss
    </p>
    <p class="mt-3 text-slate-600">
      Because your TDEE decreases as you lose weight (roughly 10–15 fewer calories per day for every kg lost), the calculator simulates this by checking milestones and adjusting the deficit accordingly.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 30-year-old woman, 165 cm, 80 kg, wants to reach 65 kg with a 500-calorie daily deficit.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Total to lose:</span> <span class="text-slate-600">80 − 65 = <strong>15 kg</strong></span></div>
        <div><span class="font-medium text-slate-700">Weekly loss rate:</span> <span class="text-slate-600">500 × 7 ÷ 7,700 ≈ <strong>0.45 kg/week</strong></span></div>
        <div><span class="font-medium text-slate-700">Initial projection:</span> <span class="text-slate-600">15 ÷ 0.45 ≈ <strong>33 weeks</strong></span></div>
        <div><span class="font-medium text-slate-700">With TDEE adjustment:</span> <span class="text-slate-600">Approximately <strong>36–38 weeks</strong> (slightly longer as TDEE drops)</span></div>
        <div><span class="font-medium text-slate-700">Calorie intake at start:</span> <span class="text-slate-600">~1,950 − 500 = <strong>1,450 cal/day</strong></span></div>
        <div><span class="font-medium text-slate-700">Calorie intake at goal:</span> <span class="text-slate-600">~1,750 − 500 = <strong>1,250 cal/day</strong></span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎯</span>
      <h3 class="mt-2 font-semibold text-slate-900">Goal-oriented dieter</h3>
      <p class="mt-1 text-sm text-slate-600">Set a realistic end date for your weight loss journey. Knowing you need X weeks helps with motivation, planning and celebrating progress.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👰</span>
      <h3 class="mt-2 font-semibold text-slate-900">Event planner</h3>
      <p class="mt-1 text-sm text-slate-600">Planning for a wedding, reunion or holiday? See if your goal is achievable in the time available, and adjust your start date or deficit accordingly.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏃</span>
      <h3 class="mt-2 font-semibold text-slate-900">Athlete cutting weight</h3>
      <p class="mt-1 text-sm text-slate-600">Plan a weight cut for a competition or weigh-in with enough time to avoid crash dieting. A longer, slower cut preserves performance and muscle.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍⚕️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Health coach</h3>
      <p class="mt-1 text-sm text-slate-600">Show clients a realistic timeline for their weight loss goal so they understand why slow and steady wins the race and do not get discouraged.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your stats</h3>
        <p class="mt-1 text-sm text-slate-600">Provide your current weight, target weight, height, age and sex. These set your baseline TDEE and determine how much you need to lose.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose your deficit</h3>
        <p class="mt-1 text-sm text-slate-600">Select a daily deficit that fits your goal timeline and comfort. Moderate deficits (300–500 cal) are safer and more sustainable for most people.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your timeline</h3>
        <p class="mt-1 text-sm text-slate-600">See the projected number of weeks or months. Mark the estimated goal date on your calendar and use it as a guide, not a deadline.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for staying on track</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Expect plateaus</h3>
        <p class="mt-1 text-sm text-slate-600">Weight loss is not linear. You will have weeks where nothing seems to change despite perfect adherence. This is normal — water retention and metabolic adaptation cause temporary stalls.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Recalculate every 5 kg</h3>
        <p class="mt-1 text-sm text-slate-600">Your TDEE drops as you lose weight, so your deficit narrows if you keep eating the same amount. Recalculate your intake every 5 kg to keep progress steady.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Focus on the process, not the deadline</h3>
        <p class="mt-1 text-sm text-slate-600">The timeline is an estimate. If it takes a few weeks longer, that is okay. Sustainable habits matter more than hitting an arbitrary date on the calendar.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/calorie-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Calorie Calculator</a>
      <a href="/tools/calorie-deficit-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Calorie Deficit Calculator</a>
      <a href="/tools/macro-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Macro Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'block' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const age = parseFloat(el('age').value);
      // Current/target weight fields are always visible in kg regardless of
      // the metric/imperial toggle (only height has separate imperial
      // inputs) -- reading them only inside the metric branch meant the
      // tool never produced a result at all when Imperial was selected.
      const curKg = parseFloat(el('m-cur').value);
      const tgtKg = parseFloat(el('m-tgt').value);
      let cm;
      if (metric) {
        cm = parseFloat(el('m-h').value);
      } else {
        const ft = parseFloat(el('i-ft').value) || 0, inch = parseFloat(el('i-in').value) || 0;
        cm = (ft * 12 + inch) * 2.54;
      }
      if (!age || !cm || !curKg || !tgtKg || age <= 0 || cm <= 0 || curKg <= 0 || tgtKg <= 0 || tgtKg >= curKg) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const deficit = parseFloat(el('deficit').value);
      const totalKg = curKg - tgtKg;
      const weeklyKg = deficit * 7 / 7700;
      let simWeight = curKg;
      let weeks = 0;
      const bmr = (w) => 10 * w + 6.25 * cm - 5 * age + (el('sex').value === 'male' ? 5 : -161);
      while (simWeight > tgtKg && weeks < 520) {
        const currentTdee = bmr(simWeight) * 1.55;
        const effectiveDeficit = Math.min(deficit, currentTdee - 800);
        if (effectiveDeficit <= 0) break;
        const weekly = effectiveDeficit * 7 / 7700;
        simWeight -= weekly;
        weeks++;
      }
      const date = new Date();
      date.setDate(date.getDate() + weeks * 7);
      const options = { year: 'numeric', month: 'long', day: 'numeric' };
      el('r-time').textContent = `${Math.round(weeks)} weeks`;
      el('r-rate').textContent = `~${weeklyKg.toFixed(2)} kg/week`;
      el('r-total').textContent = `${totalKg.toFixed(1)} kg`;
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'age', 'm-h', 'm-cur', 'm-tgt', 'i-ft', 'i-in', 'deficit'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
