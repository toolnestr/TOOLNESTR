---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Investment Calculator';
const description =
  'Free investment calculator. Project the future value of an investment with regular monthly ' +
  'contributions and an expected annual return. Works in any currency.';
const intro =
  'See how an investment could grow with a starting amount, regular monthly contributions and an expected annual return.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'How is the future value estimated?', a: 'We compound your starting amount and each monthly contribution at your expected annual return, month by month, over the number of years you choose.' },
  { q: 'What return rate should I use?', a: 'That’s up to you. Historically, broad stock markets have averaged roughly 7% per year after inflation, but returns are never guaranteed.' },
  { q: 'Is this financial advice?', a: 'No. It’s an estimate to help you plan. Investments carry risk and can go down as well as up.' },
  { q: 'How much should I invest each month?', a: 'A common rule of thumb is to invest 10–15% of your gross income, but any amount is better than none. The calculator lets you try different monthly contributions to find a balance between comfort and ambition.' },
  { q: 'What if I increase my contributions over time?', a: 'Many investors raise their monthly contributions as their income grows. You can run a second scenario with a higher amount to see how pay raises and cost-of-living adjustments can accelerate your progress.' },
  { q: 'How does inflation affect my investment returns?', a: 'Inflation eats into your real purchasing power. If your investments return 7% but inflation is 3%, your real return is roughly 4%. Our <a href="/tools/inflation-calculator" class="font-medium text-indigo-600 hover:underline">Inflation Calculator</a> helps you see the difference.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Currency</span>
        <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option>$</option><option>€</option><option>£</option><option>₹</option><option>₨</option><option>¥</option><option>₦</option><option>A$</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Starting amount</span>
        <input id="start" type="number" step="any" placeholder="5000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Monthly contribution</span>
        <input id="monthly" type="number" step="any" placeholder="200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Expected return % / year</span>
        <input id="rate" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Years</span>
        <input id="years" type="number" step="any" placeholder="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">End balance</div><div id="r-end" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Total invested</div><div id="r-invested" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Total return</div><div id="r-return" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this investment calculator</h2>
    <p class="mt-2 text-slate-600">
      Regular investing plus time is one of the most reliable ways to build wealth. This calculator
      projects how a starting amount and steady monthly contributions could grow at an expected
      annual return, so you can see the power of consistency and set realistic goals. For a deeper look at how compounding drives growth, visit our <a href="/tools/compound-interest" class="font-medium text-indigo-600 hover:underline">Compound Interest Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚠️ Estimates only — not financial advice. Investments can go down as well as up.</p>
      <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
      <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
        <li>Enter your starting investment amount and the expected annual return rate.</li>
        <li>Set your monthly contribution — the amount you plan to add each month.</li>
        <li>Choose the number of years you intend to stay invested.</li>
        <li>View your projected end balance, total invested and total return.</li>
      </ol>

      <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
      <p class="mt-2 text-slate-600">
        This calculator is ideal when you're mapping out a retirement savings plan, setting up a college fund for a child, or building a down payment fund over several years. It is also useful for side-by-side comparisons of different investment strategies — for example, investing a lump sum now versus spreading smaller amounts over time to see which approach builds more wealth.
      </p>

      <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
        <li>Use a realistic expected return — 7% is a common historical average for the stock market before inflation, but past performance does not guarantee future results.</li>
        <li>Be consistent with your contributions; regular investing through market ups and downs (dollar-cost averaging) often outperforms trying to time the market.</li>
        <li>Run scenarios with different return rates (pessimistic, moderate, optimistic) to understand the range of possible outcomes.</li>
      </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const cur = el('cur');
    const fmt = (n) => cur.value + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    function update() {
      const start = parseFloat(el('start').value) || 0;
      const monthly = parseFloat(el('monthly').value) || 0;
      const rate = parseFloat(el('rate').value);
      const years = parseFloat(el('years').value);
      if (isNaN(rate) || isNaN(years) || years <= 0) { ['r-end', 'r-invested', 'r-return'].forEach((id) => (el(id).textContent = '—')); return; }
      const mr = rate / 100 / 12, months = years * 12;
      let fv = start * Math.pow(1 + mr, months);
      fv += mr === 0 ? monthly * months : monthly * ((Math.pow(1 + mr, months) - 1) / mr);
      const invested = start + monthly * months;
      el('r-end').textContent = fmt(fv);
      el('r-invested').textContent = fmt(invested);
      el('r-return').textContent = fmt(fv - invested);
    }
    ['cur', 'start', 'monthly', 'rate', 'years'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
