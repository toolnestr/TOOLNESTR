---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Road Base Calculator';
const description = 'Estimate the tons of crushed stone base material needed under a driveway or road from its area, compacted depth and material density.';
const intro = 'Estimate the tons of crushed stone base you need under a driveway or road, from its area, compacted depth, and material density.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much base material do I need for a driveway?', a: 'Multiply the area by the compacted base depth to get the volume, then multiply by the density of your crushed stone, typically around 100 to 120 pounds per cubic foot compacted, to get the weight in tons.' },
  { q: 'How deep should a road base be?', a: 'A typical residential driveway base runs 4 to 6 inches of compacted crushed stone; areas with soft or clay-heavy soil, or that will see heavier vehicles, often need 8 inches or more. Follow AASHTO base-course guidance and your local soil conditions for the exact depth.' },
  { q: 'Why does the density vary between materials?', a: 'Crushed stone density depends on the rock type and gradation — a well-graded crusher run compacts denser than a single-size clean stone. This calculator lets you pick a density in the typical range so the estimate matches your specific material.' },
  { q: 'Do I need to compact the base?', a: 'Yes. An uncompacted base settles unevenly under traffic, causing dips and cracking in the surface above it. Base material should be placed in lifts and mechanically compacted to the design depth before paving or pouring over it.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="length" type="number" step="any" placeholder="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="width" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Compacted depth (in)</span>
        <input id="depth" type="number" step="any" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Material</span>
        <select id="density" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="100">Clean crushed stone (~100 lb/ft³)</option>
          <option value="110" selected>Crusher run / graded base (~110 lb/ft³)</option>
          <option value="120">Dense-graded aggregate (~120 lb/ft³)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Base material needed</div>
        <div id="r-tons" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Volume</div><div id="r-vol" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic yards</div><div id="r-cy" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="260" viewBox="0 0 800 260" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rb-title rb-desc">
      <title id="rb-title">Compacted road base layer under a driveway</title>
      <desc id="rb-desc">A cross-section of compacted crushed stone base beneath the wearing surface, with the tonnage formula</desc>
      <rect x="100" y="170" width="300" height="14" fill="#94a3b8" stroke="#64748b" stroke-width="1.5" />
      <rect x="100" y="184" width="300" height="30" fill="#78716c" stroke="#57534e" stroke-width="1.5" />
      <text x="420" y="180" font-size="12" fill="#475569" font-family="system-ui,sans-serif">surface (asphalt/concrete)</text>
      <text x="420" y="204" font-size="12" fill="#475569" font-family="system-ui,sans-serif">compacted base</text>
      <rect x="480" y="90" width="290" height="120" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="500" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Base tonnage</text>
      <text x="500" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">volume = area &times; (depth&frasl;12)</text>
      <text x="500" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">tons = volume &times; density &divide; 2000</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The compacted base spreads traffic loads and drains water away from the surface above it.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the road base calculator works</h2>
    <p class="mt-2 text-slate-600">
      A base course of crushed stone sits under a driveway or road surface to spread traffic loads over a wider area of soil and to let water drain away instead of pooling under the pavement. Sizing it works the same way as any material takeoff: multiply the area by the compacted depth to get the volume, then convert that volume to weight using the material's density.
    </p>
    <p class="mt-3 text-slate-600">
      Crushed stone density depends on the rock type and how it is graded. A clean, single-size crushed stone runs lighter, around 100 pounds per cubic foot compacted, while a well-graded crusher run — a mix of stone sizes down to fines that locks together tightly — compacts denser, up to about 120 pounds per cubic foot. Picking the density that matches your material gives a more accurate tonnage.
    </p>
    <p class="mt-3 text-slate-600">
      This follows AASHTO base-course sizing logic: depth and material selection depend on the subgrade soil and expected traffic loading, following your project's geotechnical or engineering guidance. Typical residential depths run 4 to 6 inches; heavier loads or poor soil call for a deeper base. The base must be compacted in place, not just dumped loose, to reach the design depth and density this estimate assumes.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the area</h3>
        <p class="mt-1 text-sm text-slate-600">Length and width in feet, and your target compacted depth in inches.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick the material</h3>
        <p class="mt-1 text-sm text-slate-600">Match the density option to your specific crushed stone or crusher run.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Order and compact</h3>
        <p class="mt-1 text-sm text-slate-600">Place in lifts and compact to reach the depth this estimate assumes.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Volume</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= L &times; W &times; (D&frasl;12)</span>. 40 ft &times; 12 ft &times; (6&frasl;12): 480 &times; 0.5 = <strong>240 ft&sup3;</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Weight and tons</p>
        <p class="mt-1 text-slate-600">
          At 110 lb/ft&sup3;: 240 &times; 110 = 26,400 lb &divide; 2000 = <strong>13.2 tons</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Cubic yards</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= ft&sup3; &divide; 27</span> = 240 &divide; 27 = <strong>8.9 cu yd</strong>, for suppliers who sell by volume instead of weight.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A wide 60 ft &times; 16 ft gravel road base, 8 in deep, dense-graded aggregate.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Area:</span> <span class="text-slate-600">60 &times; 16 = 960 ft²</span></div>
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">960 &times; (8/12) = 640 ft³</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">640 &times; 120 = 76,800 lb</span></div>
        <div><span class="font-medium text-slate-700">Tons:</span> <span class="text-slate-600"><strong>38.4 tons</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/asphalt-driveway-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Asphalt Driveway Calculator</a>
      <a href="/tools/gravel-sand-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gravel &amp; Sand Calculator</a>
      <a href="/tools/cubic-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Cubic Yardage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      const D = parseFloat(el('depth').value);
      const density = parseFloat(el('density').value);
      if (!L || !W || !D || L <= 0 || W <= 0 || D <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const area = L * W;
      const vol = area * (D / 12);
      const lb = vol * density;
      const tons = lb / 2000;
      const cy = vol / 27;

      el('r-tons').textContent = tons.toFixed(1) + ' tons';
      el('r-note').textContent = 'at ' + D + ' in compacted depth';
      el('r-area').textContent = area.toFixed(0) + ' ft²';
      el('r-vol').textContent = vol.toFixed(1) + ' ft³';
      el('r-cy').textContent = cy.toFixed(2) + ' cu yd';
      el('results').classList.remove('hidden');
    }

    ['length', 'width', 'depth'].forEach((id) => el(id).addEventListener('input', update));
    el('density').addEventListener('change', update);
  </script>
</ToolLayout>
