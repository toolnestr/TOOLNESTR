---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Energy Pyramid / 10% Rule Calculator';
const description = "Energy pyramid calculator: solve energy available at each trophic level using the 10% rule, showing why food chains rarely exceed 4-5 levels.";
const intro = "Solve how much energy is available at each trophic level using the ecological 10% rule — only about 10% of energy transfers from one level to the next, with the rest lost as heat and unused biomass. Two 3D diagrams compare a wide producer base to a narrow top-predator level, and charts show energy dropping sharply level by level.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is the 10% rule in ecology?', a: 'The 10% rule states that on average, only about 10% of the energy available at one trophic level gets transferred to and stored as biomass in the next level up — the remaining 90% is lost, mostly as metabolic heat.' },
  { q: 'Why is so much energy lost between trophic levels?', a: "Most consumed energy is used for an organism's own metabolism, movement, and body heat (especially in warm-blooded animals), and additional energy is lost in feces and other undigested material — only a small fraction actually gets converted into new consumer biomass." },
  { q: 'Why do food chains rarely have more than 4-5 trophic levels?', a: 'Because each level only retains about 10% of the energy from the level below, the available energy shrinks by roughly tenfold at every step — by the 5th or 6th level, there simply isn\'t enough energy remaining to support a viable population.' },
  { q: 'Does the 10% rule apply exactly to every ecosystem?', a: "No — 10% is a useful average and teaching approximation, but actual transfer efficiency varies by ecosystem and organism type, typically ranging from about 5% to 20% depending on factors like an organism's metabolism and how digestible its food is." },
  { q: 'What is a trophic level?', a: 'A trophic level is a feeding position in a food chain — producers (like plants) occupy the first level, primary consumers (herbivores) the second, secondary consumers (carnivores that eat herbivores) the third, and so on up the chain.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Energy Pyramid / 10% Rule Calculator',
  description: 'Solve energy available at each trophic level using the 10% ecological transfer efficiency rule.',
  steps: [
    { name: 'Enter producer energy', text: 'The total energy available at the first (producer) trophic level.' },
    { name: 'Enter transfer efficiency and number of levels', text: 'Default 10%, adjustable for different ecosystems; choose how many trophic levels to calculate.' },
    { name: 'Read energy at each level', text: 'Energy available at every subsequent trophic level is calculated automatically.' },
  ],
};

const formulas = [
  { expr: 'Energy at level n = Producer energy × (efficiency)ⁿ⁻¹', note: 'efficiency is typically about 10% (0.10) per level transfer' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a standard four-level food chain', tone: 'slate',
    given: 'Producers (grass) contain 1,000,000 kcal of energy. Using the standard 10% transfer efficiency across 4 trophic levels.',
    rows: [
      { label: 'Level 1 (producers):', value: '1,000,000 kcal' },
      { label: 'Level 2 (primary consumers):', value: '1,000,000 × 0.10 = 100,000 kcal' },
      { label: 'Level 3 (secondary consumers):', value: '100,000 × 0.10 = 10,000 kcal' },
      { label: 'Level 4 (tertiary consumers):', value: '10,000 × 0.10 = 1,000 kcal', full: true },
    ],
    note: 'Each step up the pyramid loses 90% of the available energy — after just 3 transfers, only 0.1% of the original producer energy remains.',
  },
  {
    title: 'Worked example 2 — why a 5th trophic level is rare', tone: 'amber',
    given: 'Same 1,000,000 kcal starting energy, continuing to a hypothetical 5th trophic level.',
    rows: [
      { label: 'Level 5 energy:', value: '1,000,000 × 0.10⁴ = 100 kcal' },
      { label: 'Interpretation:', value: 'Only 0.01% of the original energy remains — far too little to support a stable population of top predators', full: true },
    ],
    note: "This is exactly why apex predators (like large sharks or eagles) typically occupy no more than the 4th or 5th trophic level — beyond that, there simply isn't enough energy left in the system.",
  },
];

const comparison = {
  heading: 'Energy remaining by trophic level',
  note: 'Starting from 1,000,000 kcal of producer energy at 10% transfer efficiency.',
  headers: [{ label: 'Trophic level' }, { label: 'Example organisms' }, { label: 'Energy available' }],
  rows: [
    ['1 — Producers', 'Grass, algae, phytoplankton', '1,000,000 kcal'],
    ['2 — Primary consumers ★', 'Grasshoppers, zooplankton, deer', '100,000 kcal'],
    ['3 — Secondary consumers', 'Frogs, small fish, foxes', '10,000 kcal'],
    ['4 — Tertiary consumers', 'Snakes, large fish, hawks', '1,000 kcal'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Each level supports roughly one-tenth the total energy (and typically far fewer individual organisms) of the level below it.',
};

const realWorld = [
  { emoji: '🌾', title: 'Agricultural land-use efficiency', body: 'The 10% rule is exactly why eating lower on the food chain (plants directly) is far more land- and energy-efficient than eating animals that were fed on plants — each additional trophic step multiplies the land and resources required.' },
  { emoji: '🌊', title: 'Fisheries and marine ecosystem management', body: 'Fisheries scientists use trophic-level energy transfer estimates to predict how much fish biomass an ecosystem can sustainably support at each feeding level.' },
  { emoji: '🦅', title: 'Apex predator conservation', body: "Understanding energy pyramid limits explains why top predators are naturally rare and require enormous supporting ecosystems — a key consideration in conservation planning for large carnivores." },
  { emoji: '🧪', title: 'Bioaccumulation and toxicology', body: 'While energy decreases dramatically up the pyramid, certain persistent toxins (like mercury) actually concentrate in the opposite direction — understanding trophic structure is essential for predicting where contamination risks are highest.' },
];

const misconceptions = [
  { claim: '"Exactly 10% of energy transfers between every trophic level, every time."', truth: '10% is a useful teaching average — real transfer efficiencies vary by ecosystem and species, typically ranging from about 5% to 20% depending on factors like metabolism type and food digestibility.' },
  { claim: '"The energy that isn\'t transferred simply disappears."', truth: "Untransferred energy isn't destroyed — most is released as metabolic heat (following the laws of thermodynamics), and some remains in unconsumed or undigested organic matter that decomposers eventually break down." },
  { claim: '"A trophic pyramid always has exactly the same shape for numbers of organisms as it does for energy."', truth: "Energy pyramids are always narrower at the top, but a pyramid of numbers (counting individual organisms) can occasionally invert — a single large tree, for instance, might support many more herbivorous insects than there are trees, even though energy still decreases up the chain." },
  { claim: '"Longer food chains are always better for an ecosystem."', truth: "There's no inherent ecological benefit to chain length — food chain length is simply constrained by the amount of usable energy remaining at each level, and most real ecosystems settle at whatever length their available energy can actually support." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 46, "Ecosystems" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/46-3-energy-flow-through-ecosystems" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Lindeman (1942)</strong> — foundational trophic-dynamic ecology paper establishing energy transfer efficiency concepts, <em>Ecology</em>.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Ecosystem energy flow chapter.' },
];
const sourcesNote = 'Energy at level n = producer energy × (efficiency)ⁿ⁻¹. 10% is the standard teaching approximation for trophic transfer efficiency. Results are rounded for display.';

const howToUse = [
  { title: 'Enter producer energy', body: 'Total energy available at the base (producer) trophic level, in any consistent unit.' },
  { title: 'Set transfer efficiency', body: 'Default 10%, adjustable to model different ecosystems (typically 5-20%).' },
  { title: 'Choose number of levels', body: 'Energy at every trophic level up to your chosen maximum calculates automatically.' },
];

const related = [
  { href: '/tools/biomass-calculator', emoji: '📦', title: 'Biomass Calculator', desc: 'Biomass across trophic levels and per unit area.' },
  { href: '/tools/population-density-calculator', emoji: '🌍', title: 'Population Density Calculator', desc: 'D = N/A — individuals per unit area.' },
  { href: '/tools/shannon-diversity-index-calculator', emoji: '🦋', title: 'Shannon Diversity Index Calculator', desc: "H' = −Σ(pᵢ ln pᵢ) — measure community biodiversity." },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="every step up a food chain throws away roughly nine-tenths of the available energy as metabolic heat, which is exactly why food chains stay short and top predators stay rare — there simply isn't enough energy left to support many more levels."
  howIntro="Energy enters an ecosystem through producers (like plants) capturing sunlight, but every time that energy moves up to the next feeding level, most of it is lost — spent on an organism's own metabolism, movement, and body heat, or left over as undigested waste. Only roughly 10% of the energy at one trophic level typically ends up stored as new biomass in the level above it, which is why multiplying by 0.10 repeatedly for each additional level shows energy shrinking by a factor of ten at every single step. This single repeated 10% loss is the entire reason food chains are naturally short and top-of-the-pyramid predators are always comparatively rare."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the energy pyramid actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Producer energy (kcal)</span>
        <input id="e0" type="number" step="any" value="1000000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Transfer efficiency (%)</span>
        <input id="eff" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of trophic levels</span>
        <input id="levels" type="number" step="1" min="2" max="8" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="pyramid-body" class="mt-6 space-y-2"></div>
    <p id="ep-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Wide base vs. narrow top</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-base" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Producer level (wide)</h3>
          <p class="mt-1 text-sm text-slate-600">Abundant energy and biomass supports a wide base of producers.</p>
        </div>
        <div>
          <div id="diag-top" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Top predator level (narrow)</h3>
          <p class="mt-1 text-sm text-slate-600">Only a tiny fraction of the original energy remains, supporting far fewer top predators.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Energy pyramid charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Energy available per trophic level</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pyramid"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Effect of transfer efficiency on level-4 energy</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-efficiency"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};
      const levelNames = ['Producers', 'Primary consumers', 'Secondary consumers', 'Tertiary consumers', 'Quaternary consumers', 'Level 6', 'Level 7', 'Level 8'];

      // ---- calculator ----
      function update() {
        el('ep-err').textContent = '';
        el('pyramid-body').innerHTML = '';
        const e0 = parseFloat(el('e0').value), effPct = parseFloat(el('eff').value), levels = parseInt(el('levels').value, 10);
        if (isNaN(e0) || isNaN(effPct) || isNaN(levels)) return;
        if (e0 <= 0 || effPct <= 0 || effPct > 100 || levels < 2) { el('ep-err').textContent = 'Producer energy must be positive; efficiency must be between 0 and 100%; at least 2 levels required.'; return; }
        const eff = effPct / 100;
        const energies = [];
        let rows = '';
        for (let i = 0; i < levels; i++) {
          const energy = e0 * Math.pow(eff, i);
          energies.push(energy);
          const widthPct = 100 * Math.pow(0.8, i);
          rows += '<div class="flex items-center gap-3"><div class="w-32 shrink-0 text-xs text-slate-500 sm:w-40">' + (levelNames[i] || 'Level ' + (i + 1)) + '</div><div class="flex-1"><div class="rounded bg-indigo-500 py-1.5 text-center text-xs font-semibold text-white" style="width:' + widthPct + '%">' + fmt(energy) + ' kcal</div></div></div>';
        }
        el('pyramid-body').innerHTML = rows;
        updateCharts(energies, eff);
      }
      ['e0', 'eff', 'levels'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.pyramid = new Chart(el('chart-pyramid'), {
          type: 'bar',
          data: { labels: levelNames.slice(0, 4), datasets: [{ label: 'Energy (kcal)', data: [1000000, 100000, 10000, 1000], backgroundColor: '#6366f1' }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Energy (kcal, log scale)' } } }, plugins: { legend: { display: false } } }),
        });
        const effLabels = [5, 10, 15, 20];
        charts.efficiency = new Chart(el('chart-efficiency'), {
          type: 'bar',
          data: { labels: effLabels.map((e) => e + '%'), datasets: [{ label: 'Level 4 energy (kcal)', data: effLabels.map((e) => 1000000 * Math.pow(e / 100, 3)), backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Energy at level 4 (kcal)' } } }, plugins: { legend: { display: false } } }),
        });
      }
      function updateCharts(energies, eff) {
        if (charts.pyramid) {
          charts.pyramid.data.labels = energies.map((_, i) => levelNames[i] || 'Level ' + (i + 1));
          charts.pyramid.data.datasets[0].data = energies;
          charts.pyramid.update('none');
        }
      }

      function trophicScene(container, count, size) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < count; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(size, 12, 10), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          const angle = (i / count) * Math.PI * 2;
          const r = 1.8;
          m.position.set(Math.cos(angle) * r, Math.sin(angle) * r * 0.5, (Math.random() - 0.5) * 1.5);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagBase = null, diagTop = null;
      function initDiagBase() { const c = el('diag-base'); if (!c) throw new Error('no container'); diagBase = trophicScene(c, 30, 0.22); }
      function initDiagTop() { const c = el('diag-top'); if (!c) throw new Error('no container'); diagTop = trophicScene(c, 2, 0.5); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[energy-pyramid] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagBase(); } catch (e) { console.error('[energy-pyramid] base diagram failed', e); }
          try { initDiagTop(); } catch (e) { console.error('[energy-pyramid] top diagram failed', e); }
        }
        mountResize([diagBase, diagTop]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
