---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Age Calculator';
const description =
  'Free age calculator. Enter your date of birth to see your exact age in years, ' +
  'months and days — plus total weeks, days, hours and a countdown to your next birthday.';
const intro =
  'Enter your date of birth (and optionally a date to calculate up to). You will get your ' +
  'exact age and a countdown to your next birthday — instantly and privately.';
const category = { id: 'everyday', name: 'Everyday' };
const faqs = [
  { q: 'How is my exact age calculated?', a: 'We compare your date of birth to today (or a date you choose) and break the difference into full years, months and days.' },
  { q: 'Can I calculate age on a past or future date?', a: 'Yes. Change the "Age at date" field to any date to see how old someone was, or will be, then.' },
  { q: 'Does it account for leap years?', a: 'Yes. The calculation uses real calendar dates, so leap years and different month lengths are handled correctly.' },
  { q: 'Is my data private?', a: 'Completely. The calculator runs in your browser — no dates are sent anywhere.' },
  { q: 'Can I calculate someone elses age?', a: 'Yes — simply enter their date of birth. The calculator works for anyone, so you can check the age of a family member or friend too.' },
  { q: 'What if I was born on a leap day (29 February)?', a: 'The calculator handles this correctly. For non-leap years, it considers 1 March as the equivalent birthday for countdown purposes.' },
  { q: 'Why does my age show months and days separately?', a: 'Years alone can be misleading — someone who is "5 years old" could be anywhere from 5.0 to almost 6.0. The months and days breakdown gives you the full picture.' },
  { q: 'What is the oldest age this calculator supports?', a: 'The calculator works for any date from year 1 to year 9999. For most historical or future dates, it gives accurate results.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Date of birth</span>
        <input id="dob" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Age at date</span>
        <input id="asof" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Your age is</div>
        <div id="main-age" class="mt-1 text-2xl font-bold sm:text-3xl">—</div>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl bg-slate-50 p-3 text-center">
          <div id="t-months" class="text-lg font-bold text-slate-800">0</div>
          <div class="text-xs text-slate-500">Months</div>
        </div>
        <div class="rounded-xl bg-slate-50 p-3 text-center">
          <div id="t-weeks" class="text-lg font-bold text-slate-800">0</div>
          <div class="text-xs text-slate-500">Weeks</div>
        </div>
        <div class="rounded-xl bg-slate-50 p-3 text-center">
          <div id="t-days" class="text-lg font-bold text-slate-800">0</div>
          <div class="text-xs text-slate-500">Days</div>
        </div>
        <div class="rounded-xl bg-slate-50 p-3 text-center">
          <div id="t-hours" class="text-lg font-bold text-slate-800">0</div>
          <div class="text-xs text-slate-500">Hours</div>
        </div>
      </div>

      <p id="next-bday" class="mt-4 text-center text-sm text-slate-600"></p>
    </div>

    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Pick your date of birth to see your age.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How age calculation works</h2>
    <p class="mt-2 text-slate-600">
      Computing exact age is more nuanced than simply subtracting two dates. A naive approach would divide milliseconds by 365.25 days, but that produces fractional results that don't match how humans describe age. Our calculator uses a calendar-aware algorithm that decomposes the date difference into whole years, months and remaining days.
    </p>
    <p class="mt-3 text-slate-600">
      The algorithm works as follows: start with <code>years = toYear - fromYear</code>, then adjust by month and day offsets. If the current month is before the birth month, subtract one year and add 12 months. If the current day is before the birth day within the same month, borrow days from the previous month. For total weeks, hours and days, we convert the raw millisecond difference (<code>to - from</code>) using fixed conversions: 86,400,000 ms per day, 7 days per week, 24 hours per day.
    </p>

    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Born: <strong>15 March 1990</strong> &nbsp;|&nbsp; Target: <strong>25 June 2026</strong></p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Exact age:</span> <span class="text-slate-600">36 years, 3 months, 10 days</span></div>
        <div><span class="font-medium text-slate-700">Total months:</span> <span class="text-slate-600">435</span></div>
        <div><span class="font-medium text-slate-700">Total weeks:</span> <span class="text-slate-600">~1,893</span></div>
        <div><span class="font-medium text-slate-700">Total days:</span> <span class="text-slate-600">13,251</span></div>
        <div><span class="font-medium text-slate-700">Total hours:</span> <span class="text-slate-600">318,024</span></div>
        <div><span class="font-medium text-slate-700">Next birthday:</span> <span class="text-slate-600">263 days (15 Mar 2027)</span></div>
      </div>
    </div>
  </section>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 200" width="800" height="200" role="img" aria-labelledby="age-title age-desc">
      <title id="age-title">Age Breakdown Diagram</title>
      <desc id="age-desc">Three stacked horizontal bars showing years, months, and days as components of total age on a timeline</desc>
      <rect x="50" y="30" width="700" height="28" rx="4" fill="#e0e7ff" />
      <rect x="50" y="30" width="525" height="28" rx="4" fill="#6366f1" />
      <text x="312" y="49" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="14" font-weight="700">Years</text>
      <rect x="50" y="68" width="700" height="28" rx="4" fill="#e0e7ff" />
      <rect x="50" y="68" width="350" height="28" rx="4" fill="#818cf8" />
      <text x="225" y="87" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="14" font-weight="700">Months</text>
      <rect x="50" y="106" width="700" height="28" rx="4" fill="#e0e7ff" />
      <rect x="50" y="106" width="175" height="28" rx="4" fill="#a5b4fc" />
      <text x="137" y="125" text-anchor="middle" fill="#fff" font-family="system-ui, sans-serif" font-size="14" font-weight="700">Days</text>
      <line x1="50" y1="155" x2="750" y2="155" stroke="#cbd5e1" stroke-width="2" />
      <circle cx="50" cy="155" r="4" fill="#94a3b8" />
      <circle cx="750" cy="155" r="4" fill="#94a3b8" />
      <text x="50" y="180" fill="#64748b" font-family="system-ui, sans-serif" font-size="13">Birth</text>
      <text x="750" y="180" text-anchor="end" fill="#64748b" font-family="system-ui, sans-serif" font-size="13">Today</text>
      <text x="400" y="180" text-anchor="middle" fill="#475569" font-family="system-ui, sans-serif" font-size="13" font-weight="600">Timeline</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Age is decomposed into years, months, and days along a timeline from birth to the reference date</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Why knowing your exact age matters</h2>
    <p class="mt-2 text-slate-600">
      Age is more than a number — it determines eligibility for school admissions, drivers licenses, voting, retirement, insurance rates, medical screenings and legal agreements. But "years old" only tells part of the story. Your exact age in years, months and days matters for milestones, health tracking, and legal precision.
    </p>

    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">School enrollment cutoff</span><span class="text-slate-400">Age 5 by Sep 1</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Drivers license</span><span class="text-slate-400">Age 16–18</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:40%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Voting age</span><span class="text-slate-400">Age 18</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:45%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Alcohol purchase (US)</span><span class="text-slate-400">Age 21</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Full retirement (US)</span><span class="text-slate-400">Age 67</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-violet-500" style="width:100%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎂</span>
      <h3 class="mt-2 font-semibold text-slate-900">Birthday Planning</h3>
      <p class="mt-1 text-sm text-slate-600">Know exactly how many days until your next birthday. Perfect for milestone celebrations like 18th, 21st, 30th, 50th or 100th.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📋</span>
      <h3 class="mt-2 font-semibold text-slate-900">Forms & Applications</h3>
      <p class="mt-1 text-sm text-slate-600">Many official forms ask for "age in years and months." This calculator gives you the exact breakdown for insurance, medical and legal documents.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👶</span>
      <h3 class="mt-2 font-semibold text-slate-900">Parenting & Pediatrics</h3>
      <p class="mt-1 text-sm text-slate-600">Track a childs age in months for developmental milestones and pediatric appointments. Doctors often track ages in months for the first 3 years.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🐶</span>
      <h3 class="mt-2 font-semibold text-slate-900">Pet Age Comparison</h3>
      <p class="mt-1 text-sm text-slate-600">Curious how old your pet is in human years? Use our <a href="/tools/dog-age-calculator" class="font-medium text-indigo-600 hover:underline">Dog Age Calculator</a> after finding their actual age here.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the age calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter birth date</h3>
        <p class="mt-1 text-sm text-slate-600">Select the date of birth using the date picker. The calculator works for any date in the past.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose reference date</h3>
        <p class="mt-1 text-sm text-slate-600">Defaults to today. Change it to any past or future date to calculate age at that point.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Get instant results</h3>
        <p class="mt-1 text-sm text-slate-600">See years, months, days, weeks, hours and a countdown to the next birthday — all at once.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Leap year and birthday logic</h2>
    <p class="mt-2 text-slate-600">
      Leap years add a 29th day to February every year divisible by 4, except century years not divisible by 400. The year 2000 was a leap year; 1900 was not; 2100 will not be. Our calculator handles this automatically via JavaScript's <code>Date</code> object, which respects the Gregorian calendar including all leap year rules.
    </p>
    <p class="mt-3 text-slate-600">
      For people born on 29 February, the "birthday" in non-leap years is ambiguous. Our calculator uses 1 March as the equivalent date, which is the convention followed by most legal systems and online services. The countdown to the next birthday correctly accounts for whether the current or upcoming year is a leap year. If you were born on a leap day, your age in non-leap years is calculated as if your birthday fell on 1 March for month-and-day arithmetic.
    </p>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Age milestones worth knowing</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">1,000 days old</h3>
        <p class="mt-1 text-sm text-slate-600">Around age 2 years, 9 months — a fun milestone for baby photos and memory books.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">10,000 days old</h3>
        <p class="mt-1 text-sm text-slate-600">Around age 27 — a popular milestone for "10,000 day" celebrations.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">1,000,000 hours old</h3>
        <p class="mt-1 text-sm text-slate-600">Around age 114 — an extraordinary milestone very few people reach.</p>
      </div>
    </div>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <div class="rounded-lg bg-indigo-50 p-3 text-center">
        <div class="text-lg font-bold text-indigo-700">1,000 days</div>
        <div class="text-xs text-slate-500">~2 years 9 months</div>
      </div>
      <div class="rounded-lg bg-indigo-50 p-3 text-center">
        <div class="text-lg font-bold text-indigo-700">10,000 days</div>
        <div class="text-xs text-slate-500">~27 years 4 months</div>
      </div>
      <div class="rounded-lg bg-indigo-50 p-3 text-center">
        <div class="text-lg font-bold text-indigo-700">30,000 days</div>
        <div class="text-xs text-slate-500">~82 years 2 months</div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Age calculation across cultures</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Western (birthday-based)</h3>
        <p class="mt-1 text-sm text-slate-600">Age 0 at birth, increments by 1 on each birthday. This is the system used by most of the world and by this calculator. A child born on 31 December 2025 becomes age 1 on 31 December 2026.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Korean age</h3>
        <p class="mt-1 text-sm text-slate-600">Age 1 at birth, everyone advances a year on New Year's Day. A baby born on 31 December 2025 turns 2 on 1 January 2026. Korean age is typically 1–2 years older than Western age.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Chinese (nominal) age</h3>
        <p class="mt-1 text-sm text-slate-600">Age 1 at birth, increments at Chinese New Year based on the lunar calendar. The exact age depends on when the lunar new year falls relative to the birth date.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Legal vs biological age</h3>
        <p class="mt-1 text-sm text-slate-600">Legal age (for contracts, driving, drinking) uses the birthday-based system universally. Biological age, used in medicine, considers developmental factors and can differ from chronological age.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const dob = document.getElementById('dob');
    const asof = document.getElementById('asof');
    const result = document.getElementById('result');
    const hint = document.getElementById('hint');
    const el = (id) => document.getElementById(id);

    function todayLocalISO() {
      const d = new Date();
      const mm = String(d.getMonth() + 1).padStart(2, '0');
      const dd = String(d.getDate()).padStart(2, '0');
      return `${d.getFullYear()}-${mm}-${dd}`;
    }
    asof.value = todayLocalISO();

    // `from`/`to` are parsed from "YYYY-MM-DD" strings, which the Date constructor
    // treats as UTC midnight. Reading them back with local getters (getMonth/getDate)
    // shifts the calendar day by one for any timezone behind UTC, so all arithmetic
    // here uses the UTC getters/constructor to stay consistent with how they were parsed.
    function diffYMD(from, to) {
      // Advance `from` by whole years+months (clamping to the target month's real
      // length, e.g. Jan 31 + 1 month -> Feb 28) and take the remaining days from
      // that anchor date. A naive single-borrow subtraction goes negative whenever
      // `from`'s day-of-month doesn't exist a month later (e.g. 31 Jan -> 1 Mar).
      function addYM(date, years, months) {
        let year = date.getUTCFullYear() + years;
        let month = date.getUTCMonth() + months;
        year += Math.floor(month / 12);
        month = ((month % 12) + 12) % 12;
        const daysInMonth = new Date(Date.UTC(year, month + 1, 0)).getUTCDate();
        const day = Math.min(date.getUTCDate(), daysInMonth);
        return new Date(Date.UTC(year, month, day));
      }
      let y = to.getUTCFullYear() - from.getUTCFullYear();
      let m = to.getUTCMonth() - from.getUTCMonth();
      if (m < 0) { y--; m += 12; }
      let anchor = addYM(from, y, m);
      if (anchor > to) {
        m--;
        if (m < 0) { y--; m += 12; }
        anchor = addYM(from, y, m);
      }
      const d = Math.round((to - anchor) / 86400000);
      return { y, m, d };
    }

    function update() {
      if (!dob.value || !asof.value) return;
      const from = new Date(dob.value);
      const to = new Date(asof.value);
      if (to < from) {
        hint.textContent = '"Age at date" must be after the date of birth.';
        hint.classList.remove('hidden');
        result.classList.add('hidden');
        return;
      }

      const { y, m, d } = diffYMD(from, to);
      const ms = to - from;
      const totalDays = Math.floor(ms / 86400000);

      el('main-age').textContent = `${y} years, ${m} months, ${d} days`;
      el('t-months').textContent = (y * 12 + m).toLocaleString();
      el('t-weeks').textContent = Math.floor(totalDays / 7).toLocaleString();
      el('t-days').textContent = totalDays.toLocaleString();
      el('t-hours').textContent = (totalDays * 24).toLocaleString();

      let next = new Date(Date.UTC(to.getUTCFullYear(), from.getUTCMonth(), from.getUTCDate()));
      if (next < to) next = new Date(Date.UTC(to.getUTCFullYear() + 1, from.getUTCMonth(), from.getUTCDate()));
      const daysToBday = Math.ceil((next - to) / 86400000);
      el('next-bday').textContent =
        daysToBday === 0 ? '🎉 It\'s your birthday today!' : `🎂 Next birthday in ${daysToBday} day${daysToBday === 1 ? '' : 's'}.`;

      result.classList.remove('hidden');
      hint.classList.add('hidden');
    }

    dob.addEventListener('change', update);
    asof.addEventListener('change', update);
  </script>
</ToolLayout>
