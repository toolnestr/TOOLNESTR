---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'CGPA to Percentage Calculator';
const description =
  'Free CGPA to percentage calculator. Convert your CGPA to a percentage using the CBSE ' +
  'formula or a custom multiplier. Instant, accurate and free.';
const intro =
  'Enter your CGPA to convert it to a percentage. Uses the popular CBSE formula (CGPA × 9.5) or your own multiplier.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'How do I convert CGPA to percentage?', a: 'The most common method (used by CBSE in India) multiplies your CGPA by 9.5. For example, a CGPA of 8.0 equals 8.0 × 9.5 = 76%.' },
  { q: 'What if my university uses a different formula?', a: 'Choose “Custom multiplier” and enter the factor your university uses (for example ×10), and the calculator updates instantly.' },
  { q: 'Is this accepted everywhere?', a: 'The 9.5 multiplier is widely used but not universal. Always check your university or board’s official formula for official purposes.' },
  { q: 'What is the maximum CGPA that can be converted?', a: 'Most CGPA scales go up to 10, but some go up to 5 or 4. The calculator works with any CGPA value — just enter yours as is.' },
  { q: 'My university uses a 10-point CGPA but with a different multiplier. How do I find it?', a: 'Check your university’s examination rules or academic regulations. Many publish an official conversion table or formula on their website.' },
  { q: 'Can I convert to CGPA from percentage?', a: 'Yes — use our <a href="/tools/percentage-to-cgpa" class="font-medium text-indigo-600 hover:underline">Percentage to CGPA Calculator</a> for the reverse conversion.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Your CGPA</span>
        <input id="cgpa" type="number" step="any" placeholder="8.0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Formula</span>
        <select id="mult" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="9.5">CBSE (× 9.5)</option>
          <option value="10">× 10</option>
          <option value="custom">Custom multiplier</option>
        </select></label>
      <label id="custom-wrap" class="block sm:max-w-[12rem]" style="display:none"><span class="text-sm font-medium text-slate-700">Custom multiplier</span>
        <input id="custom" type="number" step="any" value="9.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Your percentage</div>
      <div id="pct" class="mt-1 text-3xl font-bold">—</div>
      <div id="formula" class="mt-1 font-mono text-sm opacity-80"></div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your CGPA to convert it to a percentage.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About CGPA to percentage conversion</h2>
    <p class="mt-2 text-slate-600">
      Many schools and universities (especially in India, Pakistan and across Asia) grade on a
      CGPA scale, but job applications, foreign universities and scholarships often ask for a
      percentage. This calculator converts your CGPA to a percentage instantly using the widely
      used CBSE formula, or any custom multiplier your institution specifies. To convert in reverse, use our <a href="/tools/percentage-to-cgpa" class="font-medium text-indigo-600 hover:underline">Percentage to CGPA Calculator</a>.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter your CGPA (e.g. 8.0).</li>
      <li>Choose the formula — CBSE (× 9.5), × 10, or a custom multiplier.</li>
      <li>Your percentage appears instantly with the calculation shown.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use this when filling out job applications that require a percentage, applying to universities abroad that don't use the CGPA system, completing scholarship forms, or preparing your academic profile for placement interviews. Many Indian employers and foreign universities specifically ask for a percentage equivalent.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>The CBSE multiplier of 9.5 is widely accepted across India, but always check if your board or university specifies a different factor.</li>
      <li>If your institution doesn't specify a multiplier, select "Custom" and try to find the official conversion from your registrar's office.</li>
      <li>For converting percentage back to CGPA, use our <a href="/tools/percentage-to-cgpa" class="font-medium text-indigo-600 hover:underline">Percentage to CGPA Calculator</a>.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    el('mult').addEventListener('change', () => {
      el('custom-wrap').style.display = el('mult').value === 'custom' ? 'block' : 'none';
      update();
    });
    function update() {
      const cgpa = parseFloat(el('cgpa').value);
      const m = el('mult').value === 'custom' ? parseFloat(el('custom').value) : parseFloat(el('mult').value);
      if (isNaN(cgpa) || isNaN(m)) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      const pct = cgpa * m;
      el('pct').textContent = (Math.round(pct * 100) / 100) + '%';
      el('formula').textContent = `${cgpa} × ${m} = ${Math.round(pct * 100) / 100}%`;
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }
    ['cgpa', 'custom'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
