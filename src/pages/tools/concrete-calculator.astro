---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Concrete Calculator';
const description = 'Calculate cubic yards of concrete and number of bags needed from length, width, and depth.';
const intro = 'Estimate the cubic yards of concrete and number of bags needed for any slab or pour.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'How many cubic feet are in a cubic yard?', a: 'There are 27 cubic feet in one cubic yard (3 ft x 3 ft x 3 ft). This is the standard unit for ordering ready-mix concrete.' },
  { q: 'How many bags of concrete do I need per cubic yard?', a: 'A 60 lb bag yields about 0.45 cubic feet, so you need roughly 60 bags per cubic yard. An 80 lb bag yields about 0.6 cubic feet, needing about 45 bags per cubic yard.' },
  { q: 'Should I order extra concrete?', a: 'Yes, order 5-10% extra to account for spillage, uneven subgrade, and slight over-excavation. Ready-mix trucks carry a minimum load, so check with your supplier.' },
  { q: 'What is the minimum depth for a concrete slab?', a: 'A 4-inch thickness is standard for patios, walkways, and garage floors. Driveways need 5-6 inches. Heavy-load areas may require 8 inches or more.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="length" type="number" step="any" placeholder="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="width" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Depth (in)</span>
        <input id="depth" type="number" step="any" placeholder="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Bag size</span>
      <div class="mt-1 flex gap-2">
        {['60 lb', '80 lb', 'Ready-mix'].map((b) => (
          <button data-bag={b} class="bag-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{b}</button>
        ))}
      </div>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Concrete needed</div>
        <div id="r-cy" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-mix" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic feet</div><div id="r-cf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Bags needed</div><div id="r-bags" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Tons</div><div id="r-tons" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="conc-title conc-desc">
      <title id="conc-title">Concrete slab cross-section diagram</title>
      <desc id="conc-desc">A concrete slab showing length, width, and depth dimensions with the formula volume = L x W x D</desc>
      <rect x="100" y="100" width="500" height="120" fill="#d1d5db" stroke="#6366f1" stroke-width="2" rx="2" />
      <rect x="100" y="100" width="500" height="120" fill="url(#conc-pat)" opacity="0.15" />
      <defs>
        <pattern id="conc-pat" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="10" cy="10" r="1.5" fill="#6366f1" />
          <circle cx="2" cy="2" r="1" fill="#6366f1" />
          <circle cx="18" cy="5" r="1" fill="#6366f1" />
        </pattern>
      </defs>
      <text x="350" y="165" text-anchor="middle" font-size="18" fill="#1e293b" font-family="system-ui,sans-serif" font-weight="bold">Concrete Slab</text>
      <line x1="100" y1="80" x2="600" y2="80" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <polygon points="100,80 112,75 112,85" fill="#94a3b8" />
      <polygon points="600,80 588,75 588,85" fill="#94a3b8" />
      <text x="350" y="70" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Length (L)</text>
      <line x1="85" y1="100" x2="85" y2="220" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <polygon points="85,100 77,112 93,112" fill="#94a3b8" />
      <polygon points="85,220 77,208 93,208" fill="#94a3b8" />
      <text x="72" y="165" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif" transform="rotate(-90 72 165)">Width (W)</text>
      <line x1="600" y1="100" x2="640" y2="100" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <line x1="600" y1="220" x2="640" y2="220" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <line x1="640" y1="100" x2="640" y2="220" stroke="#94a3b8" stroke-width="1.5" />
      <polygon points="640,100 632,108 648,108" fill="#94a3b8" />
      <polygon points="640,220 632,212 648,212" fill="#94a3b8" />
      <text x="652" y="165" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Depth (D)</text>
      <rect x="110" y="240" width="250" height="90" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="125" y="262" font-size="12" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Volume formula</text>
      <text x="125" y="280" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Cu ft = L &times; W &times; D&frasl;12</text>
      <text x="125" y="298" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Cu yd = Cu ft &divide; 27</text>
      <text x="125" y="316" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Bags = Cu ft &divide; bag yield</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Concrete volume is calculated as length times width times depth, converted to cubic yards</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the concrete calculator works</h2>
    <p class="mt-2 text-slate-600">
      The concrete calculator estimates the total volume of concrete needed for a slab based on length, width, and depth. It converts the volume from cubic feet to cubic yards — the standard unit for ordering ready-mix concrete. It also calculates the number of bags required based on the bag size you choose.
    </p>
    <p class="mt-3 text-slate-600">
      Concrete volume is straightforward: multiply the length by the width to get the surface area, then multiply by the depth. Since depth is typically measured in inches while length and width are in feet, the calculator converts depth to feet by dividing by 12. The result in cubic feet is then divided by 27 to get cubic yards, since one cubic yard equals 27 cubic feet.
    </p>
    <p class="mt-3 text-slate-600">
      For bagged concrete, the calculator uses standard yields: a 60 lb bag covers approximately 0.45 cubic feet, while an 80 lb bag covers about 0.6 cubic feet. Ready-mix orders are typically placed by the cubic yard and delivered by a concrete truck carrying 8-12 cubic yards per load.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the area</h3>
        <p class="mt-1 text-sm text-slate-600">Measure the length and width of the slab area in feet. Measure the planned depth in inches.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose bag type</h3>
        <p class="mt-1 text-sm text-slate-600">Select 60 lb bags, 80 lb bags, or ready-mix. The calculator adjusts the bag count accordingly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Review results</h3>
        <p class="mt-1 text-sm text-slate-600">Check cubic yards for ready-mix or bag count for DIY. Add 5-10% extra for waste and spillage.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Volume in cubic feet</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">V = L &times; W &times; (D &divide; 12)</span>. A slab 20&prime; &times; 10&prime; with a 4-inch depth gives 20 &times; 10 &times; (4&divide;12) = <strong>66.67 cu ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Convert to cubic yards</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">CY = V &divide; 27</span>. From the example: 66.67 &divide; 27 = <strong>2.47 cu yd</strong>. You would order 2.5 cubic yards from the ready-mix company.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Bag count</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Bags = V &divide; bag yield</span>. Using 60 lb bags (0.45 cu ft each): 66.67 &divide; 0.45 = <strong>148 bags</strong>. With 80 lb bags (0.6 cu ft): 66.67 &divide; 0.6 = <strong>111 bags</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 24&prime; &times; 20&prime; driveway at 5 inches deep, with 10% extra for waste.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">24 &times; 20 &times; (5&divide;12) = 200 cu ft</span></div>
        <div><span class="font-medium text-slate-700">Cubic yards:</span> <span class="text-slate-600">200 &divide; 27 = 7.41 cu yd</span></div>
        <div><span class="font-medium text-slate-700">With 10% waste:</span> <span class="text-slate-600">7.41 &times; 1.1 = <strong>8.15 cu yd</strong></span></div>
        <div><span class="font-medium text-slate-700">80 lb bags:</span> <span class="text-slate-600">200 &divide; 0.6 = 334 bags</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the concrete calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Driveway and patio</h3>
        <p class="mt-1 text-sm text-slate-600">Plan your driveway or patio pour with confidence. Know exactly how much concrete to order, whether you are using bagged mix for a small patio or ready-mix for a full driveway. Add rebar or wire mesh reinforcement for strength.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Foundation footings</h3>
        <p class="mt-1 text-sm text-slate-600">Calculate concrete for foundation footings and stem walls. Footings require precise volume estimates since they are below grade and harder to adjust during the pour.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌳</span>
        <h3 class="mt-2 font-semibold text-slate-900">Walkways and paths</h3>
        <p class="mt-1 text-sm text-slate-600">Garden paths and front walkways typically use 4-inch thick concrete. The calculator helps you compare the cost of bagged vs. ready-mix concrete for these smaller projects.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Pool deck and steps</h3>
        <p class="mt-1 text-sm text-slate-600">Pool surrounds, steps, and benches all need concrete. Measure the irregular shape as a series of rectangles and add the volumes together for an accurate total.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for ordering concrete</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always order 10% extra</h3>
        <p class="mt-1 text-sm text-slate-600">Subgrades are rarely perfectly level, and some concrete is lost to spillage and the truck chute. Adding 10% to your estimate ensures you do not run short. Any leftover concrete can be used for a small project or disposed of according to local regulations.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Understand ready-mix minimums</h3>
        <p class="mt-1 text-sm text-slate-600">Most ready-mix trucks carry a minimum load of 3-4 cubic yards. If your project needs less, you will pay a short-load fee. Compare the cost of bagged concrete versus a short load of ready-mix to find the cheaper option for small pours.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Reinforcement matters for strength</h3>
        <p class="mt-1 text-sm text-slate-600">Concrete is strong in compression but weak in tension. For slabs that will bear weight — driveways, garage floors, foundations — add rebar or welded wire mesh. The calculator does not include reinforcement materials, so budget for them separately.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/concrete-slab-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Slab Calculator</a>
      <a href="/tools/cubic-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Cubic Yardage Calculator</a>
      <a href="/tools/gravel-sand-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gravel & Sand Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let bagSize = '60 lb';
    const bagYields = { '60 lb': 0.45, '80 lb': 0.6 };

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      const D = parseFloat(el('depth').value);
      if (!L || !W || !D || L <= 0 || W <= 0 || D <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const cf = L * W * (D / 12);
      const cy = cf / 27;
      const tons = cy * 1.95;
      const yieldVal = bagYields[bagSize] || 0.45;
      const bags = Math.ceil(cf / yieldVal);

      el('r-cy').textContent = cy.toFixed(2) + ' cu yd';
      el('r-mix').textContent = 'Order ' + Math.ceil(cy) + (bagSize === 'Ready-mix' ? ' cu yd' : ' cu yd (or bag it)');
      el('r-cf').textContent = cf.toFixed(1) + ' cu ft';
      el('r-bags').textContent = bags.toLocaleString() + ' bags';
      el('r-tons').textContent = tons.toFixed(2) + ' tons';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.bag-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.bag-btn').forEach((b) => {
          b.className = 'bag-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50';
        });
        btn.className = 'bag-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
        bagSize = btn.dataset.bag;
        update();
      });
    });

    ['length', 'width', 'depth'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
    document.querySelector('.bag-btn').click();
  </script>
</ToolLayout>
