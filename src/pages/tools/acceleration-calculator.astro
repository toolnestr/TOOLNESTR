---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Acceleration Calculator';
const description = 'Acceleration calculator with a live 3D speeding-up/slowing-down animation and charts. Solve a = Δv / Δt for acceleration, initial velocity, final velocity, or time, with worked examples.';
const intro = 'Enter any three of initial velocity, final velocity, time and acceleration — the fourth solves instantly, and a live 3D scene plus charts show the velocity vector grow or shrink.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is acceleration?', a: 'Acceleration is the rate of change of velocity with time: a = Δv / Δt = (v_f − v_i) / t. It is a vector — a positive or negative sign tells you the direction of the change, not just how fast velocity is changing.' },
  { q: 'What is the formula for acceleration?', a: 'a = (v_f − v_i) / t, where v_i is the initial velocity, v_f is the final velocity, and t is the time taken for that change. Units are m/s² in SI.' },
  { q: 'Does negative acceleration always mean slowing down?', a: 'No. Negative acceleration means the acceleration vector points in the negative direction. If the object is already moving in the negative direction, a negative acceleration makes it speed up, not slow down. Deceleration only occurs when acceleration and velocity point opposite ways.' },
  { q: 'Is deceleration a real physics term?', a: 'It is a useful everyday word for "slowing down," but physics only needs one signed quantity: acceleration. An object decelerates whenever its acceleration and velocity have opposite signs, regardless of which way it is moving.' },
  { q: 'Can something have zero velocity but nonzero acceleration?', a: 'Yes — at the top of a ball\'s toss, its velocity is momentarily zero but gravity is still pulling it down at 9.81 m/s². Zero velocity is an instant; acceleration describes how velocity is changing at that instant, and those are independent facts.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Acceleration Calculator',
  description: 'Calculate acceleration, initial velocity, final velocity, or time from the other three quantities.',
  steps: [
    { name: 'Enter three values', text: 'Type any three of initial velocity, final velocity, time and acceleration.' },
    { name: 'Read the result', text: 'The fourth value solves instantly, and the 3D scene updates.' },
    { name: 'Check the graphs', text: 'The velocity-vs-time chart shows the ramp whose slope is the acceleration.' },
  ],
};

const formulas = [
  { expr: 'a = Δv / t', note: 'change in velocity over time' },
  { expr: 'a = (v<sub>f</sub> − v<sub>i</sub>) / t', note: 'expanded form' },
  { expr: 'v<sub>f</sub> = v<sub>i</sub> + a·t', note: 'rearranged for final velocity' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a car speeding up', tone: 'slate',
    given: 'A car starts from rest (v_i = 0 m/s) and reaches v_f = 27 m/s in t = 9.0 s. Find its acceleration.',
    rows: [
      { label: 'Change in velocity:', value: 'Δv = 27 − 0 = 27 m/s' },
      { label: 'Time:', value: 't = 9.0 s' },
      { label: 'Acceleration:', value: 'a = 27 ÷ 9.0 = 3.00 m/s²', full: true },
    ],
  },
  {
    title: 'Worked example 2 — braking to a stop', tone: 'amber',
    given: 'A cyclist travelling at v_i = 25 m/s brakes to a complete stop (v_f = 0) in t = 5.0 s. Find the acceleration.',
    rows: [
      { label: 'Change in velocity:', value: 'Δv = 0 − 25 = −25 m/s' },
      { label: 'Time:', value: 't = 5.0 s' },
      { label: 'Acceleration:', value: 'a = −25 ÷ 5.0 = −5.00 m/s²', full: true },
    ],
    note: 'The negative sign means the acceleration points opposite to the direction of travel — this is the everyday "deceleration."',
  },
];

const comparison = {
  heading: 'Typical accelerations',
  note: 'Ordered from gentle to extreme — all approximate, real-world figures.',
  headers: [{ label: 'Scenario' }, { label: 'Acceleration' }, { label: 'In g' }],
  rows: [
    ['Elevator starting to move', '≈ 1 m/s²', '≈ 0.1 g'],
    ['Car, 0–60 mph (0–27 m/s) in ~7 s', '≈ 3.9 m/s²', '≈ 0.4 g'],
    ['Free fall near Earth\'s surface', '9.81 m/s²', '1.0 g'],
    ['Hard braking in a car', '≈ 7–9 m/s²', '≈ 0.7–0.9 g'],
    ['Falcon 9 at liftoff (approx.)', '≈ 13–20 m/s²', '≈ 1.3–2 g'],
  ],
  highlightIndex: 2,
  footnote: '1 g = 9.81 m/s², standard gravity. Rocket and braking figures vary with vehicle and conditions.',
};

const realWorld = [
  { emoji: '🏎️', title: 'Car performance', body: 'Manufacturers quote 0–60 mph times because it is a direct, comparable measure of average acceleration — the same a = Δv/t used here, just expressed as a headline number.' },
  { emoji: '🎢', title: 'Roller coasters', body: 'Designers cap acceleration (both speeding up and cornering) to stay within a safe and comfortable g-force range for riders, using exactly this formula to plan each drop and launch segment.' },
  { emoji: '🏈', title: 'Sports performance', body: 'A sprinter\'s acceleration off the blocks, or a pitched ball\'s acceleration during the throw, are measured with a = Δv/t to compare athletes and technique.' },
];

const misconceptions = [
  { claim: '"Acceleration means speeding up."', truth: 'Acceleration is any change in velocity — speeding up, slowing down, or changing direction all count. A car braking has acceleration; so does a car turning a corner at constant speed, because its velocity direction is changing.' },
  { claim: '"Zero velocity means zero acceleration."', truth: 'Not true at a turning point. A ball thrown straight up has zero velocity at the peak of its flight, but gravity still accelerates it downward at 9.81 m/s² the whole time — velocity and acceleration are independent quantities.' },
  { claim: '"Negative acceleration always means slowing down."', truth: 'It means the acceleration vector points in the negative direction. If the object is moving in the negative direction already, a negative acceleration speeds it up. Deceleration happens only when acceleration opposes velocity.' },
  { claim: '"Constant speed means constant acceleration is impossible."', truth: 'Speed and velocity are different. An object moving at constant speed around a curve has a constantly changing velocity direction, so it is accelerating (centripetal acceleration) even though its speed never changes.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §3.3 "Average and Instantaneous Acceleration" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/3-3-average-and-instantaneous-acceleration" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 2, Motion Along a Straight Line (Acceleration).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 2, Motion in One Dimension (Acceleration).' },
];
const sourcesNote = 'a = Δv / t assumes constant (uniform) acceleration over the interval. Results rounded for display.';

const howToUse = [
  { title: 'Enter three values', body: 'Fill any three of v_i, v_f, t and a; the fourth solves live.' },
  { title: 'Watch the scene', body: 'The 3D car speeds up or slows down to match your inputs, with a vector showing velocity.' },
  { title: 'Read the graphs', body: 'The v-t ramp\'s slope is the acceleration; the second chart shows how a changes with t at fixed Δv.' },
];

const related = [
  { href: '/tools/average-velocity-calculator', emoji: '📍', title: 'Average Velocity Calculator', desc: 'v_avg = Δx/Δt — solve for any variable.' },
  { href: '/tools/free-fall-calculator', emoji: '⬇️', title: 'Free Fall Calculator', desc: 'Time and velocity under gravity.' },
  { href: '/tools/momentum-calculator', emoji: '🎯', title: 'Momentum & Impulse Calculator', desc: 'p = mv plus impulse calculations.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="acceleration is how fast velocity itself is changing — a steady ramp in the velocity-vs-time graph, with the ramp's slope equal to a."
  howIntro="Rearranged, the same relation solves any of the four quantities: v<sub>f</sub> = v<sub>i</sub> + a·t, v<sub>i</sub> = v<sub>f</sub> − a·t, and t = (v<sub>f</sub> − v<sub>i</sub>) / a. The sign of a only tells you its direction — whether that means speeding up or slowing down depends on which way the object is already moving."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where acceleration actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any three values — the fourth solves instantly.</p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial velocity (v<sub>i</sub>)</span>
        <input id="vi" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Final velocity (v<sub>f</sub>)</span>
        <input id="vf" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time (t)</span>
        <input id="t" type="number" step="any" placeholder="s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Acceleration (a)</span>
        <input id="a" type="number" step="any" placeholder="m/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Initial velocity</div><div id="r-vi" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Final velocity</div><div id="r-vf" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Time</div><div id="r-t" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Acceleration</div><div id="r-a" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="acc-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D scene + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D speed-up / slow-down</h2>
      <p class="mt-1 text-sm text-slate-500">Set v_i, v_f and t; the car's velocity vector grows or shrinks to match, and the acceleration updates live. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-3">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">v<sub>i</sub> <span id="out-bvi" class="font-mono text-indigo-600">0.0 m/s</span></span>
          <input id="b-vi" type="range" min="-20" max="20" step="0.5" value="0" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">v<sub>f</sub> <span id="out-bvf" class="font-mono text-indigo-600">15.0 m/s</span></span>
          <input id="b-vf" type="range" min="-20" max="20" step="0.5" value="15" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">t <span id="out-bt" class="font-mono text-indigo-600">5.0 s</span></span>
          <input id="b-t" type="range" min="0.5" max="10" step="0.1" value="5" class="mt-2 w-full accent-indigo-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">Acceleration a = <span id="out-ba" class="font-mono font-bold">3.00 m/s²</span></div>
      <div id="acc3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="acc3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Motion graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Velocity vs time — the ramp's slope is a</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">a vs t at fixed Δv — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-at"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup, arrow } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('acc-err').textContent = '';
        ['r-vi', 'r-vf', 'r-t', 'r-a'].forEach((id) => (el(id).textContent = '—'));
        const vi = parseFloat(el('vi').value), vf = parseFloat(el('vf').value), t = parseFloat(el('t').value), a = parseFloat(el('a').value);
        const filled = [!isNaN(vi), !isNaN(vf), !isNaN(t), !isNaN(a)];
        const n = filled.filter(Boolean).length;
        if (n < 3) return;
        let rvi = vi, rvf = vf, rt = t, ra = a;
        if (!filled[3]) { // solve a
          if (t === 0) { el('acc-err').textContent = 'Time cannot be zero.'; return; }
          ra = (vf - vi) / t;
        } else if (!filled[1]) { // solve vf
          rvf = vi + a * t;
        } else if (!filled[0]) { // solve vi
          rvi = vf - a * t;
        } else if (!filled[2]) { // solve t
          if (a === 0) { el('acc-err').textContent = vf === vi ? 'Acceleration is zero — time is undetermined for any Δv of zero.' : 'Acceleration cannot be zero when velocity changes.'; return; }
          rt = (vf - vi) / a;
          if (rt < 0) { el('acc-err').textContent = 'These values imply a negative time — check the signs of v_i, v_f and a.'; return; }
        }
        el('r-vi').textContent = fmt(rvi) + ' m/s';
        el('r-vf').textContent = fmt(rvf) + ' m/s';
        el('r-t').textContent = fmt(rt) + ' s';
        el('r-a').textContent = fmt(ra) + ' m/s²';
      }
      ['vi', 'vf', 't', 'a'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let scene = null;
      function bState() {
        const vi = parseFloat(el('b-vi').value), vf = parseFloat(el('b-vf').value), t = parseFloat(el('b-t').value);
        return { vi, vf, t, a: t > 0 ? (vf - vi) / t : 0 };
      }
      function onB() {
        const s = bState();
        el('out-bvi').textContent = s.vi.toFixed(1) + ' m/s';
        el('out-bvf').textContent = s.vf.toFixed(1) + ' m/s';
        el('out-bt').textContent = s.t.toFixed(1) + ' s';
        el('out-ba').textContent = fmt(s.a) + ' m/s²';
        try { if (scene) scene.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-vi').addEventListener('input', onB);
      el('b-vf').addEventListener('input', onB);
      el('b-t').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.vt = new Chart(el('chart-vt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Velocity', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: false, tension: 0, pointRadius: 3 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Velocity (m/s)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.at = new Chart(el('chart-at'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'a', data: [], borderColor: '#f59e0b', pointRadius: 0, tension: 0.3 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 't (s)' } }, y: { title: { display: true, text: 'a (m/s²)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        charts.vt.data.labels = ['0', fmt(s.t)];
        charts.vt.data.datasets[0].data = [s.vi, s.vf];
        charts.vt.update();
        const dv = s.vf - s.vi;
        const L = [], D = [];
        for (let t = 0.5; t <= 10.001; t += 0.25) { L.push(t.toFixed(2)); D.push(t > 0 ? +(dv / t).toFixed(4) : 0); }
        charts.at.data.labels = L; charts.at.data.datasets[0].data = D; charts.at.update();
      }

      // ---- interactive scene ----
      function initScene() {
        const c = el('acc3d'); if (!c) throw new Error('no scene');
        const s = makeScene(c, 16, new THREE.Vector3(0, 0, 0), OPTS);
        s.scene.add(new THREE.GridHelper(30, 15, 0xcbd5e1, 0xe2e8f0));
        const road = new THREE.Mesh(new THREE.BoxGeometry(30, 0.1, 3), new THREE.MeshStandardMaterial({ color: 0x94a3b8 }));
        road.position.y = -0.15; s.scene.add(road);
        const car = new THREE.Mesh(new THREE.BoxGeometry(1.6, 0.8, 1), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
        car.position.set(0, 0.4, 0); s.scene.add(car);
        let arrowHelper = null, t0 = performance.now(), animT = 0;
        function update(state) {
          if (arrowHelper) { s.scene.remove(arrowHelper); arrowHelper = null; }
          const vLen = Math.max(Math.abs(state.vf), Math.abs(state.vi), 0.5) * 0.18;
          const dir = state.vf >= 0 ? 1 : -1;
          const from = new THREE.Vector3(car.position.x, 1.1, 0);
          const to = new THREE.Vector3(car.position.x + dir * Math.max(0.3, Math.abs(state.vf) * 0.18), 1.1, 0);
          if (Math.abs(state.vf) > 1e-6) { arrowHelper = arrow(from, to, 0x6366f1); s.scene.add(arrowHelper); }
        }
        function frame(now) {
          requestAnimationFrame(frame);
          if (!reduceMotion) s.spin(0.0016);
          s.renderer.render(s.scene, s.camera);
        }
        frame();
        scene = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { update(); } catch (e) { console.error('[acceleration] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[acceleration] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[acceleration] charts failed', e); }
        if (window.THREE) {
          try { initScene(); } catch (e) { console.error('[acceleration] scene failed', e); el('acc3d-fallback').classList.remove('hidden'); }
        } else { el('acc3d-fallback').classList.remove('hidden'); }
        mountResize([scene]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
