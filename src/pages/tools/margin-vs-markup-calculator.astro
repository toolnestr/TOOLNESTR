---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Margin vs Markup Calculator';
const description = 'Convert instantly between profit margin (percentage of selling price) and markup (percentage of cost) for clothing and retail pricing.';
const intro = 'Convert between margin and markup — enter either one and see the other, plus the resulting price.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What\'s the actual difference between margin and markup?', a: 'Margin is profit as a percentage of the selling price: profit ÷ price. Markup is profit as a percentage of cost: profit ÷ cost. Same dollar profit, two different percentages, because they divide by different numbers.' },
  { q: 'Why is a 100% markup only a 50% margin?', a: 'If cost is $20 and markup is 100%, profit is $20 and price is $40. Margin is profit ÷ price = 20 ÷ 40 = 50%. Markup uses the smaller number (cost) as its denominator, so markup percentages are always higher than the margin percentage for the same transaction, once above 0%.' },
  { q: 'Can margin ever be 100% or higher?', a: 'Margin can approach but never reach 100%, since that would mean zero cost. Markup, by contrast, has no upper limit — a very high markup (say, 900%) corresponds to a margin approaching but still under 100% (90% in that example).' },
  { q: 'Which one should I use for clothing retail pricing?', a: 'Markup is more common for setting prices from cost (multiply cost by a known markup factor); margin is more common for evaluating overall business profitability (what percentage of total revenue is actual profit). Both describe the same numbers — use whichever your business or accountant works in.' },
];
const howTo = {
  name: 'How to convert between margin and markup',
  steps: [
    { name: 'Choose which you know', text: 'Toggle between entering a markup % or a margin %.' },
    { name: 'Enter the percentage', text: 'Type in the value you have.' },
    { name: 'Read the converted figure', text: 'The equivalent margin or markup appears instantly, with a sample price/profit breakdown.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['I know markup %', 'I know margin %'].map((d) => (
        <button data-mode={d} class="mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span id="input-label" class="text-sm font-medium text-slate-700">Markup (%)</span>
      <input id="pct" type="number" step="any" placeholder="e.g. 100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-fuchsia-600 p-4 text-center text-white"><div id="r-label" class="text-sm opacity-80">Equivalent margin</div><div id="r-other" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">On a $100 cost item</div><div id="r-example" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="160" viewBox="0 0 800 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="mm-title mm-desc">
      <title id="mm-title">Markup versus margin denominators</title>
      <desc id="mm-desc">Two fraction diagrams showing markup divides by cost while margin divides by price</desc>
      <text x="200" y="30" text-anchor="middle" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Markup</text>
      <text x="200" y="70" text-anchor="middle" font-size="16" fill="#c026d3" font-family="system-ui,sans-serif">profit ÷ cost</text>
      <text x="600" y="30" text-anchor="middle" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Margin</text>
      <text x="600" y="70" text-anchor="middle" font-size="16" fill="#c026d3" font-family="system-ui,sans-serif">profit ÷ price</text>
      <line x1="400" y1="10" x2="400" y2="150" stroke="#e2e8f0" stroke-width="1.5" />
      <text x="200" y="120" text-anchor="middle" font-size="11" fill="#94a3b8" font-family="system-ui,sans-serif">Always the higher number</text>
      <text x="600" y="120" text-anchor="middle" font-size="11" fill="#94a3b8" font-family="system-ui,sans-serif">Always the lower number</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Same profit, different denominator — markup is always numerically higher than margin</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How margin and markup convert</h2>
    <p class="mt-2 text-slate-600">
      Markup and margin describe the exact same dollar profit on a sale, but as a percentage of two different base numbers. Markup is profit divided by cost: <span class="font-mono">markup% = (price − cost) ÷ cost</span>. Margin is profit divided by the selling price: <span class="font-mono">margin% = (price − cost) ÷ price</span>. Because price is always larger than cost (assuming any profit at all), margin is always the smaller percentage of the two.
    </p>
    <p class="mt-3 text-slate-600">
      The conversion formulas are: <span class="font-mono">margin = markup ÷ (1 + markup)</span> and <span class="font-mono">markup = margin ÷ (1 − margin)</span> (both as decimals). These are worth memorizing for quick mental conversion — a 50% margin always corresponds to exactly a 100% markup, a useful anchor point since both describe doubling the cost to set the price.
    </p>
    <p class="mt-3 text-xs text-slate-400">Margin/markup conversion formulas are standard retail and cost-accounting relationships.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A retailer knows their markup is 150% and wants the equivalent margin.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Markup:</span> <span class="text-slate-600">150% = 1.5</span></div>
        <div><span class="font-medium text-slate-700">Margin:</span> <span class="text-slate-600">1.5 ÷ (1 + 1.5) = <strong>60%</strong></span></div>
        <div><span class="font-medium text-slate-700">On $20 cost:</span> <span class="text-slate-600">price = $50, profit = $30</span></div>
        <div><span class="font-medium text-slate-700">Check:</span> <span class="text-slate-600">30 ÷ 50 = <strong>60%</strong> ✓</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      This mix-up causes real confusion in clothing retail negotiations and financial reporting: a buyer who says "we need at least a 50% margin" and a supplier who quotes "our standard markup is 50%" are describing very different profitability — the buyer's 50% margin equals a 100% markup, while the supplier's 50% markup only equals a 33% margin, a substantial gap that can derail a pricing conversation if the two sides aren't using the same term.
    </p>
    <p class="mt-3 text-slate-600">
      Financial statements and gross-profit reporting almost always use margin (percentage of revenue), since that's what maps directly to total company profitability, while day-to-day pricing decisions on the retail floor are more often expressed as markup, since it's the more intuitive "add this much to what I paid" framing for setting a shelf price.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Margin and markup are just two names for the same percentage." <strong class="text-slate-900">They're numerically different.</strong> Except at 0%, markup is always a larger number than margin for the identical transaction, because of the different denominators.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"You can average or add margin and markup together." <strong class="text-slate-900">They shouldn't be mixed directly.</strong> Always convert to the same measure first — averaging a 50% margin and a 60% markup as if they're the same unit produces a meaningless number.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/clothing-markup-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Markup Calculator</a>
      <a href="/tools/wholesale-to-retail-pricing-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Wholesale-to-Retail Pricing Calculator</a>
      <a href="/tools/garment-cost-sheet-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Quick Cost Sheet Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'I know markup %';

    function update() {
      const pct = parseFloat(el('pct').value);
      if (!(pct >= 0)) { el('results').classList.add('hidden'); return; }
      const d = pct / 100;
      let markup, margin;
      if (mode === 'I know markup %') {
        markup = d;
        margin = markup / (1 + markup);
        el('r-label').textContent = 'Equivalent margin';
        el('r-other').textContent = (margin * 100).toFixed(2) + '%';
      } else {
        margin = d;
        if (margin >= 1) { el('results').classList.add('hidden'); return; }
        markup = margin / (1 - margin);
        el('r-label').textContent = 'Equivalent markup';
        el('r-other').textContent = (markup * 100).toFixed(2) + '%';
      }
      const cost = 100;
      const price = cost * (1 + markup);
      const profit = price - cost;
      el('r-example').textContent = 'Price $' + price.toFixed(2) + ', profit $' + profit.toFixed(2);
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach((b) => {
          b.className = 'mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'mode-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        mode = btn.dataset.mode;
        el('input-label').textContent = mode === 'I know markup %' ? 'Markup (%)' : 'Margin (%)';
        update();
      });
    });

    el('pct').addEventListener('input', update);
    document.querySelector('.mode-btn').click();
  </script>
</ToolLayout>
