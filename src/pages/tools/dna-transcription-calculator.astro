---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'DNA to mRNA Transcription Tool';
const description = "DNA to mRNA transcription tool. Convert a DNA template strand into its complementary mRNA sequence, with worked examples and base-pairing rules.";
const intro = 'Enter a DNA template strand sequence to generate its complementary mRNA transcript, following the base-pairing rules of transcription (A→U, T→A, C→G, G→C). Two 3D diagrams show RNA polymerase reading the template strand and the resulting base-pairing, and charts show base composition before and after transcription.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is transcription?', a: 'Transcription is the process of copying a gene\'s DNA sequence into a complementary mRNA molecule, carried out by the enzyme RNA polymerase. This mRNA later carries the genetic instructions to ribosomes for protein synthesis.' },
  { q: 'What are the base-pairing rules for transcription?', a: 'The DNA template strand pairs with mRNA as follows: T pairs with A, A pairs with U (uracil replaces thymine in RNA), C pairs with G, and G pairs with C.' },
  { q: 'Why does RNA use uracil (U) instead of thymine (T)?', a: 'RNA polymerase incorporates uracil instead of thymine wherever the template strand has an adenine (A) — uracil is chemically similar to thymine but lacks a methyl group, one of several molecular differences that distinguish RNA from DNA.' },
  { q: 'What is the difference between the template strand and the coding strand?', a: 'The template strand is the DNA strand actually read and copied by RNA polymerase. The coding (sense) strand has the same sequence as the resulting mRNA (with T instead of U) and is not directly read — it\'s complementary to the template strand.' },
  { q: 'Does the mRNA sequence match the coding strand or the template strand?', a: 'The mRNA sequence matches the coding strand (with U substituted for T), and is complementary to the template strand — since mRNA is synthesized by pairing with the template, it ends up being the "same" sequence as the non-template (coding) strand.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the DNA to mRNA Transcription Tool',
  description: 'Convert a DNA template strand sequence into its complementary mRNA transcript.',
  steps: [
    { name: 'Enter the DNA template strand', text: 'Type a sequence using only A, T, C, and G, read 3\' to 5\'.' },
    { name: 'Read the mRNA output', text: 'The complementary mRNA sequence (5\' to 3\') is generated instantly, with U replacing A-pairing T.' },
    { name: 'Check base composition', text: 'Compare the base makeup of the DNA template and resulting mRNA transcript.' },
  ],
};

const formulas = [
  { expr: 'DNA template T → mRNA A', note: 'template thymine pairs with mRNA adenine' },
  { expr: 'DNA template A → mRNA U', note: 'template adenine pairs with mRNA uracil (not thymine)' },
  { expr: 'DNA template C → mRNA G, G → mRNA C', note: 'cytosine and guanine pair as usual' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a short DNA template producing a start codon', tone: 'slate',
    given: "DNA template strand (3'→5'): T A C G G A T C C",
    rows: [
      { label: 'Base-by-base pairing:', value: 'T→A, A→U, C→G, G→C, G→C, A→U, T→A, C→G, C→G' },
      { label: "mRNA (5'→3'):", value: 'A U G C C U A G G', full: true },
    ],
    note: "This template happens to produce the mRNA sequence AUG-CCU-AGG — notice it starts with AUG, the universal start codon that begins translation for methionine.",
  },
  {
    title: 'Worked example 2 — a template rich in G/C', tone: 'amber',
    given: "DNA template strand (3'→5'): G C G C A T G C",
    rows: [
      { label: 'Base-by-base pairing:', value: 'G→C, C→G, G→C, C→G, A→U, T→A, G→C, C→G' },
      { label: "mRNA (5'→3'):", value: 'C G C G U A C G', full: true },
    ],
    note: 'A G/C-rich template produces a G/C-rich mRNA transcript, since G and C always pair with each other regardless of which strand is being read.',
  },
];

const comparison = {
  heading: 'DNA-to-RNA base pairing rules at a glance',
  note: 'Three of the four base pairings work exactly like DNA-DNA pairing — only adenine\'s partner changes.',
  headers: [{ label: 'DNA template base' }, { label: 'mRNA base' }, { label: 'Note' }],
  rows: [
    ['T', 'A', 'Standard pairing'],
    ['A ★', 'U', 'Uracil replaces thymine in RNA'],
    ['C', 'G', 'Standard pairing'],
    ['G', 'C', 'Standard pairing'],
  ],
  highlightIndex: 1,
  footnote: '★ The only pairing rule that changes from DNA-DNA replication — everywhere else, transcription follows familiar Watson-Crick base pairing.',
};

const realWorld = [
  { emoji: '💊', title: 'mRNA vaccine design', body: 'Understanding transcription is foundational to how mRNA vaccines work — synthetic mRNA sequences are designed and manufactured to instruct cells to produce a specific viral protein, triggering immune protection.' },
  { emoji: '🔬', title: 'Gene expression research', body: 'Molecular biologists study transcription to understand which genes are actively being expressed as mRNA in a cell at any given time, a key measurement in genomics research.' },
  { emoji: '🧬', title: 'Understanding genetic mutations', body: 'A mutation in the DNA template strand directly changes the mRNA sequence produced, which can alter or destroy the protein that mRNA eventually codes for — transcription is the crucial first link in that chain.' },
  { emoji: '🎓', title: 'Teaching the central dogma of molecular biology', body: 'DNA→mRNA transcription is the first step of the central dogma (DNA→RNA→protein), one of the most fundamental concepts taught in any molecular biology course.' },
];

const misconceptions = [
  { claim: '"mRNA is a mirror-image copy of the DNA template strand, using the same bases."', truth: 'mRNA is complementary to the template strand (not identical), and it substitutes uracil (U) for every position where DNA would use thymine (T) — it is not a base-for-base identical copy.' },
  { claim: '"The coding strand is the one that gets read to make mRNA."', truth: "It's actually the opposite — RNA polymerase reads the TEMPLATE strand to synthesize mRNA. The coding (sense) strand is not directly read; it simply happens to share the same sequence as the resulting mRNA (with T instead of U)." },
  { claim: '"Transcription and translation are the same process."', truth: 'Transcription copies DNA into mRNA (happening in the nucleus in eukaryotes). Translation is the separate, later process where ribosomes read that mRNA to assemble a protein (happening in the cytoplasm) — they are two distinct steps of gene expression.' },
  { claim: '"Every DNA base gets transcribed into mRNA."', truth: 'Only the gene\'s coding region (and some regulatory sequences) gets transcribed — vast stretches of DNA outside of active genes are never transcribed into mRNA at all, and even within a gene, non-coding introns are typically spliced out afterward in eukaryotes.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 15, "Genes and Proteins" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/15-3-transcription" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Chapter 6, How Cells Read the Genome: From DNA to Protein.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 17, Gene Expression.' },
];
const sourcesNote = 'DNA template T→A, A→U, C→G, G→C for mRNA. Input should use only A, T, C, G; non-matching characters are ignored.';

const howToUse = [
  { title: 'Enter the DNA template strand', body: "Type a sequence of A, T, C, G bases, read 3' to 5'." },
  { title: 'Read the mRNA transcript', body: "The complementary mRNA sequence appears instantly, 5' to 3', with U in place of T." },
  { title: 'Compare base composition', body: 'See how the four-base makeup shifts from DNA to mRNA.' },
];

const related = [
  { href: '/tools/mrna-translation-calculator', emoji: '🧬', title: 'mRNA to Protein Translation Tool', desc: 'Translate mRNA codons into an amino acid sequence.' },
  { href: '/tools/gc-content-calculator', emoji: '🔬', title: 'GC Content Calculator', desc: 'GC% = (G+C)/total bases × 100.' },
  { href: '/tools/reverse-complement-calculator', emoji: '🔄', title: 'Reverse Complement Sequence Tool', desc: 'Find the reverse complement of a DNA strand.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="RNA polymerase builds a new mRNA strand by pairing each DNA template base with its RNA complement — the same base-pairing logic as DNA replication, except adenine on the template pairs with uracil instead of thymine, since RNA uses uracil in thymine's place."
  howIntro="Transcription works through the same Watson-Crick base-pairing chemistry that holds the DNA double helix together, but building an RNA strand instead of a second DNA strand. RNA polymerase moves along the DNA template strand, and for each base it encounters, it adds the complementary RNA nucleotide: template T pairs with mRNA A, template C pairs with mRNA G, template G pairs with mRNA C, and — the one change from ordinary DNA pairing — template A pairs with mRNA U (uracil) instead of T, since RNA nucleotides use uracil rather than thymine."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where DNA transcription actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">DNA template strand (3'→5'), letters A/T/C/G only</span>
      <input id="dna" type="text" value="TACGGATCC" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">mRNA transcript (5'→3')</div>
      <div id="r-mrna" class="mt-1 break-all font-mono text-xl font-bold">—</div>
    </div>
    <p id="tr-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Transcription in 3D</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-template" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. DNA template strand</h3>
          <p class="mt-1 text-sm text-slate-600">A single strand of DNA bases (colored by type) — the strand RNA polymerase actually reads.</p>
        </div>
        <div>
          <div id="diag-pairing" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. mRNA base-pairing with the template</h3>
          <p class="mt-1 text-sm text-slate-600">The new mRNA strand (top) forming alongside the DNA template (bottom) it was copied from.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Base composition charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">DNA template base composition</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dna"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">mRNA transcript base composition</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mrna"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const PAIR = { T: 'A', A: 'U', C: 'G', G: 'C' };
      const COLORS = { A: 0x6366f1, T: 0xf59e0b, C: 0x10b981, G: 0xef4444, U: 0xa855f7 };

      function toMRNA(dna) {
        return dna.split('').map((b) => PAIR[b] || '').join('');
      }
      function update() {
        el('tr-err').textContent = '';
        const raw = (el('dna').value || '').toUpperCase().replace(/[^ATCG]/g, '');
        el('dna').value = el('dna').value.toUpperCase();
        if (!raw) { el('r-mrna').textContent = '—'; return; }
        el('r-mrna').textContent = toMRNA(raw);
      }
      el('dna').addEventListener('input', update);

      // ---- charts ----
      const charts = {};
      function composition(seq) {
        const counts = { A: 0, T: 0, C: 0, G: 0, U: 0 };
        seq.split('').forEach((b) => { if (counts[b] !== undefined) counts[b]++; });
        return counts;
      }
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const dnaSeq = 'TACGGATCC';
        const mrnaSeq = toMRNA(dnaSeq);
        const dnaComp = composition(dnaSeq);
        const mrnaComp = composition(mrnaSeq);
        charts.dna = new Chart(el('chart-dna'), {
          type: 'bar',
          data: { labels: ['A', 'T', 'C', 'G'], datasets: [{ label: 'Count', data: ['A', 'T', 'C', 'G'].map((b) => dnaComp[b]), backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Base count' } } }, plugins: { legend: { display: false } } }),
        });
        charts.mrna = new Chart(el('chart-mrna'), {
          type: 'bar',
          data: { labels: ['A', 'U', 'C', 'G'], datasets: [{ label: 'Count', data: ['A', 'U', 'C', 'G'].map((b) => mrnaComp[b]), backgroundColor: ['#6366f1', '#a855f7', '#10b981', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Base count' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function strandScene(container, seq, offsetY) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const n = seq.length;
        seq.split('').forEach((b, i) => {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.32, 14, 12), new THREE.MeshStandardMaterial({ color: COLORS[b] || 0x94a3b8 }));
          sph.position.set((i - n / 2) * 0.75, offsetY, 0);
          s.scene.add(sph);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function pairingScene(container) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const dnaSeq = 'TACGGATCC';
        const mrnaSeq = toMRNA(dnaSeq);
        const n = dnaSeq.length;
        dnaSeq.split('').forEach((b, i) => {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.28, 12, 10), new THREE.MeshStandardMaterial({ color: COLORS[b] || 0x94a3b8 }));
          sph.position.set((i - n / 2) * 0.75, -0.8, 0);
          s.scene.add(sph);
          const mSph = new THREE.Mesh(new THREE.SphereGeometry(0.28, 12, 10), new THREE.MeshStandardMaterial({ color: COLORS[mrnaSeq[i]] || 0x94a3b8 }));
          mSph.position.set((i - n / 2) * 0.75, 0.8, 0);
          s.scene.add(mSph);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagTemplate = null, diagPairing = null;
      function initDiagTemplate() { const c = el('diag-template'); if (!c) throw new Error('no container'); diagTemplate = strandScene(c, 'TACGGATCC', 0); }
      function initDiagPairing() { const c = el('diag-pairing'); if (!c) throw new Error('no container'); diagPairing = pairingScene(c); }

      function boot() {
        try { update(); } catch (e) { console.error('[dna-transcription] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[dna-transcription] charts failed', e); }
        if (window.THREE) {
          try { initDiagTemplate(); } catch (e) { console.error('[dna-transcription] template diagram failed', e); }
          try { initDiagPairing(); } catch (e) { console.error('[dna-transcription] pairing diagram failed', e); }
        }
        mountResize([diagTemplate, diagPairing]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
