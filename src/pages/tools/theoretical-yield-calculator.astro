---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Theoretical Yield Calculator';
const description = "Theoretical yield calculator with a live 3D reactant-to-product visualization and charts. Calculate theoretical yield from mass.";
const intro = 'Enter the mass and molar mass of your limiting reactant, plus the stoichiometric coefficients from the balanced equation, to calculate moles of product and the theoretical yield in grams.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is theoretical yield?', a: 'Theoretical yield is the maximum mass of product a reaction can form, calculated from the limiting reactant using stoichiometry, assuming complete conversion with no losses whatsoever.' },
  { q: 'How do you calculate theoretical yield?', a: 'Convert the limiting reactant\'s mass to moles (mass ÷ molar mass), convert to moles of product using the mole ratio from the balanced equation (coefficient of product ÷ coefficient of reactant), then convert moles of product to mass (moles × molar mass of product).' },
  { q: 'Why do I need a balanced equation first?', a: 'The mole ratio between reactant and product comes directly from the coefficients in the balanced equation. An unbalanced equation gives the wrong ratio and therefore the wrong theoretical yield — balance it first, for example with a chemical equation balancer.' },
  { q: 'Is theoretical yield the same as actual yield?', a: 'No. Theoretical yield is the calculated ideal maximum from stoichiometry. Actual yield is what you actually measure after running the reaction and purifying the product — it is almost always lower, due to side reactions, incomplete conversion and purification losses.' },
  { q: 'What if I have two reactants — which one do I use?', a: 'Use the limiting reactant — the one that runs out first and caps how much product can form. If you are not sure which reactant is limiting, use a limiting reagent calculator first to identify it, then feed its mass into this calculator.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Theoretical Yield Calculator',
  description: 'Calculate theoretical yield of a product from the mass of a limiting reactant and the balanced equation coefficients.',
  steps: [
    { name: 'Enter the reactant data', text: 'Type the mass and molar mass of the limiting reactant.' },
    { name: 'Enter the coefficients', text: 'Use the reactant and product coefficients from the balanced equation.' },
    { name: 'Enter the product molar mass', text: 'Type the molar mass of the product you are forming.' },
    { name: 'Read the theoretical yield', text: 'Moles of reactant, moles of product, and theoretical yield in grams solve instantly.' },
  ],
};

const formulas = [
  { expr: 'mol reactant = mass ÷ M<sub>reactant</sub>', note: 'mass to moles' },
  { expr: 'mol product = mol reactant × (coeff<sub>product</sub> ÷ coeff<sub>reactant</sub>)', note: 'mole ratio from balanced equation' },
  { expr: 'theoretical yield = mol product × M<sub>product</sub>', note: 'moles to mass of product' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — thermite reaction', tone: 'slate',
    given: '2 Al + Fe₂O₃ → Al₂O₃ + 2 Fe. You start with 10.0 g of Al (M = 26.98 g/mol), the limiting reactant. Find the theoretical yield of Fe (M = 55.85 g/mol).',
    rows: [
      { label: 'Moles Al:', value: '10.0 ÷ 26.98 = 0.3706 mol' },
      { label: 'Mole ratio Fe:Al:', value: '2 ÷ 2 = 1' },
      { label: 'Moles Fe:', value: '0.3706 × 1 = 0.3706 mol' },
      { label: 'Theoretical yield:', value: '0.3706 × 55.85 = 20.7 g Fe', full: true },
    ],
    note: 'A 1:1 mole ratio here means moles of product equal moles of reactant — the coefficients happen to match.',
  },
  {
    title: 'Worked example 2 — ammonia synthesis', tone: 'amber',
    given: 'N₂ + 3 H₂ → 2 NH₃. You start with 15.0 g of H₂ (M = 2.016 g/mol), the limiting reactant. Find the theoretical yield of NH₃ (M = 17.03 g/mol).',
    rows: [
      { label: 'Moles H₂:', value: '15.0 ÷ 2.016 = 7.440 mol' },
      { label: 'Mole ratio NH₃:H₂:', value: '2 ÷ 3 = 0.6667' },
      { label: 'Moles NH₃:', value: '7.440 × 0.6667 = 4.960 mol' },
      { label: 'Theoretical yield:', value: '4.960 × 17.03 = 84.5 g NH₃', full: true },
    ],
    note: 'Here the coefficients differ (3 vs 2), so the mole ratio noticeably shrinks the moles of product below the moles of reactant.',
  },
];

const comparison = {
  heading: 'How theoretical yield is calculated by reaction type',
  note: 'The core three-step chain (mass → mol → mol → mass) is identical; only the mole ratio changes.',
  headers: [{ label: 'Reaction type' }, { label: 'Example' }, { label: 'Mole ratio (product:reactant)' }],
  rows: [
    ['1:1 stoichiometry', '2 Al + Fe₂O₃ → Al₂O₃ + 2 Fe (Fe:Al)', '2:2 = 1.00'],
    ['Product ratio &lt; 1', 'N₂ + 3 H₂ → 2 NH₃ (NH₃:H₂)', '2:3 = 0.667'],
    ['Product ratio &gt; 1', '2 H₂ + O₂ → 2 H₂O (H₂O:H₂)', '2:2 = 1.00'],
    ['Decomposition', 'CaCO₃ → CaO + CO₂ (CaO:CaCO₃)', '1:1 = 1.00'],
  ],
  highlightIndex: 1,
  footnote: 'The mole ratio is always coefficient of product ÷ coefficient of the reactant you started from — read straight from the balanced equation.',
};

const realWorld = [
  { emoji: '🏭', title: 'Industrial process design', body: 'Chemical engineers calculate theoretical yield at the design stage to size reactors, estimate raw-material feed rates, and set production targets before a single batch is ever run.' },
  { emoji: '💊', title: 'Pharmaceutical batch planning', body: 'Before scaling up a drug synthesis, chemists calculate theoretical yield for every step to forecast how much active ingredient a batch of starting material can possibly produce, which drives costing and scheduling.' },
  { emoji: '🔬', title: 'Lab report grading', body: 'Instructors compare a student\'s reported yield against the correctly calculated theoretical yield to check both the student\'s stoichiometry and their lab technique — an error here throws off every yield calculation downstream.' },
];

const misconceptions = [
  { claim: '"Theoretical yield is just whatever number you plug into a yield formula."', truth: 'Theoretical yield is itself calculated — from the limiting reactant\'s mass, its molar mass, the mole ratio from the balanced equation, and the product\'s molar mass. It is not a given, it is derived.' },
  { claim: '"You can use either reactant\'s mass to calculate theoretical yield."', truth: 'Only the limiting reactant determines theoretical yield. Using the excess reactant overstates how much product could actually form, because the limiting reactant runs out first.' },
  { claim: '"The mole ratio is always 1:1."', truth: 'The mole ratio is coefficient of product ÷ coefficient of reactant from the balanced equation, and is only 1:1 when those coefficients happen to match — as in worked example 1, but not example 2.' },
  { claim: '"Theoretical yield can be achieved in the lab with careful technique."', truth: 'Theoretical yield assumes 100% conversion with zero losses — an idealized ceiling. Real reactions lose product to side reactions, incomplete conversion and purification, so actual yield is always at or below it.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 4.4, Reaction Yields (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/4-4-reaction-yields" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 3.6&ndash;3.7, Stoichiometric Calculations and Limiting Reactants.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Chapter 3, Stoichiometry, section on calculating theoretical yield.' },
];
const sourcesNote = 'Theoretical yield = (mass ÷ molar mass of reactant) × (coeff product ÷ coeff reactant) × molar mass of product. Use the limiting reactant\'s mass. Results are rounded for display.';

const howToUse = [
  { title: 'Enter reactant data', body: 'Mass (g) and molar mass (g/mol) of the limiting reactant.' },
  { title: 'Enter coefficients', body: 'Reactant and product coefficients from the balanced equation.' },
  { title: 'Enter product molar mass', body: 'g/mol of the product you are forming.' },
];

const related = [
  { href: '/tools/percent-yield-calculator', emoji: '🎯', title: 'Percent Yield Calculator', desc: 'Actual vs theoretical yield, solve any variable.' },
  { href: '/tools/limiting-reagent-calculator', emoji: '⚖️', title: 'Limiting Reagent Calculator', desc: 'Find which reactant runs out first.' },
  { href: '/tools/atomic-mass-calculator', emoji: '🔬', title: 'Molar Mass Calculator', desc: 'Molar mass from a chemical formula.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="theoretical yield is the mass of product a reaction could form if the limiting reactant converted completely — found by walking mass → moles → moles of product (via the mole ratio) → mass of product."
  howIntro="This calculator does the full stoichiometric chain for you: it converts the limiting reactant's mass to moles, applies the mole ratio (coefficient of product ÷ coefficient of reactant) from your balanced equation, and converts the resulting moles of product back to a mass. The output — theoretical yield — is exactly the number a <a href='/tools/percent-yield-calculator' class='text-indigo-500 hover:underline'>percent yield calculator</a> needs as its theoretical yield input, so the two tools chain together naturally."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where theoretical yield actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 p-4">
        <h3 class="text-sm font-bold text-indigo-700">Limiting reactant</h3>
        <label class="mt-2 block"><span class="text-sm font-medium text-slate-700">Mass (g)</span>
          <input id="r-mass" type="number" step="any" placeholder="g" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-2 block"><span class="text-sm font-medium text-slate-700">Molar mass (g/mol)</span>
          <input id="r-molar" type="number" step="any" placeholder="g/mol" value="26.98" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-2 block"><span class="text-sm font-medium text-slate-700">Coefficient (reactant)</span>
          <input id="r-coeff" type="number" step="1" min="1" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div class="rounded-xl border border-slate-200 p-4">
        <h3 class="text-sm font-bold text-green-700">Product</h3>
        <label class="mt-2 block"><span class="text-sm font-medium text-slate-700">Coefficient (product)</span>
          <input id="p-coeff" type="number" step="1" min="1" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="mt-2 block"><span class="text-sm font-medium text-slate-700">Molar mass (g/mol)</span>
          <input id="p-molar" type="number" step="any" placeholder="g/mol" value="55.85" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Moles reactant</div><div id="r-1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Moles product</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Theoretical yield</div><div id="r-3" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="ty-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-piles" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. The mole ratio can shrink or match the pile</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-indigo-600">left pile</span> (reactant, in moles) converts into the <span class="font-semibold text-emerald-600">right pile</span> (product, in moles) using the mole ratio from the balanced equation — here NH₃:H₂ = 2:3, so the product pile ends up smaller.</p>
        </div>
        <div>
          <div id="diag-bars" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Theoretical yield scales linearly with mass</h3>
          <p class="mt-1 text-sm text-slate-600">Three reactant masses, same mole ratio and molar masses — doubling the starting mass simply doubles the theoretical yield.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Theoretical yield graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Moles of product vs reactant mass (linear)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-molprod"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Theoretical yield vs product molar mass (fixed moles product)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-yieldmm"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('ty-err').textContent = '';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        const mass = parseFloat(el('r-mass').value), molar = parseFloat(el('r-molar').value);
        const rCoeff = parseFloat(el('r-coeff').value), pCoeff = parseFloat(el('p-coeff').value);
        const pMolar = parseFloat(el('p-molar').value);
        if ([mass, molar, rCoeff, pCoeff, pMolar].some((v) => isNaN(v))) return;
        if (molar <= 0 || pMolar <= 0) { el('ty-err').textContent = 'Molar masses must be positive.'; return; }
        if (rCoeff <= 0 || pCoeff <= 0) { el('ty-err').textContent = 'Coefficients must be positive.'; return; }
        if (mass < 0) { el('ty-err').textContent = 'Mass cannot be negative.'; return; }
        const molReactant = mass / molar;
        const molProduct = molReactant * (pCoeff / rCoeff);
        const theoYield = molProduct * pMolar;
        el('r-1').textContent = fmt(molReactant) + ' mol';
        el('r-2').textContent = fmt(molProduct) + ' mol';
        el('r-3').textContent = fmt(theoYield) + ' g';
        updateCharts();
      }
      ['r-mass', 'r-molar', 'r-coeff', 'p-coeff', 'p-molar'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.molprod = new Chart(el('chart-molprod'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'mol product', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0.1, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Reactant mass (g)' } }, y: { title: { display: true, text: 'Moles of product' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.yieldmm = new Chart(el('chart-yieldmm'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Theoretical yield (g)', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.1, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Product molar mass (g/mol)' } }, y: { title: { display: true, text: 'Theoretical yield (g)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts();
      }
      function updateCharts() {
        if (!charts.ready) return;
        const molar = parseFloat(el('r-molar').value), rCoeff = parseFloat(el('r-coeff').value);
        const pCoeff = parseFloat(el('p-coeff').value), pMolar = parseFloat(el('p-molar').value);
        if ([molar, rCoeff, pCoeff, pMolar].some((v) => isNaN(v) || v <= 0)) return;

        const L1 = [], D1 = [];
        for (let m = 1; m <= 50.001; m += 1) {
          const molReactant = m / molar;
          const molProduct = molReactant * (pCoeff / rCoeff);
          L1.push(m.toFixed(0)); D1.push(+molProduct.toFixed(4));
        }
        charts.molprod.data.labels = L1; charts.molprod.data.datasets[0].data = D1; charts.molprod.update();

        const mass = parseFloat(el('r-mass').value) || 10;
        const molReactant = mass / molar;
        const molProduct = molReactant * (pCoeff / rCoeff);
        const L2 = [], D2 = [];
        for (let mm = 10; mm <= 250.001; mm += 10) { L2.push(mm.toFixed(0)); D2.push(+(molProduct * mm).toFixed(4)); }
        charts.yieldmm.data.labels = L2; charts.yieldmm.data.datasets[0].data = D2; charts.yieldmm.update();
      }

      // ---- standalone 3D diagrams (static, auto-rotating) ----
      function pileLayout(pile, count, cx) {
        const perRow = 6;
        for (let i = 0; i < pile.length; i++) {
          const p = pile[i];
          if (i < count) {
            const row = Math.floor(i / perRow), col = i % perRow;
            p.position.set(cx + (col - (perRow - 1) / 2) * 0.85, row * 0.85 - 2, 0);
            p.visible = true;
          } else p.visible = false;
        }
      }

      // ---- diagram 1: reactant pile -> product pile (static, mole-ratio 2:3 example) ----
      function initDiagPiles() {
        const c = el('diag-piles'); if (!c) throw new Error('no container');
        const s = makeScene(c, 14, new THREE.Vector3(0, 0, 0), SCENE_OPTS);
        const matR = new THREE.MeshStandardMaterial({ color: 0x6366f1 });
        const matP = new THREE.MeshStandardMaterial({ color: 0x10b981 });
        const MAX_P = 24;
        const geo = new THREE.SphereGeometry(0.35, 12, 12);
        const pilesR = [], pilesP = [];
        for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(geo, matR); p.visible = false; s.scene.add(p); pilesR.push(p); }
        for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(geo, matP); p.visible = false; s.scene.add(p); pilesP.push(p); }
        pileLayout(pilesR, 18, -3.2);           // reactant: 18 units
        pileLayout(pilesP, 12, 3.2);            // product: 18 * (2/3) = 12 units
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagPiles = { resize: s.resize };
      }

      // ---- diagram 2: theoretical-yield bars for three illustrative reactant masses ----
      function initDiagBars() {
        const c = el('diag-bars'); if (!c) throw new Error('no container');
        const s = makeScene(c, 14, new THREE.Vector3(0, 1.2, 0), SCENE_OPTS);
        const grid = new THREE.GridHelper(10, 10, 0xe2e8f0, 0xeef2f7); s.scene.add(grid);
        const masses = [10, 20, 30]; // g, illustrative
        const spacing = 2.4, startX = -spacing;
        masses.forEach((m, i) => {
          const h = (m / 30) * 4.5;
          const bar = new THREE.Mesh(new THREE.BoxGeometry(1.2, h, 1.2), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          bar.position.set(startX + i * spacing, -2.25 + h / 2, 0);
          s.scene.add(bar);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagBars = { resize: s.resize };
      }
      let diagPiles = null, diagBars = null;

      function boot() {
        try { update(); } catch (e) { console.error('[theoretical-yield] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[theoretical-yield] charts failed', e); }
        if (window.THREE) {
          try { initDiagPiles(); } catch (e) { console.error('[theoretical-yield] piles diagram failed', e); }
          try { initDiagBars(); } catch (e) { console.error('[theoretical-yield] bars diagram failed', e); }
        }
        mountResize([diagPiles, diagBars]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
