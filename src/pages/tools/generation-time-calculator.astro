---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Generation (Doubling) Time Calculator';
const description = 'Generation time calculator with a live 3D cell division diagram and charts. Solve g = t/n for microbial generation (doubling) time from population counts, using n = log2(Nt/N0), with worked examples.';
const intro = 'Solve g = t/n for the average generation (doubling) time of a growing population — first finding the number of generations n that occurred using n = log₂(Nt/N0), then dividing the elapsed time by that count. Two 3D diagrams compare a population after few generations to one after many, and charts show how generation count and doubling time relate across a range of population growth.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is generation time?', a: 'Generation time (also called doubling time) is the average time it takes for a population to double in size — for bacteria specifically, it\'s the average time for one round of cell division across the whole population.' },
  { q: 'How do you find the number of generations from population counts?', a: 'Each generation doubles the population, so the number of generations n satisfies Nt = N0 × 2ⁿ. Solving for n gives n = log₂(Nt/N0), which can also be computed as n = 3.3 × log₁₀(Nt/N0) using base-10 logarithms.' },
  { q: 'How is this different from the Bacterial Growth Rate Calculator?', a: 'The Bacterial Growth Rate Calculator solves for the continuous exponential growth rate constant k. This calculator instead counts whole generations (doublings) directly and divides elapsed time by that count — a more intuitive, discrete way of expressing the same underlying growth speed.' },
  { q: 'Why is generation time useful in microbiology labs?', a: 'It gives a simple, intuitive number for planning experiments — knowing a culture doubles every 20 minutes tells you exactly how long to incubate it to reach a target cell density.' },
  { q: 'Does generation time have to be a whole number?', a: 'No — while the number of generations (n) in a real growth period is usually treated as continuous rather than a whole number, generation time itself is simply an average rate and can be any positive value, like 27.4 minutes.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Generation (Doubling) Time Calculator',
  description: 'Solve g = t/n for generation time from population counts and elapsed time.',
  steps: [
    { name: 'Enter initial and final population', text: 'Type the population count at the start (N0) and after some elapsed time (Nt).' },
    { name: 'Enter elapsed time', text: 'Provide the time between the two counts.' },
    { name: 'Read the generation time', text: 'The number of generations and the average generation time solve instantly.' },
  ],
};

const formulas = [
  { expr: 'n = log₂(Nt/N0)', note: 'number of generations (doublings) that occurred' },
  { expr: 'g = t / n', note: 'generation (doubling) time — total elapsed time divided by number of generations' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — three doublings in two hours', tone: 'slate',
    given: 'A culture grows from N0 = 100 to Nt = 800 cells over t = 2 hours.',
    rows: [
      { label: 'Number of generations:', value: 'n = log₂(800/100) = log₂(8) = 3' },
      { label: 'Formula:', value: 'g = t / n' },
      { label: 'Result:', value: 'g = 2/3 hours ≈ 40 minutes per generation', full: true },
    ],
    note: 'The population exactly doubled three times (100→200→400→800), which is why n comes out to a clean whole number here.',
  },
  {
    title: 'Worked example 2 — a longer growth period', tone: 'amber',
    given: 'A culture grows from N0 = 500 to Nt = 16,000 cells over t = 4 hours.',
    rows: [
      { label: 'Number of generations:', value: 'n = log₂(16000/500) = log₂(32) = 5' },
      { label: 'Formula:', value: 'g = t / n' },
      { label: 'Result:', value: 'g = 4/5 hours = 48 minutes per generation', full: true },
    ],
    note: 'This matches a well-known fast-growing organism\'s doubling time range, illustrating how quickly bacterial populations can multiply under ideal conditions.',
  },
];

const comparison = {
  heading: 'Generation time for common organisms (approximate, ideal conditions)',
  note: 'Generation time varies enormously across different microorganisms.',
  headers: [{ label: 'Organism' }, { label: 'Approx. generation time' }],
  rows: [
    ['E. coli (ideal lab conditions) ★', '~20 minutes'],
    ['Vibrio natriegens (fastest known bacterium)', '~10 minutes'],
    ['Mycobacterium tuberculosis', '~24 hours'],
    ['Slow environmental soil bacteria', 'Days'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row. E. coli\'s roughly 20-minute generation time under ideal lab conditions is one of the most commonly cited benchmarks in microbiology teaching.',
};

const realWorld = [
  { emoji: '🧫', title: 'Planning lab culture experiments', body: 'Knowing a microorganism\'s generation time lets researchers precisely predict how long to incubate a culture to reach a target cell density for downstream experiments.' },
  { emoji: '🏭', title: 'Industrial biotechnology scheduling', body: 'Fermentation and bioreactor operations schedule batch cycles around known generation times to maximize the number of production runs per day.' },
  { emoji: '💊', title: 'Predicting infection progression', body: 'Estimating a pathogen\'s generation time in the body helps clinicians and epidemiologists model how quickly an infection or outbreak might progress.' },
  { emoji: '🔬', title: 'Comparing microbial species', body: 'Generation time is one of the simplest, most direct ways to compare the growth potential of different microbial species under the same conditions.' },
];

const misconceptions = [
  { claim: '"Generation time is the time for a single individual cell to divide once."', truth: "Generation time is a population-average measure — it describes how quickly the population as a whole doubles, not necessarily how long any one specific cell takes, since individual division times naturally vary somewhat within a population." },
  { claim: '"A shorter generation time means a species is more evolutionarily advanced."', truth: "Generation time reflects metabolic and environmental factors, not evolutionary sophistication — many simple, ancient bacterial lineages have extremely short generation times, while some complex organisms reproduce far more slowly." },
  { claim: '"Generation time stays exactly the same throughout an entire culture\'s growth."', truth: 'Generation time is fastest and most consistent during the exponential (log) phase — as nutrients deplete or the population approaches carrying capacity, the effective generation time lengthens considerably.' },
  { claim: '"You need to directly observe and count individual cell divisions to measure generation time."', truth: "Generation time can be calculated entirely from just two population counts and the elapsed time between them, using g = t/n — no direct observation of individual divisions is required." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Microbiology</em></strong> — Chapter 9, "Microbial Growth" (free, peer-reviewed). <a href="https://openstax.org/books/microbiology/pages/9-1-how-microbes-grow" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Madigan et al., <em>Brock Biology of Microorganisms</em></strong> — Bacterial growth and generation time chapter.' },
  { html: '<strong>Tortora, Funke &amp; Case, <em>Microbiology: An Introduction</em></strong> — Microbial growth measurement chapter.' },
];
const sourcesNote = 'n = log₂(Nt/N0); g = t/n. Assumes exponential (log-phase) growth throughout the observed interval. Results are rounded for display.';

const howToUse = [
  { title: 'Enter population counts', body: 'Type the starting population (N0) and the population after growth (Nt).' },
  { title: 'Enter elapsed time', body: 'Provide the total time between the two measurements.' },
  { title: 'Read generation count and time', body: 'Both the number of generations and the average time per generation solve instantly.' },
];

const related = [
  { href: '/tools/bacterial-growth-rate-calculator', emoji: '⏱️', title: 'Bacterial Growth Rate Calculator', desc: 'k = ln(Nt/N0)/t — the continuous growth rate constant.' },
  { href: '/tools/microbial-growth-curve-calculator', emoji: '📈', title: 'Microbial Growth Curve Plotter', desc: 'Visualize lag, log, stationary, and death phases.' },
  { href: '/tools/serial-dilution-calculator', emoji: '🧫', title: 'Serial Dilution Calculator', desc: 'Dilution factor per step and cumulative dilution.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="counting exactly how many times a population must have doubled to get from its starting size to its ending size turns a growth curve into a single, easy-to-compare number: the average time each doubling took."
  howIntro="Because each generation doubles a population's size, going from N0 to Nt requires exactly n doublings, where 2ⁿ = Nt/N0 — solved directly as n = log₂(Nt/N0). Once you know how many generations actually occurred, dividing the total elapsed time by that count gives the average generation time, a single intuitive number describing how quickly that population reproduces. This discrete, doubling-counted view is mathematically equivalent to the continuous growth-rate-constant approach, but many microbiologists find it more directly meaningful for planning lab work."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where generation time actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial population (N0)</span>
        <input id="n0" type="number" step="any" value="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Final population (Nt)</span>
        <input id="nt" type="number" step="any" value="800" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Elapsed time, t (hours)</span>
        <input id="t" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Number of generations (n)</div><div id="r-n" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Generation time (g)</div><div id="r-g" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="gt-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Few generations vs. many generations</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-few" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Few generations elapsed</h3>
          <p class="mt-1 text-sm text-slate-600">A small number of doublings have occurred — fewer, larger cell clusters.</p>
        </div>
        <div>
          <div id="diag-many" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Many generations elapsed</h3>
          <p class="mt-1 text-sm text-slate-600">Many more doublings have occurred — many more, smaller-looking cell clusters.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Generation time graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Population after n generations (starting at 100)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-gens"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Generation time comparison by organism</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-species"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('gt-err').textContent = '';
        el('r-n').textContent = '—'; el('r-g').textContent = '—';
        const n0 = parseFloat(el('n0').value), nt = parseFloat(el('nt').value), t = parseFloat(el('t').value);
        if (isNaN(n0) || isNaN(nt) || isNaN(t)) return;
        if (n0 <= 0 || nt <= 0 || t <= 0) { el('gt-err').textContent = 'Population counts and time must be positive.'; return; }
        if (nt < n0) { el('gt-err').textContent = 'Final population must be greater than or equal to initial population.'; return; }
        const n = Math.log(nt / n0) / Math.log(2);
        el('r-n').textContent = fmt(n);
        if (n > 0) el('r-g').textContent = fmt(t / n) + ' hr';
        else el('r-g').textContent = 'N/A (no growth)';
      }
      ['n0', 'nt', 't'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const genLabels = [], genData = [];
        for (let n = 0; n <= 8; n++) { genLabels.push(n); genData.push(100 * Math.pow(2, n)); }
        new Chart(el('chart-gens'), {
          type: 'bar',
          data: { labels: genLabels, datasets: [{ label: 'Population', data: genData, backgroundColor: '#6366f1' }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Generations (n)' } }, y: { type: 'logarithmic', title: { display: true, text: 'Population' } } }, plugins: { legend: { display: false } } }),
        });
        new Chart(el('chart-species'), {
          type: 'bar',
          data: { labels: ['V. natriegens', 'E. coli', 'M. tuberculosis (÷100)', 'Slow soil bacteria (÷1000)'], datasets: [{ label: 'Relative generation time (minutes, scaled)', data: [10, 20, 14.4, 1440], backgroundColor: ['#10b981', '#6366f1', '#f59e0b', '#94a3b8'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Minutes (log scale, some values scaled for comparison)' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function clusterScene(container, clusterCount, clusterSize) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < clusterCount; i++) {
          const cx = (Math.random() - 0.5) * 4, cy = (Math.random() - 0.5) * 3, cz = (Math.random() - 0.5) * 2;
          for (let j = 0; j < clusterSize; j++) {
            const m = new THREE.Mesh(new THREE.SphereGeometry(0.16, 8, 6), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
            m.position.set(cx + (Math.random() - 0.5) * 0.5, cy + (Math.random() - 0.5) * 0.5, cz + (Math.random() - 0.5) * 0.5);
            s.scene.add(m);
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagFew = null, diagMany = null;
      function initDiagFew() { const c = el('diag-few'); if (!c) throw new Error('no container'); diagFew = clusterScene(c, 3, 3); }
      function initDiagMany() { const c = el('diag-many'); if (!c) throw new Error('no container'); diagMany = clusterScene(c, 8, 4); }

      function boot() {
        try { update(); } catch (e) { console.error('[generation-time] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[generation-time] charts failed', e); }
        if (window.THREE) {
          try { initDiagFew(); } catch (e) { console.error('[generation-time] few-generations diagram failed', e); }
          try { initDiagMany(); } catch (e) { console.error('[generation-time] many-generations diagram failed', e); }
        }
        mountResize([diagFew, diagMany]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
