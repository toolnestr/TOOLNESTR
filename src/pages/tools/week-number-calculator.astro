---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Week Number Calculator';
const description =
  'Free online week number calculator. Find the ISO week number, week of the year and year for any date.';
const intro =
  'Select any date to see its ISO week number, day of the week, and which week of the year it falls in.';
const category = { id: 'time-date', name: 'Time & Date' };
const faqs = [
  { q: 'What is an ISO week number?', a: 'The ISO week date system (ISO 8601) assigns a week number to each week of the year. Weeks start on Monday, and week 1 is the week containing the first Thursday of the year.' },
  { q: 'How is the week year different from the calendar year?', a: 'The week year can differ from the calendar year. For example, January 1 may belong to week 52 or 53 of the previous year, making its week year the previous year.' },
  { q: 'When does week 1 of the year start?', a: 'Week 1 is the week that contains the first Thursday of the Gregorian year. It always starts on the Monday of that week.' },
  { q: 'How many weeks are in a year?', a: 'Most years have 52 weeks. A year has 53 weeks if the year starts on a Thursday (common year) or on a Wednesday or Thursday (leap year).' },
  { q: 'What is the day of year?', a: 'Day of year is a number from 1 to 365 (or 366 in a leap year) representing the sequential day count from January 1.' },
  { q: 'What quarter is a date in?', a: 'Q1 is January–March, Q2 is April–June, Q3 is July–September, Q4 is October–December.' },
  { q: 'What week of the month is it?', a: 'Week of the month counts which occurrence of that weekday within the month. For example, the second Monday of the month.' },
  { q: 'Can I see the date range of a week?', a: 'Yes. The calculator shows the Monday and Sunday dates of the week the selected date falls in.' },
  { q: 'Does it work for dates far in the past or future?', a: 'The ISO week algorithm works for any date that JavaScript can represent, covering roughly year 1 to year 9999.' },
  { q: 'Why do some years have 53 weeks?', a: 'A year has 53 weeks if it starts on a Thursday (common year) or on a Wednesday if a leap year. This ensures the first Thursday rule is satisfied.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 space-y-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Select a date</span>
        <input id="date-picker" type="date" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>

      <div id="results" class="mt-6 hidden">
        <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
          <div class="text-sm opacity-80">ISO Week Number</div>
          <div id="iso-week" class="mt-1 text-3xl font-bold">—</div>
        </div>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="week-year" class="text-base font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Week Year</div></div>
          <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="day-of-week" class="text-lg font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Day of Week</div></div>
          <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="day-of-year" class="text-lg font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Day of Year</div></div>
          <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="quarter" class="text-lg font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Quarter</div></div>
        </div>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
          <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="week-of-month" class="text-lg font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Week of Month</div></div>
          <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="week-start" class="text-base font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Week Start (Mon)</div></div>
          <div class="rounded-xl bg-slate-50 p-3 text-center"><div id="week-end" class="text-base font-bold text-slate-800">—</div><div class="text-xs text-slate-500">Week End (Sun)</div></div>
        </div>
      </div>
      <p id="calc-hint" class="mt-4 text-center text-sm text-slate-400">Pick a date to see its week information.</p>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Week number distribution across the year</h2>
    <p class="mt-2 text-slate-600">How many days fall in each ISO week number during a typical year.</p>
    <div id="dist-chart" class="mt-5 space-y-1 max-h-80 overflow-y-auto"></div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Project Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Uses ISO week numbers for sprint planning, milestone tracking and reporting in agile software development workflows.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Payroll Admin</h3>
      <p class="mt-1 text-sm text-slate-600">Determines which pay period a date falls into, especially for weekly or bi-weekly payroll cycles that follow ISO weeks.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Plans lessons by week number, aligns curriculum with school term weeks and schedules exams in specific weeks of the year.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F389;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Event Planner</h3>
      <p class="mt-1 text-sm text-slate-600">Coordinates events by week number to simplify scheduling across different organizations and industries.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Date</th><th class="p-3">ISO Week</th><th class="p-3">Week Year</th><th class="p-3">Notes</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Jan 1 (normal year)</td><td class="p-3">1</td><td class="p-3">Same year</td><td class="p-3">Jan 1 is in week 1 if it is Monday–Wednesday; week 52/53 if Thursday–Sunday</td></tr>
        <tr><td class="p-3 font-medium">Jan 1 (leap year)</td><td class="p-3">1</td><td class="p-3">Same year</td><td class="p-3">Same rule applies regardless of leap year</td></tr>
        <tr><td class="p-3 font-medium">Dec 31</td><td class="p-3">52 or 53</td><td class="p-3">Same or next</td><td class="p-3">Can be week 1 of the next year if Dec 31 is Monday</td></tr>
        <tr><td class="p-3 font-medium">First Thursday</td><td class="p-3">1</td><td class="p-3">Same year</td><td class="p-3">Week 1 always contains the first Thursday</td></tr>
        <tr><td class="p-3 font-medium">Feb 29 (leap)</td><td class="p-3">9</td><td class="p-3">Same year</td><td class="p-3">Always in week 9</td></tr>
        <tr><td class="p-3 font-medium">Jun 30</td><td class="p-3">26 or 27</td><td class="p-3">Same year</td><td class="p-3">Mid-year boundary, varies by year</td></tr>
        <tr><td class="p-3 font-medium">Sep 30</td><td class="p-3">39 or 40</td><td class="p-3">Same year</td><td class="p-3">End of Q3</td></tr>
        <tr><td class="p-3 font-medium">Dec 25</td><td class="p-3">51 or 52</td><td class="p-3">Same year</td><td class="p-3">Christmas always near end of year</td></tr>
        <tr><td class="p-3 font-medium">53-week year example</td><td class="p-3">53</td><td class="p-3">Same year</td><td class="p-3">2026 has 53 ISO weeks (Jan 1 is Thursday)</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Week Number Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a date</h3>
        <p class="mt-1 text-sm text-slate-600">Use the date picker to select any date you want to analyze.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Review ISO week data</h3>
        <p class="mt-1 text-sm text-slate-600">See the ISO week number, week year, day of week, day of year and quarter all at once.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check week boundaries</h3>
        <p class="mt-1 text-sm text-slate-600">View the Monday start and Sunday end dates of the week, plus which occurrence of that weekday within the month.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with week numbers</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">ISO vs US week numbering</h3>
        <p class="mt-1 text-sm text-slate-600">ISO weeks start on Monday and week 1 is defined by the first Thursday. In the US system, weeks start on Sunday and week 1 always starts on January 1. Make sure you know which system your organization uses.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Week year matters for reporting</h3>
        <p class="mt-1 text-sm text-slate-600">When tracking metrics by week, use the week year (not the calendar year) to keep weeks together. January 1 may belong to the previous year's last week, and reporting it under that year's data is more consistent.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">53-week years are rare</h3>
        <p class="mt-1 text-sm text-slate-600">Only about 4–5 years in a 28-year cycle have 53 weeks. 2026 is one of them. If your payroll or planning system needs to handle 53-week years, make sure it accounts for the extra period.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is ISO week number</h2>
    <p class="mt-2 text-slate-600">ISO 8601 defines a week date system where weeks start on Monday. Week 1 of a year is the week that contains the first Thursday of that year. This means the first few days of January may belong to week 52 or 53 of the previous year, and the last days of December may belong to week 1 of the next year.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How week numbering works</h2>
    <p class="mt-2 text-slate-600">The ISO week calculation uses the first Thursday rule: find the Thursday of the same week as the target date, then compute (ordinal day of that Thursday - 1) / 7 + 1. The week year of the target date is the year of that Thursday. This ensures every week has exactly 7 days and belongs to exactly one year.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Date:</span> <span class="text-slate-600">January 1, 2026</span></div>
        <div><span class="font-medium text-slate-700">ISO week:</span> <span class="text-slate-600">Week 1 (if Thu-Sat) or Week 53/1</span></div>
        <div><span class="font-medium text-slate-700">ISO rule:</span> <span class="text-slate-600">First Thursday determines week 1</span></div>
        <div><span class="font-medium text-slate-700">Week year:</span> <span class="text-slate-600">2026 (starts on Thursday, so 53 weeks)</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Week year vs calendar year</h2>
    <p class="mt-2 text-slate-600">The week year (also called ISO year) can differ from the Gregorian calendar year. For example, January 1, 2027 is a Friday, which means it falls in week 53 of ISO year 2026. The week year is 2026, not 2027. This is important for any system that groups data by week for reporting or analysis.</p>
  </section>

  <script is:inline>
    const el = id => document.getElementById(id);
    const datePicker = el('date-picker');
    const results = el('results');
    const hint = el('calc-hint');

    datePicker.value = new Date().toISOString().slice(0, 10);

    function getISOWeek(d) {
      const temp = new Date(d.getTime());
      const dayNum = (temp.getDay() + 6) % 7;
      temp.setDate(temp.getDate() - dayNum + 3);
      const firstThursday = temp.getTime();
      temp.setMonth(0, 1);
      if (temp.getDay() !== 4) {
        temp.setMonth(0, 1 + ((4 - temp.getDay()) + 7) % 7);
      }
      const weekNum = 1 + Math.round((firstThursday - temp.getTime()) / 604800000);
      return weekNum;
    }

    function getWeekYear(d) {
      const temp = new Date(d.getTime());
      const dayNum = (temp.getDay() + 6) % 7;
      temp.setDate(temp.getDate() - dayNum + 3);
      return temp.getFullYear();
    }

    function getDayOfYear(d) {
      const start = new Date(d.getFullYear(), 0, 0);
      return Math.floor((d - start) / 86400000);
    }

    function getQuarter(d) {
      const m = d.getMonth();
      return Math.floor(m / 3) + 1;
    }

    function getWeekOfMonth(d) {
      const day = d.getDate();
      const weekday = d.getDay();
      const firstOccurrence = 1 + (weekday - new Date(d.getFullYear(), d.getMonth(), 1).getDay() + 7) % 7;
      return Math.ceil((day - firstOccurrence + 1) / 7);
    }

    function getWeekRange(d) {
      const day = d.getDay();
      const diffToMon = (day === 0 ? -6 : 1 - day);
      const mon = new Date(d);
      mon.setDate(d.getDate() + diffToMon);
      const sun = new Date(mon);
      sun.setDate(mon.getDate() + 6);
      return { mon, sun };
    }

    function update() {
      if (!datePicker.value) return;
      const d = new Date(datePicker.value + 'T12:00:00');

      const isoWeek = getISOWeek(d);
      const weekYear = getWeekYear(d);
      const dayOfWeek = d.toLocaleDateString('en', { weekday: 'long' });
      const dayOfYear = getDayOfYear(d);
      const quarter = 'Q' + getQuarter(d);
      const weekOfMonth = getWeekOfMonth(d);
      const range = getWeekRange(d);

      el('iso-week').textContent = isoWeek;
      el('week-year').textContent = weekYear;
      el('day-of-week').textContent = dayOfWeek;
      el('day-of-year').textContent = dayOfYear;
      el('quarter').textContent = quarter;
      el('week-of-month').textContent = weekOfMonth;

      const opts = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
      el('week-start').textContent = range.mon.toLocaleDateString('en', opts);
      el('week-end').textContent = range.sun.toLocaleDateString('en', opts);

      results.classList.remove('hidden');
      hint.classList.add('hidden');
    }

    function renderDistribution() {
      const chart = document.getElementById('dist-chart');
      const year = new Date().getFullYear();
      const weeks = {};
      for (let m = 0; m < 12; m++) {
        const daysInMonth = new Date(year, m + 1, 0).getDate();
        for (let day = 1; day <= daysInMonth; day++) {
          const d = new Date(year, m, day);
          const w = getISOWeek(d);
          weeks[w] = (weeks[w] || 0) + 1;
        }
      }
      const maxCount = Math.max(...Object.values(weeks), 1);
      chart.innerHTML = Object.entries(weeks).sort((a, b) => Number(a[0]) - Number(b[0])).map(([w, count]) => {
        const pct = (count / maxCount) * 100;
        return `<div>
          <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Week ${w}</span><span class="text-slate-400">${count} days</span></div>
          <div class="mt-0.5 h-2 w-full rounded-full bg-slate-100"><div class="h-2 rounded-full bg-indigo-500" style="width:${pct}%"></div></div>
        </div>`;
      }).join('');
    }

    datePicker.addEventListener('change', update);
    update();
    renderDistribution();
  </script>
</ToolLayout>
