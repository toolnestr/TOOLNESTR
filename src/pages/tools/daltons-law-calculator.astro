---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Dalton's Law (Partial Pressure) Calculator";
const description = "Dalton's Law of partial pressures calculator with a live 3D gas-mixture diagram and charts. Sum up to 4 partial pressures, or find partial pressures from mole fractions.";
const intro = "Add up partial pressures with P_total = P1 + P2 + P3 + P4, or work the other way from mole fractions and total pressure. Static 3D diagrams and charts show how a gas mixture's total pressure comes from each gas contributing independently.";
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is Dalton's law of partial pressures?", a: "Dalton's law states that the total pressure of a mixture of non-reacting gases equals the sum of the partial pressures each gas would exert if it alone occupied the whole container: P_total = P1 + P2 + P3 + ... Each gas behaves as if the others were not there." },
  { q: 'What is a partial pressure?', a: 'The partial pressure of a gas in a mixture is the pressure that gas alone would exert if it occupied the entire container at the same temperature. It depends only on how many molecules of that gas are present and the container volume and temperature — not on what other gases share the space.' },
  { q: 'How does mole fraction relate to partial pressure?', a: 'The partial pressure of a component equals its mole fraction times the total pressure: Pi = Xi × P_total, where Xi = ni / n_total. This is often the fastest way to find a partial pressure when you know the composition of a mixture and its total pressure.' },
  { q: 'Does Dalton\'s law apply to real (non-ideal) gases?', a: "Dalton's law is exact for ideal gases and a very good approximation for most real gas mixtures at ordinary pressures and temperatures, where intermolecular interactions are small. At very high pressure or low temperature, real gases deviate and the simple additive rule becomes less accurate." },
  { q: 'Why is Dalton\'s law used for collecting gas over water?', a: 'When a gas is collected by displacing water, the collected sample is actually a mixture of the target gas plus water vapor. Dalton\'s law lets you subtract the known vapor pressure of water at that temperature from the total measured pressure to isolate the partial pressure of the gas you actually collected.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: "How to use the Dalton's Law Calculator",
  description: 'Sum partial pressures to find total pressure, or find each partial pressure from mole fractions and total pressure.',
  steps: [
    { name: 'Pick a mode', text: '"Sum pressures" adds up to 4 partial pressures. "From mole fractions" finds each partial pressure from Xi and P_total.' },
    { name: 'Enter the values', text: 'Type each partial pressure, or each mole fraction plus the total pressure.' },
    { name: 'Read the result', text: 'The total pressure (or each partial pressure) solves instantly.' },
  ],
};

const formulas = [
  { expr: 'P<sub>total</sub> = P₁ + P₂ + P₃ + P₄', note: 'sum of partial pressures of each gas' },
  { expr: 'P<sub>i</sub> = X<sub>i</sub> × P<sub>total</sub>', note: 'partial pressure from mole fraction, X<sub>i</sub> = n<sub>i</sub>/n<sub>total</sub>' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — approximate composition of air', tone: 'slate',
    given: 'A gas mixture approximating dry air: P(N₂) = 0.780 atm, P(O₂) = 0.210 atm, P(Ar) = 0.0093 atm, P(CO₂) = 0.0004 atm. Find the total pressure.',
    rows: [
      { label: 'Sum:', value: 'P_total = 0.780 + 0.210 + 0.0093 + 0.0004' },
      { label: 'Total pressure:', value: 'P_total = 0.9997 ≈ 1.00 atm', full: true },
    ],
    note: 'The four partial pressures sum to almost exactly 1.00 atm — consistent with dry air at roughly 1 atm total pressure.',
  },
  {
    title: 'Worked example 2 — partial pressure from mole fraction', tone: 'amber',
    given: 'A cylinder holds a mixture of O₂ and N₂ at a total pressure of 5.00 atm. The mole fraction of O₂ is 0.30. Find the partial pressure of O₂.',
    rows: [
      { label: 'Formula:', value: 'P(O₂) = X(O₂) × P_total' },
      { label: 'Substitute:', value: 'P(O₂) = 0.30 × 5.00 atm' },
      { label: 'Partial pressure:', value: 'P(O₂) = 1.50 atm', full: true },
    ],
    note: 'The remaining mole fraction (0.70) belongs to N₂, giving P(N₂) = 0.70 × 5.00 = 3.50 atm, and 1.50 + 3.50 = 5.00 atm checks out.',
  },
];

const comparison = {
  heading: 'Approximate composition of dry air at sea level',
  note: 'Partial pressures at a total pressure of 1 atm — the classic textbook example of Dalton\'s law.',
  headers: [{ label: 'Gas' }, { label: 'Mole fraction' }, { label: 'Partial pressure (atm)' }],
  rows: [
    ['Nitrogen (N₂)', '0.780', '0.780'],
    ['Oxygen (O₂)', '0.210', '0.210'],
    ['Argon (Ar)', '0.0093', '0.0093'],
    ['Carbon dioxide (CO₂)', '0.0004', '0.0004'],
  ],
  highlightIndex: 1,
  footnote: 'Mole fraction and partial pressure (in atm, at 1 atm total) are numerically identical — a handy shortcut for gas mixtures at 1 atm total pressure.',
};

const realWorld = [
  { emoji: '🤿', title: 'Scuba diving gas mixtures', body: "Divers breathe mixtures like nitrox or trimix where the partial pressure of oxygen and nitrogen must stay within safe limits. Dalton's law lets divers calculate each gas's partial pressure at depth, where ambient pressure — and therefore every partial pressure — rises." },
  { emoji: '🫁', title: 'Respiratory physiology', body: 'Oxygen moves from lungs to blood because its partial pressure in the alveoli is higher than in venous blood. Clinicians track arterial partial pressures of O₂ and CO₂ (PaO₂, PaCO₂) as core measures of lung function.' },
  { emoji: '🧪', title: 'Collecting gas over water', body: "When a gas is collected by water displacement in the lab, the container also holds water vapor. Subtracting water's known vapor pressure from the total measured pressure isolates the partial pressure of the actual gas produced." },
  { emoji: '🏭', title: 'Industrial gas blending', body: "Manufacturers of specialty gas mixtures — welding gases, calibration standards, medical gas blends — rely on Dalton's law to blend components to an exact total pressure and composition." },
];

const misconceptions = [
  { claim: '"Each gas in a mixture exerts less pressure because it shares space with others."', truth: "A gas's partial pressure depends on how many of its own molecules are present, not on sharing space — each gas behaves as though it alone filled the container. Adding more of a different gas does not reduce the first gas's partial pressure at all." },
  { claim: '"Mole fraction and partial pressure are always numerically the same."', truth: 'They are only numerically equal (in atm) when the total pressure is exactly 1 atm, since Pi = Xi × P_total. At any other total pressure, you must multiply the mole fraction by that total to get the partial pressure.' },
  { claim: '"Dalton\'s law only works for exactly two gases."', truth: "It applies to any number of non-reacting gases in a mixture — the sum simply has more terms. The calculator here supports up to four gases, and the same additive logic extends to as many components as the mixture contains." },
  { claim: '"Partial pressure means the gas is only partially present."', truth: "\"Partial\" refers to that gas's share of the total pressure, not an incomplete amount of the gas. The gas is fully present at its actual concentration — partial pressure is simply the pressure contribution attributable to it." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 9, Gases: Dalton\'s law of partial pressures (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/9-3-stoichiometry-of-gaseous-substances-mixtures-and-reactions" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 10, Gases.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — partial pressures and gas mixtures.' },
];
const sourcesNote = 'P_total = ΣPi; Pi = Xi × P_total. Air composition figures are standard approximate reference values. Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"Sum pressures" totals up to four partial pressures; "From mole fractions" finds each Pi from Xi and P_total.' },
  { title: 'Enter the values', body: 'Leave unused gas rows blank to work with 2, 3 or 4 gases.' },
  { title: 'Read the result', body: 'The total pressure (or each partial pressure) solves live, with the 3D diagrams and charts.' },
];

const related = [
  { href: '/tools/ideal-gas-law-calculator', emoji: '🧮', title: 'Ideal Gas Law Calculator', desc: 'PV = nRT — solve for any variable.' },
  { href: '/tools/boyles-law-calculator', emoji: '🎈', title: "Boyle's Law Calculator", desc: 'P₁V₁ = P₂V₂ — solve any variable.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'M = mol/L — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="in a mixture of gases, each gas exerts its own pressure independently, as if the others were not there — total pressure is simply the sum of the parts."
  howIntro="Rearranged with mole fractions, Pi = Xi × P_total lets you go the other way: if you know the composition of a mixture (as mole fractions) and its total pressure, you can find any individual gas's partial pressure directly, without needing to know moles or volume at all."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Dalton's law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-sum" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Sum pressures</button>
      <button id="mode-frac" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From mole fractions</button>
    </div>

    <div id="sum-fields" class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">P₁ (gas 1)</span>
        <input id="p1" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">P₂ (gas 2)</span>
        <input id="p2" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">P₃ (gas 3, optional)</span>
        <input id="p3" type="number" step="any" placeholder="blank = absent" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">P₄ (gas 4, optional)</span>
        <input id="p4" type="number" step="any" placeholder="blank = absent" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="frac-fields" class="hidden gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">X₁ (mole fraction 1)</span>
        <input id="x1" type="number" step="any" placeholder="0–1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">X₂ (mole fraction 2)</span>
        <input id="x2" type="number" step="any" placeholder="0–1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">X₃ (optional)</span>
        <input id="x3" type="number" step="any" placeholder="blank = absent" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Total pressure</span>
        <input id="ptot-in" type="number" step="any" placeholder="atm" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4" id="sum-out">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white sm:col-span-4"><div class="text-sm opacity-80">Total pressure P_total</div><div id="r-total" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-4 hidden" id="frac-out">
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P₁</div><div id="r-p1" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P₂</div><div id="r-p2" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P₃</div><div id="r-p3" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Remaining (P₄)</div><div id="r-p4" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="dl-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-mixed" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Mixed together, still independent</h3>
          <p class="mt-1 text-sm text-slate-600">Four gas types (different colored spheres) share one container. Each still contributes its own partial pressure exactly as if it were alone — mixing does not reduce any gas's contribution.</p>
        </div>
        <div>
          <div id="diag-separated" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Same gases, separated into containers</h3>
          <p class="mt-1 text-sm text-slate-600">The same four gases, now split into separate containers of equal volume. Each container's pressure is that gas's partial pressure — summing them gives the same total as the mixture on the left.</p>
        </div>
      </div>
      <p id="diag3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Partial pressure graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Partial pressure per gas — air composition example</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-bars"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Stacked partial pressures summing to total pressure</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-stack"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'sum';
      function switchMode(m) {
        mode = m;
        el('mode-sum').className = m === 'sum' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-frac').className = m === 'frac' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('sum-fields').className = m === 'sum' ? 'grid gap-4 sm:grid-cols-4' : 'hidden';
        el('frac-fields').className = m === 'frac' ? 'grid gap-4 sm:grid-cols-4' : 'hidden gap-4 sm:grid-cols-4';
        el('sum-out').className = m === 'sum' ? 'mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4' : 'mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4 hidden';
        el('frac-out').className = m === 'frac' ? 'mt-3 grid grid-cols-1 gap-3 sm:grid-cols-4' : 'mt-3 grid grid-cols-1 gap-3 sm:grid-cols-4 hidden';
        el('dl-err').textContent = '';
        update();
      }
      function update() {
        el('dl-err').textContent = '';
        if (mode === 'sum') {
          const p1 = parseFloat(el('p1').value), p2 = parseFloat(el('p2').value);
          const p3 = parseFloat(el('p3').value), p4 = parseFloat(el('p4').value);
          el('r-total').textContent = '—';
          if (isNaN(p1) || isNaN(p2)) return;
          let total = p1 + p2;
          if (!isNaN(p3)) total += p3;
          if (!isNaN(p4)) total += p4;
          el('r-total').textContent = fmt(total) + ' atm';
        } else {
          const x1 = parseFloat(el('x1').value), x2 = parseFloat(el('x2').value);
          const x3 = parseFloat(el('x3').value), ptot = parseFloat(el('ptot-in').value);
          ['r-p1', 'r-p2', 'r-p3', 'r-p4'].forEach((id) => (el(id).textContent = '—'));
          if (isNaN(x1) || isNaN(x2) || isNaN(ptot)) return;
          const x3v = isNaN(x3) ? 0 : x3;
          const xsum = x1 + x2 + x3v;
          if (xsum > 1.0001) { el('dl-err').textContent = 'Mole fractions cannot sum to more than 1.'; return; }
          const x4 = 1 - xsum;
          el('r-p1').textContent = fmt(x1 * ptot) + ' atm';
          el('r-p2').textContent = fmt(x2 * ptot) + ' atm';
          el('r-p3').textContent = isNaN(x3) ? 'n/a' : fmt(x3 * ptot) + ' atm';
          el('r-p4').textContent = fmt(x4 * ptot) + ' atm (X=' + fmt(x4) + ')';
        }
      }
      el('mode-sum').addEventListener('click', () => switchMode('sum'));
      el('mode-frac').addEventListener('click', () => switchMode('frac'));
      ['p1', 'p2', 'p3', 'p4', 'x1', 'x2', 'x3', 'ptot-in'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts (fixed illustrative air-composition example) ----
      const charts = {};
      const GASES = ['N₂', 'O₂', 'Ar', 'CO₂'];
      const PRESSURES = [0.780, 0.210, 0.0093, 0.0004];
      const COLORS = ['#6366f1', '#ef4444', '#10b981', '#f59e0b'];

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.bars = new Chart(el('chart-bars'), {
          type: 'bar',
          data: { labels: GASES, datasets: [{ label: 'Partial pressure (atm)', data: PRESSURES, backgroundColor: COLORS }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Partial pressure (atm)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.stack = new Chart(el('chart-stack'), {
          type: 'bar',
          data: {
            labels: ['Air mixture'],
            datasets: GASES.map((g, i) => ({ label: g, data: [PRESSURES[i]], backgroundColor: COLORS[i] })),
          },
          options: Object.assign({}, base, {
            indexAxis: 'y',
            scales: { x: { stacked: true, title: { display: true, text: 'Pressure (atm)' } }, y: { stacked: true } },
            plugins: { legend: { position: 'bottom' } },
          }),
        });
        charts.ready = true;
      }

      // ---- static diagram 1: 4 gas types mixed in one container ----
      function containerBox(THREE, w, h, d) {
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.18, roughness: 0.1, side: THREE.DoubleSide });
        return new THREE.Mesh(new THREE.BoxGeometry(w, h, d), glassMat);
      }
      let diagMixed = null, diagSeparated = null;
      function initDiagMixed() {
        const c = el('diag-mixed'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        s.scene.add(containerBox(THREE, 5, 5, 5));
        const colors = [0x6366f1, 0xef4444, 0x10b981, 0xf59e0b];
        const geo = new THREE.SphereGeometry(0.18, 10, 10);
        colors.forEach((col) => {
          const mat = new THREE.MeshStandardMaterial({ color: col });
          for (let i = 0; i < 8; i++) {
            const p = new THREE.Mesh(geo, mat);
            p.position.set((Math.random() - 0.5) * 4, (Math.random() - 0.5) * 4, (Math.random() - 0.5) * 4);
            s.scene.add(p);
          }
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagMixed = { resize: s.resize };
      }
      function initDiagSeparated() {
        const c = el('diag-separated'); if (!c) throw new Error('no container');
        const s = makeScene(c, 14, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        const colors = [0x6366f1, 0xef4444, 0x10b981, 0xf59e0b];
        const xs = [-4.5, -1.5, 1.5, 4.5];
        const geo = new THREE.SphereGeometry(0.16, 10, 10);
        colors.forEach((col, i) => {
          const grp = new THREE.Group(); grp.position.x = xs[i];
          grp.add(containerBox(THREE, 2.4, 2.4, 2.4));
          const mat = new THREE.MeshStandardMaterial({ color: col });
          for (let j = 0; j < 8; j++) {
            const p = new THREE.Mesh(geo, mat);
            p.position.set((Math.random() - 0.5) * 1.9, (Math.random() - 0.5) * 1.9, (Math.random() - 0.5) * 1.9);
            grp.add(p);
          }
          s.scene.add(grp);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagSeparated = { resize: s.resize };
      }

      function boot() {
        try { switchMode('sum'); } catch (e) { console.error('[daltons-law] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[daltons-law] charts failed', e); }
        if (window.THREE) {
          try { initDiagMixed(); } catch (e) { console.error('[daltons-law] mixed diagram failed', e); el('diag3d-fallback').classList.remove('hidden'); }
          try { initDiagSeparated(); } catch (e) { console.error('[daltons-law] separated diagram failed', e); el('diag3d-fallback').classList.remove('hidden'); }
        } else { el('diag3d-fallback').classList.remove('hidden'); }
        mountResize([diagMixed, diagSeparated]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
