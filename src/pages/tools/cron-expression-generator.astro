---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Cron Expression Generator';
const description = 'Build cron schedules with dropdowns and presets — no syntax needed. Get the cron string, plain-English description, and next run times.';
const intro = 'Build a cron schedule with dropdowns — no syntax memorizing.';
const category = { id: 'developers', name: 'Developers' };
const seoTitle = 'Cron Expression Generator — Build & Preview Cron Schedules';
const seoDesc = 'Generate cron expressions with simple menus, see a plain-English description, and preview the next run times. Free crontab generator.';
const faqs = [
  { q: 'What do the five cron fields mean?', a: 'Minute, hour, day-of-month, month, and day-of-week, in that order.' },
  { q: 'How do I run something every 5 minutes?', a: 'Use */5 * * * *.' },
  { q: 'What timezone does cron use?', a: 'Usually the server local timezone — set or check TZ/CRON_TZ if needed.' },
  { q: 'What does */n mean?', a: 'Every n units — */5 in minute field means every 5 minutes.' },
  { q: 'What happens if both day-of-month and day-of-week are set?', a: 'Cron uses OR logic — the task runs when either field matches the current date.' },
  { q: 'How do I schedule something for weekdays only?', a: 'Use 1-5 in the day-of-week field (Monday=1 through Friday=5).' },
  { q: 'What is the difference between cron and crontab?', a: 'Cron is the scheduler daemon; crontab is the file that lists cron jobs. Each line in a crontab is a cron expression followed by a command.' },
  { q: 'Is this tool private?', a: 'Yes — all processing happens in your browser. No data is sent to any server.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-5">
      <div>
        <label class="block text-sm font-medium text-slate-700" for="minute-sel">Minute</label>
        <select id="minute-sel" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="*">Every minute</option>
          <option value="*/5">Every 5 min</option>
          <option value="*/10">Every 10 min</option>
          <option value="*/15">Every 15 min</option>
          <option value="*/30">Every 30 min</option>
          <option value="custom">Custom…</option>
        </select>
        <input id="minute-custom" type="number" min="0" max="59" placeholder="0–59" class="mt-1 hidden w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="hour-sel">Hour</label>
        <select id="hour-sel" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="*">Every hour</option>
          <option value="*/2">Every 2 hrs</option>
          <option value="*/6">Every 6 hrs</option>
          <option value="*/12">Every 12 hrs</option>
          <option value="custom">Custom…</option>
        </select>
        <input id="hour-custom" type="number" min="0" max="23" placeholder="0–23" class="mt-1 hidden w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="dom-sel">Day of Month</label>
        <select id="dom-sel" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="*">Every day</option>
          <option value="custom">Custom…</option>
        </select>
        <input id="dom-custom" type="number" min="1" max="31" placeholder="1–31" class="mt-1 hidden w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="month-sel">Month</label>
        <select id="month-sel" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="*">Every month</option>
          <option value="1">January</option>
          <option value="2">February</option>
          <option value="3">March</option>
          <option value="4">April</option>
          <option value="5">May</option>
          <option value="6">June</option>
          <option value="7">July</option>
          <option value="8">August</option>
          <option value="9">September</option>
          <option value="10">October</option>
          <option value="11">November</option>
          <option value="12">December</option>
          <option value="custom">Custom…</option>
        </select>
        <input id="month-custom" type="text" placeholder="e.g. 1-6" class="mt-1 hidden w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="dow-sel">Day of Week</label>
        <select id="dow-sel" class="mt-1 w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="*">Every day</option>
          <option value="0">Sunday</option>
          <option value="1">Monday</option>
          <option value="2">Tuesday</option>
          <option value="3">Wednesday</option>
          <option value="4">Thursday</option>
          <option value="5">Friday</option>
          <option value="6">Saturday</option>
          <option value="1-5">Weekdays (Mon–Fri)</option>
          <option value="custom">Custom…</option>
        </select>
        <input id="dow-custom" type="text" placeholder="e.g. 0,6" class="mt-1 hidden w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>

    <div class="mt-4 flex flex-wrap gap-2">
      <button class="preset-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50" data-expr="*/5 * * * *">Every 5 min</button>
      <button class="preset-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50" data-expr="0 9 * * *">Daily at 9 AM</button>
      <button class="preset-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50" data-expr="0 0 * * 1">Every Monday</button>
      <button class="preset-btn rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50" data-expr="0 9 * * 1-5">Weekdays at 9 AM</button>
    </div>

    <div class="mt-5 rounded-xl border border-indigo-100 bg-indigo-50 p-4">
      <label class="text-sm font-medium text-slate-700">Cron expression</label>
      <div class="mt-1 flex items-stretch gap-2">
        <input id="cron-result" readonly value="* * * * *" class="w-full rounded-xl border border-indigo-200 bg-white px-4 py-3 font-mono text-lg font-bold text-indigo-700 outline-none" />
        <button id="copy-btn" class="shrink-0 rounded-xl bg-indigo-600 px-5 text-sm font-medium text-white transition hover:bg-indigo-700">Copy</button>
      </div>
      <div id="desc" class="mt-2 text-sm font-medium text-indigo-700">Every minute</div>
      <div id="runs" class="mt-2 space-y-0.5 text-xs text-slate-600"></div>
      <div id="warn" class="mt-2 hidden rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-800"></div>
    </div>

    <div class="mt-4 rounded-xl border border-slate-100 bg-slate-50 p-3 text-xs text-slate-500">
      <span class="font-medium">Privacy:</span> All processing happens in your browser. No cron expressions or data are sent to any server.
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How cron expressions work</h2>
    <div class="mt-4 overflow-x-auto">
      <svg viewBox="0 0 720 130" class="w-full max-w-2xl" role="img" aria-label="Diagram showing five cron fields flowing into a cron string">
        <rect x="0" y="10" width="100" height="50" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="50" y="42" text-anchor="middle" font-size="13" font-weight="700" fill="#4338ca">Minute</text>
        <rect x="120" y="10" width="100" height="50" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="170" y="42" text-anchor="middle" font-size="13" font-weight="700" fill="#4338ca">Hour</text>
        <rect x="240" y="10" width="100" height="50" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="290" y="35" text-anchor="middle" font-size="13" font-weight="700" fill="#4338ca">Day of</text>
        <text x="290" y="50" text-anchor="middle" font-size="13" font-weight="700" fill="#4338ca">Month</text>
        <rect x="360" y="10" width="100" height="50" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="410" y="35" text-anchor="middle" font-size="13" font-weight="700" fill="#4338ca">Month</text>
        <text x="410" y="50" text-anchor="middle" font-size="13" font-weight="700" fill="#4338ca">(1–12)</text>
        <rect x="480" y="10" width="100" height="50" rx="10" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
        <text x="530" y="35" text-anchor="middle" font-size="13" font-weight="700" fill="#4338ca">Day of</text>
        <text x="530" y="50" text-anchor="middle" font-size="13" font-weight="700" fill="#4338ca">Week</text>
        <path d="M 50 60 L 50 90 L 140 90" fill="none" stroke="#94a3b8" stroke-width="2" marker-end="url(#arrow)" />
        <path d="M 170 60 L 170 90 L 185 90" fill="none" stroke="#94a3b8" stroke-width="2" />
        <path d="M 290 60 L 290 90" fill="none" stroke="#94a3b8" stroke-width="2" />
        <path d="M 410 60 L 410 90" fill="none" stroke="#94a3b8" stroke-width="2" />
        <path d="M 530 60 L 530 90 L 320 90" fill="none" stroke="#94a3b8" stroke-width="2" />
        <rect x="140" y="80" width="440" height="40" rx="8" fill="#6366f1" />
        <text x="360" y="105" text-anchor="middle" font-size="15" font-weight="700" fill="#ffffff" font-family="monospace">* &nbsp; * &nbsp; * &nbsp; * &nbsp; *</text>
        <defs>
          <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 0 0 L 10 5 L 0 10 Z" fill="#94a3b8" />
          </marker>
        </defs>
      </svg>
    </div>
    <p class="mt-4 text-slate-600">A cron expression is a string of five space-separated fields that define a schedule: <strong class="text-slate-800">minute</strong> (0–59), <strong class="text-slate-800">hour</strong> (0–23), <strong class="text-slate-800">day of month</strong> (1–31), <strong class="text-slate-800">month</strong> (1–12 or names), and <strong class="text-slate-800">day of week</strong> (0–7, where 0 and 7 both mean Sunday). Each field accepts a specific syntax that determines when the cron job triggers.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What each field means</h2>
    <p class="mt-2 text-slate-600">Every cron expression has five fields. Here is what each one controls and the values it accepts.</p>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-slate-500">
          <tr>
            <th class="p-3">Field</th>
            <th class="p-3">Range</th>
            <th class="p-3">Allowed values</th>
            <th class="p-3">Example</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700">
          <tr><td class="p-3 font-medium">Minute</td><td class="p-3">0–59</td><td class="p-3">*, */n, n, n-m, a,b,c</td><td class="p-3 font-mono text-xs">*/5</td></tr>
          <tr><td class="p-3 font-medium">Hour</td><td class="p-3">0–23</td><td class="p-3">*, */n, n, n-m, a,b,c</td><td class="p-3 font-mono text-xs">9</td></tr>
          <tr><td class="p-3 font-medium">Day of month</td><td class="p-3">1–31</td><td class="p-3">*, n, n-m, a,b,c</td><td class="p-3 font-mono text-xs">15</td></tr>
          <tr><td class="p-3 font-medium">Month</td><td class="p-3">1–12</td><td class="p-3">*, n, n-m, a,b,c, JAN–DEC</td><td class="p-3 font-mono text-xs">1</td></tr>
          <tr><td class="p-3 font-medium">Day of week</td><td class="p-3">0–7</td><td class="p-3">*, n, n-m, a,b,c, SUN–SAT</td><td class="p-3 font-mono text-xs">1-5</td></tr>
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-sm text-slate-600">The asterisk <code class="font-mono">*</code> means "every" — it matches all values in that field. A step value like <code class="font-mono">*/5</code> means "every 5 units." Ranges (<code class="font-mono">1-5</code>) match any value in the range, and lists (<code class="font-mono">1,3,5</code>) match any of the listed values.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Cron syntax at a glance</h2>
    <p class="mt-2 text-slate-600">Beyond simple numbers, cron supports several operators that give you precise control over scheduling.</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><code class="font-mono text-indigo-600">*</code> — Wildcard</h3>
        <p class="mt-1 text-sm text-slate-600">Matches every possible value for the field. For example, <code class="font-mono">*</code> in the hour field means every hour of the day.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><code class="font-mono text-indigo-600">*/n</code> — Step</h3>
        <p class="mt-1 text-sm text-slate-600">Runs every <em>n</em> units. <code class="font-mono">*/15</code> in the minute field fires at minutes 0, 15, 30, and 45.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><code class="font-mono text-indigo-600">n-m</code> — Range</h3>
        <p class="mt-1 text-sm text-slate-600">Matches any value between <em>n</em> and <em>m</em> inclusive. <code class="font-mono">9-17</code> in the hour field matches 9 AM through 5 PM.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900"><code class="font-mono text-indigo-600">a,b,c</code> — List</h3>
        <p class="mt-1 text-sm text-slate-600">Matches any of the comma-separated values. <code class="font-mono">1,3,5</code> in the day-of-week field matches Monday, Wednesday, and Friday.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example: "Every weekday at 9 AM"</h2>
    <p class="mt-2 text-slate-600">Let us build the cron expression for a job that runs at 9:00 AM on every weekday (Monday through Friday).</p>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <div class="grid gap-2 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Minute:</span> <span class="text-slate-600">0 (at the start of the hour)</span></div>
        <div><span class="font-medium text-slate-700">Hour:</span> <span class="text-slate-600">9 (9 AM)</span></div>
        <div><span class="font-medium text-slate-700">Day of month:</span> <span class="text-slate-600">* (every day is handled by DOW)</span></div>
        <div><span class="font-medium text-slate-700">Month:</span> <span class="text-slate-600">* (every month)</span></div>
        <div><span class="font-medium text-slate-700">Day of week:</span> <span class="text-slate-600">1-5 (Monday through Friday)</span></div>
      </div>
      <div class="mt-3 rounded-lg bg-indigo-100 p-3 text-center font-mono text-lg font-bold text-indigo-700">0 9 * * 1-5</div>
      <p class="mt-3 text-sm text-slate-600">The cron daemon reads this as: "When the minute is 0, the hour is 9, and the day of week is between 1 and 5, run the command." The <code class="font-mono">*</code> fields tell cron not to restrict those dimensions.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common cron use cases</h2>
    <p class="mt-2 text-slate-600">Cron expressions are used across many domains of software engineering and system administration.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">&#x1F4E1;</span>
        <h3 class="mt-2 font-semibold text-slate-900">Server job scheduling</h3>
        <p class="mt-1 text-sm text-slate-600">System administrators use cron for log rotation, backup scripts, database dumps, certificate renewal, cache invalidation, and system health checks that run at defined intervals.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">&#x2699;&#xFE0F;</span>
        <h3 class="mt-2 font-semibold text-slate-900">CI / automation pipelines</h3>
        <p class="mt-1 text-sm text-slate-600">Continuous integration systems like GitHub Actions, Jenkins, and GitLab CI use cron expressions for scheduled workflows — nightly builds, weekly regression tests, or monthly dependency updates.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">&#x1F4CA;</span>
        <h3 class="mt-2 font-semibold text-slate-900">Data processing</h3>
        <p class="mt-1 text-sm text-slate-600">ETL pipelines, report generation, data aggregation, and analytics jobs often run on cron schedules. A daily export at midnight or an hourly synch with external APIs are typical patterns.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">&#x1F4D6;</span>
        <h3 class="mt-2 font-semibold text-slate-900">Learning cron syntax</h3>
        <p class="mt-1 text-sm text-slate-600">Developers new to Linux or server administration use interactive generators to build cron expressions without memorising syntax, gradually learning how the five fields combine to form schedules.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with cron</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Day-of-month AND day-of-week use OR logic</h3>
        <p class="mt-1 text-sm text-slate-600">When both fields are restricted (not <code class="font-mono">*</code>), cron runs the job when <em>either</em> condition matches. For example, <code class="font-mono">0 0 1,15 * 5</code> runs on the 1st, the 15th, <em>and</em> every Friday — which may be more often than intended. If you need AND logic, use a wrapper script with conditional checks.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Times use the server timezone</h3>
        <p class="mt-1 text-sm text-slate-600">Cron reads the system clock and uses the local timezone configured on the server. If your server is in UTC but you need a schedule in Eastern Time, set the <code class="font-mono">CRON_TZ</code> or <code class="font-mono">TZ</code> variable at the top of your crontab file (supported by Vixie cron and modern forks).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Test before deploying</h3>
        <p class="mt-1 text-sm text-slate-600">Always verify your cron expression before putting it into production. Use the next-run preview above to confirm the timing is what you expect. A mistake like <code class="font-mono">* * * * *</code> for a database backup job could run your backup script every 60 seconds.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Be mindful of daylight saving time</h3>
        <p class="mt-1 text-sm text-slate-600">Cron jobs scheduled during a DST transition may skip an hour (spring forward) or repeat (fall back). Jobs at 2:30 AM may behave unpredictably twice a year. Where possible, schedule critical jobs outside DST windows or use UTC-based scheduling.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Redirect output for debugging</h3>
        <p class="mt-1 text-sm text-slate-600">Cron sends output by email to the crontab owner. Always add output redirection to your cron jobs: <code class="font-mono">0 3 * * * /usr/bin/backup.sh &gt;&gt; /var/log/backup.log 2&gt;&amp;1</code>. This captures both stdout and stderr into a log file you can inspect later.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-slate-600">If you already have a cron expression and need to understand what it does, try these complementary tools.</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/crontab-to-human" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">
        <span class="text-lg">&#x1F4C6;</span> Crontab to Human-Readable
        <span class="block text-xs font-normal text-slate-500">Convert cron expressions to plain English</span>
      </a>
      <a href="/tools/jwt-decoder" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">
        <span class="text-lg">&#x1F512;</span> JWT Decoder
        <span class="block text-xs font-normal text-slate-500">Inspect JSON Web Token contents</span>
      </a>
      <a href="/tools/uuid-generator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">
        <span class="text-lg">&#x1F194;</span> UUID Generator
        <span class="block text-xs font-normal text-slate-500">Generate unique identifiers</span>
      </a>
    </div>
  </section>

  <script is:inline>
    var el = function(id) { return document.getElementById(id); };

    var minuteSel = el('minute-sel');
    var minuteCustom = el('minute-custom');
    var hourSel = el('hour-sel');
    var hourCustom = el('hour-custom');
    var domSel = el('dom-sel');
    var domCustom = el('dom-custom');
    var monthSel = el('month-sel');
    var monthCustom = el('month-custom');
    var dowSel = el('dow-sel');
    var dowCustom = el('dow-custom');
    var cronResult = el('cron-result');
    var descEl = el('desc');
    var runsEl = el('runs');
    var warnEl = el('warn');
    var copyBtn = el('copy-btn');

    var selects = [minuteSel, hourSel, domSel, monthSel, dowSel];
    var customs = [minuteCustom, hourCustom, domCustom, monthCustom, dowCustom];

    function getFieldValue(sel, custom) {
      if (sel.value === 'custom') {
        var v = custom.value.trim();
        if (sel === minuteSel) {
          var n = parseInt(v, 10);
          if (isNaN(n) || n < 0 || n > 59) return '';
          return String(n);
        }
        if (sel === hourSel) {
          var n = parseInt(v, 10);
          if (isNaN(n) || n < 0 || n > 23) return '';
          return String(n);
        }
        if (sel === domSel) {
          var n = parseInt(v, 10);
          if (isNaN(n) || n < 1 || n > 31) return '';
          return String(n);
        }
        return v || '';
      }
      return sel.value;
    }

    function toggleCustom(sel, input) {
      if (sel.value === 'custom') {
        input.classList.remove('hidden');
        input.focus();
      } else {
        input.classList.add('hidden');
      }
    }

    function update() {
      var parts = [
        getFieldValue(minuteSel, minuteCustom),
        getFieldValue(hourSel, hourCustom),
        getFieldValue(domSel, domCustom),
        getFieldValue(monthSel, monthCustom),
        getFieldValue(dowSel, dowCustom),
      ];

      var empty = parts.some(function(p) { return p === ''; });
      if (empty) {
        cronResult.value = '—';
        descEl.textContent = 'Complete all fields';
        runsEl.innerHTML = '';
        warnEl.classList.add('hidden');
        return;
      }

      var expr = parts.join(' ');
      cronResult.value = expr;

      var desc = describeCron(parts);
      descEl.textContent = desc;

      var warn = validateCron(parts);
      if (warn) {
        warnEl.textContent = warn;
        warnEl.classList.remove('hidden');
      } else {
        warnEl.classList.add('hidden');
      }

      var times = getNextCronTimes(parts, 5);
      if (times.length) {
        var html = '<span class="font-medium text-slate-500">Next 5 runs:</span>';
        for (var i = 0; i < times.length; i++) {
          html += '<div class="pl-1">' + formatDate(times[i]) + '</div>';
        }
        runsEl.innerHTML = html;
      } else {
        runsEl.innerHTML = '<span class="text-amber-600">Could not compute next runs for this pattern.</span>';
      }
    }

    function describeCron(parts) {
      var m = parts[0], h = parts[1], dom = parts[2], mon = parts[3], dow = parts[4];

      if (m === '*' && h === '*' && dom === '*' && mon === '*' && dow === '*') return 'Every minute';
      if (h === '*' && dom === '*' && mon === '*' && dow === '*') {
        if (m === '*/5') return 'Every 5 minutes';
        if (m === '*/10') return 'Every 10 minutes';
        if (m === '*/15') return 'Every 15 minutes';
        if (m === '*/30') return 'Every 30 minutes';
        if (/^\d+$/.test(m) && parseInt(m) > 0) return 'Every hour at minute ' + m;
        if (/^\d+$/.test(m) && parseInt(m) === 0) return 'Every hour';
        if (m.startsWith('*/')) return 'Every ' + m.slice(2) + ' minutes';
        return 'Every minute when conditions match';
      }

      var timeStr = '';
      if (/^\d+$/.test(h) && /^\d+$/.test(m)) {
        var hr = parseInt(h, 10);
        var mi = parseInt(m, 10);
        var ampm = hr >= 12 ? 'PM' : 'AM';
        var hr12 = hr % 12 || 12;
        timeStr = hr12 + ':' + String(mi).padStart(2, '0') + ' ' + ampm;
      } else if (/^\d+$/.test(h) && m === '*') {
        var hr = parseInt(h, 10);
        var ampm = hr >= 12 ? 'PM' : 'AM';
        var hr12 = hr % 12 || 12;
        timeStr = 'every minute of ' + hr12 + ' ' + ampm;
      } else if (h === '*' && /^\d+$/.test(m)) {
        timeStr = 'minute ' + m + ' of every hour';
      } else {
        timeStr = m + ' ' + h;
      }

      var dayStr = '';
      if (dom === '*' && dow === '*') dayStr = 'every day';
      else if (dom !== '*' && dow === '*') dayStr = 'on day ' + dom + ' of the month';
      else if (dom === '*' && dow !== '*') dayStr = 'on ' + describeDOW(dow);
      else dayStr = 'on day ' + dom + ' AND ' + describeDOW(dow) + ' (OR logic)';

      var monStr = '';
      if (mon !== '*') {
        if (/^\d+$/.test(mon)) monStr = ' in ' + ['January','February','March','April','May','June','July','August','September','October','November','December'][parseInt(mon,10)-1];
        else monStr = ' in months matching ' + mon;
      } else {
        monStr = '';
      }

      return 'At ' + timeStr + ' ' + dayStr + monStr;
    }

    function describeDOW(dow) {
      var map = { '0': 'Sunday', '1': 'Monday', '2': 'Tuesday', '3': 'Wednesday', '4': 'Thursday', '5': 'Friday', '6': 'Saturday' };
      if (dow === '1-5') return 'weekdays (Mon–Fri)';
      if (dow === '0,6') return 'weekends';
      if (map[dow]) return map[dow];
      if (dow.indexOf('-') > -1) {
        var p = dow.split('-');
        return (map[p[0]] || p[0]) + ' through ' + (map[p[1]] || p[1]);
      }
      return 'day-of-week ' + dow;
    }

    function validateCron(parts) {
      var dom = parts[2], dow = parts[4];
      if (dom !== '*' && dow !== '*' && dom.indexOf(',') === -1 && dow.indexOf(',') === -1) {
        if (dom.indexOf('-') === -1 && dow.indexOf('-') === -1 && /^\d+$/.test(dom) && /^\d+$/.test(dow)) {
          return 'Note: Both day-of-month and day-of-week are set. Cron uses OR logic — the job runs when either matches.';
        }
      }
      if (parts[0] === '*' && parts[1] === '*' && parts[2] === '*' && parts[3] === '*' && parts[4] === '*') {
        return '';
      }
      return '';
    }

    function matchesField(val, field, min, max) {
      if (field === '*') return true;
      if (field.indexOf(',') > -1) {
        var vals = field.split(',');
        for (var i = 0; i < vals.length; i++) {
          if (matchesField(val, vals[i].trim(), min, max)) return true;
        }
        return false;
      }
      if (field.indexOf('/') > -1) {
        var sp = field.split('/');
        var base = sp[0].trim();
        var step = parseInt(sp[1], 10);
        if (step === 0) return false;
        if (base === '*') return val % step === 0;
        if (base.indexOf('-') > -1) {
          var r = base.split('-');
          var rlo = parseInt(r[0], 10), rhi = parseInt(r[1], 10);
          if (val < rlo || val > rhi) return false;
          return (val - rlo) % step === 0;
        }
        return false;
      }
      if (field.indexOf('-') > -1 && field.indexOf('/') === -1) {
        var sp = field.split('-');
        var lo = parseInt(sp[0], 10), hi = parseInt(sp[1], 10);
        return val >= lo && val <= hi;
      }
      var n = parseInt(field, 10);
      if (!isNaN(n)) return val === n;
      return false;
    }

    function getNextCronTimes(parts, count) {
      var now = new Date();
      var current = new Date(now);
      current.setSeconds(0, 0);
      current.setMinutes(current.getMinutes() + 1);

      var results = [];
      var maxIter = 525600;
      var iter = 0;

      while (results.length < count && iter < maxIter) {
        iter++;
        var y = current.getFullYear();
        var mo = current.getMonth() + 1;
        var d = current.getDate();
        var h = current.getHours();
        var mi = current.getMinutes();
        var dw = current.getDay();

        if (matchesField(mi, parts[0], 0, 59) &&
            matchesField(h, parts[1], 0, 23) &&
            matchesField(d, parts[2], 1, 31) &&
            matchesField(mo, parts[3], 1, 12) &&
            matchesField(dw, parts[4], 0, 6)) {
          results.push(new Date(current));
        }

        current.setMinutes(current.getMinutes() + 1);
      }

      return results;
    }

    function formatDate(d) {
      var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      var day = days[d.getDay()];
      var mon = months[d.getMonth()];
      var date = d.getDate();
      var hr = d.getHours();
      var mi = d.getMinutes();
      var ampm = hr >= 12 ? 'PM' : 'AM';
      var hr12 = hr % 12 || 12;
      return day + ', ' + mon + ' ' + date + ' — ' + hr12 + ':' + String(mi).padStart(2, '0') + ' ' + ampm;
    }

    function setPreset(expr) {
      var parts = expr.split(/\s+/);
      var fieldSets = [
        [minuteSel, minuteCustom],
        [hourSel, hourCustom],
        [domSel, domCustom],
        [monthSel, monthCustom],
        [dowSel, dowCustom],
      ];
      for (var i = 0; i < 5; i++) {
        var sel = fieldSets[i][0], custom = fieldSets[i][1];
        var opts = sel.options;
        var found = false;
        for (var j = 0; j < opts.length; j++) {
          if (opts[j].value === parts[i]) {
            sel.value = parts[i];
            custom.classList.add('hidden');
            found = true;
            break;
          }
        }
        if (!found) {
          sel.value = 'custom';
          custom.value = parts[i];
          custom.classList.remove('hidden');
        }
      }
      update();
    }

    selects.forEach(function(sel, i) {
      sel.addEventListener('change', function() {
        toggleCustom(sel, customs[i]);
        if (sel.value !== 'custom') update();
      });
    });

    customs.forEach(function(input, i) {
      input.addEventListener('input', update);
      input.addEventListener('blur', update);
    });

    document.querySelectorAll('.preset-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        setPreset(this.getAttribute('data-expr'));
      });
    });

    copyBtn.addEventListener('click', async function() {
      var val = cronResult.value;
      if (!val || val === '—') return;
      try {
        await navigator.clipboard.writeText(val);
        var orig = copyBtn.textContent;
        copyBtn.textContent = '\u2713';
        setTimeout(function() { copyBtn.textContent = orig; }, 1200);
      } catch (e) {}
    });

    update();
  </script>
</ToolLayout>
