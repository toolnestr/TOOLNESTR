---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Scientific Calculator';
const description =
  'Free online scientific calculator. Do trigonometry (sin, cos, tan), logarithms, powers, ' +
  'roots, π and e, with degree or radian mode. Works in your browser.';
const intro =
  'A full scientific calculator with trigonometry, logarithms, powers and roots. Switch between degrees and radians.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'How do I use trig functions?', a: 'Tap sin, cos or tan, enter the angle, then close the bracket. Use the DEG/RAD button to choose whether angles are in degrees or radians.' },
  { q: 'What do log and ln mean?', a: 'log is the base-10 logarithm and ln is the natural logarithm (base e).' },
  { q: 'How do I calculate powers and roots?', a: 'Use ^ for powers (e.g. 2^10) and the √ button for square roots.' },
  { q: 'Can I use the result in a new calculation?', a: 'Yes. After hitting =, type a new operation and the previous result is used as the starting value.' },
  { q: 'Why did I get an error?', a: 'Common causes: unclosed brackets, dividing by zero, or taking the square root of a negative number. Check your expression.' },
  { q: 'What\'s the difference between DEG and RAD?', a: 'DEG means angles are in degrees (0–360). RAD means angles are in radians (0 to 2π). Use DEG for most everyday problems and RAD for calculus or advanced math.' },
];

const buttons = [
  { l: 'sin', ins: 'sin(' }, { l: 'cos', ins: 'cos(' }, { l: 'tan', ins: 'tan(' }, { l: 'DEG', act: 'degrad', id: 'degrad' },
  { l: 'log', ins: 'log(' }, { l: 'ln', ins: 'ln(' }, { l: '√', ins: '√(' }, { l: 'xⁿ', ins: '^' },
  { l: '(', ins: '(' }, { l: ')', ins: ')' }, { l: 'π', ins: 'π' }, { l: 'e', ins: 'e' },
  { l: 'C', act: 'clear', cls: 'text-red-600' }, { l: '⌫', act: 'back' }, { l: '%', ins: '%' }, { l: '÷', ins: '÷', cls: 'text-indigo-600' },
  { l: '7', ins: '7' }, { l: '8', ins: '8' }, { l: '9', ins: '9' }, { l: '×', ins: '×', cls: 'text-indigo-600' },
  { l: '4', ins: '4' }, { l: '5', ins: '5' }, { l: '6', ins: '6' }, { l: '−', ins: '−', cls: 'text-indigo-600' },
  { l: '1', ins: '1' }, { l: '2', ins: '2' }, { l: '3', ins: '3' }, { l: '+', ins: '+', cls: 'text-indigo-600' },
  { l: '0', ins: '0' }, { l: '.', ins: '.' }, { l: '=', act: 'eq', cls: 'bg-indigo-600 text-white hover:bg-indigo-700', span: true },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <input id="display" type="text" readonly value="0" class="mb-3 w-full rounded-xl border border-slate-300 bg-slate-50 p-4 text-right font-mono text-2xl outline-none" />
    <div class="grid grid-cols-4 gap-2">
      {buttons.map((b) => (
        <button
          data-ins={b.ins}
          data-act={b.act}
          id={b.id}
          class:list={[
            'rounded-xl border border-slate-200 py-3 text-base font-medium transition hover:bg-slate-50',
            b.cls,
            b.span ? 'col-span-2' : '',
          ]}
        >{b.l}</button>
      ))}
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Type your expression using the on-screen buttons or your keyboard.</li>
      <li>Use sin, cos, tan for trigonometry and log/ln for logarithms.</li>
      <li>Press = to see the result. Use C to clear or ⌫ to delete the last character.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      A scientific calculator is essential whenever basic arithmetic isn’t enough. Students use it for trigonometry homework, solving for unknown angles in triangles, or working with exponential growth in science class. Developers and engineers rely on logarithms for algorithmic complexity, decibel calculations, and signal processing. Even hobbyists use it when tinkering with electronics — calculating resistor values or tuning frequencies for audio projects.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Always check whether you’re in DEG or RAD mode before doing trigonometry — using the wrong mode is the most common mistake.</li>
      <li>Use parentheses around function arguments: type <code class="rounded bg-slate-100 px-1 text-sm">sin(30)</code> not <code class="rounded bg-slate-100 px-1 text-sm">sin 30</code>.</li>
      <li>For complex expressions, build them step by step and check the display after each term.</li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this scientific calculator</h2>
    <p class="mt-2 text-slate-600">
      A scientific calculator handles much more than basic arithmetic — trigonometry, logarithms,
      exponents, roots and constants like π and e. This one runs right in your browser, works on
      mobile, and lets you switch between degree and radian modes for trig functions.
      Need help with fractions? Try the <a href="/tools/fraction-calculator" class="font-medium text-indigo-600 hover:underline">Fraction Calculator</a>
      or calculate percentages with the <a href="/tools/percentage-calculator" class="font-medium text-indigo-600 hover:underline">Percentage Calculator</a>.
    </p>
  </section>

  <script is:inline>
    const display = document.getElementById('display');
    let deg = true;
    let justEvaluated = false;

    function current() { return display.value === '0' ? '' : display.value; }

    function evaluate() {
      let js = current()
        .replaceAll('×', '*').replaceAll('÷', '/').replaceAll('−', '-')
        .replaceAll('π', 'pi').replaceAll('√', 'sqrt').replaceAll('^', '**')
        .replaceAll('%', '/100');
      const stripped = js.replace(/sin|cos|tan|log|ln|sqrt|pi|e|\*\*/g, '');
      if (/[^0-9+\-*/().\s]/.test(stripped)) return 'Error';
      try {
        const D = deg ? Math.PI / 180 : 1;
        const f = new Function('sin', 'cos', 'tan', 'log', 'ln', 'sqrt', 'pi', 'e',
          '"use strict"; return (' + js + ');');
        const v = f((x) => Math.sin(x * D), (x) => Math.cos(x * D), (x) => Math.tan(x * D),
          (x) => Math.log10(x), (x) => Math.log(x), (x) => Math.sqrt(x), Math.PI, Math.E);
        if (typeof v !== 'number' || !isFinite(v)) return 'Error';
        return String(Math.round(v * 1e10) / 1e10);
      } catch (e) { return 'Error'; }
    }

    document.querySelectorAll('[data-ins], [data-act]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const ins = btn.dataset.ins, act = btn.dataset.act;
        if (act === 'clear') { display.value = '0'; justEvaluated = false; return; }
        if (act === 'back') { display.value = current().slice(0, -1) || '0'; return; }
        if (act === 'degrad') {
          deg = !deg; btn.textContent = deg ? 'DEG' : 'RAD'; return;
        }
        if (act === 'eq') { display.value = evaluate(); justEvaluated = true; return; }
        if (ins !== undefined) {
          if (justEvaluated && /[0-9.]/.test(ins) && display.value !== 'Error') { display.value = ''; }
          justEvaluated = false;
          display.value = current() + ins;
        }
      });
    });
  </script>
</ToolLayout>
