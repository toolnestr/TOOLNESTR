---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Centripetal Force Calculator';
const description = 'Centripetal force calculator with a live 3D orbiting mass and charts. Solve Fc = mv²/r for force, mass, velocity, or radius, with worked examples for cars, orbits, and rides.';
const intro = 'Solve Fc = mv²/r for any of centripetal force, mass, speed, or radius. A live 3D mass swings on a string with tangential-velocity and inward-force arrows, and charts show how force depends on speed and radius.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is centripetal force?', a: 'Centripetal force (Fc) is the net force required to keep an object moving in a circular path — it always points toward the centre of the circle. Fc = mv²/r, where m is mass, v is speed, and r is the radius of the circular path. Units are newtons (N).' },
  { q: 'Is centripetal force a new, separate kind of force?', a: 'No. "Centripetal" describes the direction and role of a force — toward the centre, causing circular motion — not a new fundamental force. It is supplied by something real: tension in a string, gravity for orbits, friction for a car on a curve, or the normal force on a banked track.' },
  { q: 'What is the difference between centripetal and centrifugal force?', a: 'Centripetal force is real and points inward, keeping an object on its circular path. "Centrifugal force" is the outward-feeling force experienced only in the rotating object\'s own (non-inertial) reference frame — it is a fictitious force that does not appear in an outside, inertial observer\'s analysis.' },
  { q: 'How else can centripetal force be written?', a: 'Using angular velocity ω (rad/s): Fc = mω²r. Using the period T (time per revolution): Fc = m(4π²r)/T². All three forms are equivalent because v = ωr = 2πr/T.' },
  { q: 'What happens if the centripetal force disappears?', a: 'The object stops moving in a circle and travels in a straight line (Newton\'s first law) tangent to the circle at the instant the force vanishes — this is why a spun object flies off in a straight line, not outward along a radius, when released.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Centripetal Force Calculator',
  description: 'Calculate centripetal force from mass, speed, and radius using Fc = mv²/r.',
  steps: [
    { name: 'Choose what to solve for', text: 'Pick force, mass, speed, or radius as the unknown.' },
    { name: 'Enter the other three values', text: 'Fill in the remaining quantities.' },
    { name: 'Read the result', text: 'The force solves instantly, and the 3D orbiting mass and charts update.' },
  ],
};

const formulas = [
  { expr: 'F<sub>c</sub> = m v² / r', note: 'centripetal force from mass, speed, and radius' },
  { expr: 'F<sub>c</sub> = m ω² r', note: 'from angular velocity ω (rad/s)' },
  { expr: 'F<sub>c</sub> = m (4π² r) / T²', note: 'from the period T (time per revolution)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — car rounding a curve', tone: 'slate',
    given: 'A 1200 kg car rounds a curve of radius 50 m at 20 m/s. Find the centripetal force needed.',
    rows: [
      { label: 'Formula:', value: 'Fc = mv²/r' },
      { label: 'Substitute:', value: 'Fc = 1200 × (20)² ÷ 50 = 1200 × 400 ÷ 50' },
      { label: 'Centripetal force:', value: 'Fc = 9,600 N', full: true },
    ],
    note: 'This force is supplied by friction between the tyres and the road — if friction cannot supply 9,600 N, the car slides outward.',
  },
  {
    title: 'Worked example 2 — solving for speed', tone: 'amber',
    given: 'A 0.50 kg ball on a string can withstand a maximum tension of 45 N before the string snaps. The string is 0.90 m long. Find the maximum speed before it breaks.',
    rows: [
      { label: 'Rearrange:', value: 'v = √(Fc·r / m)' },
      { label: 'Substitute:', value: 'v = √(45 × 0.90 ÷ 0.50) = √(40.5 ÷ 0.50) = √81' },
      { label: 'Maximum speed:', value: 'v = 9.0 m/s', full: true },
    ],
  },
];

const comparison = {
  heading: 'Centripetal force in common scenarios',
  note: 'Approximate values — real systems vary with exact mass, speed, and radius.',
  headers: [{ label: 'Scenario' }, { label: 'Mass', sub: 'kg' }, { label: 'Speed', sub: 'm/s' }, { label: 'Radius', sub: 'm' }, { label: 'Fc', sub: 'N' }],
  rows: [
    ['Car cornering', '1200', '20', '50', '9,600'],
    ['Spinning fairground ride', '70', '8', '4', '1,120'],
    ['Satellite in low orbit', '500', '7,600', '6.8×10⁶', '~4,240'],
    ['Ball on a string', '0.5', '9.0', '0.9', '45'],
    ['Centrifuge sample', '0.02', '15', '0.1', '45'],
  ],
  highlightIndex: 0,
  footnote: 'Fc = mv²/r in every case; the source of the force differs — friction, tension, gravity, or a container wall.',
};

const realWorld = [
  { emoji: '🚗', title: 'Cars on curves', body: 'Friction between tyres and road supplies the centripetal force that keeps a car turning. If a curve is taken too fast for the available friction (wet or icy roads reduce it), the required Fc exceeds what friction can provide and the car skids outward in a straight line.' },
  { emoji: '🎢', title: 'Roller coasters and rides', body: 'Loops and spinning rides rely on centripetal force supplied by the track\'s normal force or a harness/seat. At the top of a vertical loop, gravity contributes to (or entirely supplies) the centripetal force needed to keep riders on the track.' },
  { emoji: '🛰️', title: 'Orbits', body: 'Gravity supplies the centripetal force that keeps satellites and planets in orbit: GMm/r² = mv²/r. Setting these equal is how orbital speed and period are derived — no engine thrust is needed to "hold" a stable orbit, only gravity.' },
  { emoji: '🧪', title: 'Centrifuges', body: 'Spinning a sample at high angular velocity creates a large centripetal force requirement; denser particles need more force to stay on the circular path and effectively migrate outward relative to lighter ones, which is how centrifuges separate mixtures.' },
];

const misconceptions = [
  { claim: '"Centripetal force is a separate, distinct force pushing outward."', truth: 'Centripetal force is not a new force and it points inward, not outward. It is just the label for whatever net force — tension, friction, gravity, normal force — is directed toward the centre and causes circular motion.' },
  { claim: '"An object moving in a circle at constant speed has no acceleration."', truth: 'Constant speed does not mean constant velocity — direction is always changing in circular motion, so there is a continuous centripetal acceleration (v²/r) directed inward, even though speed itself stays constant.' },
  { claim: '"If you cut the string, the object flies straight outward."', truth: 'It flies off tangent to the circle at the point of release — perpendicular to the radius, not directly outward along it — because Newton\'s first law says it continues in the direction it was already moving at that instant.' },
  { claim: '"Bigger radius always means bigger centripetal force."', truth: 'For fixed speed, Fc = mv²/r actually decreases as r increases — a larger circle at the same speed needs less inward force. Force only grows with radius if speed is held fixed by increasing ω or if v grows with r (as it does for fixed ω, since v = ωr).' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §6.3 "Centripetal Force" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/6-3-centripetal-force" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 6, Force and Motion II, Uniform Circular Motion.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 6, Circular Motion and Other Applications of Newton\'s Laws.' },
];
const sourcesNote = 'Fc = mv²/r assumes uniform circular motion (constant speed). Results are rounded for display.';

const howToUse = [
  { title: 'Choose the unknown', body: 'The calculator solves for force, mass, speed, or radius from the other three.' },
  { title: 'Enter the other values', body: 'Use consistent SI units: kg, m/s, m, N.' },
  { title: 'Watch the orbit', body: 'Use the sliders to see how speed and radius change the inward force arrow in 3D.' },
];

const related = [
  { href: '/tools/torque-calculator', emoji: '🔩', title: 'Torque Calculator', desc: 'τ = rFsinθ — solve torque, lever arm, force, or angle.' },
  { href: '/tools/uniform-circular-motion-calculator', emoji: '🔄', title: 'Uniform Circular Motion Calculator', desc: 'Centripetal accel/force, period, ω from r and v.' },
  { href: '/tools/momentum-calculator', emoji: '🎯', title: 'Momentum & Impulse Calculator', desc: 'p = mv plus a combined impulse mode.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="centripetal force is whatever net inward push or pull keeps an object moving along a circular path instead of flying off in a straight line."
  howIntro="Rearranged, Fc = mv²/r solves any variable: m = Fc·r/v², v = √(Fc·r/m), and r = mv²/Fc. Because Fc grows with the square of speed, doubling your speed around the same curve quadruples the force needed to hold the path — which is exactly why fast corners feel so much more demanding than slow ones."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where centripetal force actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-fc" type="button" data-solve="fc" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Force (Fc)</button>
      <button id="mode-m" type="button" data-solve="m" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Mass (m)</button>
      <button id="mode-v" type="button" data-solve="v" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Speed (v)</button>
      <button id="mode-r" type="button" data-solve="r" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Radius (r)</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-4">
      <label id="field-fc" class="block"><span class="text-sm font-medium text-slate-700">Force (Fc)</span>
        <input id="fc" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-m" class="block"><span class="text-sm font-medium text-slate-700">Mass (m)</span>
        <input id="m" type="number" step="any" placeholder="kg" value="1200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-v" class="block"><span class="text-sm font-medium text-slate-700">Speed (v)</span>
        <input id="v" type="number" step="any" placeholder="m/s" value="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-r" class="block"><span class="text-sm font-medium text-slate-700">Radius (r)</span>
        <input id="r" type="number" step="any" placeholder="m" value="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div id="box-fc" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Force</div><div id="r-fc" class="mt-1 text-2xl font-bold">—</div></div>
      <div id="box-m" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Mass</div><div id="r-m" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-v" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Speed</div><div id="r-v" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-r" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Radius</div><div id="r-r" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="cf-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-orbit" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. The force always points inward</h3>
          <p class="mt-1 text-sm text-slate-600">A mass at four positions around its circular path — every <span class="font-semibold text-red-500">red</span> force arrow points toward the centre, never outward or forward, no matter where the mass is on the circle.</p>
        </div>
        <div>
          <div id="diag-fcv" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Force grows with the square of speed</h3>
          <p class="mt-1 text-sm text-slate-600">Three Fc-vs-v curves at different radii — every curve is a parabola, so doubling speed always quadruples the required force, regardless of radius.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Centripetal force graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Fc vs speed (at your current m, r) — a quadratic curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-v"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Fc vs radius (at your current m, v) — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-r2"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };
      const B_MASS = 0.5; // fixed mass (kg) used by the charts

      // ---- calculator ----
      let solveFor = 'fc';
      const modeBtns = { fc: 'mode-fc', m: 'mode-m', v: 'mode-v', r: 'mode-r' };
      const fieldEls = { fc: 'field-fc', m: 'field-m', v: 'field-v', r: 'field-r' };
      const boxEls = { fc: 'box-fc', m: 'box-m', v: 'box-v', r: 'box-r' };

      function switchSolve(s) {
        solveFor = s;
        Object.keys(modeBtns).forEach((k) => {
          el(modeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(fieldEls).forEach((k) => {
          el(fieldEls[k]).style.opacity = k === s ? '0.45' : '1';
        });
        Object.keys(boxEls).forEach((k) => {
          el(boxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        update();
      }

      function update() {
        el('cf-err').textContent = '';
        ['r-fc', 'r-m', 'r-v', 'r-r'].forEach((id) => (el(id).textContent = '—'));
        const fc = parseFloat(el('fc').value);
        const m = parseFloat(el('m').value);
        const v = parseFloat(el('v').value);
        const r = parseFloat(el('r').value);

        if (solveFor === 'fc') {
          if (isNaN(m) || isNaN(v) || isNaN(r)) return;
          if (r === 0) { el('cf-err').textContent = 'Radius cannot be zero.'; return; }
          const f = (m * v * v) / r;
          el('r-fc').textContent = fmt(f) + ' N';
          el('r-m').textContent = fmt(m) + ' kg';
          el('r-v').textContent = fmt(v) + ' m/s';
          el('r-r').textContent = fmt(r) + ' m';
        } else if (solveFor === 'm') {
          if (isNaN(fc) || isNaN(v) || isNaN(r)) return;
          if (v === 0) { el('cf-err').textContent = 'Speed must be nonzero to solve for mass.'; return; }
          const mm = (fc * r) / (v * v);
          el('r-fc').textContent = fmt(fc) + ' N';
          el('r-m').textContent = fmt(mm) + ' kg';
          el('r-v').textContent = fmt(v) + ' m/s';
          el('r-r').textContent = fmt(r) + ' m';
        } else if (solveFor === 'v') {
          if (isNaN(fc) || isNaN(m) || isNaN(r)) return;
          if (m === 0) { el('cf-err').textContent = 'Mass must be nonzero to solve for speed.'; return; }
          const ratio = (fc * r) / m;
          if (ratio < 0) { el('cf-err').textContent = 'Force, radius, and mass must give a non-negative value under the square root.'; return; }
          const vv = Math.sqrt(ratio);
          el('r-fc').textContent = fmt(fc) + ' N';
          el('r-m').textContent = fmt(m) + ' kg';
          el('r-v').textContent = fmt(vv) + ' m/s';
          el('r-r').textContent = fmt(r) + ' m';
        } else if (solveFor === 'r') {
          if (isNaN(fc) || isNaN(m) || isNaN(v)) return;
          if (fc === 0) { el('cf-err').textContent = 'Force must be nonzero to solve for radius.'; return; }
          const rr = (m * v * v) / fc;
          el('r-fc').textContent = fmt(fc) + ' N';
          el('r-m').textContent = fmt(m) + ' kg';
          el('r-v').textContent = fmt(v) + ' m/s';
          el('r-r').textContent = fmt(rr) + ' m';
        }
      }
      el('mode-fc').addEventListener('click', () => switchSolve('fc'));
      el('mode-m').addEventListener('click', () => switchSolve('m'));
      el('mode-v').addEventListener('click', () => switchSolve('v'));
      el('mode-r').addEventListener('click', () => switchSolve('r'));
      ['fc', 'm', 'v', 'r'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts shared state ----
      const charts = {};
      function bState() {
        const v = 6, r = 1;
        return { v, r, m: B_MASS, Fc: (B_MASS * v * v) / r };
      }

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.v = new Chart(el('chart-v'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Fc', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Speed v (m/s)' } }, y: { title: { display: true, text: 'Fc (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.r2 = new Chart(el('chart-r2'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Fc', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Radius r (m)' } }, y: { title: { display: true, text: 'Fc (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L1 = [], D1 = [];
        for (let vv = 0.5; vv <= 12.001; vv += 0.5) { L1.push(vv.toFixed(1)); D1.push(+((s.m * vv * vv) / s.r).toFixed(3)); }
        charts.v.data.labels = L1; charts.v.data.datasets[0].data = D1; charts.v.update();

        const L2 = [], D2 = [];
        for (let rr = 0.3; rr <= 3.0001; rr += 0.15) { L2.push(rr.toFixed(2)); D2.push(+((s.m * s.v * s.v) / rr).toFixed(3)); }
        charts.r2.data.labels = L2; charts.r2.data.datasets[0].data = D2; charts.r2.update();
      }

      // ---- Diagram 1: mass at four orbit positions, force arrow always inward ----
      let diagOrbit = null;
      function initDiagOrbit() {
        const c = el('diag-orbit'); if (!c) throw new Error('no container');
        const s = makeScene(c, 8, new THREE.Vector3(0, 0, 0), OPTS);
        s.scene.add(new THREE.GridHelper(10, 10, 0xe2e8f0, 0xeef2f7));
        const R = 2.4;
        const ballMat = new THREE.MeshStandardMaterial({ color: 0x6366f1 });
        const circlePts = [];
        for (let i = 0; i <= 48; i++) { const a = (i / 48) * Math.PI * 2; circlePts.push(new THREE.Vector3(Math.cos(a) * R, Math.sin(a) * R, 0)); }
        s.scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(circlePts), new THREE.LineBasicMaterial({ color: 0x94a3b8 })));
        [0, 90, 180, 270].forEach((deg) => {
          const a = deg * Math.PI / 180;
          const pos = new THREE.Vector3(Math.cos(a) * R, Math.sin(a) * R, 0);
          const ball = new THREE.Mesh(new THREE.SphereGeometry(0.18, 16, 12), ballMat);
          ball.position.copy(pos);
          s.scene.add(ball);
          const inward = pos.clone().normalize().multiplyScalar(-1);
          s.scene.add(arrow(pos, pos.clone().add(inward.multiplyScalar(0.9)), 0xef4444));
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagOrbit = { resize: s.resize };
      }

      // ---- Diagram 2: family of Fc-vs-v curves at different radii ----
      let diagFcv = null;
      function initDiagFcv() {
        const c = el('diag-fcv'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(4, 2, 0), OPTS);
        const grid = new THREE.GridHelper(16, 16, 0xe2e8f0, 0xeef2f7); grid.position.set(4, 0, 0); s.scene.add(grid);
        const m = 1;
        const radii = [0.5, 1, 2];
        radii.forEach((r) => {
          const pts = [];
          for (let v = 0; v <= 8; v += 0.4) { pts.push(new THREE.Vector3(v, Math.min(8, (m * v * v) / r * 0.3), 0)); }
          const col = r === 1 ? 0x4f46e5 : 0x94a3b8;
          const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: col, transparent: r !== 1, opacity: r === 1 ? 1 : 0.7 }));
          s.scene.add(line);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0035); s.renderer.render(s.scene, s.camera); }
        frame();
        diagFcv = { resize: s.resize };
      }

      function boot() {
        try { switchSolve('fc'); update(); } catch (e) { console.error('[centripetal-force] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[centripetal-force] charts failed', e); }
        if (window.THREE) {
          try { initDiagOrbit(); } catch (e) { console.error('[centripetal-force] orbit diagram failed', e); }
          try { initDiagFcv(); } catch (e) { console.error('[centripetal-force] fcv diagram failed', e); }
        }
        mountResize([diagOrbit, diagFcv]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
