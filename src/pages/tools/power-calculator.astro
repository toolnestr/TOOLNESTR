---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Power Calculator';
const description = 'Free electrical power calculator. Calculate power (watts) from voltage, current and resistance using P=VI, P=I\u00b2R and P=V\u00b2/R.';
const intro = 'Enter any two electrical values (voltage, current, resistance, power) to compute the remaining parameters using the power law and Ohm\u2019s Law.';
const category = { id: 'engineering', name: 'Electrical Engineering' };
const faqs = [
  { q: 'What is electrical power?', a: 'Electrical power is the rate at which electrical energy is transferred or consumed in a circuit. It is measured in watts (W) and calculated as P = V \u00d7 I, where V is voltage and I is current.' },
  { q: 'What are the three power formulas?', a: 'Power can be calculated three ways: P = VI (using voltage and current), P = I\u00b2R (using current and resistance), and P = V\u00b2/R (using voltage and resistance). All three give the same result and are derived from combining P = VI with Ohm\u2019s Law.' },
  { q: 'What is the difference between AC power and DC power?', a: 'DC power is simple: P = V \u00d7 I with constant values. AC power is more complex because voltage and current alternate sinusoidally. For AC, P = V\u0280\u1d39\u1d38 \u00d7 I\u0280\u1d39\u1d38 \u00d7 PF, where PF is the power factor.' },
  { q: 'What is power factor?', a: 'Power factor (PF) is the ratio of real power to apparent power in an AC circuit, ranging from 0 to 1. A PF of 1 means all power is used effectively. Low PF causes higher current for the same real power, increasing losses.' },
  { q: 'What is the difference between real power and apparent power?', a: 'Real power (watts) does useful work. Apparent power (volt-amps, VA) is the product of RMS voltage and current. Reactive power (VAR) oscillates between source and load without doing work. PF = real power / apparent power.' },
  { q: 'How do I calculate energy consumption in kWh?', a: 'Energy (kWh) = Power (kW) \u00d7 Time (hours). For example, a 100W bulb running for 10 hours uses 1 kWh. Multiply by your electricity rate to find the cost.' },
  { q: 'What happens if a component\u2019s power rating is exceeded?', a: 'Exceeding the power rating causes overheating. A resistor may change value or burn out. A semiconductor junction may fail catastrophically. Always design with a safety margin of at least 50\u2013100% above the calculated dissipation.' },
  { q: 'Why use RMS values for AC power?', a: 'RMS (Root Mean Square) values give the DC-equivalent heating effect of an AC waveform. For a sinusoidal AC, V\u0280\u1d39\u1d38 = V\u209a\u2094\u209b/\u221a2. Using RMS ensures power calculations are correct for AC circuits.' },
  { q: 'What is the maximum power transfer theorem?', a: 'Maximum power is transferred from a source to a load when the load resistance equals the source resistance (impedance matching). This is important in audio systems, RF circuits, and power supply design.' },
  { q: 'How does wire resistance affect power delivery?', a: 'Wire resistance causes I\u00b2R losses \u2014 power wasted as heat in the wiring. For long runs or high currents, these losses can be significant. Using thicker wire (lower resistance) reduces these losses and improves efficiency.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Voltage (V)</span>
        <input id="v" type="number" step="any" placeholder="120" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current (A)</span>
        <input id="i" type="number" step="any" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Resistance (&Omega;)</span>
        <input id="r" type="number" step="any" placeholder="24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Power (W)</span>
        <input id="p" type="number" step="any" placeholder="600" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Voltage</div><div id="r-v" class="mt-1 text-xl font-bold">\u2014</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Current</div><div id="r-i" class="mt-1 text-xl font-bold text-emerald-600">\u2014</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Resistance</div><div id="r-r" class="mt-1 text-xl font-bold text-amber-600">\u2014</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Power</div><div id="r-p" class="mt-1 text-xl font-bold text-slate-800">\u2014</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different power consumption ranges mean</h2>
    <p class="mt-2 text-slate-600">Power consumption spans orders of magnitude across electronics, appliances and industrial equipment.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">mW range</span><span class="text-slate-400">0.001 \u2013 1 W \u2014 Electronics, sensors</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:5%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">W range</span><span class="text-slate-400">1 \u2013 100 W \u2014 Household electronics</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">kW range</span><span class="text-slate-400">0.1 \u2013 10 kW \u2014 Appliances, tools</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">MW range</span><span class="text-slate-400">10 kW \u2013 100+ MW \u2014 Industrial, grid</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:50%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDD17</span>
      <h3 class="mt-2 font-semibold text-slate-900">Electronics Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Verify power dissipation in components, size power supplies, and ensure designs stay within safe thermal limits.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83C\uDFE0</span>
      <h3 class="mt-2 font-semibold text-slate-900">Home Appliance User</h3>
      <p class="mt-1 text-sm text-slate-600">Estimate appliance power consumption and calculate energy costs to manage your electricity bill more effectively.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDCCA</span>
      <h3 class="mt-2 font-semibold text-slate-900">Energy Auditor</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate power usage of equipment during energy audits and identify opportunities for efficiency improvements and savings.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">\uD83D\uDD0C</span>
      <h3 class="mt-2 font-semibold text-slate-900">Student</h3>
      <p class="mt-1 text-sm text-slate-600">Practice power calculations using all three formula variations and verify homework answers for electrical engineering courses.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Device</th><th class="p-3">Typical power</th><th class="p-3">Energy / hour</th><th class="p-3">Cost @ $0.12/kWh</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">LED bulb</td><td class="p-3">9 W</td><td class="p-3">0.009 kWh</td><td class="p-3">$0.001</td></tr>
        <tr><td class="p-3 font-medium">Laptop charger</td><td class="p-3">65 W</td><td class="p-3">0.065 kWh</td><td class="p-3">$0.008</td></tr>
        <tr><td class="p-3 font-medium">Desktop computer</td><td class="p-3">300 W</td><td class="p-3">0.300 kWh</td><td class="p-3">$0.036</td></tr>
        <tr><td class="p-3 font-medium">Refrigerator</td><td class="p-3">500 W</td><td class="p-3">0.500 kWh</td><td class="p-3">$0.060</td></tr>
        <tr><td class="p-3 font-medium">Microwave oven</td><td class="p-3">1000 W</td><td class="p-3">1.000 kWh</td><td class="p-3">$0.120</td></tr>
        <tr><td class="p-3 font-medium">Air conditioner (window)</td><td class="p-3">1500 W</td><td class="p-3">1.500 kWh</td><td class="p-3">$0.180</td></tr>
        <tr><td class="p-3 font-medium">Electric heater</td><td class="p-3">2000 W</td><td class="p-3">2.000 kWh</td><td class="p-3">$0.240</td></tr>
        <tr><td class="p-3 font-medium">EV charger</td><td class="p-3">7000 W</td><td class="p-3">7.000 kWh</td><td class="p-3">$0.840</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Power Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter two values</h3>
        <p class="mt-1 text-sm text-slate-600">Type any two of the four parameters \u2014 voltage, current, resistance, power. The calculator uses all three power formulas.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the results</h3>
        <p class="mt-1 text-sm text-slate-600">All four values update instantly \u2014 voltage, current, resistance and power \u2014 cross-checked for consistency.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Apply the results</h3>
        <p class="mt-1 text-sm text-slate-600">Use the calculated power to select components, estimate energy costs, or verify that your circuit operates within safe limits.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate power calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use RMS values for AC circuits</h3>
        <p class="mt-1 text-sm text-slate-600">For AC power calculations, always use RMS voltage and RMS current. For a standard sinusoidal waveform, V\u0280\u1d39\u1d38 = V\u209a\u2094\u209b / \u221a2. Using peak values will give incorrect results.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Consider power factor for AC loads</h3>
        <p class="mt-1 text-sm text-slate-600">For AC circuits with inductive or capacitive loads (motors, transformers, LED drivers), the power factor reduces real power. Real power = V \u00d7 I \u00d7 PF. This calculator assumes resistive loads (PF = 1).</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Always check maximum ratings</h3>
        <p class="mt-1 text-sm text-slate-600">Compare calculated power dissipation against component ratings. A 1/4W resistor with 1W dissipation will fail. Design with a safety margin of at least 50% above calculated values.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use consistent units</h3>
        <p class="mt-1 text-sm text-slate-600">Enter all values in base units (volts, amps, ohms, watts). The calculator handles the math, but using mixed units like kilovolts and milliamps without conversion will produce wrong results.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The power formulas</h2>
    <p class="mt-2 text-slate-600">Electrical power is calculated using three equivalent formulas derived from P = VI and Ohm\u2019s Law. P = VI is the fundamental definition of electrical power. Substituting V = IR gives P = I\u00b2R, and substituting I = V/R gives P = V\u00b2/R. Each form is useful depending on which two quantities you know.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">AC vs DC power</h2>
    <p class="mt-2 text-slate-600">DC power calculation is straightforward: P = V \u00d7 I, where both are constant. AC power is more complex because voltage and current alternate. For resistive loads, P = V\u0280\u1d39\u1d38 \u00d7 I\u0280\u1d39\u1d38 works the same as DC. For reactive loads, the power factor must be included, and there is a distinction between real power (W), reactive power (VAR), and apparent power (VA).</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Real vs apparent power</h2>
    <p class="mt-2 text-slate-600">In AC circuits, real power (P, in watts) does actual work. Apparent power (S, in volt-amps) is the product of RMS voltage and current. Reactive power (Q, in VAR) oscillates between source and load. The relationship is S\u00b2 = P\u00b2 + Q\u00b2, and power factor PF = P/S. A purely resistive load has PF = 1; a purely reactive load has PF = 0.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Energy calculation (kWh)</h2>
    <p class="mt-2 text-slate-600">Energy consumption is power multiplied by time. One kilowatt-hour (kWh) is the energy used by a 1,000 W device running for one hour. To calculate energy cost: Energy (kWh) = Power (W) / 1000 \u00d7 Time (hours), then multiply by your electricity rate. For example, a 100 W bulb for 10 hours uses 1 kWh; at $0.12/kWh that costs $0.12.</p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function fmt(n) { return parseFloat(n.toFixed(4)).toString(); }
    let updating = false;

    function update(source) {
      if (updating) return;
      updating = true;

      const v = parseFloat(el('v').value);
      const i = parseFloat(el('i').value);
      const r = parseFloat(el('r').value);
      const p = parseFloat(el('p').value);

      const hasV = !isNaN(v);
      const hasI = !isNaN(i);
      const hasR = !isNaN(r);
      const hasP = !isNaN(p);

      const count = hasV + hasI + hasR + hasP;

      if (count < 2) {
        ['r-v','r-i','r-r','r-p'].forEach(id => el(id).textContent = '\u2014');
        updating = false;
        return;
      }

      let newV = NaN, newI = NaN, newR = NaN, newP = NaN;

      if (hasV && hasI) { newV = v; newI = i; newR = v / i; newP = v * i; }
      else if (hasV && hasR) { newV = v; newR = r; newI = v / r; newP = v * v / r; }
      else if (hasV && hasP) { newV = v; newP = p; newI = p / v; newR = v * v / p; }
      else if (hasI && hasR) { newR = r; newI = i; newV = i * r; newP = i * i * r; }
      else if (hasI && hasP) { newI = i; newP = p; newV = p / i; newR = p / (i * i); }
      else if (hasR && hasP) { newR = r; newP = p; newV = Math.sqrt(p * r); newI = Math.sqrt(p / r); }
      else { updating = false; return; }

      if (source !== 'v' && !isNaN(newV)) el('v').value = fmt(newV);
      if (source !== 'i' && !isNaN(newI)) el('i').value = fmt(newI);
      if (source !== 'r' && !isNaN(newR)) el('r').value = fmt(newR);
      if (source !== 'p' && !isNaN(newP)) el('p').value = fmt(newP);

      el('r-v').textContent = isNaN(newV) ? '\u2014' : fmt(newV) + ' V';
      el('r-i').textContent = isNaN(newI) ? '\u2014' : fmt(newI) + ' A';
      el('r-r').textContent = isNaN(newR) ? '\u2014' : fmt(newR) + ' \u03a9';
      el('r-p').textContent = isNaN(newP) ? '\u2014' : fmt(newP) + ' W';

      updating = false;
    }

    ['v','i','r','p'].forEach(id => el(id).addEventListener('input', () => update(id)));
  </script>
</ToolLayout>
