---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Power Calculator';
const description = "Electrical power calculator. Solve P=VI, P=I²R, and P=V²/R for power, voltage, current, or resistance, with worked examples and an energy-cost table.";
const intro = 'Enter any two of voltage, current, resistance, or power to solve for the rest using the power law and Ohm\'s Law. Two 3D diagrams compare a low-power and high-power circuit, and charts show how power scales with voltage and current.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is electrical power?', a: 'Electrical power is the rate at which electrical energy is transferred or consumed in a circuit. It is measured in watts (W) and calculated as P = V × I, where V is voltage and I is current.' },
  { q: 'What are the three power formulas?', a: 'Power can be calculated three ways: P = VI (using voltage and current), P = I²R (using current and resistance), and P = V²/R (using voltage and resistance). All three give the same result and follow from combining P = VI with Ohm\'s Law.' },
  { q: 'What is the difference between AC power and DC power?', a: 'DC power is straightforward: P = V × I with constant values. AC power is more complex because voltage and current alternate — for AC, real power P = V_RMS × I_RMS × PF, where PF is the power factor.' },
  { q: 'What is power factor?', a: 'Power factor (PF) is the ratio of real power to apparent power in an AC circuit, ranging from 0 to 1. A PF of 1 means all delivered power does useful work; a low PF means higher current is needed for the same real power.' },
  { q: 'How do I calculate energy consumption in kWh?', a: 'Energy (kWh) = Power (kW) × Time (hours). A 100 W bulb running for 10 hours uses 1 kWh — multiply by your electricity rate to find the cost.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Power Calculator',
  description: 'Solve for electrical power, voltage, current, or resistance using P=VI, P=I²R, and P=V²/R.',
  steps: [
    { name: 'Enter any two values', text: 'Provide any two of voltage, current, resistance, or power.' },
    { name: 'Read all four results', text: 'All four quantities solve instantly and are cross-checked against each other.' },
    { name: 'Estimate energy cost', text: 'Use the resulting power with time and your electricity rate to estimate running cost.' },
  ],
};

const formulas = [
  { expr: 'P = V × I', note: 'power from voltage and current — the fundamental definition' },
  { expr: 'P = I²R', note: 'power from current and resistance (via Ohm\'s Law V=IR)' },
  { expr: 'P = V²/R', note: 'power from voltage and resistance (via Ohm\'s Law I=V/R)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a household appliance circuit', tone: 'slate',
    given: 'A device draws 5 A from a 120 V supply. Find the power, resistance, and verify with all three formulas.',
    rows: [
      { label: 'Direct power:', value: 'P = V × I = 120 × 5 = 600 W' },
      { label: 'Resistance:', value: 'R = V / I = 120 / 5 = 24 Ω' },
      { label: 'Verify with I²R:', value: 'P = 5² × 24 = 600 W ✓' },
      { label: 'Verify with V²/R:', value: 'P = 120² / 24 = 600 W ✓', full: true },
    ],
    note: 'All three power formulas agree exactly, as they must — they are algebraically equivalent, just rearranged for whichever two values you happen to know.',
  },
  {
    title: 'Worked example 2 — energy cost over time', tone: 'amber',
    given: 'The same 600 W device runs for 4 hours. Electricity costs $0.12 per kWh. Find the energy used and the cost.',
    rows: [
      { label: 'Energy:', value: 'E = P × t = 0.6 kW × 4 h = 2.4 kWh' },
      { label: 'Cost:', value: 'Cost = 2.4 kWh × $0.12/kWh = $0.288', full: true },
    ],
    note: 'Converting power to kilowatts before multiplying by hours is the standard way utility bills calculate energy charges.',
  },
];

const comparison = {
  heading: 'Typical household device power draw',
  note: 'Devices span nearly three orders of magnitude in power draw — understanding this range helps with circuit sizing and energy budgeting.',
  headers: [{ label: 'Device' }, { label: 'Power' }, { label: 'Energy / hour' }],
  rows: [
    ['LED bulb', '9 W', '0.009 kWh'],
    ['Laptop charger', '65 W', '0.065 kWh'],
    ['Household circuit ★', '600 W', '0.600 kWh'],
    ['Electric heater', '2000 W', '2.000 kWh'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). Even a modest 600 W device adds up to real energy cost when it runs for hours at a time.',
};

const realWorld = [
  { emoji: '🔌', title: 'Electronics and circuit design', body: 'Engineers verify power dissipation in components, size power supplies, and ensure designs stay within safe thermal limits before a single prototype is built.' },
  { emoji: '🏠', title: 'Home energy management', body: 'Estimating appliance power consumption lets homeowners calculate energy costs and identify the biggest opportunities to reduce their electricity bill.' },
  { emoji: '📊', title: 'Energy auditing', body: 'Professional energy audits calculate the power usage of equipment across a facility to identify efficiency improvements and prioritize the highest-impact upgrades.' },
  { emoji: '🔋', title: 'Battery and power supply sizing', body: 'Choosing a battery or power supply rated for the right wattage requires knowing the actual power draw of every connected device — undersizing risks overheating or failure.' },
];

const misconceptions = [
  { claim: '"All three power formulas (P=VI, P=I²R, P=V²/R) give different answers for the same circuit."', truth: 'All three are algebraically equivalent — they must give exactly the same power for a consistent circuit, since each is just P=VI rewritten using Ohm\'s Law (V=IR) to substitute out one variable.' },
  { claim: '"Doubling the voltage always doubles the power."', truth: 'It depends on which formula applies — for a fixed resistance, P=V²/R means doubling voltage actually quadruples power, since voltage is squared in that form.' },
  { claim: '"Watts and watt-hours (or kWh) measure the same thing."', truth: 'Watts (W) measure instantaneous power — the rate of energy use right now. Watt-hours (or kWh) measure total energy consumed over time, found by multiplying power by duration.' },
  { claim: '"A higher power rating always means a device uses more energy."', truth: 'Total energy used depends on both power and how long the device runs — a high-power device used briefly can use less total energy than a low-power device left running for a long time.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — Chapter 9, "Current and Resistance" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/9-4-electrical-energy-and-power" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 27, Circuits (Power in Electric Circuits).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 27, Current and Resistance.' },
];
const sourcesNote = 'P=VI, P=I²R, P=V²/R. This calculator assumes DC or purely resistive AC circuits (power factor = 1). Results are rounded for display.';

const howToUse = [
  { title: 'Enter any two values', body: 'Provide voltage, current, resistance, or power — the other two fill in automatically.' },
  { title: 'Read all four results', body: 'Voltage, current, resistance, and power are all shown, cross-checked for consistency.' },
  { title: 'Estimate running cost', body: 'Multiply the resulting power by hours of use and your electricity rate to estimate cost.' },
];

const related = [
  { href: '/tools/ohms-law-calculator', emoji: '🔌', title: "Ohm's Law Calculator", desc: 'V=IR — solve voltage, current, resistance, or power.' },
  { href: '/tools/electric-power-calculator', emoji: '💡', title: 'Electric Power Calculator', desc: 'P = V×I plus energy (kWh) and electricity cost.' },
  { href: '/tools/series-resistor-calculator', emoji: '🔌', title: 'Series Resistor Calculator', desc: 'R_total = R1 + R2 + ... plus current and voltage-divider drops.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="electrical power is the rate energy flows through a circuit, and because voltage, current, and resistance are all tied together by Ohm's Law, any two of them are enough to find every other electrical quantity in a simple resistive circuit."
  howIntro="Power is fundamentally defined as P = V×I — voltage times current. Substituting Ohm's Law (V = IR) into that definition eliminates V in favor of I and R, giving P = I²R; substituting I = V/R instead eliminates I, giving P = V²/R. All three forms describe the exact same physical quantity, just expressed using whichever two variables happen to be known in a given problem."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where electrical power calculations actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-sm text-slate-500">Enter any two values, leave the rest blank.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Voltage (V)</span>
        <input id="v" type="number" step="any" placeholder="120" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current (I)</span>
        <input id="i" type="number" step="any" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Resistance (Ω)</span>
        <input id="r" type="number" step="any" placeholder="24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Power (W)</span>
        <input id="p" type="number" step="any" placeholder="600" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Voltage</div><div id="r-v" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Current</div><div id="r-i" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Resistance</div><div id="r-r" class="mt-1 text-xl font-bold text-amber-600">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Power</div><div id="r-p" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="pwr-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Low power vs high power circuits</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-low" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A low-power circuit (LED bulb)</h3>
          <p class="mt-1 text-sm text-slate-600">A small resistor glows dimly — low current, low power, minimal heat generated.</p>
        </div>
        <div>
          <div id="diag-high" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. A high-power circuit (heater)</h3>
          <p class="mt-1 text-sm text-slate-600">A larger resistive element dissipates far more power as heat — the same P=I²R relationship at a much larger scale.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Power graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Power vs voltage (fixed R=24Ω) — the quadratic P=V²/R curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-v"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Power vs current (fixed R=24Ω) — the quadratic P=I²R curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-i"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator (preserves original two-of-four solve logic) ----
      let updating = false;
      function update(source) {
        if (updating) return;
        updating = true;
        el('pwr-err').textContent = '';
        const v = parseFloat(el('v').value);
        const i = parseFloat(el('i').value);
        const r = parseFloat(el('r').value);
        const p = parseFloat(el('p').value);
        const hasV = !isNaN(v), hasI = !isNaN(i), hasR = !isNaN(r), hasP = !isNaN(p);
        const count = hasV + hasI + hasR + hasP;
        if (count < 2) {
          ['r-v', 'r-i', 'r-r', 'r-p'].forEach((id) => (el(id).textContent = '—'));
          updating = false;
          return;
        }
        let newV = NaN, newI = NaN, newR = NaN, newP = NaN;
        if (hasV && hasI) { newV = v; newI = i; newR = v / i; newP = v * i; }
        else if (hasV && hasR) { newV = v; newR = r; newI = v / r; newP = (v * v) / r; }
        else if (hasV && hasP) { newV = v; newP = p; newI = p / v; newR = (v * v) / p; }
        else if (hasI && hasR) { newR = r; newI = i; newV = i * r; newP = i * i * r; }
        else if (hasI && hasP) { newI = i; newP = p; newV = p / i; newR = p / (i * i); }
        else if (hasR && hasP) { newR = r; newP = p; newV = Math.sqrt(p * r); newI = Math.sqrt(p / r); }
        else { updating = false; return; }
        if (source !== 'v' && !isNaN(newV)) el('v').value = fmt(newV);
        if (source !== 'i' && !isNaN(newI)) el('i').value = fmt(newI);
        if (source !== 'r' && !isNaN(newR)) el('r').value = fmt(newR);
        if (source !== 'p' && !isNaN(newP)) el('p').value = fmt(newP);
        el('r-v').textContent = isNaN(newV) ? '—' : fmt(newV) + ' V';
        el('r-i').textContent = isNaN(newI) ? '—' : fmt(newI) + ' A';
        el('r-r').textContent = isNaN(newR) ? '—' : fmt(newR) + ' Ω';
        el('r-p').textContent = isNaN(newP) ? '—' : fmt(newP) + ' W';
        updating = false;
      }
      ['v', 'i', 'r', 'p'].forEach((id) => el(id).addEventListener('input', () => update(id)));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsV = [], dataV = [];
        for (let vv = 0; vv <= 200; vv += 20) { labelsV.push(vv); dataV.push(+((vv * vv) / 24).toFixed(1)); }
        charts.v = new Chart(el('chart-v'), {
          type: 'line',
          data: { labels: labelsV, datasets: [{ label: 'P (W)', data: dataV, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Voltage (V)' } }, y: { title: { display: true, text: 'Power (W)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsI = [], dataI = [];
        for (let ii = 0; ii <= 10; ii += 1) { labelsI.push(ii); dataI.push(+(ii * ii * 24).toFixed(1)); }
        charts.i = new Chart(el('chart-i'), {
          type: 'line',
          data: { labels: labelsI, datasets: [{ label: 'P (W)', data: dataI, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Current (A)' } }, y: { title: { display: true, text: 'Power (W)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function circuitScene(container, size, color) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const bulb = new THREE.Mesh(new THREE.SphereGeometry(size, 20, 16), new THREE.MeshStandardMaterial({ color, roughness: 0.3, emissive: color, emissiveIntensity: 0.4 }));
        s.scene.add(bulb);
        const wireMat = new THREE.LineBasicMaterial({ color: 0x94a3b8 });
        const pts = [new THREE.Vector3(-3, -1.5, 0), new THREE.Vector3(-size - 0.3, 0, 0)];
        s.scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), wireMat));
        const pts2 = [new THREE.Vector3(size + 0.3, 0, 0), new THREE.Vector3(3, -1.5, 0)];
        s.scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts2), wireMat));
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() { const c = el('diag-low'); if (!c) throw new Error('no container'); diagLow = circuitScene(c, 0.7, 0xfbbf24); }
      function initDiagHigh() { const c = el('diag-high'); if (!c) throw new Error('no container'); diagHigh = circuitScene(c, 1.6, 0xef4444); }

      function boot() {
        try { update(); } catch (e) { console.error('[power] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[power] charts failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[power] low diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[power] high diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
