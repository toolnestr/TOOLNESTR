---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Nautical Miles to Km"
  emoji="📏"
  fromUnit="nautical miles" toUnit="kilometers"
  fromTitle="Nautical Miles" toTitle="Kilometers"
  fromSym="nmi" toSym="km"
  quantity="length"
  kind="factor" factor={1.852}
  reverseSlug="km-to-miles" reverseLabel="Km to Miles Converter"
  hasReverse={false}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Used in sailing and aviation, where distances in nautical miles are converted to kilometers for planning."
/>
