---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Liters", sym: "L", toBase: 1 }, { name: "Milliliters", sym: "mL", toBase: 0.001 }, { name: "Cubic meters", sym: "m³", toBase: 1000 }, { name: "US gallons", sym: "gal", toBase: 3.785411784 }, { name: "US quarts", sym: "qt", toBase: 0.946352946 }, { name: "US pints", sym: "pt", toBase: 0.473176473 }, { name: "US cups", sym: "cup", toBase: 0.2365882365 }, { name: "US fluid ounces", sym: "fl oz", toBase: 0.0295735296 }, { name: "Tablespoons", sym: "tbsp", toBase: 0.0147867648 }, { name: "Teaspoons", sym: "tsp", toBase: 0.0049289216 }];
---
<MultiUnitConverter
  title="Volume Converter"
  emoji="🧪"
  quantity="volume"
  baseName="liter"
  units={units}
  defaultFrom={0} defaultTo={3}
  intro="Convert between volume units — liters, milliliters, cubic meters, us gallons, us quarts and more."
  blurb="Volume measures how much space a liquid or solid fills, from a teaspoon to a tank."
  related={[{"slug":"liters-to-gallons","label":"Liters to Gallons Converter"},{"slug":"cups-to-ml","label":"Cups to Ml Converter"},{"slug":"ml-to-ounces","label":"Ml to Fluid Ounces Converter"}]}
/>
