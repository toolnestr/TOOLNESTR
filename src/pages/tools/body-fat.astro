---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Body Fat Calculator';
const description =
  'Free body fat calculator using the U.S. Navy method. Estimate your body fat percentage from ' +
  'a few tape measurements, in metric or imperial units.';
const intro =
  'Enter a few body measurements to estimate your body fat percentage using the U.S. Navy method.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How accurate is the U.S. Navy method?', a: 'It\u2019s a widely used estimate based on tape measurements and is reasonably accurate for most people, though not as precise as a clinical body-composition scan.' },
  { q: 'Where do I measure?', a: 'Neck: just below the larynx. Waist: at the navel (men) or the narrowest point (women). Hip (women): at the widest point. Measure relaxed, without pulling the tape tight.' },
  { q: 'Is this medical advice?', a: 'No \u2014 it\u2019s an estimate for general information only.' },
  { q: 'What is a healthy body fat percentage?', a: 'For men, 10\u201320% is generally healthy; for women, 18\u201328%. Athletes often fall lower and anything above 25% (men) or 32% (women) is considered above average. Essential fat levels are about 3\u20135% for men and 10\u201313% for women.' },
  { q: 'How often should I measure body fat?', a: 'Monthly is ideal \u2014 body fat changes slowly, so weekly measurements are usually just noise. Measure at the same time of day and under the same conditions for consistency.' },
  { q: 'What\u2019s the difference between essential fat and storage fat?', a: 'Essential fat is the minimum needed for healthy function (found in nerves, bone marrow, organs) and is higher in women due to childbearing needs. Storage fat is the extra energy reserve under your skin and around organs.' },
  { q: 'Can body fat percentage be too low?', a: 'Yes. Essential fat levels are about 3\u20135% for men and 10\u201313% for women. Dropping below these can impair hormone function, bone health, immune response and temperature regulation.' },
  { q: 'How does age affect body fat percentage?', a: 'Body fat naturally increases with age as muscle mass declines, even if your weight stays the same. This is why body composition tracking becomes more informative than the scale as you get older.' },
  { q: 'What is visceral fat and why does it matter?', a: 'Visceral fat is the fat stored deep in your abdomen around your organs. It\u2019s more dangerous than subcutaneous fat because it releases inflammatory substances linked to heart disease and diabetes.' },
  { q: 'How does body fat distribution affect health risk?', a: 'Carrying more fat around the waist (apple shape) is linked to higher cardiovascular risk than carrying it around the hips and thighs (pear shape). Waist-to-hip ratio is a good additional check.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric (cm)</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial (in)</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
        <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (<span class="unit">cm</span>)</span>
        <input id="height" type="number" step="any" placeholder="175" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Neck (<span class="unit">cm</span>)</span>
        <input id="neck" type="number" step="any" placeholder="38" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waist (<span class="unit">cm</span>)</span>
        <input id="waist" type="number" step="any" placeholder="85" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="hip-wrap" class="block" style="display:none"><span class="text-sm font-medium text-slate-700">Hip (<span class="unit">cm</span>)</span>
        <input id="hip" type="number" step="any" placeholder="95" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Estimated body fat</div>
      <div id="bf-val" class="mt-1 text-3xl font-bold">—</div>
      <div id="bf-cat" class="mt-1 text-sm font-medium"></div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Fill in your measurements to estimate body fat.</p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical advice.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About body fat percentage</h2>
    <p class="mt-2 text-slate-600">
      Body fat percentage is often a more useful measure of fitness than weight alone. The U.S.
      Navy method estimates it from simple tape measurements you can take at home, making it an
      easy way to track changes over time as you train. Combine it with the <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a> and <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> for a complete picture of your health.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the Body Fat Calculator when weight alone isn’t telling you the full story — for example, if you’ve started strength training and want to track fat loss even if the scale doesn’t move. It’s popular with fitness enthusiasts who want a more accurate signal than BMI, and with coaches who need an affordable, repeatable way to monitor client progress without expensive scans.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Use a flexible, non-stretchable tape measure and keep it level and snug — not tight enough to compress the skin.</li>
      <li>Take each measurement three times and use the average to reduce error from placement variation.</li>
      <li>Measure at the same time of day (ideally in the morning before eating) for consistent tracking over time.</li>
    </ul>
  </section>

  <!-- Body fat ranges bar chart -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different body fat ranges mean</h2>
    <p class="mt-2 text-slate-600">Body fat percentage is typically grouped into categories that reflect fitness level and health risk. The ranges differ for men and women due to biological differences.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Essential fat</span><span class="text-slate-400">3–5% men / 10–13% women</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Athlete</span><span class="text-slate-400">5–10% men / 13–18% women</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:25%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Fitness</span><span class="text-slate-400">10–14% men / 18–21% women</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Average</span><span class="text-slate-400">14–18% men / 21–25% women</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Above average</span><span class="text-slate-400">18–25% men / 25–32% women</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">High</span><span class="text-slate-400">25%+ men / 32%+ women</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:25%"></div></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏃</span>
      <h3 class="mt-2 font-semibold text-slate-900">Fitness enthusiast</h3>
      <p class="mt-1 text-sm text-slate-600">Track changes in body composition that the scale can't show you, especially useful during a recomp or bodybuilding prep phase.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎯</span>
      <h3 class="mt-2 font-semibold text-slate-900">Weight-loss seeker</h3>
      <p class="mt-1 text-sm text-slate-600">Monitor whether the weight you're losing is actually fat or just water and muscle, so you can adjust your diet and training accordingly.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Personal trainer</h3>
      <p class="mt-1 text-sm text-slate-600">Get an affordable, repeatable body-fat estimate for clients that you can track month to month without expensive DEXA scan appointments.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧘</span>
      <h3 class="mt-2 font-semibold text-slate-900">Health-aware individual</h3>
      <p class="mt-1 text-sm text-slate-600">Understand whether your body fat sits in a healthy range and learn where your risk factors lie for conditions linked to excess body fat.</p>
    </div>
  </section>

  <!-- Body fat reference table -->
  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Category</th><th class="p-3">Men (% body fat)</th><th class="p-3">Women (% body fat)</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Essential fat</td><td class="p-3">3 – 5%</td><td class="p-3">10 – 13%</td></tr>
        <tr><td class="p-3 font-medium">Athlete</td><td class="p-3">5 – 10%</td><td class="p-3">13 – 18%</td></tr>
        <tr><td class="p-3 font-medium">Fitness</td><td class="p-3">10 – 14%</td><td class="p-3">18 – 21%</td></tr>
        <tr><td class="p-3 font-medium">Average</td><td class="p-3">14 – 18%</td><td class="p-3">21 – 25%</td></tr>
        <tr><td class="p-3 font-medium">Above average</td><td class="p-3">18 – 25%</td><td class="p-3">25 – 32%</td></tr>
        <tr><td class="p-3 font-medium">High</td><td class="p-3">25%+</td><td class="p-3">32%+</td></tr>
      </tbody>
    </table>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Body Fat Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Take your measurements</h3>
        <p class="mt-1 text-sm text-slate-600">Use a flexible tape to measure your neck, waist and (if female) hips. Keep the tape snug but not compressing the skin.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your height</h3>
        <p class="mt-1 text-sm text-slate-600">Add your height and sex, then enter the tape measurements in metric (cm) or imperial (in) as preferred.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your estimate</h3>
        <p class="mt-1 text-sm text-slate-600">Your estimated body fat percentage and category appear instantly. Use it as a trend marker by measuring monthly under the same conditions.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate body fat measurement</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Measure consistently</h3>
        <p class="mt-1 text-sm text-slate-600">Always measure at the same time of day (ideally morning, before eating) and under the same conditions. Body water levels affect tape measurements significantly.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use the right technique</h3>
        <p class="mt-1 text-sm text-slate-600">Pull the tape snug but never tight enough to compress the skin. Take each measurement three times and average them to reduce placement errors.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Track trends, not single readings</h3>
        <p class="mt-1 text-sm text-slate-600">Body fat changes slowly. A single reading can be misleading — focus on the direction of change over several weeks or months rather than the absolute number.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      document.querySelectorAll('.unit').forEach((u) => (u.textContent = isMetric ? 'cm' : 'in'));
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const female = el('sex').value === 'female';
      el('hip-wrap').style.display = female ? 'block' : 'none';
      const k = metric ? 1 : 2.54; // inches → cm
      const height = parseFloat(el('height').value) * k;
      const neck = parseFloat(el('neck').value) * k;
      const waist = parseFloat(el('waist').value) * k;
      const hip = parseFloat(el('hip').value) * k;
      let bf;
      try {
        if (female) {
          if (!height || !neck || !waist || !hip || (waist + hip - neck) <= 0) throw 0;
          bf = 495 / (1.29579 - 0.35004 * Math.log10(waist + hip - neck) + 0.22100 * Math.log10(height)) - 450;
        } else {
          if (!height || !neck || !waist || (waist - neck) <= 0) throw 0;
          bf = 495 / (1.0324 - 0.19077 * Math.log10(waist - neck) + 0.15456 * Math.log10(height)) - 450;
        }
      } catch (e) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      if (!isFinite(bf) || bf <= 0 || bf > 70) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      let cat;
      if (female) cat = bf < 14 ? 'Essential/athlete' : bf < 21 ? 'Fitness' : bf < 25 ? 'Average' : bf < 32 ? 'Above average' : 'High';
      else cat = bf < 6 ? 'Essential/athlete' : bf < 14 ? 'Fitness' : bf < 18 ? 'Average' : bf < 25 ? 'Above average' : 'High';
      el('bf-val').textContent = bf.toFixed(1) + '%';
      el('bf-cat').textContent = cat;
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'height', 'neck', 'waist', 'hip'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
