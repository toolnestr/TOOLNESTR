---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Body Fat Calculator';
const description =
  'Free body fat calculator using the U.S. Navy method. Estimate your body fat percentage from ' +
  'a few tape measurements, in metric or imperial units.';
const intro =
  'Enter a few body measurements to estimate your body fat percentage using the U.S. Navy method.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How accurate is the U.S. Navy method?', a: 'It’s a widely used estimate based on tape measurements and is reasonably accurate for most people, though not as precise as a clinical body-composition scan.' },
  { q: 'Where do I measure?', a: 'Neck: just below the larynx. Waist: at the navel (men) or the narrowest point (women). Hip (women): at the widest point. Measure relaxed, without pulling the tape tight.' },
  { q: 'Is this medical advice?', a: 'No — it’s an estimate for general information only.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric (cm)</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial (in)</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
        <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (<span class="unit">cm</span>)</span>
        <input id="height" type="number" step="any" placeholder="175" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Neck (<span class="unit">cm</span>)</span>
        <input id="neck" type="number" step="any" placeholder="38" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waist (<span class="unit">cm</span>)</span>
        <input id="waist" type="number" step="any" placeholder="85" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="hip-wrap" class="block" style="display:none"><span class="text-sm font-medium text-slate-700">Hip (<span class="unit">cm</span>)</span>
        <input id="hip" type="number" step="any" placeholder="95" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Estimated body fat</div>
      <div id="bf-val" class="mt-1 text-3xl font-bold">—</div>
      <div id="bf-cat" class="mt-1 text-sm font-medium"></div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Fill in your measurements to estimate body fat.</p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical advice.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About body fat percentage</h2>
    <p class="mt-2 text-slate-600">
      Body fat percentage is often a more useful measure of fitness than weight alone. The U.S.
      Navy method estimates it from simple tape measurements you can take at home, making it an
      easy way to track changes over time as you train.
    </p>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a>
      or <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      document.querySelectorAll('.unit').forEach((u) => (u.textContent = isMetric ? 'cm' : 'in'));
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const female = el('sex').value === 'female';
      el('hip-wrap').style.display = female ? 'block' : 'none';
      const k = metric ? 1 : 2.54; // inches → cm
      const height = parseFloat(el('height').value) * k;
      const neck = parseFloat(el('neck').value) * k;
      const waist = parseFloat(el('waist').value) * k;
      const hip = parseFloat(el('hip').value) * k;
      let bf;
      try {
        if (female) {
          if (!height || !neck || !waist || !hip || (waist + hip - neck) <= 0) throw 0;
          bf = 495 / (1.29579 - 0.35004 * Math.log10(waist + hip - neck) + 0.22100 * Math.log10(height)) - 450;
        } else {
          if (!height || !neck || !waist || (waist - neck) <= 0) throw 0;
          bf = 495 / (1.0324 - 0.19077 * Math.log10(waist - neck) + 0.15456 * Math.log10(height)) - 450;
        }
      } catch (e) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      if (!isFinite(bf) || bf <= 0 || bf > 70) { el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return; }
      let cat;
      if (female) cat = bf < 14 ? 'Essential/athlete' : bf < 21 ? 'Fitness' : bf < 25 ? 'Average' : bf < 32 ? 'Above average' : 'High';
      else cat = bf < 6 ? 'Essential/athlete' : bf < 14 ? 'Fitness' : bf < 18 ? 'Average' : bf < 25 ? 'Above average' : 'High';
      el('bf-val').textContent = bf.toFixed(1) + '%';
      el('bf-cat').textContent = cat;
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'height', 'neck', 'waist', 'hip'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
