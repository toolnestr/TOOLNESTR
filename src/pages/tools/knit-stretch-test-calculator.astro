---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Knit Stretch % Test Calculator';
const description = 'Calculate a knit fabric\'s stretch percentage from a 4-inch stretch test, and see which patterns it suits.';
const intro = 'Calculate a knit fabric\'s stretch percentage from a simple 4-inch stretch test.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I perform the stretch test?', a: 'Mark or measure 4 inches of relaxed fabric along its most stretchy direction (usually the crossgrain for knits). Stretch that 4-inch section as far as it comfortably goes without curling or distorting, and measure the stretched length.' },
  { q: 'Why 4 inches specifically?', a: 'A 4-inch starting length is a widely used, easy-to-measure standard for home sewing stretch tests, and most pattern envelopes that specify a stretch requirement (like a percentage gauge printed on the pattern) are calibrated to this same 4-inch test.' },
  { q: 'What is the difference between 2-way and 4-way stretch?', a: 'Two-way stretch fabric stretches in one direction only (usually crossgrain/width), while four-way stretch fabric stretches in both the width and the length (crossgrain and lengthwise grain) — check both directions separately if a pattern requires 4-way stretch.' },
  { q: 'What happens if I use a pattern requiring more stretch than my fabric has?', a: 'The finished garment will likely be too tight or the fabric may be strained beyond its comfortable recovery range, leading to a garment that feels restrictive or loses its shape from the fabric being over-stretched during construction and wear.' },
];
const howTo = {
  name: 'How to test knit fabric stretch',
  steps: [
    { name: 'Measure 4 inches of relaxed fabric', text: 'Mark or measure exactly 4 inches along the fabric\'s stretchiest direction.' },
    { name: 'Stretch and measure', text: 'Stretch that section as far as comfortable and measure the new length.' },
    { name: 'Read the stretch percentage', text: 'The stretch percentage and suggested pattern suitability appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Stretched length (in), starting from 4 in</span>
      <input id="stretched" type="number" step="any" placeholder="e.g. 6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Stretch percentage</div>
        <div id="r-pct" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Suitable for</div><div id="r-category" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="kstc-title kstc-desc">
      <title id="kstc-title">Fabric shown relaxed at 4 inches and stretched longer</title>
      <desc id="kstc-desc">A short fabric strip labeled 4 inches relaxed, next to a longer stretched version of the same strip</desc>
      <rect x="100" y="60" width="120" height="40" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <text x="160" y="120" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">4 in relaxed</text>
      <rect x="400" y="60" width="220" height="40" fill="#f0abfc" stroke="#c026d3" stroke-width="2" />
      <text x="510" y="120" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Stretched length</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Stretch percentage compares the relaxed and fully stretched length</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How stretch percentage is calculated</h2>
    <p class="mt-2 text-slate-600">
      Starting from a standard 4-inch relaxed length, stretch percentage is the increase in length divided by the original 4 inches, expressed as a percentage. A 4-inch section that stretches to 6 inches has grown by 2 inches, and 2 ÷ 4 = 50%, meaning the fabric has 50% stretch.
    </p>
    <p class="mt-3 text-slate-600">
      Pattern companies commonly print a stretch gauge or a required percentage range directly on knit patterns, calibrated to this same 4-inch test method, so measuring your fabric this way lets you compare it directly against a pattern's stated requirement rather than guessing whether "medium stretch" fabric is stretchy enough.
    </p>
    <p class="mt-3 text-xs text-slate-400">The 4-inch stretch test is a widely used standard home-sewing method for gauging knit fabric stretch percentage against pattern requirements.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 4-inch section of fabric stretches comfortably to 6 inches.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Increase:</span> <span class="text-slate-600">6 − 4 = 2 in</span></div>
        <div><span class="font-medium text-slate-700">Stretch percentage:</span> <span class="text-slate-600">2 ÷ 4 = <strong>50%</strong></span></div>
        <div><span class="font-medium text-slate-700">Category:</span> <span class="text-slate-600">Moderate stretch — suits most knit patterns</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Buying knit fabric without a printed stretch percentage on the bolt is common, especially at fabric markets or from remnant bins, and a quick 4-inch test lets a shopper check on the spot whether a fabric meets a specific pattern's stated stretch requirement before committing to a purchase.
    </p>
    <p class="mt-3 text-slate-600">
      Activewear and swimwear patterns typically require high stretch (75% or more) with good recovery, while a relaxed t-shirt or lounge pattern may work fine with fabric in the 25-50% range — testing before cutting avoids the disappointment of a finished garment that's either uncomfortably tight or unexpectedly loose and saggy.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"More stretch is always better for a knit pattern." <strong class="text-slate-900">Not automatically.</strong> A pattern drafted for moderate-stretch fabric can turn out too loose and unstructured in a much higher-stretch fabric than intended, since the pattern's finished measurements assume a specific stretch range.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Stretch percentage tells you everything about how a knit will perform." <strong class="text-slate-900">It's only part of the picture.</strong> Recovery (how well the fabric snaps back after stretching) matters just as much — a fabric can have high stretch but poor recovery, leading to a garment that bags out and loses shape after wear.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/elastic-length-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Elastic Length Calculator</a>
      <a href="/tools/ease-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Ease Calculator</a>
      <a href="/tools/fabric-shrinkage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Shrinkage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const RELAXED = 4;

    function category(pct) {
      if (pct < 25) return 'Low stretch — stable knits, structured patterns';
      if (pct < 50) return 'Moderate stretch — suits most knit patterns';
      if (pct < 75) return 'High stretch — activewear, fitted knits';
      return 'Mechanical/super stretch — swimwear, dancewear';
    }

    function update() {
      const stretched = parseFloat(el('stretched').value);
      if (!stretched || stretched < RELAXED) { el('results').classList.add('hidden'); return; }
      const pct = ((stretched - RELAXED) / RELAXED) * 100;
      el('r-pct').textContent = pct.toFixed(0) + '%';
      el('r-category').textContent = category(pct);
      el('results').classList.remove('hidden');
    }

    el('stretched').addEventListener('input', update);
  </script>
</ToolLayout>
