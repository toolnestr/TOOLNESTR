---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = '99 Names of Allah (Asma ul Husna)';
const description = 'Browse and search all 99 Names of Allah (Asma ul Husna) with Arabic script, transliteration and English meanings.';
const intro = 'Browse and search the 99 beautiful Names of Allah, with Arabic, transliteration and meaning.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'What are the 99 Names of Allah?', a: 'They are the beautiful names and attributes of Allah (Asma ul Husna) mentioned in the Qur’an and Sunnah, such as Ar-Rahman (the Most Compassionate) and Al-Quddus (the Most Holy). Each describes a perfection of Allah.' },
  { q: 'What is the benefit of learning them?', a: 'The Prophet ﷺ said whoever enumerates and acts upon the names of Allah will enter Paradise. Learning them deepens knowledge of Allah, enriches du’a, and strengthens reliance and love.' },
  { q: 'What is the source of the names?', a: 'The names come from the Qur’an and authentic hadith. The well-known list of exactly 99 is a widely used compilation; scholars note the names of Allah are not strictly limited to this number.' },
  { q: 'How do I search the list?', a: 'Type any part of a name or its meaning in the search box — for example “merciful”, “light” or “rahman” — and the list filters instantly.' },
];

const names = [
  [1, 'Ar-Rahman', 'الرحمن', 'The Most Compassionate'], [2, 'Ar-Raheem', 'الرحيم', 'The Most Merciful'], [3, 'Al-Malik', 'الملك', 'The King'], [4, 'Al-Quddus', 'القدوس', 'The Most Holy'], [5, 'As-Salam', 'السلام', 'The Source of Peace'], [6, "Al-Mu'min", 'المؤمن', 'The Granter of Security'], [7, 'Al-Muhaymin', 'المهيمن', 'The Guardian'], [8, 'Al-Aziz', 'العزيز', 'The Almighty'], [9, 'Al-Jabbar', 'الجبار', 'The Compeller'], [10, 'Al-Mutakabbir', 'المتكبر', 'The Supreme'],
  [11, 'Al-Khaliq', 'الخالق', 'The Creator'], [12, 'Al-Bari', 'البارئ', 'The Originator'], [13, 'Al-Musawwir', 'المصور', 'The Fashioner'], [14, 'Al-Ghaffar', 'الغفار', 'The All-Forgiving'], [15, 'Al-Qahhar', 'القهار', 'The Subduer'], [16, 'Al-Wahhab', 'الوهاب', 'The Bestower'], [17, 'Ar-Razzaq', 'الرزاق', 'The Provider'], [18, 'Al-Fattah', 'الفتاح', 'The Opener'], [19, 'Al-Alim', 'العليم', 'The All-Knowing'], [20, 'Al-Qabid', 'القابض', 'The Withholder'],
  [21, 'Al-Basit', 'الباسط', 'The Extender'], [22, 'Al-Khafid', 'الخافض', 'The Reducer'], [23, 'Ar-Rafi', 'الرافع', 'The Exalter'], [24, "Al-Mu'izz", 'المعز', 'The Honourer'], [25, 'Al-Mudhill', 'المذل', 'The Dishonourer'], [26, 'As-Sami', 'السميع', 'The All-Hearing'], [27, 'Al-Basir', 'البصير', 'The All-Seeing'], [28, 'Al-Hakam', 'الحكم', 'The Judge'], [29, 'Al-Adl', 'العدل', 'The Utterly Just'], [30, 'Al-Latif', 'اللطيف', 'The Subtle One'],
  [31, 'Al-Khabir', 'الخبير', 'The All-Aware'], [32, 'Al-Halim', 'الحليم', 'The Forbearing'], [33, 'Al-Azim', 'العظيم', 'The Magnificent'], [34, 'Al-Ghafur', 'الغفور', 'The Great Forgiver'], [35, 'Ash-Shakur', 'الشكور', 'The Appreciative'], [36, 'Al-Ali', 'العلي', 'The Most High'], [37, 'Al-Kabir', 'الكبير', 'The Most Great'], [38, 'Al-Hafiz', 'الحفيظ', 'The Preserver'], [39, 'Al-Muqit', 'المقيت', 'The Sustainer'], [40, 'Al-Hasib', 'الحسيب', 'The Reckoner'],
  [41, 'Al-Jalil', 'الجليل', 'The Majestic'], [42, 'Al-Karim', 'الكريم', 'The Most Generous'], [43, 'Ar-Raqib', 'الرقيب', 'The Watchful'], [44, 'Al-Mujib', 'المجيب', 'The Responsive'], [45, 'Al-Wasi', 'الواسع', 'The All-Encompassing'], [46, 'Al-Hakim', 'الحكيم', 'The All-Wise'], [47, 'Al-Wadud', 'الودود', 'The Most Loving'], [48, 'Al-Majid', 'المجيد', 'The Most Glorious'], [49, "Al-Ba'ith", 'الباعث', 'The Resurrector'], [50, 'Ash-Shahid', 'الشهيد', 'The Witness'],
  [51, 'Al-Haqq', 'الحق', 'The Truth'], [52, 'Al-Wakil', 'الوكيل', 'The Trustee'], [53, 'Al-Qawiyy', 'القوي', 'The Most Strong'], [54, 'Al-Matin', 'المتين', 'The Firm'], [55, 'Al-Waliyy', 'الولي', 'The Protecting Friend'], [56, 'Al-Hamid', 'الحميد', 'The Praiseworthy'], [57, 'Al-Muhsi', 'المحصي', 'The Counter'], [58, 'Al-Mubdi', 'المبدئ', 'The Originator'], [59, "Al-Mu'id", 'المعيد', 'The Restorer'], [60, 'Al-Muhyi', 'المحيي', 'The Giver of Life'],
  [61, 'Al-Mumit', 'المميت', 'The Bringer of Death'], [62, 'Al-Hayy', 'الحي', 'The Ever-Living'], [63, 'Al-Qayyum', 'القيوم', 'The Self-Subsisting'], [64, 'Al-Wajid', 'الواجد', 'The Finder'], [65, 'Al-Majid', 'الماجد', 'The Noble'], [66, 'Al-Wahid', 'الواحد', 'The One'], [67, 'Al-Ahad', 'الأحد', 'The Indivisible'], [68, 'As-Samad', 'الصمد', 'The Eternal Refuge'], [69, 'Al-Qadir', 'القادر', 'The Capable'], [70, 'Al-Muqtadir', 'المقتدر', 'The Powerful'],
  [71, 'Al-Muqaddim', 'المقدم', 'The Expediter'], [72, "Al-Mu'akhkhir", 'المؤخر', 'The Delayer'], [73, 'Al-Awwal', 'الأول', 'The First'], [74, 'Al-Akhir', 'الآخر', 'The Last'], [75, 'Az-Zahir', 'الظاهر', 'The Manifest'], [76, 'Al-Batin', 'الباطن', 'The Hidden'], [77, 'Al-Wali', 'الوالي', 'The Governor'], [78, "Al-Muta'ali", 'المتعالي', 'The Most Exalted'], [79, 'Al-Barr', 'البر', 'The Source of Goodness'], [80, 'At-Tawwab', 'التواب', 'The Acceptor of Repentance'],
  [81, 'Al-Muntaqim', 'المنتقم', 'The Avenger'], [82, 'Al-Afuww', 'العفو', 'The Pardoner'], [83, "Ar-Ra'uf", 'الرؤوف', 'The Most Kind'], [84, 'Malik-ul-Mulk', 'مالك الملك', 'Owner of all Sovereignty'], [85, 'Dhul-Jalali wal-Ikram', 'ذو الجلال والإكرام', 'Lord of Majesty and Bounty'], [86, 'Al-Muqsit', 'المقسط', 'The Equitable'], [87, 'Al-Jami', 'الجامع', 'The Gatherer'], [88, 'Al-Ghani', 'الغني', 'The Self-Sufficient'], [89, 'Al-Mughni', 'المغني', 'The Enricher'], [90, 'Al-Mani', 'المانع', 'The Preventer'],
  [91, 'Ad-Darr', 'الضار', 'The Distresser'], [92, 'An-Nafi', 'النافع', 'The Benefiter'], [93, 'An-Nur', 'النور', 'The Light'], [94, 'Al-Hadi', 'الهادي', 'The Guide'], [95, 'Al-Badi', 'البديع', 'The Incomparable Originator'], [96, 'Al-Baqi', 'الباقي', 'The Everlasting'], [97, 'Al-Warith', 'الوارث', 'The Inheritor'], [98, 'Ar-Rashid', 'الرشيد', 'The Guide to the Right Path'], [99, 'As-Sabur', 'الصبور', 'The Patient'],
];
const sources = [
  { html: "<strong>The Qur’an</strong> — e.g. Surah an-Nisa (4:11–12, 4:176) for the fixed inheritance shares (fara’id)." },
  { html: "<strong>Sahih al-Bukhari &amp; Sahih Muslim</strong> — hadith on inheritance, zakat and nisab thresholds." },
  { html: "<strong>AAOIFI and recognized fiqh councils</strong> (e.g. Islamic Fiqh Academy) for contemporary rulings. <a href=\"https://aaoifi.com/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">aaoifi.com</a>" },
];
const sourcesNote = "Rulings differ between scholars and schools (madhahib), and calculated astronomical times/dates may differ from local sighting. Confirm with a qualified scholar before acting.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <input id="search" type="search" placeholder="Search a name or meaning… e.g. merciful, light, rahman" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
    <p id="count" class="mt-2 text-sm text-slate-500">99 names</p>
    <div id="grid" class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {names.map((n) => (
        <div class="name-card rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm" data-search={(n[1] + ' ' + n[3]).toLowerCase()}>
          <div class="flex items-start justify-between">
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-indigo-100 text-xs font-bold text-indigo-700">{n[0]}</span>
            <span class="text-2xl text-slate-800" lang="ar" dir="rtl">{n[2]}</span>
          </div>
          <div class="mt-2 font-semibold text-slate-900">{n[1]}</div>
          <div class="text-sm text-slate-500">{n[3]}</div>
        </div>
      ))}
    </div>
    <p id="empty" class="mt-4 hidden text-center text-sm text-slate-500">No names match your search.</p>
  </div>

  <figure class="mt-10">
    <svg width="800" height="120" viewBox="0 0 800 120" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="an-title an-desc">
      <title id="an-title">Decorative arch header for the 99 Names</title>
      <desc id="an-desc">An ornamental Islamic arch framing the title of the 99 Names of Allah.</desc>
      <path d="M150 110 V60 a250 50 0 0 1 500 0 V110" fill="#eef2ff" stroke="#a5b4fc" stroke-width="2" />
      <text x="400" y="70" text-anchor="middle" font-size="20" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">Asma ul Husna</text>
      <text x="400" y="94" text-anchor="middle" font-size="13" fill="#4f46e5" font-family="system-ui,sans-serif">The 99 Beautiful Names of Allah</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The beautiful names by which Allah has described Himself.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About the 99 Names of Allah</h2>
    <p class="mt-2 text-slate-600">Among the most cherished knowledge in Islam are the beautiful names of Allah, the Asma ul Husna. The Qur’an instructs, “And to Allah belong the best names, so invoke Him by them” (7:180). Each name reveals a perfection of Allah — His mercy, knowledge, power, generosity and justice — and together they teach the believer who Allah is and how to relate to Him in worship, hope and reliance.</p>
    <p class="mt-3 text-slate-600">This page presents the well-known list of 99 names with the Arabic script, an English transliteration, and a concise meaning for each. You can scroll the full set or use the search box to find a name instantly — type part of a transliteration like “rahman”, or an English word like “merciful”, “forgiver” or “light”, and the list filters as you type. Everything is built into the page, so it works offline and nothing is tracked.</p>
    <p class="mt-3 text-slate-600">The Prophet ﷺ said: “Allah has ninety-nine names, one hundred less one; whoever enumerates them will enter Paradise.” Scholars explain that enumerating them includes memorising them, understanding their meanings, and acting upon them — calling on Allah by the name that fits each need, and letting these attributes shape one’s character and du’a. Use this reference to learn a few each day, to enrich your supplications, and to grow in knowledge and love of your Creator.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/tasbih-counter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Digital Tasbih Counter</a>
      <a href="/tools/hijri-date-today" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Today’s Hijri Date</a>
      <a href="/tools/ramadan-countdown" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Ramadan Countdown</a>
    </div>
  </section>

  <script is:inline>
    const search = document.getElementById('search');
    const cards = Array.from(document.querySelectorAll('.name-card'));
    const count = document.getElementById('count'), empty = document.getElementById('empty');
    search.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase();
      let shown = 0;
      cards.forEach((c) => { const match = !q || c.dataset.search.indexOf(q) !== -1; c.style.display = match ? '' : 'none'; if (match) shown++; });
      count.textContent = shown + (shown === 1 ? ' name' : ' names');
      empty.classList.toggle('hidden', shown !== 0);
    });
  </script>
</ToolLayout>
