---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Osmosis/Tonicity Predictor';
const description = "Osmosis and tonicity calculator: compare intracellular and extracellular solute levels to predict water movement and whether a cell swells or shrinks.";
const intro = 'Compare a cell\'s internal solute concentration to its surrounding solution to predict which way water will move by osmosis, and what happens to the cell as a result — for both animal cells (crenation/lysis) and plant cells (plasmolysis/turgor). Two 3D diagrams compare a shrinking cell in a hypertonic solution to a swelling cell in a hypotonic solution, and charts show water movement direction across a range of concentration differences.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is tonicity?', a: "Tonicity describes how a surrounding solution's solute concentration compares to a cell's internal concentration, and therefore which way water will move across the cell membrane by osmosis." },
  { q: 'What do hypertonic, hypotonic, and isotonic mean?', a: 'A hypertonic solution has a higher solute concentration than the cell (water leaves the cell). A hypotonic solution has a lower solute concentration (water enters the cell). An isotonic solution has equal concentration (no net water movement).' },
  { q: 'Why do plant cells not burst in a hypotonic solution the way animal cells can?', a: 'Plant cells have a rigid cell wall outside the cell membrane that resists expansion — as water enters, internal pressure (turgor pressure) builds up against the wall, making the cell turgid and firm rather than causing it to burst.' },
  { q: 'What happens to an animal cell in a hypertonic solution?', a: 'Water leaves the cell, causing it to shrink and shrivel — a process called crenation. In a plant cell, the same water loss causes the cell membrane to pull away from the rigid cell wall, a distinct process called plasmolysis.' },
  { q: 'Why does osmosis matter for medical IV fluids?', a: "IV fluids must be isotonic to blood cells (or carefully managed if not) — an accidentally hypotonic IV fluid could cause red blood cells to swell and burst (hemolysis), while a hypertonic one could cause them to shrink and crenate, both of which are medically dangerous." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Osmosis/Tonicity Predictor',
  description: 'Compare intracellular and extracellular solute concentration to predict water movement and cell outcome.',
  steps: [
    { name: 'Enter both concentrations', text: 'Solute concentration inside the cell and in the surrounding solution, in mOsm/L.' },
    { name: 'Choose cell type', text: 'Animal cell (no wall) or plant cell (with a rigid cell wall).' },
    { name: 'Read the prediction', text: 'Tonicity, water movement direction, and the resulting cell behavior are shown instantly.' },
  ],
};

const formulas = [
  { expr: 'Compare C_outside to C_inside', note: 'higher outside concentration → hypertonic (water leaves); lower → hypotonic (water enters); equal → isotonic' },
  { expr: 'Water moves toward the higher solute concentration', note: 'osmosis moves water down its own concentration gradient, i.e., toward the more concentrated solute side' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a red blood cell in a hypertonic solution', tone: 'slate',
    given: 'A red blood cell has an internal concentration of 300 mOsm/L, placed in a solution of 500 mOsm/L.',
    rows: [
      { label: 'Comparison:', value: 'Outside (500) > Inside (300) → the solution is hypertonic relative to the cell' },
      { label: 'Water movement:', value: 'Water leaves the cell, moving toward the higher outside concentration' },
      { label: 'Result:', value: 'The cell shrinks and shrivels — a process called crenation', full: true },
    ],
    note: 'This is exactly why saltwater is dangerous to drink in excess — it draws water out of your cells rather than hydrating them.',
  },
  {
    title: 'Worked example 2 — a plant cell in a hypotonic solution', tone: 'amber',
    given: 'A plant cell has an internal concentration of 300 mOsm/L, placed in pure water (0 mOsm/L, hypotonic).',
    rows: [
      { label: 'Comparison:', value: 'Outside (0) < Inside (300) → the solution is hypotonic relative to the cell' },
      { label: 'Water movement:', value: 'Water enters the cell, moving toward the higher internal concentration' },
      { label: 'Result:', value: 'The cell becomes turgid (firm) as the rigid cell wall resists further expansion — it does not burst', full: true },
    ],
    note: "This turgor pressure is exactly what keeps a healthy, well-watered plant's leaves and stems firm and upright — wilting happens when cells lose this turgor pressure instead.",
  },
];

const comparison = {
  heading: 'Tonicity outcomes by cell type',
  note: 'The cell wall in plant cells fundamentally changes the outcome compared to animal cells.',
  headers: [{ label: 'Tonicity' }, { label: 'Animal cell result' }, { label: 'Plant cell result' }],
  rows: [
    ['Hypertonic solution ★', 'Crenation (shrinks, shrivels)', 'Plasmolysis (membrane pulls from wall)'],
    ['Isotonic solution', 'No change', 'No change (wall not under tension)'],
    ['Hypotonic solution', 'Swells, may lyse (burst)', 'Turgid (firm, does not burst)'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 1). The presence or absence of a rigid cell wall is the single biggest factor determining whether osmotic water entry is dangerous or beneficial to the cell.',
};

const realWorld = [
  { emoji: '💉', title: 'Medical IV fluid formulation', body: "IV fluids given to patients must be carefully matched to blood tonicity (typically isotonic, like 0.9% saline) — an incorrectly hypotonic or hypertonic IV fluid can damage red blood cells throughout the body." },
  { emoji: '🥗', title: 'Food preservation (salting and pickling)', body: 'Salting or sugaring food creates a strongly hypertonic environment that draws water out of any bacterial or fungal cells present, inhibiting their growth — the same osmosis principle used for centuries in food preservation.' },
  { emoji: '🌱', title: 'Plant irrigation and fertilizer management', body: "Over-fertilizing soil can create a hypertonic environment around plant roots, drawing water out of root cells instead of into them — a phenomenon known as fertilizer burn." },
  { emoji: '🧫', title: 'Laboratory cell culture technique', body: 'Cell culture media must be carefully formulated to be isotonic to the cells being grown, since even small osmotic imbalances can stress or kill cultured cells.' },
];

const misconceptions = [
  { claim: '"Hypertonic and hypotonic describe a fixed property of a solution, independent of what it\'s compared to."', truth: "Tonicity is always a relative, two-way comparison — the same solution can be hypertonic relative to one cell type and hypotonic relative to another, depending on each cell's own internal concentration." },
  { claim: '"Water moves from an area of low water concentration to high water concentration."', truth: "It's more precise (and less confusing) to describe osmosis in terms of solute concentration: water moves toward the side with the higher solute concentration, which is mathematically the same as saying it moves toward lower water concentration, but avoids ambiguity." },
  { claim: '"Plant cells can never be harmed by a hypotonic environment."', truth: "While the cell wall prevents plant cells from bursting in a hypotonic solution, they can still be damaged by a strongly hypertonic environment (plasmolysis), and severe or prolonged plasmolysis can be lethal to the cell." },
  { claim: '"Osmosis and diffusion are the same process."', truth: 'Osmosis specifically refers to the movement of water across a selectively permeable membrane; diffusion is the more general movement of any particle from high to low concentration. Osmosis is technically a special case of diffusion, applied specifically to water.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 5, "Structure and Function of Plasma Membranes" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/5-2-passive-transport" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Membrane transport and osmosis chapter.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Cell membrane transport chapter.' },
];
const sourcesNote = 'Comparison-based prediction: water moves toward the higher solute concentration side. Results assume a selectively permeable membrane freely permeable to water.';

const howToUse = [
  { title: 'Enter both concentrations', body: 'Intracellular and extracellular solute concentration, in mOsm/L.' },
  { title: 'Select cell type', body: 'Animal cell or plant cell — the cell wall changes the predicted outcome.' },
  { title: 'Read the prediction', body: 'Tonicity classification, water movement direction, and resulting cell behavior display instantly.' },
];

const related = [
  { href: '/tools/surface-area-volume-ratio-calculator', emoji: '📦', title: 'Surface Area-to-Volume Ratio Calculator', desc: 'SA:V = 6/s — why cells stay small.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'Solution concentration from moles and volume.' },
  { href: '/tools/dilution-calculator', emoji: '💧', title: 'Dilution Calculator', desc: 'C1V1=C2V2 — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="water always moves across a cell membrane toward whichever side has the higher solute concentration, and whether that movement helps or harms the cell depends entirely on which direction it's headed and whether the cell has a rigid wall to resist it."
  howIntro="A cell membrane is selectively permeable to water, which means water can cross it freely even when the larger solute particles dissolved on either side cannot. Osmosis moves that water toward the side with a higher solute concentration, diluting the more concentrated side until equilibrium is reached (or, in a living cell, until the membrane's limits are tested). Comparing a cell's internal solute concentration to its surroundings — hypertonic (more concentrated outside), hypotonic (less concentrated outside), or isotonic (equal) — directly predicts which way water will move and by how much. Whether that movement helps the cell (turgor in a walled plant cell) or seriously harms it (lysis in an unwalled animal cell) depends entirely on whether a rigid cell wall is present to resist the resulting pressure."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where osmosis and tonicity actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Inside cell (mOsm/L)</span>
        <input id="cin" type="number" step="any" value="300" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Outside solution (mOsm/L)</span>
        <input id="cout" type="number" step="any" value="500" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Cell type</span>
      <div class="mt-1 flex gap-2">
        <button id="type-animal" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Animal cell</button>
        <button id="type-plant" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Plant cell</button>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Tonicity</div><div id="r-tonicity" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Water movement</div><div id="r-water" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Cell outcome</div><div id="r-outcome" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="os-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Shrinking vs. swelling cell</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-shrink" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. In a hypertonic solution</h3>
          <p class="mt-1 text-sm text-slate-600">Water leaves the cell, causing it to shrink and shrivel (crenation).</p>
        </div>
        <div>
          <div id="diag-swell" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. In a hypotonic solution</h3>
          <p class="mt-1 text-sm text-slate-600">Water enters the cell, causing it to swell (and potentially burst without a wall).</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Osmosis charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Water movement direction vs. concentration difference</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-direction"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Cell volume change over time (hypotonic exposure)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-volume"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let cellType = 'animal';

      function switchType(t) {
        cellType = t;
        el('type-animal').className = t === 'animal' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('type-plant').className = t === 'plant' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
      }

      function update() {
        el('os-err').textContent = '';
        el('r-tonicity').textContent = '—'; el('r-water').textContent = '—'; el('r-outcome').textContent = '—';
        const cin = parseFloat(el('cin').value), cout = parseFloat(el('cout').value);
        if (isNaN(cin) || isNaN(cout)) return;
        if (cin < 0 || cout < 0) { el('os-err').textContent = 'Concentrations cannot be negative.'; return; }
        let tonicity, water, outcome;
        if (cout > cin) {
          tonicity = 'Hypertonic';
          water = 'Out of the cell';
          outcome = cellType === 'animal' ? 'Crenation (shrinks)' : 'Plasmolysis (membrane pulls from wall)';
        } else if (cout < cin) {
          tonicity = 'Hypotonic';
          water = 'Into the cell';
          outcome = cellType === 'animal' ? 'Swells, may lyse' : 'Turgid (firm, does not burst)';
        } else {
          tonicity = 'Isotonic';
          water = 'No net movement';
          outcome = 'No change';
        }
        el('r-tonicity').textContent = tonicity;
        el('r-water').textContent = water;
        el('r-outcome').textContent = outcome;
      }
      el('type-animal').addEventListener('click', () => { switchType('animal'); update(); });
      el('type-plant').addEventListener('click', () => { switchType('plant'); update(); });
      ['cin', 'cout'].forEach((id) => el(id).addEventListener('input', update));

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const diffLabels = [], diffData = [];
        for (let d = -400; d <= 400; d += 100) { diffLabels.push(d); diffData.push(d); }
        new Chart(el('chart-direction'), {
          type: 'bar',
          data: { labels: diffLabels, datasets: [{ label: 'Outside − Inside (mOsm/L)', data: diffData, backgroundColor: diffData.map((d) => (d > 0 ? '#ef4444' : d < 0 ? '#6366f1' : '#94a3b8')) }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Concentration difference (mOsm/L)' } } }, plugins: { legend: { display: false } } }),
        });
        const tLabels = [0, 1, 2, 3, 4, 5];
        new Chart(el('chart-volume'), {
          type: 'line',
          data: { labels: tLabels, datasets: [{ label: 'Relative cell volume', data: [1, 1.15, 1.25, 1.3, 1.32, 1.33], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 3 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (minutes)' } }, y: { title: { display: true, text: 'Relative cell volume' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function cellScene(container, scale) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const cell = new THREE.Mesh(new THREE.SphereGeometry(1.5 * scale, 24, 20), new THREE.MeshStandardMaterial({ color: 0x6366f1, transparent: true, opacity: 0.55 }));
        s.scene.add(cell);
        const nucleus = new THREE.Mesh(new THREE.SphereGeometry(0.4 * scale, 16, 14), new THREE.MeshStandardMaterial({ color: 0x4338ca }));
        s.scene.add(nucleus);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagShrink = null, diagSwell = null;
      function initDiagShrink() { const c = el('diag-shrink'); if (!c) throw new Error('no container'); diagShrink = cellScene(c, 0.65); }
      function initDiagSwell() { const c = el('diag-swell'); if (!c) throw new Error('no container'); diagSwell = cellScene(c, 1.3); }

      function boot() {
        try { switchType('animal'); update(); } catch (e) { console.error('[osmosis-tonicity] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[osmosis-tonicity] charts failed', e); }
        if (window.THREE) {
          try { initDiagShrink(); } catch (e) { console.error('[osmosis-tonicity] shrink diagram failed', e); }
          try { initDiagSwell(); } catch (e) { console.error('[osmosis-tonicity] swell diagram failed', e); }
        }
        mountResize([diagShrink, diagSwell]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
