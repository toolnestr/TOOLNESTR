  <script is:inline>
    (function() {
      var bcryptPromise = null;

      function getBcrypt() {
        if (!bcryptPromise) {
          bcryptPromise = import('https://esm.sh/bcryptjs@2.4.3').then(function(m) {
            return m.default || m;
          }).catch(function(err) {
            console.error('Failed to load bcryptjs from CDN:', err);
            showStatus('Failed to load bcrypt library. Please check your internet connection and try again.', false);
            return null;
          });
        }
        return bcryptPromise;
      }

      var el = function(id) { return document.getElementById(id); };

      var tabHash = el('tab-hash');
      var tabVerify = el('tab-verify');
      var panelHash = el('panel-hash');
      var panelVerify = el('panel-verify');

      var hashInput = el('hash-input');
      var rounds = el('rounds');
      var hashBtn = el('hash-btn');
      var hashOutput = el('hash-output');
      var copyBtn = el('copy-btn');

      var verifyInput = el('verify-input');
      var verifyHash = el('verify-hash');
      var verifyBtn = el('verify-btn');
      var verifyResult = el('verify-result');

      var status = el('status');

      function showStatus(msg, ok) {
        status.textContent = msg;
        status.className = 'mt-3 rounded-lg px-3 py-2 text-sm font-medium ' + (ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700');
        status.classList.remove('hidden');
      }

      function hideStatus() {
        status.classList.add('hidden');
      }

      function setActiveTab(tab) {
        if (tab === 'hash') {
          tabHash.className = 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700';
          tabVerify.className = 'rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50';
          panelHash.classList.remove('hidden');
          panelVerify.classList.add('hidden');
          verifyResult.classList.add('hidden');
        } else {
          tabHash.className = 'rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50';
          tabVerify.className = 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700';
          panelHash.classList.add('hidden');
          panelVerify.classList.remove('hidden');
          verifyResult.classList.add('hidden');
        }
        hideStatus();
      }

      tabHash.addEventListener('click', function() { setActiveTab('hash'); });
      tabVerify.addEventListener('click', function() { setActiveTab('verify'); });

      hashBtn.addEventListener('click', async function() {
        var text = hashInput.value;
        if (!text) { showStatus('Please enter text to hash.', false); return; }
        var roundsVal = parseInt(rounds.value, 10);
        if (isNaN(roundsVal) || roundsVal < 4 || roundsVal > 16) {
          showStatus('Salt rounds must be between 4 and 16.', false);
          return;
        }
        hideStatus();
        hashBtn.textContent = 'Hashing…';
        hashBtn.disabled = true;
        try {
          var bcrypt = await getBcrypt();
          if (!bcrypt) { hashBtn.textContent = 'Generate Hash'; hashBtn.disabled = false; return; }
          var hash = bcrypt.hashSync(text, roundsVal);
          hashOutput.value = hash;
          showStatus('Bcrypt hash generated successfully.', true);
        } catch (e) {
          showStatus('Error generating hash: ' + e.message, false);
        }
        hashBtn.textContent = 'Generate Hash';
        hashBtn.disabled = false;
      });

      verifyBtn.addEventListener('click', async function() {
        var text = verifyInput.value;
        var hash = verifyHash.value;
        if (!text || !hash) { showStatus('Please enter both plaintext and a bcrypt hash.', false); return; }
        hideStatus();
        verifyBtn.textContent = 'Verifying…';
        verifyBtn.disabled = true;
        try {
          var bcrypt = await getBcrypt();
          if (!bcrypt) { verifyBtn.textContent = 'Verify'; verifyBtn.disabled = false; return; }
          var match = bcrypt.compareSync(text, hash);
          verifyResult.classList.remove('hidden');
          if (match) {
            verifyResult.className = 'mt-4 rounded-xl border border-green-300 bg-green-50 p-4 text-center text-lg font-bold text-green-700';
            verifyResult.textContent = '\u2713 Match';
          } else {
            verifyResult.className = 'mt-4 rounded-xl border border-red-300 bg-red-50 p-4 text-center text-lg font-bold text-red-700';
            verifyResult.textContent = '\u2717 No match';
          }
          showStatus('Verification complete.', true);
        } catch (e) {
          showStatus('Error verifying hash: ' + e.message, false);
        }
        verifyBtn.textContent = 'Verify';
        verifyBtn.disabled = false;
      });

      copyBtn.addEventListener('click', async function() {
        if (!hashOutput.value) return;
        try {
          await navigator.clipboard.writeText(hashOutput.value);
          var b = copyBtn; var o = b.textContent; b.textContent = 'Copied!'; setTimeout(function() { b.textContent = o; }, 1200);
        } catch (e) {}
      });
    })();
  </script>
</ToolLayout>
