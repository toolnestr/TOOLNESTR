---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Natural Logarithm (ln) Calculator';
const description = 'Calculate the natural logarithm ln(x), log base b, and apply the change-of-base formula. Free online logarithm calculator.';
const intro = 'Compute natural logarithms, common logarithms, and logarithms in any base with instant results.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is a natural logarithm?', a: 'The natural logarithm ln(x) is the logarithm with base e, where e ≈ 2.71828. It answers the question: to what power must e be raised to equal x?' },
  { q: 'What is the domain of ln(x)?', a: 'The natural logarithm is only defined for positive real numbers (x > 0). The logarithm of zero or a negative number is undefined in the real number system.' },
  { q: 'What is the change-of-base formula?', a: 'The change-of-base formula allows you to compute logarithms in any base: log_b(x) = ln(x) / ln(b). This is how calculators compute logarithms in uncommon bases.' },
  { q: 'What is the relationship between ln and log?', a: 'ln(x) is the natural log (base e). log(x) typically means base 10 (common log). They are related by ln(x) = log(x) × ln(10) ≈ log(x) × 2.3026.' },
  { q: 'Why is ln(1) = 0?', a: 'Because e⁰ = 1. Any number raised to the power of zero equals 1, so the logarithm (in any base) of 1 is always 0.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-3">
      <div class="flex-1 min-w-[140px]">
        <label class="block text-sm font-medium text-slate-700" for="log-number">Number (x)</label>
        <input id="log-number" type="number" step="any" value="100" placeholder="e.g. 100"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <div class="w-28">
        <label class="block text-sm font-medium text-slate-700" for="log-base">Base (b)</label>
        <input id="log-base" type="number" step="any" value="10" placeholder="10"
          class="mt-1 block w-full rounded-xl border border-slate-300 px-4 py-3 text-base outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>
    <div id="ln-result" class="rounded-xl bg-indigo-600 p-5 text-center text-white">
      <span id="ln-expression" class="text-sm opacity-90">ln(100) =</span>
      <span id="ln-value" class="ml-2 text-2xl font-bold">4.605170186</span>
    </div>
    <div id="log-result" class="mt-3 rounded-xl bg-slate-50 p-4 text-center text-sm text-slate-600">
      <span id="log-expression">log₁₀(100) = 2</span>
    </div>
    <div id="cob-result" class="mt-2 hidden rounded-xl border border-slate-200 bg-slate-50 p-3 text-center text-xs text-slate-400"></div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="600" height="360" viewBox="0 0 600 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ln-title ln-desc">
      <title id="ln-title">Graph of the natural logarithm function y = ln(x) showing the vertical asymptote at x = 0</title>
      <desc id="ln-desc">A coordinate grid with the curve y = ln(x) plotted. The curve approaches the y-axis (x=0) asymptotically, passes through (1,0) and (e,1), and increases slowly for large x.</desc>
      <rect x="60" y="20" width="500" height="300" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1.5" rx="4" />
      <line x1="60" y1="170" x2="560" y2="170" stroke="#94a3b8" stroke-width="1.5" />
      <line x1="160" y1="20" x2="160" y2="320" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="4,4" />
      <text x="560" y="165" text-anchor="end" fill="#94a3b8" font-size="12">x</text>
      <text x="155" y="340" text-anchor="middle" fill="#94a3b8" font-size="12">0</text>
      <text x="260" y="340" text-anchor="middle" fill="#94a3b8" font-size="12">1</text>
      <text x="380" y="340" text-anchor="middle" fill="#94a3b8" font-size="12">e</text>
      <path d="M160 320 Q 170 310, 180 290 Q 200 250, 240 200 Q 280 160, 320 130 Q 380 100, 440 85 Q 500 75, 560 68" fill="none" stroke="#6366f1" stroke-width="3" />
      <circle cx="260" cy="170" r="4" fill="#10b981" />
      <circle cx="380" cy="100" r="4" fill="#f59e0b" />
      <text x="260" y="160" text-anchor="middle" fill="#10b981" font-size="12" font-weight="bold">(1, 0)</text>
      <text x="380" y="90" text-anchor="middle" fill="#f59e0b" font-size="12" font-weight="bold">(e, 1)</text>
      <text x="75" y="40" fill="#ef4444" font-size="12" font-weight="bold">x = 0 (asymptote)</text>
      <text x="460" y="60" fill="#6366f1" font-size="13" font-weight="bold">y = ln(x)</text>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The natural logarithm curve y = ln(x) increases slowly for large x and approaches negative infinity as x approaches 0 from the positive side.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How logarithms work</h2>
    <p class="mt-2 text-slate-600">A logarithm answers the question: what exponent produces this number? Specifically, log<sub>b</sub>(x) = y means that b<sup>y</sup> = x. The natural logarithm ln(x) uses the special constant e ≈ 2.718281828459045 as its base. The constant e arises naturally in calculus, compound interest, and many physical processes, making ln(x) the most mathematically convenient logarithm to work with.</p>
    <p class="mt-3 text-slate-600">The natural logarithm has several defining properties. It is the inverse function of the exponential function e<sup>x</sup>, meaning ln(e<sup>x</sup>) = x and e<sup>ln(x)</sup> = x for x > 0. Its derivative is 1/x, which makes it indispensable in calculus. The integral of 1/x from 1 to a is ln(a), connecting logarithms to areas under curves.</p>
    <p class="mt-3 text-slate-600">The change-of-base formula allows you to compute logarithms in any base using natural logarithms: log<sub>b</sub>(x) = ln(x) / ln(b). This is how this calculator works internally — it computes ln(x) and ln(b) using JavaScript's Math.log function, then divides them to get the result in the desired base.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Definition</h3>
        <p class="mt-1 font-mono text-lg font-bold text-indigo-700">ln(x) = y &hArr; e<sup>y</sup> = x</p>
        <p class="mt-2 text-sm text-slate-600">The natural logarithm of x is the exponent y such that e raised to the power y equals x.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <h3 class="font-semibold text-slate-900">Change-of-base</h3>
        <p class="mt-1 font-mono text-lg font-bold text-emerald-700">log<sub>b</sub>(x) = ln(x) / ln(b)</p>
        <p class="mt-2 text-sm text-slate-600">This formula lets you compute logarithms in any base using natural logarithms.</p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example: log₁₀(100)</h3>
      <div class="mt-2 space-y-1 text-sm text-slate-600">
        <p>Step 1: We want log₁₀(100). Use change-of-base: log₁₀(100) = ln(100) / ln(10)</p>
        <p>Step 2: ln(100) ≈ 4.605170186, ln(10) ≈ 2.302585093</p>
        <p>Step 3: 4.605170186 / 2.302585093 = 2</p>
        <p class="font-semibold text-emerald-700">Therefore: log₁₀(100) = 2, because 10² = 100</p>
        <p class="mt-1 text-slate-500">Similarly, ln(100) ≈ 4.605, meaning e<sup>4.605</sup> ≈ 100.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4CA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">Natural logarithms appear in physics (entropy, radioactive decay), chemistry (reaction rates, pH = -log[H⁺]), and biology (population growth models, drug concentration curves). The logarithmic scale compresses wide-ranging data into manageable numbers.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4B0;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Finance Professionals</h3>
      <p class="mt-1 text-sm text-slate-600">Continuously compounded interest uses ln: A = Pe<sup>rt</sup>. The time to double an investment is ln(2)/r. Logarithmic returns are used in financial modeling because they are time-additive and normally distributed under the Black-Scholes model.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Data Scientists</h3>
      <p class="mt-1 text-sm text-slate-600">Log transformations stabilize variance and make skewed distributions more normal. Log-loss (cross-entropy) is a standard loss function for classification models. Information theory measures entropy in nats (using ln) or bits (using log₂).</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3ED;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Engineers</h3>
      <p class="mt-1 text-sm text-slate-600">Decibels use log₁₀: dB = 10 × log₁₀(P/P₀). The Richter scale for earthquakes uses log₁₀. Signal processing, control systems, and acoustics all rely heavily on logarithmic measures to handle wide dynamic ranges.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the logarithm calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the number</h3>
        <p class="mt-1 text-sm text-slate-600">Type the positive number you want the logarithm of. Only positive numbers are valid — the calculator warns for zero or negative inputs.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the base</h3>
        <p class="mt-1 text-sm text-slate-600">The default base is e (natural log). Change to 10 for common log, 2 for binary log, or any positive base other than 1.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the results</h3>
        <p class="mt-1 text-sm text-slate-600">Both ln(x) and log_b(x) are shown. The change-of-base formula is displayed in the detail section so you can verify the calculation.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with logarithms</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">The three most useful bases</h3>
        <p class="mt-1 text-sm text-slate-600">Base e (natural log, ln) is used in calculus, physics, and continuous growth models. Base 10 (common log, log) is used in engineering, decibels, and the Richter scale. Base 2 (binary log, lg) is used in computer science for algorithm analysis, information theory, and data structures.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Logarithm properties simplify complex expressions</h3>
        <p class="mt-1 text-sm text-slate-600">The key properties are: ln(ab) = ln(a) + ln(b), ln(a/b) = ln(a) - ln(b), and ln(a<sup>b</sup>) = b × ln(a). These properties convert multiplication into addition, division into subtraction, and powers into multiplication, making complex calculations much simpler.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Avoid common mistakes</h3>
        <p class="mt-1 text-sm text-slate-600">Remember that ln(a + b) does NOT equal ln(a) + ln(b). The logarithm of a sum has no simple simplification. Also, the base of a logarithm must be positive and not equal to 1. The domain is strictly positive real numbers — ln(0) is undefined and approaches negative infinity as x approaches 0 from the right.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Logarithms linearize exponential data</h3>
        <p class="mt-1 text-sm text-slate-600">If you suspect data follows an exponential trend y = ae<sup>bx</span>, taking the natural log transforms it to ln(y) = ln(a) + bx, which is a linear relationship. This is the foundation of log-linear plots and exponential regression in data analysis.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/exponent-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4D0;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Exponent Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate x to the power of y for any real base and exponent.</p>
      </a>
      <a href="/tools/square-root-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x221A;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Square Root Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Calculate any nth root of a number.</p>
      </a>
      <a href="/tools/exponential-growth-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">&#x1F4C8;</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Exponential Growth Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">Project values over time with exponential models.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const logNumber = document.getElementById('log-number');
    const logBase = document.getElementById('log-base');
    const lnExpression = document.getElementById('ln-expression');
    const lnValue = document.getElementById('ln-value');
    const lnResult = document.getElementById('ln-result');
    const logExpression = document.getElementById('log-expression');
    const cobResult = document.getElementById('cob-result');

    function calculate() {
      const x = parseFloat(logNumber.value);
      const b = parseFloat(logBase.value);

      if (isNaN(x) || isNaN(b)) {
        lnExpression.innerHTML = '<em>enter values</em>';
        lnValue.textContent = '—';
        logExpression.textContent = '—';
        cobResult.classList.add('hidden');
        lnResult.classList.remove('bg-emerald-600', 'bg-red-600');
        lnResult.classList.add('bg-indigo-600');
        return;
      }

      if (x <= 0) {
        lnExpression.innerHTML = `<span>ln(${x.toLocaleString()}) =</span>`;
        lnValue.textContent = 'Undefined (x must be > 0)';
        logExpression.textContent = '—';
        cobResult.classList.add('hidden');
        lnResult.classList.remove('bg-indigo-600', 'bg-emerald-600');
        lnResult.classList.add('bg-red-600');
        return;
      }

      if (b <= 0 || b === 1) {
        lnExpression.innerHTML = `<span>ln(${x.toLocaleString()}) =</span>`;
        const natLog = Math.log(x);
        lnValue.textContent = natLog.toLocaleString(undefined, { maximumFractionDigits: 10 });
        logExpression.textContent = `Base must be > 0 and ≠ 1`;
        cobResult.classList.add('hidden');
        lnResult.classList.remove('bg-red-600');
        lnResult.classList.add('bg-indigo-600');
        return;
      }

      lnResult.classList.remove('bg-red-600');
      lnResult.classList.add('bg-indigo-600');

      const natLog = Math.log(x);
      const logBaseB = Math.log(x) / Math.log(b);

      lnExpression.innerHTML = `<span>ln(${x.toLocaleString()}) =</span>`;
      lnValue.textContent = natLog.toLocaleString(undefined, { maximumFractionDigits: 10 });

      const bDisplay = b === Math.E ? 'e' : b.toLocaleString();
      logExpression.innerHTML = `log<sub>${bDisplay}</sub>(${x.toLocaleString()}) = ${logBaseB.toLocaleString(undefined, { maximumFractionDigits: 10 })}`;

      cobResult.classList.remove('hidden');
      cobResult.innerHTML = `Change-of-base: log<sub>${bDisplay}</sub>(${x.toLocaleString()}) = ln(${x.toLocaleString()}) / ln(${bDisplay}) = ${natLog.toLocaleString(undefined, { maximumFractionDigits: 6 })} / ${Math.log(b).toLocaleString(undefined, { maximumFractionDigits: 6 })} = ${logBaseB.toLocaleString(undefined, { maximumFractionDigits: 6 })}`;
    }

    logNumber.addEventListener('input', calculate);
    logBase.addEventListener('input', calculate);
    calculate();
  </script>
</ToolLayout>
