---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Vinyl Siding Calculator';
const description = 'Estimate how much vinyl siding you need in squares and boxes from your wall area, window and door openings, and a waste allowance.';
const intro = 'Estimate the vinyl siding you need — in squares and boxes — from your total wall area, the openings to subtract, and a waste allowance.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much vinyl siding do I need?', a: 'Add up the area of all the walls, subtract the window and door openings, and add about 10 percent for waste. Siding is sold by the "square," which covers 100 square feet, so divide your adjusted area by 100 to get squares.' },
  { q: 'What is a square of siding?', a: 'A square is 100 square feet of finished coverage, the standard unit for siding and roofing. A typical box of vinyl siding holds two squares, or 200 square feet, though this varies by profile and brand.' },
  { q: 'How do I find my wall area?', a: 'For each wall, multiply its width by its height. For gable ends, use half the width times the height to the peak. Add all the walls together for the gross area, then subtract the openings.' },
  { q: 'Why add extra for waste?', a: 'Siding is cut to fit around windows, doors, and corners, and those offcuts are usually too short to reuse. Ten percent is typical for a simple house; add more, up to 15 percent, for lots of openings, corners, or angled cuts.' },
];
const howTo = {
  name: 'How to calculate how much vinyl siding you need',
  steps: [
    { name: 'Total the walls', text: 'Add up the area of every wall, including gable ends, in square feet.' },
    { name: 'Subtract openings', text: 'Enter the combined area of windows and doors to take out.' },
    { name: 'Read squares and boxes', text: 'Get the squares and boxes to order, with waste already added.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Total wall area (sq ft)</span>
        <input id="gross" type="number" step="any" placeholder="1500" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Openings to subtract (sq ft)</span>
        <input id="openings" type="number" step="any" placeholder="200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waste allowance</span>
        <select id="waste" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="10" selected>10% (simple house)</option>
          <option value="15">15% (many openings/corners)</option>
          <option value="5">5% (large plain walls)</option>
        </select></label>
    </div>
    <p class="mt-3 text-xs text-slate-500">Tip: wall area = perimeter &times; wall height; add half-width &times; peak height for each gable end.</p>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Vinyl siding needed</div>
        <div id="r-squares" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-boxes" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Net area</div><div id="r-net" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">With waste</div><div id="r-adj" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Boxes (200 ft²)</div><div id="r-boxct" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="300" viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="vs-title vs-desc">
      <title id="vs-title">Wall area minus openings for siding</title>
      <desc id="vs-desc">A house wall with siding courses and a window opening, and the siding formula</desc>
      <polygon points="90,120 220,60 350,120" fill="#e0e7ff" stroke="#6366f1" stroke-width="2" />
      <rect x="90" y="120" width="260" height="130" fill="#eef2ff" stroke="#6366f1" stroke-width="2" />
      <g stroke="#a5b4fc" stroke-width="1.5"><line x1="90" y1="145" x2="350" y2="145"/><line x1="90" y1="170" x2="350" y2="170"/><line x1="90" y1="195" x2="350" y2="195"/><line x1="90" y1="220" x2="350" y2="220"/></g>
      <rect x="150" y="160" width="55" height="55" fill="#ffffff" stroke="#4f46e5" stroke-width="2" />
      <text x="245" y="240" font-size="11" fill="#475569" font-family="system-ui,sans-serif">subtract openings</text>
      <rect x="420" y="90" width="300" height="130" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Siding estimate</text>
      <text x="440" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">net = wall area &minus; openings</text>
      <text x="440" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">adjusted = net &times; (1 + waste)</text>
      <text x="440" y="188" font-size="12" fill="#475569" font-family="system-ui,sans-serif">squares = adjusted &divide; 100</text>
      <text x="440" y="210" font-size="12" fill="#475569" font-family="system-ui,sans-serif">1 box = 2 squares = 200 ft&sup2;</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Siding is figured from wall area minus openings, converted to 100-square-foot squares.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the vinyl siding calculator works</h2>
    <p class="mt-2 text-slate-600">
      Vinyl siding is estimated by area. You add up the square footage of every wall to be covered, then subtract the windows, doors, and other openings that will not be sided. That net area is what actually needs siding, but you always buy a bit more because pieces get cut to fit and the offcuts are wasted.
    </p>
    <p class="mt-3 text-slate-600">
      The calculator applies your waste allowance to the net area, then converts to squares — the industry unit of 100 square feet used for both siding and roofing. Dividing the adjusted area by 100 gives the squares, and since a typical box of vinyl siding holds two squares, dividing by 200 gives the number of boxes to order.
    </p>
    <p class="mt-3 text-slate-600">
      To find the wall area, multiply each wall's width by its height, and add half the width times the peak height for any gable end. This tool counts the field siding only; corner posts, J-channel, starter strip, and other trim are ordered separately by the linear foot. Coverage per box varies by profile, so confirm against your product's spec sheet.
    </p>
    <p class="mt-3 text-xs text-slate-400">Installation practices and material terminology follow ASTM D4756 (Standard Practice for Installation of Rigid PVC Siding and Soffit) and ASTM D3679 (Standard Specification for Rigid Poly(Vinyl Chloride) (PVC) Siding).</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Total the walls</h3>
        <p class="mt-1 text-sm text-slate-600">Add up the area of every wall, including gable ends, in square feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Subtract openings</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the combined area of windows and doors to take out.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read squares and boxes</h3>
        <p class="mt-1 text-sm text-slate-600">Get the squares and boxes to order, with waste already added.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Net area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= wall area &minus; openings</span>. 1500 &minus; 200 = <strong>1300 ft&sup2;</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Adjusted for waste</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= net &times; (1 + waste)</span>. With 10%: 1300 &times; 1.10 = <strong>1430 ft&sup2;</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Squares and boxes</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">squares = 1430 &divide; 100 = 14.3</span>; boxes = 1430 &divide; 200 = 7.15 &rarr; <strong>8 boxes</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A small house: 4 walls totaling 1120 ft², 150 ft² of openings, 15% waste.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Net:</span> <span class="text-slate-600">1120 &minus; 150 = 970 ft²</span></div>
        <div><span class="font-medium text-slate-700">With waste:</span> <span class="text-slate-600">970 &times; 1.15 = 1116 ft²</span></div>
        <div><span class="font-medium text-slate-700">Squares:</span> <span class="text-slate-600">1116 &divide; 100 = <strong>11.2 squares</strong></span></div>
        <div><span class="font-medium text-slate-700">Boxes:</span> <span class="text-slate-600">1116 &divide; 200 = 6 boxes</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Planning the job</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧱</span>
        <h3 class="mt-2 font-semibold text-slate-900">Do not forget the trim</h3>
        <p class="mt-1 text-sm text-slate-600">Starter strip, J-channel, corner posts, and soffit are sold by the linear foot, not the square. Measure the corners and opening perimeters separately for those pieces.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🎨</span>
        <h3 class="mt-2 font-semibold text-slate-900">Buy one lot at a time</h3>
        <p class="mt-1 text-sm text-slate-600">Vinyl color can vary slightly between production runs. Order all your boxes together and check the lot numbers so the whole house matches.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📐</span>
        <h3 class="mt-2 font-semibold text-slate-900">Keep offcuts organized</h3>
        <p class="mt-1 text-sm text-slate-600">Longer offcuts can fill short runs under windows and above doors. Sorting scraps by length cuts real waste below the allowance you budgeted.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌡️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Allow for expansion</h3>
        <p class="mt-1 text-sm text-slate-600">Vinyl moves with temperature, so it is hung loosely with a gap at the ends. This does not change the quantity but is critical to a job that will not buckle.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A typical two-story house re-side is the calculator's most common use case. With 2,400 ft² of gross wall area and 320 ft² of window and door openings, the net area comes to 2,080 ft². Applying the standard 10% waste allowance brings that to 2,288 ft², which works out to 22.9 squares — or 12 boxes at 200 ft² each, since 2,288 ÷ 200 rounds up from 11.44. That rounding matters: ordering 11 boxes instead of 12 would leave the crew about 88 ft² short partway through the job, forcing a mid-project supply run and risking a lot-number mismatch on the replacement box.
    </p>
    <p class="mt-3 text-slate-600">
      Small additions and porch enclosures sit at the other end of the scale. A 480 ft² addition with 40 ft² of openings and a 15% waste allowance — appropriate given the tight corners and trim around a small structure — nets 440 ft², adjusts to 506 ft², and rounds up to 3 boxes (506 ÷ 200 = 2.53). On a job this size, the difference between the 10% and 15% waste settings is only about 22 ft², but it can still be the difference between 2 and 3 boxes ordered, so matching the waste percentage to the actual cutting complexity avoids paying for a box that is not needed.
    </p>
    <p class="mt-3 text-slate-600">
      Detached garages illustrate the low-waste end of the range. A garage with 900 ft² of gross wall area, only 60 ft² of openings (typically one service door and a small window), and a 5% waste allowance for its large, uninterrupted wall faces nets 840 ft², adjusts to 882 ft², and needs 5 boxes (882 ÷ 200 = 4.41, rounded up). Because garages have so few openings relative to their wall area, the waste allowance has a smaller dollar impact than on a house facade dense with windows and trim.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A box of siding always covers 200 square feet, so I can order by box count alone." <strong class="text-slate-900">Not always.</strong> Coverage per box varies by panel profile, exposure, and manufacturer — some double-4 profiles yield slightly less than 100 ft² per square once overlap is accounted for. Always confirm the actual coverage on the product's spec sheet before finalizing an order, especially when switching brands mid-project.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Vinyl siding should be nailed tight against the wall like wood siding." <strong class="text-slate-900">This causes buckling.</strong> Vinyl expands and contracts significantly with temperature, so ASTM D4756 calls for nailing in the center of the slot with the panel hanging loosely, plus a small gap at trim and corner posts. Fastening it tightly prevents that movement and leads to wavy, buckled panels within a single hot summer.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/square-footage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
      <a href="/tools/roofing-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Roofing Calculator</a>
      <a href="/tools/paint-coverage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Paint Coverage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const gross = parseFloat(el('gross').value);
      let openings = parseFloat(el('openings').value); if (!openings || openings < 0) openings = 0;
      const waste = parseFloat(el('waste').value) / 100;
      if (!gross || gross <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const net = Math.max(gross - openings, 0);
      const adj = net * (1 + waste);
      const squares = adj / 100;
      const boxes = Math.ceil(adj / 200);

      el('r-squares').textContent = squares.toFixed(1) + ' squares';
      el('r-boxes').textContent = 'order ' + boxes + ' boxes (200 ft² each)';
      el('r-net').textContent = net.toFixed(0) + ' ft²';
      el('r-adj').textContent = adj.toFixed(0) + ' ft²';
      el('r-boxct').textContent = boxes.toLocaleString();
      el('results').classList.remove('hidden');
    }

    ['gross', 'openings'].forEach((id) => el(id).addEventListener('input', update));
    el('waste').addEventListener('change', update);
  </script>
</ToolLayout>
