  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function category(bmi) {
      if (bmi < 18.5) return ['Underweight', '#60a5fa'];
      if (bmi < 25) return ['Normal weight', '#34d399'];
      if (bmi < 30) return ['Overweight', '#fbbf24'];
      return ['Obese', '#f87171'];
    }

    function update() {
      let hM, wKg;
      if (metric) {
        hM = parseFloat(el('m-h').value) / 100;
        wKg = parseFloat(el('m-w').value);
      } else {
        const ft = parseFloat(el('i-ft').value) || 0;
        const inch = parseFloat(el('i-in').value) || 0;
        hM = (ft * 12 + inch) * 0.0254;
        wKg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      if (!hM || !wKg || hM <= 0 || wKg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const bmi = wKg / (hM * hM);
      const [cat] = category(bmi);
      el('bmi-val').textContent = bmi.toFixed(1);
      el('bmi-cat').textContent = cat;
      el('result').classList.remove('hidden');
      el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['m-h', 'm-w', 'i-ft', 'i-in', 'i-w'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
