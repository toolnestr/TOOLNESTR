---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'BMI Calculator';
const description =
  'Free BMI calculator. Find your Body Mass Index from your height and weight in metric or ' +
  'imperial units, and see which BMI category you fall into. Runs in your browser.';
const intro =
  'Enter your height and weight (metric or imperial) to calculate your Body Mass Index and see your weight category.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is BMI?', a: 'Body Mass Index is a simple measure that uses your height and weight to estimate whether you are in a healthy weight range. BMI = weight (kg) ÷ height (m)².' },
  { q: 'What are the BMI categories?', a: 'Under 18.5 is underweight, 18.5–24.9 is normal, 25–29.9 is overweight, and 30 or above is obese (for adults).' },
  { q: 'Is BMI accurate for everyone?', a: 'BMI is a useful general guide but does not account for muscle, bone or body composition, so very muscular people may read as “overweight”. It is informational, not medical advice.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <!-- Metric inputs -->
    <div id="metric" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <!-- Imperial inputs -->
    <div id="imperial" class="grid gap-4 sm:grid-cols-3" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Your BMI</div>
      <div id="bmi-val" class="mt-1 text-3xl font-bold">—</div>
      <div id="bmi-cat" class="mt-1 text-sm font-medium"></div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your height and weight to see your BMI.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About BMI</h2>
    <p class="mt-2 text-slate-600">
      Body Mass Index (BMI) is a quick, widely used screening tool that estimates whether your
      weight is in a healthy range for your height. It’s used by doctors, gyms and health apps as a
      simple starting point. This calculator works in both metric and imperial units and tells you
      your category instantly.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">
      ⚕️ This tool is for general information only and is not medical advice. Talk to a healthcare
      professional about your individual health.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Choose Metric or Imperial units.</li>
      <li>Enter your height and weight.</li>
      <li>See your BMI value and category instantly.</li>
    </ol>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a>
      or <a href="/tools/ideal-weight" class="font-medium text-indigo-600 hover:underline">Ideal Weight Calculator</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function category(bmi) {
      if (bmi < 18.5) return ['Underweight', '#60a5fa'];
      if (bmi < 25) return ['Normal weight', '#34d399'];
      if (bmi < 30) return ['Overweight', '#fbbf24'];
      return ['Obese', '#f87171'];
    }

    function update() {
      let hM, wKg;
      if (metric) {
        hM = parseFloat(el('m-h').value) / 100;
        wKg = parseFloat(el('m-w').value);
      } else {
        const ft = parseFloat(el('i-ft').value) || 0;
        const inch = parseFloat(el('i-in').value) || 0;
        hM = (ft * 12 + inch) * 0.0254;
        wKg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      if (!hM || !wKg || hM <= 0 || wKg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const bmi = wKg / (hM * hM);
      const [cat] = category(bmi);
      el('bmi-val').textContent = bmi.toFixed(1);
      el('bmi-cat').textContent = cat;
      el('result').classList.remove('hidden');
      el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['m-h', 'm-w', 'i-ft', 'i-in', 'i-w'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
