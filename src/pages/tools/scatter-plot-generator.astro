<script is:inline>
  (async function () {
    const { Chart, registerables } = await import(
      'https://esm.sh/chart.js@4.4.4'
    );
    Chart.register(...registerables);

    const $ = (id) => document.getElementById(id);
    const dataEl = $('data');
    const titleEl = $('title');
    const xlabelEl = $('xlabel');
    const ylabelEl = $('ylabel');
    const trendCheck = $('trendline');
    const canvas = $('canvas');
    const err = $('err');
    const stats = $('stats');
    const countEl = $('count');
    const corrEl = $('correlation');

    let chart = null;

    function parseData(text) {
      const lines = text.trim().split('\n').filter(Boolean);
      const points = [];
      for (const line of lines) {
        const parts = line.split(',');
        if (parts.length < 2) continue;
        const x = parseFloat(parts[0].trim());
        const y = parseFloat(parts[1].trim());
        if (isNaN(x) || isNaN(y)) continue;
        points.push({ x, y });
      }
      return points;
    }

    function linearRegression(points) {
      const n = points.length;
      const sumX = points.reduce((s, p) => s + p.x, 0);
      const sumY = points.reduce((s, p) => s + p.y, 0);
      const sumXY = points.reduce((s, p) => s + p.x * p.y, 0);
      const sumX2 = points.reduce((s, p) => s + p.x * p.x, 0);
      const sumY2 = points.reduce((s, p) => s + p.y * p.y, 0);
      const denom = n * sumX2 - sumX * sumX;
      if (denom === 0) return null;
      const slope = (n * sumXY - sumX * sumY) / denom;
      const intercept = (sumY - slope * sumX) / n;
      const rNum = n * sumXY - sumX * sumY;
      const rDen = Math.sqrt((n * sumX2 - sumX * sumX) * (n * sumY2 - sumY * sumY));
      const r = rDen === 0 ? 0 : rNum / rDen;
      return { slope, intercept, r };
    }

    function generate() {
      const points = parseData(dataEl.value);
      if (points.length < 2) {
        err.textContent = 'Enter at least two valid data points (x, y).';
        err.classList.remove('hidden');
        stats.classList.add('hidden');
        return;
      }
      err.classList.add('hidden');

      const showTrend = trendCheck.checked;
      const chartTitle = titleEl.value || 'Scatter Plot';
      const xLabel = xlabelEl.value || 'X';
      const yLabel = ylabelEl.value || 'Y';

      const datasets = [
        {
          label: 'Data',
          data: points,
          backgroundColor: 'rgba(99, 102, 241, 0.7)',
          borderColor: 'rgba(99, 102, 241, 1)',
          pointRadius: 5,
          pointHoverRadius: 7,
        },
      ];

      let rValue = null;

      if (showTrend) {
        const reg = linearRegression(points);
        if (reg) {
          rValue = reg.r;
          const minX = Math.min(...points.map((p) => p.x));
          const maxX = Math.max(...points.map((p) => p.x));
          const trendData = [
            { x: minX, y: reg.slope * minX + reg.intercept },
            { x: maxX, y: reg.slope * maxX + reg.intercept },
          ];
          datasets.push({
            label: 'Trend Line',
            data: trendData,
            type: 'line',
            showLine: true,
            borderColor: 'rgba(239, 68, 68, 0.9)',
            borderWidth: 2.5,
            borderDash: [6, 4],
            pointRadius: 0,
            pointHitRadius: 0,
            fill: false,
            tension: 0,
          });
        }
      }

      if (chart) {
        chart.destroy();
      }

      const ctx = canvas.getContext('2d');
      chart = new Chart(ctx, {
        type: 'scatter',
        data: { datasets },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          animation: { duration: 300 },
          plugins: {
            title: {
              display: true,
              text: chartTitle,
              font: { size: 16, weight: 'bold' },
              padding: { bottom: 12 },
            },
            legend: {
              display: datasets.length > 1,
              position: 'top',
              labels: { font: { size: 12 }, padding: 12 },
            },
            tooltip: {
              callbacks: {
                label: function (context) {
                  if (context.dataset.label === 'Trend Line') return '';
                  return '(' + context.parsed.x + ', ' + context.parsed.y + ')';
                },
              },
            },
          },
          scales: {
            x: {
              type: 'linear',
              position: 'bottom',
              title: {
                display: true,
                text: xLabel,
                font: { size: 13 },
              },
              grid: { color: 'rgba(0,0,0,0.06)' },
            },
            y: {
              type: 'linear',
              title: {
                display: true,
                text: yLabel,
                font: { size: 13 },
              },
              grid: { color: 'rgba(0,0,0,0.06)' },
              beginAtZero: false,
            },
          },
        },
      });

      countEl.textContent = points.length;
      if (rValue !== null) {
        const abs = Math.abs(rValue);
        let strength = '';
        if (abs > 0.8) strength = ' (strong)';
        else if (abs > 0.5) strength = ' (moderate)';
        else if (abs > 0.3) strength = ' (weak)';
        else strength = ' (very weak)';
        corrEl.textContent = rValue.toFixed(4) + strength;
      } else {
        corrEl.textContent = '--';
      }
      stats.classList.remove('hidden');
    }

    $('generate').addEventListener('click', generate);
    $('download').addEventListener('click', function () {
      if (!chart) return;
      const a = document.createElement('a');
      chart.canvas.toBlob(function (blob) {
        a.href = URL.createObjectURL(blob);
        a.download = 'scatter-plot.png';
        a.click();
      });
    });

    generate();
  })();
</script>
