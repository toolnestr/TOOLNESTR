---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Scatter Plot Generator';
const description =
  'Generate scatter plots from XY data points with optional trend lines. Enter your data pairs to visualize correlations and download the chart as an image.';
const intro =
  'Generate scatter plots from XY data points with trend lines.';
const category = { id: 'charts', name: 'Chart Generators' };
const faqs = [
  {
    q: 'What is a scatter plot?',
    a: 'A graph that plots individual data points on X and Y axes to show relationships between two variables.',
  },
  {
    q: 'Can I add a trend line?',
    a: 'Yes — toggle a linear regression trend line to see correlation direction and strength.',
  },
  {
    q: 'What data format is required?',
    a: 'Enter one point per line as "x, y" — e.g. "1, 2.5" or "10, 20".',
  },
  {
    q: 'Can I download the chart?',
    a: 'Yes — download as PNG image or copy the chart URL.',
  },
  {
    q: 'How is the trend line calculated?',
    a: 'The tool computes a linear regression (least squares) through your data points and plots the best-fit line.',
  },
  {
    q: 'What is the correlation coefficient?',
    a: 'Pearson\'s r measures the strength and direction of the linear relationship between X and Y, from -1 (perfect negative) to +1 (perfect positive).',
  },
  {
    q: 'What happens if I enter invalid data?',
    a: 'Lines that do not contain two comma-separated numbers are skipped. An error shows if no valid data points are found.',
  },
  {
    q: 'Is my data stored or uploaded?',
    a: 'No. Charts are rendered entirely in your browser using Chart.js. Your data never leaves your computer.',
  },
];
