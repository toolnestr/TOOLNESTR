---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'PDF Page Remover';
const description = 'Remove specific pages from a PDF by page number, range, or list. Download the result instantly — all in your browser.';
const intro = 'Remove specific pages from a PDF and download the rest.';
const category = { id: 'pdf', name: 'PDF Tools' };
const faqs = [
  { q: 'Can I remove multiple pages at once?', a: 'Yes — enter "1,3,5-7" to remove pages 1, 3, 5, 6, and 7.' },
  { q: 'Is the original file modified?', a: 'No — a new PDF without the removed pages is downloaded.' },
  { q: 'Does it work for scanned PDFs?', a: 'Yes — page removal works at the page level regardless of content.' },
  { q: 'Is my file uploaded?', a: 'No — everything runs in your browser using pdf-lib.' },
];
const seoTitle = 'PDF Page Remover — Delete Pages from PDF Online';
const seoDesc = 'Remove specific pages from a PDF by page number or range. Free online PDF page remover — works in your browser.';
---

<ToolLayout title={seoTitle} description={seoDesc} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label for="file-input" class="flex cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 p-8 text-center transition hover:border-indigo-400 hover:bg-indigo-50/40">
      <span class="text-3xl">📄</span>
      <span class="mt-2 font-medium text-slate-700">Upload PDF</span>
      <span class="mt-1 text-sm text-slate-400">Click to browse or drag a file</span>
      <input id="file-input" type="file" accept="application/pdf" class="hidden" />
    </label>

    <div id="controls" class="mt-4 hidden space-y-4">
      <p id="info" class="text-sm font-medium text-slate-600"></p>

      <label class="block">
        <span class="text-sm font-medium text-slate-700">Pages to remove</span>
        <input id="pages-input" type="text" placeholder="e.g. 1,3,5-7" class="mt-1 w-full rounded-xl border border-slate-300 p-2.5 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <span class="mt-1 block text-xs text-slate-400">Enter page numbers, ranges with hyphens, or a comma-separated list.</span>
      </label>

      <div class="flex flex-wrap items-center gap-2">
        <button id="process-btn" disabled class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-700 disabled:cursor-not-allowed disabled:opacity-40">Remove pages → Download</button>
        <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
        <span id="status" class="text-sm text-slate-500"></span>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How page removal works</h2>
    <p class="mt-2 text-slate-600">This tool loads your PDF, reads the list of pages you want to remove, and builds a new PDF containing only the pages you kept. The original file is never modified — a brand-new document is created and downloaded to your device.</p>
    <p class="mt-3 text-slate-600">The removal process uses the <span class="font-mono text-indigo-600">pdf-lib</span> library to copy each kept page into a fresh PDF document. Every page that isn't in your removal list is preserved exactly — text, images, fonts, annotations, and formatting remain completely unchanged.</p>

    <div class="mt-6 flex justify-center">
      <svg viewBox="0 0 360 280" class="w-full max-w-sm h-auto" xmlns="http://www.w3.org/2000/svg">
        <rect x="50" y="30" width="200" height="260" rx="4" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1.5" />
        <text x="150" y="55" text-anchor="middle" font-size="10" fill="#64748b" font-family="sans-serif">Page 1</text>
        <rect x="70" y="70" width="160" height="6" rx="2" fill="#e2e8f0" />
        <rect x="70" y="84" width="140" height="6" rx="2" fill="#e2e8f0" />
        <rect x="70" y="98" width="160" height="6" rx="2" fill="#e2e8f0" />

        <rect x="80" y="110" width="200" height="260" rx="4" fill="#fef2f2" stroke="#fca5a5" stroke-width="1.5" />
        <text x="180" y="135" text-anchor="middle" font-size="10" fill="#dc2626" font-family="sans-serif">Page 2</text>
        <line x1="90" y1="148" x2="270" y2="148" stroke="#fca5a5" stroke-width="1" />
        <line x1="90" y1="162" x2="260" y2="162" stroke="#fca5a5" stroke-width="1" />
        <line x1="90" y1="176" x2="270" y2="176" stroke="#fca5a5" stroke-width="1" />
        <line x1="90" y1="190" x2="250" y2="190" stroke="#fca5a5" stroke-width="1" />
        <line x1="120" y1="120" x2="240" y2="360" stroke="#dc2626" stroke-width="2" opacity="0.6" />
        <line x1="240" y1="120" x2="120" y2="360" stroke="#dc2626" stroke-width="2" opacity="0.6" />
        <text x="180" y="390" text-anchor="middle" font-size="10" fill="#dc2626" font-family="sans-serif">Crossed out — removed</text>

        <rect x="110" y="130" width="200" height="260" rx="4" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="1.5" />
        <text x="210" y="155" text-anchor="middle" font-size="10" fill="#64748b" font-family="sans-serif">Page 3</text>
        <rect x="130" y="170" width="160" height="6" rx="2" fill="#e2e8f0" />
        <rect x="130" y="184" width="140" height="6" rx="2" fill="#e2e8f0" />
        <rect x="130" y="198" width="160" height="6" rx="2" fill="#e2e8f0" />

        <path d="M 100 80 C 100 60, 300 60, 300 80" fill="none" stroke="#818cf8" stroke-width="2" stroke-dasharray="5,3" marker-end="url(#arrowBlue)" />
        <path d="M 300 140 C 300 120, 320 120, 320 140" fill="none" stroke="#818cf8" stroke-width="2" stroke-dasharray="5,3" marker-end="url(#arrowBlue)" />
        <defs>
          <marker id="arrowBlue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 0 0 L 10 5 L 0 10 Z" fill="#818cf8" />
          </marker>
        </defs>
        <text x="320" y="85" font-size="9" fill="#818cf8" font-family="sans-serif">pulled out</text>
        <text x="325" y="135" font-size="9" fill="#818cf8" font-family="sans-serif">pulled out</text>
      </svg>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for page removal</h2>
    <p class="mt-2 text-slate-600">Removing pages from a PDF is useful for trimming down documents, deleting irrelevant sections, or cleaning up scanned files before sharing. Here are some common scenarios where page removal helps.</p>
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🗑️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Removing blank pages</h3>
        <p class="mt-1 text-sm text-slate-600">Scanned documents and exported PDFs often contain blank or nearly blank pages interspersed throughout. Removing them reduces file size and makes the document easier to navigate, especially when printing.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">✂️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Deleting unwanted sections</h3>
        <p class="mt-1 text-sm text-slate-600">Delete appendix sections, advertisement pages, disclaimers, or outdated content from a PDF. For example, remove the terms and conditions pages from a contract draft before sharing, or delete blank separator pages from a report.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">📏</span>
        <h3 class="mt-2 font-semibold text-slate-900">Trimming PDFs</h3>
        <p class="mt-1 text-sm text-slate-600">Trim a large PDF down to only the pages you actually need. Remove cover pages, end notes, or duplicate pages to create a lean document that focuses on the content that matters to your audience.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🖼️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Cleaning scanned files</h3>
        <p class="mt-1 text-sm text-slate-600">Scanned multi-page documents sometimes include test pages, calibration sheets, or accidentally duplicated scans. Remove these extra pages to produce a clean, final document before sending or archiving.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the PDF page remover</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Upload a PDF</h3>
        <p class="mt-1 text-sm text-slate-600">Click the upload area and select the PDF you want to remove pages from.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-600">Enter pages to remove</h3>
        <p class="mt-1 text-sm text-slate-600">Type page numbers, ranges (e.g. 5-7), or a comma-separated list like 1,3,5-7.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Download the result</h3>
        <p class="mt-1 text-sm text-slate-600">Click "Remove pages → Download" and your trimmed PDF is saved automatically.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for removing pages</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use ranges with hyphens</h3>
        <p class="mt-1 text-sm text-slate-600">To remove a block of consecutive pages, use a hyphen between the start and end numbers. For example, <span class="font-mono text-indigo-600">5-7</span> removes pages 5, 6, and 7. This is much faster than typing each number individually.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Comma-separate non-contiguous pages</h3>
        <p class="mt-1 text-sm text-slate-600">For pages that aren't next to each other, use commas to separate them. For example, <span class="font-mono text-indigo-600">2,5,9</span> removes pages 2, 5, and 9 while keeping everything else. You can also combine ranges and individual numbers: <span class="font-mono text-indigo-600">1,3,5-7</span>.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">You can't remove all pages</h3>
        <p class="mt-1 text-sm text-slate-600">The tool requires at least one page to remain in the output. If you try to remove every page from the document, an error message is shown and the download is blocked. This prevents creating an empty or invalid PDF file.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Check page numbers against the info</h3>
        <p class="mt-1 text-sm text-slate-600">After uploading, the tool shows the total page count of your document. Double-check that your removal list references valid page numbers (1 to total) — any out-of-range numbers are ignored to prevent errors.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">The original file is safe</h3>
        <p class="mt-1 text-sm text-slate-600">This tool never modifies your original PDF. It always creates a brand-new file containing only the pages you kept. Your source document remains untouched on your device, so you can always go back and try a different removal list.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to remove pages from a PDF</h2>
    <p class="mt-2 text-slate-600">Removing pages from a PDF is one of the most straightforward document editing tasks, yet it has many practical applications across different fields. Students frequently trim lecture slides or study guides by removing cover pages, blank sheets, and extraneous appendix material, resulting in a compact document that is easier to annotate and review on a tablet or phone. Instead of carrying a 50-page slide deck, a student can remove the title slide, agenda, and closing remarks to focus on the actual content — often cutting the file size in half.</p>
    <p class="mt-3 text-slate-600">Office workers and administrators use page removal to clean up documents before sharing with colleagues or clients. A business proposal might include internal notes, draft watermarks, or duplicate pages that were added during the review process. Removing these before the final send creates a polished, professional document that presents the intended content without distractions. Similarly, removing blank pages from a scanned report or a PDF exported from a presentation tool improves readability and reduces confusion when recipients print the document.</p>
    <p class="mt-3 text-slate-600">Legal professionals and paralegals often deal with large document bundles that contain irrelevant or privileged pages mixed in with discoverable content. Removing specific pages that are outside the scope of a request or that contain confidential annotations allows them to share only the relevant portions while keeping the overall document structure intact. This is much more efficient than splitting and recombining documents, especially when only a handful of pages need to be excluded from a large case file.</p>
    <p class="mt-3 text-slate-600">Publishers and authors use page removal when preparing manuscripts for submission or formatting for different platforms. A draft manuscript might include placeholder pages, illustration notes to the typesetter, or blank verso pages that are part of the book layout but shouldn't appear in a digital review copy. Removing these pages produces a clean reading version that reviewers can focus on without being distracted by layout instructions or blank sheets. The same approach works for removing ad pages from a PDF magazine before reading offline, or stripping out the copyright page from a preview copy.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Limitations and considerations</h2>
    <p class="mt-2 text-slate-600">PDF page removal works with standard, unencrypted PDF files. Password-protected or encrypted PDFs cannot be processed because the browser-side library cannot decrypt them. If your document is password-protected, remove the password using your PDF reader software first, then load the unprotected file into this tool. Always delete unprotected copies after processing if document security is important.</p>
    <p class="mt-3 text-slate-600">Very large PDFs with hundreds of pages or large file sizes consume significant browser memory. If your device has limited RAM, consider removing pages in smaller batches or closing other browser tabs before processing. The tool loads the entire PDF into memory before creating the output, so file size and page count both affect performance. For extremely large files, the page removal may take several seconds to complete — please wait for the download prompt before attempting another operation.</p>
    <p class="mt-3 text-slate-600">Scanned PDFs work identically to digital PDFs — each scanned page is treated as a single page and can be removed like any other. The removal process copies entire pages without modifying their content, so scanned images, OCR text layers, and metadata are preserved in the output. Form fields and annotations on kept pages are also carried over to the new document.</p>
    <p class="mt-3 text-slate-600">There is no undo once the download is saved to your device. If you accidentally remove the wrong pages, re-upload the original PDF and try again with a corrected removal list. The original file is never modified, so you can experiment with different removal lists as many times as you need without any risk to your source document.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-slate-600">Explore other PDF tools in the collection:</p>
    <div class="mt-4 flex flex-wrap gap-2">
      <a href="/tools/pdf-page-numbers/" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:text-indigo-700">PDF Page Numbers</a>
      <a href="/tools/pdf-rotate/" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:text-indigo-700">PDF Rotate</a>
      <a href="/tools/pdf-to-text/" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:text-indigo-700">PDF to Text</a>
      <a href="/tools/pdf-watermark/" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:text-indigo-700">PDF Watermark</a>
      <a href="/tools/merge-pdf/" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:text-indigo-700">Merge PDF</a>
      <a href="/tools/split-pdf/" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:text-indigo-700">Split PDF</a>
    </div>
  </section>

  <script>
    import { PDFDocument } from 'pdf-lib';

    const input = document.getElementById('file-input');
    const controls = document.getElementById('controls');
    const info = document.getElementById('info');
    const pagesInput = document.getElementById('pages-input');
    const processBtn = document.getElementById('process-btn');
    const clearBtn = document.getElementById('clear-btn');
    const status = document.getElementById('status');

    let currentBytes = null;
    let currentName = '';
    let totalPages = 0;

    function parsePages(inputStr, total) {
      if (!inputStr.trim()) return null;
      const parts = inputStr.split(',');
      const indices = new Set();
      for (const part of parts) {
        const trimmed = part.trim();
        if (!trimmed) continue;
        if (trimmed.includes('-')) {
          const rangeParts = trimmed.split('-');
          if (rangeParts.length !== 2) return null;
          const start = parseInt(rangeParts[0], 10);
          const end = parseInt(rangeParts[1], 10);
          if (isNaN(start) || isNaN(end) || start < 1 || end > total || start > end) return null;
          for (let i = start; i <= end; i++) indices.add(i - 1);
        } else {
          const num = parseInt(trimmed, 10);
          if (isNaN(num) || num < 1 || num > total) return null;
          indices.add(num - 1);
        }
      }
      return [...indices].sort((a, b) => a - b);
    }

    input.addEventListener('change', async () => {
      const file = input.files[0];
      if (!file) return;
      status.textContent = '';
      try {
        currentBytes = await file.arrayBuffer();
        currentName = file.name.replace(/\.pdf$/i, '');
        const doc = await PDFDocument.load(currentBytes, { ignoreEncryption: true });
        totalPages = doc.getPageCount();
        info.textContent = `"${file.name}" — ${totalPages} page${totalPages === 1 ? '' : 's'}`;
        controls.classList.remove('hidden');
        processBtn.disabled = false;
      } catch {
        controls.classList.add('hidden');
        processBtn.disabled = true;
        status.textContent = '⚠️ Could not read this PDF — it may be corrupted or password-protected.';
      }
    });

    clearBtn.addEventListener('click', () => {
      currentBytes = null;
      currentName = '';
      totalPages = 0;
      controls.classList.add('hidden');
      processBtn.disabled = true;
      status.textContent = '';
      input.value = '';
      pagesInput.value = '';
    });

    processBtn.addEventListener('click', async () => {
      if (!currentBytes) return;

      const pageStr = pagesInput.value.trim();
      if (!pageStr) {
        status.textContent = 'Please enter which pages to remove.';
        return;
      }

      const removeIndices = parsePages(pageStr, totalPages);
      if (removeIndices === null) {
        status.textContent = 'Invalid page input — use numbers, commas, and hyphens only (e.g. 1,3,5-7).';
        return;
      }

      if (removeIndices.length === 0) {
        status.textContent = 'No valid pages to remove.';
        return;
      }

      if (removeIndices.length >= totalPages) {
        status.textContent = 'Can\'t remove all pages — at least one page must remain.';
        return;
      }

      processBtn.disabled = true;
      status.textContent = 'Removing pages…';

      try {
        const src = await PDFDocument.load(currentBytes, { ignoreEncryption: true });
        const out = await PDFDocument.create();

        const removeSet = new Set(removeIndices);
        const keepIndices = [];
        for (let i = 0; i < totalPages; i++) {
          if (!removeSet.has(i)) keepIndices.push(i);
        }

        const pages = await out.copyPages(src, keepIndices);
        pages.forEach((p) => out.addPage(p));
        const bytes = await out.save();
        const blob = new Blob([bytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${currentName}-trimmed.pdf`;
        a.click();
        setTimeout(() => URL.revokeObjectURL(url), 5000);

        const removedCount = removeIndices.length;
        status.textContent = `✓ Done! Removed ${removedCount} page${removedCount === 1 ? '' : 's'}. ${totalPages - removedCount} page${totalPages - removedCount === 1 ? '' : 's'} remain.`;
      } catch {
        status.textContent = '⚠️ Something went wrong while removing pages.';
      } finally {
        processBtn.disabled = false;
      }
    });
  </script>
</ToolLayout>
