---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Vapor Pressure Calculator';
const description = "Vapor pressure calculator with a live 3D diagram and charts. Solve Raoult's law for vapor pressure lowering from a dissolved solute, or total vapor pressure for an ideal two-liquid mixture, with worked examples.";
const intro = "Solve Raoult's law P = X·P° for vapor pressure — either the lowering caused by a non-volatile dissolved solute, or the total vapor pressure of an ideal mixture of two volatile liquids. Two 3D diagrams compare a pure solvent to one with a dissolved solute, and charts show how vapor pressure changes with composition.";
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is Raoult's law?", a: "Raoult's law states that a solvent's vapor pressure above a solution equals its mole fraction times its pure vapor pressure: P = X·P°. For a mixture of two volatile liquids, the total vapor pressure is the sum of each component's contribution." },
  { q: 'Why does dissolving a solute lower vapor pressure?', a: "A non-volatile solute takes up some of the surface area where solvent molecules would otherwise escape into vapor, diluting the solvent's effective concentration — fewer solvent molecules at the surface means a lower vapor pressure at any given temperature." },
  { q: 'What is an ideal solution?', a: 'An ideal solution is one where interactions between different molecules are essentially the same as interactions between identical molecules, so Raoult\'s law holds closely across the entire range of composition — real mixtures like benzene and toluene approximate this well.' },
  { q: 'How is vapor pressure lowering related to boiling point elevation?', a: 'They are two views of the same phenomenon: lowering a liquid\'s vapor pressure means it needs a higher temperature to reach the point where vapor pressure equals atmospheric pressure (boiling) — vapor pressure lowering is the underlying cause of boiling point elevation.' },
  { q: 'Do all solutions follow Raoult\'s law exactly?', a: "No — Raoult's law describes ideal behavior. Real solutions with strong or weak interactions between different molecules (compared to like molecules) show positive or negative deviations from the law, especially at higher solute concentrations." },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Vapor Pressure Calculator',
  description: "Solve Raoult's law for vapor pressure lowering from a solute, or total vapor pressure of a two-liquid mixture.",
  steps: [
    { name: 'Pick a mode', text: 'Non-volatile solute (colligative lowering) or ideal mixture of two volatile liquids.' },
    { name: 'Enter the required values', text: 'Pure vapor pressure(s) and either moles of solvent/solute, or mole fraction of each liquid.' },
    { name: 'Read the result', text: 'Vapor pressure and, in solute mode, the amount of lowering solve instantly.' },
  ],
};

const formulas = [
  { expr: 'P_solution = X_solvent · P°_solvent', note: "Raoult's law — non-volatile solute case" },
  { expr: 'ΔP = X_solute · P°_solvent', note: 'vapor pressure lowering caused by the solute' },
  { expr: 'P_total = X_A·P°_A + X_B·P°_B', note: 'ideal mixture of two volatile liquids A and B' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — glucose dissolved in water', tone: 'slate',
    given: 'Water\'s pure vapor pressure at 25°C, P° = 23.8 mmHg. 5 mol of water is mixed with 0.5 mol of glucose (non-volatile).',
    rows: [
      { label: 'Mole fraction of water:', value: 'X = 5 / (5+0.5) = 0.909' },
      { label: 'Formula:', value: 'P_solution = X·P°' },
      { label: 'Substitute:', value: 'P_solution = 0.909 × 23.8' },
      { label: 'Result:', value: 'P_solution ≈ 21.64 mmHg, so ΔP ≈ 2.16 mmHg', full: true },
    ],
    note: 'The vapor pressure dropped by about 9%, matching exactly the 9.09% mole fraction of glucose — the lowering scales directly with how much of the solution is solute, regardless of what the solute actually is.',
  },
  {
    title: 'Worked example 2 — an ideal benzene-toluene mixture', tone: 'amber',
    given: 'Benzene P° = 95.1 mmHg, toluene P° = 28.4 mmHg. Mixture is 60% benzene, 40% toluene by mole fraction.',
    rows: [
      { label: 'Formula:', value: 'P_total = X_benzene·P°_benzene + X_toluene·P°_toluene' },
      { label: 'Substitute:', value: 'P_total = (0.6 × 95.1) + (0.4 × 28.4)' },
      { label: 'Result:', value: 'P_total = 57.06 + 11.36 = 68.42 mmHg', full: true },
    ],
    note: 'Unlike the solute case, both components here are volatile and both contribute to the total vapor pressure — this is the general form of Raoult\'s law for a mixture of two liquids that can both evaporate.',
  },
];

const comparison = {
  heading: 'Vapor pressure lowering vs. mole fraction of solute',
  note: 'Water at 25°C, P° = 23.8 mmHg — a non-volatile solute at increasing mole fraction.',
  headers: [{ label: 'Solute mole fraction' }, { label: 'Solution vapor pressure' }, { label: 'Lowering (ΔP)' }],
  rows: [
    ['0.05', '22.61 mmHg', '1.19 mmHg'],
    ['0.091 ★', '21.64 mmHg', '2.16 mmHg'],
    ['0.20', '19.04 mmHg', '4.76 mmHg'],
    ['0.40', '14.28 mmHg', '9.52 mmHg'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Lowering scales linearly with solute mole fraction — double the solute fraction, double the vapor pressure drop.',
};

const realWorld = [
  { emoji: '🧴', title: 'Perfume and fragrance formulation', body: 'Perfumers blend volatile compounds with different vapor pressures to control how a scent evolves over time — high-vapor-pressure "top notes" evaporate first, while lower-vapor-pressure "base notes" linger far longer.' },
  { emoji: '⛽', title: 'Fuel blending', body: "Gasoline formulations are engineered with specific vapor pressure targets — seasonal blends use lower vapor pressure in summer to reduce evaporative emissions, and higher vapor pressure in winter so engines start reliably in the cold." },
  { emoji: '🌡️', title: 'Distillation and separation processes', body: "Raoult's law for volatile mixtures is the foundation of distillation calculations, letting chemical engineers predict vapor composition at each stage of separating a mixture like crude oil into its components." },
  { emoji: '🧪', title: 'Determining molar mass experimentally', body: 'Measuring vapor pressure lowering for a solution of known mass is one classic way to determine the molar mass of an unknown non-volatile solute, since the lowering depends directly on moles of solute present.' },
];

const misconceptions = [
  { claim: '"Any dissolved substance lowers a solvent\'s vapor pressure the same way."', truth: "This is only true for a non-volatile solute. Dissolving a volatile substance instead contributes its own vapor pressure to the total, following the two-liquid form of Raoult's law — the total vapor pressure can even end up higher than either pure liquid's, depending on composition." },
  { claim: '"Vapor pressure lowering depends on what the solute is chemically."', truth: "Like other colligative properties, vapor pressure lowering for a non-volatile solute depends only on the mole fraction of solute particles present, not on their chemical identity — equal mole fractions of different non-volatile solutes lower vapor pressure by the same amount." },
  { claim: '"A solution\'s vapor pressure can never exceed either pure component\'s."', truth: "For an ideal mixture of two volatile liquids, the total vapor pressure is always between the two pure vapor pressures — but real, non-ideal mixtures can show positive deviations from Raoult's law, producing a total vapor pressure that exceeds even the more volatile pure liquid." },
  { claim: '"Vapor pressure and boiling point are unrelated properties."', truth: "They are directly connected: boiling happens exactly when a liquid's vapor pressure rises to match the surrounding atmospheric pressure. Anything that lowers vapor pressure (like a dissolved solute) necessarily raises the temperature needed to reach that same atmospheric pressure — this is precisely why vapor pressure lowering and boiling point elevation are two sides of the same effect." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 11, "Solutions and Colloids" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/11-4-colligative-properties" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Atkins &amp; de Paula, <em>Physical Chemistry</em></strong> — Ideal and real solutions chapters.' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 13, Properties of Solutions.' },
];
const sourcesNote = "P = X·P° (Raoult's law). Results are rounded for display.";

const howToUse = [
  { title: 'Choose your mode', body: 'Non-volatile solute (colligative lowering), or ideal mixture of two volatile liquids.' },
  { title: 'Enter pure vapor pressures', body: 'Look these up for your solvent(s) at the relevant temperature.' },
  { title: 'Enter composition', body: 'Moles of solvent/solute, or mole fractions for a two-liquid mixture.' },
];

const related = [
  { href: '/tools/boiling-point-elevation-calculator', emoji: '♨️', title: 'Boiling Point Elevation Calculator', desc: 'ΔTb = i·Kb·m — how much a solute raises the boiling point.' },
  { href: '/tools/freezing-point-depression-calculator', emoji: '❄️', title: 'Freezing Point Depression Calculator', desc: 'ΔTf = i·Kf·m — how much a solute lowers the freezing point.' },
  { href: '/tools/molality-calculator', emoji: '🧊', title: 'Molality Calculator', desc: 'm = mol solute / kg solvent — solve any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a liquid's vapor pressure comes from how many of its own molecules are free to escape into the vapor phase, so anything that dilutes those molecules — whether an inert solute taking up space or a second volatile liquid sharing the surface — proportionally changes the vapor pressure."
  howIntro="Every liquid has molecules constantly escaping into vapor and recondensing, and vapor pressure measures how much escaped vapor it takes to reach equilibrium with the liquid. Raoult's law says that a component's contribution to vapor pressure is simply its mole fraction times its own pure vapor pressure. Dissolve a non-volatile solute and it dilutes the solvent at the surface, lowering vapor pressure proportionally to how much solute is present. Mix two volatile liquids instead, and both contribute their own share to a combined total vapor pressure — the same underlying law, just applied twice."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where vapor pressure actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-solute" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Non-volatile solute</button>
      <button id="mode-mixture" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Two-liquid mixture</button>
    </div>

    <div id="panel-solute">
      <div class="grid gap-4 sm:grid-cols-3">
        <label class="block"><span class="text-sm font-medium text-slate-700">Pure solvent P° (mmHg)</span>
          <input id="p0" type="number" step="any" value="23.8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Moles solvent</span>
          <input id="n-solvent" type="number" step="any" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Moles solute</span>
          <input id="n-solute" type="number" step="any" value="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Solution vapor pressure</div><div id="r-psol" class="mt-1 text-2xl font-bold">—</div></div>
        <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Lowering (ΔP)</div><div id="r-dp" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      </div>
    </div>

    <div id="panel-mixture" class="hidden">
      <div class="grid gap-4 sm:grid-cols-3">
        <label class="block"><span class="text-sm font-medium text-slate-700">P°_A (mmHg)</span>
          <input id="pa0" type="number" step="any" value="95.1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">P°_B (mmHg)</span>
          <input id="pb0" type="number" step="any" value="28.4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Mole fraction of A (X_A)</span>
          <input id="xa" type="number" step="any" value="0.6" min="0" max="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Total vapor pressure</div><div id="r-ptotal" class="mt-1 text-2xl font-bold">—</div></div>
        <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P_A contribution</div><div id="r-pa" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">P_B contribution</div><div id="r-pb" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      </div>
    </div>
    <p id="vp-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Pure solvent vs. solution with solute</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-pure" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Pure solvent</h3>
          <p class="mt-1 text-sm text-slate-600">Only solvent molecules (blue) at the surface — nothing dilutes their escape into vapor.</p>
        </div>
        <div>
          <div id="diag-solution" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Solution with dissolved solute</h3>
          <p class="mt-1 text-sm text-slate-600">Solute particles (amber) take up surface space, lowering the effective vapor pressure.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Vapor pressure graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">P_solution vs. solvent mole fraction (water, P°=23.8mmHg)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-solute"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Ideal mixture: P_A, P_B, P_total vs. X_A</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mixture"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- mode switch ----
      let mode = 'solute';
      function switchMode(m) {
        mode = m;
        el('mode-solute').className = m === 'solute' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-mixture').className = m === 'mixture' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('panel-solute').classList.toggle('hidden', m !== 'solute');
        el('panel-mixture').classList.toggle('hidden', m !== 'mixture');
        el('vp-err').textContent = '';
      }

      // ---- calculator ----
      function updateSolute() {
        el('vp-err').textContent = '';
        el('r-psol').textContent = '—'; el('r-dp').textContent = '—';
        const p0 = parseFloat(el('p0').value), ns = parseFloat(el('n-solvent').value), nu = parseFloat(el('n-solute').value);
        if (isNaN(p0) || isNaN(ns) || isNaN(nu)) return;
        if (p0 <= 0 || ns <= 0 || nu < 0) { el('vp-err').textContent = 'Vapor pressure and moles of solvent must be positive; moles of solute cannot be negative.'; return; }
        const x = ns / (ns + nu);
        const psol = x * p0;
        el('r-psol').textContent = fmt(psol) + ' mmHg';
        el('r-dp').textContent = fmt(p0 - psol) + ' mmHg';
      }
      function updateMixture() {
        el('vp-err').textContent = '';
        el('r-ptotal').textContent = '—'; el('r-pa').textContent = '—'; el('r-pb').textContent = '—';
        const pa0 = parseFloat(el('pa0').value), pb0 = parseFloat(el('pb0').value), xa = parseFloat(el('xa').value);
        if (isNaN(pa0) || isNaN(pb0) || isNaN(xa)) return;
        if (pa0 <= 0 || pb0 <= 0 || xa < 0 || xa > 1) { el('vp-err').textContent = 'Vapor pressures must be positive; X_A must be between 0 and 1.'; return; }
        const xb = 1 - xa;
        const pa = xa * pa0, pb = xb * pb0;
        el('r-ptotal').textContent = fmt(pa + pb) + ' mmHg';
        el('r-pa').textContent = fmt(pa) + ' mmHg';
        el('r-pb').textContent = fmt(pb) + ' mmHg';
      }
      el('mode-solute').addEventListener('click', () => { switchMode('solute'); updateSolute(); });
      el('mode-mixture').addEventListener('click', () => { switchMode('mixture'); updateMixture(); });
      ['p0', 'n-solvent', 'n-solute'].forEach((id) => el(id).addEventListener('input', updateSolute));
      ['pa0', 'pb0', 'xa'].forEach((id) => el(id).addEventListener('input', updateMixture));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const xLabels = [], pData = [];
        for (let x = 0.5; x <= 1; x += 0.05) { xLabels.push(x.toFixed(2)); pData.push(+(x * 23.8).toFixed(2)); }
        new Chart(el('chart-solute'), {
          type: 'line',
          data: { labels: xLabels, datasets: [{ label: 'P_solution (mmHg)', data: pData, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Solvent mole fraction' } }, y: { title: { display: true, text: 'Vapor pressure (mmHg)' } } }, plugins: { legend: { display: false } } }),
        });
        const xaLabels = [], paData = [], pbData = [], ptotData = [];
        for (let x = 0; x <= 1; x += 0.1) { xaLabels.push(x.toFixed(1)); paData.push(+(x * 95.1).toFixed(1)); pbData.push(+((1 - x) * 28.4).toFixed(1)); ptotData.push(+(x * 95.1 + (1 - x) * 28.4).toFixed(1)); }
        new Chart(el('chart-mixture'), {
          type: 'line',
          data: {
            labels: xaLabels,
            datasets: [
              { label: 'P_A', data: paData, borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
              { label: 'P_B', data: pbData, borderColor: '#f59e0b', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
              { label: 'P_total', data: ptotData, borderColor: '#10b981', backgroundColor: 'transparent', tension: 0, pointRadius: 0, borderDash: [6, 3] },
            ],
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'X_A' } }, y: { title: { display: true, text: 'Vapor pressure (mmHg)' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }

      function moleculeScene(container, soluteCount) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const box = new THREE.Mesh(new THREE.BoxGeometry(4, 3, 3), new THREE.MeshBasicMaterial({ color: 0x94a3b8, wireframe: true }));
        s.scene.add(box);
        for (let i = 0; i < 20; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.16, 10, 8), new THREE.MeshStandardMaterial({ color: 0x38bdf8 }));
          m.position.set((Math.random() - 0.5) * 3.5, (Math.random() - 0.5) * 2.5, (Math.random() - 0.5) * 2.5);
          s.scene.add(m);
        }
        for (let i = 0; i < soluteCount; i++) {
          const p = new THREE.Mesh(new THREE.SphereGeometry(0.22, 10, 8), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
          p.position.set((Math.random() - 0.5) * 3.5, (Math.random() - 0.5) * 2.5, (Math.random() - 0.5) * 2.5);
          s.scene.add(p);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagPure = null, diagSolution = null;
      function initDiagPure() { const c = el('diag-pure'); if (!c) throw new Error('no container'); diagPure = moleculeScene(c, 0); }
      function initDiagSolution() { const c = el('diag-solution'); if (!c) throw new Error('no container'); diagSolution = moleculeScene(c, 8); }

      function boot() {
        try { switchMode('solute'); updateSolute(); } catch (e) { console.error('[vapor-pressure] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[vapor-pressure] charts failed', e); }
        if (window.THREE) {
          try { initDiagPure(); } catch (e) { console.error('[vapor-pressure] pure diagram failed', e); }
          try { initDiagSolution(); } catch (e) { console.error('[vapor-pressure] solution diagram failed', e); }
        }
        mountResize([diagPure, diagSolution]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
