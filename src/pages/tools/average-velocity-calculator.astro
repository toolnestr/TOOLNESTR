---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Average Velocity Calculator';
const description = 'Average velocity calculator with a live 3D track animation and charts. Solve v_avg = Δx / Δt from displacement and time, with worked examples and the average-velocity-vs-average-speed distinction explained.';
const intro = 'Enter displacement and time (or the initial/final position and time) — average velocity solves instantly, and a live 3D marker on a track plus charts show what the secant slope means.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is average velocity?', a: 'Average velocity is the total displacement divided by the total time taken: v_avg = Δx / Δt. Because displacement is a vector, average velocity is also a vector — it has a direction and can be negative or zero, even if the object moved a lot.' },
  { q: 'Is average velocity the same as average speed?', a: 'Only when the motion is one-directional. Average speed is total distance travelled divided by total time (always ≥ 0). Average velocity is total displacement divided by total time, and it can be smaller than average speed — or even zero — if the object doubles back.' },
  { q: 'What is the formula for average velocity?', a: 'v_avg = Δx / Δt = (x_f − x_i) / (t_f − t_i). It only needs the start and end position and the total elapsed time — the path taken in between does not matter.' },
  { q: 'Can average velocity be negative?', a: 'Yes. If the final position is behind the initial position (in whatever direction you have defined as positive), the displacement Δx is negative, so v_avg is negative — it simply means the net motion was in the negative direction.' },
  { q: 'How is average velocity different from instantaneous velocity?', a: 'Average velocity uses the net displacement over a finite time interval. Instantaneous velocity is the rate of change of position at one instant — the slope of the position-vs-time graph at a single point, found by shrinking Δt toward zero.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Average Velocity Calculator',
  description: 'Calculate average velocity from displacement and time, and see the difference between average velocity and average speed.',
  steps: [
    { name: 'Enter two values', text: 'Type any two of displacement (Δx), time (Δt), and average velocity (v_avg).' },
    { name: 'Read the result', text: 'The third value solves instantly, and the 3D track marker updates.' },
    { name: 'Check the graphs', text: 'The position-vs-time chart shows the secant line whose slope is v_avg.' },
  ],
};

const formulas = [
  { expr: 'v<sub>avg</sub> = Δx / Δt', note: 'displacement over elapsed time' },
  { expr: 'v<sub>avg</sub> = (x<sub>f</sub> − x<sub>i</sub>) / (t<sub>f</sub> − t<sub>i</sub>)', note: 'expanded form' },
  { expr: 'speed<sub>avg</sub> = distance / Δt', note: 'always ≥ 0 — a different quantity' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a runner on a straight track', tone: 'slate',
    given: 'A sprinter starts at x_i = 0 m and finishes at x_f = 400 m, 50 s later. Find the average velocity.',
    rows: [
      { label: 'Displacement:', value: 'Δx = 400 − 0 = 400 m' },
      { label: 'Time:', value: 'Δt = 50 s' },
      { label: 'Average velocity:', value: 'v_avg = 400 ÷ 50 = 8.00 m/s', full: true },
    ],
  },
  {
    title: 'Worked example 2 — the round trip (velocity vs speed)', tone: 'amber',
    given: 'A driver goes 60 km east in 1.0 h, then 60 km west back to the start in another 1.0 h. Find average velocity and average speed.',
    rows: [
      { label: 'Total displacement:', value: 'Δx = 60 − 60 = 0 km' },
      { label: 'Total time:', value: 'Δt = 1.0 + 1.0 = 2.0 h' },
      { label: 'Average velocity:', value: 'v_avg = 0 ÷ 2.0 = 0 km/h' },
      { label: 'Average speed:', value: 'distance/time = 120 ÷ 2.0 = 60 km/h', full: true },
    ],
    note: 'Same trip, two very different numbers — velocity cares about net displacement, speed cares about total distance.',
  },
];

const comparison = {
  heading: 'Average velocity vs average speed',
  note: 'They agree only when motion never reverses direction.',
  headers: [{ label: 'Scenario' }, { label: 'Avg. velocity' }, { label: 'Avg. speed' }],
  rows: [
    ['400 m sprint, straight line', '8.00 m/s', '8.00 m/s'],
    ['60 km out, 60 km back (2 h)', '0 km/h', '60 km/h'],
    ['Runner on a 400 m oval track (1 lap)', '0 m/s', 'track speed &gt; 0'],
    ['Car drives 100 km east, then 40 km west (2 h)', '30 km/h east', '70 km/h'],
  ],
  highlightIndex: 1,
  footnote: 'Displacement is net (start → end); distance is the odometer reading. Speed ≥ |velocity| always.',
};

const realWorld = [
  { emoji: '🗺️', title: 'Trip planning', body: 'Mapping apps quote an average speed for a route because distance travelled is what uses fuel and time — but if you need to know how far from home you ended up, that is the displacement-based average velocity.' },
  { emoji: '📍', title: 'GPS tracking', body: 'Fitness trackers log distance (an odometer sum) to compute average pace/speed, while your net displacement from the start point — useful for "as the crow flies" stats — comes from average velocity.' },
  { emoji: '🏟️', title: 'Sports analytics', body: 'A player who sprints back and forth across a pitch can have huge average speed but near-zero average velocity for a possession, which is exactly why coaches track both numbers separately.' },
];

const misconceptions = [
  { claim: '"Average velocity and average speed are always the same."', truth: 'Only for motion in a single direction. As soon as the path doubles back, distance travelled exceeds the net displacement, so average speed is strictly greater than the magnitude of average velocity.' },
  { claim: '"If average velocity is zero, the object never moved."', truth: 'It only means the object ended up where it started. It may have travelled a large distance in between — a runner finishing a lap has zero average velocity but a large, very real average speed.' },
  { claim: '"Average velocity tells you the speed at every moment."', truth: 'It only describes the net rate over the whole interval. The object could have sped up, slowed down, or stopped along the way — instantaneous velocity is needed for that detail.' },
  { claim: '"A negative average velocity means the object slowed down."', truth: 'The sign of v_avg indicates direction, not speeding up or slowing down. A negative v_avg simply means the net displacement was in the negative direction you defined.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §3.2 "Instantaneous Velocity and Speed" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/3-2-instantaneous-velocity-and-speed" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 2, Motion Along a Straight Line (Average Velocity and Average Speed).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 2, Motion in One Dimension.' },
];
const sourcesNote = 'v_avg = Δx / Δt is a net, signed quantity; average speed uses total distance and is never negative. Results rounded for display.';

const howToUse = [
  { title: 'Enter two values', body: 'Fill any two of displacement, time and average velocity; the third solves live.' },
  { title: 'Watch the track', body: 'The 3D marker moves from x_i to x_f over the given time, matching your inputs.' },
  { title: 'Read the graphs', body: 'The position-time secant slope is v_avg; the second chart shows how v_avg changes with Δt at fixed Δx.' },
];

const related = [
  { href: '/tools/acceleration-calculator', emoji: '🚀', title: 'Acceleration Calculator', desc: 'a = Δv/Δt — solve for any variable.' },
  { href: '/tools/free-fall-calculator', emoji: '⬇️', title: 'Free Fall Calculator', desc: 'Time and velocity under gravity.' },
  { href: '/tools/projectile-motion-calculator', emoji: '🎯', title: 'Projectile Motion Calculator', desc: 'Range, height and time from launch speed.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="average velocity is net displacement divided by total time — the straight-line slope from where you started to where you ended up, no matter how winding the path in between."
  howIntro="Rearranged, the same relation solves any of the three quantities: Δx = v<sub>avg</sub> × Δt and Δt = Δx / v<sub>avg</sub>. Because Δx is signed, v<sub>avg</sub> is signed too — it is a genuinely different number from average speed whenever the motion reverses direction."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where average velocity actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any two values — the third solves instantly.</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Displacement (Δx)</span>
        <input id="dx" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time (Δt)</span>
        <input id="dt" type="number" step="any" placeholder="s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Average velocity (v<sub>avg</sub>)</span>
        <input id="vavg" type="number" step="any" placeholder="m/s" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Displacement</div><div id="r-dx" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Time</div><div id="r-dt" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Average velocity</div><div id="r-vavg" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="av-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D track + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D track</h2>
      <p class="mt-1 text-sm text-slate-500">Set the final position and the time; the marker sits at x_f, and the arrow shows the direction and size of v_avg. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Final position x<sub>f</sub> <span id="out-bxf" class="font-mono text-indigo-600">10.0 m</span></span>
          <input id="b-xf" type="range" min="-20" max="20" step="0.5" value="10" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Time Δt <span id="out-bdt" class="font-mono text-indigo-600">2.0 s</span></span>
          <input id="b-dt" type="range" min="0.5" max="10" step="0.1" value="2" class="mt-2 w-full accent-indigo-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">Average velocity v<sub>avg</sub> = <span id="out-bv" class="font-mono font-bold">5.00 m/s</span></div>
      <div id="track3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="track3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Motion graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Position vs time — the secant slope is v_avg</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-xt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">v_avg vs Δt at fixed Δx — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vdt"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup, arrow } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('av-err').textContent = '';
        ['r-dx', 'r-dt', 'r-vavg'].forEach((id) => (el(id).textContent = '—'));
        const dx = parseFloat(el('dx').value), dt = parseFloat(el('dt').value), v = parseFloat(el('vavg').value);
        const filled = [!isNaN(dx), !isNaN(dt), !isNaN(v)];
        if (filled.filter(Boolean).length < 2) return;
        let rdx = NaN, rdt = NaN, rv = NaN;
        if (filled[0] && filled[1]) {
          if (dt === 0) { el('av-err').textContent = 'Time cannot be zero.'; return; }
          rdx = dx; rdt = dt; rv = dx / dt;
        } else if (filled[0] && filled[2]) {
          if (v === 0) { el('av-err').textContent = 'Cannot solve time when average velocity is zero and displacement is nonzero.'; return; }
          rdx = dx; rv = v; rdt = dx / v;
        } else if (filled[1] && filled[2]) {
          if (dt === 0) { el('av-err').textContent = 'Time cannot be zero.'; return; }
          rdt = dt; rv = v; rdx = v * dt;
        }
        if (!isNaN(rdx)) el('r-dx').textContent = fmt(rdx) + ' m';
        if (!isNaN(rdt)) el('r-dt').textContent = fmt(rdt) + ' s';
        if (!isNaN(rv)) el('r-vavg').textContent = fmt(rv) + ' m/s';
      }
      ['dx', 'dt', 'vavg'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let track = null;
      const XI = -10; // fixed start position (scene units = metres)
      function bState() {
        const xf = parseFloat(el('b-xf').value), dt = parseFloat(el('b-dt').value);
        return { xi: XI, xf, dt, v: dt > 0 ? (xf - XI) / dt : 0 };
      }
      function onB() {
        const s = bState();
        el('out-bxf').textContent = s.xf.toFixed(1) + ' m';
        el('out-bdt').textContent = s.dt.toFixed(1) + ' s';
        el('out-bv').textContent = fmt(s.v) + ' m/s';
        try { if (track) track.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-xf').addEventListener('input', onB);
      el('b-dt').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.xt = new Chart(el('chart-xt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Position', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: false, tension: 0, pointRadius: 3 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Position (m)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.vdt = new Chart(el('chart-vdt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'v_avg', data: [], borderColor: '#f59e0b', pointRadius: 0, tension: 0.3 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Δt (s)' } }, y: { title: { display: true, text: 'v_avg (m/s)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        charts.xt.data.labels = ['0', fmt(s.dt)];
        charts.xt.data.datasets[0].data = [s.xi, s.xf];
        charts.xt.update();
        const dx = s.xf - s.xi;
        const L = [], D = [];
        for (let t = 0.5; t <= 10.001; t += 0.25) { L.push(t.toFixed(2)); D.push(t > 0 ? +(dx / t).toFixed(4) : 0); }
        charts.vdt.data.labels = L; charts.vdt.data.datasets[0].data = D; charts.vdt.update();
      }

      // ---- interactive track ----
      function initTrack() {
        const c = el('track3d'); if (!c) throw new Error('no track');
        const s = makeScene(c, 22, new THREE.Vector3(0, 0, 0), OPTS);
        s.scene.add(new THREE.GridHelper(40, 20, 0xcbd5e1, 0xe2e8f0));
        const rail = new THREE.Mesh(new THREE.BoxGeometry(40, 0.15, 0.6), new THREE.MeshStandardMaterial({ color: 0x94a3b8 }));
        s.scene.add(rail);
        const startMarker = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 1.2, 12), new THREE.MeshStandardMaterial({ color: 0x64748b }));
        startMarker.position.set(XI, 0.6, 0); s.scene.add(startMarker);
        const ball = new THREE.Mesh(new THREE.SphereGeometry(0.6, 24, 24), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
        s.scene.add(ball);
        let arrowHelper = null;
        function update(state) {
          ball.position.set(state.xf, 0.6, 0);
          if (arrowHelper) { s.scene.remove(arrowHelper); }
          const dir = state.xf - state.xi;
          if (Math.abs(dir) > 1e-6) {
            const from = new THREE.Vector3(state.xi, 1.6, 0);
            const to = new THREE.Vector3(state.xf, 1.6, 0);
            arrowHelper = arrow(from, to, 0xef4444);
            s.scene.add(arrowHelper);
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        track = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { update(); } catch (e) { console.error('[average-velocity] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[average-velocity] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[average-velocity] charts failed', e); }
        if (window.THREE) {
          try { initTrack(); } catch (e) { console.error('[average-velocity] track failed', e); el('track3d-fallback').classList.remove('hidden'); }
        } else { el('track3d-fallback').classList.remove('hidden'); }
        mountResize([track]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
