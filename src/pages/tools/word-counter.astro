---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site.js';

const title = 'Word & Character Counter';
const description =
  'Free online word counter. Instantly count words, characters, sentences, ' +
  'paragraphs and reading time as you type. Works in your browser — nothing is uploaded.';

const faqs = [
  { q: 'How does the word counter work?', a: 'Just type or paste your text. The counts update instantly in your browser — no button to press and nothing is sent to any server.' },
  { q: 'Is there a word limit?', a: 'No. You can paste essays, articles or whole documents. Everything is processed on your device.' },
  { q: 'How is reading time calculated?', a: 'Reading time assumes an average reading speed of about 200 words per minute, a common estimate for adults.' },
  { q: 'Is my text private?', a: 'Yes. The tool runs entirely in your browser, so your text never leaves your device.' },
];

// SEO structured data: the tool + the FAQ.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: `${title} — ${site.name}`,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Any (web browser)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description,
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <!-- Breadcrumb (good for SEO + navigation) -->
    <nav class="mb-4 text-sm text-slate-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-1">›</span>
      <a href="/#everyday" class="hover:text-indigo-600">Everyday</a>
      <span class="mx-1">›</span>
      <span class="text-slate-700">Word Counter</span>
    </nav>

    <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
      Word &amp; Character Counter
    </h1>
    <p class="mt-2 text-slate-600">
      Type or paste your text below to see live counts of words, characters, sentences,
      paragraphs and estimated reading time.
    </p>

    <!-- THE TOOL -->
    <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
      <textarea
        id="text-input"
        rows="9"
        placeholder="Start typing or paste your text here…"
        class="w-full resize-y rounded-xl border border-slate-300 p-4 text-base leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
      ></textarea>

      <!-- Live stats -->
      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        <div class="rounded-xl bg-indigo-50 p-3 text-center">
          <div id="stat-words" class="text-2xl font-bold text-indigo-700">0</div>
          <div class="text-xs font-medium text-slate-500">Words</div>
        </div>
        <div class="rounded-xl bg-indigo-50 p-3 text-center">
          <div id="stat-chars" class="text-2xl font-bold text-indigo-700">0</div>
          <div class="text-xs font-medium text-slate-500">Characters</div>
        </div>
        <div class="rounded-xl bg-indigo-50 p-3 text-center">
          <div id="stat-chars-ns" class="text-2xl font-bold text-indigo-700">0</div>
          <div class="text-xs font-medium text-slate-500">No spaces</div>
        </div>
        <div class="rounded-xl bg-indigo-50 p-3 text-center">
          <div id="stat-sentences" class="text-2xl font-bold text-indigo-700">0</div>
          <div class="text-xs font-medium text-slate-500">Sentences</div>
        </div>
        <div class="rounded-xl bg-indigo-50 p-3 text-center">
          <div id="stat-paragraphs" class="text-2xl font-bold text-indigo-700">0</div>
          <div class="text-xs font-medium text-slate-500">Paragraphs</div>
        </div>
        <div class="rounded-xl bg-indigo-50 p-3 text-center">
          <div id="stat-reading" class="text-2xl font-bold text-indigo-700">0s</div>
          <div class="text-xs font-medium text-slate-500">Reading time</div>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <button id="copy-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Copy text</button>
        <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
      </div>
    </div>

    <!-- Content for SEO + users -->
    <section class="prose-tool mt-10">
      <h2 class="text-xl font-bold text-slate-900">About this word counter</h2>
      <p class="mt-2 text-slate-600">
        This free word counter helps writers, students, marketers and social media users keep
        their text within limits. Whether you're writing an essay with a word target, a meta
        description under 160 characters, or a tweet, you'll see every count update instantly as
        you type. Because it runs entirely in your browser, it's fast and completely private.
      </p>

      <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
      <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
        <li>Type directly into the box, or paste text you've copied from anywhere.</li>
        <li>Watch the word, character, sentence and paragraph counts update live.</li>
        <li>Check the estimated reading time for articles and scripts.</li>
        <li>Use “Copy text” to copy it back, or “Clear” to start over.</li>
      </ol>

      <h2 class="mt-8 text-xl font-bold text-slate-900">Frequently asked questions</h2>
      <div class="mt-3 space-y-4">
        {faqs.map((f) => (
          <div class="rounded-xl border border-slate-200 bg-white p-4">
            <h3 class="font-semibold text-slate-900">{f.q}</h3>
            <p class="mt-1 text-sm text-slate-600">{f.a}</p>
          </div>
        ))}
      </div>

      <h2 class="mt-8 text-xl font-bold text-slate-900">Related tools</h2>
      <p class="mt-2 text-sm text-slate-600">
        More tools are coming soon — Case Converter, JSON Formatter and many more.
        <a href="/" class="font-medium text-indigo-600 hover:underline">Browse all tools →</a>
      </p>
    </section>
  </div>

  <script is:inline>
    const input = document.getElementById('text-input');
    const el = (id) => document.getElementById(id);

    function update() {
      const text = input.value;
      const trimmed = text.trim();

      const words = trimmed ? trimmed.split(/\s+/).length : 0;
      const chars = text.length;
      const charsNoSpaces = text.replace(/\s/g, '').length;
      const sentences = trimmed ? (trimmed.match(/[^.!?]+[.!?]+/g) || [trimmed]).length : 0;
      const paragraphs = trimmed ? trimmed.split(/\n+/).filter((p) => p.trim()).length : 0;

      const totalSeconds = Math.round((words / 200) * 60);
      let reading;
      if (totalSeconds < 60) reading = totalSeconds + 's';
      else reading = Math.floor(totalSeconds / 60) + 'm ' + (totalSeconds % 60) + 's';

      el('stat-words').textContent = words.toLocaleString();
      el('stat-chars').textContent = chars.toLocaleString();
      el('stat-chars-ns').textContent = charsNoSpaces.toLocaleString();
      el('stat-sentences').textContent = sentences.toLocaleString();
      el('stat-paragraphs').textContent = paragraphs.toLocaleString();
      el('stat-reading').textContent = words ? reading : '0s';
    }

    input.addEventListener('input', update);

    el('clear-btn').addEventListener('click', () => {
      input.value = '';
      update();
      input.focus();
    });

    el('copy-btn').addEventListener('click', async () => {
      if (!input.value) return;
      try {
        await navigator.clipboard.writeText(input.value);
        const btn = el('copy-btn');
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => (btn.textContent = original), 1500);
      } catch (e) { /* clipboard not available */ }
    });

    update();
  </script>
</BaseLayout>
