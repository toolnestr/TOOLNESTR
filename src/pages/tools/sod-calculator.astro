---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Sod Calculator';
const description = 'Calculate the number of sod rolls and pallets needed for your lawn area.';
const intro = 'Estimate how many rolls or pallets of sod you need for any lawn area.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'How big is a roll of sod?', a: 'Standard sod rolls are 2 ft x 5 ft (10 sq ft each). Some suppliers use 1.5 ft x 6 ft (9 sq ft) or 2 ft x 6 ft (12 sq ft). Always confirm the roll size with your supplier before ordering.' },
  { q: 'How many rolls are on a pallet?', a: 'A standard pallet of sod contains about 50-70 rolls, covering approximately 450-700 sq ft depending on the roll size. A full pallet weighs 1,500-3,000 lbs.' },
  { q: 'How quickly do I need to install sod?', a: 'Sod should be installed within 24-36 hours of harvesting. Keep rolls in the shade and lightly water them if you cannot install immediately. Do not stack rolls more than 3-4 high to prevent heat damage.' },
  { q: 'How much water does new sod need?', a: 'Water new sod daily for the first 2-3 weeks. The goal is to keep the soil underneath the sod moist, not just the grass blades. Each watering should provide about 1/4 to 1/2 inch of water.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Lawn length (ft)</span>
        <input id="length" type="number" step="any" placeholder="50" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Lawn width (ft)</span>
        <input id="width" type="number" step="any" placeholder="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Roll size</span>
      <div class="mt-1 flex gap-2">
        {['2x5 ft (10 sq ft)', '1.5x6 ft (9 sq ft)', '2x6 ft (12 sq ft)'].map((r) => (
          <button data-sf={r.match(/(\d+)/g)[1]} class="roll-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{r}</button>
        ))}
      </div>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Sod needed</div>
        <div id="r-rolls" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-detail" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Lawn area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Pallets needed</div><div id="r-pals" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sod-title sod-desc">
      <title id="sod-title">Lawn divided into sod strips diagram</title>
      <desc id="sod-desc">A rectangular lawn divided into parallel strips representing rolls of sod laid side by side</desc>
      <rect x="80" y="60" width="560" height="240" fill="#f0fdf4" stroke="#86efac" stroke-width="2" rx="4" />
      <g stroke="#22c55e" stroke-width="1.5" opacity="0.5">
        <line x1="170" y1="60" x2="170" y2="300" />
        <line x1="260" y1="60" x2="260" y2="300" />
        <line x1="350" y1="60" x2="350" y2="300" />
        <line x1="440" y1="60" x2="440" y2="300" />
        <line x1="530" y1="60" x2="530" y2="300" />
      </g>
      <g stroke="#86efac" stroke-width="0.5">
        <line x1="125" y1="60" x2="125" y2="300" />
        <line x1="215" y1="60" x2="215" y2="300" />
        <line x1="305" y1="60" x2="305" y2="300" />
        <line x1="395" y1="60" x2="395" y2="300" />
        <line x1="485" y1="60" x2="485" y2="300" />
        <line x1="575" y1="60" x2="575" y2="300" />
      </g>
      <text x="360" y="340" text-anchor="middle" font-size="13" fill="#64748b" font-family="system-ui,sans-serif">Sod strips laid in staggered rows for a seamless lawn</text>
      <line x1="80" y1="35" x2="640" y2="35" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="360" y="26" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Lawn length</text>
      <line x1="60" y1="60" x2="60" y2="300" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="48" y="185" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif" transform="rotate(-90 48 185)">Lawn width</text>
      <text x="215" y="100" text-anchor="middle" font-size="10" fill="#15803d" font-family="system-ui,sans-serif">Sod strip</text>
      <text x="395" y="220" text-anchor="middle" font-size="10" fill="#15803d" font-family="system-ui,sans-serif">Sod strip</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The lawn area divided into rolls of sod, each strip representing one roll</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the sod calculator works</h2>
    <p class="mt-2 text-slate-600">
      The sod calculator estimates the number of rolls of sod needed for a rectangular lawn based on its length and width. It calculates the total area in square feet, divides by the roll size to get the number of rolls, and estimates how many pallets you need based on a standard pallet capacity of 50 rolls.
    </p>
    <p class="mt-3 text-slate-600">
      Sod is sold by the roll, with standard sizes varying by region and supplier. The most common roll size is 2 ft x 5 ft (10 sq ft). Larger rolls cover more area per piece but are heavier to carry. The calculator lets you select from common roll sizes to match your local supplier. Always round up to ensure you have enough.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the lawn</h3>
        <p class="mt-1 text-sm text-slate-600">Measure the length and width of the area to be sodded. For irregular shapes, divide into rectangles.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select roll size</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the roll size your supplier offers. The most common is 10 sq ft per roll.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Order and install</h3>
        <p class="mt-1 text-sm text-slate-600">Order the number of rolls or pallets. Install within 24 hours of delivery for best results.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Lawn area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Area = L &times; W</span>. For a 50&prime; &times; 40&prime; lawn: 50 &times; 40 = <strong>2,000 sq ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Rolls needed</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Rolls = ceil(Area / roll size)</span>. With 10 sq ft rolls: 2,000 / 10 = <strong>200 rolls</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Pallets</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Pallets = ceil(rolls / 50)</span>. 200 / 50 = <strong>4 pallets</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A front lawn 60&prime; &times; 45&prime; and a side strip 60&prime; &times; 8&prime;. Using 10 sq ft rolls.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Main lawn:</span> <span class="text-slate-600">60 &times; 45 = 2,700 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Side strip:</span> <span class="text-slate-600">60 &times; 8 = 480 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Total area:</span> <span class="text-slate-600">2,700 + 480 = 3,180 sq ft</span></div>
        <div><span class="font-medium text-slate-700">Rolls:</span> <span class="text-slate-600">3,180 / 10 = 318 rolls. Pallets: 318 / 50 = <strong>7 pallets</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the sod calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌱</span>
        <h3 class="mt-2 font-semibold text-slate-900">New lawn installation</h3>
        <p class="mt-1 text-sm text-slate-600">Establish a new lawn from sod instead of seed for instant results. Sod is more expensive than seed but provides an immediate, weed-free lawn that can be used within 2-3 weeks.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏡</span>
        <h3 class="mt-2 font-semibold text-slate-900">Lawn renovation</h3>
        <p class="mt-1 text-sm text-slate-600">Replace a damaged or patchy lawn with fresh sod. Remove the old grass, amend the soil, and lay new sod for an instant transformation. The calculator helps you order exactly what you need.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">New construction landscaping</h3>
        <p class="mt-1 text-sm text-slate-600">Builders sod the lots of newly constructed homes for immediate curb appeal. Calculate the entire lot area minus the house and driveway. Order sod delivery timed with the final grading and irrigation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌿</span>
        <h3 class="mt-2 font-semibold text-slate-900">Patch repair</h3>
        <p class="mt-1 text-sm text-slate-600">Small patches of dead or damaged grass can be replaced with a few rolls of sod. Match the grass type to your existing lawn for a seamless blend. The calculator works for any size — even a single roll.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for laying sod</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Prepare the soil properly</h3>
        <p class="mt-1 text-sm text-slate-600">Till the soil to a depth of 4-6 inches, remove rocks and debris, and level the surface. Add 2-3 inches of topsoil or compost if your native soil is poor. The soil grade should slope away from the house for drainage. Rake smooth and lightly compact before laying sod.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Stagger the seams like brickwork</h3>
        <p class="mt-1 text-sm text-slate-600">Lay rolls in a staggered pattern, offsetting the end joints like a brick wall. This prevents long seams that could open up as the sod shrinks. Butt the rolls tightly together without overlapping or leaving gaps.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Roll and water immediately</h3>
        <p class="mt-1 text-sm text-slate-600">After laying each section, roll the sod with a lawn roller (filled 1/3 with water) to ensure good soil contact. Water thoroughly within 30 minutes of installation — the soil should be wet 4-6 inches deep. Keep foot traffic off the new sod for at least 2 weeks.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/mulch-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Mulch Calculator</a>
      <a href="/tools/square-footage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
      <a href="/tools/cubic-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Cubic Yardage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let rollSf = 10;

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      if (!L || !W || L <= 0 || W <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const area = L * W;
      const rolls = Math.ceil(area / rollSf);
      const pals = Math.ceil(rolls / 50);
      el('r-rolls').textContent = rolls.toLocaleString() + ' rolls';
      el('r-detail').textContent = '(at ' + rollSf + ' sq ft / roll)';
      el('r-area').textContent = area.toFixed(1) + ' sq ft';
      el('r-pals').textContent = pals.toLocaleString() + ' pallet' + (pals !== 1 ? 's' : '');
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.roll-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.roll-btn').forEach((b) => {
          b.className = 'roll-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50';
        });
        btn.className = 'roll-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
        rollSf = parseInt(btn.dataset.sf, 10);
        update();
      });
    });

    ['length', 'width'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
    document.querySelector('.roll-btn').click();
  </script>
</ToolLayout>
