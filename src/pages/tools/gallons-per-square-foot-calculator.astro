---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Gallons per Square Foot Coverage Calculator';
const description = "Find how many gallons you need to cover an area from the product coverage rate — for paint, sealer, stain, primer and driveway coatings.";
const intro = 'Find how many gallons you need to cover an area, from your product’s coverage rate.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How many gallons do I need to cover a given area?', a: 'Divide the area in square feet by the product coverage rate in square feet per gallon, then multiply by the number of coats. For 900 sq ft at 350 sq ft/gal and one coat: 900 ÷ 350 = 2.57 gallons, rounded up to 3 gallons.' },
  { q: 'What coverage rate should I use?', a: 'Use the figure on the product label. Interior wall paint typically covers 350 to 400 sq ft per gallon, primer 200 to 300, semi-transparent deck stain 200 to 300, solid stain 150 to 250, and concrete sealer 250 to 400. Rough or porous surfaces cover at the lower end.' },
  { q: 'Do I need to add for multiple coats?', a: 'Yes. Each coat needs its own share of paint, so two coats roughly double the gallons. The calculator multiplies the single-coat amount by the number of coats you enter, then rounds up to whole cans.' },
  { q: 'Why round up to whole gallons?', a: 'Paint and coatings are sold in whole gallons and quarts, and running out mid-job risks a visible lap mark or a slightly different batch color. Rounding up ensures you finish the job, with a little left for touch-ups.' },
];
const howTo = {
  name: 'How to calculate gallons per square foot coverage',
  steps: [
    { name: 'Measure the area', text: 'Measure the total square feet of wall, deck, or floor you are covering.' },
    { name: 'Read the label rate', text: 'Find the square feet per gallon coverage rate printed on the product label.' },
    { name: 'Set the coats', text: 'Enter the number of coats to get the whole gallons to buy for the job.' },
  ],
};
const sources = [
  { html: "<strong>American Concrete Institute — ACI 318</strong>, Building Code Requirements for Structural Concrete. <a href=\"https://www.concrete.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">concrete.org</a>" },
  { html: "<strong>ICC — International Residential Code (IRC)</strong>, span, footing and framing tables. <a href=\"https://codes.iccsafe.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">codes.iccsafe.org</a>" },
  { html: "<strong>APA – The Engineered Wood Association</strong>, allowable span and load guidance." },
];
const sourcesNote = "Estimates for planning only. Span, load and code values vary by jurisdiction — verify against your local adopted code and a licensed engineer before building.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Area to cover (sq ft)</span>
        <input id="area" type="number" step="any" placeholder="900" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Coverage rate (sq ft/gal)</span>
        <input id="rate" type="number" step="any" placeholder="350" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of coats</span>
        <input id="coats" type="number" step="1" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Buy this much</div>
        <div id="r-buy" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Exact gallons</div><div id="r-exact" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Per coat</div><div id="r-percoat" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Total area painted</div><div id="r-total" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="gc-title gc-desc">
      <title id="gc-title">Coverage-rate gallons formula</title>
      <desc id="gc-desc">A paint can covering a wall and the gallons formula</desc>
      <rect x="70" y="70" width="120" height="90" fill="#ede9fe" stroke="#8b5cf6" stroke-width="1.5" />
      <rect x="210" y="95" width="46" height="60" rx="4" fill="#c4b5fd" stroke="#7c3aed" stroke-width="1.5" />
      <rect x="222" y="82" width="22" height="14" fill="#a78bfa" />
      <text x="130" y="180" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">area to cover</text>
      <rect x="330" y="55" width="410" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="350" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Gallons needed</text>
      <text x="350" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">gallons = area &divide; coverage rate &times; coats</text>
      <text x="350" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">then round up to whole cans</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Coverage rate is how many square feet one gallon spreads over at the right thickness.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the coverage calculator works</h2>
    <p class="mt-2 text-slate-600">
      Every liquid coating — paint, primer, stain, sealer — has a coverage rate printed on the label, given in square feet per gallon. That number is how far one gallon spreads while still laying down at the film thickness the manufacturer intends. To find how much you need, divide the area you are covering by that coverage rate; the result is the gallons for a single coat.
    </p>
    <p class="mt-3 text-slate-600">
      Most jobs need more than one coat, so the calculator multiplies the single-coat gallons by the number of coats. Two coats of wall paint roughly doubles the paint required. The exact answer almost never lands on a whole number, so it is rounded up to the next whole gallon, because coatings sell in whole cans and running short mid-wall leaves a visible lap line or a color mismatch from a new batch.
    </p>
    <p class="mt-3 text-slate-600">
      It also helps to separate the coverage rate for a first coat from later coats. Bare drywall, new wood, and unsealed concrete are porous and drink up more product on the first pass, while later coats glide over an already-sealed surface and go further. Manufacturers publish a single coverage figure as a practical average, but professionals often budget slightly more for the first coat and slightly less for subsequent ones when working on new or unfinished substrates.
    </p>
    <p class="mt-3 text-slate-600">
      Coverage rates follow manufacturer norms: interior wall paint spreads about 350 to 400 square feet per gallon, primer and porous surfaces far less, and heavy solid stains or textured surfaces less still. Rough, unsealed, or highly absorbent surfaces soak up more, so pick a rate at the low end of the label range when in doubt. The estimate assumes even application over a sound surface.
    </p>
    <p class="mt-3 text-xs text-slate-400">Coverage-rate ranges reflect typical manufacturer spread-rate labeling for architectural coatings, consistent with ASTM D5146 test methods for coating film properties.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the area</h3>
        <p class="mt-1 text-sm text-slate-600">Total square feet of wall, deck, or floor.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the label rate</h3>
        <p class="mt-1 text-sm text-slate-600">Square feet per gallon for your product.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the coats</h3>
        <p class="mt-1 text-sm text-slate-600">Get whole gallons to buy for the job.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Per coat</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= area &divide; coverage rate</span>. 900 sq ft at 350 sq ft/gal: 900 ÷ 350 = <strong>2.57 gal</strong> per coat.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">All coats</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">&times; coats</span>. Two coats: 2.57 × 2 = <strong>5.14 gal</strong> exact.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Round up</p>
        <p class="mt-1 text-slate-600">
          5.14 → <strong>6 gallons</strong> to buy, leaving a little for touch-ups.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 500 sq ft deck getting 2 coats of solid stain at 200 sq ft/gal.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Per coat:</span> <span class="text-slate-600">500 ÷ 200 = 2.5 gal</span></div>
        <div><span class="font-medium text-slate-700">Two coats:</span> <span class="text-slate-600">2.5 × 2 = 5.0 gal</span></div>
        <div><span class="font-medium text-slate-700">Buy:</span> <span class="text-slate-600"><strong>5 gallons</strong></span></div>
        <div><span class="font-medium text-slate-700">Covers:</span> <span class="text-slate-600">1,000 sq ft of painted area</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the coverage calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🎨</span>
        <h3 class="mt-2 font-semibold text-slate-900">Interior wall paint</h3>
        <p class="mt-1 text-sm text-slate-600">Bedrooms, living rooms, and hallways typically get two coats. Calculating the exact gallons needed avoids buying an extra can you do not need or running short mid-wall.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🛖</span>
        <h3 class="mt-2 font-semibold text-slate-900">Deck and fence stain</h3>
        <p class="mt-1 text-sm text-slate-600">Semi-transparent and solid stains have much lower coverage rates than wall paint, especially on rough-sawn lumber, so this calculator helps avoid underestimating a deck refinishing job.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🛣️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Driveway and concrete sealer</h3>
        <p class="mt-1 text-sm text-slate-600">Sealers spread differently depending on whether the concrete is broom-finished or smooth. Entering the correct coverage rate for the surface texture keeps the estimate accurate.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🖌️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Primer and specialty coatings</h3>
        <p class="mt-1 text-sm text-slate-600">Primers, epoxy floor coatings, and waterproofing membranes often have much lower coverage rates than finish coats. This tool works for any coating as long as you know its labeled spread rate.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A standard bedroom repaint is the most common job this calculator handles. A 400 sq ft wall area at a typical 375 sq ft/gal coverage rate, two coats, needs (400 ÷ 375) × 2 = 2.13 gallons exact — round up to 3 gallons, since paint only sells in whole cans and 2 gallons would leave the second coat short.
    </p>
    <p class="mt-3 text-slate-600">
      Driveway sealing is usually a single-coat job with a lower coverage rate. A 600 sq ft driveway sealed at 300 sq ft/gal for one coat needs exactly 600 ÷ 300 = 2 gallons — a case where the exact math lands on a whole number, so no rounding waste at all.
    </p>
    <p class="mt-3 text-slate-600">
      Deck staining sits in between. A 350 sq ft deck getting two coats of stain at 250 sq ft/gal needs (350 ÷ 250) × 2 = 2.8 gallons exact, rounding up to 3 gallons — the extra 0.2 gallons of headroom is typically enough for touch-ups on rail spindles and stair edges that get missed on the first pass.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"The coverage rate on the can is exact for any surface." <strong class="text-slate-900">It is a best-case number.</strong> Label coverage rates assume a smooth, properly prepared surface applied at the recommended film thickness. Rough, porous, or unprimed surfaces soak up significantly more product, so real-world coverage often runs lower than the label states.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Two coats always use exactly double the paint of one coat." <strong class="text-slate-900">Close, but not exact.</strong> The first coat on bare or porous material typically absorbs more product than the second coat, which goes over an already-sealed surface. Two coats usually uses somewhat less than double the paint of a single coat on new drywall or wood.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/paint-coverage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Paint Coverage Calculator</a>
      <a href="/tools/deck-stain-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Deck Stain Calculator</a>
      <a href="/tools/square-footage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Square Footage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const area = parseFloat(el('area').value);
      const rate = parseFloat(el('rate').value);
      let coats = parseFloat(el('coats').value); if (!(coats > 0)) coats = 1;
      if (!(area > 0 && rate > 0)) { el('results').classList.add('hidden'); return; }

      const perCoat = area / rate;
      const exact = perCoat * coats;
      const buy = Math.ceil(exact);

      el('r-buy').textContent = buy + (buy === 1 ? ' gallon' : ' gallons');
      el('r-note').textContent = coats + ' coat' + (coats > 1 ? 's' : '') + ' at ' + rate + ' sq ft/gal';
      el('r-exact').textContent = exact.toFixed(2) + ' gal';
      el('r-percoat').textContent = perCoat.toFixed(2) + ' gal';
      el('r-total').textContent = (area * coats).toLocaleString() + ' sq ft';
      el('results').classList.remove('hidden');
    }

    ['area', 'rate', 'coats'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
