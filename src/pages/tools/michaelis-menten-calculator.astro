---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Michaelis-Menten Enzyme Kinetics Calculator';
const description = 'Michaelis-Menten enzyme kinetics calculator with a live 3D enzyme-substrate diagram and charts. Solve v = Vmax[S]/(Km+[S]) for reaction velocity, with worked examples and the classic saturation curve.';
const intro = 'Enter substrate concentration, Vmax, and Km to compute enzyme reaction velocity using the Michaelis-Menten equation, the foundational model of enzyme kinetics. Two 3D diagrams compare an enzyme at low and high substrate saturation, and charts trace the classic hyperbolic saturation curve.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is the Michaelis-Menten equation?', a: 'The Michaelis-Menten equation, v = Vmax[S]/(Km+[S]), describes how an enzyme-catalyzed reaction\'s velocity (v) depends on substrate concentration ([S]), the maximum possible velocity (Vmax), and the Michaelis constant (Km).' },
  { q: 'What is Vmax?', a: 'Vmax is the maximum reaction velocity an enzyme can achieve when it is completely saturated with substrate — adding more substrate beyond this point cannot increase the reaction rate further, since every enzyme molecule is already working at full capacity.' },
  { q: 'What is Km, and what does it represent?', a: 'Km (the Michaelis constant) is the substrate concentration at which the reaction velocity equals exactly half of Vmax. A low Km indicates high enzyme-substrate affinity (the enzyme reaches half-max speed at a low substrate concentration); a high Km indicates lower affinity.' },
  { q: 'Why does the reaction rate level off at high substrate concentration?', a: 'At high substrate concentration, essentially all enzyme molecules are already bound to substrate and actively converting it to product — adding more substrate can\'t speed things up further since there\'s no free enzyme left to bind it, producing the characteristic plateau at Vmax.' },
  { q: 'How is Michaelis-Menten kinetics used practically?', a: 'It\'s used to characterize enzyme efficiency, compare how different enzymes or mutations affect catalytic activity, and to understand and predict the effects of inhibitors — many drugs work by altering an enzyme\'s Km or Vmax.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Michaelis-Menten Enzyme Kinetics Calculator',
  description: 'Solve v = Vmax[S]/(Km+[S]) for enzyme reaction velocity from substrate concentration, Vmax, and Km.',
  steps: [
    { name: 'Enter Vmax and Km', text: "Provide the enzyme's maximum velocity and Michaelis constant." },
    { name: 'Enter substrate concentration', text: 'Provide [S], the substrate concentration for this calculation.' },
    { name: 'Read the velocity', text: 'Reaction velocity (v) solves instantly.' },
  ],
};

const formulas = [
  { expr: 'v = Vmax[S] / (Km + [S])', note: 'reaction velocity — Vmax = maximum velocity, Km = Michaelis constant, [S] = substrate concentration' },
  { expr: 'v = Vmax/2 when [S] = Km', note: 'the defining property of Km — half-maximal velocity' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — substrate concentration equal to Km', tone: 'slate',
    given: 'An enzyme has Vmax = 100 μmol/min and Km = 5 mM. Find the velocity when [S] = 5 mM (equal to Km).',
    rows: [
      { label: 'Formula:', value: 'v = Vmax[S] / (Km + [S])' },
      { label: 'Substitute:', value: 'v = 100 × 5 / (5 + 5) = 500 / 10' },
      { label: 'Result:', value: 'v = 50 μmol/min — exactly half of Vmax, confirming [S]=Km gives v=Vmax/2', full: true },
    ],
    note: 'This exact result (v = Vmax/2 when [S] = Km) is the defining mathematical property that gives Km its physical meaning and makes it experimentally measurable.',
  },
  {
    title: 'Worked example 2 — substrate concentration well above Km', tone: 'amber',
    given: 'The same enzyme (Vmax=100 μmol/min, Km=5mM), now at a much higher substrate concentration, [S] = 20 mM.',
    rows: [
      { label: 'Formula:', value: 'v = Vmax[S] / (Km + [S])' },
      { label: 'Substitute:', value: 'v = 100 × 20 / (5 + 20) = 2000 / 25' },
      { label: 'Result:', value: 'v = 80 μmol/min — approaching but not reaching Vmax (100 μmol/min)', full: true },
    ],
    note: 'Even at 4× the Km concentration, velocity has only reached 80% of Vmax — the curve approaches Vmax asymptotically, technically never quite reaching it at any finite substrate concentration.',
  },
];

const comparison = {
  heading: 'Reaction velocity as substrate concentration rises',
  note: 'Velocity rises quickly at low [S], then flattens out as the enzyme approaches saturation — the classic Michaelis-Menten hyperbolic curve.',
  headers: [{ label: '[S] (mM)' }, { label: 'v (% of Vmax)' }],
  rows: [
    ['1 (well below Km)', '16.7%'],
    ['5 (= Km) ★', '50.0%'],
    ['20 (4× Km)', '80.0%'],
    ['100 (20× Km)', '95.2%'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Notice how much substrate is needed just to go from 80% to 95% of Vmax — the curve saturates slowly at high concentrations, a hallmark of Michaelis-Menten kinetics.',
};

const realWorld = [
  { emoji: '💊', title: 'Drug development and enzyme inhibitor design', body: 'Understanding how a drug changes an enzyme\'s Km or Vmax is central to characterizing how competitive, non-competitive, or uncompetitive inhibitors work — foundational knowledge in pharmacology.' },
  { emoji: '🧬', title: 'Diagnosing metabolic enzyme deficiencies', body: 'Clinical biochemists measure patient enzyme kinetics to diagnose metabolic disorders where a mutated enzyme shows an abnormal Km or Vmax, affecting how efficiently it processes its substrate.' },
  { emoji: '🏭', title: 'Industrial enzyme and biocatalysis optimization', body: 'Biotechnology companies use Michaelis-Menten parameters to select and engineer enzymes for industrial processes, optimizing substrate concentrations for maximum production efficiency.' },
  { emoji: '🔬', title: 'Basic enzymology research', body: "Comparing Km and Vmax values between related enzymes (or mutant variants of the same enzyme) is one of the most fundamental techniques biochemists use to characterize how a protein's structure relates to its catalytic function." },
];

const misconceptions = [
  { claim: '"Adding more substrate always increases the reaction rate proportionally."', truth: 'This is only true at very low substrate concentrations (well below Km) — as [S] approaches and exceeds Km, the rate increase slows dramatically and eventually plateaus near Vmax, since the enzyme becomes saturated.' },
  { claim: '"A low Km means an enzyme works slowly."', truth: 'Km measures substrate affinity (how little substrate is needed to reach half-maximal speed), not overall speed — a low-Km enzyme can actually reach its (possibly very high) Vmax with less substrate needed, which is generally a sign of high efficiency, not slowness.' },
  { claim: '"Vmax is a fixed property of the substrate, not the enzyme."', truth: "Vmax depends on the enzyme's own catalytic turnover rate and how much enzyme is present in the reaction — it is a property of the enzyme (and its concentration), not an intrinsic property of the substrate molecule itself." },
  { claim: '"The reaction velocity can exceed Vmax if you add enough substrate."', truth: "Vmax is a true mathematical asymptote — the Michaelis-Menten equation guarantees velocity approaches but never exceeds Vmax, no matter how much substrate is added, since Vmax represents every enzyme molecule already working at its maximum turnover rate." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 6, "Metabolism" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/6-4-enzymes" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Chapter 3, Proteins (Enzyme Kinetics).' },
  { html: '<strong>Nelson &amp; Cox, <em>Lehninger Principles of Biochemistry</em></strong> — Chapter 6, Enzymes.' },
];
const sourcesNote = 'v = Vmax[S]/(Km+[S]). Assumes steady-state single-substrate enzyme kinetics (the classic Michaelis-Menten model). Results are rounded for display.';

const howToUse = [
  { title: 'Enter Vmax and Km', body: 'Provide the maximum velocity and Michaelis constant for your enzyme.' },
  { title: 'Enter substrate concentration', body: 'Provide [S] to calculate velocity at that specific concentration.' },
  { title: 'Read the velocity', body: 'v solves instantly, showing where the reaction sits on the saturation curve.' },
];

const related = [
  { href: '/tools/reaction-rate-calculator', emoji: '⏳', title: 'Reaction Rate Calculator', desc: 'rate = |ΔX| / (coefficient × Δt) — reactant or product.' },
  { href: '/tools/arrhenius-equation-calculator', emoji: '🏔️', title: 'Arrhenius Equation Calculator', desc: 'k = Ae^(-Ea/RT), or find Ea from two (T,k) points.' },
  { href: '/tools/protein-molecular-weight-calculator', emoji: '🧬', title: 'Protein Molecular Weight Calculator', desc: 'Sum amino acid residue masses for a protein sequence.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="an enzyme can only work as fast as it can bind, convert, and release substrate molecules one at a time, so once every enzyme molecule is continuously occupied with substrate, adding more substrate does nothing to speed the reaction further — the reaction rate simply plateaus at that saturation ceiling."
  howIntro="At low substrate concentration, most enzyme molecules are free and waiting, so adding more substrate directly increases how often binding events happen, and reaction velocity rises nearly proportionally with [S]. As [S] grows large, however, more and more enzyme becomes continuously occupied, so each additional bit of substrate has less and less free enzyme available to bind — velocity rises more and more slowly, asymptotically approaching Vmax. Km, the substrate concentration giving exactly half of Vmax, serves as a convenient reference point marking roughly where a given enzyme transitions from the steep, nearly-linear region of the curve into the flattening, saturating region."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Michaelis-Menten kinetics actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Vmax (μmol/min)</span>
        <input id="vmax" type="number" step="any" value="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Km (mM)</span>
        <input id="km" type="number" step="any" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Substrate concentration [S] (mM)</span>
        <input id="s" type="number" step="any" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Reaction velocity (v)</div><div id="r-v" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">% of Vmax</div><div id="r-pct" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="mm-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Low vs high substrate saturation</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-lowsat" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Low substrate concentration</h3>
          <p class="mt-1 text-sm text-slate-600">Most enzyme molecules (indigo) sit unoccupied, waiting for a scarce substrate (amber) — plenty of room to speed up as [S] rises.</p>
        </div>
        <div>
          <div id="diag-highsat" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. High substrate concentration (near saturation)</h3>
          <p class="mt-1 text-sm text-slate-600">Nearly every enzyme molecule (indigo) is occupied with substrate (amber) — adding more substrate barely speeds things up further.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Michaelis-Menten graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">The classic hyperbolic saturation curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-curve"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Lineweaver-Burk double-reciprocal plot</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-lb"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function update() {
        el('mm-err').textContent = '';
        el('r-v').textContent = '—'; el('r-pct').textContent = '—';
        const vmax = parseFloat(el('vmax').value), km = parseFloat(el('km').value), s = parseFloat(el('s').value);
        if (isNaN(vmax) || isNaN(km) || isNaN(s)) return;
        if (vmax <= 0 || km <= 0 || s < 0) { el('mm-err').textContent = 'Vmax and Km must be positive; [S] cannot be negative.'; return; }
        const v = (vmax * s) / (km + s);
        el('r-v').textContent = fmt(v) + ' μmol/min';
        el('r-pct').textContent = fmt((v / vmax) * 100) + '%';
      }
      ['vmax', 'km', 's'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsS = [], dataV = [];
        for (let s = 0; s <= 50; s += 2) { labelsS.push(s); dataV.push(+((100 * s) / (5 + s)).toFixed(2)); }
        charts.curve = new Chart(el('chart-curve'), {
          type: 'line',
          data: { labels: labelsS, datasets: [{ label: 'v (μmol/min)', data: dataV, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.35, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: '[S] (mM)' } }, y: { title: { display: true, text: 'v (μmol/min)' }, max: 105 } }, plugins: { legend: { display: false } } }),
        });
        const labelsInvS = [], dataInvV = [];
        for (let s = 1; s <= 20; s += 1) { const v = (100 * s) / (5 + s); labelsInvS.push((1 / s).toFixed(2)); dataInvV.push(+(1 / v).toFixed(4)); }
        charts.lb = new Chart(el('chart-lb'), {
          type: 'line',
          data: { labels: labelsInvS, datasets: [{ label: '1/v', data: dataInvV, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: '1/[S]' } }, y: { title: { display: true, text: '1/v' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function enzymeScene(container, occupiedFraction) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const total = 20;
        const occupied = Math.round(total * occupiedFraction);
        for (let i = 0; i < total; i++) {
          const phi = Math.acos(1 - (2 * (i + 0.5)) / total);
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const r = 2;
          const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
          const enzyme = new THREE.Mesh(new THREE.SphereGeometry(0.32, 14, 12), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.5 }));
          enzyme.position.set(x, y, z);
          s.scene.add(enzyme);
          if (i < occupied) {
            const substrate = new THREE.Mesh(new THREE.SphereGeometry(0.14, 10, 8), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
            substrate.position.set(x * 1.15, y * 1.15, z * 1.15);
            s.scene.add(substrate);
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLow = null, diagHigh = null;
      function initDiagLow() { const c = el('diag-lowsat'); if (!c) throw new Error('no container'); diagLow = enzymeScene(c, 0.15); }
      function initDiagHigh() { const c = el('diag-highsat'); if (!c) throw new Error('no container'); diagHigh = enzymeScene(c, 0.9); }

      function boot() {
        try { update(); } catch (e) { console.error('[michaelis-menten] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[michaelis-menten] charts failed', e); }
        if (window.THREE) {
          try { initDiagLow(); } catch (e) { console.error('[michaelis-menten] low diagram failed', e); }
          try { initDiagHigh(); } catch (e) { console.error('[michaelis-menten] high diagram failed', e); }
        }
        mountResize([diagLow, diagHigh]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
