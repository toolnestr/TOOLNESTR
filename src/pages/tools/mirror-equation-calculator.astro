---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Mirror Equation Calculator';
const description = "Mirror equation calculator. Solve 1/f = 1/do + 1/di for image distance and magnification in concave and convex mirrors, with worked examples.";
const intro = 'Solve 1/f = 1/do + 1/di for the image distance formed by a curved mirror, plus magnification m = −di/do. Two 3D diagrams compare a concave mirror (real, inverted image) to a convex mirror (virtual, upright image), and charts show how image distance and magnification change as the object moves.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the mirror equation?', a: 'The mirror equation is 1/f = 1/do + 1/di, where f is the focal length, do is the object distance from the mirror, and di is the image distance. It applies to both concave and convex mirrors using a sign convention.' },
  { q: 'What is the sign convention for mirrors?', a: 'Concave (converging) mirrors have a positive focal length; convex (diverging) mirrors have a negative focal length. A positive image distance (di) means a real image in front of the mirror; a negative di means a virtual image behind the mirror.' },
  { q: 'How is magnification calculated?', a: 'Magnification is m = −di/do. A negative m means the image is inverted; a positive m means upright. |m| > 1 means enlarged, |m| < 1 means reduced.' },
  { q: 'Why do convex mirrors always produce a smaller, upright image?', a: 'A convex mirror has a negative focal length, which forces the mirror equation to always produce a negative (virtual) image distance for any positive object distance — the image is always virtual, upright, and reduced, which is exactly why convex mirrors are used for wide-view safety mirrors.' },
  { q: 'What happens when the object is exactly at the focal point of a concave mirror?', a: 'When do = f, the mirror equation gives 1/di = 1/f − 1/f = 0, so di is infinite — the reflected rays emerge perfectly parallel and never converge to form an image at any finite distance.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Mirror Equation Calculator',
  description: 'Solve 1/f = 1/do + 1/di for image distance and magnification given a mirror\'s focal length and object distance.',
  steps: [
    { name: 'Enter the focal length', text: 'Use a positive value for a concave mirror or a negative value for a convex mirror.' },
    { name: 'Enter the object distance', text: 'Distance from the object to the mirror\'s surface, always positive for a real object.' },
    { name: 'Read the image distance and magnification', text: 'A positive image distance means real (in front of the mirror); negative means virtual (behind it).' },
  ],
};

const formulas = [
  { expr: '1/f = 1/do + 1/di', note: 'mirror equation — f = focal length, do = object distance, di = image distance' },
  { expr: 'm = −di/do', note: 'magnification — negative means inverted, positive means upright' },
  { expr: 'hi = m × ho', note: 'image height from object height and magnification' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — concave mirror, object at the center of curvature', tone: 'slate',
    given: 'A concave mirror has f = 15 cm. An object sits do = 30 cm away (exactly at the center of curvature, R = 2f).',
    rows: [
      { label: 'Formula:', value: '1/di = 1/f − 1/do' },
      { label: 'Substitute:', value: '1/di = 1/15 − 1/30 = 1/30' },
      { label: 'Image distance:', value: 'di = 30 cm (real image, same distance as the object)' },
      { label: 'Magnification:', value: 'm = −30/30 = −1.00 (inverted, same size)', full: true },
    ],
    note: 'This is the special case where object and image distances are equal — it only happens when the object sits exactly at the center of curvature.',
  },
  {
    title: 'Worked example 2 — convex mirror (a car\'s passenger-side mirror)', tone: 'amber',
    given: 'A convex mirror has f = −20 cm (negative, since it diverges light). An object sits do = 15 cm away.',
    rows: [
      { label: 'Formula:', value: '1/di = 1/f − 1/do' },
      { label: 'Substitute:', value: '1/di = −1/20 − 1/15 = −7/60' },
      { label: 'Image distance:', value: 'di ≈ −8.57 cm (negative → virtual image, behind the mirror)' },
      { label: 'Magnification:', value: 'm = −(−8.57)/15 ≈ +0.57 (upright, reduced to 57% size)', full: true },
    ],
    note: 'This is why objects in a convex mirror look smaller and closer than they appear — and why these mirrors carry the familiar warning "objects in mirror are closer than they appear."',
  },
];

const comparison = {
  heading: 'Image distance vs. object distance (concave mirror, f = 15 cm)',
  note: 'As the object moves closer to the focal point, the image distance grows dramatically — and eventually flips to virtual once the object moves inside f.',
  headers: [{ label: 'Object distance (do)' }, { label: 'Image distance (di)' }, { label: 'Magnification' }, { label: 'Image type' }],
  rows: [
    ['45 cm (beyond 2f)', '22.5 cm', '−0.50', 'Real, inverted, reduced'],
    ['30 cm (at 2f) ★', '30 cm', '−1.00', 'Real, inverted, same size'],
    ['20 cm (between f and 2f)', '60 cm', '−3.00', 'Real, inverted, enlarged'],
    ['10 cm (inside f)', '−30 cm', '+3.00', 'Virtual, upright, enlarged'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Crossing the focal point flips the image from real to virtual — this is the single most important qualitative shift to remember for concave mirrors.',
};

const realWorld = [
  { emoji: '🚗', title: 'Vehicle safety mirrors', body: 'Convex mirrors are used for passenger-side mirrors and store security mirrors because their wide field of view (from the always-reduced image) lets a small mirror show a much larger area than a flat mirror could.' },
  { emoji: '🔭', title: 'Reflecting telescopes', body: 'Large concave mirrors gather and focus starlight far more effectively than lenses of comparable size, since mirrors don\'t suffer from chromatic aberration — this is the working principle behind every major research telescope.' },
  { emoji: '💇', title: 'Makeup and shaving mirrors', body: 'A concave mirror held closer than its focal length produces the enlarged, upright image used in magnifying vanity mirrors — move it past the focal point and the image flips and inverts.' },
  { emoji: '🔦', title: 'Headlights and spotlights', body: 'Concave mirrors placed at the focal point of a light source reflect the light into a parallel beam, which is exactly why car headlights and flashlight reflectors are shaped as parabolic (near-spherical) concave mirrors.' },
];

const misconceptions = [
  { claim: '"Concave mirrors always produce a magnified image."', truth: "Concave mirrors only magnify when the object is closer than the center of curvature (do < 2f). Beyond that distance, the image is real but smaller than the object — magnification depends entirely on where the object sits relative to f and 2f." },
  { claim: '"A virtual image means no image actually forms."', truth: "A virtual image is a perfectly real, viewable image — you can see it by looking into the mirror. It's called virtual only because light rays don't actually converge there; they only appear to converge when traced backward, so the image can't be projected onto a screen the way a real image can." },
  { claim: '"Convex mirrors can sometimes produce a real, inverted image."', truth: "For any real object, a convex mirror's negative focal length mathematically forces di to always be negative — the image is always virtual, upright, and reduced. This never changes regardless of how close or far the object is." },
  { claim: '"The mirror equation only works for mirrors, not lenses."', truth: 'The identical equation 1/f = 1/do + 1/di (with a different sign convention) also describes thin lenses — the underlying geometric optics is the same whether light is being reflected or refracted to form an image.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 3</em></strong> — Chapter 2, "Geometric Optics and Image Formation" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-3/pages/2-3-spherical-mirrors" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Hecht, <em>Optics</em></strong> — Spherical mirror imaging chapter.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Geometric Optics.' },
];
const sourcesNote = '1/f = 1/do + 1/di, m = −di/do. Sign convention: concave f > 0, convex f < 0; real image di > 0, virtual image di < 0. Results are rounded for display.';

const howToUse = [
  { title: 'Enter focal length with correct sign', body: 'Positive for concave (converging), negative for convex (diverging) mirrors.' },
  { title: 'Enter object distance', body: 'Always a positive value for a real object placed in front of the mirror.' },
  { title: 'Read image distance and magnification', body: 'Positive di = real image; negative di = virtual image. The sign of m tells you upright vs. inverted.' },
];

const related = [
  { href: '/tools/wavelength-frequency-calculator', emoji: '〰️', title: 'Wavelength Calculator', desc: 'v = fλ — solve wave speed, frequency, or wavelength.' },
  { href: '/tools/frequency-calculator', emoji: '📻', title: 'Frequency Calculator', desc: 'f = 1/T — period, frequency, and angular frequency.' },
  { href: '/tools/sound-intensity-calculator', emoji: '🔊', title: 'Sound Intensity Calculator', desc: 'β = 10log₁₀(I/I₀) — intensity and decibels.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a curved mirror bends reflected light toward (concave) or away from (convex) a single focal point, and exactly where the object sits relative to that focal point determines whether the resulting image is real or virtual, upright or inverted, and bigger or smaller than the original."
  howIntro="Every spherical mirror has a focal length that describes how strongly it bends light — concave mirrors converge light to a real focal point in front of the mirror (positive f), while convex mirrors spread light apart so it only appears to come from a focal point behind the mirror (negative f). The mirror equation 1/f = 1/do + 1/di connects that focal length to any specific object distance, solving exactly where the image forms. The sign of the resulting image distance tells you everything: positive means the image is real and can be projected onto a screen; negative means it's virtual and only visible by looking directly into the mirror."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the mirror equation actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Focal length, f (cm) — positive concave, negative convex</span>
        <input id="fl" type="number" step="any" value="15" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Object distance, do (cm)</span>
        <input id="do" type="number" step="any" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <label class="mt-4 block max-w-xs"><span class="text-sm font-medium text-slate-700">Object height, ho (cm) — optional</span>
      <input id="ho" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Image distance (di)</div><div id="r-di" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Magnification (m)</div><div id="r-m" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Image type</div><div id="r-type" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="mirror-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Concave vs. convex mirrors</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-concave" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Concave mirror</h3>
          <p class="mt-1 text-sm text-slate-600">Curves inward, converging reflected light to a real focal point in front of the mirror.</p>
        </div>
        <div>
          <div id="diag-convex" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Convex mirror</h3>
          <p class="mt-1 text-sm text-slate-600">Curves outward, spreading reflected light so it only appears to come from behind the mirror.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Mirror equation graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Image distance vs. object distance (concave, f=15cm)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-di"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Magnification vs. object distance (concave, f=15cm)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-m"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('mirror-err').textContent = '';
        el('r-di').textContent = '—'; el('r-m').textContent = '—'; el('r-type').textContent = '—';
        const f = parseFloat(el('fl').value), doV = parseFloat(el('do').value);
        if (isNaN(f) || isNaN(doV)) return;
        if (f === 0 || doV <= 0) { el('mirror-err').textContent = 'Object distance must be positive and focal length cannot be zero.'; return; }
        const invDi = 1 / f - 1 / doV;
        if (invDi === 0) { el('r-di').textContent = 'Infinite'; el('r-type').textContent = 'Parallel rays (do = f)'; return; }
        const di = 1 / invDi;
        const m = -di / doV;
        el('r-di').textContent = fmt(di) + ' cm';
        el('r-m').textContent = fmt(m) + '×';
        const real = di > 0;
        const upright = m > 0;
        const size = Math.abs(m) > 1 ? 'enlarged' : Math.abs(m) < 1 ? 'reduced' : 'same size';
        el('r-type').textContent = (real ? 'Real, ' : 'Virtual, ') + (upright ? 'upright, ' : 'inverted, ') + size;
      }
      ['fl', 'do', 'ho'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const f = 15;
        const labels = [], diData = [], mData = [];
        for (let d = 5; d <= 60; d += 2.5) {
          labels.push(d);
          const invDi = 1 / f - 1 / d;
          const di = invDi !== 0 ? 1 / invDi : null;
          diData.push(di !== null ? +Math.min(Math.max(di, -80), 80).toFixed(2) : null);
          mData.push(di !== null ? +Math.min(Math.max(-di / d, -8), 8).toFixed(2) : null);
        }
        new Chart(el('chart-di'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'di (cm)', data: diData, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.2, pointRadius: 0, spanGaps: false }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Object distance do (cm)' } }, y: { title: { display: true, text: 'Image distance di (cm)' } } }, plugins: { legend: { display: false } } }),
        });
        new Chart(el('chart-m'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'm', data: mData, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.2, pointRadius: 0, spanGaps: false }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Object distance do (cm)' } }, y: { title: { display: true, text: 'Magnification m' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function mirrorScene(container, concave) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const geo = new THREE.SphereGeometry(3, 32, 32, 0, Math.PI * 0.55, Math.PI * 0.25, Math.PI * 0.5);
        const mesh = new THREE.Mesh(geo, new THREE.MeshStandardMaterial({ color: 0x94a3b8, side: THREE.DoubleSide, metalness: 0.3, roughness: 0.3 }));
        mesh.rotation.z = concave ? Math.PI / 2 : -Math.PI / 2;
        mesh.position.x = concave ? 1 : -1;
        s.scene.add(mesh);
        for (let i = -2; i <= 2; i++) {
          const y = i * 0.6;
          const pts = concave
            ? [new THREE.Vector3(-3, y, 0), new THREE.Vector3(0, y, 0), new THREE.Vector3(2, 0, 0)]
            : [new THREE.Vector3(-3, y, 0), new THREE.Vector3(0, y, 0), new THREE.Vector3(3, y * 1.8, 0)];
          const g = new THREE.BufferGeometry().setFromPoints(pts);
          s.scene.add(new THREE.Line(g, new THREE.LineBasicMaterial({ color: 0xf59e0b })));
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagConcave = null, diagConvex = null;
      function initDiagConcave() { const c = el('diag-concave'); if (!c) throw new Error('no container'); diagConcave = mirrorScene(c, true); }
      function initDiagConvex() { const c = el('diag-convex'); if (!c) throw new Error('no container'); diagConvex = mirrorScene(c, false); }

      function boot() {
        try { update(); } catch (e) { console.error('[mirror-equation] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[mirror-equation] charts failed', e); }
        if (window.THREE) {
          try { initDiagConcave(); } catch (e) { console.error('[mirror-equation] concave diagram failed', e); }
          try { initDiagConvex(); } catch (e) { console.error('[mirror-equation] convex diagram failed', e); }
        }
        mountResize([diagConcave, diagConvex]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
