          var sig = await crypto.subtle.sign('HMAC', cryptoKey, msgData);
          var arr = Array.from(new Uint8Array(sig));
          resultHex = arr.map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
        }
        output.value = fmt === 'base64' ? hexToBase64(resultHex) : resultHex;
        show('HMAC generated successfully', true);
      } catch (e) {
        show('Error generating HMAC: ' + e.message, false);
      }
    }

    el('generate-btn').addEventListener('click', generate);
    el('clear-btn').addEventListener('click', function() { message.value = ''; key.value = ''; output.value = ''; status.classList.add('hidden'); message.focus(); });
    el('copy-btn').addEventListener('click', async function() {
      if (!output.value) return;
      try {
        await navigator.clipboard.writeText(output.value);
        var b = el('copy-btn'); var o = b.textContent; b.textContent = 'Copied!'; setTimeout(function() { b.textContent = o; }, 1200);
      } catch (e) {}
    });
  </script>
</ToolLayout>
