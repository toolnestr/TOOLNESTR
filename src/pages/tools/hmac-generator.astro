    function hmacMD5(key, msg) {
      var blockSize = 64;
      if (key.length > blockSize) key = MD5(key);
      while (key.length < blockSize) key += String.fromCharCode(0);
      var ipad = '', opad = '';
      for (var i = 0; i < blockSize; i++) {
        ipad += String.fromCharCode(key.charCodeAt(i) ^ 0x36);
        opad += String.fromCharCode(key.charCodeAt(i) ^ 0x5C);
      }
      return MD5(opad + MD5(ipad + msg));
    }

    var el = function(id) { return document.getElementById(id); };
    var message = el('message'), key = el('key'), output = el('output'), status = el('status');
    var algorithm = el('algorithm'), format = el('format');

    function show(msg, ok) {
      status.textContent = msg;
      status.className = 'mt-3 rounded-lg px-3 py-2 text-sm font-medium ' + (ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700');
      status.classList.remove('hidden');
    }

    function hexToBase64(h) {
      var bins = '';
      for (var i = 0; i < h.length; i += 2) bins += String.fromCharCode(parseInt(h.substr(i, 2), 16));
      return btoa(bins);
    }

    async function generate() {
      var msg = message.value, k = key.value;
      if (!msg || !k) { output.value = ''; show('Please enter both a message and a secret key.', false); return; }
      var algo = algorithm.value, fmt = format.value;
      try {
        var resultHex;
        if (algo === 'MD5') {
          resultHex = hmacMD5(k, msg);
        } else {
          var enc = new TextEncoder();
          var keyData = enc.encode(k);
          var msgData = enc.encode(msg);
