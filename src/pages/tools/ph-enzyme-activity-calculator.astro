---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'pH-Enzyme Activity Simulator';
const description = 'pH-enzyme activity simulator with a live 3D enzyme shape diagram and charts. Model relative enzyme activity across a range of pH using a bell-shaped curve around the optimal pH, with worked examples for pepsin and trypsin.';
const intro = "Model an enzyme's relative activity across a range of pH values using a bell-shaped curve centered on its optimal pH — activity peaks exactly at the optimum and falls off symmetrically as pH moves away from it. Two 3D diagrams compare a properly-folded enzyme at its optimal pH to a denatured one far outside its range, and charts compare activity curves for different enzymes side by side.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'Why does enzyme activity depend on pH?', a: "An enzyme's active site relies on specific amino acid side chains holding a precise electrical charge and shape to bind its substrate — pH changes the protonation state of those side chains, which can distort the active site and reduce or eliminate activity outside the enzyme's optimal pH range." },
  { q: "Why do different enzymes have such different optimal pH values?", a: "Each enzyme evolved to function in its specific working environment — pepsin operates in the strongly acidic stomach (optimal pH ~2), while trypsin works in the more basic small intestine (optimal pH ~8), each with active site chemistry tuned to its own environment." },
  { q: 'What happens to an enzyme far outside its optimal pH range?', a: 'Activity drops sharply, and at extreme pH values the enzyme can denature entirely — its 3D structure unfolds as normal charge interactions holding it together break down, usually causing a permanent, irreversible loss of function.' },
  { q: 'Is the bell-curve model exact for every real enzyme?', a: "It's a useful simplification — some enzymes have a fairly symmetric bell-shaped pH-activity curve, but many real enzymes show asymmetric curves, plateaus, or multiple activity peaks reflecting more complex active-site chemistry." },
  { q: 'Can an enzyme recover activity after being exposed to the wrong pH?', a: 'It depends on severity — mild, brief pH stress often allows the enzyme to refold and regain activity once returned to its optimal range, but denaturation from extreme pH is frequently permanent, much like how cooking an egg cannot be undone.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the pH-Enzyme Activity Simulator',
  description: "Model an enzyme's relative activity across a range of pH values around its optimum.",
  steps: [
    { name: 'Enter the optimal pH', text: "The pH at which the enzyme shows its maximum (100%) activity." },
    { name: 'Enter the curve width', text: 'How sharply activity falls off as pH moves away from the optimum — a smaller width means a narrower, more sensitive enzyme.' },
    { name: 'Read activity at any pH', text: 'Relative activity at your chosen pH calculates instantly.' },
  ],
};

const formulas = [
  { expr: 'Activity(pH) = 100 × exp(−(pH − pH_opt)² / (2 × width²))', note: 'a bell-shaped (Gaussian-like) model of relative enzyme activity vs. pH' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — activity away from the optimum', tone: 'slate',
    given: 'An enzyme with optimal pH = 7 and curve width = 1.5, evaluated at pH = 5.',
    rows: [
      { label: 'Formula:', value: 'Activity = 100 × exp(−(pH−pH_opt)²/(2×width²))' },
      { label: 'Substitute:', value: 'Activity = 100 × exp(−(5−7)²/(2×1.5²)) = 100 × exp(−4/4.5)' },
      { label: 'Result:', value: 'Activity ≈ 41.1% of maximum', full: true },
    ],
    note: 'Just 2 pH units away from the optimum, this enzyme has already lost more than half its activity — illustrating how sensitive enzyme function can be to pH.',
  },
  {
    title: 'Worked example 2 — why pepsin and trypsin work in different organs', tone: 'amber',
    given: 'Pepsin (optimal pH 2, width 1) and trypsin (optimal pH 8, width 1.5), both evaluated at the stomach\'s pH of 2.',
    rows: [
      { label: 'Pepsin at pH 2:', value: 'Activity = 100% (exactly at its optimum)' },
      { label: 'Trypsin at pH 2:', value: 'Activity = 100 × exp(−(2−8)²/(2×1.5²)) = 100 × exp(−8) ≈ 0.03%' },
      { label: 'Interpretation:', value: 'trypsin is essentially completely inactive in the stomach\'s acidic environment', full: true },
    ],
    note: 'This is exactly why the digestive system uses different enzymes in different organs — trypsin is instead secreted into the small intestine, where a much more basic pH matches its own optimum.',
  },
];

const comparison = {
  heading: 'Optimal pH for common digestive and cellular enzymes',
  note: 'Each enzyme is tuned to the pH of its own working environment.',
  headers: [{ label: 'Enzyme' }, { label: 'Location' }, { label: 'Optimal pH' }],
  rows: [
    ['Pepsin ★', 'Stomach', '~2'],
    ['Salivary amylase', 'Mouth', '~6.8'],
    ['Trypsin', 'Small intestine', '~8'],
    ['Lysozyme', 'Tears, saliva', '~9'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 2). Pepsin\'s extremely acidic optimum is a striking adaptation to the stomach\'s harsh, acid-rich environment.',
};

const realWorld = [
  { emoji: '🍽️', title: 'Digestive physiology', body: "The human digestive system relies on a sequence of enzymes each tuned to the changing pH environment food passes through — from the mouth, to the strongly acidic stomach, to the more basic small intestine." },
  { emoji: '💊', title: 'Enzyme-based drug and diagnostic design', body: 'Pharmaceutical and diagnostic enzyme products must be formulated to remain active at the pH of their intended use — an enzyme-based test strip or oral drug must survive the pH conditions it will actually encounter.' },
  { emoji: '🏭', title: 'Industrial enzyme applications', body: 'Detergents, food processing, and biofuel production all rely on enzymes selected or engineered for the specific pH conditions of their industrial process.' },
  { emoji: '🧫', title: 'Cell biology and metabolic research', body: "Understanding an enzyme's pH-activity profile helps researchers interpret experimental results and choose appropriate buffer conditions for studying that enzyme in the lab." },
];

const misconceptions = [
  { claim: '"An enzyme works equally well at any pH, as long as the substrate is present."', truth: "Enzyme activity is highly pH-dependent because pH affects the protonation state and shape of the active site — most enzymes have a fairly narrow pH range where they function well, dropping off sharply outside it." },
  { claim: '"A neutral pH (7) is always the best pH for enzyme activity."', truth: "Optimal pH depends entirely on the enzyme's normal working environment — pepsin's optimum near pH 2 and trypsin's optimum near pH 8 are both textbook examples of enzymes that work best far from neutral pH." },
  { claim: '"Any pH change temporarily reduces activity, but activity always fully recovers when pH returns to normal."', truth: "Mild pH shifts are often reversible, but extreme pH exposure can permanently denature an enzyme's 3D structure, causing irreversible loss of function even after the pH is corrected." },
  { claim: '"All enzymes have the exact same shaped pH-activity curve, just shifted to a different optimal pH."', truth: 'While a symmetric bell curve is a common simplified teaching model, real enzymes vary considerably in how sharply their activity falls off around the optimum, and some show asymmetric curves or broader plateaus rather than a perfectly symmetric peak.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 6, "Metabolism" (free, peer-reviewed, enzyme function and regulation). <a href="https://openstax.org/books/biology-2e/pages/6-4-enzymes" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Lehninger, <em>Principles of Biochemistry</em></strong> — Enzyme kinetics and pH-dependence chapter.' },
  { html: '<strong>Berg, Tymoczko &amp; Stryer, <em>Biochemistry</em></strong> — Enzyme mechanism and environmental factors chapter.' },
];
const sourcesNote = 'Activity(pH)=100×exp(−(pH−pH_opt)²/(2×width²)). A simplified symmetric bell-curve model — real enzyme pH-activity profiles can be asymmetric. Results are rounded for display.';

const howToUse = [
  { title: 'Enter optimal pH', body: 'The pH at which the enzyme shows maximum (100%) activity.' },
  { title: 'Enter curve width', body: 'How sharply activity falls off away from the optimum.' },
  { title: 'Enter a test pH', body: 'Relative activity at that pH calculates instantly.' },
];

const related = [
  { href: '/tools/michaelis-menten-calculator', emoji: '🔑', title: 'Michaelis-Menten Enzyme Kinetics Calculator', desc: 'v = Vmax[S]/(Km+[S]) — enzyme reaction velocity.' },
  { href: '/tools/ph-calculator', emoji: '🌈', title: 'pH Calculator', desc: 'pH from concentration or reverse.' },
  { href: '/tools/amino-acid-sequence-analyzer', emoji: '🧬', title: 'Amino Acid Sequence Analyzer', desc: 'Composition, hydrophobicity, and charge from a sequence.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="an enzyme's active site is only the right shape and charge to grip its substrate within a narrow pH window, and moving away from that window in either direction — too acidic or too basic — costs it activity in exactly the same way, which is why enzyme pH-activity curves come out symmetric and bell-shaped."
  howIntro="An enzyme's active site depends on specific amino acid side chains holding precise electrical charges to correctly bind and process its substrate. Shifting pH away from the enzyme's optimum changes how protonated those side chains are, gradually distorting the active site's shape and charge distribution in either direction — whether pH moves higher or lower. This symmetric falloff on both sides of a single peak is exactly what a bell-shaped curve captures, and modeling it lets you predict how much activity an enzyme retains at any pH, and directly compare how differently-tuned enzymes (like stomach pepsin and intestinal trypsin) each perform outside their own home environment."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where pH-dependent enzyme activity actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Optimal pH</span>
        <input id="phopt" type="number" step="any" value="7" min="0" max="14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Curve width</span>
        <input id="width" type="number" step="any" value="1.5" min="0.1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Test pH</span>
        <input id="phtest" type="number" step="any" value="5" min="0" max="14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Relative activity at test pH</div><div id="r-activity" class="mt-1 text-2xl font-bold">—</div></div>
    <p id="phe-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Optimal pH vs. denaturing pH</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-folded" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. At optimal pH</h3>
          <p class="mt-1 text-sm text-slate-600">The enzyme holds its precise, functional 3D shape.</p>
        </div>
        <div>
          <div id="diag-denatured" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Far outside optimal pH</h3>
          <p class="mt-1 text-sm text-slate-600">The enzyme's structure loosens and unfolds, losing function.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">pH-activity charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Your enzyme's activity curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-curve"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pepsin vs. trypsin activity curves</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-compare"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};

      function activity(pH, pHopt, width) {
        return 100 * Math.exp(-Math.pow(pH - pHopt, 2) / (2 * width * width));
      }

      // ---- calculator ----
      function update() {
        el('phe-err').textContent = '';
        el('r-activity').textContent = '—';
        const pHopt = parseFloat(el('phopt').value), width = parseFloat(el('width').value), pHtest = parseFloat(el('phtest').value);
        if (isNaN(pHopt) || isNaN(width) || isNaN(pHtest)) return;
        if (width <= 0 || pHopt < 0 || pHopt > 14 || pHtest < 0 || pHtest > 14) { el('phe-err').textContent = 'pH values must be between 0 and 14; width must be positive.'; return; }
        const act = activity(pHtest, pHopt, width);
        el('r-activity').textContent = act.toFixed(1) + '%';
        updateCurve(pHopt, width);
      }
      ['phopt', 'width', 'phtest'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.curve = new Chart(el('chart-curve'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Relative activity (%)', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'pH' } }, y: { min: 0, max: 100, title: { display: true, text: 'Relative activity (%)' } } }, plugins: { legend: { display: false } } }),
        });
        const pHLabels = [];
        for (let pH = 0; pH <= 14; pH += 0.5) pHLabels.push(pH.toFixed(1));
        charts.compare = new Chart(el('chart-compare'), {
          type: 'line',
          data: {
            labels: pHLabels,
            datasets: [
              { label: 'Pepsin (opt=2)', data: pHLabels.map((pH) => activity(parseFloat(pH), 2, 1)), borderColor: '#ef4444', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
              { label: 'Trypsin (opt=8)', data: pHLabels.map((pH) => activity(parseFloat(pH), 8, 1.5)), borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
            ],
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'pH' } }, y: { min: 0, max: 100, title: { display: true, text: 'Relative activity (%)' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }
      function updateCurve(pHopt, width) {
        if (!charts.curve) return;
        const labels = [], data = [];
        for (let pH = 0; pH <= 14; pH += 0.5) { labels.push(pH.toFixed(1)); data.push(+activity(pH, pHopt, width).toFixed(2)); }
        charts.curve.data.labels = labels;
        charts.curve.data.datasets[0].data = data;
        charts.curve.update('none');
      }

      function enzymeScene(container, folded) {
        const s = makeScene(container, 6, new THREE.Vector3(0, 0, 0), OPTS);
        const points = [];
        const n = 24;
        for (let i = 0; i < n; i++) {
          const t = i / n;
          if (folded) {
            const angle = t * Math.PI * 4;
            points.push(new THREE.Vector3(Math.cos(angle) * (1 + 0.3 * Math.sin(t * 10)), Math.sin(angle) * (1 + 0.3 * Math.cos(t * 8)), (t - 0.5) * 2));
          } else {
            points.push(new THREE.Vector3((Math.random() - 0.5) * 4, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 3));
          }
        }
        const geo = new THREE.BufferGeometry().setFromPoints(points);
        s.scene.add(new THREE.Line(geo, new THREE.LineBasicMaterial({ color: folded ? 0x6366f1 : 0x94a3b8 })));
        points.forEach((p) => {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.14, 10, 8), new THREE.MeshStandardMaterial({ color: folded ? 0x6366f1 : 0x94a3b8 }));
          m.position.copy(p);
          s.scene.add(m);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagFolded = null, diagDenatured = null;
      function initDiagFolded() { const c = el('diag-folded'); if (!c) throw new Error('no container'); diagFolded = enzymeScene(c, true); }
      function initDiagDenatured() { const c = el('diag-denatured'); if (!c) throw new Error('no container'); diagDenatured = enzymeScene(c, false); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[ph-enzyme-activity] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagFolded(); } catch (e) { console.error('[ph-enzyme-activity] folded diagram failed', e); }
          try { initDiagDenatured(); } catch (e) { console.error('[ph-enzyme-activity] denatured diagram failed', e); }
        }
        mountResize([diagFolded, diagDenatured]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
