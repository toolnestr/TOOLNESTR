---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Ounces to Grams"
  emoji="⚖️"
  fromUnit="ounces" toUnit="grams"
  fromTitle="Ounces" toTitle="Grams"
  fromSym="oz" toSym="g"
  quantity="weight"
  kind="factor" factor={28.349523125}
  reverseSlug="grams-to-ounces" reverseLabel="Grams to Ounces Converter"
  hasReverse={true}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Bakers and cooks use it constantly to turn ounces from a recipe into the grams shown on a digital scale."
/>
