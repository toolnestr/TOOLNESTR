---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Bias Tape Calculator';
const description = 'Calculate how much continuous bias tape you can cut from a square of fabric, or what size square you need.';
const intro = 'Calculate continuous bias tape length from a fabric square, or the square size needed for a target length.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is continuous bias binding?', a: 'It is a method of cutting one long, continuous bias strip from a square of fabric by joining the two opposite edges into a tube before cutting, rather than cutting many separate short strips and sewing them together end to end.' },
  { q: 'Why is bias tape cut at a 45-degree angle?', a: 'Cutting on the true bias (45 degrees to the grain) gives the strip maximum stretch and lets it curve smoothly around necklines, armholes, and other curved edges without puckering, which a strip cut on the straight grain cannot do.' },
  { q: 'Does this formula account for seam allowance when joining the tube?', a: 'This gives the theoretical maximum continuous length from the square\'s area; in practice, subtract a small amount (a few inches) for the seam used to join the fabric into a tube and for trimming the tube\'s ends.' },
  { q: 'What strip width should I use?', a: 'Common finished bias tape widths are 0.5 inch (single-fold) and 1 inch (double-fold, before folding); cut the strip roughly 4 times the desired finished width to allow for folding both raw edges under.' },
];
const howTo = {
  name: 'How to calculate continuous bias tape',
  steps: [
    { name: 'Choose calculation direction', text: 'Find tape length from a square size, or find the square size needed for a target length.' },
    { name: 'Enter your known value', text: 'Enter the fabric square\'s side length, or your target tape length.' },
    { name: 'Enter strip width', text: 'Enter the width you plan to cut each bias strip.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Square → Length', 'Length → Square'].map((d) => (
        <button data-mode={d} class="mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">{d}</button>
      ))}
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span id="input-label" class="text-sm font-medium text-slate-700">Fabric square side (in)</span>
        <input id="value" type="number" step="any" placeholder="e.g. 36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Strip width (in)</span>
        <input id="stripWidth" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div id="output-label" class="text-sm opacity-80">Continuous tape length</div>
        <div id="r-value" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="btc-title btc-desc">
      <title id="btc-title">Fabric square with diagonal bias strips marked</title>
      <desc id="btc-desc">A square of fabric with diagonal parallel lines at 45 degrees representing bias-cut strips</desc>
      <rect x="300" y="20" width="200" height="160" fill="#fecdd3" stroke="#e11d48" stroke-width="2" />
      {[0, 30, 60, 90, 120, 150].map((offset) => (
        <line x1={300 + offset} y1="180" x2={300 + offset + 160} y2="20" stroke="#e11d48" stroke-width="1.5" opacity="0.6" />
      ))}
      <text x="600" y="90" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Continuous strip length ≈</text>
      <text x="600" y="108" font-size="13" fill="#475569" font-family="system-ui,sans-serif">side² ÷ strip width</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Bias strips are cut diagonally so the tape stretches around curves</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How continuous bias tape is calculated</h2>
    <p class="mt-2 text-slate-600">
      The continuous bias method cuts one long strip from a square of fabric by first joining two opposite edges into a tube, then cutting in a spiral along marked bias lines. Because the entire square's area ends up as one continuous strip of a fixed width, the total length is simply the square's area divided by the strip width — a bigger square or a narrower strip both produce more total length.
    </p>
    <p class="mt-3 text-slate-600">
      Working backward from a target length, the required square's area is the target length multiplied by the strip width, and the square's side length is the square root of that area.
    </p>
    <p class="mt-3 text-xs text-slate-400">This is the standard area-based formula for the continuous bias binding method used across dressmaking and quilting references; subtract a small amount for the tube-joining seam and trimmed ends in practice.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 36-inch square of fabric, cut into 2-inch-wide continuous bias strips.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Square area:</span> <span class="text-slate-600">36 × 36 = 1,296 in²</span></div>
        <div><span class="font-medium text-slate-700">Tape length:</span> <span class="text-slate-600">1,296 ÷ 2 = 648 in</span></div>
        <div><span class="font-medium text-slate-700">In yards:</span> <span class="text-slate-600">648 ÷ 36 = <strong>18 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Binding a quilt's curved edges, finishing a garment's neckline and armholes in one matching fabric, or edging a round tablecloth all rely on bias tape's ability to curve without puckering — knowing how much continuous tape a given fabric scrap can yield helps decide whether a leftover piece is enough for a project or whether more fabric needs buying.
    </p>
    <p class="mt-3 text-slate-600">
      Self-made bias tape in a specific matching or contrasting fabric is common when no commercial bias tape matches a project's exact color or print — calculating the needed square upfront avoids cutting and piecing fabric twice.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Doubling the square size doubles the tape length." <strong class="text-slate-900">It roughly quadruples it.</strong> Since length depends on area, not side length, doubling a square's side length actually multiplies its area — and therefore the tape length — by about four times.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any diagonal cut counts as true bias." <strong class="text-slate-900">Only at 45 degrees.</strong> A cut at any other angle to the grain has less stretch than a true 45-degree bias cut, which is why continuous bias binding is specifically marked and cut at that exact angle.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/quilt-binding-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Quilt Binding Calculator</a>
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Yardage Calculator</a>
      <a href="/tools/seam-allowance-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Seam Allowance Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'Square → Length';

    function update() {
      const v = parseFloat(el('value').value);
      const stripWidth = parseFloat(el('stripWidth').value);
      if (!v || v <= 0 || !stripWidth || stripWidth <= 0) { el('results').classList.add('hidden'); return; }

      if (mode === 'Square → Length') {
        const area = v * v;
        const length = area / stripWidth;
        el('r-value').textContent = (length / 36).toFixed(2) + ' yd (' + length.toFixed(1) + ' in)';
      } else {
        const area = v * stripWidth;
        const side = Math.sqrt(area);
        el('r-value').textContent = side.toFixed(1) + ' in square';
      }
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach((b) => {
          b.className = 'mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50';
        });
        btn.className = 'mode-btn rounded-lg border border-rose-300 bg-rose-100 px-4 py-1.5 text-sm font-medium text-rose-700 transition';
        mode = btn.dataset.mode;
        el('input-label').textContent = mode === 'Square → Length' ? 'Fabric square side (in)' : 'Target tape length (in)';
        el('output-label').textContent = mode === 'Square → Length' ? 'Continuous tape length' : 'Fabric square needed';
        el('value').placeholder = mode === 'Square → Length' ? 'e.g. 36' : 'e.g. 400';
        update();
      });
    });

    el('value').addEventListener('input', update);
    el('stripWidth').addEventListener('input', update);
    document.querySelector('.mode-btn').click();
  </script>
</ToolLayout>
