---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Average Calculator (Mean, Median, Mode)';
const description =
  'Free average calculator. Enter numbers to instantly find the mean, median, mode, range, ' +
  'sum and count. Perfect for homework, grades and quick stats.';
const intro =
  'Type or paste your numbers to instantly get the mean (average), median, mode, range, sum and count.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What’s the difference between mean, median and mode?', a: 'Mean is the sum divided by the count (the usual “average”). Median is the middle value when sorted. Mode is the value that appears most often.' },
  { q: 'Can there be more than one mode?', a: 'Yes. If several values tie for most frequent, they’re all shown. If no value repeats, there is no mode.' },
  { q: 'How do I enter numbers?', a: 'Separate them with spaces, commas or new lines — the calculator handles it.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea id="nums" rows="4" placeholder="e.g. 5, 8, 8, 12, 20" class="w-full resize-y rounded-xl border border-slate-300 p-3 font-mono text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">5, 8, 8, 12, 20</textarea>
    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-sm opacity-80">Mean</div><div id="r-mean" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Median</div><div id="r-median" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Mode</div><div id="r-mode" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Range</div><div id="r-range" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Sum</div><div id="r-sum" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Count</div><div id="r-count" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this average calculator</h2>
    <p class="mt-2 text-slate-600">
      “Average” can mean a few different things in statistics. This calculator gives you all the
      common measures at once — mean, median and mode — plus the range, sum and count, so you can
      quickly summarise any set of numbers for homework, grades or reports.
    </p>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/standard-deviation" class="font-medium text-indigo-600 hover:underline">Standard Deviation Calculator</a>
      or <a href="/tools/percentage-calculator" class="font-medium text-indigo-600 hover:underline">Percentage Calculator</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const round = (n) => Math.round(n * 1e6) / 1e6;

    function update() {
      const vals = el('nums').value.split(/[\s,]+/).filter((s) => s !== '').map(Number).filter((x) => !isNaN(x));
      if (vals.length === 0) { ['mean', 'median', 'mode', 'range', 'sum', 'count'].forEach((k) => (el('r-' + k).textContent = '—')); return; }
      const n = vals.length;
      const sum = vals.reduce((a, b) => a + b, 0);
      const sorted = [...vals].sort((a, b) => a - b);
      const median = n % 2 ? sorted[(n - 1) / 2] : (sorted[n / 2 - 1] + sorted[n / 2]) / 2;
      // mode
      const freq = {};
      let maxF = 0;
      vals.forEach((v) => { freq[v] = (freq[v] || 0) + 1; maxF = Math.max(maxF, freq[v]); });
      const modes = Object.keys(freq).filter((k) => freq[k] === maxF);
      el('r-mean').textContent = round(sum / n);
      el('r-median').textContent = round(median);
      el('r-mode').textContent = maxF <= 1 ? 'none' : modes.join(', ');
      el('r-range').textContent = round(sorted[n - 1] - sorted[0]);
      el('r-sum').textContent = round(sum);
      el('r-count').textContent = n;
    }
    el('nums').addEventListener('input', update);
    update();
  </script>
</ToolLayout>
