---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Charles's Law Calculator";
const description = "Charles's Law calculator with a live 3D expanding balloon and charts. Solve V1/T1 = V2/T2 for any variable.";
const intro = "Solve V₁/T₁ = V₂/T₂ for any of the four variables — temperature is always converted to kelvin automatically. A live 3D balloon expands and changes color with temperature, alongside charts of the classic V–T line through absolute zero.";
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is Charles's law?", a: "Charles's law states that at constant pressure and a fixed amount of gas, volume and absolute temperature are directly proportional: V₁/T₁ = V₂/T₂. Heat a gas and it expands; cool it and it contracts, in direct proportion to its temperature in kelvin." },
  { q: 'Why must temperature be in kelvin, not Celsius, for Charles\'s law?', a: 'The proportionality V ∝ T only holds for absolute temperature. Celsius has an arbitrary zero point (the freezing point of water), so ratios of Celsius values are meaningless for this law — 40°C is not "twice as hot" as 20°C. Kelvin starts at absolute zero, where a gas\'s volume would theoretically reach zero, so ratios of kelvin temperatures correctly track ratios of volume. Always convert with K = °C + 273.15 before using the formula.' },
  { q: "What has to stay constant for Charles's law to apply?", a: 'Pressure and the amount of gas (moles) must both stay fixed. Charles\'s law isolates the volume–temperature relationship only when those two are held constant — if pressure also changes, you need the combined gas law instead.' },
  { q: 'How did Charles\'s law lead to the discovery of absolute zero?', a: "Plotting volume against Celsius temperature for a gas at constant pressure gives a straight line. Extrapolating that line backward, it crosses V = 0 at almost exactly -273.15°C for every gas, regardless of what gas it is. That universal x-intercept is what led scientists to define absolute zero (0 K) as the coldest possible temperature — the point where an ideal gas's volume would vanish." },
  { q: "Can Charles's law volume actually reach zero?", a: "No — real gases liquefy or solidify long before reaching absolute zero, so the straight-line V–T relationship breaks down at low temperatures. The V = 0 extrapolation is a theoretical construct of the ideal gas model, not something you can observe directly, but it correctly predicts where absolute zero sits on the temperature scale." },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: "How to use the Charles's Law Calculator",
  description: "Calculate the missing volume or temperature value using V1/T1 = V2/T2, with automatic Celsius-to-Kelvin conversion.",
  steps: [
    { name: 'Enter three values', text: 'Type any three of V₁, T₁, V₂, T₂. Leave the unknown one blank. Switch the temperature unit toggle between °C and K as needed.' },
    { name: 'Read the result', text: 'The fourth value solves instantly, with temperatures always converted to kelvin internally.' },
    { name: 'Explore the balloon', text: 'Drag the temperature slider to see the 3D balloon expand and change color live.' },
  ],
};

const formulas = [
  { expr: 'V₁/T₁ = V₂/T₂', note: 'volume ÷ absolute temperature is constant at fixed P and n' },
  { expr: 'K = °C + 273.15', note: 'convert to kelvin before using the formula — always' },
  { expr: 'V₂ = V₁ × T₂ / T₁', note: 'solve for the new volume' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — heating a gas sample', tone: 'slate',
    given: 'A gas occupies 2.00 L at 20°C. It is heated at constant pressure to 80°C. Find the new volume.',
    rows: [
      { label: 'Convert to kelvin:', value: 'T₁ = 20 + 273.15 = 293.15 K, T₂ = 80 + 273.15 = 353.15 K', full: true },
      { label: 'Rearrange:', value: 'V₂ = V₁ × T₂ ÷ T₁' },
      { label: 'Substitute:', value: 'V₂ = 2.00 × 353.15 ÷ 293.15' },
      { label: 'New volume:', value: 'V₂ ≈ 2.41 L', full: true },
    ],
    note: 'Using Celsius directly (80 ÷ 20 = 4×) would badly overstate the expansion — the correct kelvin ratio gives only about a 20% increase.',
  },
  {
    title: 'Worked example 2 — a weather balloon cooling as it rises', tone: 'amber',
    given: 'A weather balloon holds 5.00 L of gas at 25°C at launch. As it rises, the surrounding air cools it to -40°C, while pressure inside stays effectively constant. Find the new volume.',
    rows: [
      { label: 'Convert to kelvin:', value: 'T₁ = 25 + 273.15 = 298.15 K, T₂ = -40 + 273.15 = 233.15 K', full: true },
      { label: 'Rearrange:', value: 'V₂ = V₁ × T₂ ÷ T₁' },
      { label: 'Substitute:', value: 'V₂ = 5.00 × 233.15 ÷ 298.15' },
      { label: 'New volume:', value: 'V₂ ≈ 3.91 L', full: true },
    ],
    note: 'The gas contracts as it cools, exactly as Charles\'s law predicts — this is one reason balloon envelopes are launched under-inflated, with room to change size in either direction.',
  },
];

const comparison = {
  heading: "Charles's law vs Boyle's law vs Gay-Lussac's law",
  note: 'Each law holds one variable fixed and relates the other two — easy to mix up unless you track what stays constant.',
  headers: [{ label: 'Law' }, { label: 'Held constant' }, { label: 'Relationship' }],
  rows: [
    ["Charles's law", 'Pressure, moles', 'V and T — directly proportional (V₁/T₁ = V₂/T₂)'],
    ["Boyle's law", 'Temperature, moles', 'P and V — inversely proportional (P₁V₁ = P₂V₂)'],
    ["Gay-Lussac's law", 'Volume, moles', 'P and T — directly proportional (P₁/T₁ = P₂/T₂)'],
  ],
  highlightIndex: 0,
  footnote: 'All three are special cases of the combined/ideal gas law PV = nRT, each freezing one variable to isolate the other two.',
};

const realWorld = [
  { emoji: '🎈', title: 'Hot air balloons', body: "Heating the air inside a balloon envelope makes it expand and become less dense than the surrounding cool air, generating lift. This is the single most direct, visible demonstration of Charles's law in everyday life." },
  { emoji: '🌤️', title: 'Weather balloons', body: 'As a weather balloon climbs into the cold upper atmosphere, the gas inside contracts as temperature falls, then re-expands as ambient pressure drops with altitude — a combination of Charles\'s and Boyle\'s effects that engineers must plan for.' },
  { emoji: '🔧', title: 'Engine cylinders', body: 'Combustion rapidly heats gas inside an engine cylinder at roughly constant pressure during parts of the cycle, driving the dramatic volume expansion that pushes the piston — Charles\'s law in a very compressed timescale.' },
  { emoji: '🧴', title: 'Aerosol can warnings', body: 'Aerosol cans warn against storage near heat because warming the gas inside raises its volume (and pressure) sharply, risking rupture — the same underlying physics as the balloon, just in a rigid container instead.' },
];

const misconceptions = [
  { claim: '"You can plug Celsius values straight into Charles\'s law."', truth: 'False — this is the single most common student error. The V ∝ T proportionality only holds for absolute temperature. You must convert every temperature to kelvin (K = °C + 273.15) before using V₁/T₁ = V₂/T₂, or the answer will be badly wrong.' },
  { claim: '"Charles\'s law means volume and temperature are equal."', truth: 'False — they are proportional, not equal. V/T is a constant ratio, not V = T. Doubling the absolute temperature doubles the volume; it does not make the volume numerically equal to the temperature.' },
  { claim: '"Charles\'s law works even if pressure changes too."', truth: "False — pressure (and the amount of gas) must be held constant. That constraint is the entire premise of the law. If pressure changes as well, you need the combined gas law, P₁V₁/T₁ = P₂V₂/T₂, instead." },
  { claim: '"A gas\'s volume can actually reach zero at absolute zero."', truth: "Not physically — real gases liquefy or solidify long before 0 K, so the straight-line V–T relationship breaks down at low temperatures. The V = 0 extrapolation is a theoretical idealization, but it is precisely what led scientists to locate absolute zero at -273.15°C." },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — gas laws and Charles\'s law (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/9-2-relating-pressure-volume-amount-and-temperature-the-ideal-gas-law" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 10, Gases.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — the gas laws and kinetic molecular theory.' },
];
const sourcesNote = "Charles's law assumes constant pressure and a fixed amount of gas (n). Temperatures are converted to kelvin internally. Results are rounded for display.";

const howToUse = [
  { title: 'Enter three values', body: 'Fill any three of V₁, T₁, V₂, T₂; the fourth solves live.' },
  { title: 'Mind the units', body: 'Toggle °C or K for each temperature field — conversion to kelvin happens automatically before solving.' },
  { title: 'See it in the balloon', body: 'Drag the temperature slider and watch the 3D balloon expand and shift color from blue to red.' },
];

const related = [
  { href: '/tools/boyles-law-calculator', emoji: '🎈', title: "Boyle's Law Calculator", desc: 'P₁V₁ = P₂V₂ — solve any variable.' },
  { href: '/tools/ideal-gas-law-calculator', emoji: '🧮', title: 'Ideal Gas Law Calculator', desc: 'PV = nRT — solve for any variable.' },
  { href: '/tools/gas-laws-calculator', emoji: '🌡️', title: "Boyle's & Charles's Law Calculator", desc: 'Switch between multiple gas laws in one tool.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="heat a gas at constant pressure and it expands in direct proportion to its absolute temperature — but that proportion only works in kelvin, never Celsius."
  howIntro="Rearranged, V₁/T₁ = V₂/T₂ solves any of the four variables: V₂ = V₁T₂/T₁ and T₂ = T₁V₂/V₁. It only holds when pressure and the amount of gas (moles) stay fixed — and temperature must be absolute (kelvin), since the direct proportionality breaks down completely if you use Celsius, whose zero point is arbitrary rather than physical."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Charles's law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 rounded-lg bg-amber-50 p-3 text-sm text-amber-800"><strong>Important:</strong> Charles's law requires absolute temperature. Enter °C or K below — °C is converted to kelvin automatically before solving.</p>
    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume V₁</span>
        <input id="V1" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature T₁</span>
        <div class="mt-1 flex gap-1">
          <input id="T1" type="number" step="any" placeholder="value" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <select id="T1u" class="rounded-xl border border-slate-300 px-2 text-sm"><option value="C">°C</option><option value="K">K</option></select>
        </div></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Volume V₂</span>
        <input id="V2" type="number" step="any" placeholder="L" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Temperature T₂</span>
        <div class="mt-1 flex gap-1">
          <input id="T2" type="number" step="any" placeholder="value" class="w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <select id="T2u" class="rounded-xl border border-slate-300 px-2 text-sm"><option value="C">°C</option><option value="K">K</option></select>
        </div></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">V₁</div><div id="r-V1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">T₁</div><div id="r-T1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">V₂</div><div id="r-V2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">T₂</div><div id="r-T2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="cl-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D balloon + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-balloon" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Hotter gas takes up more room</h3>
          <p class="mt-1 text-sm text-slate-600">A cold, small, <span class="font-semibold text-sky-500">blue</span> balloon next to a hot, large, <span class="font-semibold text-rose-500">red</span> one — the same gas at two different absolute temperatures, expanding at constant pressure.</p>
        </div>
        <div>
          <div id="diag-vt-lines" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Every line points to absolute zero</h3>
          <p class="mt-1 text-sm text-slate-600">Straight V-vs-T lines for different gas samples all extrapolate back to the same point: V = 0 at 0 K. That shared intercept is exactly how absolute zero was discovered.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Charles's law graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Volume vs kelvin temperature — a straight line through absolute zero</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">V/T ratio vs temperature — constant, by Charles's law</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vtconst"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function toK(val, unit) { return unit === 'C' ? val + 273.15 : val; }
      function fromK(k, unit) { return unit === 'C' ? k - 273.15 : k; }

      // ---- calculator ----
      function update() {
        el('cl-err').textContent = '';
        ['r-V1', 'r-T1', 'r-V2', 'r-T2'].forEach((id) => (el(id).textContent = '—'));
        const V1 = parseFloat(el('V1').value);
        const V2 = parseFloat(el('V2').value);
        const T1u = el('T1u').value, T2u = el('T2u').value;
        const T1raw = parseFloat(el('T1').value), T2raw = parseFloat(el('T2').value);
        const T1 = isNaN(T1raw) ? NaN : toK(T1raw, T1u);
        const T2 = isNaN(T2raw) ? NaN : toK(T2raw, T2u);
        const vals = { V1, T1, V2, T2 };
        const filled = Object.keys(vals).filter((k) => !isNaN(vals[k]));
        if (filled.length < 3) return;
        const missing = Object.keys(vals).filter((k) => isNaN(vals[k]));

        function fmtT(k, unit) { return fmt(k) + ' K (' + fmt(fromK(k, unit)) + '°C)'; }

        if (missing.length !== 1) {
          if (T1 <= 0 || T2 <= 0) { el('cl-err').textContent = 'Absolute temperature must be above 0 K.'; return; }
          el('r-V1').textContent = fmt(V1) + ' L';
          el('r-T1').textContent = fmtT(T1, T1u);
          el('r-V2').textContent = fmt(V2) + ' L';
          el('r-T2').textContent = fmtT(T2, T2u);
          return;
        }
        const m = missing[0];
        let out = { V1, T1, V2, T2 };
        try {
          if (m === 'V1') { if (T1 <= 0) throw new Error('T1 must be above 0 K.'); out.V1 = (V2 * T1) / T2; }
          else if (m === 'T1') { if (V1 === 0) throw new Error('V1 cannot be zero.'); out.T1 = (V1 * T2) / V2; if (out.T1 <= 0) throw new Error('Resulting T1 is at or below absolute zero — check inputs.'); }
          else if (m === 'V2') { if (T1 <= 0) throw new Error('T1 must be above 0 K.'); out.V2 = (V1 * T2) / T1; }
          else if (m === 'T2') { if (V1 === 0) throw new Error('V1 cannot be zero.'); out.T2 = (V2 * T1) / V1; if (out.T2 <= 0) throw new Error('Resulting T2 is at or below absolute zero — check inputs.'); }
        } catch (e) { el('cl-err').textContent = e.message; return; }
        el('r-V1').textContent = fmt(out.V1) + ' L';
        el('r-T1').textContent = fmtT(out.T1, T1u);
        el('r-V2').textContent = fmt(out.V2) + ' L';
        el('r-T2').textContent = fmtT(out.T2, T2u);
      }
      ['V1', 'T1', 'V2', 'T2', 'T1u', 'T2u'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const K_RATIO = 2.00 / 293.15; // fixed V1/T1 = 2.00 L / 293.15 K for chart reference
      const charts = {};
      function bState() { return { t: 293.15, v: 2.00 }; }

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.vt = new Chart(el('chart-vt'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'V', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Temperature (K)' } }, y: { title: { display: true, text: 'Volume (L)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.vtconst = new Chart(el('chart-vtconst'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'V/T', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Temperature (K)' } }, y: { title: { display: true, text: 'V / T (L/K)' }, suggestedMin: 0, suggestedMax: K_RATIO * 2 } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L = [], D = [], C = [];
        for (let tt = 0; tt <= 500.001; tt += 10) { L.push(tt.toFixed(0)); D.push(+(K_RATIO * tt).toFixed(4)); C.push(+K_RATIO.toFixed(6)); }
        charts.vt.data.labels = L; charts.vt.data.datasets[0].data = D; charts.vt.update();
        charts.vtconst.data.labels = L; charts.vtconst.data.datasets[0].data = C; charts.vtconst.update();
      }

      // ---- standalone diagram: balloon at two static temperatures ----
      function initDiagBalloon() {
        const c = el('diag-balloon'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        function balloonAt(x, radius, color) {
          const grp = new THREE.Group(); grp.position.x = x;
          const mat = new THREE.MeshStandardMaterial({ color, roughness: 0.35, metalness: 0.05 });
          const mesh = new THREE.Mesh(new THREE.SphereGeometry(radius, 32, 28), mat);
          mesh.position.y = radius - 1.2; grp.add(mesh);
          const knot = new THREE.Mesh(new THREE.ConeGeometry(0.25, 0.5, 16), new THREE.MeshStandardMaterial({ color: 0x64748b, roughness: 0.5 }));
          knot.position.y = mesh.position.y - radius - 0.2; grp.add(knot);
          return grp;
        }
        s.scene.add(balloonAt(-3, 1.1, 0x38bdf8));  // cold, small, blue
        s.scene.add(balloonAt(3, 2.0, 0xf43f5e));   // hot, large, red
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }

      // ---- standalone diagram: family of V-vs-T lines through absolute zero ----
      function initDiagVTLines() {
        const c = el('diag-vt-lines'); if (!c) throw new Error('no container');
        const s = makeScene(c, 15, new THREE.Vector3(5, 3, 0), MOL_OPTS);
        const grid = new THREE.GridHelper(12, 12, 0xe2e8f0, 0xeef2f7); grid.position.set(6, 0, 6); s.scene.add(grid);
        const slopes = [0.006822, 0.012, 0.018]; // different V/T ratios (different gas samples)
        slopes.forEach((m) => {
          const pts = [];
          for (let t = 0; t <= 500; t += 25) pts.push(new THREE.Vector3(t / 50, Math.min(10, m * t * 10), 0));
          const col = m === 0.006822 ? 0x6366f1 : 0x94a3b8;
          const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: col, transparent: m !== 0.006822, opacity: m === 0.006822 ? 1 : 0.6 }));
          s.scene.add(line);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0035); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }

      let diagBalloon = null, diagVT = null;

      function boot() {
        try { update(); } catch (e) { console.error('[charles] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[charles] charts failed', e); }
        if (window.THREE) {
          try { diagBalloon = initDiagBalloon(); } catch (e) { console.error('[charles] balloon diagram failed', e); }
          try { diagVT = initDiagVTLines(); } catch (e) { console.error('[charles] V-T lines diagram failed', e); }
        }
        mountResize([diagBalloon, diagVT]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
