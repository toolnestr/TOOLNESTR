---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Tip Calculator';
const description =
  'Free tip calculator with bill split. Enter the bill, choose a tip percentage and the ' +
  'number of people to see the tip, total and amount per person. Works in any currency.';
const intro =
  'Enter your bill, pick a tip percentage and split it between people. See the tip, total and per-person amount instantly.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'How much should I tip?', a: 'It varies by country and service, but 15–20% is common in the US. Many places include service or don’t expect tips at all — use whatever percentage suits you.' },
  { q: 'Can I split the bill?', a: 'Yes. Set the number of people and the calculator shows how much each person pays, tip included.' },
  { q: 'Does it work in my currency?', a: 'Yes — pick your currency symbol. The math is the same everywhere.' },
  { q: 'Is anything uploaded?', a: 'No. It all runs in your browser.' },
  { q: 'What if the service charge is already included in the bill?', a: 'Check your bill first. If a service charge (often 10–15%) is already added, you may choose to tip only the difference or round up.' },
  { q: 'Do I have to tip the same percentage for everyone?', a: 'The calculator uses a single tip percentage for the whole group. If individuals want to tip differently, use the per-person amount as a guide and adjust manually.' },
  { q: 'How do I tip on the pre-tax or post-tax amount?', a: 'Most tipping guides suggest tipping on the pre-tax amount, but opinions vary. Our calculator lets you enter whatever bill amount you prefer.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Currency</span>
        <select id="currency" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option>$</option><option>€</option><option>£</option><option>₹</option><option>₨</option><option>¥</option><option>₦</option><option>A$</option>
        </select>
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Bill amount</span>
        <input id="bill" type="number" min="0" step="any" placeholder="0.00" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">People</span>
        <input id="people" type="number" min="1" step="1" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
    </div>

    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Tip %</span>
      <div class="mt-1 flex flex-wrap items-center gap-2">
        {[10, 15, 18, 20, 25].map((p) => (
          <button data-tip={p} class="tip-preset rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{p}%</button>
        ))}
        <input id="tip" type="number" min="0" step="any" value="15" class="w-24 rounded-lg border border-slate-300 px-3 py-1.5 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Tip</div><div id="r-tip" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Total</div><div id="r-total" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-sm opacity-80">Each person</div><div id="r-each" class="mt-1 text-xl font-bold">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this tip calculator</h2>
    <p class="mt-2 text-slate-600">
      Splitting a restaurant bill and working out a fair tip is quick with this calculator. Enter
      the bill, tap a tip percentage (or type your own), and set how many people are sharing — it
      instantly shows the tip, the grand total, and exactly how much each person owes. It works in
      any currency, so it's handy while travelling too. For calculating discounts while shopping, check our <a href="/tools/discount-calculator" class="font-medium text-indigo-600 hover:underline">Discount Calculator</a>.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Pick your currency and enter the bill amount.</li>
      <li>Choose a tip percentage or type a custom one.</li>
      <li>Set the number of people to split between.</li>
      <li>Read the tip, total and per-person amounts.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Dining out with friends, ordering delivery, tipping a hairstylist or tour guide, or travelling to a country where tipping customs are different from your own — this calculator ensures you never over- or under-tip. The bill-splitting feature also makes group dinners effortless.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Use the preset buttons (10%, 15%, 18%, 20%, 25%) for common tipping percentages, or type a custom one.</li>
      <li>The "Each person" amount updates when you change the number of people — perfect for splitting evenly at group outings.</li>
      <li>If you're shopping for discounts instead, check our <a href="/tools/discount-calculator" class="font-medium text-indigo-600 hover:underline">Discount Calculator</a>.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const currency = el('currency'), bill = el('bill'), people = el('people'), tip = el('tip');

    function fmt(n) { return currency.value + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }

    function update() {
      const b = parseFloat(bill.value);
      const t = parseFloat(tip.value) || 0;
      const p = Math.max(1, parseInt(people.value, 10) || 1);
      if (isNaN(b) || b < 0) { el('r-tip').textContent = el('r-total').textContent = el('r-each').textContent = '—'; return; }
      const tipAmt = b * t / 100;
      const total = b + tipAmt;
      el('r-tip').textContent = fmt(tipAmt);
      el('r-total').textContent = fmt(total);
      el('r-each').textContent = fmt(total / p);
    }

    document.querySelectorAll('.tip-preset').forEach((btn) => btn.addEventListener('click', () => { tip.value = btn.dataset.tip; update(); }));
    [currency, bill, people, tip].forEach((e) => e.addEventListener('input', update));
  </script>
</ToolLayout>
