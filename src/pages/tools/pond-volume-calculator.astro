---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Pond Volume Calculator';
const description = 'Estimate how many gallons of water your pond holds from its length, width and average depth — for rectangular, circular and free-form garden ponds.';
const intro = 'Estimate how many gallons your pond holds, so you can size a pump, liner, or the right dose of treatment.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate pond volume in gallons?', a: 'Multiply length × width × average depth in feet to get cubic feet, then multiply by 7.48 to get US gallons. For an irregular, free-form pond, multiply that result by about 0.85 to account for the sloped, non-rectangular sides.' },
  { q: 'What is the shape factor for an irregular pond?', a: 'A natural, curved pond does not fill its bounding rectangle, so most guides apply a shape factor of roughly 0.85 (85%) to a rectangular estimate. For a rough oval you can use the circular formula instead, which is already about 79% of the bounding box.' },
  { q: 'Why does pond volume matter?', a: 'Volume sets the pump and filter size (you generally circulate the whole pond every 1 to 2 hours), the correct dose of any water treatment or algaecide, and the fish stocking limit. Dosing off the wrong volume can under-treat the water or harm fish.' },
  { q: 'How do I find the average depth?', a: 'Take several depth readings across the pond — near the edges where it is shallow and in the center where it is deepest — and average them. Using only the deepest point will badly overestimate the volume of a bowl-shaped pond.' },
];
const howTo = {
  name: 'How to calculate pond volume in gallons',
  steps: [
    { name: 'Measure the outline', text: 'Length and width, or diameter for a round pond, in feet.' },
    { name: 'Average the depth', text: 'Combine several readings from edge to center.' },
    { name: 'Size pump and dose', text: 'Use the gallons to pick a pump and treatment amount.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block max-w-xs"><span class="text-sm font-medium text-slate-700">Pond shape</span>
      <select id="shape" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="rect" selected>Rectangular</option>
        <option value="circ">Circular</option>
        <option value="free">Free-form / irregular</option>
      </select></label>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label id="w-len" class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="len" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-width" class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="width" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="w-dia" class="hidden"><span class="text-sm font-medium text-slate-700">Diameter (ft)</span>
        <input id="dia" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Average depth (ft)</span>
        <input id="depth" type="number" step="any" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Pond volume</div>
        <div id="r-gal" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic feet</div><div id="r-cf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Liters</div><div id="r-l" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Pump min (½ turnover)</div><div id="r-pump" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="pv-title pv-desc">
      <title id="pv-title">Pond cross-section and the gallon formula</title>
      <desc id="pv-desc">A garden pond with sloped sides and the volume-to-gallons conversion</desc>
      <path d="M80 70 Q100 60 140 66 Q220 74 300 66 Q360 60 380 70 L350 150 Q230 175 110 150 Z" fill="#bae6fd" stroke="#0ea5e9" stroke-width="1.5" />
      <line x1="80" y1="70" x2="380" y2="70" stroke="#0ea5e9" stroke-width="1" stroke-dasharray="4 3" />
      <text x="230" y="200" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">length × width × avg depth</text>
      <rect x="470" y="60" width="270" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="490" y="88" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Gallons</text>
      <text x="490" y="114" font-size="12" fill="#475569" font-family="system-ui,sans-serif">gal = ft&sup3; &times; 7.48</text>
      <text x="490" y="136" font-size="12" fill="#475569" font-family="system-ui,sans-serif">free-form: &times; 0.85 shape factor</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Curved, sloped ponds hold less than their bounding box — the shape factor corrects for that.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the pond volume calculator works</h2>
    <p class="mt-2 text-slate-600">
      Pond volume follows the same volume-to-gallons logic as any tank: find the cubic feet, then multiply by 7.48 to get US gallons. A rectangular pond is length × width × average depth. A circular pond is π × radius² × average depth. The one twist with ponds is that they are rarely perfect boxes — the sides slope inward and the outline curves — so a raw rectangular estimate overstates the true volume.
    </p>
    <p class="mt-3 text-slate-600">
      To correct for that, free-form ponds use a shape factor of about 0.85, meaning the pond actually holds roughly 85% of its bounding rectangle. This is the widely used water-garden rule of thumb. The other key input is average depth, not maximum depth: because most ponds are shallow at the edges and deepest in the middle, using only the deep-point reading can double the real volume.
    </p>
    <p class="mt-3 text-slate-600">
      Volume drives three practical decisions. Pumps are sized to circulate the whole pond every one to two hours, so a good pump is rated at least half the volume in gallons per hour. Water treatments and algaecides are dosed per gallon, so an accurate volume keeps you from under- or over-dosing. And fish stocking limits are set per gallon of water to keep oxygen and waste levels safe.
    </p>
    <p class="mt-3 text-xs text-slate-400">Pump turnover rates and the free-form shape factor follow water-garden industry rules of thumb published by the Pond and Water Garden trade association guidance used by aquatics retailers.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the outline</h3>
        <p class="mt-1 text-sm text-slate-600">Length and width, or diameter for a round pond, in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Average the depth</h3>
        <p class="mt-1 text-sm text-slate-600">Combine several readings from edge to center.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Size pump and dose</h3>
        <p class="mt-1 text-sm text-slate-600">Use the gallons to pick a pump and treatment amount.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Cubic feet</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= L &times; W &times; depth</span>. A 12 ft × 8 ft pond, 2 ft average deep: 12 × 8 × 2 = <strong>192 ft³</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Gallons</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">gal = ft&sup3; &times; 7.48</span> = 192 × 7.48 = <strong>1,436 US gallons</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Free-form correction</p>
        <p class="mt-1 text-slate-600">
          For an irregular pond, multiply by 0.85: 1,436 × 0.85 = <strong>1,221 gallons</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A round koi pond 10 ft across with an average depth of 3 ft.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Radius:</span> <span class="text-slate-600">10 ÷ 2 = 5 ft</span></div>
        <div><span class="font-medium text-slate-700">Cubic feet:</span> <span class="text-slate-600">π × 5² × 3 = 235.6 ft³</span></div>
        <div><span class="font-medium text-slate-700">US gallons:</span> <span class="text-slate-600">235.6 × 7.48 = <strong>1,762 gal</strong></span></div>
        <div><span class="font-medium text-slate-700">Min pump:</span> <span class="text-slate-600">≈ 881 GPH for a 2-hour turnover</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the pond volume calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🐠</span>
        <h3 class="mt-2 font-semibold text-slate-900">Koi and fish stocking</h3>
        <p class="mt-1 text-sm text-slate-600">Determine a safe stocking density in inches of fish per gallon, and confirm your filtration system is rated to handle the pond's actual water volume.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">💊</span>
        <h3 class="mt-2 font-semibold text-slate-900">Treatment dosing</h3>
        <p class="mt-1 text-sm text-slate-600">Get an accurate gallon figure before applying algaecide, dechlorinator, or bacterial treatments, all of which are dosed per gallon of pond water.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">⚙️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Pump and filter sizing</h3>
        <p class="mt-1 text-sm text-slate-600">Match a pump's gallons-per-hour rating to your pond's turnover needs, whether that's a fast 1-hour cycle for a heavily stocked koi pond or a gentler 2-hour cycle for a planted water garden.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧱</span>
        <h3 class="mt-2 font-semibold text-slate-900">Liner and excavation planning</h3>
        <p class="mt-1 text-sm text-slate-600">Estimate volume early in a new pond build to cross-check liner sizing and the amount of soil that will need to be excavated and hauled away.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A backyard wildlife pond with soft, curved edges — roughly 15 ft by 10 ft with a 1.5 ft average depth — bounds a rectangle of 15 × 10 × 1.5 = 225 cubic feet, but since it's free-form the calculator applies the 0.85 shape factor for 191.25 cubic feet, or about 1,431 US gallons. That correction matters here: skipping it would overstate the pond's true volume by roughly 15%, which throws off both pump sizing and treatment dosing.
    </p>
    <p class="mt-3 text-slate-600">
      A formal rectangular reflecting pond, 20 ft by 6 ft with a uniform 2.5 ft depth and no shape correction since its sides are straight, holds 20 × 6 × 2.5 = 300 cubic feet, or 2,244 gallons. Straight-sided pools like this are the one pond shape where the raw rectangular formula is already exact, no adjustment needed.
    </p>
    <p class="mt-3 text-slate-600">
      A large circular koi pond, 18 ft across and 4 ft deep, works out to π × 9² × 4 = 1,017.9 cubic feet, or 7,614 gallons — big enough that a proper 2-hour turnover calls for a pump rated around 3,807 gallons per hour, illustrating how quickly pump requirements scale once a pond moves from a small garden feature to a serious koi-keeping setup.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Measuring the deepest point of the pond gives the most accurate volume." <strong class="text-slate-900">It actually causes the biggest overestimate.</strong> Most garden ponds slope up toward the edges, so a bowl-shaped pond measured only at its deepest point can show double the real average depth — always average several readings from edge to center instead.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A bigger pump always keeps pond water healthier." <strong class="text-slate-900">Oversizing has real downsides.</strong> Excess flow can stress fish, disturb plants, and strip beneficial bacteria off filter media before it has time to work — the standard guidance is to turn the whole pond volume over once every one to two hours, not as fast as possible.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pool-volume-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Pool Volume Calculator</a>
      <a href="/tools/water-tank-volume-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Water Tank Volume Calculator</a>
      <a href="/tools/gpm-flow-rate-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">GPM Flow Rate Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function sync() {
      const shape = el('shape').value;
      const round = shape === 'circ';
      el('w-len').classList.toggle('hidden', round);
      el('w-width').classList.toggle('hidden', round);
      el('w-dia').classList.toggle('hidden', !round);
      update();
    }

    function update() {
      const shape = el('shape').value;
      const depth = parseFloat(el('depth').value);
      if (!(depth > 0)) return hide();
      let cf = 0;
      if (shape === 'circ') {
        const d = parseFloat(el('dia').value);
        if (!(d > 0)) return hide();
        cf = Math.PI * Math.pow(d / 2, 2) * depth;
      } else {
        const L = parseFloat(el('len').value), W = parseFloat(el('width').value);
        if (!(L > 0 && W > 0)) return hide();
        cf = L * W * depth;
        if (shape === 'free') cf *= 0.85;
      }
      const gal = cf * 7.48052;
      const liters = cf * 28.3168;
      const pumpGph = gal / 2; // 2-hour turnover

      el('r-gal').textContent = gal.toFixed(0) + ' US gal';
      el('r-note').textContent = shape === 'free' ? 'includes 0.85 free-form shape factor' : 'filled to the average depth';
      el('r-cf').textContent = cf.toFixed(1) + ' ft³';
      el('r-l').textContent = liters.toFixed(0) + ' L';
      el('r-pump').textContent = pumpGph.toFixed(0) + ' GPH';
      el('results').classList.remove('hidden');
    }
    function hide() { el('results').classList.add('hidden'); }

    el('shape').addEventListener('change', sync);
    ['len', 'width', 'dia', 'depth'].forEach((id) => el(id).addEventListener('input', update));
    sync();
  </script>
</ToolLayout>
