---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Avogadro's Number Calculator";
const description = "Avogadro's number calculator with a live 3D particle scene and charts. Convert moles to particle count (N = n×N_A) or mass to particle count via molar mass, with worked examples.";
const intro = "Convert between moles and number of particles using N = n × N_A, or go straight from a substance's mass to its particle count via molar mass. A live 3D scene and charts show just how enormous 6.022 × 10²³ really is.";
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: "What is Avogadro's number?", a: 'Avogadro\'s number (N_A) is 6.02214076 × 10²³ — the number of elementary entities (atoms, molecules, ions, or formula units) in exactly one mole of a substance. It is the bridge between the microscopic world of individual particles and the macroscopic world of grams you can weigh on a scale.' },
  { q: 'Why is it that specific value?', a: 'Historically, the mole was defined so that 12 grams of carbon-12 contained exactly N_A atoms, and N_A was measured experimentally. Since the 2019 redefinition of the SI, N_A is instead a fixed, exact defining constant (6.02214076 × 10²³ /mol), and the mass of carbon-12 is now the measured quantity — the relationship is the same, but the roles of "definition" and "measurement" swapped.' },
  { q: 'What counts as a "particle" here?', a: 'Whatever entity you specify: atoms of an element, molecules of a compound, ions, electrons, or formula units of an ionic solid. N = n × N_A always gives the count of whatever single entity your "mole" refers to — one mole of NaCl formula units, one mole of water molecules, one mole of electrons, and so on.' },
  { q: 'How large is 6.022 × 10²³ really?', a: 'It is an inconceivably large number — far beyond anything encountered in daily counting. To give a sense of scale, 6.022 × 10²³ grains of ordinary sand would be enough to bury the entire surface of the Earth many kilometres deep. Even a tiny fraction of a mole (a few thousandths) already corresponds to hundreds of billions of trillions of particles.' },
  { q: 'How do I convert mass directly to number of particles?', a: 'First divide mass by the substance\'s molar mass to get moles (mol = mass / M), then multiply by N_A: particles = (mass / M) × N_A. This calculator\'s "Mass ⇄ particles" mode does both steps in one place using the same 118-element atomic weight table as the Molar Mass Calculator.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: "How to use the Avogadro's Number Calculator",
  description: 'Convert between moles and particle count directly, or from a compound\'s mass via its molar mass.',
  steps: [
    { name: 'Pick a mode', text: '"Moles ⇄ particles" for N = n × N_A directly, or "Mass ⇄ particles" to go from grams via a chemical formula.' },
    { name: 'Enter the values', text: 'Type moles or particle count (mode 1), or a mass and formula (mode 2).' },
    { name: 'Read the result', text: 'The particle count solves instantly in scientific notation, and the 3D scene and charts update.' },
  ],
};

const formulas = [
  { expr: 'N = n × N<sub>A</sub>', note: 'particle count from moles' },
  { expr: 'N<sub>A</sub> = 6.02214076 × 10²³ /mol', note: 'the 2019 SI-exact defined value' },
  { expr: 'n = mass / M, then N = n × N<sub>A</sub>', note: 'mass → moles → particle count' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — moles to molecules', tone: 'slate',
    given: 'How many water molecules are in 0.500 mol of H₂O?',
    rows: [
      { label: 'Formula:', value: 'N = n × N<sub>A</sub>' },
      { label: 'Substitute:', value: 'N = 0.500 × 6.02214076 × 10²³' },
      { label: 'Result:', value: 'N = 3.01107038 × 10²³ ≈ <strong>3.011 × 10²³ molecules</strong>', full: true },
    ],
  },
  {
    title: 'Worked example 2 — mass to molecules', tone: 'amber',
    given: 'How many molecules are in 18.0 g of water (molar mass 18.015 g/mol)?',
    rows: [
      { label: 'Moles:', value: 'n = 18.0 ÷ 18.015 = 0.99917 mol' },
      { label: 'Particles:', value: 'N = 0.99917 × 6.02214076 × 10²³' },
      { label: 'Result:', value: 'N = 6.0171 × 10²³ ≈ <strong>6.017 × 10²³ molecules</strong>', full: true },
    ],
    note: 'Notice 18.0 g of water is close to one mole (18.015 g/mol), so its particle count is close to N_A itself.',
  },
];

const comparison = {
  heading: 'Particle count for common mole amounts',
  note: 'The particle count scales linearly with moles — but because N_A is so large, even small mole amounts give astronomical counts.',
  headers: [{ label: 'Amount (mol)' }, { label: 'Particle count' }],
  rows: [
    ['0.001 mol', '6.022 × 10²⁰'],
    ['0.01 mol', '6.022 × 10²¹'],
    ['0.1 mol', '6.022 × 10²²'],
    ['1.0 mol', '6.022 × 10²³'],
    ['2.0 mol', '1.204 × 10²⁴'],
  ],
  highlightIndex: 3,
  footnote: 'Particle count = moles × 6.02214076 × 10²³. Values rounded to 4 significant figures.',
};

const realWorld = [
  { emoji: '⚗️', title: 'Stoichiometry', body: 'Balanced equations are written in moles, but reactions happen atom-by-atom and molecule-by-molecule. Avogadro\'s number is what lets chemists translate between the mole ratios on paper and the actual particles reacting in a flask.' },
  { emoji: '🔬', title: 'Determining atomic and molecular masses', body: 'Historical and modern experiments that measure N_A (oil-drop style charge experiments, X-ray crystal density measurements) are what pin down atomic masses in the first place, connecting a single atom\'s mass to a weighable, mole-scale sample.' },
  { emoji: '🧪', title: 'Concentration at the particle level', body: 'Molarity (mol/L) becomes physically meaningful only once you can convert it to actual ion or molecule counts — essential for understanding reaction rates, osmotic pressure, and biochemical signalling, which depend on real particle numbers, not just moles.' },
];

const misconceptions = [
  { claim: '"Avogadro\'s number only applies to gases."', truth: 'It applies to any substance and any specified particle — solids, liquids, gases, ions, or electrons. It is unrelated to the ideal gas law\'s "22.4 L per mole," which is a separate, gas-specific fact at STP.' },
  { claim: '"A mole is a unit of mass."', truth: 'A mole is a unit of amount — a counting unit, just like "dozen," except it counts 6.022 × 10²³ things instead of 12. A mole of different substances has different masses (their molar mass in grams), but always the same number of particles.' },
  { claim: '"6.022 × 10²³ is a rounded, approximate number."', truth: 'Since the 2019 SI redefinition, N_A = 6.02214076 × 10²³ /mol is an exact defining constant with no uncertainty — it is not measured, it is fixed by definition, and the kilogram and other units are calibrated around it.' },
  { claim: '"You only use Avogadro\'s number for chemistry problems, not real particle counts."', truth: 'It genuinely converts to real, physical particle counts. 1 mole of any gas at standard conditions really does contain 6.022 × 10²³ individual molecules bouncing around — it is not just a bookkeeping trick.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — the mole and Avogadro\'s number (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/3-1-formula-mass-and-the-mole-concept" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 3, The Mole and Avogadro\'s Number.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — moles, molar mass and stoichiometric conversions.' },
  { html: '<strong>NIST, <em>The International System of Units (SI)</em></strong> — the 2019 redefinition fixing N_A as an exact constant. <a href="https://www.nist.gov/si-redefinition" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">nist.gov</a>' },
];
const sourcesNote = 'N_A = 6.02214076 × 10²³ /mol (SI-exact since 2019). Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"Moles ⇄ particles" for direct N = n × N_A; "Mass ⇄ particles" to start from grams and a formula.' },
  { title: 'Enter your values', body: 'Fill in moles or particles (mode 1), or mass and a chemical formula (mode 2).' },
  { title: 'See the scale', body: 'The 3D scene and charts illustrate just how large the resulting particle count is.' },
];

const related = [
  { href: '/tools/atomic-mass-calculator', emoji: '🔬', title: 'Molar Mass Calculator', desc: 'Molar mass from any chemical formula.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'M = mol/L — solve for any variable.' },
  { href: '/tools/mole-ratio-calculator', emoji: '🔢', title: 'Mole Ratio Calculator', desc: 'Convert moles of one species to another.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="Avogadro's number is the fixed conversion factor between how many particles you have and how many moles that represents — N = n × N_A, always."
  howIntro="Rearranged, the same relationship recovers moles from a particle count: <span class='font-mono'>n = N / N_A</span>. Because most substances are weighed rather than counted, the practical route is usually mass → moles (via molar mass) → particles, all in one step: <span class='font-mono'>N = (mass / M) × N_A</span>."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Avogadro's number actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-n" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Moles ⇄ particles</button>
      <button id="mode-mass" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Mass ⇄ particles</button>
    </div>

    <div id="n-fields" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Moles (n)</span>
        <input id="moles" type="number" step="any" placeholder="mol" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of particles (N)</span>
        <input id="particles" type="text" placeholder="e.g. 6.022e23" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="mass-fields" class="hidden grid-cols-1 gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Chemical formula</span>
        <input id="formula" type="text" placeholder="H2O" value="H2O" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (g)</span>
        <input id="mass" type="number" step="any" placeholder="g" value="18.0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Particles</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Moles</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Molar mass</div><div id="r-3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="av-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D particle scene + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D particle scene (illustrative)</h2>
      <p class="mt-1 text-sm text-slate-500">Drag the slider to pick a tiny mole amount — even a few thousandths of a mole already means hundreds of billions of trillions of real particles. The 3D scene shows a fixed, capped cluster of spheres (up to 130) as an <strong>illustration only</strong> — 6.022 × 10²³ particles can never be rendered on screen, so the sphere count does <em>not</em> scale to match the real number. The readout below shows the true scientific-notation count. Drag to orbit (touch works too).</p>
      <label class="mt-3 block">
        <span class="flex items-center justify-between text-sm font-medium text-slate-700">Moles <span id="out-nmol" class="font-mono text-green-600">0.000500 mol</span></span>
        <input id="n-slider" type="range" min="0" max="0.001" step="0.00001" value="0.0005" class="mt-2 w-full accent-green-600" />
      </label>
      <div class="mt-2 rounded-xl bg-green-50 p-3 text-center text-sm text-green-700">Particles represented = <span id="out-nparticles" class="font-mono font-bold">—</span></div>
      <div id="particles3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="particles3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Avogadro's number graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Particle count vs moles (log scale) — 0.001 to 1.0 mol</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-log"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Mass vs particle count for the current formula</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mass"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const NA = 6.02214076e23;

      // ---- atomic masses (same table as the Molar Mass Calculator) ----
      const atomicMasses = { H: 1.008, He: 4.0026, Li: 6.94, Be: 9.0122, B: 10.81, C: 12.011, N: 14.007, O: 16.00, F: 19.00, Ne: 20.180, Na: 22.990, Mg: 24.305, Al: 26.982, Si: 28.086, P: 30.974, S: 32.06, Cl: 35.45, Ar: 39.95, K: 39.098, Ca: 40.078, Sc: 44.956, Ti: 47.867, V: 50.942, Cr: 51.996, Mn: 54.938, Fe: 55.845, Co: 58.933, Ni: 58.693, Cu: 63.546, Zn: 65.38, Ga: 69.723, Ge: 72.63, As: 74.922, Se: 78.96, Br: 79.904, Kr: 83.80, Rb: 85.468, Sr: 87.62, Y: 88.906, Zr: 91.224, Nb: 92.906, Mo: 95.95, Tc: 98.0, Ru: 101.07, Rh: 102.91, Pd: 106.42, Ag: 107.87, Cd: 112.41, In: 114.82, Sn: 118.71, Sb: 121.76, Te: 127.60, I: 126.90, Xe: 131.29, Cs: 132.91, Ba: 137.33, La: 138.91, Ce: 140.12, Pr: 140.91, Nd: 144.24, Pm: 145.0, Sm: 150.36, Eu: 151.96, Gd: 157.25, Tb: 158.93, Dy: 162.50, Ho: 164.93, Er: 167.26, Tm: 168.93, Yb: 173.05, Lu: 174.97, Hf: 178.49, Ta: 180.95, W: 183.84, Re: 186.21, Os: 190.23, Ir: 192.22, Pt: 195.08, Au: 196.97, Hg: 200.59, Tl: 204.38, Pb: 207.2, Bi: 208.98, Po: 209.0, At: 210.0, Rn: 222.0, Fr: 223.0, Ra: 226.0, Ac: 227.0, Th: 232.04, Pa: 231.04, U: 238.03, Np: 237.0, Pu: 244.0, Am: 243.0, Cm: 247.0, Bk: 247.0, Cf: 251.0, Es: 252.0, Fm: 257.0, Md: 258.0, No: 259.0, Lr: 262.0, Rf: 267.0, Db: 268.0, Sg: 269.0, Bh: 270.0, Hs: 269.0, Mt: 278.0, Ds: 281.0, Rg: 282.0, Cn: 285.0, Nh: 286.0, Fl: 289.0, Mc: 290.0, Lv: 293.0, Ts: 294.0, Og: 294.0 };
      function parseGroup(str, pos) {
        let i = pos, counts = {};
        while (i < str.length && str[i] !== ')' && str[i] !== ']') {
          if (str[i] === '(' || str[i] === '[') {
            const inner = parseGroup(str, i + 1);
            i = inner.i;
            if (i >= str.length || (str[i] !== ')' && str[i] !== ']')) throw new Error('Unmatched bracket in: ' + str);
            i++;
            let numStr = '';
            while (i < str.length && str[i] >= '0' && str[i] <= '9') numStr += str[i++];
            const mult = numStr ? parseInt(numStr, 10) : 1;
            for (const sym in inner.counts) counts[sym] = (counts[sym] || 0) + inner.counts[sym] * mult;
          } else if (str[i] >= 'A' && str[i] <= 'Z') {
            let sym = str[i++];
            while (i < str.length && str[i] >= 'a' && str[i] <= 'z') sym += str[i++];
            if (!atomicMasses[sym]) throw new Error('Unknown element: ' + sym);
            let numStr = '';
            while (i < str.length && str[i] >= '0' && str[i] <= '9') numStr += str[i++];
            const num = numStr ? parseInt(numStr, 10) : 1;
            counts[sym] = (counts[sym] || 0) + num;
          } else {
            throw new Error('Invalid character: ' + str[i]);
          }
        }
        return { counts, i };
      }
      function parseFormula(f) {
        if (!f) return {};
        const segments = f.split(/[·.]/).map(s => s.trim()).filter(s => s.length > 0);
        if (segments.length === 0) return { error: 'Invalid formula' };
        const result = {};
        try {
          for (const seg of segments) {
            let idx = 0, coefStr = '';
            while (idx < seg.length && seg[idx] >= '0' && seg[idx] <= '9') coefStr += seg[idx++];
            const coef = coefStr ? parseInt(coefStr, 10) : 1;
            const rest = seg.slice(idx);
            if (!rest) throw new Error('Invalid formula segment: ' + seg);
            const { counts, i } = parseGroup(rest, 0);
            if (i !== rest.length) throw new Error('Unmatched bracket in: ' + rest);
            for (const sym in counts) result[sym] = (result[sym] || 0) + counts[sym] * coef;
          }
        } catch (e) {
          return { error: e.message };
        }
        return result;
      }
      function molarMassOf(formulaStr) {
        const counts = parseFormula(formulaStr);
        if (counts.error) return { error: counts.error };
        let total = 0, any = false;
        for (const sym in counts) { total += atomicMasses[sym] * counts[sym]; any = true; }
        if (!any) return { error: 'Enter a formula' };
        return { mass: total };
      }

      // ---- sci notation formatter ----
      function sci(x, sig) {
        sig = sig || 4;
        if (!isFinite(x) || isNaN(x)) return '—';
        if (x === 0) return '0';
        const neg = x < 0; x = Math.abs(x);
        const exp = Math.floor(Math.log10(x));
        const mant = x / Math.pow(10, exp);
        let mantStr = mant.toFixed(sig - 1);
        // handle rounding pushing mantissa to 10.xxx
        if (parseFloat(mantStr) >= 10) { mantStr = (parseFloat(mantStr) / 10).toFixed(sig - 1); }
        return (neg ? '-' : '') + mantStr + ' × 10' + supNum(exp);
      }
      function supNum(n) {
        const map = { '0': '⁰', '1': '¹', '2': '²', '3': '³', '4': '⁴', '5': '⁵', '6': '⁶', '7': '⁷', '8': '⁸', '9': '⁹', '-': '⁻' };
        return String(n).split('').map(c => map[c] || c).join('');
      }

      // ---- calculator ----
      let mode = 'n';
      function switchMode(m) {
        mode = m;
        el('mode-n').className = m === 'n' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-mass').className = m === 'mass' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('n-fields').className = m === 'n' ? 'grid gap-4 sm:grid-cols-2' : 'hidden';
        el('mass-fields').className = m === 'mass' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid-cols-1 gap-4 sm:grid-cols-2';
        el('lab-1').textContent = 'Particles';
        el('lab-2').textContent = 'Moles';
        el('lab-3').textContent = m === 'n' ? 'Particles (exact)' : 'Molar mass';
        update();
      }

      function update() {
        el('av-err').textContent = '';
        ['r-1', 'r-2', 'r-3'].forEach((id) => (el(id).textContent = '—'));
        if (mode === 'n') {
          const molesVal = el('moles').value.trim();
          const particlesVal = el('particles').value.trim();
          const nHas = molesVal !== '' && !isNaN(parseFloat(molesVal));
          const pHas = particlesVal !== '' && !isNaN(parseFloat(particlesVal));
          if (!nHas && !pHas) return;
          let n, N;
          if (nHas) { n = parseFloat(molesVal); N = n * NA; }
          else { N = parseFloat(particlesVal); n = N / NA; }
          if (n < 0 || N < 0) { el('av-err').textContent = 'Values cannot be negative.'; return; }
          el('r-1').textContent = sci(N);
          el('r-2').textContent = fmt(n) + ' mol';
          el('r-3').textContent = N.toExponential(6).replace('e+', ' × 10^');
        } else {
          const f = el('formula').value.trim();
          const mass = parseFloat(el('mass').value);
          if (!f) { el('av-err').textContent = 'Enter a chemical formula.'; return; }
          const mm = molarMassOf(f);
          if (mm.error) { el('av-err').textContent = mm.error; return; }
          if (isNaN(mass) || mass < 0) { el('av-err').textContent = 'Enter a valid, non-negative mass.'; return; }
          const n = mass / mm.mass;
          const N = n * NA;
          el('r-1').textContent = sci(N);
          el('r-2').textContent = fmt(n) + ' mol';
          el('r-3').textContent = fmt(mm.mass) + ' g/mol';
        }
      }
      el('mode-n').addEventListener('click', () => switchMode('n'));
      el('mode-mass').addEventListener('click', () => switchMode('mass'));
      ['moles', 'particles', 'formula', 'mass'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let scene3d = null;
      const MAX_P = 130;

      function sliderMoles() { return parseFloat(el('n-slider').value); }
      function onSlider() {
        const n = sliderMoles();
        const N = n * NA;
        el('out-nmol').textContent = n.toFixed(6) + ' mol';
        el('out-nparticles').textContent = sci(N);
        try { if (scene3d) scene3d.update(); } catch (e) {}
      }
      el('n-slider').addEventListener('input', onSlider);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const molAmounts = [0.001, 0.01, 0.1, 1.0];
        charts.log = new Chart(el('chart-log'), {
          type: 'bar',
          data: {
            labels: molAmounts.map(m => m + ' mol'),
            datasets: [{ label: 'Particles', data: molAmounts.map(m => m * NA), backgroundColor: '#6366f1', borderRadius: 4 }],
          },
          options: Object.assign({}, base, {
            scales: {
              y: { type: 'logarithmic', title: { display: true, text: 'Particles (log scale)' } },
            },
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => sci(ctx.parsed.y) + ' particles' } } },
          }),
        });
        charts.mass = new Chart(el('chart-mass'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Particles', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0.2, pointRadius: 0 }] },
          options: Object.assign({}, base, {
            scales: { x: { title: { display: true, text: 'Mass (g)' } }, y: { title: { display: true, text: 'Particles' }, beginAtZero: true } },
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => sci(ctx.parsed.y) + ' particles' } } },
          }),
        });
        charts.ready = true;
        updateMassChart();
      }
      function updateMassChart() {
        if (!charts.ready) return;
        const f = el('formula') && el('formula').value.trim() ? el('formula').value.trim() : 'H2O';
        const mm = molarMassOf(f);
        const M = mm.error ? 18.015 : mm.mass;
        const L = [], D = [];
        for (let g = 0; g <= 50.001; g += 2.5) {
          L.push(g.toFixed(1));
          D.push((g / M) * NA);
        }
        charts.mass.data.labels = L;
        charts.mass.data.datasets[0].data = D;
        charts.mass.update();
      }

      // ---- interactive illustrative particle cluster ----
      function initScene() {
        const c = el('particles3d'); if (!c) throw new Error('no particles container');
        const s = makeScene(c, 8, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        const geo = new THREE.SphereGeometry(0.28, 12, 12);
        const mat = new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.4 });
        const spheres = [];
        for (let i = 0; i < MAX_P; i++) {
          const sph = new THREE.Mesh(geo, mat);
          const R = 1.3 + Math.cbrt(MAX_P) * 0.55;
          const gAngle = Math.PI * (3 - Math.sqrt(5));
          const yFrac = MAX_P > 1 ? 1 - (i / (MAX_P - 1)) * 2 : 0;
          const rad = Math.sqrt(Math.max(0, 1 - yFrac * yFrac));
          const theta = gAngle * i;
          sph.position.set(Math.cos(theta) * rad * R, yFrac * R, Math.sin(theta) * rad * R);
          s.scene.add(sph);
          spheres.push(sph);
        }
        function update() {
          // fixed illustrative cluster — always shows all MAX_P spheres regardless of slider value,
          // because the real particle count (10^20+) can never be rendered literally.
          spheres.forEach((sph) => { sph.visible = true; });
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        scene3d = { update, resize: s.resize };
        update();
      }

      function boot() {
        try { switchMode('n'); } catch (e) { console.error('[avogadro] calc init failed', e); }
        try { onSlider(); } catch (e) { console.error('[avogadro] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[avogadro] charts failed', e); }
        if (window.THREE) {
          try { initScene(); } catch (e) { console.error('[avogadro] scene failed', e); el('particles3d-fallback').classList.remove('hidden'); }
        } else { el('particles3d-fallback').classList.remove('hidden'); }
        mountResize([scene3d]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
