---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'DNA Concentration (A260) Calculator';
const description = 'DNA/RNA concentration calculator with a live 3D spectrophotometer diagram and charts. Convert A260 absorbance into nucleic acid concentration using the Beer-Lambert relationship, plus A260/A280 and A260/A230 purity ratios, with worked examples.';
const intro = 'Enter an A260 absorbance reading (and dilution factor) to find nucleic acid concentration, using the standard conversion factors for double-stranded DNA, single-stranded DNA, or RNA. Two 3D diagrams compare a dilute sample to a concentrated one, and charts show the linear relationship between absorbance and concentration for each nucleic acid type.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is A260?', a: 'A260 is the absorbance of a sample at a wavelength of 260 nanometres, the wavelength nucleic acids absorb most strongly due to their purine and pyrimidine bases — it\'s the standard measurement for estimating DNA or RNA concentration.' },
  { q: 'Why do dsDNA, ssDNA, and RNA use different conversion factors?', a: 'The exact absorbance-to-concentration relationship depends on subtle structural differences — double-stranded DNA has some UV absorbance quenched by base stacking, so its factor (50 ng/µL per A260 unit) differs from single-stranded DNA (33) and RNA (40), which stack less and absorb slightly more per unit mass.' },
  { q: 'What is the A260/A280 ratio used for?', a: 'A260/A280 checks for protein contamination, since proteins absorb strongly at 280 nm. Pure DNA typically reads about 1.8, and pure RNA about 2.0 — a noticeably lower ratio suggests protein contamination in the sample.' },
  { q: 'What is the A260/A230 ratio used for?', a: 'A260/A230 checks for contamination by organic compounds and chaotropic salts (like phenol or guanidinium, often left over from extraction), which absorb around 230 nm. A good ratio is typically 2.0-2.2 — a lower ratio suggests carryover contamination from the extraction process.' },
  { q: 'Why does the dilution factor matter?', a: "Absorbance readings are only accurate within a linear range (roughly 0.1–1.0 for most spectrophotometers) — samples are often diluted before measuring, so the dilution factor must be multiplied back in to get the original, undiluted sample's true concentration." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the DNA Concentration (A260) Calculator',
  description: 'Convert an A260 absorbance reading into nucleic acid concentration, with purity ratio checks.',
  steps: [
    { name: 'Enter A260 and dilution factor', text: 'Type the measured absorbance and how much the sample was diluted before measuring.' },
    { name: 'Choose the nucleic acid type', text: 'Select dsDNA, ssDNA, or RNA — each uses a different conversion factor.' },
    { name: 'Check purity ratios', text: 'Optionally enter A280 and A230 to see the A260/A280 and A260/A230 purity ratios.' },
  ],
};

const formulas = [
  { expr: 'Concentration (ng/µL) = A260 × dilution factor × conversion factor', note: 'conversion factor: dsDNA=50, ssDNA=33, RNA=40 ng/µL per A260 unit' },
  { expr: 'A260/A280 ratio', note: 'protein contamination check — pure DNA ≈1.8, pure RNA ≈2.0' },
  { expr: 'A260/A230 ratio', note: 'organic/chaotropic salt contamination check — good samples ≈2.0-2.2' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a diluted dsDNA sample', tone: 'slate',
    given: 'A dsDNA sample was diluted 1:10 before measuring, giving A260 = 0.75.',
    rows: [
      { label: 'Formula:', value: 'Concentration = A260 × dilution factor × 50' },
      { label: 'Substitute:', value: 'Concentration = 0.75 × 10 × 50' },
      { label: 'Result:', value: 'Concentration = 375 ng/µL', full: true },
    ],
    note: 'Multiplying the dilution factor back in is essential — forgetting it is one of the most common errors when reporting nucleic acid concentration from a spectrophotometer reading.',
  },
  {
    title: 'Worked example 2 — an RNA sample with a purity check', tone: 'amber',
    given: 'An undiluted RNA sample reads A260 = 1.2 and A280 = 0.60.',
    rows: [
      { label: 'Concentration:', value: 'Concentration = 1.2 × 1 × 40 = 48 ng/µL' },
      { label: 'A260/A280 ratio:', value: '1.2 / 0.60 = 2.0 — matches the expected value for pure RNA' },
      { label: 'Interpretation:', value: 'No significant protein contamination detected', full: true },
    ],
    note: "A ratio noticeably below 2.0 for RNA (or below 1.8 for DNA) would signal protein contamination requiring further sample cleanup before use in sensitive downstream applications.",
  },
];

const comparison = {
  heading: 'Conversion factors and expected purity ratios by nucleic acid type',
  note: 'Each nucleic acid type has its own standard conversion factor and expected pure-sample ratio.',
  headers: [{ label: 'Type' }, { label: 'ng/µL per A260 unit' }, { label: 'Expected A260/A280' }],
  rows: [
    ['dsDNA ★', '50', '≈1.8'],
    ['ssDNA', '33', '≈1.8'],
    ['RNA', '40', '≈2.0'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 1). Selecting the wrong nucleic acid type is a common source of concentration errors — always confirm whether the sample is DNA or RNA before applying a conversion factor.',
};

const realWorld = [
  { emoji: '🧬', title: 'PCR and sequencing sample prep', body: 'Every PCR reaction and sequencing run requires a precisely known amount of template DNA — spectrophotometric quantification is the fast, routine first check before more expensive downstream steps.' },
  { emoji: '🔬', title: 'Quality control in molecular labs', body: 'The A260/A280 and A260/A230 purity ratios are standard quality checkpoints reported alongside concentration in essentially every DNA/RNA extraction protocol, flagging contaminated samples before they\'re used further.' },
  { emoji: '💉', title: 'Clinical and diagnostic genomics', body: 'Genetic testing labs quantify and check the purity of extracted patient DNA/RNA samples before running diagnostic assays, since contaminated or under-concentrated samples can produce unreliable results.' },
  { emoji: '🧪', title: 'RNA-seq and gene expression studies', body: "RNA integrity and concentration checks (including A260 measurements) are a mandatory first step before RNA sequencing, since low-quality or degraded RNA input can compromise an entire sequencing run." },
];

const misconceptions = [
  { claim: '"A260 absorbance directly gives you the concentration in ng/µL without any conversion."', truth: "A260 is just a raw absorbance reading — it must be multiplied by the appropriate conversion factor (which differs for dsDNA, ssDNA, and RNA) and by the dilution factor to arrive at an actual concentration value." },
  { claim: '"A260/A280 near 1.8 always means the sample is 100% pure with no other issues."', truth: "A260/A280 only screens for protein contamination specifically — it says nothing about degradation, salt contamination (which A260/A230 checks instead), or whether the sample is genuinely intact, undegraded nucleic acid." },
  { claim: '"Using the same conversion factor for DNA and RNA gives an acceptable approximation."', truth: "The dsDNA (50) and RNA (40) factors differ by 25%, which is far too large an error to ignore for quantitative work — using the wrong factor will systematically over- or under-estimate concentration." },
  { claim: '"A higher A260/A230 ratio is always better, with no upper limit to worry about."', truth: 'While a low A260/A230 does indicate contamination, ratios noticeably above the typical 2.0-2.2 range can also signal measurement or blank-reference issues — the expected range itself is the target, not simply "as high as possible."' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 17, "Biotechnology and Genomics" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/17-1-biotechnology" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Thermo Fisher Scientific (NanoDrop)</strong> — standard nucleic acid quantification conversion factors and purity ratio guidelines.' },
  { html: '<strong>Sambrook &amp; Russell, <em>Molecular Cloning: A Laboratory Manual</em></strong> — Nucleic acid quantification chapter.' },
];
const sourcesNote = 'Conversion factors: dsDNA=50, ssDNA=33, RNA=40 ng/µL per A260 unit (standard spectrophotometric convention). Results are rounded for display.';

const howToUse = [
  { title: 'Enter A260 and dilution factor', body: 'Type the absorbance reading and how much the sample was diluted (use 1 if undiluted).' },
  { title: 'Select the nucleic acid type', body: 'Choose dsDNA, ssDNA, or RNA to apply the correct conversion factor.' },
  { title: 'Check purity (optional)', body: 'Enter A280 and A230 to see the standard purity ratios.' },
];

const related = [
  { href: '/tools/gc-content-calculator', emoji: '🧫', title: 'GC Content Calculator', desc: 'Percentage of G and C bases in a sequence.' },
  { href: '/tools/dna-melting-temperature-calculator', emoji: '🌡️', title: 'DNA Melting Temperature Calculator', desc: 'Wallace rule Tm from sequence composition.' },
  { href: '/tools/molarity-calculator', emoji: '🧪', title: 'Molarity Calculator', desc: 'Solution concentration from moles and volume.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="nucleic acids absorb UV light at 260nm in direct proportion to how much of them is present, so a single absorbance reading — scaled by a nucleic-acid-specific conversion factor — is enough to estimate concentration in seconds, without running a single gel."
  howIntro="The Beer-Lambert law describes how a solution's absorbance scales linearly with the concentration of whatever's absorbing the light — for nucleic acids, that means A260 absorbance scales directly with how much DNA or RNA is dissolved in the sample. Because double-stranded DNA, single-stranded DNA, and RNA each absorb slightly differently at 260nm (due to how their strands stack and pair), each nucleic acid type has its own standard conversion factor for translating absorbance into a concentration in nanograms per microlitre. Two extra readings — A280 and A230 — flag common contaminants: proteins absorb strongly at 280nm, while leftover extraction chemicals absorb around 230nm, so comparing each to A260 gives a fast purity check alongside the concentration itself."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where DNA/RNA concentration measurement actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">A260</span>
        <input id="a260" type="number" step="any" value="0.75" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Dilution factor</span>
        <input id="dilution" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Nucleic acid type</span>
        <select id="type" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="50">dsDNA (×50)</option>
          <option value="33">ssDNA (×33)</option>
          <option value="40">RNA (×40)</option>
        </select></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">A280 (optional, for purity)</span>
        <input id="a280" type="number" step="any" placeholder="e.g. 0.42" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">A230 (optional, for purity)</span>
        <input id="a230" type="number" step="any" placeholder="e.g. 0.36" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Concentration</div><div id="r-conc" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">A260/A280</div><div id="r-r280" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">A260/A230</div><div id="r-r230" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="dc-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Dilute vs. concentrated sample</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-dilute" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Dilute sample</h3>
          <p class="mt-1 text-sm text-slate-600">Fewer nucleic acid molecules — less UV light absorbed, a lower A260 reading.</p>
        </div>
        <div>
          <div id="diag-concentrated" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Concentrated sample</h3>
          <p class="mt-1 text-sm text-slate-600">Many more nucleic acid molecules — much more UV light absorbed, a higher A260 reading.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Absorbance-to-concentration charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Concentration vs. A260 (all three types)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-linear"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Purity ratio reference ranges</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-purity"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('dc-err').textContent = '';
        el('r-conc').textContent = '—'; el('r-r280').textContent = '—'; el('r-r230').textContent = '—';
        const a260 = parseFloat(el('a260').value), dil = parseFloat(el('dilution').value), factor = parseFloat(el('type').value);
        if (isNaN(a260) || isNaN(dil)) return;
        if (a260 < 0 || dil <= 0) { el('dc-err').textContent = 'A260 cannot be negative; dilution factor must be positive.'; return; }
        const conc = a260 * dil * factor;
        el('r-conc').textContent = fmt(conc) + ' ng/µL';
        const a280 = parseFloat(el('a280').value);
        const a230 = parseFloat(el('a230').value);
        if (!isNaN(a280) && a280 > 0) el('r-r280').textContent = fmt(a260 / a280);
        if (!isNaN(a230) && a230 > 0) el('r-r230').textContent = fmt(a260 / a230);
      }
      ['a260', 'dilution', 'type', 'a280', 'a230'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const a260Labels = [];
        const dsData = [], ssData = [], rnaData = [];
        for (let a = 0; a <= 1.5; a += 0.15) { a260Labels.push(a.toFixed(2)); dsData.push(+(a * 50).toFixed(1)); ssData.push(+(a * 33).toFixed(1)); rnaData.push(+(a * 40).toFixed(1)); }
        new Chart(el('chart-linear'), {
          type: 'line',
          data: {
            labels: a260Labels,
            datasets: [
              { label: 'dsDNA', data: dsData, borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
              { label: 'RNA', data: rnaData, borderColor: '#f59e0b', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
              { label: 'ssDNA', data: ssData, borderColor: '#10b981', backgroundColor: 'transparent', tension: 0, pointRadius: 0 },
            ],
          },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'A260' } }, y: { title: { display: true, text: 'Concentration (ng/µL)' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        new Chart(el('chart-purity'), {
          type: 'bar',
          data: { labels: ['DNA A260/A280', 'RNA A260/A280', 'A260/A230 (both)'], datasets: [{ label: 'Expected ratio', data: [1.8, 2.0, 2.1], backgroundColor: ['#6366f1', '#f59e0b', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Expected ratio' } } }, plugins: { legend: { display: false } } }),
        });
      }

      function sampleScene(container, count) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const cuvette = new THREE.Mesh(new THREE.BoxGeometry(1.6, 3, 1.6), new THREE.MeshBasicMaterial({ color: 0x94a3b8, wireframe: true }));
        s.scene.add(cuvette);
        for (let i = 0; i < count; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.12, 10, 8), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          m.position.set((Math.random() - 0.5) * 1.3, (Math.random() - 0.5) * 2.6, (Math.random() - 0.5) * 1.3);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagDilute = null, diagConcentrated = null;
      function initDiagDilute() { const c = el('diag-dilute'); if (!c) throw new Error('no container'); diagDilute = sampleScene(c, 8); }
      function initDiagConcentrated() { const c = el('diag-concentrated'); if (!c) throw new Error('no container'); diagConcentrated = sampleScene(c, 40); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[dna-concentration] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagDilute(); } catch (e) { console.error('[dna-concentration] dilute diagram failed', e); }
          try { initDiagConcentrated(); } catch (e) { console.error('[dna-concentration] concentrated diagram failed', e); }
        }
        mountResize([diagDilute, diagConcentrated]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
