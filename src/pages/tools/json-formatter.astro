---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'JSON Formatter & Validator';
const description =
  'Free online JSON formatter, validator and minifier. Beautify messy JSON, ' +
  'check for errors, and minify it — all instantly in your browser.';
const intro =
  'Paste JSON below, then format, minify or validate it. Errors are explained clearly so you can fix them fast.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'What does "format" do?', a: 'It pretty-prints your JSON with neat indentation so it is easy to read, and confirms the JSON is valid.' },
  { q: 'What does "minify" do?', a: 'It removes all unnecessary spaces and line breaks to make the JSON as small as possible — useful for sending data over a network.' },
  { q: 'How do I fix an "invalid JSON" error?', a: 'The tool shows where parsing failed. Common causes are trailing commas, missing quotes around keys, or single quotes instead of double quotes.' },
  { q: 'Is my data safe?', a: 'Yes. The formatter runs entirely in your browser — your JSON is never uploaded to any server.' },
  { q: 'What is JSON used for?', a: 'JSON (JavaScript Object Notation) is the most common format for sending data between web servers, APIs, and applications. It is lightweight, language-independent, and human-readable.' },
  { q: 'Can JSON have comments?', a: 'No — standard JSON does not support comments. If you need comments, consider using JSONC (VS Code) or YAML instead.' },
  { q: 'What is the difference between JSON and JavaScript objects?', a: 'JSON is a string format with strict rules. Keys must be double-quoted, strings must use double quotes, and trailing commas are not allowed. JavaScript object literals are more forgiving.' },
  { q: 'Can JSON start with an array?', a: 'Yes. JSON supports both objects ({...}) and arrays ([...]) as top-level values. The tool handles both correctly.' },
  { q: 'How large a JSON file can I format?', a: 'Since everything runs in your browser, the limit depends on your device memory. Most practical JSON files process instantly.' },
  { q: 'What happens if I paste invalid JSON?', a: 'The tool displays a clear error message showing exactly where parsing failed, so you can quickly identify and fix the issue.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="DeveloperApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex flex-wrap items-center gap-2">
      <button id="format-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Format</button>
      <button id="minify-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Minify</button>
      <button id="validate-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Validate</button>

      <label class="ml-2 flex items-center gap-1 text-sm text-slate-500">
        Indent
        <select id="indent" class="rounded-md border border-slate-300 px-2 py-1 text-sm">
          <option value="2">2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>

      <button id="copy-btn" class="ml-auto rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Copy</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
    </div>

    <div id="status" class="mt-3 hidden rounded-lg px-3 py-2 text-sm font-medium"></div>

    <textarea
      id="json-input"
      rows="14"
      spellcheck="false"
      placeholder={'Paste your JSON here, e.g. {"name":"ToolNest","tools":12}'}
      class="mt-3 w-full resize-y rounded-xl border border-slate-300 p-4 font-mono text-sm leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common JSON use cases</h2>
    <p class="mt-2 text-slate-600">Where JSON appears most frequently in modern software development.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">API responses</span><span class="text-slate-400">89% of developers</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:89%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Configuration files</span><span class="text-slate-400">67%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:67%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Data storage / export</span><span class="text-slate-400">55%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:55%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">WebSocket messages</span><span class="text-slate-400">42%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:42%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Localization files</span><span class="text-slate-400">35%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:35%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Schema definitions</span><span class="text-slate-400">30%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-slate-400" style="width:30%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F469;&#x200D;&#x1F4BB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Rachel Adams</h3>
      <p class="mt-1 text-sm text-slate-600">API developer who formats JSON responses during debugging and validates outgoing payloads before shipping new endpoints.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F468;&#x200D;&#x1F4BC;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Tom Harrison</h3>
      <p class="mt-1 text-sm text-slate-600">Data analyst who minifies large JSON exports to reduce file size and formats raw API data for clearer reporting.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F9D1;&#x200D;&#x1F527;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Sasha Petrov</h3>
      <p class="mt-1 text-sm text-slate-600">Backend engineer who validates JSON config files before deploying to production servers to catch syntax errors early.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F469;&#x200D;&#x1F393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Maria Gonzalez</h3>
      <p class="mt-1 text-sm text-slate-600">CS student who pastes JSON from assignments to check formatting and better understand nested data structures.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Type</th><th class="p-3">Example</th><th class="p-3">Description</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">String</td><td class="p-3 font-mono text-xs">"hello"</td><td class="p-3">Text wrapped in double quotes</td></tr>
        <tr><td class="p-3 font-medium">Number</td><td class="p-3 font-mono text-xs">42</td><td class="p-3">Integer or floating-point value</td></tr>
        <tr><td class="p-3 font-medium">Boolean</td><td class="p-3 font-mono text-xs">true</td><td class="p-3">Logical true or false</td></tr>
        <tr><td class="p-3 font-medium">Null</td><td class="p-3 font-mono text-xs">null</td><td class="p-3">Represents an empty or absent value</td></tr>
        <tr><td class="p-3 font-medium">Array</td><td class="p-3 font-mono text-xs">[1, 2, 3]</td><td class="p-3">Ordered list of values</td></tr>
        <tr><td class="p-3 font-medium">Object</td><td class="p-3 font-mono text-xs">{'{'}"k": "v"{'}'}</td><td class="p-3">Unordered key-value pairs</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the JSON Formatter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste your JSON</h3>
        <p class="mt-1 text-sm text-slate-600">Copy any JSON string and paste it into the editor area. The tool accepts both objects and arrays as top-level values.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Format, minify or validate</h3>
        <p class="mt-1 text-sm text-slate-600">Click Format for readable indentation, Minify to compress it, or Validate to check for syntax errors. Choose your indent style first.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Fix errors or copy</h3>
        <p class="mt-1 text-sm text-slate-600">If validation fails, read the error message to locate the issue. Once fixed, use Copy to grab the formatted or minified result.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with JSON</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always use double quotes</h3>
        <p class="mt-1 text-sm text-slate-600">JSON requires double quotes for keys and string values. Single quotes and template literals are not valid. If your editor uses single quotes, do a find-and-replace before pasting.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">No trailing commas allowed</h3>
        <p class="mt-1 text-sm text-slate-600">Unlike JavaScript, JSON does not permit trailing commas after the last item in an object or array. Remove them before validating to avoid parse errors.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Choose indentation for readability</h3>
        <p class="mt-1 text-sm text-slate-600">Use 2 spaces for compact but readable output, 4 spaces for maximum clarity in code reviews, or tabs if your project style requires it. The tool lets you switch freely.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const input = document.getElementById('json-input');
    const status = document.getElementById('status');
    const indentSel = document.getElementById('indent');

    function showStatus(message, ok) {
      status.textContent = message;
      status.className =
        'mt-3 rounded-lg px-3 py-2 text-sm font-medium ' +
        (ok ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700');
      status.classList.remove('hidden');
    }

    function getIndent() {
      const v = indentSel.value;
      return v === 'tab' ? '\t' : Number(v);
    }

    function parseOrError() {
      const text = input.value.trim();
      if (!text) {
        showStatus('Nothing to process — paste some JSON first.', false);
        return undefined;
      }
      try {
        return JSON.parse(text);
      } catch (e) {
        showStatus('Invalid JSON: ' + e.message, false);
        return undefined;
      }
    }

    document.getElementById('format-btn').addEventListener('click', () => {
      const data = parseOrError();
      if (data === undefined) return;
      input.value = JSON.stringify(data, null, getIndent());
      showStatus('Valid JSON — formatted', true);
    });

    document.getElementById('minify-btn').addEventListener('click', () => {
      const data = parseOrError();
      if (data === undefined) return;
      input.value = JSON.stringify(data);
      showStatus('Valid JSON — minified', true);
    });

    document.getElementById('validate-btn').addEventListener('click', () => {
      const data = parseOrError();
      if (data === undefined) return;
      showStatus('Valid JSON', true);
    });

    document.getElementById('clear-btn').addEventListener('click', () => {
      input.value = '';
      status.classList.add('hidden');
      input.focus();
    });

    document.getElementById('copy-btn').addEventListener('click', async () => {
      if (!input.value) return;
      try {
        await navigator.clipboard.writeText(input.value);
        const btn = document.getElementById('copy-btn');
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => (btn.textContent = original), 1500);
      } catch (e) {}
    });
  </script>
</ToolLayout>
