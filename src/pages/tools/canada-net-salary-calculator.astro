        ]},
        'PE': { name: 'Prince Edward Island', brackets: [
          { min: 0, max: 31984, rate: 0.098 },
          { min: 31984, max: 63969, rate: 0.138 },
          { min: 63969, max: Infinity, rate: 0.167 }
        ]}
      };

      const CPP_RATE = 0.0595;
      const QPP_RATE = 0.064;
      const CPP_MAX_EARNINGS = 71300;
      const EI_RATE = 0.0166;
      const EI_MAX_EARNINGS = 65700;
      const FEDERAL_BPA_CREDIT = 2419;

      function calcBracketTax(income, brackets) {
        let tax = 0;
        let prev = 0;
        for (const b of brackets) {
          if (income > prev) {
            const taxable = Math.min(income, b.max) - prev;
            tax += taxable * b.rate;
          }
          if (income <= b.max) break;
          prev = b.max;
        }
        return tax;
      }

      function getMarginalRate(income, brackets) {
        for (const b of brackets) {
          if (income > b.min && income <= b.max) return b.rate;
        }
        return brackets[brackets.length - 1].rate;
      }

      function calculate() {
        const salary = parseFloat(el('salary').value);
        const province = el('province').value;

        if (isNaN(salary) || salary < 0) {
          el('result').classList.add('hidden');
          return;
        }

        const provData = PROVINCIAL_RATES[province];

        const federalTaxRaw = calcBracketTax(salary, FEDERAL_BRACKETS);
        const federalTax = Math.max(0, federalTaxRaw - FEDERAL_BPA_CREDIT);
        const provincialTax = calcBracketTax(salary, provData.brackets);

        const isQc = province === 'QC';
        const cppRate = isQc ? QPP_RATE : CPP_RATE;
        const cpp = Math.min(salary, CPP_MAX_EARNINGS) * cppRate;

        const ei = Math.min(salary, EI_MAX_EARNINGS) * EI_RATE;

        const totalDeductions = federalTax + provincialTax + cpp + ei;
        const netIncome = salary - totalDeductions;

        const federalMarginal = getMarginalRate(salary, FEDERAL_BRACKETS);
        const provincialMarginal = getMarginalRate(salary, provData.brackets);
        const marginalTotal = federalMarginal + provincialMarginal;

        const monthly = netIncome / 12;
        const semiMonthly = netIncome / 24;
        const biweekly = netIncome / 26;
        const weekly = netIncome / 52;
        const hourly = netIncome / (40 * 52);

        el('r-gross').textContent = fmt(salary);
        el('r-federal').textContent = fmt(federalTax);
        el('r-provincial').textContent = fmt(provincialTax);
        el('r-cpp').textContent = fmt(cpp);
        el('r-ei').textContent = fmt(ei);
        el('r-net').textContent = fmt(netIncome);
        el('r-marginal').textContent = (marginalTotal * 100).toFixed(1) + '%';
        el('r-monthly').textContent = fmt(monthly);
        el('r-semi').textContent = fmt(semiMonthly);
        el('r-biweekly').textContent = fmt(biweekly);
        el('r-weekly').textContent = fmt(weekly);
        el('r-hourly').textContent = fmt(hourly);

        el('result').classList.remove('hidden');
      }

      el('calcBtn').addEventListener('click', calculate);
      el('salary').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') calculate();
      });
    });
  </script>
