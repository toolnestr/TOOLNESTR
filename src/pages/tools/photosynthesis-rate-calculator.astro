---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Photosynthesis Rate Calculator';
const description = 'Photosynthesis rate calculator with a live 3D leaf diagram and charts. Solve gross and net photosynthetic O2 output from light intensity using a saturation curve, plus the light compensation point, with worked examples.';
const intro = "Solve gross photosynthetic rate from light intensity using a saturation curve, rate = Rmax×I/(Kl+I), then subtract respiration to find net O2 output and the light compensation point where the two exactly balance. Two 3D diagrams compare a leaf in dim light to one in bright, saturating light, and charts show the classic photosynthesis-light-intensity curve.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'How does light intensity affect photosynthesis rate?', a: "At low light, photosynthesis rate rises almost linearly with light intensity because light is the limiting factor. As intensity keeps increasing, the rate levels off (saturates) once some other factor — usually CO2 availability or the capacity of the light-independent reactions — becomes limiting instead." },
  { q: 'What is the light compensation point?', a: "The light compensation point is the light intensity at which a plant's gross photosynthetic O2 production exactly equals its own respiratory O2 consumption — below this point, the plant is a net O2 consumer (net CO2 producer); above it, a net O2 producer." },
  { q: 'What is the difference between gross and net photosynthesis?', a: 'Gross photosynthesis is the total rate of O2 produced by the light-dependent and light-independent reactions. Net photosynthesis subtracts the O2 consumed by the plant\'s own ongoing cellular respiration, giving the actual O2 released to the environment.' },
  { q: 'Why does the photosynthesis rate curve level off instead of increasing forever?', a: "Beyond a certain light intensity, the rate-limiting step shifts away from light capture — the plant's enzymes (like RuBisCO) and CO2 supply can only process a finite amount of captured light energy per second, capping the maximum possible rate (Rmax)." },
  { q: 'Do shade plants and sun plants have different light compensation points?', a: "Yes — shade-adapted plants typically evolve a lower light compensation point (often coupled with lower respiration rate) so they can achieve net positive photosynthesis even in dim light, while sun-adapted plants often have a higher compensation point but a higher maximum rate (Rmax) in bright light." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Photosynthesis Rate Calculator',
  description: 'Solve gross and net photosynthesis rate from light intensity, plus the light compensation point.',
  steps: [
    { name: 'Enter Rmax and Kl', text: 'Maximum photosynthetic rate and the light intensity at half that maximum.' },
    { name: 'Enter respiration rate', text: 'The plant\'s constant background O2 consumption from cellular respiration.' },
    { name: 'Enter a light intensity', text: 'Gross rate, net rate, and the light compensation point solve instantly.' },
  ],
};

const formulas = [
  { expr: 'Gross rate = Rmax × I / (Kl + I)', note: 'saturation curve — I=light intensity, Kl=intensity at half-maximal rate' },
  { expr: 'Net rate = Gross rate − respiration rate', note: 'actual O2 released to the environment' },
  { expr: 'Compensation point: I where gross rate = respiration rate', note: 'the light intensity at which net O2 exchange is exactly zero' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — gross rate at half-saturating light', tone: 'slate',
    given: 'Rmax = 20 µmol O2/m²/s, Kl = 200 µmol photons/m²/s, evaluated at light intensity I = 200 (exactly equal to Kl).',
    rows: [
      { label: 'Formula:', value: 'Gross rate = Rmax × I / (Kl + I)' },
      { label: 'Substitute:', value: '20 × 200 / (200+200) = 20 × 0.5' },
      { label: 'Result:', value: 'Gross rate = 10 µmol O2/m²/s — exactly half of Rmax', full: true },
    ],
    note: 'This is exactly why Kl is defined as the light intensity giving half-maximal rate — it always produces exactly Rmax/2 by the formula\'s own construction.',
  },
  {
    title: 'Worked example 2 — finding the light compensation point', tone: 'amber',
    given: 'Same Rmax=20, Kl=200, with a respiration rate of 4 µmol O2/m²/s.',
    rows: [
      { label: 'Set gross rate = respiration:', value: '20I/(200+I) = 4' },
      { label: 'Solve for I:', value: '20I = 4(200+I) → 16I = 800 → I = 50' },
      { label: 'Result:', value: 'Light compensation point = 50 µmol photons/m²/s', full: true },
    ],
    note: 'Below 50 µmol photons/m²/s, this plant consumes more O2 through respiration than it produces through photosynthesis — it needs at least this much light just to break even.',
  },
];

const comparison = {
  heading: 'Gross photosynthesis rate across light intensities',
  note: 'Using Rmax=20, Kl=200 from worked example 1 — notice the diminishing returns as light increases.',
  headers: [{ label: 'Light intensity (µmol/m²/s)' }, { label: 'Gross rate (µmol O2/m²/s)' }],
  rows: [
    ['50', '4.0'],
    ['200 ★', '10.0'],
    ['800', '16.0'],
    ['2000', '18.2'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). Doubling light intensity from 200 to 400 would only raise the rate from 10 to 13.3 — the curve\'s diminishing returns are the hallmark of a saturation relationship.',
};

const realWorld = [
  { emoji: '🌾', title: 'Greenhouse and indoor agriculture lighting design', body: 'Controlled-environment agriculture uses photosynthesis-light curves to choose the most cost-effective light intensity — pushing light far beyond the saturation point wastes energy without meaningfully increasing crop growth.' },
  { emoji: '🌊', title: 'Aquatic ecosystem productivity', body: 'Oceanographers use similar light-response curves to estimate phytoplankton photosynthesis rates at different water depths, since light intensity drops sharply with depth.' },
  { emoji: '🌳', title: 'Forest canopy and shade tolerance research', body: "Comparing light compensation points between species helps ecologists predict which plants can survive in a forest's shaded understory versus which require full sun exposure." },
  { emoji: '🌍', title: 'Climate and carbon cycle modeling', body: 'Global carbon cycle models incorporate photosynthesis-light response curves to estimate how much CO2 vegetation removes from the atmosphere under different light and climate conditions.' },
];

const misconceptions = [
  { claim: '"More light always means more photosynthesis, with no limit."', truth: "Photosynthesis rate saturates at high light intensity because some other factor (usually CO2 availability or enzyme capacity) becomes limiting — beyond that point, additional light provides essentially no further benefit." },
  { claim: '"Plants only perform photosynthesis, not respiration."', truth: 'All plant cells constantly perform cellular respiration to generate ATP, exactly like animal cells do — photosynthesis and respiration run simultaneously, and net O2 output is the difference between the two.' },
  { claim: '"A plant below its light compensation point isn\'t doing photosynthesis at all."', truth: "The plant is still photosynthesizing — it just isn't producing enough O2 through photosynthesis to fully offset its own respiratory O2 consumption, resulting in net O2 consumption rather than zero photosynthetic activity." },
  { claim: '"All plants have the same light compensation point."', truth: 'Shade-adapted and sun-adapted plants have evolved measurably different compensation points and maximum rates, reflecting the very different light environments each is adapted to survive in.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 8, "Photosynthesis" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/8-1-overview-of-photosynthesis" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Taiz &amp; Zeiger, <em>Plant Physiology</em></strong> — Photosynthesis light-response curves chapter.' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Photosynthesis chapter.' },
];
const sourcesNote = 'Gross rate = Rmax×I/(Kl+I); net rate = gross − respiration. A simplified model assuming CO2 and temperature are non-limiting. Results are rounded for display.';

const howToUse = [
  { title: 'Enter Rmax and Kl', body: 'Maximum photosynthetic rate and the half-saturation light intensity.' },
  { title: 'Enter respiration rate', body: 'The plant\'s ongoing background O2 consumption.' },
  { title: 'Enter light intensity', body: 'Gross rate, net rate, and the compensation point calculate instantly.' },
];

const related = [
  { href: '/tools/cellular-respiration-calculator', emoji: '🫁', title: 'Cellular Respiration Equation Balancer', desc: 'Glucose oxidation stoichiometry and ATP yield.' },
  { href: '/tools/michaelis-menten-calculator', emoji: '🔑', title: 'Michaelis-Menten Enzyme Kinetics Calculator', desc: 'v = Vmax[S]/(Km+[S]) — enzyme reaction velocity.' },
  { href: '/tools/energy-pyramid-calculator', emoji: '🔺', title: 'Energy Pyramid / 10% Rule Calculator', desc: 'Energy transfer efficiency across trophic levels.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a plant's photosynthesis rate races to keep up with rising light at first, but it can only convert captured light energy into sugar as fast as its own enzymes and CO2 supply allow — so the rate inevitably levels off, no matter how much brighter the light gets."
  howIntro="At low light intensity, every extra photon captured translates almost directly into extra photosynthetic output, since light itself is the bottleneck. As intensity keeps climbing, the plant's light-independent reactions (and CO2 supply) can no longer keep pace with the ever-growing stream of captured light energy, so the rate curve bends and eventually flattens toward a maximum, Rmax. Because the plant's own cells are simultaneously consuming O2 through ordinary respiration, only the excess above that respiratory cost actually escapes to the environment — this is precisely why a real plant needs to clear a minimum light threshold, the light compensation point, before it becomes a net oxygen producer at all."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where photosynthesis rate actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Max rate, Rmax (µmol O2/m²/s)</span>
        <input id="rmax" type="number" step="any" value="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Half-saturation light, Kl</span>
        <input id="kl" type="number" step="any" value="200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Respiration rate (µmol O2/m²/s)</span>
        <input id="resp" type="number" step="any" value="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Light intensity, I</span>
        <input id="light" type="number" step="any" value="200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Gross rate</div><div id="r-gross" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Net rate</div><div id="r-net" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Compensation point</div><div id="r-comp" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="pr-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Dim light vs. saturating light</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-dim" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Dim light</h3>
          <p class="mt-1 text-sm text-slate-600">Few captured photons — photosynthesis rate is light-limited.</p>
        </div>
        <div>
          <div id="diag-bright" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Saturating light</h3>
          <p class="mt-1 text-sm text-slate-600">Abundant photons — the rate has plateaued near its maximum.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Photosynthesis rate charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Gross and net rate vs. light intensity</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-curve"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Sun plant vs. shade plant compensation points</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-compensation"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};

      function gross(I, rmax, kl) { return (rmax * I) / (kl + I); }

      // ---- calculator ----
      function update() {
        el('pr-err').textContent = '';
        el('r-gross').textContent = '—'; el('r-net').textContent = '—'; el('r-comp').textContent = '—';
        const rmax = parseFloat(el('rmax').value), kl = parseFloat(el('kl').value), resp = parseFloat(el('resp').value), light = parseFloat(el('light').value);
        if ([rmax, kl, resp, light].some(isNaN)) return;
        if (rmax <= 0 || kl <= 0 || resp < 0 || light < 0) { el('pr-err').textContent = 'Rmax and Kl must be positive; respiration and light cannot be negative.'; return; }
        if (resp >= rmax) { el('pr-err').textContent = 'Respiration rate must be less than Rmax for a compensation point to exist.'; return; }
        const g = gross(light, rmax, kl);
        el('r-gross').textContent = fmt(g) + ' µmol/m²/s';
        el('r-net').textContent = fmt(g - resp) + ' µmol/m²/s';
        const compPoint = (kl * resp) / (rmax - resp);
        el('r-comp').textContent = fmt(compPoint) + ' µmol/m²/s';
        updateCurve(rmax, kl, resp);
      }
      ['rmax', 'kl', 'resp', 'light'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.curve = new Chart(el('chart-curve'), {
          type: 'line',
          data: { labels: [], datasets: [
            { label: 'Gross rate', data: [], borderColor: '#10b981', backgroundColor: 'transparent', tension: 0.2, pointRadius: 0 },
            { label: 'Net rate', data: [], borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0.2, pointRadius: 0 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Light intensity' } }, y: { title: { display: true, text: 'Rate (µmol O2/m²/s)' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.compensation = new Chart(el('chart-compensation'), {
          type: 'bar',
          data: { labels: ['Sun plant', 'Shade plant'], datasets: [{ label: 'Compensation point', data: [80, 15], backgroundColor: ['#f59e0b', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Light compensation point' } } }, plugins: { legend: { display: false } } }),
        });
      }
      function updateCurve(rmax, kl, resp) {
        if (!charts.curve) return;
        const labels = [], grossData = [], netData = [];
        for (let I = 0; I <= kl * 6; I += kl * 6 / 20) {
          labels.push(I.toFixed(0));
          const g = gross(I, rmax, kl);
          grossData.push(+g.toFixed(2));
          netData.push(+(g - resp).toFixed(2));
        }
        charts.curve.data.labels = labels;
        charts.curve.data.datasets[0].data = grossData;
        charts.curve.data.datasets[1].data = netData;
        charts.curve.update('none');
      }

      function leafScene(container, particleCount) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const leaf = new THREE.Mesh(new THREE.SphereGeometry(1.6, 20, 16), new THREE.MeshStandardMaterial({ color: 0x22c55e, transparent: true, opacity: 0.4 }));
        leaf.scale.set(1, 1.4, 0.2);
        s.scene.add(leaf);
        for (let i = 0; i < particleCount; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.08, 8, 6), new THREE.MeshStandardMaterial({ color: 0xfacc15 }));
          m.position.set((Math.random() - 0.5) * 3.5, (Math.random() - 0.5) * 3, 1 + Math.random());
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagDim = null, diagBright = null;
      function initDiagDim() { const c = el('diag-dim'); if (!c) throw new Error('no container'); diagDim = leafScene(c, 5); }
      function initDiagBright() { const c = el('diag-bright'); if (!c) throw new Error('no container'); diagBright = leafScene(c, 35); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[photosynthesis-rate] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagDim(); } catch (e) { console.error('[photosynthesis-rate] dim diagram failed', e); }
          try { initDiagBright(); } catch (e) { console.error('[photosynthesis-rate] bright diagram failed', e); }
        }
        mountResize([diagDim, diagBright]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
