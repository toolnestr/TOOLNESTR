---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Rafter Length Calculator';
const description = 'Find the rafter length for a roof from its run and pitch, including an overhang allowance, using the Pythagorean theorem.';
const intro = 'Find the rafter length you need to cut, from the horizontal run, roof pitch, and overhang, using the Pythagorean theorem.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How do I calculate rafter length?', a: 'A rafter is the hypotenuse of a right triangle formed by the horizontal run and the vertical rise. Find the rise by multiplying the run by the pitch (rise per 12 inches, divided by 12), then use the Pythagorean theorem: rafter length equals the square root of run squared plus rise squared.' },
  { q: 'What is roof run versus roof span?', a: 'The span is the total width of the building; the run is half the span for a simple gable roof, since the rafter travels from the outside wall to the center ridge. Enter the run — half the span — not the full building width.' },
  { q: 'Do I need to add anything for the overhang?', a: 'Yes. This calculator finds the length from the wall plate to the ridge. Add your desired eave overhang separately, since it extends the rafter tail beyond the wall and is not part of the run-to-ridge span.' },
  { q: 'Does this account for the ridge board thickness?', a: 'No, this gives the theoretical centerline length. In the field, carpenters shorten the actual cut by half the ridge board thickness on each rafter so the pair meets correctly at the ridge — a small adjustment made after this length is found.' },
];
const howTo = {
  name: 'How to calculate rafter length',
  steps: [
    { name: 'Enter the run', text: "Half the building's span, in feet, from wall to ridge centerline." },
    { name: 'Set the pitch', text: 'The rise per 12 inches of run, such as 6 for a 6-in-12 roof.' },
    { name: 'Add the overhang', text: 'Include your eave overhang for the full rafter cut length.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Run (ft, half the building span)</span>
        <input id="run" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pitch (rise per 12" run)</span>
        <input id="pitch" type="number" step="any" placeholder="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Overhang (in)</span>
        <input id="overhang" type="number" step="any" placeholder="18" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total rafter length</div>
        <div id="r-total" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Run-to-ridge length</div><div id="r-main" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Rise</div><div id="r-rise" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Angle</div><div id="r-angle" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="280" viewBox="0 0 800 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rl-title rl-desc">
      <title id="rl-title">Rafter as the hypotenuse of run and rise</title>
      <desc id="rl-desc">A right triangle formed by run, rise, and the rafter length, with the overhang extending past the wall</desc>
      <line x1="90" y1="220" x2="420" y2="220" stroke="#94a3b8" stroke-width="2" />
      <line x1="60" y1="220" x2="90" y2="220" stroke="#d97706" stroke-width="4" />
      <path d="M90 220 L420 220 L420 110 Z" fill="none" stroke="#6366f1" stroke-width="3" />
      <path d="M60 220 L90 220 L90 195 Z" fill="none" stroke="#d97706" stroke-width="2" />
      <text x="255" y="240" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">run</text>
      <text x="435" y="165" font-size="12" fill="#475569" font-family="system-ui,sans-serif">rise</text>
      <text x="75" y="240" text-anchor="middle" font-size="10" fill="#92400e" font-family="system-ui,sans-serif">overhang</text>
      <rect x="470" y="90" width="290" height="130" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="490" y="118" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Rafter length</text>
      <text x="490" y="144" font-size="12" fill="#475569" font-family="system-ui,sans-serif">rise = run &times; pitch&frasl;12</text>
      <text x="490" y="166" font-size="12" fill="#475569" font-family="system-ui,sans-serif">rafter = &radic;(run&sup2; + rise&sup2;)</text>
      <text x="490" y="188" font-size="12" fill="#475569" font-family="system-ui,sans-serif">total = rafter + overhang&frasl;cos(angle)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The rafter is the hypotenuse of the run and rise; the overhang extends the tail past the wall.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the rafter length calculator works</h2>
    <p class="mt-2 text-slate-600">
      A common rafter forms the hypotenuse of a right triangle: the run is the horizontal leg, from the outside wall to the center of the ridge, and the rise is the vertical leg, how much the roof climbs over that run. The rise is found from the pitch — the rise-per-12-inches ratio — multiplied by the actual run and divided by 12.
    </p>
    <p class="mt-3 text-slate-600">
      With both legs known, the Pythagorean theorem gives the rafter length: the square root of the run squared plus the rise squared. That is the length from the top of the wall plate to the centerline of the ridge. The overhang, the part of the rafter that extends past the wall to form the eave, is added on separately along the same slope angle, since it is not part of the run-to-ridge triangle.
    </p>
    <p class="mt-3 text-slate-600">
      This is standard IRC/IBC rafter geometry — the same right-triangle relationship every span table and framing square is built on. In the field, carpenters typically shorten the final cut by half the ridge board's thickness on each side so the two opposing rafters meet cleanly at the ridge; that small trim happens after laying out this theoretical length.
    </p>
    <p class="mt-3 text-xs text-slate-400">Rafter sizing and span limits follow IRC Chapter 8 (Roof-Ceiling Construction) and the AWC span tables referenced by Section R802.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the run</h3>
        <p class="mt-1 text-sm text-slate-600">Half the building's span, in feet, from wall to ridge centerline.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the pitch</h3>
        <p class="mt-1 text-sm text-slate-600">The rise per 12 inches of run, such as 6 for a 6-in-12 roof.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Add the overhang</h3>
        <p class="mt-1 text-sm text-slate-600">Include your eave overhang for the full rafter cut length.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Rise</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">rise = run &times; pitch&frasl;12</span>. A 12 ft run at 6 in 12: 12 &times; 6&frasl;12 = <strong>6 ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Run-to-ridge length</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= &radic;(run&sup2; + rise&sup2;)</span> = &radic;(144+36) = &radic;180 = <strong>13.42 ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">With overhang</p>
        <p class="mt-1 text-slate-600">
          An 18&Prime; (1.5 ft) overhang along the slope: 1.5&frasl;cos(26.57&deg;) = 1.68 ft. Total = 13.42 + 1.68 = <strong>15.1 ft</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 28 ft wide building (14 ft run) at 8 in 12 pitch, 12&Prime; overhang.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Rise:</span> <span class="text-slate-600">14 &times; 8/12 = 9.33 ft</span></div>
        <div><span class="font-medium text-slate-700">Main length:</span> <span class="text-slate-600">&radic;(196+87.1) = 16.83 ft</span></div>
        <div><span class="font-medium text-slate-700">Angle:</span> <span class="text-slate-600">atan(8/12) = 33.7°</span></div>
        <div><span class="font-medium text-slate-700">Total with overhang:</span> <span class="text-slate-600"><strong>≈ 18.03 ft</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      A garage addition with a 32 ft span (16 ft run) at a moderate 5 in 12 pitch with a 24-inch overhang is a common permit-ready scenario. The rise works out to 16 &times; 5&frasl;12 = 6.67 ft, giving a run-to-ridge length of &radic;(256+44.4) = <strong>17.33 ft</strong>, and with the overhang added along the 22.6&deg; slope, the total cut length comes to <strong>19.5 ft</strong> — long enough that most lumberyards would special-order 20 ft dimensional stock rather than splice shorter boards.
    </p>
    <p class="mt-3 text-slate-600">
      A steep 9 in 12 roof over a compact 20 ft span (10 ft run) with a 16-inch overhang shows how pitch, not span, drives length on smaller structures. The rise is 7.5 ft, the run-to-ridge length is exactly &radic;(100+56.25) = <strong>12.5 ft</strong>, and at a 36.9&deg; angle the overhang adds relatively more slope length per inch than a shallow roof would, bringing the total to <strong>14.17 ft</strong>.
    </p>
    <p class="mt-3 text-slate-600">
      A wide 40 ft span (20 ft run) at a shallow 4 in 12 pitch with an 18-inch overhang is typical of ranch-style additions. Rise is 6.67 ft, the main rafter length is 21.08 ft, and the gentle 18.4&deg; angle means the overhang barely stretches beyond its flat 1.5 ft measurement, landing the total near <strong>22.66 ft</strong> — a length that pushes into engineered I-joist or LVL territory rather than standard dimensional lumber for many species and grades.
    </p>
    <p class="mt-3 text-slate-600">
      Lumberyards typically stock dimensional rafter stock in 2 ft increments — 12, 14, 16, 18, 20, 22, and 24 ft lengths — so once the calculator returns a total, framers round up to the next available stock length rather than ordering an exact custom cut. This is also the point where many builders decide whether trussed rafters make more economic sense than site-built stick framing, since factory trusses become more competitive as calculated span and rise increase.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Run means the full width of the building." <strong class="text-slate-900">It is half that.</strong> For a simple gable roof, the run is measured from the outside wall to the centerline of the ridge — for a 24 ft wide building, the run is 12 ft, not 24 ft. Entering the full span instead of half of it roughly doubles the calculated rafter length.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"The rafter length calculation already accounts for the ridge board and birdsmouth cuts." <strong class="text-slate-900">It does not.</strong> This calculator gives the theoretical centerline-to-centerline length. Real-world cuts get shortened by half the ridge board's thickness at the top and adjusted at the birdsmouth notch where the rafter meets the wall plate — both are field adjustments made after this baseline length.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/roof-pitch-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Roof Pitch Calculator</a>
      <a href="/tools/truss-spacing-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Roof Truss Spacing Calculator</a>
      <a href="/tools/gambrel-roof-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Gambrel Roof Rafter Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const run = parseFloat(el('run').value);
      const pitch = parseFloat(el('pitch').value);
      let overhangIn = parseFloat(el('overhang').value); if (!overhangIn || overhangIn < 0) overhangIn = 0;
      if (!run || !pitch || run <= 0 || pitch <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const rise = run * (pitch / 12);
      const mainLen = Math.sqrt(run * run + rise * rise);
      const angleRad = Math.atan(pitch / 12);
      const angleDeg = angleRad * (180 / Math.PI);
      const overhangFt = overhangIn / 12;
      const overhangSlope = overhangFt / Math.cos(angleRad);
      const total = mainLen + overhangSlope;

      el('r-total').textContent = total.toFixed(2) + ' ft';
      el('r-note').textContent = 'includes ' + overhangIn + ' in overhang along the slope';
      el('r-main').textContent = mainLen.toFixed(2) + ' ft';
      el('r-rise').textContent = rise.toFixed(2) + ' ft';
      el('r-angle').textContent = angleDeg.toFixed(1) + '°';
      el('results').classList.remove('hidden');
    }

    ['run', 'pitch', 'overhang'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
