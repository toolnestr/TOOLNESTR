---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Ring Size Calculator';
const description = 'Find your ring size in US, UK, and EU systems from finger circumference or diameter in millimeters. Get an accurate size before buying any ring.';
const intro = 'Convert a measured finger circumference or diameter into US, UK, and EU ring sizes.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I measure my finger for ring size?', a: 'Wrap a strip of paper or string snugly around the base of your finger, mark where it overlaps, then measure that length in millimeters with a ruler — that number is your circumference. Measure at the end of the day when fingers are largest, and avoid measuring when cold.' },
  { q: 'Should I measure circumference or diameter?', a: 'Circumference (distance around the finger) is easier and more accurate to measure at home than diameter (distance across), since diameter requires measuring an existing ring rather than your finger directly. This tool accepts either.' },
  { q: 'Why do knuckles matter for ring sizing?', a: 'A ring must pass over the knuckle to reach the base of the finger, so if your knuckle is noticeably larger than the base, size for comfortable passage over the knuckle rather than a snug fit at the base, or consider a ring with a hidden sizing mechanism.' },
  { q: 'Do ring sizes differ between US and EU the same way as clothing?', a: 'No — ring sizing in every major system is ultimately based on the same physical circumference or diameter measurement, just labeled differently (a letter in the UK, a number close to the millimeter circumference in the EU, and a separate numeric scale in the US), so the conversion is a direct physical relationship rather than an approximate offset.' },
];
const howTo = {
  name: 'How to find your ring size',
  steps: [
    { name: 'Measure your finger', text: 'Wrap string or paper around the base of the finger and measure the circumference in millimeters.' },
    { name: 'Enter the measurement', text: 'Type the circumference (or diameter, using the toggle) into the calculator.' },
    { name: 'Read your size', text: 'Your US, UK, and EU ring sizes appear instantly, rounded to the nearest standard size.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex gap-2">
      {['Circumference (mm)', 'Diameter (mm)'].map((d) => (
        <button data-mode={d} class="mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">{d}</button>
      ))}
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Measurement (mm)</span>
      <input id="measure" type="number" step="any" placeholder="e.g. 54" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-fuchsia-600 p-3 text-center"><div class="text-sm text-fuchsia-100">US</div><div id="r-us" class="mt-1 text-lg font-bold text-white">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">UK</div><div id="r-uk" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">EU</div><div id="r-eu" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="rsc-title rsc-desc">
      <title id="rsc-title">Ring circumference and diameter diagram</title>
      <desc id="rsc-desc">A circle representing a ring, labeled with diameter across the center and circumference around the edge</desc>
      <circle cx="400" cy="110" r="70" fill="none" stroke="#c026d3" stroke-width="4" />
      <line x1="330" y1="110" x2="470" y2="110" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" />
      <text x="400" y="100" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Diameter</text>
      <text x="400" y="205" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Circumference = π × Diameter</text>
      <text x="530" y="60" font-size="12" fill="#94a3b8" font-family="system-ui,sans-serif">Ring size scales</text>
      <text x="530" y="78" font-size="12" fill="#94a3b8" font-family="system-ui,sans-serif">track this circle directly</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Every ring-size system is a label for the same physical circle</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How ring sizing works</h2>
    <p class="mt-2 text-slate-600">
      Unlike clothing sizes, which are somewhat arbitrary labels, ring sizes are direct stand-ins for a physical measurement: the inner circumference (or diameter) of the ring. The relationship between the two is simple geometry — circumference equals π (about 3.14159) times diameter — so measuring either one is enough to find your size in any system.
    </p>
    <p class="mt-3 text-slate-600">
      US sizing runs on its own numeric scale from roughly size 3 to 13 for adults, UK sizing uses letters from A to Z, and EU (Continental) sizing uses a number that sits close to the actual circumference in millimeters. Because all three trace back to the same physical circle, converting between them is a lookup against millimeter measurements rather than an approximate offset like clothing sizing.
    </p>
    <p class="mt-3 text-xs text-slate-400">Size-to-millimeter relationships follow the standard international jewelry sizing chart used across US, UK, and EU (ISO) ring sizing conventions.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A string wrapped around a finger measures 54 mm around.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Circumference:</span> <span class="text-slate-600">54 mm</span></div>
        <div><span class="font-medium text-slate-700">Diameter:</span> <span class="text-slate-600">54 ÷ π ≈ 17.2 mm</span></div>
        <div><span class="font-medium text-slate-700">US size:</span> <span class="text-slate-600"><strong>US 7</strong></span></div>
        <div><span class="font-medium text-slate-700">UK / EU size:</span> <span class="text-slate-600"><strong>UK N · EU 54</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Buying an engagement ring as a surprise is the highest-stakes version of this problem — there's no chance to try it on first, so shoppers borrow an existing ring the person wears on the correct finger, measure its inside diameter with a ruler, and convert. Getting this wrong by even one size means an expensive resize before it can be worn.
    </p>
    <p class="mt-3 text-slate-600">
      International jewelry shopping runs into the same UK-letter-versus-US-number confusion as clothing, but with less room for error, since a ring that's a full size off either won't go over the knuckle or will spin loosely on the finger — there's no "roomy fit" equivalent to a slightly baggy shirt.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All my fingers are the same ring size." <strong class="text-slate-900">Rarely true.</strong> Dominant-hand fingers are often slightly larger, and each finger has a different base circumference, so measure the specific finger the ring will be worn on, not a different one.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Wide bands fit the same as thin bands in the same size." <strong class="text-slate-900">Not exactly.</strong> Wider bands touch more of the finger's surface and tend to feel tighter than a thin band of the same labeled size, so many jewelers recommend going up half a size for bands wider than about 6mm.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/glove-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Glove Size Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
      <a href="/tools/belt-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Belt Size Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'Circumference (mm)';

    // [circumference mm, US size, UK letter, EU size]
    const table = [
      [44.2, 3, 'F', 44], [45.5, 3.5, 'G', 46], [46.8, 4, 'H', 47], [48.0, 4.5, 'I', 48],
      [49.3, 5, 'J', 49], [50.6, 5.5, 'K', 51], [51.9, 6, 'L', 52], [53.1, 6.5, 'M', 53],
      [54.4, 7, 'N', 54], [55.7, 7.5, 'O', 56], [57.0, 8, 'P', 57], [58.3, 8.5, 'Q', 58],
      [59.5, 9, 'R', 60], [60.8, 9.5, 'S', 61], [62.1, 10, 'T', 62], [63.4, 10.5, 'U', 63],
      [64.6, 11, 'V', 65], [65.9, 11.5, 'W', 66], [67.2, 12, 'X', 67], [69.7, 13, 'Z', 70],
    ];

    function nearest(circ) {
      let best = table[0];
      let bestDiff = Math.abs(circ - table[0][0]);
      table.forEach((row) => {
        const diff = Math.abs(circ - row[0]);
        if (diff < bestDiff) { best = row; bestDiff = diff; }
      });
      return best;
    }

    function update() {
      const v = parseFloat(el('measure').value);
      if (!v || v <= 0) { el('results').classList.add('hidden'); return; }
      const circ = mode === 'Diameter (mm)' ? v * Math.PI : v;
      const row = nearest(circ);
      el('r-us').textContent = 'US ' + row[1];
      el('r-uk').textContent = 'UK ' + row[2];
      el('r-eu').textContent = 'EU ' + row[3];
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mode-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mode-btn').forEach((b) => {
          b.className = 'mode-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50';
        });
        btn.className = 'mode-btn rounded-lg border border-fuchsia-300 bg-fuchsia-100 px-4 py-1.5 text-sm font-medium text-fuchsia-700 transition';
        mode = btn.dataset.mode;
        update();
      });
    });

    el('measure').addEventListener('input', update);
    document.querySelector('.mode-btn').click();
  </script>
</ToolLayout>
