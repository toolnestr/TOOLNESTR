---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Digital Tasbih Counter';
const description = 'A free digital tasbih (dhikr) counter that saves your progress, counts completed rounds, and vibrates when you reach your target of 33, 99 or 100.';
const intro = 'Tap to count your dhikr. Your progress is saved automatically on your device.';
const category = { id: 'islamic', name: 'Islamic Tools', emoji: '🕌' };
const faqs = [
  { q: 'How do I use the tasbih counter?', a: 'Set your target (33, 99 or 100), then tap the large circle once for each dhikr. The counter tracks your total and completed rounds, and gently vibrates when you reach the target on supported devices.' },
  { q: 'What are common dhikr counts?', a: 'After each prayer many recite SubhanAllah 33 times, Alhamdulillah 33 times and Allahu Akbar 34 times (totalling 100). Others repeat a phrase 99 or 100 times. Choose the target that matches your routine.' },
  { q: 'Does it save my progress?', a: 'Yes. Your count is stored locally in your browser, so it remains if you close the tab and return on the same device. Nothing is uploaded.' },
  { q: 'How do I reset the counter?', a: 'Tap the Reset button to set the count and rounds back to zero. Your target stays as you set it.' },
];

const beads = Array.from({ length: 24 }).map((_, i) => {
  const a = (i / 24) * Math.PI * 2;
  return { cx: 400 + Math.cos(a) * 70, cy: 100 + Math.sin(a) * 70, first: i === 0 };
});
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex items-center justify-between">
      <label class="text-sm font-medium text-slate-700">Target
        <select id="target" class="ml-2 rounded-lg border border-slate-300 p-2 outline-none focus:border-indigo-400"><option value="33">33</option><option value="99">99</option><option value="100">100</option></select>
      </label>
      <div class="text-sm text-slate-500">Rounds: <span id="rounds" class="font-bold text-indigo-600">0</span></div>
    </div>

    <button id="bead" class="press mt-5 flex w-full flex-col items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-700 py-12 text-white shadow-lg transition active:scale-95" aria-label="Tap to count">
      <span class="text-sm opacity-80">Tap to count</span>
      <span id="count" class="my-2 text-6xl font-extrabold tabular-nums">0</span>
      <span class="text-xs opacity-70">of <span id="target-lbl">33</span></span>
    </button>

    <div class="mt-4 grid grid-cols-2 gap-3">
      <button id="undo" class="rounded-xl border border-slate-300 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50">↶ Undo</button>
      <button id="reset" class="rounded-xl border border-rose-300 py-3 text-sm font-medium text-rose-600 transition hover:bg-rose-50">Reset</button>
    </div>
    <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-slate-100"><div id="bar" class="h-full rounded-full bg-indigo-500 transition-all" style="width:0%"></div></div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="tc-title tc-desc">
      <title id="tc-title">Ring of prayer beads</title>
      <desc id="tc-desc">A loop of prayer beads representing a digital tasbih for counting dhikr.</desc>
      {beads.map((b) => (<circle cx={b.cx} cy={b.cy} r="8" fill={b.first ? '#6366f1' : '#c7d2fe'} />))}
      <circle cx="400" cy="100" r="40" fill="#eef2ff" stroke="#a5b4fc" /><text x="400" y="106" text-anchor="middle" font-size="14" fill="#3730a3" font-family="system-ui,sans-serif" font-weight="bold">Dhikr</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">A digital tasbih to keep your count of remembrance wherever you are.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About the digital tasbih</h2>
    <p class="mt-2 text-slate-600">Dhikr — the remembrance of Allah — is one of the most beloved acts of worship, and a tasbih (prayer beads) helps keep an accurate count. This digital tasbih does the same job on any device: tap the large button once for each repetition of a phrase such as SubhanAllah, Alhamdulillah, Allahu Akbar, or any supplication you are reciting. When you reach your chosen target, the counter records a completed round and starts again, so you can keep going indefinitely.</p>
    <p class="mt-3 text-slate-600">Your count and round total are saved in your browser, which means you can close the page and return later on the same device without losing your place. An Undo button corrects an accidental double-tap, and Reset clears everything when you want a fresh start. On phones that support it, a gentle vibration confirms each completed target so you can keep your eyes lowered and focus on the words.</p>
    <p class="mt-3 text-slate-600">Choose 33 for the classic after-prayer adhkar, or 99 and 100 for longer sessions. Because everything runs locally, the tasbih works offline and keeps your worship private. It is a simple, distraction-free companion for the masjid, the commute, or quiet moments at home.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common dhikr after prayer</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-center"><div class="text-2xl font-bold text-indigo-600">33×</div><h3 class="mt-1 font-semibold text-slate-900">SubhanAllah</h3><p class="mt-1 text-sm text-slate-600">“Glory be to Allah.”</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-center"><div class="text-2xl font-bold text-indigo-600">33×</div><h3 class="mt-1 font-semibold text-slate-900">Alhamdulillah</h3><p class="mt-1 text-sm text-slate-600">“All praise is for Allah.”</p></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-center"><div class="text-2xl font-bold text-indigo-600">34×</div><h3 class="mt-1 font-semibold text-slate-900">Allahu Akbar</h3><p class="mt-1 text-sm text-slate-600">“Allah is the Greatest.”</p></div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/asma-ul-husna" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">99 Names of Allah</a>
      <a href="/tools/hijri-date-today" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Today’s Hijri Date</a>
      <a href="/tools/ramadan-countdown" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Ramadan Countdown</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let count = 0, rounds = 0, target = 33;
    try { const s = JSON.parse(localStorage.getItem('tasbih') || '{}'); count = s.count || 0; rounds = s.rounds || 0; target = s.target || 33; } catch (e) {}
    el('target').value = String(target);
    function save() { try { localStorage.setItem('tasbih', JSON.stringify({ count, rounds, target })); } catch (e) {} }
    function render() {
      el('count').textContent = count;
      el('rounds').textContent = rounds;
      el('target-lbl').textContent = target;
      el('bar').style.width = Math.min(100, (count / target) * 100) + '%';
    }
    function tap() {
      count += 1;
      if (count >= target) { count = 0; rounds += 1; if (navigator.vibrate) navigator.vibrate([60, 40, 60]); }
      else if (navigator.vibrate) navigator.vibrate(15);
      save(); render();
    }
    el('bead').addEventListener('click', tap);
    el('undo').addEventListener('click', () => { if (count > 0) count -= 1; else if (rounds > 0) { rounds -= 1; count = target - 1; } save(); render(); });
    el('reset').addEventListener('click', () => { count = 0; rounds = 0; save(); render(); });
    el('target').addEventListener('change', () => { target = parseInt(el('target').value, 10); if (count >= target) count = 0; save(); render(); });
    render();
  </script>
</ToolLayout>
