---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Gravel & Sand Calculator';
const description = 'Calculate cubic yards and tons of gravel or sand needed for area and depth.';
const intro = 'Estimate cubic yards and tons of gravel, sand, or aggregate for any project.';
const category = { id: 'construction', name: 'Construction & Home Improvement' };
const faqs = [
  { q: 'How much does a cubic yard of gravel weigh?', a: 'A cubic yard of gravel weighs approximately 1.9-2.0 tons (3,800-4,000 lbs). The exact weight depends on the stone size and type. Pea gravel is lighter, while crushed stone is heavier.' },
  { q: 'What depth of gravel do I need for a driveway?', a: 'A gravel driveway needs 4-6 inches of compacted gravel. Use a 6-inch base of larger crushed stone (#3 or #4) topped with 2-4 inches of smaller gravel (#57 or #67) for a stable, smooth surface.' },
  { q: 'Should I order by cubic yard or ton?', a: 'Most suppliers sell bulk material by the ton, but they also quote by the cubic yard. Use the calculator to get both numbers so you can compare quotes from different suppliers.' },
  { q: 'How much sand do I need for a paver base?', a: 'Paver sand base should be 1-2 inches deep after compaction. For a 100 sq ft patio: 100 &times; (1.5/12) = 12.5 cu ft, which is about 0.46 cu yd or roughly 0.9 tons.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Length (ft)</span>
        <input id="length" type="number" step="any" placeholder="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Width (ft)</span>
        <input id="width" type="number" step="any" placeholder="12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Depth (in)</span>
        <input id="depth" type="number" step="any" placeholder="4" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-4">
      <span class="text-sm font-medium text-slate-700">Material type</span>
      <div class="mt-1 flex flex-wrap gap-2">
        {['Gravel (1.95 t/cy)', 'Sand (1.35 t/cy)', 'Crushed stone (2.0 t/cy)', 'Pea gravel (1.8 t/cy)'].map((m) => (
          <button data-type={m} class="mat-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">{m}</button>
        ))}
      </div>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Material needed</div>
        <div id="r-cy" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-tons" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic feet</div><div id="r-cf" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Cubic yards</div><div id="r-cy2" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Estimated tons</div><div id="r-tons2" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="360" viewBox="0 0 800 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="gravel-title gravel-desc">
      <title id="gravel-title">Driveway gravel cross-section diagram</title>
      <desc id="gravel-desc">A cross-section of a gravel driveway showing the depth of gravel layers over compacted subgrade</desc>
      <rect x="100" y="160" width="550" height="120" fill="#e5e7eb" stroke="#9ca3af" stroke-width="1" rx="2" />
      <rect x="100" y="140" width="550" height="25" fill="#d1d5db" stroke="#9ca3af" stroke-width="1" rx="2" />
      <circle cx="150" cy="148" r="4" fill="#6b7280" opacity="0.3" />
      <circle cx="200" cy="150" r="5" fill="#6b7280" opacity="0.3" />
      <circle cx="250" cy="145" r="3" fill="#6b7280" opacity="0.3" />
      <circle cx="300" cy="152" r="4" fill="#6b7280" opacity="0.3" />
      <circle cx="350" cy="147" r="5" fill="#6b7280" opacity="0.3" />
      <circle cx="400" cy="150" r="3" fill="#6b7280" opacity="0.3" />
      <circle cx="450" cy="148" r="4" fill="#6b7280" opacity="0.3" />
      <circle cx="500" cy="151" r="5" fill="#6b7280" opacity="0.3" />
      <circle cx="550" cy="146" r="3" fill="#6b7280" opacity="0.3" />
      <circle cx="600" cy="149" r="4" fill="#6b7280" opacity="0.3" />
      <rect x="100" y="280" width="550" height="50" fill="#fcd34d" opacity="0.2" stroke="#d97706" stroke-width="1" rx="2" />
      <text x="375" y="310" text-anchor="middle" font-size="12" fill="#92400e" font-family="system-ui,sans-serif">Compacted subgrade (soil)</text>
      <line x1="100" y1="130" x2="100" y2="140" stroke="#94a3b8" stroke-width="1" />
      <line x1="100" y1="130" x2="650" y2="130" stroke="#94a3b8" stroke-width="1" stroke-dasharray="5 3" />
      <line x1="650" y1="130" x2="650" y2="140" stroke="#94a3b8" stroke-width="1" />
      <text x="375" y="122" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui,sans-serif">Gravel depth</text>
      <text x="375" y="340" text-anchor="middle" font-size="13" fill="#64748b" font-family="system-ui,sans-serif">Gravel surface layer over compacted subgrade — depth determines volume</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Gravel driveway cross-section showing the depth of aggregate over compacted soil</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the gravel and sand calculator works</h2>
    <p class="mt-2 text-slate-600">
      The gravel and sand calculator determines the volume of material needed for a rectangular area at a given depth. It calculates cubic feet, converts to cubic yards, and estimates weight in tons based on the material type's density. Different materials have different densities — gravel is heavier than sand, and crushed stone is heavier than pea gravel.
    </p>
    <p class="mt-3 text-slate-600">
      To use the calculator, enter the length and width of the area in feet and the desired depth in inches. Select the material type — each type has a different tons-per-cubic-yard factor. The calculator shows the volume in cubic feet and cubic yards, plus the estimated weight in tons. Most suppliers sell bulk aggregates by the ton, so the weight is the practical number for ordering.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Measure the area</h3>
        <p class="mt-1 text-sm text-slate-600">Measure the length and width of the area to be covered. Determine the depth needed.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select material</h3>
        <p class="mt-1 text-sm text-slate-600">Choose gravel, sand, crushed stone, or pea gravel. The density changes the weight estimate.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-600">Order the right amount</h3>
        <p class="mt-1 text-sm text-slate-600">Call your supplier with the cubic yards or tons. Add 10% for compaction and spreading waste.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Volume in cubic feet</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">V = L &times; W &times; (D/12)</span>. For a 20&prime; &times; 12&prime; driveway at 4 inches: 20 &times; 12 &times; (4/12) = <strong>80 cu ft</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Cubic yards</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">CY = V / 27</span>. 80 / 27 = <strong>2.96 cu yd</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Weight in tons</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">Tons = CY &times; density (t/cy)</span>. For gravel at 1.95 t/cy: 2.96 &times; 1.95 = <strong>5.77 tons</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 30&prime; &times; 20&prime; gravel parking area, 6 inches deep, using crushed stone (2.0 t/cy), plus 10% extra for compaction.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Volume:</span> <span class="text-slate-600">30 &times; 20 &times; (6/12) = 300 cu ft</span></div>
        <div><span class="font-medium text-slate-700">Cubic yards:</span> <span class="text-slate-600">300 / 27 = 11.11 cu yd</span></div>
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">11.11 &times; 2.0 = 22.22 tons</span></div>
        <div><span class="font-medium text-slate-700">With 10% extra:</span> <span class="text-slate-600"><strong>24.44 tons</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases for the gravel and sand calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🚗</span>
        <h3 class="mt-2 font-semibold text-slate-900">Driveway topping</h3>
        <p class="mt-1 text-sm text-slate-600">Add a fresh layer of gravel to your driveway. Standard depth is 4 inches. Calculate the volume based on your driveway dimensions and order the right amount for a smooth, mud-free surface.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🌿</span>
        <h3 class="mt-2 font-semibold text-slate-900">Garden paths</h3>
        <p class="mt-1 text-sm text-slate-600">Pea gravel paths are attractive and functional in gardens. Use 2-3 inches of depth. The calculator helps you find the right amount for winding paths and irregular garden beds.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧱</span>
        <h3 class="mt-2 font-semibold text-slate-900">Paver base</h3>
        <p class="mt-1 text-sm text-slate-600">Sand is used as the setting bed for pavers. Calculate the sand volume needed at 1-2 inches depth over the entire paver area. Add the gravel base layer (4-6 inches) separately.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏗️</span>
        <h3 class="mt-2 font-semibold text-slate-900">Foundation backfill</h3>
        <p class="mt-1 text-sm text-slate-600">Crushed stone is used for foundation drainage and backfill. Calculate the volume of the trench around the foundation footings to determine how much stone to order.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for buying aggregate</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Order extra for compaction</h3>
        <p class="mt-1 text-sm text-slate-600">Aggregates compact by 10-20% when rolled or tamped. Order 10-15% more than the calculated volume to account for compaction. This is especially important for driveways and base layers where proper compaction determines long-term stability.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Know the difference between stone sizes</h3>
        <p class="mt-1 text-sm text-slate-600">Crushed stone is graded by number: #57 (1 inch) is the most common for driveways and base layers. #67 (3/4 inch) works well for pathways. #3 (2 inches) is used as a base layer. Pea gravel (3/8-1/2 inch) is for decorative surfaces and paths.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Check delivery minimums</h3>
        <p class="mt-1 text-sm text-slate-600">Most aggregate suppliers have a minimum delivery of 3-5 tons. For smaller amounts, you will pay more per ton or need to pick it up yourself in a truck or trailer. Bagged gravel from home centers costs more per ton but is better for small projects.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/concrete-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Calculator</a>
      <a href="/tools/cubic-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Cubic Yardage Calculator</a>
      <a href="/tools/mulch-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Mulch Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let density = 1.95;

    function update() {
      const L = parseFloat(el('length').value);
      const W = parseFloat(el('width').value);
      const D = parseFloat(el('depth').value);
      if (!L || !W || !D || L <= 0 || W <= 0 || D <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const cf = L * W * (D / 12);
      const cy = cf / 27;
      const tons = cy * density;
      el('r-cy').textContent = cy.toFixed(2) + ' cu yd';
      el('r-tons').textContent = '(' + tons.toFixed(2) + ' tons)';
      el('r-cf').textContent = cf.toFixed(1) + ' cu ft';
      el('r-cy2').textContent = cy.toFixed(3) + ' cu yd';
      el('r-tons2').textContent = tons.toFixed(2) + ' tons';
      el('results').classList.remove('hidden');
    }

    document.querySelectorAll('.mat-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.mat-btn').forEach((b) => {
          b.className = 'mat-btn rounded-lg border border-slate-300 px-4 py-1.5 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50';
        });
        btn.className = 'mat-btn rounded-lg border border-indigo-300 bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-700 transition';
        const label = btn.dataset.type;
        if (label.includes('1.95')) density = 1.95;
        else if (label.includes('1.35')) density = 1.35;
        else if (label.includes('2.0')) density = 2.0;
        else if (label.includes('1.8')) density = 1.8;
        update();
      });
    });

    ['length', 'width', 'depth'].forEach((id) => {
      el(id).addEventListener('input', update);
    });
    document.querySelector('.mat-btn').click();
  </script>
</ToolLayout>
