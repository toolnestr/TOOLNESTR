---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Pleat Allowance Calculator';
const description = 'Calculate the extra fabric needed for pleats on any project, from curtains to cushions. Get accurate flat width so your pleats come out even every time.';
const intro = 'Calculate the extra flat fabric width needed for a set of pleats on any project.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How is this different from the Pleated Skirt Calculator?', a: 'The underlying math is identical (each pleat consumes twice its depth in extra fabric), but this tool is written generically for any project — curtains, valances, cushion covers, or garments — rather than specifically for a skirt waistband.' },
  { q: 'What pleat depth is typical?', a: 'Pleat depth commonly ranges from about 1 inch for subtle pleating to 3 inches or more for dramatic, deep pleats — deeper pleats create a bolder fold but consume proportionally more fabric.' },
  { q: 'Can I use this for inverted or box pleats?', a: 'Yes — box and inverted pleats are essentially two knife pleats folding toward or away from each other, so they use approximately the same twice-the-depth fabric allowance per pleat as a standard knife pleat.' },
  { q: 'Does pleat spacing affect the fabric calculation?', a: 'Not directly — this calculator only needs the total number of pleats and their depth, since spacing just determines where along the finished width each pleat sits, not how much extra fabric each one individually consumes.' },
];
const howTo = {
  name: 'How to calculate pleat allowance',
  steps: [
    { name: 'Enter finished flat width', text: 'Enter the target finished width after pleating (like a window or waistband measurement).' },
    { name: 'Enter pleat count and depth', text: 'Enter how many pleats you want and how deep each should be.' },
    { name: 'Read total fabric width needed', text: 'The total flat fabric width to cut before pleating appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Finished flat width (in)</span>
        <input id="finished" type="number" step="any" placeholder="e.g. 48" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of pleats</span>
        <input id="numPleats" type="number" step="1" placeholder="e.g. 8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pleat depth (in)</span>
        <input id="depth" type="number" step="any" placeholder="e.g. 2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Total fabric width needed</div>
        <div id="r-width" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="pac-title pac-desc">
      <title id="pac-title">Flat fabric strip folded into several pleats</title>
      <desc id="pac-desc">A flat fabric strip shown folding into several accordion-style pleats, illustrating extra fabric consumed per pleat</desc>
      <path d="M100 90 L160 60 L160 120 L220 60 L220 120 L280 60 L280 120 L340 60 L340 120 L400 60 L400 120 L460 90" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <text x="400" y="150" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Total width = finished width + (pleats × 2 × depth)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Each pleat adds twice its depth to the total flat fabric needed</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How pleat allowance is calculated</h2>
    <p class="mt-2 text-slate-600">
      Every pleat folds fabric back on itself, consuming twice its finished depth in flat fabric — once for the visible fold and once for the fabric tucked underneath it. This calculator multiplies your pleat count by twice the pleat depth, then adds that total to your target finished width to find the flat fabric width needed before pleating.
    </p>
    <p class="mt-3 text-slate-600">
      This same formula applies whether the finished pleated piece is a curtain heading, a valance, a waistband, or any other pleated project — only the finished target width and pleat details change between applications, not the underlying math.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows the standard fabric-consumption formula for knife and box pleats used across home-decor and garment sewing references.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A pleated curtain heading needs to finish at 48 inches wide, using 8 pleats, each 2 inches deep.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Extra per pleat:</span> <span class="text-slate-600">2 × 2 = 4 in</span></div>
        <div><span class="font-medium text-slate-700">Total pleat fabric:</span> <span class="text-slate-600">8 × 4 = 32 in</span></div>
        <div><span class="font-medium text-slate-700">Total flat width:</span> <span class="text-slate-600">48 + 32 = <strong>80 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Pinch-pleat curtain headings are a common non-garment use of this calculation, since the pleated heading tape needs a specific fabric width to create the intended pleat count and depth across a given rod width — this differs from the fullness-ratio approach used for gathered curtains, since pinch pleats are precisely folded rather than loosely gathered.
    </p>
    <p class="mt-3 text-slate-600">
      Costume and formalwear designers use pleat allowance calculations for structured details like a pleated bodice panel or a pleated obi-style sash, where the finished pleated width needs to fit a specific body measurement exactly, making an accurate fabric calculation essential before cutting expensive fabric.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Pleat depth and pleat spacing are the same measurement." <strong class="text-slate-900">They aren't.</strong> Depth is how far the fabric folds back on itself; spacing is the distance between pleats along the finished width — this calculator only needs depth, since spacing doesn't change the total fabric consumed.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"This formula only applies to skirts." <strong class="text-slate-900">It's fully generic.</strong> The same twice-the-depth-per-pleat math applies to any pleated project — curtains, cushions, sashes, and structured garment details all follow this identical formula.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pleated-skirt-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Pleated Skirt Calculator</a>
      <a href="/tools/gathering-ratio-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Gathering Ratio Calculator</a>
      <a href="/tools/curtain-panel-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Curtain Panel Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const finished = parseFloat(el('finished').value);
      const numPleats = parseFloat(el('numPleats').value);
      const depth = parseFloat(el('depth').value);
      if (!finished || !numPleats || !depth || finished <= 0 || numPleats <= 0 || depth <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const total = finished + numPleats * 2 * depth;
      el('r-width').textContent = total.toFixed(1) + ' in';
      el('results').classList.remove('hidden');
    }

    ['finished', 'numPleats', 'depth'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
