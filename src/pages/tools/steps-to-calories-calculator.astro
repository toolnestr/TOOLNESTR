---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Steps to Calories Calculator';
const description =
  'Free steps to calories calculator. Estimate calories burned from step count based on your weight and stride length. Metric or imperial.';
const intro =
  'Enter your step count and weight to estimate how many calories you burned walking or running.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How many calories do I burn per step?', a: 'The average person burns about 0.04–0.06 calories per step, or roughly 40–60 calories per 1,000 steps. The exact number depends on your weight, stride length and walking speed.' },
  { q: 'Does running burn more calories per step?', a: 'Yes — running has a higher MET value than walking, so you burn more calories per step. The difference is significant: running 10,000 steps burns roughly 30–50% more calories than walking the same step count.' },
  { q: 'How accurate is the step-to-calorie conversion?', a: 'It is a reasonable estimate based on stride length averages and MET values. Accuracy improves if you know your exact stride length. Fitness trackers with GPS and HR can be more personalised.' },
  { q: 'What is the average stride length?', a: 'Average stride length is about height × 0.415 for walking. For a person 170 cm tall, that is roughly 71 cm (28 inches). Taller people cover more distance per step and burn slightly more per step.' },
  { q: 'How many steps should I aim for per day?', a: 'The common 10,000-step target is a general wellness guideline, not a strict scientific threshold. Research shows health benefits increase up to about 7,500–8,000 steps per day, with diminishing returns beyond that.' },
];
const sources = [
  { html: "<strong>NIH / National Institutes of Health</strong> and <strong>CDC</strong> reference values and formulas. <a href=\"https://www.nih.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nih.gov</a>" },
  { html: "<strong>Peer-reviewed equations</strong> (e.g. Mifflin-St Jeor, Harris-Benedict) as originally published." },
  { html: "<strong>ACOG</strong> for pregnancy, ovulation and due-date methodology. <a href=\"https://www.acog.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">acog.org</a>" },
];
const sourcesNote = "Not medical advice. Estimates only — consult a qualified healthcare professional for any personal health decision.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <label class="block"><span class="text-sm font-medium text-slate-700">Activity type</span>
      <select id="mode" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="walk">Walking</option>
        <option value="run">Running / Jogging</option>
      </select></label>

    <div id="metric" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Steps taken</span>
        <input id="m-steps" type="number" step="1" placeholder="10000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-2" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Steps taken</span>
        <input id="i-steps" type="number" step="1" placeholder="10000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (<span class="unit">cm</span>) — to estimate stride length</span>
        <input id="height" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated calories burned</div>
        <div id="r-cal" class="mt-1 text-3xl font-bold">—</div>
        <div class="text-sm opacity-80">calories</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Distance covered</div><div id="r-dist" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Calories per 1,000 steps</div><div id="r-cpk" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your steps, weight and height to estimate calories burned.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About steps and calories</h2>
    <p class="mt-2 text-slate-600">
      Walking and running are among the most accessible forms of exercise. Knowing how many calories you burn per step helps you quantify your daily activity and incorporate it into your overall energy balance. This calculator uses your height to estimate stride length, then calculates the distance you covered and the energy cost based on your weight and activity type (walking or running). Walking at a moderate pace has a MET of roughly 3.5, while running at 6 mph has a MET of about 9.8. Pair this with the <a href="/tools/calories-burned-calculator/" class="font-medium text-indigo-600 hover:underline">Calories Burned Calculator</a> for other activities, and check the <a href="/tools/pace-calculator/" class="font-medium text-indigo-600 hover:underline">Pace Calculator</a> for running-specific metrics.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">These are estimates. Individual results vary with walking speed, terrain and fitness level.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" role="img" aria-labelledby="stc-title stc-desc">
      <title id="stc-title">Footprint trail showing steps over distance</title>
      <desc id="stc-desc">A trail of footprints spaced evenly across a path, showing the relationship between steps taken and distance covered.</desc>
      <path d="M50,130 Q200,60 400,100 Q600,140 750,90" fill="none" stroke="#e2e8f0" stroke-width="3" />
      <ellipse cx="100" cy="110" rx="14" ry="18" fill="#6366f1" transform="rotate(-15,100,110)" />
      <ellipse cx="180" cy="100" rx="14" ry="18" fill="#6366f1" transform="rotate(-10,180,100)" />
      <ellipse cx="260" cy="95" rx="14" ry="18" fill="#6366f1" transform="rotate(-5,260,95)" />
      <ellipse cx="340" cy="98" rx="14" ry="18" fill="#6366f1" />
      <ellipse cx="420" cy="105" rx="14" ry="18" fill="#6366f1" transform="rotate(5,420,105)" />
      <ellipse cx="500" cy="115" rx="14" ry="18" fill="#6366f1" transform="rotate(10,500,115)" />
      <ellipse cx="580" cy="120" rx="14" ry="18" fill="#6366f1" transform="rotate(12,580,120)" />
      <ellipse cx="660" cy="110" rx="14" ry="18" fill="#6366f1" transform="rotate(8,660,110)" />
      <text x="400" y="165" text-anchor="middle" font-size="11" fill="#94a3b8">Each footprint represents a step — more steps = more distance = more calories burned</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">A trail of footprints representing steps along a walking path</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The calculator first estimates your stride length based on your height. For walking, stride length is approximately height × 0.415. For running, the stride is longer — approximately height × 0.45. The total distance is steps × stride length. Then, using the MET value for walking (3.5) or running (9.8), the energy cost is calculated as MET × weight (kg) × duration (hours). The duration is estimated from the distance and a typical speed (5 km/h for walking, 10 km/h for running).
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Stride length (walking)</strong> = height (cm) × 0.415<br>
      <strong>Stride length (running)</strong> = height (cm) × 0.45<br>
      <strong>Distance</strong> = steps × stride length<br>
      <strong>Duration</strong> = distance / speed<br>
      <strong>Calories</strong> = MET × weight × duration
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A person 170 cm tall, weighing 70 kg, walks 10,000 steps.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Stride length:</span> <span class="text-slate-600">170 × 0.415 = <strong>70.6 cm</strong></span></div>
        <div><span class="font-medium text-slate-700">Distance:</span> <span class="text-slate-600">10,000 × 0.706 = <strong>7.06 km</strong></span></div>
        <div><span class="font-medium text-slate-700">Duration:</span> <span class="text-slate-600">7.06 / 5 = <strong>1.41 hours</strong> (85 min)</span></div>
        <div><span class="font-medium text-slate-700">Calories:</span> <span class="text-slate-600">3.5 × 70 × 1.41 = <strong>345 cal</strong></span></div>
        <div><span class="font-medium text-slate-700">Per 1,000 steps:</span> <span class="text-slate-600">345 / 10 = <strong>34.5 cal</strong></span></div>
        <div><span class="font-medium text-slate-700">Same steps running:</span> <span class="text-slate-600">9.8 × 70 × (7.06/10) ≈ <strong>485 cal</strong></span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚶</span>
      <h3 class="mt-2 font-semibold text-slate-900">Daily step goal seeker</h3>
      <p class="mt-1 text-sm text-slate-600">Track the calorie impact of hitting your daily step goal. Seeing that 10,000 steps burns ~350 calories can be powerful motivation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏃</span>
      <h3 class="mt-2 font-semibold text-slate-900">Jogger tracking progress</h3>
      <p class="mt-1 text-sm text-slate-600">Compare walking vs running the same step count. The calorie difference is striking and shows why intensity matters for energy expenditure.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👟</span>
      <h3 class="mt-2 font-semibold text-slate-900">Fitness watch user</h3>
      <p class="mt-1 text-sm text-slate-600">Cross-check your fitness tracker's calorie estimate against this independent calculation. Trackers can be off by 20% or more.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧑‍💼</span>
      <h3 class="mt-2 font-semibold text-slate-900">Office worker</h3>
      <p class="mt-1 text-sm text-slate-600">Understand how many calories a lunchtime walk burns. Even 5,000 extra steps per day can add up to meaningful weekly expenditure.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Log your steps</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the number of steps from your phone, watch or pedometer. Most modern phones count steps automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your stats</h3>
        <p class="mt-1 text-sm text-slate-600">Provide your weight and height. Height is used to estimate stride length, which determines distance.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your burn</h3>
        <p class="mt-1 text-sm text-slate-600">See total calories, distance covered and calories per 1,000 steps. Use this to plan your daily activity goal.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for maximising step-based calorie burn</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Increase your pace</h3>
        <p class="mt-1 text-sm text-slate-600">Brisk walking (5-6 km/h) burns significantly more calories per km than a leisurely stroll. Picking up the pace can boost burn by 30-50%.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Add incline</h3>
        <p class="mt-1 text-sm text-slate-600">Walking uphill increases MET from ~3.5 to ~5.0 or higher. A hilly route can burn 40% more calories than the same steps on flat ground.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Break it up</h3>
        <p class="mt-1 text-sm text-slate-600">Short walking breaks throughout the day add up. Three 10-minute walks burn about the same as one 30-minute continuous walk.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/calories-burned-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Calories Burned Calculator</a>
      <a href="/tools/pace-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Pace Calculator</a>
      <a href="/tools/calorie-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Calorie Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      document.querySelectorAll('.unit').forEach((u) => (u.textContent = isMetric ? 'cm' : 'in'));
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      let steps, kg, cm;
      if (metric) {
        steps = parseFloat(el('m-steps').value);
        kg = parseFloat(el('m-w').value);
      } else {
        steps = parseFloat(el('i-steps').value);
        kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      const hCm = parseFloat(el('height').value);
      const k = metric ? 1 : 2.54;
      cm = hCm * k;
      const mode = el('mode').value;
      if (!steps || !kg || !cm || steps <= 0 || kg <= 0 || cm <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const stride = mode === 'walk' ? cm * 0.415 : cm * 0.45;
      const distKm = (steps * stride) / 100000;
      const met = mode === 'walk' ? 3.5 : 9.8;
      const speed = mode === 'walk' ? 5.0 : 10.0;
      const hours = distKm / speed;
      const cal = met * kg * hours;
      const cpk = steps > 0 ? (cal / steps) * 1000 : 0;
      el('r-cal').textContent = Math.round(cal).toLocaleString();
      el('r-dist').textContent = distKm.toFixed(2) + ' km';
      el('r-cpk').textContent = cpk.toFixed(1);
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['mode', 'm-steps', 'm-w', 'i-steps', 'i-w', 'height'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
