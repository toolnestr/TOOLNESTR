---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Fraction Calculator';
const description =
  'Free fraction calculator. Add, subtract, multiply and divide two fractions and get the ' +
  'simplified result, plus the decimal and mixed-number form.';
const intro =
  'Enter two fractions and choose an operation to get the simplified result, decimal value and mixed number.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'Does it simplify the answer?', a: 'Yes. The result is always reduced to its simplest form, and we also show the decimal and mixed-number versions.' },
  { q: 'Can I use negative fractions?', a: 'Yes — put a minus sign in the numerator, e.g. -3 / 4.' },
  { q: 'How do I divide fractions?', a: 'Just pick the ÷ operation. Dividing by a fraction multiplies by its reciprocal, which the calculator handles for you.' },
  { q: 'What if the denominator is zero?', a: 'A denominator of zero is undefined in mathematics. The calculator will show an error message if you try it.' },
  { q: 'Can I enter improper fractions?', a: 'Yes, absolutely — any numerator larger than the denominator is fine. The result will show the mixed-number form automatically.' },
  { q: 'Is the decimal result rounded?', a: 'Yes, the decimal is rounded to 6 decimal places for readability. The underlying fraction is exact.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex flex-wrap items-center justify-center gap-3">
      <div class="text-center">
        <input id="n1" type="number" value="1" class="w-20 rounded-lg border border-slate-300 p-2 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <div class="my-1 h-px bg-slate-400"></div>
        <input id="d1" type="number" value="2" class="w-20 rounded-lg border border-slate-300 p-2 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <select id="op" class="rounded-lg border border-slate-300 p-2 text-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="+">+</option><option value="-">−</option><option value="*">×</option><option value="/">÷</option>
      </select>
      <div class="text-center">
        <input id="n2" type="number" value="1" class="w-20 rounded-lg border border-slate-300 p-2 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <div class="my-1 h-px bg-slate-400"></div>
        <input id="d2" type="number" value="3" class="w-20 rounded-lg border border-slate-300 p-2 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <span class="text-2xl text-slate-400">=</span>
      <div id="result" class="text-2xl font-bold text-indigo-600">—</div>
    </div>
    <p id="extra" class="mt-4 text-center text-sm text-slate-500"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Enter the numerator and denominator for each of the two fractions.</li>
      <li>Choose an operation — add (+), subtract (−), multiply (×) or divide (÷).</li>
      <li>The simplified result, decimal value and mixed-number form appear instantly.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Fractions appear everywhere — in recipes that call for ⅔ cup of flour, in woodworking plans that need ⅛-inch precision, and in math homework where adding ⅗ and ⅘ requires a common denominator. Teachers and students use fraction calculators to check their work, while bakers and chefs scale recipes up or down by multiplying fractions. It’s also handy for splitting bills unevenly or calculating precise material quantities in DIY projects.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Use the "Mixed" display to see improper fractions like 7/4 shown as 1 ¾ — easier to visualize.</li>
      <li>Check denominators are not zero before calculating; the calculator will warn you if they are.</li>
      <li>Use negative numerators (e.g., <code class="rounded bg-slate-100 px-1 text-sm">-3 / 4</code>) to represent negative fractions — the calculator handles them correctly.</li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this fraction calculator</h2>
    <p class="mt-2 text-slate-600">
      Working with fractions by hand means finding common denominators and simplifying — easy to
      get wrong. This calculator does it instantly: add, subtract, multiply or divide two
      fractions and get the fully simplified answer, along with the decimal and mixed-number forms.
      You can also use the <a href="/tools/scientific-calculator" class="font-medium text-indigo-600 hover:underline">Scientific Calculator</a>
      for more advanced math or the <a href="/tools/percentage-calculator" class="font-medium text-indigo-600 hover:underline">Percentage Calculator</a>
      for working with percentages.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const gcd = (a, b) => (b ? gcd(b, a % b) : Math.abs(a));

    function update() {
      const n1 = parseInt(el('n1').value, 10), d1 = parseInt(el('d1').value, 10);
      const n2 = parseInt(el('n2').value, 10), d2 = parseInt(el('d2').value, 10);
      if ([n1, d1, n2, d2].some(isNaN) || d1 === 0 || d2 === 0) { el('result').textContent = '—'; el('extra').textContent = 'Denominators can’t be zero.'; return; }
      let num, den;
      switch (el('op').value) {
        case '+': num = n1 * d2 + n2 * d1; den = d1 * d2; break;
        case '-': num = n1 * d2 - n2 * d1; den = d1 * d2; break;
        case '*': num = n1 * n2; den = d1 * d2; break;
        default: num = n1 * d2; den = d1 * n2;
      }
      if (den === 0) { el('result').textContent = '—'; el('extra').textContent = 'Cannot divide by zero.'; return; }
      if (den < 0) { num = -num; den = -den; }
      const g = gcd(num, den) || 1;
      num /= g; den /= g;
      const decimal = (num / den);
      el('result').textContent = den === 1 ? `${num}` : `${num}/${den}`;
      let extra = `Decimal: ${Math.round(decimal * 1e6) / 1e6}`;
      if (den !== 1 && Math.abs(num) > den) {
        const whole = Math.trunc(num / den), rem = Math.abs(num % den);
        if (rem) extra += ` · Mixed: ${whole} ${rem}/${den}`;
      }
      el('extra').textContent = extra;
    }
    ['n1', 'd1', 'n2', 'd2', 'op'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
