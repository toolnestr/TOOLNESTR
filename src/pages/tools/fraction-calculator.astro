---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Fraction Calculator';
const description =
  'Free fraction calculator. Add, subtract, multiply and divide two fractions and get the ' +
  'simplified result, plus the decimal and mixed-number form.';
const intro =
  'Enter two fractions and choose an operation to get the simplified result, decimal value and mixed number.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'Does it simplify the answer?', a: 'Yes. The result is always reduced to its simplest form, and we also show the decimal and mixed-number versions.' },
  { q: 'Can I use negative fractions?', a: 'Yes — put a minus sign in the numerator, e.g. -3 / 4.' },
  { q: 'How do I divide fractions?', a: 'Just pick the ÷ operation. Dividing by a fraction multiplies by its reciprocal, which the calculator handles for you.' },
  { q: 'What if the denominator is zero?', a: 'A denominator of zero is undefined in mathematics. The calculator will show an error message if you try it.' },
  { q: 'Can I enter improper fractions?', a: 'Yes, absolutely — any numerator larger than the denominator is fine. The result will show the mixed-number form automatically.' },
  { q: 'Is the decimal result rounded?', a: 'Yes, the decimal is rounded to 6 decimal places for readability. The underlying fraction is exact.' },
  { q: 'How do I add fractions with different denominators?', a: 'The calculator finds the least common denominator automatically. Just enter both fractions and choose add.' },
  { q: 'What is a mixed number?', a: 'A mixed number combines a whole number and a fraction, like 1 ¾. This calculator converts improper fractions to mixed numbers automatically.' },
  { q: 'Can I multiply more than two fractions?', a: 'Not directly. Multiply two at a time by re-entering the result with your next fraction.' },
  { q: 'Why is simplifying important?', a: 'Simplified fractions are easier to read, compare and use in further calculations. The calculator does this using the greatest common divisor.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="flex flex-wrap items-center justify-center gap-3">
      <div class="text-center">
        <input id="n1" type="number" value="1" class="w-20 rounded-lg border border-slate-300 p-2 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <div class="my-1 h-px bg-slate-400"></div>
        <input id="d1" type="number" value="2" class="w-20 rounded-lg border border-slate-300 p-2 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <select id="op" class="rounded-lg border border-slate-300 p-2 text-lg outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="+">+</option><option value="-">−</option><option value="*">×</option><option value="/">÷</option>
      </select>
      <div class="text-center">
        <input id="n2" type="number" value="1" class="w-20 rounded-lg border border-slate-300 p-2 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <div class="my-1 h-px bg-slate-400"></div>
        <input id="d2" type="number" value="3" class="w-20 rounded-lg border border-slate-300 p-2 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </div>
      <span class="text-2xl text-slate-400">=</span>
      <div id="result" class="text-2xl font-bold text-indigo-600">—</div>
    </div>
    <p id="extra" class="mt-4 text-center text-sm text-slate-500"></p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fraction arithmetic works</h2>
    <p class="mt-2 text-slate-600">
      To add or subtract fractions, you first find a <strong>common denominator</strong> &mdash; a shared multiple of both bottom numbers. The least common denominator is the <strong>LCM</strong> of the two denominators. Once both fractions have the same denominator, you add or subtract only the numerators and keep the denominator unchanged.
    </p>
    <p class="mt-3 text-slate-600">
      For multiplication, multiply the numerators together and the denominators together, then simplify using the <strong>greatest common divisor (GCD)</strong>. For division, flip the second fraction (take its reciprocal) and multiply. The result is always reduced to its simplest form by dividing numerator and denominator by their GCD.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Add <sup>2</sup>/<sub>3</sub> and <sup>3</sup>/<sub>4</sub> using the common denominator method.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Problem:</span> <span class="text-slate-600"><sup>2</sup>/<sub>3</sub> + <sup>3</sup>/<sub>4</sub></span></div>
        <div><span class="font-medium text-slate-700">LCM of 3 and 4:</span> <span class="text-slate-600">12</span></div>
        <div><span class="font-medium text-slate-700">Convert:</span> <span class="text-slate-600"><sup>2</sup>/<sub>3</sub> = <sup>8</sup>/<sub>12</sub>, <sup>3</sup>/<sub>4</sub> = <sup>9</sup>/<sub>12</sub></span></div>
        <div><span class="font-medium text-slate-700">Add:</span> <span class="text-slate-600"><sup>8</sup>/<sub>12</sub> + <sup>9</sup>/<sub>12</sub> = <sup>17</sup>/<sub>12</sub></span></div>
        <div><span class="font-medium text-slate-700">Simplify:</span> <span class="text-slate-600"><sup>17</sup>/<sub>12</sub> = 1 <sup>5</sup>/<sub>12</sub></span></div>
      </div>
    </div>
  </section>

  <figure class="mt-10">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 200" width="800" height="200" role="img" aria-labelledby="frac-title frac-desc">
      <title id="frac-title">Fraction Pie Chart Comparison</title>
      <desc id="frac-desc">Three pie charts side by side showing 1/4 (one quarter), 1/2 (one half), and 3/4 (three quarters) segments filled</desc>

      <circle cx="160" cy="100" r="60" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="2" />
      <path d="M 160 100 L 160 40 A 60 60 0 0 1 220 100 Z" fill="#6366f1" />
      <text x="160" y="108" text-anchor="middle" fill="#1e293b" font-family="system-ui, sans-serif" font-size="16" font-weight="700">1/4</text>
      <text x="160" y="182" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">One quarter</text>

      <circle cx="400" cy="100" r="60" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="2" />
      <path d="M 400 100 L 400 40 A 60 60 0 0 1 400 160 Z" fill="#818cf8" />
      <text x="400" y="108" text-anchor="middle" fill="#1e293b" font-family="system-ui, sans-serif" font-size="16" font-weight="700">1/2</text>
      <text x="400" y="182" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">One half</text>

      <circle cx="640" cy="100" r="60" fill="#f1f5f9" stroke="#cbd5e1" stroke-width="2" />
      <path d="M 640 100 L 640 40 A 60 60 0 0 1 640 160 A 60 60 0 0 1 580 100 Z" fill="#a5b4fc" />
      <text x="640" y="108" text-anchor="middle" fill="#1e293b" font-family="system-ui, sans-serif" font-size="16" font-weight="700">3/4</text>
      <text x="640" y="182" text-anchor="middle" fill="#64748b" font-family="system-ui, sans-serif" font-size="12">Three quarters</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Common fractions shown as pie charts — one quarter, one half, and three quarters of a whole</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common fraction values you will encounter</h2>
    <p class="mt-2 text-slate-600">These fractions appear most often in everyday situations — from recipes and measurements to schoolwork.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">½</span><span class="text-slate-400">One half — 0.5</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">⅓</span><span class="text-slate-400">One third — 0.333</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:80%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">¼</span><span class="text-slate-400">One quarter — 0.25</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:70%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">⅔</span><span class="text-slate-400">Two thirds — 0.667</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:55%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">¾</span><span class="text-slate-400">Three quarters — 0.75</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:40%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🥖</span>
      <h3 class="mt-2 font-semibold text-slate-900">Baker</h3>
      <p class="mt-1 text-sm text-slate-600">Scale recipes up or down by adding and multiplying fractions like ⅔ cup of sugar or ¼ teaspoon of salt.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🎓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Student</h3>
      <p class="mt-1 text-sm text-slate-600">Check fraction homework, practice addition and multiplication, and verify answers before submitting assignments.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🔨</span>
      <h3 class="mt-2 font-semibold text-slate-900">Carpenter</h3>
      <p class="mt-1 text-sm text-slate-600">Add and subtract fractional measurements like ⅛ inch and ¹⁵⁄₁₆ inch accurately for precise cuts and joins.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Chef</h3>
      <p class="mt-1 text-sm text-slate-600">Adjust portion sizes by multiplying or dividing ingredient fractions when changing recipe serving sizes.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Fraction Type</th><th class="p-3">Definition</th><th class="p-3">Example</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Proper</td><td class="p-3">Numerator is smaller than denominator</td><td class="p-3">¾</td></tr>
        <tr><td class="p-3 font-medium">Improper</td><td class="p-3">Numerator is larger than denominator</td><td class="p-3">⁷⁄₄</td></tr>
        <tr><td class="p-3 font-medium">Mixed Number</td><td class="p-3">Whole number plus a proper fraction</td><td class="p-3">1 ¾</td></tr>
        <tr><td class="p-3 font-medium">Unit Fraction</td><td class="p-3">Numerator is exactly 1</td><td class="p-3">⅕</td></tr>
        <tr><td class="p-3 font-medium">Equivalent</td><td class="p-3">Different fractions that equal the same value</td><td class="p-3">½ = ²⁄₄ = ⁴⁄₈</td></tr>
        <tr><td class="p-3 font-medium">Like Fractions</td><td class="p-3">Fractions sharing the same denominator</td><td class="p-3">⅕, ⅗</td></tr>
        <tr><td class="p-3 font-medium">Decimal</td><td class="p-3">Fraction expressed as a decimal number</td><td class="p-3">0.75</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the fraction calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the fractions</h3>
        <p class="mt-1 text-sm text-slate-600">Type the numerator and denominator for each of the two fractions you want to work with.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick an operation</h3>
        <p class="mt-1 text-sm text-slate-600">Choose add (+), subtract (−), multiply (×) or divide (÷) from the dropdown menu between the fractions.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the full result</h3>
        <p class="mt-1 text-sm text-slate-600">See the simplified fraction, exact decimal value and mixed-number form all displayed at once.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accuracy</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Always check the mixed-number result</h3>
        <p class="mt-1 text-sm text-slate-600">Improper fractions like 7/4 are easier to visualise as 1 ¾. The calculator shows this automatically, so use it to build intuition.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Verify denominators are not zero</h3>
        <p class="mt-1 text-sm text-slate-600">A zero denominator makes the fraction undefined. The calculator warns you, but always double-check your entries.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use negative numerators for negative fractions</h3>
        <p class="mt-1 text-sm text-slate-600">Enter -3 / 4 to represent negative three-quarters. The calculator correctly places the negative sign in the result.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Why fraction calculation accuracy matters</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Real-world precision requirements</h3>
        <p class="mt-1 text-sm text-slate-600">Decimal approximations can introduce rounding errors that compound over multiple calculations. A fraction like 1/3 is exactly one third, while its decimal equivalent 0.333333 is only an approximation. When you add 1/3 three times, the fraction gives exactly 1, while the decimal approach yields 0.999999. This tool preserves exact fractional values throughout all operations and only rounds for the decimal display, ensuring that chained calculations remain accurate and free from cumulative error.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Cooking and baking applications</h3>
        <p class="mt-1 text-sm text-slate-600">Recipes frequently use fractional measurements such as 1/2 cup, 3/4 teaspoon, and 1/3 tablespoon. Scaling a recipe from 4 servings to 6 requires multiplying each fraction by 1.5. This calculator handles such conversions precisely, whether you are halving a recipe, doubling it, or adapting it for a different number of servings. The mixed-number output is especially helpful here because 2 1/4 cups is more intuitive to measure than 9/4 cups.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Construction and woodworking measurements</h3>
        <p class="mt-1 text-sm text-slate-600">Carpenters and builders work with fractional inch measurements constantly: 1/8 inch, 3/16 inch, 5/8 inch. Adding and subtracting these fractions is essential for calculating material lengths, spacing, and joinery offsets. A calculator error of 1/16 inch on a single cut can compound across multiple pieces, potentially ruining a project. This tool's exact fraction arithmetic eliminates that risk by preserving precision throughout every operation.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Education and homework verification</h3>
        <p class="mt-1 text-sm text-slate-600">Students learning fraction arithmetic benefit from immediate feedback and multiple representations. Entering 2/3 + 3/5 and seeing 19/15 with its mixed-number equivalent 1 4/15 and decimal 1.266667 provides three complementary views of the same result. This multi-format output helps build intuition about the relationship between fractions, decimals, and mixed numbers while allowing students to verify their manual calculations.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    // This must live in the client script, not the Astro frontmatter --
    // a version defined up there only exists at server-side build time and
    // is never shipped to the browser, so calling it here threw an unguarded
    // ReferenceError on every single calculation (including on page load).
    const gcd = (a, b) => (b ? gcd(b, a % b) : Math.abs(a));

    function update() {
      const n1 = parseInt(el('n1').value, 10), d1 = parseInt(el('d1').value, 10);
      const n2 = parseInt(el('n2').value, 10), d2 = parseInt(el('d2').value, 10);
      if ([n1, d1, n2, d2].some(isNaN) || d1 === 0 || d2 === 0) { el('result').textContent = '—'; el('extra').textContent = 'Denominators can’t be zero.'; return; }
      let num, den;
      switch (el('op').value) {
        case '+': num = n1 * d2 + n2 * d1; den = d1 * d2; break;
        case '-': num = n1 * d2 - n2 * d1; den = d1 * d2; break;
        case '*': num = n1 * n2; den = d1 * d2; break;
        default: num = n1 * d2; den = d1 * n2;
      }
      if (den === 0) { el('result').textContent = '—'; el('extra').textContent = 'Cannot divide by zero.'; return; }
      if (den < 0) { num = -num; den = -den; }
      const g = gcd(num, den) || 1;
      num /= g; den /= g;
      const decimal = (num / den);
      el('result').textContent = den === 1 ? `${num}` : `${num}/${den}`;
      let extra = `Decimal: ${Math.round(decimal * 1e6) / 1e6}`;
      if (den !== 1 && Math.abs(num) > den) {
        const whole = Math.trunc(num / den), rem = Math.abs(num % den);
        if (rem) extra += ` · Mixed: ${whole} ${rem}/${den}`;
      }
      el('extra').textContent = extra;
    }
    ['n1', 'd1', 'n2', 'd2', 'op'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
