---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Transformer Calculator';
const description = 'Calculate transformer turns ratio, primary and secondary voltage and current. Enter any 3 values to solve for the remaining one.';
const intro = 'Calculate turns ratio, voltage, and current for transformers.';
const category = { id: 'engineering', name: 'Engineering' };
const faqs = [
  { q: 'What is turns ratio?', a: 'The ratio of primary winding turns to secondary winding turns. Np/Ns = Vp/Vs = Is/Ip.' },
  { q: 'Does this work for step-up and step-down?', a: 'Yes — enter the values you know and it solves for the unknown, regardless of direction.' },
  { q: 'What about real-world losses?', a: 'This calculator assumes an ideal transformer. Real transformers have core losses and copper losses.' },
  { q: 'What is a center-tapped transformer?', a: 'A transformer with a tap at the centre of the secondary winding, providing two equal voltages.' },
];
const appCategory = 'UtilitiesApplication';
const sources = [
  { html: "<strong>NFPA 70 — National Electrical Code (NEC)</strong>, conduit fill, box fill and conductor ampacity. <a href=\"https://www.nfpa.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nfpa.org</a>" },
  { html: "<strong>IPC-2221</strong>, Generic Standard on Printed Board Design (trace width / current). <a href=\"https://www.ipc.org/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">ipc.org</a>" },
  { html: "<strong>NIST</strong> reference constants and unit definitions; <strong>IEEE</strong> standards where applicable. <a href=\"https://www.nist.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">nist.gov</a>" },
];
const sourcesNote = "For educational and preliminary use. Verify against full engineering calculations and the governing standard before any real design.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory={appCategory} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter any 3 values to solve for the 4th.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Primary voltage V<sub>p</sub> (V)</span>
        <input id="vp" type="number" step="any" placeholder="e.g. 240" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Secondary voltage V<sub>s</sub> (V)</span>
        <input id="vs" type="number" step="any" placeholder="e.g. 12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Turns ratio N<sub>p</sub>/N<sub>s</sub></span>
        <input id="ratio" type="number" step="any" placeholder="e.g. 20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Current ratio I<sub>s</sub>/I<sub>p</sub></span>
        <input id="cr" type="number" step="any" placeholder="e.g. 20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <button id="calc-btn" class="mt-4 w-full rounded-xl bg-indigo-600 p-3 font-medium text-white transition hover:bg-indigo-700">Calculate</button>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Missing value</div><div id="r-result" class="mt-1 text-2xl font-bold">&mdash;</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Direction</div><div id="r-direction" class="mt-1 text-2xl font-bold text-slate-800">&mdash;</div></div>
    </div>
    <div id="r-error" class="mt-3 hidden text-center text-sm text-red-600"></div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" role="img" aria-labelledby="tf-title tf-desc" xmlns="http://www.w3.org/2000/svg">
      <title id="tf-title">Transformer Schematic Diagram</title>
      <desc id="tf-desc">Diagram of a transformer with iron core, primary winding Np on the left, secondary winding Ns on the right, and the turns ratio formula below</desc>
      <rect x="250" y="40" width="30" height="120" fill="#c7d2fe" stroke="#6366f1" stroke-width="2"/>
      <rect x="520" y="40" width="30" height="120" fill="#c7d2fe" stroke="#6366f1" stroke-width="2"/>
      <rect x="280" y="35" width="240" height="20" fill="#c7d2fe" stroke="#6366f1" stroke-width="2"/>
      <rect x="280" y="145" width="240" height="20" fill="#c7d2fe" stroke="#6366f1" stroke-width="2"/>
      <line x1="200" y1="50" x2="250" y2="50" stroke="#94a3b8" stroke-width="2"/>
      <line x1="200" y1="150" x2="250" y2="150" stroke="#94a3b8" stroke-width="2"/>
      <path d="M200,50 Q180,70 200,90 Q220,110 200,130 Q180,150 200,150" fill="none" stroke="#6366f1" stroke-width="3"/>
      <text x="170" y="100" text-anchor="middle" dominant-baseline="central" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="#6366f1">Np</text>
      <text x="140" y="185" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" fill="#64748b">Primary</text>
      <line x1="550" y1="50" x2="600" y2="50" stroke="#94a3b8" stroke-width="2"/>
      <line x1="550" y1="150" x2="600" y2="150" stroke="#94a3b8" stroke-width="2"/>
      <path d="M600,50 Q620,70 600,90 Q580,110 600,130 Q620,150 600,150" fill="none" stroke="#475569" stroke-width="3"/>
      <text x="630" y="100" text-anchor="middle" dominant-baseline="central" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="#475569">Ns</text>
      <text x="660" y="185" text-anchor="middle" font-family="Arial,sans-serif" font-size="13" fill="#64748b">Secondary</text>
      <text x="400" y="210" text-anchor="middle" font-family="Arial,sans-serif" font-size="14" fill="#64748b">Np / Ns = Vp / Vs = Is / Ip</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Transformer turns ratio: Np/Ns = Vp/Vs = Is/Ip</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the transformer formula works</h2>
    <p class="mt-2 text-slate-600">The fundamental relationship governing an ideal transformer is expressed by the equation <strong>N<sub>p</sub> / N<sub>s</sub> = V<sub>p</sub> / V<sub>s</sub> = I<sub>s</sub> / I<sub>p</sub></strong>. This means the turns ratio directly determines both the voltage ratio and the inverse current ratio. If you know any three of these four quantities, you can solve for the remaining one.</p>
    <p class="mt-3 text-slate-600">For an ideal transformer, power is conserved: V<sub>p</sub> &times; I<sub>p</sub> = V<sub>s</sub> &times; I<sub>s</sub>. A step-down transformer reduces voltage and increases current by the same factor. A step-up transformer does the opposite.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Given:</span> <span class="text-slate-600">V<sub>p</sub> = 240 V, V<sub>s</sub> = 12 V, N<sub>p</sub> = 100 turns</span></div>
        <div><span class="font-medium text-slate-700">Turns ratio:</span> <span class="text-slate-600">N<sub>p</sub> / N<sub>s</sub> = 240 / 12 = 20 : 1</span></div>
        <div><span class="font-medium text-slate-700">Secondary turns:</span> <span class="text-slate-600">N<sub>s</sub> = N<sub>p</sub> &times; V<sub>s</sub> / V<sub>p</sub> = 100 &times; 12 / 240 = 5 turns</span></div>
        <div><span class="font-medium text-slate-700">Type:</span> <span class="text-slate-600">Step-down 20:1</span></div>
        <div><span class="font-medium text-slate-700">If I<sub>p</sub> = 2 A:</span> <span class="text-slate-600">I<sub>s</sub> = I<sub>p</sub> &times; (V<sub>p</sub> / V<sub>s</sub>) = 2 &times; 20 = 40 A</span></div>
        <div><span class="font-medium text-slate-700">Power (ideal):</span> <span class="text-slate-600">240 &times; 2 = 12 &times; 40 = 480 VA &#10003;</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x26A1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Transformer Design</h3>
      <p class="mt-1 text-sm text-slate-600">Engineers use the turns ratio to design transformers for power distribution, ensuring the correct voltage step-up or step-down for each stage of the electrical network.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F527;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Power Supply Repair</h3>
      <p class="mt-1 text-sm text-slate-600">Technicians can verify transformer windings by measuring voltages and comparing the calculated ratio against the rated specification during power supply troubleshooting.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F3B5;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Audio Impedance Matching</h3>
      <p class="mt-1 text-sm text-slate-600">Audio transformers match impedance between amplifier outputs and speakers or microphones, using the turns ratio to transform impedance by the square of the ratio.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F50B;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Power Conversion</h3>
      <p class="mt-1 text-sm text-slate-600">Switch-mode power supplies and flyback converters rely on the turns ratio to regulate output voltage across varying input and load conditions in modern electronics.</p>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for transformer calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Ideal transformer model</h3>
        <p class="mt-1 text-sm text-slate-600">This calculator uses the ideal transformer model, which assumes 100% efficiency, no core losses, no copper losses, and perfect magnetic coupling. The ideal model is accurate enough for most design and verification purposes, especially at low power levels where losses are relatively small compared to the throughput.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Real-world efficiency</h3>
        <p class="mt-1 text-sm text-slate-600">Real transformers achieve 95&ndash;99% efficiency depending on size, core material, and design. Large power distribution transformers operate at 98&ndash;99%, while small signal transformers may be only 70&ndash;80% efficient. Losses include copper loss (I&sup2;R in windings), core loss (hysteresis and eddy currents), and stray leakage losses.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Power must balance</h3>
        <p class="mt-1 text-sm text-slate-600">For an ideal transformer, the apparent power on the primary side equals the apparent power on the secondary side: V<sub>p</sub> &times; I<sub>p</sub> = V<sub>s</sub> &times; I<sub>s</sub>. This power balance is the foundation of all transformer calculations and provides a useful sanity check for your results.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Check your ratio direction</h3>
        <p class="mt-1 text-sm text-slate-600">A ratio greater than 1 (N<sub>p</sub> &gt; N<sub>s</sub>) means step-down: voltage decreases and current increases. A ratio less than 1 means step-up: voltage increases and current decreases. Always confirm the direction matches your application before specifying a transformer.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is a transformer?</h2>
    <p class="mt-2 text-slate-600">A transformer is a passive electrical device that transfers electrical energy between two or more circuits through electromagnetic induction. It consists of two or more coils of wire (windings) wrapped around a common magnetic core. When alternating current flows through the primary winding, it creates a time-varying magnetic field in the core, which induces a voltage in the secondary winding. The ratio of input to output voltage is determined solely by the ratio of turns in the windings.</p>
    <p class="mt-3 text-slate-600">Transformers are essential to modern power systems. They allow electricity to be transmitted at high voltages (reducing line losses over long distances) and then stepped down to safe usable voltages for homes and businesses. Without transformers, long-distance electrical power distribution as we know it would not be feasible. They are also used extensively in electronics for power conversion, signal coupling, and impedance matching.</p>
    <p class="mt-3 text-slate-600">The physical size of a transformer is determined by its power rating (in VA or kVA) and operating frequency. Power transformers operating at 50/60 Hz require large iron cores, while high-frequency transformers in switch-mode supplies can be much smaller using ferrite cores. Audio transformers span the range from tiny microphone matching transformers to large output transformers in tube amplifiers.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Step-up vs step-down transformers</h2>
    <p class="mt-2 text-slate-600">A step-down transformer has more primary turns than secondary turns (Np &gt; Ns), producing a lower secondary voltage. These are commonly used in power distribution to reduce transmission voltages to safe levels for end users. A step-up transformer has fewer primary turns than secondary turns (Np &lt; Ns), producing a higher secondary voltage. Step-up transformers are used in power generation to raise voltage for efficient transmission and in applications like neon sign transformers and ignition systems.</p>
    <p class="mt-3 text-slate-600">The current direction is always opposite to the voltage direction. When voltage steps down, current steps up by the same factor, keeping power constant. For example, a transformer with a 10:1 step-down ratio reduces voltage by a factor of 10 but increases available current by a factor of 10. This is why high-voltage transmission lines carry relatively low current: the same power requires less current at higher voltage, reducing I&sup2;R losses in the conductors.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Core construction and materials</h2>
    <p class="mt-2 text-slate-600">Transformer cores are constructed from materials with high magnetic permeability to confine and guide the magnetic flux. The most common core types are: laminated silicon steel (for mains-frequency power transformers, typically 0.35&ndash;0.5 mm thick laminations insulated from each other to reduce eddy current losses), ferrite (for high-frequency applications such as switch-mode power supplies and RF transformers), amorphous metal (for ultra-efficient distribution transformers with very low core losses), and powdered iron (for intermediate frequency ranges).</p>
    <p class="mt-3 text-slate-600">The three main core geometries are core-type (windings surround the core legs), shell-type (the core surrounds the windings), and toroidal (a donut-shaped core with windings wound through the centre). Toroidal cores produce less external magnetic field and are more compact, making them ideal for audio equipment, medical devices, and sensitive instrumentation where stray magnetic fields must be minimised.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Impedance transformation</h2>
    <p class="mt-2 text-slate-600">An important property of transformers is impedance transformation. The impedance seen at the primary of a transformer is related to the impedance connected to the secondary by the square of the turns ratio: Z<sub>p</sub> = (Np/Ns)&sup2; &times; Z<sub>s</sub>. This allows transformers to match a high-impedance source to a low-impedance load, or vice versa, maximising power transfer. Audio output transformers, for example, match the high impedance of a vacuum tube amplifier to the low impedance of a loudspeaker.</p>
    <p class="mt-3 text-slate-600">This relationship also applies to transmission line transformers, baluns (balanced-to-unbalanced converters), and impedance-matching networks in RF systems. The ability to transform impedance is one of the most versatile features of transformers and extends their use far beyond simple voltage conversion.</p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Real transformer losses</h2>
    <p class="mt-2 text-slate-600">While this calculator assumes an ideal transformer, real transformers experience several types of losses: copper losses (I&sup2;R losses in the winding resistance, proportional to the square of the load current), core losses (hysteresis losses from the magnetic domains reversing direction each cycle, plus eddy current losses induced in the core material), leakage flux (magnetic field lines that do not link both windings, causing inductive voltage drop), and stray losses (eddy currents induced in the tank walls and structural parts of large transformers).</p>
    <p class="mt-3 text-slate-600">Efficiency varies with load. Most transformers achieve peak efficiency near full load. At light loads, core losses dominate; at heavy loads, copper losses dominate. Power transformers are typically designed to have minimum total loss at around 75&ndash;100% of rated load. The efficiency of a well-designed large power transformer can exceed 99%, making transformers among the most efficient electrical machines ever built.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/three-phase-power-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">Three-Phase Power Calculator</a>
      <a href="/tools/ohms-law-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">Ohm's Law Calculator</a>
      <a href="/tools/power-factor-calculator" class="rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700 transition hover:border-indigo-200 hover:text-indigo-700">Power Factor Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function directionText(ratio) {
      if (ratio > 1.005) return 'Step-down (V\u2193 I\u2191)';
      if (ratio < 0.995) return 'Step-up (V\u2191 I\u2193)';
      return '1:1 Isolation';
    }

    el('calc-btn').addEventListener('click', function () {
      const vp = parseFloat(el('vp').value);
      const vs = parseFloat(el('vs').value);
      const ratio = parseFloat(el('ratio').value);
      const cr = parseFloat(el('cr').value);

      const hasVp = !isNaN(vp) && vp > 0;
      const hasVs = !isNaN(vs) && vs > 0;
      const hasRatio = !isNaN(ratio) && ratio > 0;
      const hasCr = !isNaN(cr) && cr > 0;

      const count = hasVp + hasVs + hasRatio + hasCr;
      const errorEl = el('r-error');
      const resultEl = el('r-result');
      const dirEl = el('r-direction');

      errorEl.classList.add('hidden');

      if (count < 2 || (count === 2 && !(hasVp && hasVs))) {
        errorEl.textContent = 'Enter any 3 values to solve for the 4th.';
        errorEl.classList.remove('hidden');
        resultEl.textContent = '\u2014';
        dirEl.textContent = '\u2014';
        return;
      }

      if (count === 4) {
        const calcRatio = vp / vs;
        const dir = directionText(calcRatio);
        resultEl.textContent = 'All values known';
        dirEl.textContent = dir;
        if (!hasRatio) el('ratio').value = calcRatio.toFixed(4);
        if (!hasCr) el('cr').value = calcRatio.toFixed(4);
        return;
      }

      let rVp = hasVp ? vp : null;
      let rVs = hasVs ? vs : null;
      let rRatio = hasRatio ? ratio : null;
      let rCr = hasCr ? cr : null;

      if (hasVp && hasVs) {
        const calcRatio = vp / vs;
        if (!hasRatio) rRatio = calcRatio;
        if (!hasCr) rCr = calcRatio;
      }

      if (hasVp && hasRatio && !hasVs) {
        rVs = vp / ratio;
      }
      if (hasVs && hasRatio && !hasVp) {
        rVp = vs * ratio;
      }
      if (hasVp && hasCr && !hasVs) {
        rVs = vp / cr;
      }
      if (hasVs && hasCr && !hasVp) {
        rVp = vs * cr;
      }

      if (rRatio === null && rCr !== null) rRatio = rCr;
      if (rCr === null && rRatio !== null) rCr = rRatio;

      if (rVp === null && rVs === null && rRatio !== null && rCr !== null) {
        errorEl.textContent = 'Enter a voltage (Vp or Vs) along with the ratios.';
        errorEl.classList.remove('hidden');
        resultEl.textContent = '\u2014';
        dirEl.textContent = '\u2014';
        return;
      }

      const displayRatio = rRatio || (rVp && rVs ? rVp / rVs : null);
      const finalDir = displayRatio ? directionText(displayRatio) : '\u2014';

      let missingLabel = '';
      let missingVal = '';
      if (!hasVp) { missingLabel = 'Vp'; missingVal = rVp.toFixed(2) + ' V'; }
      else if (!hasVs) { missingLabel = 'Vs'; missingVal = rVs.toFixed(2) + ' V'; }
      else if (!hasRatio) { missingLabel = 'Np/Ns'; missingVal = rRatio.toFixed(2) + ':1'; }
      else if (!hasCr) { missingLabel = 'Is/Ip'; missingVal = rCr.toFixed(2) + ':1'; }
      else { missingLabel = 'All known'; missingVal = ''; }

      resultEl.textContent = missingVal ? missingLabel + ' = ' + missingVal : missingLabel;
      dirEl.textContent = finalDir;

      if (!hasVp) el('vp').value = rVp.toFixed(2);
      if (!hasVs) el('vs').value = rVs.toFixed(2);
      if (!hasRatio) el('ratio').value = rRatio.toFixed(4);
      if (!hasCr) el('cr').value = rCr.toFixed(4);
    });
  </script>
</ToolLayout>
