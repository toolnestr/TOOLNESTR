---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Logistic Growth / Carrying Capacity Calculator';
const description = "Logistic growth calculator. Solve the logistic growth equation for population size over time as it approaches a carrying capacity, with worked examples.";
const intro = 'Enter an initial population, carrying capacity, growth rate, and time to project logistic population growth — the realistic model where growth slows as resources become limiting. Two 3D diagrams compare a population far below and near its carrying capacity, and charts trace the classic S-shaped growth curve.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is logistic growth?', a: 'Logistic growth models population growth that slows as the population approaches a maximum sustainable size (carrying capacity, K), producing an S-shaped growth curve instead of the ever-accelerating J-shape of unconstrained exponential growth.' },
  { q: 'What is carrying capacity (K)?', a: 'Carrying capacity is the maximum population size an environment can sustainably support given its available resources (food, space, water) — growth slows as the population nears K and theoretically stops entirely once it reaches K.' },
  { q: 'How is logistic growth different from exponential growth?', a: 'Exponential growth (N₀e^(rt)) assumes unlimited resources and keeps accelerating forever. Logistic growth includes a (1−N/K) term that slows growth as N approaches K, producing a realistic leveling-off instead of unlimited acceleration.' },
  { q: 'What happens when a population is far below carrying capacity?', a: 'When N is much smaller than K, the (1−N/K) term is close to 1, so logistic growth behaves almost identically to exponential growth — rapid, accelerating growth, since resources aren\'t yet limiting.' },
  { q: 'What happens when a population reaches carrying capacity?', a: 'As N approaches K, the (1−N/K) term approaches 0, causing growth to slow toward zero — the population levels off at K, since resources can no longer support further growth.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Logistic Growth Calculator',
  description: 'Project population growth with a carrying capacity, using the logistic growth equation.',
  steps: [
    { name: 'Enter N₀, K, and r', text: 'Provide the initial population, carrying capacity, and growth rate.' },
    { name: 'Enter a time value', text: 'Provide how far into the future to project.' },
    { name: 'Read the result', text: 'Projected population N(t) solves instantly, respecting the carrying capacity.' },
  ],
};

const formulas = [
  { expr: 'N(t) = K / (1 + ((K−N₀)/N₀) × e^(−rt))', note: 'the logistic growth equation — solved form for population at time t' },
  { expr: 'dN/dt = rN(1 − N/K)', note: 'the underlying differential equation — growth slows as N approaches K' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a population approaching carrying capacity', tone: 'slate',
    given: 'A population starts at N₀ = 10 with carrying capacity K = 1000 and growth rate r = 0.3 per year. Find the population after t = 20 years.',
    rows: [
      { label: 'Formula:', value: 'N(t) = K / (1 + ((K−N₀)/N₀) × e^(−rt))' },
      { label: 'Substitute:', value: 'N(20) = 1000 / (1 + (990/10) × e^(−6)) = 1000 / (1 + 99 × 0.002479)' },
      { label: 'Result:', value: 'N(20) = 1000 / 1.2454 ≈ 803 individuals', full: true },
    ],
    note: 'After 20 years, the population has grown to roughly 803 out of a maximum sustainable 1000 — well into the leveling-off phase of the S-curve, no longer growing at its earlier explosive rate.',
  },
  {
    title: 'Worked example 2 — early-stage growth, far below capacity', tone: 'amber',
    given: 'The same population parameters (K=1000, r=0.3), but checked much earlier at t = 2 years.',
    rows: [
      { label: 'Formula:', value: 'N(t) = K / (1 + ((K−N₀)/N₀) × e^(−rt))' },
      { label: 'Substitute:', value: 'N(2) = 1000 / (1 + 99 × e^(−0.6)) = 1000 / (1 + 99 × 0.5488)' },
      { label: 'Result:', value: 'N(2) = 1000 / 55.33 ≈ 18.1 individuals', full: true },
    ],
    note: 'Early on, with N still far below K, growth looks almost exponential — the population has only grown from 10 to about 18 in 2 years, since resource limits aren\'t yet meaningfully constraining it.',
  },
];

const comparison = {
  heading: 'Logistic vs exponential growth over time',
  note: 'Both models start identically when the population is small, but logistic growth levels off while exponential growth keeps accelerating.',
  headers: [{ label: 'Time (years)' }, { label: 'Logistic N(t)' }, { label: 'Exponential N(t)' }],
  rows: [
    ['2', '18', '18'],
    ['10', '181', '201'],
    ['20 ★', '803', '4034'],
    ['30', '984', '81031'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference row (worked example 1). By year 30, exponential growth has become wildly unrealistic (over 81,000 individuals) while logistic growth has sensibly leveled off near the carrying capacity of 1000.',
};

const realWorld = [
  { emoji: '🦌', title: 'Wildlife population management', body: 'Wildlife managers use logistic growth models to estimate a habitat\'s carrying capacity for a species, informing hunting quotas, conservation targets, and reintroduction program sizing.' },
  { emoji: '🦠', title: 'Bacterial growth in a limited culture', body: 'Bacteria grown in a finite nutrient supply follow a logistic-like curve, growing exponentially at first before nutrient depletion and waste buildup slow and eventually halt growth.' },
  { emoji: '🌍', title: 'Human population projections', body: 'Long-term human population models increasingly incorporate a carrying-capacity-like framework, accounting for how finite resources and social factors are expected to slow growth as population increases.' },
  { emoji: '🐟', title: 'Fisheries sustainable yield management', body: 'Fisheries scientists use logistic growth models to estimate the maximum sustainable catch that keeps a fish population near its most productive size, avoiding overfishing collapse.' },
];

const misconceptions = [
  { claim: '"Logistic growth and exponential growth look completely different from the very start."', truth: 'They look nearly identical early on, when the population is small relative to carrying capacity — the two models only diverge noticeably as the population grows large enough that the (1−N/K) term starts meaningfully slowing logistic growth.' },
  { claim: '"A population can never exceed its carrying capacity."', truth: "The idealized logistic model assumes it can't, but real populations can temporarily overshoot carrying capacity (especially with time lags in resource depletion or predator response), often followed by a population crash back down toward or below K." },
  { claim: '"Carrying capacity is a fixed, permanent number for a given species."', truth: "Carrying capacity depends on the specific environment's resources at a given time — it can change with seasons, climate, habitat degradation, or human land use, so it isn't a fixed, universal constant for a species." },
  { claim: '"Growth rate (r) is irrelevant once you know the carrying capacity."', truth: 'Both r and K matter — K sets the ceiling the population approaches, but r determines how quickly the population climbs toward that ceiling, meaning two populations with the same K can reach it at very different speeds.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 19, "Population and Community Ecology" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/19-2-population-growth-and-regulation" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 53, Population Ecology.' },
  { html: '<strong>Molles, <em>Ecology: Concepts and Applications</em></strong> — Chapter 10, Population Growth and Regulation.' },
];
const sourcesNote = 'N(t) = K/(1+((K−N₀)/N₀)e^(−rt)), from dN/dt=rN(1−N/K). Assumes constant K and r. Results are rounded for display.';

const howToUse = [
  { title: 'Enter N₀, K, and r', body: 'Provide initial population, carrying capacity, and growth rate.' },
  { title: 'Enter a time value', body: 'Choose how far into the future to project.' },
  { title: 'Read N(t)', body: 'The projected population solves instantly, correctly leveling off near K.' },
];

const related = [
  { href: '/tools/exponential-population-growth-calculator', emoji: '📈', title: 'Exponential Population Growth Calculator', desc: 'N(t) = N₀e^(rt) — unconstrained growth model.' },
  { href: '/tools/population-density-calculator', emoji: '🌍', title: 'Population Density Calculator', desc: 'D = N/A — individuals per unit area.' },
  { href: '/tools/mark-recapture-calculator', emoji: '🐟', title: 'Mark-Recapture Population Estimator', desc: 'Estimate total population size from marked/recaptured counts.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a real population can't grow forever, because as it approaches the maximum size its environment can sustain, the same resources that fueled growth become scarcer — the logistic model captures this by multiplying the exponential growth rate by a braking term that shrinks toward zero as the population nears its ceiling."
  howIntro="Starting from the exponential growth equation dN/dt=rN, the logistic model adds a braking factor (1−N/K): when N is small compared to K, this factor is close to 1 and growth proceeds almost exponentially, but as N approaches K, the factor shrinks toward 0, slowing growth to a halt. Solving this differential equation produces the S-shaped logistic curve N(t)=K/(1+((K−N₀)/N₀)e^(−rt)), which starts by mimicking exponential growth, then bends over and levels off asymptotically at the carrying capacity K."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where logistic growth actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial population (N₀)</span>
        <input id="n0" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Carrying capacity (K)</span>
        <input id="k" type="number" step="any" value="1000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Growth rate (r)</span>
        <input id="rate" type="number" step="any" value="0.3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time (t)</span>
        <input id="time" type="number" step="any" value="20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Population N(t)</div><div id="r-nt" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="log-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Below vs near carrying capacity</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-below" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Far below carrying capacity</h3>
          <p class="mt-1 text-sm text-slate-600">Plenty of unused space (translucent) around a small population — growth proceeds almost exponentially here.</p>
        </div>
        <div>
          <div id="diag-near" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Near carrying capacity</h3>
          <p class="mt-1 text-sm text-slate-600">The environment (translucent capacity) is nearly full — growth has slowed dramatically as resources become limiting.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Logistic growth graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">The classic S-shaped logistic growth curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-curve"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Logistic vs exponential growth over time</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-compare"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function logistic(n0, k, r, t) { return k / (1 + ((k - n0) / n0) * Math.exp(-r * t)); }

      function update() {
        el('log-err').textContent = '';
        el('r-nt').textContent = '—';
        const n0 = parseFloat(el('n0').value), k = parseFloat(el('k').value), r = parseFloat(el('rate').value), t = parseFloat(el('time').value);
        if (isNaN(n0) || isNaN(k) || isNaN(r) || isNaN(t)) return;
        if (n0 <= 0 || k <= 0) { el('log-err').textContent = 'Initial population and carrying capacity must be greater than 0.'; return; }
        el('r-nt').textContent = fmt(logistic(n0, k, r, t));
      }
      ['n0', 'k', 'rate', 'time'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsT = [], dataN = [];
        for (let t = 0; t <= 30; t += 2) { labelsT.push(t); dataN.push(+logistic(10, 1000, 0.3, t).toFixed(1)); }
        charts.curve = new Chart(el('chart-curve'), {
          type: 'line',
          data: { labels: labelsT, datasets: [{ label: 'N(t)', data: dataN, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.35, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (years)' } }, y: { title: { display: true, text: 'Population N(t)' } } }, plugins: { legend: { display: false } } }),
        });
        const dataExp = labelsT.map((t) => Math.min(100000, +(10 * Math.exp(0.3 * t)).toFixed(1)));
        charts.compare = new Chart(el('chart-compare'), {
          type: 'line',
          data: { labels: labelsT, datasets: [
            { label: 'Logistic', data: dataN, borderColor: '#6366f1', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
            { label: 'Exponential', data: dataExp, borderColor: '#ef4444', backgroundColor: 'transparent', tension: 0.3, pointRadius: 0 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (years)' } }, y: { type: 'logarithmic', title: { display: true, text: 'Population (log scale)' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.ready = true;
      }

      function capacityScene(container, fillFraction) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const boundary = new THREE.Mesh(new THREE.SphereGeometry(2.4, 24, 20), new THREE.MeshStandardMaterial({ color: 0x94a3b8, wireframe: true, transparent: true, opacity: 0.3 }));
        s.scene.add(boundary);
        const count = Math.round(30 * fillFraction);
        for (let i = 0; i < count; i++) {
          const phi = Math.acos(1 - (2 * (i + 0.5)) / 30);
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const r = 1.6;
          const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.22, 10, 8), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          sph.position.set(x, y, z);
          s.scene.add(sph);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagBelow = null, diagNear = null;
      function initDiagBelow() { const c = el('diag-below'); if (!c) throw new Error('no container'); diagBelow = capacityScene(c, 0.15); }
      function initDiagNear() { const c = el('diag-near'); if (!c) throw new Error('no container'); diagNear = capacityScene(c, 0.9); }

      function boot() {
        try { update(); } catch (e) { console.error('[logistic-growth] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[logistic-growth] charts failed', e); }
        if (window.THREE) {
          try { initDiagBelow(); } catch (e) { console.error('[logistic-growth] below diagram failed', e); }
          try { initDiagNear(); } catch (e) { console.error('[logistic-growth] near diagram failed', e); }
        }
        mountResize([diagBelow, diagNear]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
