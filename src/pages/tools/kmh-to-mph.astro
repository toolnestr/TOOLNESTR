---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Km/h to Mph"
  emoji="🏎️"
  fromUnit="kilometers per hour" toUnit="miles per hour"
  fromTitle="Kilometers per Hour" toTitle="Miles per Hour"
  fromSym="km/h" toSym="mph"
  quantity="speed"
  kind="factor" factor={0.6213711922}
  reverseSlug="mph-to-kmh" reverseLabel="Mph to Km/h Converter"
  hasReverse={true}
  related={[{"slug":"speed-converter","label":"Speed Converter"}]}
  useCase="Read a metric speed in the miles per hour used on American and British roads."
/>
