---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Codon Usage Calculator';
const description = "Codon usage calculator. Tally codon frequencies from an mRNA sequence and reveal synonymous codon bias for each amino acid, with worked examples.";
const intro = 'Enter an mRNA (or DNA coding-strand) sequence to see how often each codon is used, grouped by amino acid — revealing synonymous codon bias, the tendency for some codons to be favored over other codons that encode the identical amino acid. Two 3D diagrams compare an unbiased amino acid (equal codon use) to a biased one (one codon dominating), and charts show codon frequency and GC content at the third codon position.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is codon usage bias?', a: 'Codon usage bias is the tendency for an organism (or a specific gene) to use certain synonymous codons — codons that code for the same amino acid — more often than others, even though they produce an identical protein.' },
  { q: 'Why does codon usage bias exist if synonymous codons produce the same protein?', a: "It's driven by several factors, including the relative abundance of matching tRNA molecules in a cell (more abundant tRNAs speed up translation for their matching codons), GC content pressures in the genome, and mutational biases — all of which make some codons more efficiently translated than others." },
  { q: 'What is GC3 content?', a: 'GC3 is the percentage of G or C bases specifically at the third position of each codon. Because the third codon position is the most "wobble"-tolerant (least likely to change the amino acid if mutated), GC3 content varies widely between organisms and is a common signature used to identify an organism from its DNA.' },
  { q: 'Is this the same as the mRNA to Protein Translation Tool?', a: "No — the Translation Tool converts a sequence into its resulting amino acid chain. This tool instead analyzes how frequently each individual codon appears and highlights which synonymous codons are favored for each amino acid, which the translation tool doesn't report." },
  { q: 'Why does codon usage matter for genetic engineering?', a: 'When inserting a gene from one organism into another (like a human gene into bacteria for producing a drug), scientists often "codon-optimize" the sequence — replacing codons that are rare in the host organism with more common synonymous ones — to maximize how efficiently the host translates the protein.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Codon Usage Calculator',
  description: 'Tally codon frequencies from an mRNA sequence and reveal synonymous codon usage bias.',
  steps: [
    { name: 'Enter a coding sequence', text: 'Type an mRNA or DNA coding-strand sequence, read in-frame from the first base.' },
    { name: 'Read the codon frequency table', text: 'Every codon used is tallied and grouped by the amino acid it encodes.' },
    { name: 'Check GC3 content', text: 'The percentage of G or C at the third codon position summarizes overall codon usage pattern.' },
  ],
};

const formulas = [
  { expr: 'Relative synonymous codon usage = codon count / total codons for that amino acid', note: 'shows which synonymous codon is favored' },
  { expr: 'GC3 = (G or C at position 3) / total codons × 100%', note: 'GC content specifically at the third (wobble) codon position' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — four synonymous codons for leucine', tone: 'slate',
    given: 'Sequence: CUU-CUC-CUA-CUG (4 codons, all encoding leucine).',
    rows: [
      { label: 'Codon tally:', value: 'CUU=1, CUC=1, CUA=1, CUG=1 (each 25% of leucine codons used here)' },
      { label: 'Amino acid:', value: 'All 4 codons encode leucine (Leu) — a completely unbiased usage pattern', full: true },
    ],
    note: 'Leucine has six possible synonymous codons in the standard genetic code — this example uses four of them in exactly equal proportion, showing no bias at all.',
  },
  {
    title: 'Worked example 2 — biased usage for alanine', tone: 'amber',
    given: 'Sequence: AUG-GCU-GCU-GCC-UAA (start codon, three alanine codons, stop codon).',
    rows: [
      { label: 'Alanine codon tally:', value: 'GCU=2, GCC=1 (out of 3 alanine codons total)' },
      { label: 'Usage bias:', value: 'GCU used 66.7% of the time, GCC used 33.3% of the time', full: true },
    ],
    note: 'Even in this short example, GCU is clearly favored over GCC for alanine — real genes show this same kind of pattern across thousands of codons, often reflecting which tRNAs are most abundant in that organism.',
  },
];

const comparison = {
  heading: "Leucine's six synonymous codons",
  note: 'All six codons below encode the identical amino acid (leucine) — only their usage frequency in a real gene would differ.',
  headers: [{ label: 'Codon' }, { label: 'Amino acid' }, { label: 'Synonymous group' }],
  rows: [
    ['UUA', 'Leu', "Leucine ★"],
    ['UUG', 'Leu', 'Leucine'],
    ['CUU', 'Leu', 'Leucine'],
    ['CUC', 'Leu', 'Leucine'],
    ['CUA', 'Leu', 'Leucine'],
    ['CUG', 'Leu', 'Leucine'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row. Leucine has more synonymous codons (6) than any other amino acid, making it a classic example for studying codon usage bias.',
};

const realWorld = [
  { emoji: '💉', title: 'Recombinant protein production', body: "Biotech companies producing therapeutic proteins (like insulin) in bacteria or yeast codon-optimize the inserted gene to match the host's preferred codons, dramatically increasing protein yield." },
  { emoji: '🧬', title: 'Vaccine and mRNA therapeutic design', body: "mRNA vaccines are engineered with codon usage optimized for efficient translation in human cells, directly affecting how much of the target protein the body's cells produce from the vaccine." },
  { emoji: '🔬', title: 'Species identification from DNA', body: "Codon usage patterns (including GC3 content) are distinctive enough between species that bioinformatics tools can use them as one signal to help identify the likely source organism of an unknown DNA sequence." },
  { emoji: '🧫', title: 'Studying gene expression evolution', body: 'Comparing codon usage bias between related species or between highly-expressed and rarely-expressed genes within one genome offers insight into how translation efficiency has evolved.' },
];

const misconceptions = [
  { claim: '"Codon usage bias means some codons produce a slightly different protein."', truth: "Synonymous codons by definition encode the exact same amino acid — the protein produced is identical regardless of which synonymous codon was used. Codon usage bias affects translation speed/efficiency, not the resulting protein sequence." },
  { claim: '"Every organism uses the same preferred codons."', truth: 'Codon usage bias is often organism-specific (and even gene-specific within one organism) — a codon favored in E. coli may be rare in humans, which is exactly why codon optimization is necessary when moving a gene between species.' },
  { claim: '"Codon usage bias is random noise with no biological cause."', truth: "It correlates with real biological factors — most notably the relative abundance of matching tRNA molecules in the cell, along with GC content and mutational pressures — genes using more abundant-tRNA codons tend to translate faster." },
  { claim: '"GC3 content and overall GC content of a gene are the same measurement."', truth: 'GC3 specifically measures GC content only at the third position of each codon, while overall GC content averages across all three codon positions — they can differ substantially since the third position tolerates far more variation without changing the amino acid.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 15, "Genes and Proteins" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/15-2-prokaryotic-transcription" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Translation and the genetic code chapter.' },
  { html: '<strong>Sharp &amp; Li (1987)</strong> — foundational codon usage bias research (Codon Adaptation Index), <em>Nucleic Acids Research</em>.' },
];
const sourcesNote = 'Uses the standard genetic code (NCBI translation table 1). Analyzes codons in reading frame 1 starting at the first base. Results are rounded for display.';

const howToUse = [
  { title: 'Enter a coding sequence', body: 'Type an mRNA sequence (A, U, C, G) or a DNA coding strand — both are accepted.' },
  { title: 'Read the codon table', body: 'Every codon used is tallied and grouped by the amino acid it encodes.' },
  { title: 'Check for bias', body: 'Compare usage percentages among synonymous codons for the same amino acid.' },
];

const related = [
  { href: '/tools/mrna-translation-calculator', emoji: '🔬', title: 'mRNA to Protein Translation Tool', desc: 'Translate an mRNA sequence into its amino acid chain.' },
  { href: '/tools/gc-content-calculator', emoji: '🧫', title: 'GC Content Calculator', desc: 'Percentage of G and C bases in a sequence.' },
  { href: '/tools/dna-transcription-calculator', emoji: '📜', title: 'DNA to mRNA Transcription Tool', desc: 'Convert a DNA template strand into its mRNA transcript.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="most amino acids have several interchangeable codon spellings, and cells don't use them equally — tallying which synonymous codon actually appears, and how often, reveals a real pattern shaped by translation efficiency, not just genetic redundancy."
  howIntro="The genetic code is degenerate: 61 codons encode only 20 amino acids, so most amino acids can be spelled with two to six different, fully interchangeable codons. If codon choice were random, every synonymous codon for a given amino acid would appear with roughly equal frequency in real genes — but it isn't random. Cells preferentially translate codons that match their most abundant tRNA molecules, so genes (and whole genomes) develop measurable codon usage bias, where some synonymous codons are used far more often than others despite producing an identical protein."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where codon usage actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Coding sequence (mRNA or DNA, in-frame from base 1)</span>
      <textarea id="seq" rows="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">AUGGCUGCUGCCUAA</textarea></label>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Total codons</div><div id="r-total" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">Unique codons used</div><div id="r-unique" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">GC3 content</div><div id="r-gc3" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-4 overflow-x-auto rounded-xl border border-slate-200">
      <table class="w-full text-left text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600"><tr><th class="px-3 py-2">Amino acid</th><th class="px-3 py-2">Codon</th><th class="px-3 py-2">Count</th><th class="px-3 py-2">% of synonymous group</th></tr></thead>
        <tbody id="usage-body" class="divide-y divide-slate-100"></tbody>
      </table>
    </div>
    <p id="cu-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Unbiased vs. biased codon usage</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-unbiased" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Unbiased usage</h3>
          <p class="mt-1 text-sm text-slate-600">Every synonymous codon (equal-sized spheres) appears with roughly equal frequency.</p>
        </div>
        <div>
          <div id="diag-biased" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Biased usage</h3>
          <p class="mt-1 text-sm text-slate-600">One codon (largest sphere) dominates, while its synonymous partners are rarely used.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Codon usage charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Codon frequency in your sequence</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-freq"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Leucine's 6 synonymous codons (reference)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-leu"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const CODE = {
        UUU: 'Phe', UUC: 'Phe', UUA: 'Leu', UUG: 'Leu', CUU: 'Leu', CUC: 'Leu', CUA: 'Leu', CUG: 'Leu',
        AUU: 'Ile', AUC: 'Ile', AUA: 'Ile', AUG: 'Met', GUU: 'Val', GUC: 'Val', GUA: 'Val', GUG: 'Val',
        UCU: 'Ser', UCC: 'Ser', UCA: 'Ser', UCG: 'Ser', CCU: 'Pro', CCC: 'Pro', CCA: 'Pro', CCG: 'Pro',
        ACU: 'Thr', ACC: 'Thr', ACA: 'Thr', ACG: 'Thr', GCU: 'Ala', GCC: 'Ala', GCA: 'Ala', GCG: 'Ala',
        UAU: 'Tyr', UAC: 'Tyr', UAA: 'Stop', UAG: 'Stop', CAU: 'His', CAC: 'His', CAA: 'Gln', CAG: 'Gln',
        AAU: 'Asn', AAC: 'Asn', AAA: 'Lys', AAG: 'Lys', GAU: 'Asp', GAC: 'Asp', GAA: 'Glu', GAG: 'Glu',
        UGU: 'Cys', UGC: 'Cys', UGA: 'Stop', UGG: 'Trp', CGU: 'Arg', CGC: 'Arg', CGA: 'Arg', CGG: 'Arg',
        AGU: 'Ser', AGC: 'Ser', AGA: 'Arg', AGG: 'Arg', GGU: 'Gly', GGC: 'Gly', GGA: 'Gly', GGG: 'Gly',
      };
      let charts = {};

      function update() {
        el('cu-err').textContent = '';
        ['r-total', 'r-unique', 'r-gc3'].forEach((id) => el(id).textContent = '—');
        el('usage-body').innerHTML = '';
        let seq = (el('seq').value || '').toUpperCase().replace(/[^AUTCG]/g, '').replace(/T/g, 'U');
        if (!seq) return;
        const codons = [];
        for (let i = 0; i + 3 <= seq.length; i += 3) codons.push(seq.slice(i, i + 3));
        if (codons.length === 0) { el('cu-err').textContent = 'Enter at least one full codon (3 bases).'; return; }
        const counts = {};
        let gc3 = 0;
        codons.forEach((c) => {
          counts[c] = (counts[c] || 0) + 1;
          if (c[2] === 'G' || c[2] === 'C') gc3++;
        });
        el('r-total').textContent = String(codons.length);
        el('r-unique').textContent = String(Object.keys(counts).length);
        el('r-gc3').textContent = ((gc3 / codons.length) * 100).toFixed(1) + '%';

        // group by amino acid
        const byAmino = {};
        Object.entries(counts).forEach(([codon, count]) => {
          const aa = CODE[codon] || '?';
          byAmino[aa] = byAmino[aa] || {};
          byAmino[aa][codon] = count;
        });
        let rows = '';
        Object.keys(byAmino).sort().forEach((aa) => {
          const group = byAmino[aa];
          const total = Object.values(group).reduce((a, b) => a + b, 0);
          Object.entries(group).sort((a, b) => b[1] - a[1]).forEach(([codon, count]) => {
            rows += '<tr><td class="px-3 py-2 font-medium text-slate-700">' + aa + '</td><td class="px-3 py-2 font-mono">' + codon + '</td><td class="px-3 py-2">' + count + '</td><td class="px-3 py-2">' + ((count / total) * 100).toFixed(1) + '%</td></tr>';
          });
        });
        el('usage-body').innerHTML = rows;
        updateFreqChart(counts);
      }
      el('seq').addEventListener('input', update);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.freq = new Chart(el('chart-freq'), {
          type: 'bar',
          data: { labels: ['AUG', 'GCU', 'GCC', 'UAA'], datasets: [{ label: 'Count', data: [1, 2, 1, 1], backgroundColor: '#6366f1' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Count' } } }, plugins: { legend: { display: false } } }),
        });
        charts.leu = new Chart(el('chart-leu'), {
          type: 'pie',
          data: { labels: ['UUA', 'UUG', 'CUU', 'CUC', 'CUA', 'CUG'], datasets: [{ data: [1, 1, 1, 1, 1, 1], backgroundColor: ['#6366f1', '#818cf8', '#f59e0b', '#fbbf24', '#10b981', '#34d399'] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
      }
      function updateFreqChart(counts) {
        if (!charts.freq) return;
        const labels = Object.keys(counts);
        charts.freq.data.labels = labels;
        charts.freq.data.datasets[0].data = labels.map((l) => counts[l]);
        charts.freq.update('none');
      }

      function codonScene(container, sizes, colors) {
        const s = makeScene(container, 7, new THREE.Vector3(0, 0, 0), OPTS);
        const positions = [[-2, 0], [-0.7, 0], [0.7, 0], [2, 0]];
        sizes.forEach((size, i) => {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(size, 20, 16), new THREE.MeshStandardMaterial({ color: colors[i] }));
          sph.position.set(positions[i][0], 0, 0);
          s.scene.add(sph);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagUnbiased = null, diagBiased = null;
      function initDiagUnbiased() { const c = el('diag-unbiased'); if (!c) throw new Error('no container'); diagUnbiased = codonScene(c, [0.5, 0.5, 0.5, 0.5], [0x6366f1, 0x818cf8, 0xa5b4fc, 0xc7d2fe]); }
      function initDiagBiased() { const c = el('diag-biased'); if (!c) throw new Error('no container'); diagBiased = codonScene(c, [0.85, 0.3, 0.25, 0.2], [0x6366f1, 0xc7d2fe, 0xc7d2fe, 0xc7d2fe]); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[codon-usage] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagUnbiased(); } catch (e) { console.error('[codon-usage] unbiased diagram failed', e); }
          try { initDiagBiased(); } catch (e) { console.error('[codon-usage] biased diagram failed', e); }
        }
        mountResize([diagUnbiased, diagBiased]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
