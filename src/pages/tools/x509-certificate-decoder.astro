              var lsa = readLength(v, p + 1);
              p += 1 + lsa.bytes + lsa.length;
              if (v.getUint8(p) !== 0x30) return null; // issuer
              var li = readLength(v, p + 1);
              p += 1 + li.bytes + li.length;
              if (v.getUint8(p) !== 0x30) return null; // validity
              var lv2 = readLength(v, p + 1);
              p += 1 + lv2.bytes + lv2.length;
              if (v.getUint8(p) !== 0x30) return null; // subject
              var lsub = readLength(v, p + 1);
              p += 1 + lsub.bytes + lsub.length;
              // Now at SPKI
              if (v.getUint8(p) !== 0x30) return null;
              var lspki = readLength(v, p + 1);
              var spkiEnd = p + 1 + lspki.bytes + lspki.length;
              return buf.slice(p, spkiEnd);
            }

            var spkiRaw = findSPKI(tmpDer);
            if (spkiRaw) {
              var spkiHashBuf = await crypto.subtle.digest('SHA-256', spkiRaw);
              spkiHash = hexEncode(spkiHashBuf);
            }
          } catch (e) {
            spkiHash = null;
          }

          // Populate fields
          $('field-subject').textContent = info.subject || 'N/A';
          $('field-issuer').textContent = info.issuer || 'N/A';
          $('field-serial').textContent = info.serialNumber || 'N/A';
          $('field-version').textContent = info.version || 'N/A';
          $('field-valid-from').textContent = info.validFrom || 'N/A';
          $('field-valid-to').textContent = info.validTo || 'N/A';
          $('field-sig-alg').textContent = info.signatureAlgorithm || 'N/A';
          $('field-fingerprint').textContent = fp;
          $('field-pubkey-alg').textContent = info.publicKey ? info.publicKey.algorithm : 'N/A';
          $('field-pubkey-size').textContent = info.publicKey && info.publicKey.keySize ? info.publicKey.keySize + ' bits' : 'N/A';
          $('field-spki-fingerprint').textContent = spkiHash || 'N/A';

          // Expiry badge
          var expiryBadge = $('expiry-badge');
          if (info.validTo && info.validTo !== 'N/A') {
            var parsed = Date.parse(info.validTo);
            if (!isNaN(parsed)) {
              var now = Date.now();
              if (parsed < now) {
                expiryBadge.textContent = 'Expired';
                expiryBadge.className = 'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-red-100 text-red-700';
              } else {
                var daysLeft = Math.floor((parsed - now) / 86400000);
                if (daysLeft <= 30) {
                  expiryBadge.textContent = daysLeft + ' days';
                  expiryBadge.className = 'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-amber-100 text-amber-700';
                } else {
                  expiryBadge.textContent = 'Valid';
                  expiryBadge.className = 'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-100 text-green-700';
                }
              }
            } else {
              expiryBadge.textContent = '';
              expiryBadge.className = 'hidden';
            }
          } else {
            expiryBadge.textContent = '';
            expiryBadge.className = 'hidden';
          }

          // SANs
          var sanContainer = $('field-sans');
          sanContainer.innerHTML = '';
          if (info.extensions && info.extensions.sans && info.extensions.sans.length) {
            info.extensions.sans.forEach(function (san) {
              var span = document.createElement('span');
              span.className = 'mr-1.5 mb-1.5 inline-block rounded-md bg-indigo-50 px-2 py-0.5 font-mono text-xs text-indigo-700';
              span.textContent = san;
              sanContainer.appendChild(span);
            });
          } else {
            sanContainer.textContent = 'N/A';
            sanContainer.className = 'text-sm text-slate-500';
          }

          $('field-basic-constraints').textContent = info.extensions && info.extensions.basicConstraints ? info.extensions.basicConstraints : 'N/A';
          $('field-key-usage').textContent = info.extensions && info.extensions.keyUsage && info.extensions.keyUsage.length ? info.extensions.keyUsage.join(', ') : 'N/A';
          $('field-ext-key-usage').textContent = info.extensions && info.extensions.extKeyUsage && info.extensions.extKeyUsage.length ? info.extensions.extKeyUsage.join(', ') : 'N/A';

          results.classList.remove('hidden');
          showStatus('Certificate decoded successfully', true);
        } catch (err) {
          showStatus('Error decoding certificate: ' + err.message, false);
        } finally {
          setLoading(false);
        }
      }

      decodeBtn.addEventListener('click', decodeCertificate);
    })();
  </script>
</ToolLayout>
