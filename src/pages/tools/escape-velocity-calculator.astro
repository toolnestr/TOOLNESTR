---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Escape Velocity Calculator';
const description = 'Escape velocity calculator with a live 3D launch scene and charts. Solve v_esc = √(2GM/r) for Earth, the Moon, Mars, the Sun and custom bodies, with worked examples.';
const intro = 'Pick a body or enter its mass and radius — the escape velocity solves instantly, with a live 3D launch scene comparing your object’s speed to the escape threshold and two charts comparing planets and distance.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is escape velocity?', a: 'Escape velocity is the minimum speed an unpowered object needs at a given distance from a body to break free of its gravity forever, without any further thrust. Below this speed the object eventually falls back or settles into orbit; at or above it, the object never returns.' },
  { q: 'What is the formula for escape velocity?', a: 'v_esc = √(2GM/r), where G is the gravitational constant (6.674 × 10⁻¹¹ N·m²/kg²), M is the mass of the body being escaped, and r is the distance from the body’s centre — usually its surface radius.' },
  { q: 'What is Earth’s escape velocity?', a: 'About 11.2 km/s (roughly 40,270 km/h) from the surface, using M = 5.972 × 10²⁴ kg and r = 6.371 × 10⁶ m. This is why rockets need enormous speed and fuel to leave Earth permanently, versus the ~7.8 km/s needed just to reach low orbit.' },
  { q: 'Do rockets need to travel at escape velocity the whole way up?', a: 'No. Escape velocity is the speed needed for an object coasting with no further thrust. A rocket burns fuel continuously and can leave gravity at almost any speed, as long as it keeps thrusting — escape velocity only applies once the engines stop.' },
  { q: 'How is escape velocity related to black holes?', a: 'A black hole’s event horizon is, loosely, the radius at which escape velocity equals the speed of light. Because nothing can exceed light speed, nothing — not even light — can escape from within that radius, which is why the region appears black.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Escape Velocity Calculator',
  description: 'Calculate the escape velocity from a body’s mass and radius, or pick a preset body such as Earth, the Moon, Mars or the Sun.',
  steps: [
    { name: 'Pick a body', text: 'Choose Earth, Moon, Mars, Sun — or enter a custom mass and radius.' },
    { name: 'Check the values', text: 'Selecting a preset auto-fills mass (kg) and radius (m); edit either to explore a hypothetical body.' },
    { name: 'Read the result', text: 'Escape velocity solves instantly, and the 3D scene and charts update to match.' },
  ],
};

const formulas = [
  { expr: 'v<sub>esc</sub> = √(2GM / r)', note: 'escape velocity from mass M and distance r' },
  { expr: 'G = 6.674 × 10⁻¹¹ N·m²/kg²', note: 'universal gravitational constant' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — escaping Earth', tone: 'slate',
    given: 'Earth’s mass M = 5.972 × 10²⁴ kg, surface radius r = 6.371 × 10⁶ m, G = 6.674 × 10⁻¹¹ N·m²/kg².',
    rows: [
      { label: 'Formula:', value: 'v<sub>esc</sub> = √(2GM / r)' },
      { label: 'Substitute:', value: 'v<sub>esc</sub> = √((2 × 6.674×10⁻¹¹ × 5.972×10²⁴) / 6.371×10⁶)' },
      { label: 'Result:', value: 'v<sub>esc</sub> ≈ √(1.2521×10¹⁴ / 6.371×10⁶) = √(1.9653×10⁷) ≈ <strong>11.19 km/s</strong>', full: true },
    ],
    note: 'This matches the well-known reference value of Earth’s escape velocity, about 11.2 km/s (≈ 40,270 km/h).',
  },
  {
    title: 'Worked example 2 — escaping the Moon', tone: 'amber',
    given: 'The Moon’s mass M = 7.342 × 10²² kg, surface radius r = 1.737 × 10⁶ m.',
    rows: [
      { label: 'Substitute:', value: 'v<sub>esc</sub> = √((2 × 6.674×10⁻¹¹ × 7.342×10²²) / 1.737×10⁶)' },
      { label: 'Result:', value: 'v<sub>esc</sub> ≈ <strong>2.38 km/s</strong> (≈ 8,550 km/h)', full: true },
    ],
    note: 'About one-fifth of Earth’s escape velocity — a major reason lunar-ascent rockets can be so much smaller than Earth-launch rockets.',
  },
];

const comparison = {
  heading: 'Escape velocity across the solar system',
  note: 'Same formula, wildly different results — mass and radius both matter, not just size.',
  headers: [{ label: 'Body' }, { label: 'Mass', sub: 'kg' }, { label: 'Radius', sub: 'm' }, { label: 'v_esc', sub: 'km/s' }],
  rows: [
    ['Moon', '7.342 × 10²²', '1.737 × 10⁶', '2.38'],
    ['Mars', '6.417 × 10²³', '3.390 × 10⁶', '5.03'],
    ['Earth ★', '5.972 × 10²⁴', '6.371 × 10⁶', '11.19'],
    ['Jupiter', '1.898 × 10²⁷', '6.991 × 10⁷', '60.20'],
    ['Sun', '1.989 × 10³⁰', '6.960 × 10⁸', '617.62'],
  ],
  highlightIndex: 2,
  footnote: '★ Earth reference. v_esc ∝ √(M/r) — Jupiter’s far greater mass outweighs its larger radius, giving it a much higher escape velocity than Earth despite being 11× the size.',
};

const realWorld = [
  { emoji: '🚀', title: 'Rocket launches & interplanetary probes', body: 'Missions leaving Earth’s gravity for good — like Voyager or New Horizons — must reach hyperbolic excess speed at or above escape velocity. Mission planners use v_esc to size the rocket stages and fuel budget needed for a one-way trip out of Earth’s pull.' },
  { emoji: '🛰️', title: 'Satellites vs. escaping spacecraft', body: 'Low-orbit satellites travel at only about 7.8 km/s — enough for a stable orbit but far below Earth’s 11.2 km/s escape velocity. The gap between orbital and escape speed is why staying in orbit takes far less energy than leaving Earth altogether.' },
  { emoji: '🕳️', title: 'Black holes, conceptually', body: 'Treating light as if it obeyed the same escape-velocity formula gives the (non-relativistic) idea of a Schwarzschild radius — the boundary where the calculated escape velocity equals the speed of light, beyond which nothing can get out.' },
];

const misconceptions = [
  { claim: '"Escape velocity means you need continuous thrust to leave forever."', truth: 'The opposite — escape velocity is specifically the speed for an unpowered object (engines off) to never fall back. A rocket that keeps thrusting can leave a planet at almost any speed; escape velocity only matters once the fuel runs out.' },
  { claim: '"Escape velocity is the same everywhere around a planet."', truth: 'It depends on distance from the centre: v_esc = √(2GM/r) shrinks as r grows. Escaping from a high orbit needs a lower speed than escaping from the surface, because you are already partway "up" the gravity well.' },
  { claim: '"A bigger planet always has a higher escape velocity."', truth: 'Size alone is not enough — escape velocity depends on mass and radius together (√(M/r)). A large but low-density body can have a lower escape velocity than a smaller, denser one.' },
  { claim: '"Escaping means leaving gravity’s influence entirely."', truth: 'Gravity technically never reaches zero, only approaches it. "Escaping" means having enough energy to reach an infinite distance with zero speed left over — the object slows forever but (in the idealised model) never actually turns back.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §13.4, Satellite Orbits and Energy (escape velocity) (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/13-4-satellite-orbits-and-energy" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 13, Gravitation (Escape Speed).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 13, Universal Gravitation (Energy Considerations).' },
];
const sourcesNote = 'Gravitational constant G = 6.674 × 10⁻¹¹ N·m²/kg² (CODATA). Preset masses and radii are standard textbook/NASA values. Results are rounded for display.';

const howToUse = [
  { title: 'Pick a body', body: 'Select Earth, Moon, Mars or Sun to auto-fill mass and radius, or type your own.' },
  { title: 'Adjust r if needed', body: 'Use a larger r to find the escape velocity from orbit instead of the surface.' },
  { title: 'Compare on the chart', body: 'See how v_esc stacks up across bodies and how it falls off with distance.' },
];

const related = [
  { href: '/tools/gravitational-force-calculator', emoji: '🌍', title: 'Gravitational Force Calculator', desc: "Newton's law of gravitation between masses." },
  { href: '/tools/free-fall-calculator', emoji: '⬇️', title: 'Free Fall Calculator', desc: 'Time and velocity under gravity.' },
  { href: '/tools/projectile-motion-calculator', emoji: '🎯', title: 'Projectile Motion Calculator', desc: 'Range, height and time from launch speed.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="escape velocity is the minimum speed an unpowered object needs to coast away from a body’s gravity forever, without ever falling back."
  howIntro="The formula comes from setting an object’s kinetic energy equal to the gravitational potential energy needed to reach infinity: ½mv² = GMm/r. The mass m of the escaping object cancels out entirely — escape velocity depends only on the mass and radius of the body being escaped, not on what is trying to leave it."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where escape velocity actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Pick a body, or enter a custom mass and radius — escape velocity solves instantly.</p>
    <div class="mb-4 flex flex-wrap gap-2">
      <button type="button" class="body-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-m="7.342e22" data-r="1.737e6">Moon</button>
      <button type="button" class="body-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-m="6.417e23" data-r="3.390e6">Mars</button>
      <button type="button" class="body-preset rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white" data-m="5.972e24" data-r="6.371e6">Earth</button>
      <button type="button" class="body-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600" data-m="1.989e30" data-r="6.96e8">Sun</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass (M) <span class="text-slate-400">kg</span></span>
        <input id="mass" type="text" inputmode="decimal" placeholder="e.g. 5.972e24" value="5.972e24" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Radius / distance (r) <span class="text-slate-400">m</span></span>
        <input id="radius" type="text" inputmode="decimal" placeholder="e.g. 6.371e6" value="6.371e6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Escape velocity</div><div id="r-vesc" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">In km/h</div><div id="r-kmh" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="ev-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D scene + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D launch</h2>
      <p class="mt-1 text-sm text-slate-500">Drag the sliders for mass and radius — the launch arrow compares your object’s speed against the escape-velocity threshold for the chosen body. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Mass (× Earth) <span id="out-bm" class="font-mono text-blue-600">1.00×</span></span>
          <input id="b-mass" type="range" min="0.01" max="10" step="0.01" value="1" class="mt-2 w-full accent-blue-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Radius (× Earth) <span id="out-br" class="font-mono text-blue-600">1.00×</span></span>
          <input id="b-radius" type="range" min="0.1" max="5" step="0.01" value="1" class="mt-2 w-full accent-blue-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-blue-50 p-3 text-center text-sm text-blue-700">Escape velocity v<sub>esc</sub> = <span id="out-bv" class="font-mono font-bold">—</span></div>
      <div id="scene3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="scene3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Escape velocity graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Escape velocity by body — Moon, Mars, Earth, Sun</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-bodies"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Escape velocity vs distance r (fixed Earth mass) — an inverse square-root curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-r"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const Gc = 6.674e-11;
      const EARTH_M = 5.972e24, EARTH_R = 6.371e6;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      function vesc(M, r) { return Math.sqrt((2 * Gc * M) / r); }

      // ---- calculator ----
      function update() {
        const errEl = el('ev-err'); errEl.textContent = '';
        el('r-vesc').textContent = '—'; el('r-kmh').textContent = '—';
        const M = parseFloat(el('mass').value), r = parseFloat(el('radius').value);
        if (isNaN(M) || isNaN(r)) return;
        if (M <= 0 || r <= 0) { errEl.textContent = 'Mass and radius must both be positive.'; return; }
        const v = vesc(M, r);
        el('r-vesc').textContent = fmt(v / 1000) + ' km/s';
        el('r-kmh').textContent = fmt(v * 3.6) + ' km/h';
      }
      document.querySelectorAll('.body-preset').forEach((b) => b.addEventListener('click', () => {
        document.querySelectorAll('.body-preset').forEach((x) => (x.className = 'body-preset rounded-lg bg-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600'));
        b.className = 'body-preset rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white';
        el('mass').value = b.getAttribute('data-m');
        el('radius').value = b.getAttribute('data-r');
        update();
      }));
      ['mass', 'radius'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let scene3d = null;
      function bState() {
        const mMult = parseFloat(el('b-mass').value), rMult = parseFloat(el('b-radius').value);
        const M = EARTH_M * mMult, r = EARTH_R * rMult;
        return { mMult, rMult, M, r, v: vesc(M, r) };
      }
      function onB() {
        const s = bState();
        el('out-bm').textContent = s.mMult.toFixed(2) + '×';
        el('out-br').textContent = s.rMult.toFixed(2) + '×';
        el('out-bv').textContent = fmt(s.v / 1000) + ' km/s';
        try { if (scene3d) scene3d.update(s); } catch (e) {}
      }
      el('b-mass').addEventListener('input', onB);
      el('b-radius').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const bodies = [
          { name: 'Moon', M: 7.342e22, r: 1.737e6 },
          { name: 'Mars', M: 6.417e23, r: 3.390e6 },
          { name: 'Earth', M: EARTH_M, r: EARTH_R },
          { name: 'Sun', M: 1.989e30, r: 6.96e8 },
        ];
        charts.bodies = new Chart(el('chart-bodies'), {
          type: 'bar',
          data: { labels: bodies.map((b) => b.name), datasets: [{ label: 'v_esc (km/s)', data: bodies.map((b) => +(vesc(b.M, b.r) / 1000).toFixed(2)), backgroundColor: ['#94a3b8', '#f59e0b', '#2563eb', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'Escape velocity (km/s, log scale)' } } }, plugins: { legend: { display: false } } }),
        });
        const rLabels = [], rData = [];
        for (let mult = 0.2; mult <= 5.001; mult += 0.2) { rLabels.push(mult.toFixed(1)); rData.push(+(vesc(EARTH_M, EARTH_R * mult) / 1000).toFixed(2)); }
        charts.r = new Chart(el('chart-r'), {
          type: 'line',
          data: { labels: rLabels, datasets: [{ label: 'v_esc', data: rData, borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Distance r (× Earth radius)' } }, y: { title: { display: true, text: 'Escape velocity (km/s)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- interactive 3D scene ----
      function initScene3d() {
        const c = el('scene3d'); if (!c) throw new Error('no container');
        const s = makeScene(c, 13, new THREE.Vector3(0, 1, 0), OPTS);
        const planet = new THREE.Mesh(new THREE.SphereGeometry(2, 32, 32), new THREE.MeshStandardMaterial({ color: 0x2563eb, roughness: 0.6 }));
        planet.position.y = -1; s.scene.add(planet);
        const rocket = new THREE.Mesh(new THREE.ConeGeometry(0.25, 0.9, 12), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
        rocket.position.set(0, 1.3, 0); s.scene.add(rocket);
        let launchArrow = null;
        function update(state) {
          const planetScale = Math.max(0.6, Math.min(2.2, Math.cbrt(state.rMult)));
          planet.scale.setScalar(planetScale);
          rocket.position.y = -1 + planetScale * 2 + 0.5;
          if (launchArrow) { s.scene.remove(launchArrow); launchArrow = null; }
          const REF_V = 20000; // m/s reference for arrow scaling
          const len = 1 + Math.min(1, state.v / REF_V) * 5;
          const base = rocket.position.clone();
          const color = state.v > vesc(EARTH_M, EARTH_R) ? 0xef4444 : 0x2563eb;
          launchArrow = arrow(base, new THREE.Vector3(base.x, base.y + len, base.z), color);
          s.scene.add(launchArrow);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        scene3d = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { update(); } catch (e) { console.error('[escape-velocity] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[escape-velocity] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[escape-velocity] charts failed', e); }
        if (window.THREE) {
          try { initScene3d(); } catch (e) { console.error('[escape-velocity] scene failed', e); el('scene3d-fallback').classList.remove('hidden'); }
        } else { el('scene3d-fallback').classList.remove('hidden'); }
        mountResize([scene3d]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
