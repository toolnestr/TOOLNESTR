---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Body Shape Calculator';
const description = 'Find your body shape category — hourglass, pear, apple, rectangle, or inverted triangle — from bust, waist, and hip measurements.';
const intro = 'Convert bust, waist, and hip measurements into a general body shape category.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What measurements do I need?', a: 'Bust (fullest part of the chest), waist (narrowest point of the torso), and hip (widest point of the hips and buttocks), all in inches, measured with the tape level and snug but not tight.' },
  { q: 'Is body shape the same as body fat percentage or BMI?', a: 'No — body shape describes the relative proportions between bust, waist, and hip, independent of overall size or weight, while BMI and body fat percentage measure total body composition. Two people with very different BMIs can share the same body shape category.' },
  { q: 'Why does my result feel like it doesn\'t match how I see myself?', a: 'Body shape categories are simplified buckets based on three numbers, not a complete picture — posture, muscle distribution, and where you personally carry weight all affect how a shape looks in practice, so treat the result as a general styling starting point, not a strict label.' },
  { q: 'Does body shape change over time?', a: 'Yes. Weight changes, muscle gain, pregnancy, and aging can all shift the relative proportions between bust, waist, and hip, so it is worth re-measuring periodically rather than assuming a shape from years ago still applies.' },
];
const howTo = {
  name: 'How to find your body shape',
  steps: [
    { name: 'Measure bust, waist, and hip', text: 'Measure each in inches with a soft tape measure.' },
    { name: 'Enter all three measurements', text: 'Type your bust, waist, and hip into the calculator.' },
    { name: 'Read your body shape', text: 'A general shape category appears based on the relationship between your three measurements.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Bust (in)</span>
        <input id="bust" type="number" step="any" placeholder="e.g. 38" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Waist (in)</span>
        <input id="waist" type="number" step="any" placeholder="e.g. 28" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Hip (in)</span>
        <input id="hip" type="number" step="any" placeholder="e.g. 40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Body shape</div>
        <div id="r-shape" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="mt-1 text-sm opacity-90"></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="bdc-title bdc-desc">
      <title id="bdc-title">Five body shape silhouettes side by side</title>
      <desc id="bdc-desc">Simplified outlines showing hourglass, pear, apple, rectangle, and inverted triangle body shapes</desc>
      <path d="M80 20 Q65 20 65 40 Q60 55 75 62 Q60 70 58 90 Q56 105 75 110 L105 110 Q124 105 122 90 Q120 70 105 62 Q120 55 115 40 Q115 20 80 20Z" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <text x="90" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Hourglass</text>
      <path d="M235 20 Q222 20 222 35 Q220 45 230 50 Q210 58 205 90 Q200 105 225 110 L255 110 Q280 105 275 90 Q270 58 250 50 Q260 45 258 35 Q258 20 235 20Z" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <text x="240" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Pear</text>
      <path d="M390 20 Q377 20 377 35 Q374 55 390 62 Q370 68 372 90 Q374 105 395 110 L415 110 Q436 105 438 90 Q440 68 420 62 Q436 55 433 35 Q433 20 390 20Z" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <text x="405" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Apple</text>
      <path d="M545 20 Q533 20 533 35 L525 90 Q523 105 545 110 L575 110 Q597 105 595 90 L587 35 Q587 20 575 20Z" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <text x="560" y="130" text-anchor="middle" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Rectangle</text>
      <path d="M685 20 Q665 20 662 40 Q660 55 682 60 Q698 65 700 90 Q702 105 715 110 L725 110 Q738 105 740 90 Q735 65 718 60 Q722 55 720 40 Q718 20 685 20Z" fill="none" stroke="#c026d3" stroke-width="2.5" />
      <text x="705" y="130" text-anchor="middle" font-size="10" fill="#475569" font-family="system-ui,sans-serif">Inv. Triangle</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">The five general body shape categories used in fashion styling</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How body shape classification works</h2>
    <p class="mt-2 text-slate-600">
      Body shape categories compare the relative sizes of bust, waist, and hip rather than any absolute measurement. An hourglass shape has bust and hip measurements close to each other with a clearly smaller waist. A pear (triangle) shape has hips noticeably larger than the bust. An inverted triangle has the bust noticeably larger than the hips. An apple (round) shape has a waist close in size to the bust and hip, with little waist definition. A rectangle shape has bust, waist, and hip all relatively close together with a fairly straight profile.
    </p>
    <p class="mt-3 text-slate-600">
      This calculator applies the general thresholds most styling guides use: roughly a 3.6-inch or greater difference between bust and hip signals a pear or inverted triangle, and a 9-inch or greater difference between waist and both bust and hip (with bust and hip close together) signals an hourglass. Everything else falls into apple or rectangle depending on how defined the waist is relative to bust and hip.
    </p>
    <p class="mt-3 text-xs text-slate-400">Thresholds follow commonly published fashion-styling body-shape guidelines; these are general categories for styling purposes, not a medical or anthropometric classification.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A measurement set of 38 bust, 26 waist, 39 hip.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Bust − hip:</span> <span class="text-slate-600">|38 − 39| = 1 in (close)</span></div>
        <div><span class="font-medium text-slate-700">Bust − waist:</span> <span class="text-slate-600">12 in</span></div>
        <div><span class="font-medium text-slate-700">Hip − waist:</span> <span class="text-slate-600">13 in</span></div>
        <div><span class="font-medium text-slate-700">Shape:</span> <span class="text-slate-600"><strong>Hourglass</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Personal stylists and online styling services frequently start a wardrobe consultation with a body-shape classification, since it narrows down which silhouettes (fit-and-flare, A-line, wrap, straight-cut) tend to work well without requiring a full in-person fitting first — a useful starting filter even though personal style, comfort, and preference matter as much as any category.
    </p>
    <p class="mt-3 text-slate-600">
      Swimwear and formalwear shopping often lean on body-shape guidance more than everyday clothing, since these garment types are cut closer to the body and offer fewer opportunities for alteration, making silhouette choice matter more at the point of purchase.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Body shape determines what looks good, full stop." <strong class="text-slate-900">Too rigid.</strong> These categories are a starting point for styling suggestions, not a rule about what someone is allowed to wear — personal preference and comfort matter more than fitting a category exactly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Only women's bodies are classified into shapes like this." <strong class="text-slate-900">Not exclusively.</strong> Similar shape logic (comparing shoulder, chest, and waist proportions) is used in menswear styling guidance too, just with different labels and thresholds.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/dress-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Dress Size Calculator</a>
      <a href="/tools/bra-size-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Bra Size Calculator</a>
      <a href="/tools/clothing-size-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Clothing Size Converter</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const bust = parseFloat(el('bust').value);
      const waist = parseFloat(el('waist').value);
      const hip = parseFloat(el('hip').value);
      if (!bust || !waist || !hip || bust <= 0 || waist <= 0 || hip <= 0) { el('results').classList.add('hidden'); return; }

      const bustHipDiff = Math.abs(bust - hip);
      const bustWaistDiff = bust - waist;
      const hipWaistDiff = hip - waist;
      let shape, note;

      if (bustHipDiff <= 1 && bustWaistDiff >= 9 && hipWaistDiff >= 9) {
        shape = 'Hourglass'; note = 'Bust and hip are close in size, with a clearly defined waist.';
      } else if (hip - bust >= 3.6) {
        shape = 'Pear (Triangle)'; note = 'Hips are noticeably larger than the bust.';
      } else if (bust - hip >= 3.6) {
        shape = 'Inverted Triangle'; note = 'Bust is noticeably larger than the hips.';
      } else if (bustWaistDiff < 5 && hipWaistDiff < 5) {
        shape = 'Apple (Round)'; note = 'Waist is close in size to bust and hip, with less definition.';
      } else {
        shape = 'Rectangle'; note = 'Bust, waist, and hip are relatively close in size overall.';
      }

      el('r-shape').textContent = shape;
      el('r-note').textContent = note;
      el('results').classList.remove('hidden');
    }

    ['bust', 'waist', 'hip'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
