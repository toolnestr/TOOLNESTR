---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Yards to Meters"
  emoji="📏"
  fromUnit="yards" toUnit="meters"
  fromTitle="Yards" toTitle="Meters"
  fromSym="yd" toSym="m"
  quantity="length"
  kind="factor" factor={0.9144}
  reverseSlug="meters-to-feet" reverseLabel="Meters to Feet Converter"
  hasReverse={false}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Common in fabric, landscaping and American football, where lengths in yards are converted to meters."
/>
