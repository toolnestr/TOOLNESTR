---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Gibbs Free Energy Calculator';
const description = "Gibbs free energy calculator. Solve ΔG = ΔH − TΔS for any variable, and find the crossover temperature where a reaction flips spontaneous.";
const intro = 'Solve ΔG = ΔH − TΔS for any of the four quantities, and see whether a reaction is spontaneous. Static 3D diagrams and charts show the spontaneous vs non-spontaneous energy picture and the temperature where ΔG changes sign.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is Gibbs free energy?', a: 'Gibbs free energy (G) combines a reaction\'s enthalpy change (heat) and entropy change (disorder) into a single quantity that predicts spontaneity at constant temperature and pressure: ΔG = ΔH − TΔS. A negative ΔG means the reaction proceeds spontaneously as written.' },
  { q: 'What does the sign of ΔG mean?', a: 'ΔG < 0 means the reaction is spontaneous (favorable) in the forward direction at that temperature. ΔG > 0 means it is non-spontaneous forward (but spontaneous in reverse). ΔG = 0 means the system is at equilibrium — no net driving force either way.' },
  { q: 'What units does ΔH, ΔS and T use in this calculator?', a: 'This calculator uses the standard convention: ΔH in kJ/mol, ΔS in J/(mol·K), and T in Kelvin. Because ΔH is in kJ but ΔS is in J, the calculator divides ΔS by 1000 before multiplying by T, so the TΔS term comes out in kJ/mol to match ΔH, giving ΔG in kJ/mol.' },
  { q: 'Can a reaction be non-spontaneous at one temperature but spontaneous at another?', a: 'Yes — this happens whenever ΔH and ΔS have the same sign. Because ΔG = ΔH − TΔS, raising T makes the −TΔS term larger in magnitude. If ΔS is positive, raising T eventually makes ΔG negative (spontaneous at high T); if ΔS is negative, raising T eventually makes ΔG positive (non-spontaneous at high T). The crossover temperature is T = ΔH/ΔS.' },
  { q: 'How is ΔG related to the equilibrium constant K?', a: 'At standard conditions, ΔG° = −RT ln(K). A very negative ΔG° corresponds to a large K (equilibrium favors products); a very positive ΔG° corresponds to a small K (equilibrium favors reactants). ΔG° = 0 corresponds to K = 1.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Gibbs Free Energy Calculator',
  description: 'Solve ΔG = ΔH − TΔS for any of the four variables and see the spontaneity classification.',
  steps: [
    { name: 'Enter three values', text: 'Type any three of ΔH (kJ/mol), ΔS (J/mol·K), T (K) and ΔG (kJ/mol). Leave the unknown blank.' },
    { name: 'Read the result', text: 'The fourth value solves instantly, along with a spontaneous / non-spontaneous / equilibrium label.' },
    { name: 'Check the crossover', text: 'The charts show the temperature where ΔG changes sign, when ΔH and ΔS have the same sign.' },
  ],
};

const formulas = [
  { expr: 'ΔG = ΔH − TΔS', note: 'ΔH in kJ/mol, ΔS in J/(mol·K)/1000, T in K, ΔG in kJ/mol' },
  { expr: 'T<sub>crossover</sub> = ΔH / ΔS', note: 'temperature where ΔG changes sign (ΔS in kJ/mol·K)' },
  { expr: 'ΔG &lt; 0 → spontaneous', note: 'ΔG &gt; 0 → non-spontaneous; ΔG = 0 → equilibrium' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — ammonia synthesis-like reaction at 298 K', tone: 'slate',
    given: 'ΔH = −92.4 kJ/mol, ΔS = −198.7 J/(mol·K), T = 298 K. Find ΔG and classify spontaneity.',
    rows: [
      { label: 'Convert ΔS:', value: 'ΔS = −198.7 J/(mol·K) = −0.1987 kJ/(mol·K)' },
      { label: 'Substitute:', value: 'ΔG = ΔH − TΔS = −92.4 − 298×(−0.1987)' },
      { label: 'ΔG:', value: 'ΔG = −92.4 − (−59.213) = −92.4 + 59.213 = −33.19 kJ/mol', full: true },
    ],
    note: 'ΔG ≈ −33.19 kJ/mol < 0, so the reaction is spontaneous at 298 K — even though entropy decreases, the large negative ΔH dominates at this temperature.',
  },
  {
    title: 'Worked example 2 — finding the crossover temperature', tone: 'amber',
    given: 'A reaction has ΔH = +40.0 kJ/mol and ΔS = +100.0 J/(mol·K) (both positive). Find the temperature at which ΔG = 0.',
    rows: [
      { label: 'Convert ΔS:', value: 'ΔS = 100.0 J/(mol·K) = 0.100 kJ/(mol·K)' },
      { label: 'Crossover:', value: 'T = ΔH / ΔS = 40.0 / 0.100 = 400 K' },
    ],
    note: 'Below 400 K, ΔG is positive (non-spontaneous); above 400 K, ΔG becomes negative (spontaneous) — because both ΔH and ΔS are positive, higher temperature favors spontaneity.',
  },
];

const comparison = {
  heading: 'The four ΔH/ΔS sign combinations and their spontaneity behavior',
  note: 'ΔG = ΔH − TΔS — how temperature affects spontaneity depends entirely on the signs of ΔH and ΔS.',
  headers: [{ label: 'ΔH' }, { label: 'ΔS' }, { label: 'Spontaneity' }],
  rows: [
    ['Negative (exothermic)', 'Positive (more disorder)', 'Spontaneous at all temperatures'],
    ['Positive (endothermic)', 'Negative (less disorder)', 'Non-spontaneous at all temperatures'],
    ['Negative (exothermic)', 'Negative (less disorder)', 'Spontaneous only at low T'],
    ['Positive (endothermic)', 'Positive (more disorder)', 'Spontaneous only at high T'],
  ],
  highlightIndex: 2,
  footnote: 'The last two rows have a crossover temperature T = ΔH/ΔS where ΔG changes sign — the worked examples above are the third and fourth cases.',
};

const realWorld = [
  { emoji: '🧊', title: 'Ice melting and phase transitions', body: 'Ice melting has ΔH > 0 (absorbs heat) and ΔS > 0 (liquid is more disordered than solid), so it is spontaneous only above 0°C — exactly the crossover-temperature behavior ΔG = ΔH − TΔS predicts.' },
  { emoji: '🏭', title: 'Industrial reaction feasibility', body: 'Chemical engineers use ΔG to decide whether a proposed reaction will proceed on its own at a given operating temperature, or whether the process needs to be driven by coupling it to another reaction or supplying continuous energy.' },
  { emoji: '🧬', title: 'Protein folding and biochemistry', body: 'Proteins fold into their functional shapes because the folded state has lower Gibbs free energy than the unfolded state at body temperature — ΔG governs which molecular conformations are thermodynamically favored in living cells.' },
  { emoji: '🔋', title: 'Battery and electrochemical cell design', body: 'The Gibbs free energy of a redox reaction relates directly to the cell voltage a battery can produce (ΔG = −nFE°cell) — a more negative ΔG means a stronger driving force and a higher cell voltage.' },
];

const misconceptions = [
  { claim: '"A negative ΔH always means the reaction happens spontaneously."', truth: 'Not necessarily — spontaneity depends on ΔG, not ΔH alone. If ΔS is very negative and T is high enough, the −TΔS term can outweigh even a negative ΔH, flipping ΔG positive. Exothermic reactions are common but not automatically spontaneous.' },
  { claim: '"ΔG tells you how fast a reaction happens."', truth: 'ΔG is a thermodynamic quantity describing whether a reaction is favorable overall, not how quickly it proceeds. A reaction can have a very negative ΔG yet be kinetically extremely slow without a catalyst — spontaneity and rate are separate questions.' },
  { claim: '"Spontaneous means it happens instantly and by itself, unassisted."', truth: '"Spontaneous" in thermodynamics only means the reaction is thermodynamically favorable in the forward direction — it says nothing about how fast, and many spontaneous reactions still need an initial energy input (activation energy) to get started.' },
  { claim: '"ΔS in J and ΔH in kJ can be plugged into ΔG = ΔH − TΔS directly without converting."', truth: 'They must be converted to the same energy unit first — usually by dividing ΔS (in J/mol·K) by 1000 to get kJ/(mol·K) before multiplying by T. Skipping this conversion is one of the most common arithmetic errors in this calculation.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 16, Thermodynamics: free energy (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/16-4-free-energy" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 19, Chemical Thermodynamics.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Gibbs free energy and spontaneity.' },
];
const sourcesNote = 'ΔG = ΔH − TΔS, with ΔH in kJ/mol, ΔS in J/(mol·K) converted to kJ/(mol·K), and T in Kelvin. Results are rounded for display.';

const howToUse = [
  { title: 'Enter three values', body: 'Fill any three of ΔH, ΔS, T and ΔG; the fourth solves live.' },
  { title: 'Watch the classification', body: 'A label reports spontaneous, non-spontaneous, or at equilibrium.' },
  { title: 'See the crossover', body: 'The charts trace ΔG vs T to show where a reaction flips spontaneity, if it does.' },
];

const related = [
  { href: '/tools/enthalpy-calculator', emoji: '🌋', title: 'Enthalpy Calculator', desc: 'ΔH_rxn from standard enthalpies of formation.' },
  { href: '/tools/entropy-calculator', emoji: '🎲', title: 'Entropy Calculator', desc: 'ΔS_rxn from standard entropies.' },
  { href: '/tools/equilibrium-constant-calculator', emoji: '🔁', title: 'Equilibrium Constant (Keq) Calculator', desc: 'Kc = [C]^c[D]^d / [A]^a[B]^b.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="spontaneity is a tug-of-war between the heat a reaction releases (ΔH) and the disorder it creates (ΔS), and temperature decides which one wins."
  howIntro="Because ΔG = ΔH − TΔS, whenever ΔH and ΔS share the same sign, there is a crossover temperature T = ΔH/ΔS where ΔG switches sign — below it one direction is favored, above it the other is. When ΔH and ΔS have opposite signs, ΔG keeps the same sign at every temperature, so the reaction is either always spontaneous or never spontaneous."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Gibbs free energy actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-xs text-slate-500">Enter any three of the four values; the fourth solves live. ΔH in kJ/mol, ΔS in J/(mol·K), T in Kelvin, ΔG in kJ/mol.</p>
    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">ΔH (kJ/mol)</span>
        <input id="dH" type="number" step="any" placeholder="kJ/mol" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">ΔS (J/mol·K)</span>
        <input id="dS" type="number" step="any" placeholder="J/(mol·K)" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">T (K)</span>
        <input id="T" type="number" step="any" placeholder="Kelvin" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">ΔG (kJ/mol)</span>
        <input id="dG" type="number" step="any" placeholder="kJ/mol" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">ΔG (Gibbs free energy)</div><div id="r-dg" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Spontaneity</div><div id="r-class" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="gf-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-spont" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Spontaneous: ΔG &lt; 0</h3>
          <p class="mt-1 text-sm text-slate-600">The <span class="font-semibold text-emerald-600">product platform</span> sits below the <span class="font-semibold text-red-500">reactant platform</span> in free energy — the reaction rolls downhill on its own.</p>
        </div>
        <div>
          <div id="diag-nonspont" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Non-spontaneous: ΔG &gt; 0</h3>
          <p class="mt-1 text-sm text-slate-600">Here the <span class="font-semibold text-emerald-600">product platform</span> sits above the <span class="font-semibold text-red-500">reactant platform</span> — the forward reaction must be driven by an external energy input.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Gibbs free energy graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ΔG vs T — the spontaneity crossover temperature</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-dgt"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ΔG for the four ΔH/ΔS sign combinations at 298 K</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-cases"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('gf-err').textContent = '';
        el('r-dg').textContent = '—';
        el('r-class').textContent = '—';
        const dH = parseFloat(el('dH').value), dS = parseFloat(el('dS').value);
        const T = parseFloat(el('T').value), dG = parseFloat(el('dG').value);
        const vals = { dH, dS, T, dG };
        const filled = Object.keys(vals).filter((k) => !isNaN(vals[k]));
        if (filled.length < 3) return;
        const missing = Object.keys(vals).filter((k) => isNaN(vals[k]));
        let out = { dH, dS, T, dG };
        if (missing.length === 0) {
          // all given — just show classification for provided dG
        } else if (missing.length === 1) {
          const m = missing[0];
          try {
            if (m === 'dG') { out.dG = dH - T * (dS / 1000); }
            else if (m === 'dH') { out.dH = dG + T * (dS / 1000); }
            else if (m === 'dS') { if (T === 0) throw new Error('T cannot be zero when solving for ΔS.'); out.dS = ((dH - dG) / T) * 1000; }
            else if (m === 'T') { if (dS === 0) throw new Error('ΔS cannot be zero when solving for T.'); out.T = (dH - dG) / (dS / 1000); }
          } catch (e) { el('gf-err').textContent = e.message; return; }
        } else { return; }
        el('r-dg').textContent = fmt(out.dG) + ' kJ/mol';
        if (out.dG < -0.001) el('r-class').textContent = 'Spontaneous (ΔG < 0)';
        else if (out.dG > 0.001) el('r-class').textContent = 'Non-spontaneous (ΔG > 0)';
        else el('r-class').textContent = 'At equilibrium (ΔG = 0)';
      }
      ['dH', 'dS', 'T', 'dG'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        // ΔG vs T for the amber worked example: dH=40, dS=+0.100 kJ/molK -> crossover at 400K
        const dH = 40.0, dSkj = 0.100;
        const labels = [], data = [];
        for (let t = 0; t <= 800; t += 40) { labels.push(t); data.push(+(dH - t * dSkj).toFixed(3)); }
        charts.dgt = new Chart(el('chart-dgt'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'ΔG (kJ/mol)', data, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Temperature (K)' } }, y: { title: { display: true, text: 'ΔG (kJ/mol)' } } }, plugins: { legend: { display: false } } }),
        });
        const cases = [
          { label: '−ΔH / +ΔS\n(always spont.)', dg: -92.4 - 298 * (50 / 1000) },
          { label: '+ΔH / −ΔS\n(never spont.)', dg: 40 - 298 * (-100 / 1000) },
          { label: '−ΔH / −ΔS\n(spont. low T)', dg: -92.4 - 298 * (-198.7 / 1000) },
          { label: '+ΔH / +ΔS\n(spont. high T)', dg: 40 - 298 * (100 / 1000) },
        ];
        charts.cases = new Chart(el('chart-cases'), {
          type: 'bar',
          data: { labels: cases.map((c) => c.label), datasets: [{ label: 'ΔG at 298 K (kJ/mol)', data: cases.map((c) => +c.dg.toFixed(2)), backgroundColor: cases.map((c) => (c.dg < 0 ? '#10b981' : '#ef4444')) }] },
          options: Object.assign({}, base, { indexAxis: 'y', scales: { x: { title: { display: true, text: 'ΔG at 298 K (kJ/mol)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- energy-level platform builder (static, for both diagrams) ----
      function energyLevelScene(container, yReact, yProd) {
        const s = makeScene(container, 14, new THREE.Vector3(0, 0, 0), SCENE_OPTS);
        const reactMat = new THREE.MeshStandardMaterial({ color: 0xef4444, roughness: 0.4 });
        const prodMat = new THREE.MeshStandardMaterial({ color: 0x10b981, roughness: 0.4 });
        const connectMat = new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.6, transparent: true, opacity: 0.6 });

        const reactPlat = new THREE.Mesh(new THREE.BoxGeometry(3, 0.4, 3), reactMat);
        reactPlat.position.set(-3, yReact, 0);
        s.scene.add(reactPlat);

        const prodPlat = new THREE.Mesh(new THREE.BoxGeometry(3, 0.4, 3), prodMat);
        prodPlat.position.set(3, yProd, 0);
        s.scene.add(prodPlat);

        const dy = yProd - yReact;
        const len = Math.sqrt(36 + dy * dy);
        const connector = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, len, 12), connectMat);
        connector.position.set(0, (yReact + yProd) / 2, 0);
        connector.rotation.z = Math.atan2(dy, 6) + Math.PI / 2;
        s.scene.add(connector);

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }

      let diagSpont = null, diagNonspont = null;
      function initDiagSpont() {
        const c = el('diag-spont'); if (!c) throw new Error('no container');
        diagSpont = energyLevelScene(c, 3, -2.5); // reactants higher, products lower -- spontaneous
      }
      function initDiagNonspont() {
        const c = el('diag-nonspont'); if (!c) throw new Error('no container');
        diagNonspont = energyLevelScene(c, -2.5, 3); // reactants lower, products higher -- non-spontaneous
      }

      function boot() {
        try { update(); } catch (e) { console.error('[gibbs] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[gibbs] charts failed', e); }
        if (window.THREE) {
          try { initDiagSpont(); } catch (e) { console.error('[gibbs] spontaneous diagram failed', e); }
          try { initDiagNonspont(); } catch (e) { console.error('[gibbs] non-spontaneous diagram failed', e); }
        }
        mountResize([diagSpont, diagNonspont]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
