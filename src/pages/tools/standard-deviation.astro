---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Standard Deviation Calculator';
const description =
  'Free standard deviation calculator. Enter a set of numbers to get the mean, variance and ' +
  'both population and sample standard deviation. Instant and private.';
const intro =
  'Paste or type your numbers (separated by spaces, commas or new lines) to get the mean, variance and standard deviation.';
const category = { id: 'math', name: 'Math' };
const faqs = [
  { q: 'What is standard deviation?', a: 'Standard deviation measures how spread out a set of numbers is. A low value means the numbers are close to the average; a high value means they\'re more spread out.' },
  { q: 'Population vs sample — which should I use?', a: 'Use population standard deviation when your data is the entire group. Use sample standard deviation when your data is a sample drawn from a larger group.' },
  { q: 'How do I enter my numbers?', a: 'Type or paste them separated by spaces, commas or new lines — the calculator figures it out.' },
  { q: 'What is variance?', a: 'Variance is the square of the standard deviation. It\'s another measure of spread and is shown as "Variance (sample)" in the results.' },
  { q: 'Can standard deviation be negative?', a: 'No. Standard deviation is always zero or a positive number. Zero means all values are identical.' },
  { q: 'What does a large standard deviation tell me?', a: 'A large standard deviation means your data points are widely spread from the mean — for example, salaries in a company with both entry-level and executive roles.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea id="nums" rows="4" placeholder="e.g. 10, 12, 23, 23, 16, 23, 21, 16" class="w-full resize-y rounded-xl border border-slate-300 p-3 font-mono text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">10, 12, 23, 23, 16, 23, 21, 16</textarea>
    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Count</div><div id="r-count" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Sum</div><div id="r-sum" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-sm opacity-80">Mean</div><div id="r-mean" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Sample SD</div><div id="r-ssd" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Population SD</div><div id="r-psd" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Variance (sample)</div><div id="r-var" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Type or paste your numbers separated by spaces, commas or new lines.</li>
      <li>The count, sum, mean and standard deviations update automatically as you type.</li>
      <li>Read both the sample and population standard deviations — choose the one that fits your data.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Standard deviation is essential whenever you need to understand the spread of your data. Students use it in statistics coursework to analyse test score distributions. Quality control engineers monitor manufacturing tolerances — a small standard deviation means consistent products. Financial analysts measure investment risk through the volatility of returns. Researchers use it to determine whether experimental results are significant or just random variation.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Use "Population SD" if your data covers every member of a group; use "Sample SD" if you’re working with a subset of a larger group.</li>
      <li>Remove any outliers or typos before calculating — one wrong number can skew the standard deviation significantly.</li>
      <li>Combine with the mean to understand your data: 68% of values fall within one standard deviation of the mean in a normal distribution.</li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About standard deviation</h2>
    <p class="mt-2 text-slate-600">
      Standard deviation is a core statistic that tells you how much your data varies around the
      average. It’s used everywhere from school assignments to finance and science. This calculator
      gives you the mean, variance and both sample and population standard deviation in one go.
      For basic averages, try the <a href="/tools/average-calculator" class="font-medium text-indigo-600 hover:underline">Average Calculator</a>
      or the <a href="/tools/percentage-calculator" class="font-medium text-indigo-600 hover:underline">Percentage Calculator</a>
      for percentage-based analysis.
    </p>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const round = (n) => Math.round(n * 1e6) / 1e6;

    function update() {
      const nums = el('nums').value.split(/[\s,]+/).map(Number).filter((x) => !isNaN(x) && el('nums').value.trim() !== '');
      const valid = el('nums').value.split(/[\s,]+/).filter((s) => s !== '').map(Number).filter((x) => !isNaN(x));
      if (valid.length === 0) { ['count', 'sum', 'mean', 'ssd', 'psd', 'var'].forEach((k) => (el('r-' + k).textContent = '—')); return; }
      const n = valid.length;
      const sum = valid.reduce((a, b) => a + b, 0);
      const mean = sum / n;
      const sq = valid.reduce((a, b) => a + (b - mean) ** 2, 0);
      const popVar = sq / n;
      const sampVar = n > 1 ? sq / (n - 1) : 0;
      el('r-count').textContent = n;
      el('r-sum').textContent = round(sum);
      el('r-mean').textContent = round(mean);
      el('r-psd').textContent = round(Math.sqrt(popVar));
      el('r-ssd').textContent = n > 1 ? round(Math.sqrt(sampVar)) : '—';
      el('r-var').textContent = n > 1 ? round(sampVar) : '—';
    }
    el('nums').addEventListener('input', update);
    update();
  </script>
</ToolLayout>
