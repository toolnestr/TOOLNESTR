---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Snell's Law (Refraction) Calculator";
const description = "Snell's law calculator with a live 3D bending light ray and charts. Solve n1 sinθ1 = n2 sinθ2 for any variable, plus the critical angle for total internal reflection.";
const intro = 'Solve n₁ sinθ₁ = n₂ sinθ₂ for any refractive index or angle, and find the critical angle for total internal reflection. A live 3D scene bends a light ray at an interface, and charts show the refraction curve and common refractive indices.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is refraction?', a: 'Refraction is the bending of light as it passes from one transparent medium into another with a different refractive index. It happens because light changes speed at the boundary — Snell\'s law, n₁sinθ₁ = n₂sinθ₂, describes exactly how much the ray bends, with angles measured from the normal (the line perpendicular to the interface).' },
  { q: 'What does the refractive index physically represent?', a: 'The refractive index n is the ratio of the speed of light in a vacuum to its speed in the medium: n = c/v. A higher n means light travels slower in that material. Vacuum/air is about 1.00, water about 1.33, glass about 1.50, and diamond about 2.42.' },
  { q: 'What is total internal reflection?', a: 'When light travels from a denser medium (higher n) into a less dense one (lower n) and hits the interface at an angle beyond the critical angle θc = arcsin(n2/n1), it cannot refract out at all — every bit of it reflects back into the denser medium. This is total internal reflection, and it only occurs when n1 > n2.' },
  { q: 'Why does a straw look bent in a glass of water?', a: 'Light from the submerged part of the straw refracts as it exits the water into the air, bending away from the normal because it is moving into a less dense medium (lower n). Your eye assumes light travelled in a straight line, so the submerged part appears shifted from where it actually is — making the straw look bent at the surface.' },
  { q: 'Does Snell\'s law work for any angle of incidence?', a: 'Yes, as long as a refracted ray exists. If you\'re going from a higher-index medium to a lower-index one and the angle of incidence exceeds the critical angle, there is no real solution for θ2 (sinθ2 would need to exceed 1) — that\'s exactly the total-internal-reflection condition, and the calculator flags it rather than returning an angle.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: "How to use the Snell's Law Calculator",
  description: "Calculate the refractive index or angle for light crossing a boundary between two media, using n1 sinθ1 = n2 sinθ2.",
  steps: [
    { name: 'Choose what to solve for', text: 'Pick n1, θ1, n2, or θ2 as the unknown.' },
    { name: 'Enter the other three values', text: 'Use the presets for common materials or type your own refractive index.' },
    { name: 'Read the result', text: 'The angle or index solves instantly; total internal reflection is flagged if it applies, and the 3D ray and charts update.' },
  ],
};

const formulas = [
  { expr: 'n₁ sinθ₁ = n₂ sinθ₂', note: "Snell's law — angles from the normal" },
  { expr: 'θc = arcsin(n₂ / n₁)', note: 'critical angle, only valid when n₁ &gt; n₂' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — air into water', tone: 'slate',
    given: 'Light travels from air (n1 = 1.00) into water (n2 = 1.33), hitting the surface at θ1 = 30° from the normal. Find θ2.',
    rows: [
      { label: 'Formula:', value: 'sinθ2 = (n1 sinθ1) / n2' },
      { label: 'Substitute:', value: 'sinθ2 = (1.00 × sin30°) / 1.33 = (1.00 × 0.5) / 1.33' },
      { label: 'Simplify:', value: 'sinθ2 = 0.3759' },
      { label: 'Angle:', value: 'θ2 = arcsin(0.3759) ≈ 22.08°', full: true },
    ],
    note: 'Water is denser (higher n) than air, so the ray bends toward the normal: θ2 < θ1.',
  },
  {
    title: 'Worked example 2 — critical angle in glass', tone: 'amber',
    given: 'Light inside glass (n1 = 1.50) hits a boundary with air (n2 = 1.00). Find the critical angle for total internal reflection.',
    rows: [
      { label: 'Formula:', value: 'θc = arcsin(n2 / n1)' },
      { label: 'Substitute:', value: 'θc = arcsin(1.00 / 1.50) = arcsin(0.6667)' },
      { label: 'Critical angle:', value: 'θc ≈ 41.81°', full: true },
    ],
    note: 'For any angle of incidence beyond 41.81° inside the glass, the light cannot escape into the air — it totally internally reflects.',
  },
];

const comparison = {
  heading: 'Refractive indices of common materials',
  note: 'Standard reference values at visible-light wavelengths, used as calculator presets.',
  headers: [{ label: 'Material' }, { label: 'Refractive index (n)' }],
  rows: [
    ['Vacuum / air', '1.00'],
    ['Water', '1.33'],
    ['Glass (crown)', '1.50'],
    ['Diamond', '2.42'],
  ],
  highlightIndex: 1,
  footnote: 'Actual values vary slightly with wavelength (dispersion) and exact material composition — these are widely used approximations.',
};

const realWorld = [
  { emoji: '🔦', title: 'Fiber optic cables', body: 'Light is sent down a glass or plastic core with a higher refractive index than the surrounding cladding. Because the light always strikes the core-cladding boundary beyond the critical angle, it totally internally reflects over and over, carrying signals for kilometres with minimal loss.' },
  { emoji: '👓', title: 'Eyeglass and camera lens design', body: 'Lens makers choose glass with a specific refractive index (and shape the curvature) so that Snell\'s law bends incoming light rays to converge exactly on the retina or sensor, correcting for the eye\'s natural focusing error or capturing a sharp image.' },
  { emoji: '🌈', title: 'Rainbow formation', body: 'Sunlight refracts as it enters a raindrop, reflects off the back of the drop, and refracts again on the way out. Because the refractive index depends slightly on wavelength, different colours bend by different amounts, spreading white light into the visible spectrum.' },
  { emoji: '💎', title: 'Gemstone brilliance', body: "Diamond's very high refractive index (2.42) gives it a small critical angle, so light entering the stone tends to totally internally reflect multiple times before exiting — this is a major reason cut diamonds sparkle so much more than lower-index gems." },
];

const misconceptions = [
  { claim: '"Light always bends toward the normal when entering any new medium."', truth: 'It only bends toward the normal when entering a MORE optically dense medium (higher n) — like air into water. Going the other way, into a LESS dense medium (lower n), the ray bends away from the normal instead.' },
  { claim: '"Total internal reflection can happen going from any medium to any other."', truth: 'It can only happen when light travels from a higher-index medium into a lower-index one (n1 > n2), and only when the angle of incidence exceeds the critical angle θc = arcsin(n2/n1). Going from lower to higher index, a refracted ray always exists.' },
  { claim: '"The refractive index tells you how much a material bends light, full stop."', truth: 'It sets the ratio n1sinθ1 = n2sinθ2, but the actual bend also depends on the angle of incidence — light hitting the surface straight on (θ1 = 0°) does not bend at all, no matter how different the two refractive indices are.' },
  { claim: '"A higher refractive index always means a more transparent material."', truth: 'Refractive index is about how much light slows down and bends, not about transparency or absorption. A material can have a high n and still be highly transparent (diamond) or, in principle, absorb strongly — the two properties are independent.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 3</em></strong> — §1.3 "The Law of Refraction" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-3/pages/1-3-the-law-of-refraction" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 33, Electromagnetic Waves (refraction and Snell\'s law).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 35, The Nature of Light and the Laws of Geometric Optics.' },
];
const sourcesNote = 'n1 sinθ1 = n2 sinθ2, with angles measured from the normal to the interface. Results are rounded for display.';

const howToUse = [
  { title: 'Choose the unknown', body: 'The calculator solves for n1, θ1, n2, or θ2 from the other three.' },
  { title: 'Use the material presets', body: 'Pick air, water, glass, or diamond, or type any positive refractive index.' },
  { title: 'Watch the bending ray', body: 'Use the sliders to see the ray bend at the interface, and check for total internal reflection.' },
];

const related = [
  { href: '/tools/wavelength-frequency-calculator', emoji: '🌊', title: 'Wavelength–Frequency Calculator', desc: 'c = λf — solve for any variable.' },
  { href: '/tools/coulombs-law-calculator', emoji: '⚡', title: "Coulomb's Law Calculator", desc: 'F = k|q1q2|/r² — electrostatic force.' },
  { href: '/tools/heat-transfer-calculator', emoji: '🌡️', title: 'Heat Transfer Calculator', desc: 'Q = mcΔT — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="Snell's law says the product of a medium's refractive index and the sine of the ray's angle from the normal stays the same across a boundary — n₁sinθ₁ = n₂sinθ₂ — so light bends toward the normal entering a denser medium and away from it entering a less dense one."
  howIntro="Rearranged, n1 sinθ1 = n2 sinθ2 solves any variable: sinθ2 = n1sinθ1/n2, sinθ1 = n2sinθ2/n1, n2 = n1sinθ1/sinθ2, and n1 = n2sinθ2/sinθ1. When going from a higher-index medium into a lower-index one, there is a maximum angle of incidence — the critical angle θc = arcsin(n2/n1) — beyond which no real solution for θ2 exists and the light totally internally reflects instead of refracting."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Snell's law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-n1" type="button" data-solve="n1" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">n1</button>
      <button id="mode-t1" type="button" data-solve="t1" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">θ1</button>
      <button id="mode-n2" type="button" data-solve="n2" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">n2</button>
      <button id="mode-t2" type="button" data-solve="t2" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">θ2</button>
    </div>
    <div class="mb-4 flex flex-wrap gap-2 text-xs">
      <span class="pt-2 font-medium text-slate-500">Presets:</span>
      <button type="button" data-preset-n1="1.00" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">n1 = Air (1.00)</button>
      <button type="button" data-preset-n1="1.33" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">n1 = Water (1.33)</button>
      <button type="button" data-preset-n1="1.50" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">n1 = Glass (1.50)</button>
      <button type="button" data-preset-n2="1.00" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">n2 = Air (1.00)</button>
      <button type="button" data-preset-n2="1.33" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">n2 = Water (1.33)</button>
      <button type="button" data-preset-n2="2.42" class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-semibold text-slate-600 hover:bg-slate-200">n2 = Diamond (2.42)</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-4">
      <label id="field-n1" class="block"><span class="text-sm font-medium text-slate-700">n1</span>
        <input id="n1" type="number" step="any" min="1" placeholder="e.g. 1.00" value="1.00" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-t1" class="block"><span class="text-sm font-medium text-slate-700">θ1 (deg)</span>
        <input id="t1" type="number" step="any" min="0" max="90" placeholder="0-90°" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-n2" class="block"><span class="text-sm font-medium text-slate-700">n2</span>
        <input id="n2" type="number" step="any" min="1" placeholder="e.g. 1.33" value="1.33" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-t2" class="block"><span class="text-sm font-medium text-slate-700">θ2 (deg)</span>
        <input id="t2" type="number" step="any" min="0" max="90" placeholder="0-90°" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div id="box-n1" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">n1</div><div id="r-n1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-t1" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">θ1</div><div id="r-t1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-n2" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">n2</div><div id="r-n2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-t2" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">θ2</div><div id="r-t2" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="sl-hint" class="mt-3 text-center text-sm text-slate-500"></p>
    <p id="sl-err" class="mt-1 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">3D refraction diagrams</h2>
      <p class="mt-1 text-sm text-slate-500">Two static, auto-rotating scenes: how the bend angle changes with the angle of incidence, and what happens beyond the critical angle.</p>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-refraction" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Bend angle grows with incidence angle</h3>
          <p class="mt-1 text-sm text-slate-600">Two incident/refracted ray pairs at air→water (n1=1.00, n2=1.33): a shallow 20° hit (<span class="font-semibold text-slate-500">gray</span>) bends only a little, while a steeper 50° hit (<span class="font-semibold text-indigo-600">indigo</span>) bends much more. Both stay on the same side of the dashed normal.</p>
        </div>
        <div>
          <div id="diag-tir" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Total internal reflection</h3>
          <p class="mt-1 text-sm text-slate-600">Light inside glass (n1=1.50) hitting a glass→air boundary at 60° — beyond the ≈41.8° critical angle. No ray escapes into the air; instead it fully reflects back into the glass (<span class="font-semibold text-red-500">red</span>) at the same angle from the normal.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Refraction graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">θ2 vs θ1, air (n=1.00) into water (n=1.33)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-curve"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Refractive indices of common materials</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-n"></canvas></div>
        </figure>
      </div>
      <p class="mt-2 text-xs text-slate-400">Going the reverse way — water into air — total internal reflection sets in beyond the critical angle θc = arcsin(1.00/1.33) ≈ 48.75°, so no θ2 curve exists past that point.</p>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };
      const D2R = Math.PI / 180, R2D = 180 / Math.PI;

      // ---- calculator ----
      let solveFor = 't2';
      const modeBtns = { n1: 'mode-n1', t1: 'mode-t1', n2: 'mode-n2', t2: 'mode-t2' };
      const fieldEls = { n1: 'field-n1', t1: 'field-t1', n2: 'field-n2', t2: 'field-t2' };
      const boxEls = { n1: 'box-n1', t1: 'box-t1', n2: 'box-n2', t2: 'box-t2' };

      function switchSolve(s) {
        solveFor = s;
        Object.keys(modeBtns).forEach((k) => {
          el(modeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(fieldEls).forEach((k) => {
          el(fieldEls[k]).style.opacity = k === s ? '0.45' : '1';
        });
        Object.keys(boxEls).forEach((k) => {
          el(boxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        update();
      }

      function update() {
        el('sl-err').textContent = '';
        el('sl-hint').textContent = '';
        ['r-n1', 'r-t1', 'r-n2', 'r-t2'].forEach((id) => (el(id).textContent = '—'));
        const n1 = parseFloat(el('n1').value);
        const t1 = parseFloat(el('t1').value);
        const n2 = parseFloat(el('n2').value);
        const t2 = parseFloat(el('t2').value);

        function critNote(a, b) {
          if (isNaN(a) || isNaN(b) || a <= b) return '';
          const tc = Math.asin(b / a) * R2D;
          return 'Critical angle for this pair: θc = arcsin(n2/n1) ≈ ' + fmt(tc) + '° (beyond this, total internal reflection occurs).';
        }

        if (solveFor === 't2') {
          if (isNaN(n1) || isNaN(t1) || isNaN(n2)) return;
          if (n1 <= 0 || n2 <= 0) { el('sl-err').textContent = 'Refractive indices must be positive.'; return; }
          if (t1 < 0 || t1 > 90) { el('sl-err').textContent = 'θ1 must be between 0° and 90°.'; return; }
          const s2 = (n1 * Math.sin(t1 * D2R)) / n2;
          if (s2 > 1) {
            el('sl-err').textContent = 'Total internal reflection — no refracted ray exists at this angle.';
            el('r-n1').textContent = fmt(n1); el('r-t1').textContent = fmt(t1) + '°'; el('r-n2').textContent = fmt(n2);
            el('sl-hint').textContent = critNote(n1, n2);
            return;
          }
          const tt2 = Math.asin(s2) * R2D;
          el('r-n1').textContent = fmt(n1); el('r-t1').textContent = fmt(t1) + '°'; el('r-n2').textContent = fmt(n2); el('r-t2').textContent = fmt(tt2) + '°';
          el('sl-hint').textContent = critNote(n1, n2);
        } else if (solveFor === 't1') {
          if (isNaN(n1) || isNaN(n2) || isNaN(t2)) return;
          if (n1 <= 0 || n2 <= 0) { el('sl-err').textContent = 'Refractive indices must be positive.'; return; }
          if (t2 < 0 || t2 > 90) { el('sl-err').textContent = 'θ2 must be between 0° and 90°.'; return; }
          const s1 = (n2 * Math.sin(t2 * D2R)) / n1;
          if (s1 > 1) { el('sl-err').textContent = 'No valid angle of incidence produces this θ2 with these indices.'; return; }
          const tt1 = Math.asin(s1) * R2D;
          el('r-n1').textContent = fmt(n1); el('r-t1').textContent = fmt(tt1) + '°'; el('r-n2').textContent = fmt(n2); el('r-t2').textContent = fmt(t2) + '°';
          el('sl-hint').textContent = critNote(n1, n2);
        } else if (solveFor === 'n2') {
          if (isNaN(n1) || isNaN(t1) || isNaN(t2)) return;
          if (n1 <= 0) { el('sl-err').textContent = 'n1 must be positive.'; return; }
          if (t1 < 0 || t1 > 90 || t2 < 0 || t2 > 90) { el('sl-err').textContent = 'Angles must be between 0° and 90°.'; return; }
          if (Math.sin(t2 * D2R) === 0) { el('sl-err').textContent = 'θ2 cannot be 0° when solving for n2 (unless θ1 is also 0°).'; return; }
          const nn2 = (n1 * Math.sin(t1 * D2R)) / Math.sin(t2 * D2R);
          if (nn2 <= 0) { el('sl-err').textContent = 'Resulting n2 is not physical for these inputs.'; return; }
          el('r-n1').textContent = fmt(n1); el('r-t1').textContent = fmt(t1) + '°'; el('r-n2').textContent = fmt(nn2) + ' '; el('r-t2').textContent = fmt(t2) + '°';
          el('sl-hint').textContent = critNote(n1, nn2);
        } else if (solveFor === 'n1') {
          if (isNaN(n2) || isNaN(t1) || isNaN(t2)) return;
          if (n2 <= 0) { el('sl-err').textContent = 'n2 must be positive.'; return; }
          if (t1 < 0 || t1 > 90 || t2 < 0 || t2 > 90) { el('sl-err').textContent = 'Angles must be between 0° and 90°.'; return; }
          if (Math.sin(t1 * D2R) === 0) { el('sl-err').textContent = 'θ1 cannot be 0° when solving for n1 (unless θ2 is also 0°).'; return; }
          const nn1 = (n2 * Math.sin(t2 * D2R)) / Math.sin(t1 * D2R);
          if (nn1 <= 0) { el('sl-err').textContent = 'Resulting n1 is not physical for these inputs.'; return; }
          el('r-n1').textContent = fmt(nn1) + ' '; el('r-t1').textContent = fmt(t1) + '°'; el('r-n2').textContent = fmt(n2); el('r-t2').textContent = fmt(t2) + '°';
          el('sl-hint').textContent = critNote(nn1, n2);
        }
      }
      el('mode-n1').addEventListener('click', () => switchSolve('n1'));
      el('mode-t1').addEventListener('click', () => switchSolve('t1'));
      el('mode-n2').addEventListener('click', () => switchSolve('n2'));
      el('mode-t2').addEventListener('click', () => switchSolve('t2'));
      ['n1', 't1', 'n2', 't2'].forEach((id) => el(id).addEventListener('input', update));
      document.querySelectorAll('[data-preset-n1]').forEach((b) => b.addEventListener('click', () => { el('n1').value = b.getAttribute('data-preset-n1'); update(); }));
      document.querySelectorAll('[data-preset-n2]').forEach((b) => b.addEventListener('click', () => { el('n2').value = b.getAttribute('data-preset-n2'); update(); }));

      // ---- charts shared state ----
      const charts = {};

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const L = [], D = [];
        for (let a = 0; a <= 89.001; a += 1) {
          const s2 = (1.00 * Math.sin(a * D2R)) / 1.33;
          L.push(a.toFixed(0));
          D.push(s2 <= 1 ? +(Math.asin(s2) * R2D).toFixed(3) : null);
        }
        charts.curve = new Chart(el('chart-curve'), {
          type: 'line',
          data: { labels: L, datasets: [{ label: 'θ2', data: D, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'θ1 (degrees)' } }, y: { title: { display: true, text: 'θ2 (degrees)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.n = new Chart(el('chart-n'), {
          type: 'bar',
          data: { labels: ['Air', 'Water', 'Glass', 'Diamond'], datasets: [{ label: 'n', data: [1.00, 1.33, 1.50, 2.42], backgroundColor: ['#94a3b8', '#38bdf8', '#818cf8', '#f472b6'] }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: false } } , y: { title: { display: true, text: 'Refractive index (n)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }
      function updateCharts(s) { /* charts show fixed reference curves; nothing dynamic to update */ }

      // ---- static diagram helpers ----
      function addInterface(s) {
        const planeMat = new THREE.MeshStandardMaterial({ color: 0x93c5fd, transparent: true, opacity: 0.35, side: THREE.DoubleSide });
        const plane = new THREE.Mesh(new THREE.PlaneGeometry(8, 8), planeMat);
        plane.rotation.x = -Math.PI / 2;
        s.scene.add(plane);
        s.scene.add(new THREE.GridHelper(8, 8, 0xcbd5e1, 0xe2e8f0));

        const normalGeo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, -3, 0), new THREE.Vector3(0, 3, 0)]);
        const normalMat = new THREE.LineDashedMaterial({ color: 0x64748b, dashSize: 0.15, gapSize: 0.1 });
        const normalLine = new THREE.Line(normalGeo, normalMat);
        normalLine.computeLineDistances();
        s.scene.add(normalLine);
      }

      // ---- Diagram 1: refraction at two incidence angles ----
      let diagRefraction = null;
      function initDiagRefraction() {
        const c = el('diag-refraction'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        addInterface(s);

        const R = 3.2;
        function addPair(t1deg, n1, n2, color) {
          const t1r = t1deg * D2R;
          const inStart = new THREE.Vector3(-Math.sin(t1r) * R, Math.cos(t1r) * R, 0);
          s.scene.add(arrow(inStart, new THREE.Vector3(0, 0, 0), color));
          const s2 = (n1 * Math.sin(t1r)) / n2;
          if (s2 <= 1) {
            const t2r = Math.asin(s2);
            const outEnd = new THREE.Vector3(Math.sin(t2r) * R, -Math.cos(t2r) * R, 0);
            s.scene.add(arrow(new THREE.Vector3(0, 0, 0), outEnd, color));
          }
        }
        addPair(20, 1.00, 1.33, 0x94a3b8);
        addPair(50, 1.00, 1.33, 0x6366f1);

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagRefraction = { resize: s.resize };
      }

      // ---- Diagram 2: total internal reflection ----
      let diagTIR = null;
      function initDiagTIR() {
        const c = el('diag-tir'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        addInterface(s);

        const R = 3.2;
        const t1deg = 60; // beyond the ~41.8° critical angle for glass (1.50) -> air (1.00)
        const t1r = t1deg * D2R;
        const inStart = new THREE.Vector3(-Math.sin(t1r) * R, Math.cos(t1r) * R, 0);
        s.scene.add(arrow(inStart, new THREE.Vector3(0, 0, 0), 0xef4444));
        const reflEnd = new THREE.Vector3(Math.sin(t1r) * R, Math.cos(t1r) * R, 0);
        s.scene.add(arrow(new THREE.Vector3(0, 0, 0), reflEnd, 0xef4444));

        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagTIR = { resize: s.resize };
      }

      function boot() {
        try { switchSolve('t2'); update(); } catch (e) { console.error('[snells-law] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[snells-law] charts failed', e); }
        if (window.THREE) {
          try { initDiagRefraction(); } catch (e) { console.error('[snells-law] refraction diagram failed', e); }
          try { initDiagTIR(); } catch (e) { console.error('[snells-law] TIR diagram failed', e); }
        }
        mountResize([diagRefraction, diagTIR]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
