---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fabric Shrinkage Calculator';
const description = 'Calculate fabric shrinkage percentage, or how much extra fabric to buy to compensate for expected shrinkage.';
const intro = 'Calculate shrinkage percentage from a test swatch, or how much extra fabric to buy to offset it.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I test a fabric\'s shrinkage before cutting?', a: 'Cut a square swatch (a 10-inch or 25cm square is common), measure it precisely, wash and dry it the same way you plan to treat the finished garment, then measure it again. The percentage difference is your shrinkage rate for that fabric and care method.' },
  { q: 'Should I test both length and width?', a: 'Yes — many fabrics, especially wovens, shrink more in one direction (usually length/warp) than the other, so measuring both dimensions separately gives a more accurate buying buffer than assuming uniform shrinkage.' },
  { q: 'Do all fabrics shrink the same amount?', a: 'No. Natural fibers like cotton and linen typically shrink more (often 3-8% depending on weave and finish) than synthetic fibers like polyester, which often shrink under 1%. Pre-washed or "sanforized" fabrics are treated specifically to minimize shrinkage.' },
  { q: 'Is it better to pre-wash fabric or buy extra to compensate?', a: 'Pre-washing the fabric before cutting is generally more reliable, since it shrinks the fabric before it becomes a garment rather than after — buying extra to compensate is a fallback for fabrics that can\'t be safely pre-washed (like some wools or dry-clean-only fabrics).' },
];
const howTo = {
  name: 'How to calculate fabric shrinkage',
  steps: [
    { name: 'Measure a test swatch', text: 'Measure a fabric swatch before washing, then wash and dry it as intended and measure again.' },
    { name: 'Enter both measurements', text: 'Type the original and post-wash measurements into the calculator.' },
    { name: 'Read shrinkage and buying buffer', text: 'The shrinkage percentage and the extra fabric to buy for a desired finished size appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Original measurement (in)</span>
        <input id="orig" type="number" step="any" placeholder="e.g. 10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Post-wash measurement (in)</span>
        <input id="shrunk" type="number" step="any" placeholder="e.g. 9.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Desired finished length after wash (in, optional)</span>
      <input id="desired" type="number" step="any" placeholder="e.g. 30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Shrinkage rate</div>
        <div id="r-pct" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div id="buy-row" class="hidden rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Buy this length to end up with your desired size</div><div id="r-buy" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="fsc-title fsc-desc">
      <title id="fsc-title">Fabric square before and after shrinking</title>
      <desc id="fsc-desc">A larger square labeled before-wash next to a smaller square labeled after-wash, showing fabric shrinkage</desc>
      <rect x="100" y="20" width="140" height="140" fill="none" stroke="#94a3b8" stroke-width="2" stroke-dasharray="5 3" />
      <text x="170" y="180" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Before wash</text>
      <rect x="420" y="45" width="110" height="110" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <text x="475" y="180" text-anchor="middle" font-size="13" fill="#475569" font-family="system-ui,sans-serif">After wash</text>
      <path d="M270 90 L390 90" stroke="#c026d3" stroke-width="2" marker-end="url(#arrow)" />
      <defs><marker id="arrow" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6 Z" fill="#c026d3" /></marker></defs>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Shrinkage percentage compares the swatch size before and after washing</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How shrinkage calculation works</h2>
    <p class="mt-2 text-slate-600">
      Shrinkage percentage is the difference between a fabric's original and post-wash measurement, divided by the original measurement. A swatch that measures 10 inches before washing and 9.5 inches after has shrunk by (10 − 9.5) ÷ 10 = 5%. Once you know this rate for a specific fabric and wash method, you can work backward to figure out how much fabric to buy so that after it shrinks, the finished piece is still the size you actually want.
    </p>
    <p class="mt-3 text-slate-600">
      The buying formula divides your desired finished length by (1 minus the shrinkage rate) — if you want a 30-inch finished panel from fabric that shrinks 5%, you need to buy 30 ÷ 0.95 ≈ 31.6 inches before washing, since that extra length is exactly what the wash will remove.
    </p>
    <p class="mt-3 text-xs text-slate-400">This is the standard shrinkage-allowance formula used across the textile and garment industry for pre-shrink planning.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 10-inch test swatch measures 9.5 inches after washing and drying, and the sewist wants a 30-inch finished curtain length.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Shrinkage:</span> <span class="text-slate-600">(10 − 9.5) ÷ 10 = 5%</span></div>
        <div><span class="font-medium text-slate-700">Fabric to buy:</span> <span class="text-slate-600">30 ÷ 0.95 ≈ <strong>31.6 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Quilters and garment sewists who skip pre-washing sometimes find a finished piece has shrunk noticeably at the first laundering, which is a much harder problem to fix after construction than before cutting — testing shrinkage on a swatch first, or pre-washing the full yardage, avoids discovering the problem in a completed project.
    </p>
    <p class="mt-3 text-slate-600">
      Natural-fiber fabrics bought from overseas suppliers, where finishing processes (like sanforization, which pre-shrinks fabric mechanically) may not be applied or disclosed, benefit especially from this kind of test — a shrinkage rate that seems small per swatch can translate into several inches lost on a full curtain panel or dress length.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Shrinkage only happens the first time you wash something." <strong class="text-slate-900">Mostly, but not always.</strong> Most shrinkage occurs on the first hot wash and dry cycle, but some natural fibers continue shrinking slightly over several washes, especially if later washed hotter than the first time.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A fabric shrinks the same amount in length and width." <strong class="text-slate-900">Often not true.</strong> Many woven fabrics shrink more along the length (warp direction) than the width (weft), so testing and buying extra in one direction only can leave the other direction short.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-yardage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Yardage Calculator</a>
      <a href="/tools/fabric-care-wash-temperature-guide/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Care/Wash Temperature Guide</a>
      <a href="/tools/fabric-waste-overrun-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Fabric Waste & Overrun Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const orig = parseFloat(el('orig').value);
      const shrunk = parseFloat(el('shrunk').value);
      const desired = parseFloat(el('desired').value);
      if (!orig || !shrunk || orig <= 0 || shrunk <= 0 || shrunk > orig) { el('results').classList.add('hidden'); return; }
      const pct = ((orig - shrunk) / orig) * 100;
      el('r-pct').textContent = pct.toFixed(1) + '%';
      el('results').classList.remove('hidden');
      if (desired && desired > 0) {
        const buyLength = desired / (1 - pct / 100);
        el('r-buy').textContent = buyLength.toFixed(1) + ' in';
        el('buy-row').classList.remove('hidden');
      } else {
        el('buy-row').classList.add('hidden');
      }
    }

    ['orig', 'shrunk', 'desired'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
