  <script is:inline>
  (function () {
    var STORAGE_KEY = 'toolnestr_invoice_draft_v2';
    var FIELD_IDS = ['fromName','fromAddress','fromEmail','fromPhone','fromWebsite',
      'toName','toAddress','toEmail','toPhone',
      'invNumber','invDate','invDue','invStatus','invNotes','invTerms','bankDetails','discount','taxRate'];

    let logoDataUrl = null;
    let signatureDataUrl = null;
    let signatureText = '';
    let signatureFont = 'Dancing Script';
    let sigMode = 'draw';
    let currentTemplate = 'classic';
    let items = [
      { desc: 'Service / Product', qty: 1, rate: 0 },
    ];
    let currSymbol = '$';

    // ── Helpers ──
    function fmtMoney(n) {
      return currSymbol + Number(n || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    function v(id) { return (document.getElementById(id)?.value || '').trim(); }
    function today() { return new Date().toISOString().split('T')[0]; }
    function addDays(d, n) { const dt = new Date(d); dt.setDate(dt.getDate() + n); return dt.toISOString().split('T')[0]; }
    function fmtDate(s) {
      if (!s) return '–';
      try { return new Date(s + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }); } catch { return s; }
    }
    function escapeHtml(s) { return (s || '').replace(/</g, '&lt;'); }

    // ── Init dates ──
    document.getElementById('invDate').value = today();
    document.getElementById('invDue').value  = addDays(today(), 30);

    // ── Template picker ──
    window.igSetTemplate = function (id) {
      currentTemplate = id;
      document.querySelectorAll('.tpl-option').forEach(function (el) {
        el.classList.toggle('active', el.getAttribute('data-tpl') === id);
      });
      renderPreview();
      saveDraft();
    };

    // ── Items table ──
    function renderItemsTable() {
      const tbody = document.getElementById('itemsBody');
      tbody.innerHTML = items.map((item, i) => `
        <tr>
          <td class="col-desc"><input type="text" value="${item.desc.replace(/"/g,'&quot;')}" placeholder="Description" oninput="window.igUpdate(${i},'desc',this.value)" /></td>
          <td class="col-qty"><input type="number" value="${item.qty}" min="0" step="any" oninput="window.igUpdate(${i},'qty',this.value)" /></td>
          <td class="col-rate"><input type="number" value="${item.rate}" min="0" step="any" oninput="window.igUpdate(${i},'rate',this.value)" /></td>
          <td class="col-amt"><div class="item-total">${fmtMoney(item.qty * item.rate)}</div></td>
          <td class="col-del">${items.length > 1 ? `<button class="del-btn" onclick="window.igDel(${i})">×</button>` : ''}</td>
        </tr>
      `).join('');
    }

    window.igUpdate = function(i, field, val) {
      items[i][field] = field === 'desc' ? val : parseFloat(val) || 0;
      // Update only this row's amount cell in place — rebuilding the whole
      // table on every keystroke would destroy the focused input and drop
      // the caret, forcing the user to re-click after each character.
      var row = document.querySelectorAll('#itemsBody tr')[i];
      if (row) {
        var amt = row.querySelector('.item-total');
        if (amt) amt.textContent = fmtMoney(items[i].qty * items[i].rate);
      }
      renderPreview();
      saveDraft();
    };
    window.igDel = function(i) {
      items.splice(i, 1);
      renderItemsTable();
      renderPreview();
      saveDraft();
    };

    document.getElementById('addItemBtn').addEventListener('click', () => {
      items.push({ desc: '', qty: 1, rate: 0 });
      renderItemsTable();
      renderPreview();
      saveDraft();
    });

    // ── Logo ──
    const logoUpload = document.getElementById('logoUpload');
    const logoFile   = document.getElementById('logoFile');
    logoUpload.addEventListener('click', () => logoFile.click());
    logoFile.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        logoDataUrl = ev.target.result;
        document.getElementById('logoImg').src     = logoDataUrl;
        document.getElementById('logoImg').style.display = '';
        document.getElementById('logoPlaceholder').style.display = 'none';
        renderPreview();
        saveDraft();
      };
      reader.readAsDataURL(file);
    });

    // ── Signature ──
    const sigCanvas = document.getElementById('sigCanvas');
    const sigCtx = sigCanvas.getContext('2d');
    let drawing = false, lastX = 0, lastY = 0;

    let sigDpr = 1;
    function resizeCanvas() {
      const rect = sigCanvas.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return; // hidden (display:none) — keep prior valid size
      sigDpr = window.devicePixelRatio || 1;
      sigCanvas.width = rect.width * sigDpr;
      sigCanvas.height = rect.height * sigDpr;
      sigCtx.setTransform(sigDpr, 0, 0, sigDpr, 0, 0);
      sigCtx.lineWidth = 2;
      sigCtx.lineCap = 'round';
      sigCtx.lineJoin = 'round';
      sigCtx.strokeStyle = '#1e293b';
    }
    setTimeout(resizeCanvas, 0);
    window.addEventListener('resize', resizeCanvas);

    function pos(e) {
      const rect = sigCanvas.getBoundingClientRect();
      const cx = e.touches ? e.touches[0].clientX : e.clientX;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      return { x: cx - rect.left, y: cy - rect.top };
    }
    function startDraw(e) { drawing = true; const p = pos(e); lastX = p.x; lastY = p.y; }
    function moveDraw(e) {
      if (!drawing) return;
      e.preventDefault();
      const p = pos(e);
      sigCtx.beginPath();
      sigCtx.moveTo(lastX, lastY);
      sigCtx.lineTo(p.x, p.y);
      sigCtx.stroke();
      lastX = p.x; lastY = p.y;
    }

    // Crops the signature to the actual ink bounding box (plus small padding) so
    // the exported image isn't mostly blank canvas — otherwise CSS max-height
    // scaling shrinks the visible strokes to a barely-legible sliver.
    function trimCanvasToInk() {
      const w = sigCanvas.width, h = sigCanvas.height;
      const data = sigCtx.getImageData(0, 0, w, h).data;
      let minX = w, minY = h, maxX = 0, maxY = 0, found = false;
      for (let y = 0; y < h; y += 2) {
        for (let x = 0; x < w; x += 2) {
          if (data[(y * w + x) * 4 + 3] > 10) {
            found = true;
            if (x < minX) minX = x; if (x > maxX) maxX = x;
            if (y < minY) minY = y; if (y > maxY) maxY = y;
          }
        }
      }
      if (!found) return null;
      const pad = 10 * sigDpr;
      minX = Math.max(0, minX - pad); minY = Math.max(0, minY - pad);
      maxX = Math.min(w, maxX + pad); maxY = Math.min(h, maxY + pad);
      const cropW = maxX - minX, cropH = maxY - minY;
      const out = document.createElement('canvas');
      out.width = cropW; out.height = cropH;
      out.getContext('2d').drawImage(sigCanvas, minX, minY, cropW, cropH, 0, 0, cropW, cropH);
      return out.toDataURL('image/png');
    }

    function endDraw() {
      if (!drawing) return;
      drawing = false;
      signatureDataUrl = trimCanvasToInk();
      renderPreview();
      saveDraft();
    }
    sigCanvas.addEventListener('pointerdown', startDraw);
    sigCanvas.addEventListener('pointermove', moveDraw);
    window.addEventListener('pointerup', endDraw);
    sigCanvas.addEventListener('touchstart', startDraw, { passive: true });
    sigCanvas.addEventListener('touchmove', moveDraw, { passive: false });
    sigCanvas.addEventListener('touchend', endDraw);

    document.getElementById('sigClearBtn').addEventListener('click', () => {
      sigCtx.clearRect(0, 0, sigCanvas.width / sigDpr, sigCanvas.height / sigDpr);
      signatureDataUrl = null;
      renderPreview();
      saveDraft();
    });

    const sigModeDrawBtn = document.getElementById('sigModeDrawBtn');
    const sigModeTypeBtn = document.getElementById('sigModeTypeBtn');
    const sigDrawWrap = document.getElementById('sigDrawWrap');
    const sigTypeWrap = document.getElementById('sigTypeWrap');
    function setSigMode(mode) {
      sigMode = mode;
      sigModeDrawBtn.classList.toggle('active', mode === 'draw');
      sigModeTypeBtn.classList.toggle('active', mode === 'type');
      sigDrawWrap.style.display = mode === 'draw' ? '' : 'none';
      sigTypeWrap.style.display = mode === 'type' ? '' : 'none';
      // The canvas lays out at 0x0 while its wrapper is display:none, so
      // switching back into draw mode needs a resize or drawing silently
      // no-ops on a zero-size backing store.
      if (mode === 'draw') setTimeout(resizeCanvas, 0);
      renderPreview();
      saveDraft();
    }
    sigModeDrawBtn.addEventListener('click', () => setSigMode('draw'));
    sigModeTypeBtn.addEventListener('click', () => setSigMode('type'));

    const sigTypeInput = document.getElementById('sigTypeInput');
    const sigTypePreview = document.getElementById('sigTypePreview');
    const sigFontSelect = document.getElementById('sigFontSelect');
    sigTypePreview.style.fontFamily = "'" + signatureFont + "', cursive";
    sigTypeInput.addEventListener('input', function () {
      signatureText = this.value;
      sigTypePreview.textContent = signatureText;
      renderPreview();
      saveDraft();
    });
    sigFontSelect.addEventListener('change', function () {
      signatureFont = this.value;
      sigTypePreview.style.fontFamily = "'" + signatureFont + "', cursive";
      renderPreview();
      saveDraft();
    });

    // ── Currency ──
    document.getElementById('currencySelect').addEventListener('change', function () {
      currSymbol = this.value;
      renderItemsTable();
      renderPreview();
      saveDraft();
    });

    // ── Render preview ──
    function renderPreview() {
      const subtotal  = items.reduce((s, it) => s + it.qty * it.rate, 0);
      const discPct   = parseFloat(document.getElementById('discount')?.value) || 0;
      const taxPct    = parseFloat(document.getElementById('taxRate')?.value)  || 0;
      const discAmt   = subtotal * discPct / 100;
      const taxable   = subtotal - discAmt;
      const taxAmt    = taxable * taxPct / 100;
      const total     = taxable + taxAmt;

      const fromName    = v('fromName')    || 'Your Company';
      const fromAddr    = v('fromAddress') || '';
      const fromEmail   = v('fromEmail')   || '';
      const fromPhone   = v('fromPhone')   || '';
      const fromWeb     = v('fromWebsite') || '';
      const toName      = v('toName')      || 'Client Name';
      const toAddr      = v('toAddress')   || '';
      const toEmail     = v('toEmail')     || '';
      const toPhone     = v('toPhone')     || '';
      const invNum      = v('invNumber')   || 'INV-001';
      const invDate     = v('invDate')     || today();
      const invDue      = v('invDue')      || '';
      const invStatus   = v('invStatus')   || '';
      const notes       = v('invNotes')    || '';
      const terms       = v('invTerms')    || '';
      const bankDetails = v('bankDetails') || '';

      const fromSub = [fromAddr, fromEmail, fromPhone, fromWeb].filter(Boolean).join('\n');

      const sidebarMode = currentTemplate === 'sidebar';

      const headerBlock = `
          <div class="inv-header">
            <div>
              ${logoDataUrl ? `<div class="inv-logo-area"><img src="${logoDataUrl}" alt="logo" /></div>` : ''}
              <div class="inv-company-name">${escapeHtml(fromName)}</div>
              ${fromSub ? `<div class="inv-company-sub">${escapeHtml(fromSub).replace(/\n/g,'<br>')}</div>` : ''}
            </div>
            ${sidebarMode ? '' : `
            <div class="inv-right">
              <div class="inv-title">INVOICE</div>
              <div class="inv-number">${invNum}</div>
            </div>`}
          </div>`;

      const bodyBlock = `
          ${sidebarMode ? `
          <div class="inv-right">
            <div class="inv-title">INVOICE</div>
            <div class="inv-number">${invNum}</div>
          </div>` : ''}
          <div class="inv-meta">
            <div class="inv-bill-to">
              <div class="inv-label">Bill To</div>
              <div class="inv-val" style="font-weight:700;">${escapeHtml(toName)}</div>
              ${toAddr  ? `<div class="inv-val" style="margin-top:4px;">${escapeHtml(toAddr).replace(/\n/g,'<br>')}</div>` : ''}
              ${toEmail ? `<div class="inv-val">${escapeHtml(toEmail)}</div>` : ''}
              ${toPhone ? `<div class="inv-val">${escapeHtml(toPhone)}</div>` : ''}
            </div>
            <div class="inv-dates">
              <div class="inv-label">Invoice Details</div>
              <div class="inv-date-row"><span class="dk">Invoice Date</span><span class="dv">${fmtDate(invDate)}</span></div>
              ${invDue ? `<div class="inv-date-row"><span class="dk">Due Date</span><span class="dv">${fmtDate(invDue)}</span></div>` : ''}
              <div class="inv-date-row"><span class="dk">Invoice #</span><span class="dv">${invNum}</span></div>
            </div>
          </div>

          <div class="inv-items">
            <div class="inv-items-head">
              <div>Description</div><div style="text-align:center;">Qty</div><div style="text-align:center;">Rate</div><div style="text-align:right;">Amount</div>
            </div>
            ${items.map(it => `
              <div class="inv-item-row">
                <div>${escapeHtml(it.desc) || '–'}</div>
                <div class="iq">${it.qty}</div>
                <div class="ir">${fmtMoney(it.rate)}</div>
                <div class="ia">${fmtMoney(it.qty * it.rate)}</div>
              </div>
            `).join('')}
          </div>

          <div class="inv-totals">
            <div class="totals-box">
              <div class="total-row"><span class="tk">Subtotal</span><span class="tv">${fmtMoney(subtotal)}</span></div>
              ${discPct > 0 ? `<div class="total-row"><span class="tk">Discount (${discPct}%)</span><span class="tv">− ${fmtMoney(discAmt)}</span></div>` : ''}
              ${taxPct  > 0 ? `<div class="total-row"><span class="tk">Tax (${taxPct}%)</span><span class="tv">${fmtMoney(taxAmt)}</span></div>` : ''}
              <div class="total-row grand"><span>Total Due</span><span>${fmtMoney(total)}</span></div>
            </div>
          </div>

          ${(signatureDataUrl && sigMode === 'draw') || (signatureText && sigMode === 'type') ? `
          <div class="inv-signature">
            <div class="sig-box">
              ${sigMode === 'draw' && signatureDataUrl ? `<img src="${signatureDataUrl}" alt="signature" />` : ''}
              ${sigMode === 'type' && signatureText ? `<div class="sig-typed" style="font-family:'${signatureFont}',cursive;">${escapeHtml(signatureText)}</div>` : ''}
              <div class="sig-line">Authorized Signature — ${fmtDate(invDate)}</div>
            </div>
          </div>` : ''}

          ${(notes || terms || bankDetails) ? `
          <div class="inv-footer">
            ${bankDetails ? `<div class="inv-label">Payment Details</div><div class="if-bank">${escapeHtml(bankDetails)}</div>` : ''}
            ${notes ? `<div class="inv-label" style="margin-top:${bankDetails?'12px':'0'};">Notes</div><div class="if-notes">${escapeHtml(notes)}</div>` : ''}
            ${terms ? `<div class="inv-label" style="margin-top:${(notes||bankDetails)?'12px':'0'};">Payment Terms</div><div class="if-terms">${escapeHtml(terms)}</div>` : ''}
          </div>` : ''}
      `;

      const preview = document.getElementById('invoicePreview');
      preview.className = 'tpl-' + currentTemplate;

      if (sidebarMode) {
        preview.innerHTML = `
          <div id="invoicePreview-inner">
            <div class="inv-sidebar">
              ${logoDataUrl ? `<div class="inv-logo-area"><img src="${logoDataUrl}" alt="logo" /></div>` : ''}
              <div class="inv-company-name">${escapeHtml(fromName)}</div>
              ${fromSub ? `<div class="inv-company-sub">${escapeHtml(fromSub).replace(/\n/g,'<br><br>')}</div>` : ''}
            </div>
            <div class="inv-main">${bodyBlock}</div>
          </div>
        `;
      } else {
        preview.innerHTML = headerBlock + bodyBlock;
      }

      if (invStatus) {
        const stamp = document.createElement('div');
        stamp.className = 'inv-stamp ' + invStatus;
        stamp.textContent = invStatus;
        preview.appendChild(stamp);
      }
    }

    // ── Persistence (localStorage) ──
    function saveDraft() {
      try {
        const data = {};
        FIELD_IDS.forEach(id => { const el = document.getElementById(id); if (el) data[id] = el.value; });
        data.items = items;
        data.currSymbol = currSymbol;
        data.logoDataUrl = logoDataUrl;
        data.signatureDataUrl = signatureDataUrl;
        data.signatureText = signatureText;
        data.signatureFont = signatureFont;
        data.sigMode = sigMode;
        data.currentTemplate = currentTemplate;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      } catch (e) { /* storage unavailable — silently skip persistence */ }
    }

    function loadDraft() {
      let raw;
      try { raw = localStorage.getItem(STORAGE_KEY); } catch (e) { return; }
      if (!raw) return;
      let data;
      try { data = JSON.parse(raw); } catch (e) { return; }

      FIELD_IDS.forEach(id => {
        if (data[id] !== undefined) {
          const el = document.getElementById(id);
          if (el) el.value = data[id];
        }
      });
      if (Array.isArray(data.items) && data.items.length) items = data.items;
      if (data.currSymbol) {
        currSymbol = data.currSymbol;
        document.getElementById('currencySelect').value = currSymbol;
      }
      if (data.logoDataUrl) {
        logoDataUrl = data.logoDataUrl;
        document.getElementById('logoImg').src = logoDataUrl;
        document.getElementById('logoImg').style.display = '';
        document.getElementById('logoPlaceholder').style.display = 'none';
      }
      if (data.signatureText) {
        signatureText = data.signatureText;
        sigTypeInput.value = signatureText;
        sigTypePreview.textContent = signatureText;
      }
      if (data.signatureDataUrl) {
        signatureDataUrl = data.signatureDataUrl;
        const img = new Image();
        img.onload = function () {
          resizeCanvas();
          const cssW = sigCanvas.width / sigDpr, cssH = sigCanvas.height / sigDpr;
          const scale = Math.min(cssW / img.width, cssH / img.height, 1);
          const drawW = img.width * scale, drawH = img.height * scale;
          sigCtx.drawImage(img, (cssW - drawW) / 2, (cssH - drawH) / 2, drawW, drawH);
        };
        img.src = signatureDataUrl;
      }
      if (data.signatureFont) {
        signatureFont = data.signatureFont;
        sigFontSelect.value = signatureFont;
        sigTypePreview.style.fontFamily = "'" + signatureFont + "', cursive";
      }
      if (data.sigMode) setSigMode(data.sigMode);
      if (data.currentTemplate) window.igSetTemplate(data.currentTemplate);
    }

    // ── Live updates ──
    FIELD_IDS.forEach(id => {
      document.getElementById(id)?.addEventListener('input', function () { renderPreview(); saveDraft(); });
    });

    // ── Buttons ──
    document.getElementById('printBtn').addEventListener('click', () => window.print());

    document.getElementById('resetBtn').addEventListener('click', () => {
      if (!confirm('Reset all fields? This cannot be undone.')) return;
      ['fromName','fromAddress','fromEmail','fromPhone','fromWebsite',
       'toName','toAddress','toEmail','toPhone','invNotes','invTerms','bankDetails'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
      });
      document.getElementById('invNumber').value  = 'INV-001';
      document.getElementById('discount').value   = '0';
      document.getElementById('taxRate').value    = '0';
      document.getElementById('invDate').value    = today();
      document.getElementById('invDue').value     = addDays(today(), 30);
      document.getElementById('invStatus').value  = '';
      logoDataUrl = null;
      document.getElementById('logoImg').style.display = 'none';
      document.getElementById('logoPlaceholder').style.display = '';
      signatureDataUrl = null;
      signatureText = '';
      signatureFont = 'Dancing Script';
      sigFontSelect.value = signatureFont;
      sigTypeInput.value = '';
      sigTypePreview.textContent = '';
      sigTypePreview.style.fontFamily = "'" + signatureFont + "', cursive";
      sigCtx.clearRect(0, 0, sigCanvas.width / sigDpr, sigCanvas.height / sigDpr);
      setSigMode('draw');
      items = [{ desc: 'Service / Product', qty: 1, rate: 0 }];
      window.igSetTemplate('classic');
      try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
      renderPreview();
    });

    // ── Init ──
    loadDraft();
    renderItemsTable();
    renderPreview();
  })();
  </script>
</BaseLayout>
