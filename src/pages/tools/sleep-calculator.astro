---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Sleep Calculator';
const description =
  'Free sleep calculator. Find the best time to go to bed or wake up based on 90-minute sleep ' +
  'cycles, so you wake up refreshed instead of groggy.';
const intro =
  'Choose whether you want to wake up at a certain time or go to bed now, and get the best times based on full sleep cycles.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How does the sleep calculator work?', a: 'Sleep happens in roughly 90-minute cycles. Waking at the end of a cycle (rather than mid-cycle) helps you feel refreshed. We also add about 15 minutes to fall asleep.' },
  { q: 'How many cycles should I aim for?', a: 'Most adults do best with 5–6 cycles (about 7.5–9 hours) of sleep per night.' },
  { q: 'Is this medical advice?', a: 'No \u2014 it\u2019s a helpful guide based on average sleep cycles. Everyone is different.' },
  { q: 'What happens if I wake up in the middle of a cycle?', a: 'You\u2019ll experience sleep inertia \u2014 that groggy, disoriented feeling that can last 15\u201330 minutes. Waking at the end of a cycle (when sleep is lightest) avoids this and helps you feel alert sooner.' },
  { q: 'Does the calculator work for shift workers?', a: 'Yes — the same 90-minute cycle principle applies regardless of when you sleep. Just enter the time you plan to wake up (or go to bed) and the calculator will suggest optimal times for your unique schedule.' },
  { q: 'Why do I sometimes wake up naturally before my alarm?', a: 'Your body has likely completed its last sleep cycle and transitioned to light sleep naturally. This is actually a good sign that your sleep timing is well-matched to your natural rhythm.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="m-wake" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">I want to wake up at…</button>
      <button id="m-bed" class="flex-1 rounded-lg py-2 text-slate-500">I’m going to bed at…</button>
    </div>
    <label class="block"><span class="text-sm font-medium text-slate-700">Time</span>
      <input id="time" type="time" value="07:00" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <p id="result-label" class="mt-5 text-sm font-medium text-slate-700"></p>
    <div id="times" class="mt-2 grid grid-cols-2 gap-3 sm:grid-cols-4"></div>
    <p class="mt-3 text-xs text-slate-400">Times assume about 15 minutes to fall asleep. The best options (more sleep) are highlighted.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About sleep cycles</h2>
    <p class="mt-2 text-slate-600">
      Waking up in the middle of a deep sleep cycle is what makes you feel groggy. By timing your
      sleep around complete 90-minute cycles, you’re more likely to wake up naturally and feel
      rested. This calculator works out those ideal times for you. Good sleep also supports a healthy weight — pair this with the <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a> and <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> for a complete health check.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the Sleep Calculator whenever you want to feel more refreshed in the morning — especially before a big day like an exam, interview or race. It’s also helpful if you’re struggling with morning grogginess and want to find out whether poor timing is the cause. Parents use it to plan their own sleep around irregular baby schedules, and anyone adjusting to a new time zone can use it to reset their sleep pattern faster.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Stick to a consistent sleep schedule — even on weekends — to reinforce your body’s natural circadian rhythm.</li>
      <li>Avoid screens, caffeine and heavy meals for at least an hour before your calculated bedtime for easier falling asleep.</li>
      <li>Use the "I’m going to bed now" mode to find the best alarm time, then set your alarm for the end of a sleep cycle rather than a random time.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'wake';
    const FALL = 15, CYCLE = 90;

    function fmt(d) {
      let h = d.getHours(), m = d.getMinutes();
      const ap = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      return `${h}:${m.toString().padStart(2, '0')} ${ap}`;
    }

    function setMode(m) {
      mode = m;
      el('m-wake').className = 'flex-1 rounded-lg py-2 ' + (m === 'wake' ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('m-bed').className = 'flex-1 rounded-lg py-2 ' + (m === 'bed' ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const v = el('time').value;
      if (!v) return;
      const [hh, mm] = v.split(':').map(Number);
      const base = new Date(); base.setHours(hh, mm, 0, 0);
      const cycles = [6, 5, 4, 3];
      el('result-label').textContent = mode === 'wake' ? 'Go to bed at one of these times:' : 'Set your alarm for one of these times:';
      el('times').innerHTML = '';
      cycles.forEach((c, i) => {
        const d = new Date(base);
        const mins = c * CYCLE + FALL;
        d.setMinutes(d.getMinutes() + (mode === 'wake' ? -mins : mins));
        const hrs = (c * CYCLE) / 60;
        const best = i < 2;
        const card = document.createElement('div');
        card.className = 'rounded-xl p-3 text-center ' + (best ? 'bg-indigo-600 text-white' : 'bg-slate-50 text-slate-800');
        card.innerHTML = `<div class="text-lg font-bold">${fmt(d)}</div><div class="text-xs ${best ? 'opacity-80' : 'text-slate-500'}">${hrs} hrs · ${c} cycles</div>`;
        el('times').appendChild(card);
      });
    }

    el('m-wake').addEventListener('click', () => setMode('wake'));
    el('m-bed').addEventListener('click', () => setMode('bed'));
    el('time').addEventListener('input', update);
    update();
  </script>
</ToolLayout>
