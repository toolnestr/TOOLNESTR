---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Sleep Calculator';
const description =
  'Free sleep calculator. Find the best time to go to bed or wake up based on 90-minute sleep ' +
  'cycles, so you wake up refreshed instead of groggy.';
const intro =
  'Choose whether you want to wake up at a certain time or go to bed now, and get the best times based on full sleep cycles.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How does the sleep calculator work?', a: 'Sleep happens in roughly 90-minute cycles. Waking at the end of a cycle (rather than mid-cycle) helps you feel refreshed. We also add about 15 minutes to fall asleep.' },
  { q: 'How many cycles should I aim for?', a: 'Most adults do best with 5\u20136 cycles (about 7.5\u20139 hours) of sleep per night.' },
  { q: 'Is this medical advice?', a: 'No \u2014 it\u2019s a helpful guide based on average sleep cycles. Everyone is different.' },
  { q: 'What happens if I wake up in the middle of a cycle?', a: 'You\u2019ll experience sleep inertia \u2014 that groggy, disoriented feeling that can last 15\u201330 minutes. Waking at the end of a cycle (when sleep is lightest) avoids this and helps you feel alert sooner.' },
  { q: 'Does the calculator work for shift workers?', a: 'Yes \u2014 the same 90-minute cycle principle applies regardless of when you sleep. Just enter the time you plan to wake up (or go to bed) and the calculator will suggest optimal times for your unique schedule.' },
  { q: 'Why do I sometimes wake up naturally before my alarm?', a: 'Your body has likely completed its last sleep cycle and transitioned to light sleep naturally. This is actually a good sign that your sleep timing is well-matched to your natural rhythm.' },
  { q: 'Is it better to get more cycles or higher quality sleep?', a: 'Quality matters more than quantity. Six solid cycles with good sleep hygiene beat eight cycles of fragmented, restless sleep. Focus on consistency, darkness and a cool room temperature.' },
  { q: 'How does alcohol affect sleep cycles?', a: 'Alcohol may help you fall asleep faster but it disrupts REM sleep and the later cycles, often causing early waking and poorer overall recovery. Avoiding alcohol within 3 hours of bed improves cycle quality.' },
  { q: 'Can I train myself to need less sleep?', a: 'Most people cannot function optimally on less than 7 hours. While you may adapt to 6 hours over time, chronic short sleep accumulates as sleep debt and affects cognition, mood and health.' },
  { q: 'How does screen time affect falling asleep?', a: 'Blue light from phones, tablets and computers suppresses melatonin production, making it harder to fall asleep and reducing sleep quality. Aim for at least 30\u201360 minutes of screen-free time before bed.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="m-wake" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">I want to wake up at…</button>
      <button id="m-bed" class="flex-1 rounded-lg py-2 text-slate-500">I’m going to bed at…</button>
    </div>
    <label class="block"><span class="text-sm font-medium text-slate-700">Time</span>
      <input id="time" type="time" value="07:00" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <p id="result-label" class="mt-5 text-sm font-medium text-slate-700"></p>
    <div id="times" class="mt-2 grid grid-cols-2 gap-3 sm:grid-cols-4"></div>
    <p class="mt-3 text-xs text-slate-400">Times assume about 15 minutes to fall asleep. The best options (more sleep) are highlighted.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About sleep cycles</h2>
    <p class="mt-2 text-slate-600">
      Waking up in the middle of a deep sleep cycle is what makes you feel groggy. By timing your
      sleep around complete 90-minute cycles, you’re more likely to wake up naturally and feel
      rested. This calculator works out those ideal times for you. Good sleep also supports a healthy weight — pair this with the <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI Calculator</a> and <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> for a complete health check.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the Sleep Calculator whenever you want to feel more refreshed in the morning — especially before a big day like an exam, interview or race. It’s also helpful if you’re struggling with morning grogginess and want to find out whether poor timing is the cause. Parents use it to plan their own sleep around irregular baby schedules, and anyone adjusting to a new time zone can use it to reset their sleep pattern faster.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Stick to a consistent sleep schedule — even on weekends — to reinforce your body’s natural circadian rhythm.</li>
      <li>Avoid screens, caffeine and heavy meals for at least an hour before your calculated bedtime for easier falling asleep.</li>
      <li>Use the "I’m going to bed now" mode to find the best alarm time, then set your alarm for the end of a sleep cycle rather than a random time.</li>
    </ul>
  </section>

  <!-- Sleep duration bar chart -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Recommended sleep by age</h2>
    <p class="mt-2 text-slate-600">Sleep needs change throughout life. The bars below show the recommended sleep duration ranges from the National Sleep Foundation for different age groups.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Newborn (0–3 months)</span><span class="text-slate-400">14–17 hours</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:90%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Teen (14–17 years)</span><span class="text-slate-400">8–10 hours</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:55%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Young adult (18–25)</span><span class="text-slate-400">7–9 hours</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Adult (26–64)</span><span class="text-slate-400">7–9 hours</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:50%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Older adult (65+)</span><span class="text-slate-400">7–8 hours</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:45%"></div></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📚</span>
      <h3 class="mt-2 font-semibold text-slate-900">Student</h3>
      <p class="mt-1 text-sm text-slate-600">Plan your sleep around study and exam schedules so you wake up alert and focused instead of groggy from a broken cycle.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🌙</span>
      <h3 class="mt-2 font-semibold text-slate-900">Shift worker</h3>
      <p class="mt-1 text-sm text-slate-600">Use the calculator no matter what time you sleep — the 90-minute cycle principle works for any schedule, helping you optimise rest around irregular hours.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👶</span>
      <h3 class="mt-2 font-semibold text-slate-900">New parent</h3>
      <p class="mt-1 text-sm text-slate-600">Maximise the quality of interrupted sleep by timing your own rest around your baby's schedule using the calculator's cycle-based approach.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏅</span>
      <h3 class="mt-2 font-semibold text-slate-900">Athlete</h3>
      <p class="mt-1 text-sm text-slate-600">Sleep is when your body repairs and builds muscle. Time your bedtime to get 6–7 full cycles and maximise recovery from training.</p>
    </div>
  </section>

  <!-- Sleep reference table -->
  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Age group</th><th class="p-3">Recommended sleep</th><th class="p-3">Optimal cycles (90 min each)</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Newborn (0–3 mo)</td><td class="p-3">14–17 hours</td><td class="p-3">9–11 cycles</td></tr>
        <tr><td class="p-3 font-medium">Infant (4–11 mo)</td><td class="p-3">12–15 hours</td><td class="p-3">8–10 cycles</td></tr>
        <tr><td class="p-3 font-medium">Pre-school (3–5 yrs)</td><td class="p-3">10–13 hours</td><td class="p-3">6–8 cycles</td></tr>
        <tr><td class="p-3 font-medium">School (6–13 yrs)</td><td class="p-3">9–11 hours</td><td class="p-3">6–7 cycles</td></tr>
        <tr><td class="p-3 font-medium">Teen (14–17 yrs)</td><td class="p-3">8–10 hours</td><td class="p-3">5–6 cycles</td></tr>
        <tr><td class="p-3 font-medium">Adult (18–64 yrs)</td><td class="p-3">7–9 hours</td><td class="p-3">4–6 cycles</td></tr>
        <tr><td class="p-3 font-medium">Older adult (65+)</td><td class="p-3">7–8 hours</td><td class="p-3">4–5 cycles</td></tr>
      </tbody>
    </table>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Sleep Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose your mode</h3>
        <p class="mt-1 text-sm text-slate-600">Select "I want to wake up at…" to find the best bedtime, or "I'm going to bed at…" to find the ideal wake-up time for complete sleep cycles.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set your target time</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the time you plan to wake up (or go to bed). The calculator adds about 15 minutes for falling asleep to each option.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick your best option</h3>
        <p class="mt-1 text-sm text-slate-600">Choose from the suggested times. The highlighted options with more sleep cycles (6 or 5) are recommended for most people.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for better sleep quality</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Stick to a consistent schedule</h3>
        <p class="mt-1 text-sm text-slate-600">Going to bed and waking up at the same time every day (even weekends) reinforces your circadian rhythm and makes falling asleep easier over time.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Create a screen-free wind-down</h3>
        <p class="mt-1 text-sm text-slate-600">Blue light from phones and laptops suppresses melatonin for 30–60 minutes. Turn off screens, dim the lights and read a book before your calculated bedtime.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Optimise your sleep environment</h3>
        <p class="mt-1 text-sm text-slate-600">Keep your bedroom cool (16–19°C), dark and quiet. A consistent pre-sleep routine signals your body that it's time to wind down and transition into the first sleep cycle.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let mode = 'wake';
    const FALL = 15, CYCLE = 90;

    function fmt(d) {
      let h = d.getHours(), m = d.getMinutes();
      const ap = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      return `${h}:${m.toString().padStart(2, '0')} ${ap}`;
    }

    function setMode(m) {
      mode = m;
      el('m-wake').className = 'flex-1 rounded-lg py-2 ' + (m === 'wake' ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('m-bed').className = 'flex-1 rounded-lg py-2 ' + (m === 'bed' ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      const v = el('time').value;
      if (!v) return;
      const [hh, mm] = v.split(':').map(Number);
      const base = new Date(); base.setHours(hh, mm, 0, 0);
      const cycles = [6, 5, 4, 3];
      el('result-label').textContent = mode === 'wake' ? 'Go to bed at one of these times:' : 'Set your alarm for one of these times:';
      el('times').innerHTML = '';
      cycles.forEach((c, i) => {
        const d = new Date(base);
        const mins = c * CYCLE + FALL;
        d.setMinutes(d.getMinutes() + (mode === 'wake' ? -mins : mins));
        const hrs = (c * CYCLE) / 60;
        const best = i < 2;
        const card = document.createElement('div');
        card.className = 'rounded-xl p-3 text-center ' + (best ? 'bg-indigo-600 text-white' : 'bg-slate-50 text-slate-800');
        card.innerHTML = `<div class="text-lg font-bold">${fmt(d)}</div><div class="text-xs ${best ? 'opacity-80' : 'text-slate-500'}">${hrs} hrs · ${c} cycles</div>`;
        el('times').appendChild(card);
      });
    }

    el('m-wake').addEventListener('click', () => setMode('wake'));
    el('m-bed').addEventListener('click', () => setMode('bed'));
    el('time').addEventListener('input', update);
    update();
  </script>
</ToolLayout>
