---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Nernst Equation Calculator';
const description = 'Nernst equation calculator with a live 3D electrochemical cell diagram and charts. Solve E_cell = E°_cell − (0.0592/n)log(Q) at 25°C, with worked examples.';
const intro = 'Find the cell potential under non-standard conditions with the Nernst equation, E_cell = E°_cell − (0.0592/n)log₁₀(Q) at 25°C. Static 3D diagrams and charts show a two-electrode cell and how E_cell shifts with reaction quotient Q.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What does the Nernst equation calculate?', a: 'The Nernst equation gives the actual cell potential (E_cell) of an electrochemical cell under any set of concentrations, not just standard 1 M conditions. It corrects the standard cell potential E°_cell for how far the reaction quotient Q is from 1.' },
  { q: 'What is the simplified 0.0592/n form, and when can I use it?', a: 'The full Nernst equation is E_cell = E°_cell − (RT/nF)ln(Q). At exactly 25°C (298 K), substituting R = 8.314 J/(mol·K) and F = 96,485 C/mol and converting ln to log₁₀ simplifies RT/F to 0.0592 V, giving E_cell = E°_cell − (0.0592/n)log₁₀(Q). This shortcut only holds at 25°C — at other temperatures you need the full RT/nF form.' },
  { q: 'What is Q in the Nernst equation?', a: 'Q is the reaction quotient for the cell\'s overall redox reaction — the same expression as the equilibrium constant K, but evaluated at the actual (non-equilibrium) concentrations present in the cell right now, typically [products]/[reactants] raised to their stoichiometric coefficients.' },
  { q: 'What happens to E_cell as the cell approaches equilibrium?', a: 'As a cell discharges, Q moves toward K (the equilibrium constant), and E_cell drops toward zero. At equilibrium, Q = K and E_cell = 0 — a dead battery, in effect, since no further net electron flow is thermodynamically favored.' },
  { q: 'How is the Nernst equation used in real batteries?', a: 'It explains why a battery\'s voltage is not perfectly constant — it drops gradually as the cell discharges and concentrations shift, and it also underlies concentration cells and biological membrane potentials (like the Nernst potential for ion channels in neurons).' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Nernst Equation Calculator',
  description: 'Calculate the cell potential E_cell at 25°C from the standard potential, electrons transferred, and reaction quotient.',
  steps: [
    { name: 'Enter E°_cell', text: 'Type the standard cell potential in volts.' },
    { name: 'Enter n and Q', text: 'Type the number of electrons transferred (n) and the reaction quotient Q.' },
    { name: 'Read E_cell', text: 'The actual cell potential at 25°C solves instantly using the simplified 0.0592/n form.' },
  ],
};

const formulas = [
  { expr: 'E<sub>cell</sub> = E°<sub>cell</sub> − (0.0592/n) log₁₀(Q)', note: 'simplified form, valid at 25°C (298 K)' },
  { expr: 'E<sub>cell</sub> = E°<sub>cell</sub> − (RT/nF) ln(Q)', note: 'full form for any temperature — R=8.314 J/(mol·K), F=96,485 C/mol' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — non-standard Daniell cell (Zn/Cu)', tone: 'slate',
    given: 'A Zn/Cu galvanic cell has E°_cell = 1.10 V, n = 2 electrons transferred, and Q = 0.500 (non-standard concentrations). Find E_cell at 25°C.',
    rows: [
      { label: 'Formula:', value: 'E_cell = E°_cell − (0.0592/n) log₁₀(Q)' },
      { label: 'Substitute:', value: 'E_cell = 1.10 − (0.0592/2)×log₁₀(0.500)' },
      { label: 'Compute log:', value: 'log₁₀(0.500) ≈ −0.301, so (0.0592/2)×(−0.301) ≈ −0.00891' },
      { label: 'E_cell:', value: 'E_cell = 1.10 − (−0.00891) = 1.109 V', full: true },
    ],
    note: 'E_cell ≈ 1.109 V, slightly higher than the standard 1.10 V, because Q < 1 favors the forward reaction a bit more than standard conditions.',
  },
  {
    title: 'Worked example 2 — effect of a larger reaction quotient', tone: 'amber',
    given: 'Same Zn/Cu cell, E°_cell = 1.10 V, n = 2, but now Q = 10 (products/reactants ratio has grown). Find E_cell.',
    rows: [
      { label: 'Substitute:', value: 'E_cell = 1.10 − (0.0592/2)×log₁₀(10)' },
      { label: 'Compute:', value: 'log₁₀(10) = 1, so (0.0592/2)×1 = 0.0296' },
      { label: 'E_cell:', value: 'E_cell = 1.10 − 0.0296 = 1.0704 V', full: true },
    ],
    note: 'A larger Q (more product relative to reactant) lowers E_cell — consistent with the cell having less remaining driving force as it discharges toward equilibrium.',
  },
];

const comparison = {
  heading: 'How E_cell shifts with Q, for a cell with E°_cell = 1.10 V, n = 2',
  note: 'Every tenfold change in Q shifts E_cell by exactly 0.0592/n volts — here, 0.0296 V per decade.',
  headers: [{ label: 'Q' }, { label: 'log₁₀(Q)' }, { label: 'E_cell (V)' }],
  rows: [
    ['0.01', '−2', '1.1592'],
    ['0.5', '−0.301', '1.1089'],
    ['1 (standard)', '0', '1.1000'],
    ['10', '1', '1.0704'],
    ['100', '2', '1.0408'],
  ],
  highlightIndex: 2,
  footnote: 'At Q = 1, E_cell = E°_cell exactly, since log₁₀(1) = 0 — the standard-condition reference point.',
};

const realWorld = [
  { emoji: '🔋', title: 'Battery voltage during discharge', body: 'As a battery discharges, reactant concentrations fall and product concentrations rise, pushing Q upward and E_cell downward — the Nernst equation explains why a battery\'s voltage sags gradually rather than staying perfectly flat until it suddenly dies.' },
  { emoji: '🧠', title: 'Neuronal membrane potentials', body: 'The Nernst equation (in its ion-specific form) predicts the equilibrium potential for a single ion species across a cell membrane, such as K⁺ or Na⁺ — foundational to understanding how neurons generate and propagate electrical signals.' },
  { emoji: '🧪', title: 'pH meters and ion-selective electrodes', body: 'pH meters work by measuring a voltage that depends on [H⁺] via a Nernst-equation relationship, translating that voltage into a pH reading — the same equation underlies many ion-selective electrode sensors.' },
  { emoji: '⚙️', title: 'Corrosion and metal plating engineering', body: 'Engineers use Nernst-equation reasoning to predict which metal will corrode preferentially in a given environment, and to calculate the plating voltages needed for electroplating processes at non-standard ion concentrations.' },
];

const misconceptions = [
  { claim: '"E°_cell and E_cell are always the same number."', truth: 'E°_cell is the potential only under standard conditions (1 M concentrations, 1 atm gases, 25°C). E_cell is the actual potential under whatever real conditions exist, which the Nernst equation calculates by correcting E°_cell for how far Q is from 1.' },
  { claim: '"The 0.0592/n shortcut works at any temperature."', truth: "The 0.0592 V value comes from RT/F evaluated specifically at 298 K (25°C). At any other temperature, you must use the full form E_cell = E°_cell − (RT/nF)ln(Q) with the actual temperature in Kelvin." },
  { claim: '"A bigger Q always means a bigger E_cell."', truth: "It's the opposite — because Q is subtracted (as a log term) from E°_cell, a larger Q lowers E_cell, and a smaller Q (less than 1) raises it above E°_cell. Larger Q means the reaction has moved further toward products, which reduces its remaining driving force." },
  { claim: '"When E_cell = 0, the reaction has stopped completely."', truth: 'E_cell = 0 means the cell has reached electrochemical equilibrium (Q = K) — no further net current flows, but this reflects a dynamic balance of forward and reverse electron transfer, not that all chemical activity has ceased.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 17, Electrochemistry: the Nernst equation (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/17-4-electrolysis" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 20, Electrochemistry.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — the Nernst equation and concentration cells.' },
];
const sourcesNote = 'E_cell = E°_cell − (0.0592/n)log₁₀(Q) at 25°C (298 K); full form E_cell = E°_cell − (RT/nF)ln(Q) for other temperatures. Results are rounded for display.';

const howToUse = [
  { title: 'Enter E°_cell', body: 'The standard cell potential in volts, from a standard reduction potential table.' },
  { title: 'Enter n and Q', body: 'Electrons transferred in the balanced redox reaction, and the reaction quotient at actual conditions.' },
  { title: 'Read E_cell', body: 'The actual cell potential at 25°C solves live, with the 3D cell diagram and charts.' },
];

const related = [
  { href: '/tools/equilibrium-constant-calculator', emoji: '🔁', title: 'Equilibrium Constant (Keq) Calculator', desc: 'Kc = [C]^c[D]^d / [A]^a[B]^b.' },
  { href: '/tools/reaction-quotient-calculator', emoji: '🧭', title: 'Reaction Quotient (Q) Calculator', desc: 'Compare Q to Kc and predict direction.' },
  { href: '/tools/gibbs-free-energy-calculator', emoji: '➡️', title: 'Gibbs Free Energy Calculator', desc: 'ΔG = ΔH − TΔS — solve any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a cell's real voltage is its standard voltage, nudged up or down by how far the actual concentrations are from the standard 1 M reference point."
  howIntro="Because the correction term is a logarithm of Q divided by n, every tenfold change in Q shifts E_cell by a fixed amount — 0.0592/n volts at 25°C. More electrons transferred (larger n) means each factor-of-ten change in Q has a smaller effect on the cell potential, since the correction is spread across more charge."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the Nernst equation actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-3 text-xs text-slate-500">Uses the simplified 25°C form: E_cell = E°_cell − (0.0592/n)log₁₀(Q).</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">E°_cell (V)</span>
        <input id="e0" type="number" step="any" placeholder="volts" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">n (electrons transferred)</span>
        <input id="n" type="number" step="1" min="1" placeholder="e.g. 2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Q (reaction quotient)</span>
        <input id="q" type="number" step="any" min="0" placeholder="e.g. 0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">E_cell (at 25°C)</div><div id="r-ecell" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Correction term (0.0592/n)log(Q)</div><div id="r-corr" class="mt-1 text-xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="ne-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-cell" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Two electrodes, ion flow, and electron flow</h3>
          <p class="mt-1 text-sm text-slate-600">A fixed snapshot of a galvanic cell: two electrodes in separate half-cells, connected by a wire (electron flow) and a salt bridge (ion flow) that completes the circuit.</p>
        </div>
        <div>
          <div id="diag-logq" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. E_cell vs log(Q) — a straight line</h3>
          <p class="mt-1 text-sm text-slate-600">Three fixed points on the E_cell-vs-log(Q) line for n = 2 — the slope is always −0.0592/n, regardless of E°_cell.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Nernst equation graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">E_cell vs log₁₀(Q), slope = −0.0592/n</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-line"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">E_cell at three example Q values (E°_cell = 1.10 V, n = 2)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-bar"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const SCENE_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('ne-err').textContent = '';
        el('r-ecell').textContent = '—'; el('r-corr').textContent = '—';
        const e0 = parseFloat(el('e0').value), n = parseFloat(el('n').value), q = parseFloat(el('q').value);
        if (isNaN(e0) || isNaN(n) || isNaN(q)) return;
        if (n <= 0) { el('ne-err').textContent = 'n must be a positive number of electrons.'; return; }
        if (q <= 0) { el('ne-err').textContent = 'Q must be greater than 0.'; return; }
        const corr = (0.0592 / n) * Math.log10(q);
        const ecell = e0 - corr;
        el('r-ecell').textContent = fmt(ecell) + ' V';
        el('r-corr').textContent = fmt(corr) + ' V';
      }
      ['e0', 'n', 'q'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const n2 = 2, e0Ref = 1.10;
        const labels = [], data = [];
        for (let lq = -3; lq <= 3.001; lq += 0.5) { labels.push(lq.toFixed(1)); data.push(+(e0Ref - (0.0592 / n2) * lq).toFixed(4)); }
        charts.line = new Chart(el('chart-line'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'E_cell (V)', data, borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'log₁₀(Q)' } }, y: { title: { display: true, text: 'E_cell (V)' } } }, plugins: { legend: { display: false } } }),
        });
        const qs = [0.01, 1, 100];
        const barVals = qs.map((q) => e0Ref - (0.0592 / n2) * Math.log10(q));
        charts.bar = new Chart(el('chart-bar'), {
          type: 'bar',
          data: { labels: ['Q = 0.01', 'Q = 1 (standard)', 'Q = 100'], datasets: [{ label: 'E_cell (V)', data: barVals.map((v) => +v.toFixed(4)), backgroundColor: ['#6366f1', '#10b981', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'E_cell (V)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- static diagram 1: two-electrode cell with wire + salt bridge ----
      let diagCell = null, diagLogQ = null;
      function initDiagCell() {
        const c = el('diag-cell'); if (!c) throw new Error('no container');
        const s = makeScene(c, 14, new THREE.Vector3(0, 0, 0), SCENE_OPTS);
        const liquidMat1 = new THREE.MeshStandardMaterial({ color: 0x93c5fd, transparent: true, opacity: 0.5 });
        const liquidMat2 = new THREE.MeshStandardMaterial({ color: 0xfca5a5, transparent: true, opacity: 0.5 });
        const beaker1 = new THREE.Mesh(new THREE.CylinderGeometry(1.8, 1.8, 3, 32), liquidMat1); beaker1.position.set(-3.5, -1, 0); s.scene.add(beaker1);
        const beaker2 = new THREE.Mesh(new THREE.CylinderGeometry(1.8, 1.8, 3, 32), liquidMat2); beaker2.position.set(3.5, -1, 0); s.scene.add(beaker2);
        const elecMat = new THREE.MeshStandardMaterial({ color: 0x475569, metalness: 0.5, roughness: 0.4 });
        const elec1 = new THREE.Mesh(new THREE.BoxGeometry(0.5, 4, 0.5), elecMat); elec1.position.set(-3.5, 1, 0); s.scene.add(elec1);
        const elec2 = new THREE.Mesh(new THREE.BoxGeometry(0.5, 4, 0.5), elecMat); elec2.position.set(3.5, 1, 0); s.scene.add(elec2);
        // wire (electron flow) connecting tops
        const wireMat = new THREE.MeshStandardMaterial({ color: 0xf59e0b });
        const wire = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 7, 12), wireMat);
        wire.rotation.z = Math.PI / 2; wire.position.set(0, 3.2, 0); s.scene.add(wire);
        // salt bridge (ion flow) connecting beakers, lower
        const bridgeMat = new THREE.MeshStandardMaterial({ color: 0x64748b, transparent: true, opacity: 0.6 });
        const bridge = new THREE.Mesh(new THREE.CylinderGeometry(0.35, 0.35, 7, 16), bridgeMat);
        bridge.rotation.z = Math.PI / 2; bridge.position.set(0, 1.6, 0); s.scene.add(bridge);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagCell = { resize: s.resize };
      }
      function initDiagLogQ() {
        const c = el('diag-logq'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 0, 0), SCENE_OPTS);
        const grid = new THREE.GridHelper(6, 6, 0xe2e8f0, 0xeef2f7); s.scene.add(grid);
        const slope = -0.0592 / 2 * 5; // scaled for visibility
        const line = new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-2.5, slope * 1.25 * -1, 0), new THREE.Vector3(2.5, slope * 1.25, 0)]),
          new THREE.LineBasicMaterial({ color: 0x4f46e5 })
        );
        s.scene.add(line);
        const dotGeo = new THREE.SphereGeometry(0.15, 12, 12);
        const colors = [0x6366f1, 0x10b981, 0xef4444];
        [-1, 0, 1].forEach((lq, i) => {
          const mat = new THREE.MeshStandardMaterial({ color: colors[i] });
          const m = new THREE.Mesh(dotGeo, mat);
          m.position.set(lq, -slope * 0.4 * lq * -1, 0);
          s.scene.add(m);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagLogQ = { resize: s.resize };
      }

      function boot() {
        try { update(); } catch (e) { console.error('[nernst] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[nernst] charts failed', e); }
        if (window.THREE) {
          try { initDiagCell(); } catch (e) { console.error('[nernst] cell diagram failed', e); }
          try { initDiagLogQ(); } catch (e) { console.error('[nernst] log(Q) diagram failed', e); }
        }
        mountResize([diagCell, diagLogQ]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
