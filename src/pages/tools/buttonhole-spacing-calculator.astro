---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Buttonhole Spacing Calculator';
const description = 'Calculate even spacing between buttonholes along a placket from placket length, button count, and margins.';
const intro = 'Calculate even spacing between buttonholes along a placket length.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What margin should I use at the top and bottom?', a: 'A common top margin on a shirt placket is about 0.5-0.75 inch from the neckline edge; the bottom margin (or the space before the last button) depends on the garment length, but should be enough to prevent the buttonhole from being too close to the hem or an existing seam.' },
  { q: 'Does this work for a button placed at a stress point, like a collar or bust?', a: 'This calculator gives even spacing across the whole placket; in practice, sewists often anchor one buttonhole exactly at a stress point (like the fullest part of the bust) first, then space the remaining buttons evenly around that fixed point rather than purely evenly top to bottom.' },
  { q: 'How many buttons should a shirt have?', a: 'This varies by style and placket length, but a common range for an adult shirt is 6-8 buttons; use your placket length and desired spacing (roughly 3-4 inches apart) to estimate a reasonable button count if you\'re designing from scratch.' },
  { q: 'Does spacing include the buttonhole\'s own length?', a: 'This calculator gives the spacing between the centers of each buttonhole; make sure adjacent buttonholes have enough room between their centers to fit the buttonhole length itself without overlapping.' },
];
const howTo = {
  name: 'How to calculate buttonhole spacing',
  steps: [
    { name: 'Enter placket length and margins', text: 'Enter the total placket length and your top and bottom margins.' },
    { name: 'Enter number of buttons', text: 'Enter how many buttons you want along the placket.' },
    { name: 'Read the spacing', text: 'The even spacing between buttonhole centers appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Placket length (in)</span>
        <input id="placket" type="number" step="any" placeholder="e.g. 26" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Number of buttons</span>
        <input id="numButtons" type="number" step="1" placeholder="e.g. 7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Top margin (in)</span>
        <input id="topMargin" type="number" step="any" value="0.75" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Bottom margin (in)</span>
        <input id="bottomMargin" type="number" step="any" value="0.75" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Spacing between buttonholes</div>
        <div id="r-spacing" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="bsc2-title bsc2-desc">
      <title id="bsc2-title">Vertical placket with evenly spaced buttonhole marks</title>
      <desc id="bsc2-desc">A vertical strip representing a shirt placket with evenly spaced horizontal marks representing buttonhole positions</desc>
      <rect x="370" y="20" width="60" height="140" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      {[35, 60, 85, 110, 135].map((y) => (
        <line x1="380" y1={y} x2="420" y2={y} stroke="#c026d3" stroke-width="2" />
      ))}
      <line x1="440" y1="35" x2="440" y2="60" stroke="#1e293b" stroke-width="1.5" />
      <text x="460" y="52" font-size="11" fill="#475569" font-family="system-ui,sans-serif">Spacing</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Buttonholes are spaced evenly between the top and bottom margins</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How buttonhole spacing is calculated</h2>
    <p class="mt-2 text-slate-600">
      This calculator first subtracts the top and bottom margins from the total placket length, leaving the usable length where buttons actually sit. Because the first and last button are placed at the edges of that usable length, the number of gaps between buttons is always one less than the number of buttons — dividing the usable length by (button count minus 1) gives the even spacing between each buttonhole's center.
    </p>
    <p class="mt-3 text-slate-600">
      This even-spacing approach works well for most plackets, though many sewists adjust it slightly in practice to place one button at a specific stress point (like the fullest part of the bust on a fitted shirt) and then space the rest evenly around that anchor point instead of purely top to bottom.
    </p>
    <p class="mt-3 text-xs text-slate-400">This follows the standard evenly-divided spacing method used across shirt and garment placket construction.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 26-inch shirt placket, 7 buttons, 0.75-inch margins top and bottom.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Usable length:</span> <span class="text-slate-600">26 − 1.5 = 24.5 in</span></div>
        <div><span class="font-medium text-slate-700">Gaps:</span> <span class="text-slate-600">7 − 1 = 6</span></div>
        <div><span class="font-medium text-slate-700">Spacing:</span> <span class="text-slate-600">24.5 ÷ 6 ≈ <strong>4.08 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Shirt-making is the classic use case, since a shirt placket needs visibly even spacing to look professionally finished — uneven buttonhole spacing is one of the most noticeable signs of a home-sewn garment compared to a ready-to-wear one, making this a small calculation with an outsized effect on perceived quality.
    </p>
    <p class="mt-3 text-slate-600">
      Duvet covers, pillowcases with a button closure, and other home-decor items with multiple buttons benefit from the same even-spacing math, though the margins and typical spacing distances involved are usually larger than on a fitted garment placket.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Spacing equals placket length divided by button count." <strong class="text-slate-900">Off by one.</strong> The correct divisor is one less than the button count, since the first and last buttons sit at the very edges of the usable length rather than the spacing repeating past the last button.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Even mathematical spacing always looks best regardless of the garment." <strong class="text-slate-900">Not always.</strong> Fitted garments often benefit from anchoring a button at a specific stress point rather than pure even spacing, since a perfectly even mathematical spread can place a gap at an awkward point like the bust or a seam intersection.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/buttonhole-length-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Buttonhole Length Calculator</a>
      <a href="/tools/interfacing-stabilizer-yardage-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Interfacing/Stabilizer Yardage Calculator</a>
      <a href="/tools/seam-allowance-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Seam Allowance Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const placket = parseFloat(el('placket').value);
      const numButtons = parseInt(el('numButtons').value, 10);
      const topMargin = parseFloat(el('topMargin').value) || 0;
      const bottomMargin = parseFloat(el('bottomMargin').value) || 0;
      if (!placket || !numButtons || placket <= 0 || numButtons < 2) { el('results').classList.add('hidden'); return; }
      const usable = placket - topMargin - bottomMargin;
      if (usable <= 0) { el('results').classList.add('hidden'); return; }
      const spacing = usable / (numButtons - 1);
      el('r-spacing').textContent = spacing.toFixed(2) + ' in';
      el('results').classList.remove('hidden');
    }

    ['placket', 'numButtons', 'topMargin', 'bottomMargin'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
