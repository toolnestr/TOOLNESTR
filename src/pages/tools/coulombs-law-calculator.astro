---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = "Coulomb's Law Calculator";
const description = "Coulomb's law calculator with a live 3D pair of charges and charts. Solve F = k|q1q2|/r² for force, either charge, or separation distance, with worked examples.";
const intro = "Solve F = k|q₁q₂|/r² for the electrostatic force between two point charges, or rearrange it to find a charge or the separation distance. A live 3D scene shows two charged spheres and the force arrow between them, and charts show the inverse-square distance dependence.";
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: "What is Coulomb's law?", a: "Coulomb's law gives the electrostatic force between two point charges: F = k|q₁q₂|/r², where k ≈ 8.9875×10⁹ N·m²/C² is Coulomb's constant, q₁ and q₂ are the charges in coulombs, and r is the separation distance in metres. The force acts along the line joining the two charges." },
  { q: "What does Coulomb's constant k represent?", a: "k = 1/(4πε₀), where ε₀ ≈ 8.854×10⁻¹² C²/(N·m²) is the permittivity of free space. It sets the strength of the electric force in a vacuum (or air, to a very close approximation). Its value, k ≈ 8.9875×10⁹ N·m²/C², is often rounded to 8.99×10⁹ or 9.0×10⁹ for quick estimates." },
  { q: "How does the force depend on distance?", a: "Coulomb's law is an inverse-square law: F ∝ 1/r². Doubling the separation distance cuts the force to one quarter; tripling it cuts the force to one ninth. This is the same mathematical form as Newton's law of gravitation." },
  { q: "Do like charges attract or repel?", a: "Like charges (both positive or both negative) repel; opposite charges (one positive, one negative) attract. Coulomb's law as written, F = k|q₁q₂|/r², gives only the magnitude of the force — the sign of q₁×q₂ tells you the direction: positive product means repulsion, negative product means attraction." },
  { q: "Does Coulomb's law only work for point charges?", a: "It is exact for point charges, and it also applies exactly to spherically symmetric charge distributions (like uniformly charged spheres) as long as the spheres don't overlap — in that case you can treat all the charge as concentrated at the centre, an electrostatic analogue of Newton's shell theorem for gravity." },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: "How to use the Coulomb's Law Calculator",
  description: "Calculate the electrostatic force between two point charges, or solve for a charge or distance, using F = k|q1 q2|/r².",
  steps: [
    { name: 'Choose what to solve for', text: 'Pick force, charge 1, charge 2, or distance as the unknown.' },
    { name: 'Enter the other three values', text: 'Charges are in coulombs (C) — use scientific notation like 2e-6 for microcoulomb-scale charges.' },
    { name: 'Read the result', text: 'The force solves instantly, and the 3D charge pair and charts update.' },
  ],
};

const formulas = [
  { expr: 'F = k |q₁ q₂| / r²', note: 'electrostatic force magnitude' },
  { expr: 'k ≈ 8.9875×10⁹ N·m²/C²', note: "Coulomb's constant, k = 1/(4πε₀)" },
];

const workedExamples = [
  {
    title: 'Worked example 1 — attractive force', tone: 'slate',
    given: 'A charge of +2 μC (2×10⁻⁶ C) and a charge of −3 μC (3×10⁻⁶ C) are separated by 0.5 m. Find the force between them.',
    rows: [
      { label: 'Formula:', value: 'F = k|q₁q₂|/r²' },
      { label: 'Substitute:', value: 'F = 8.9875×10⁹ × (2×10⁻⁶ × 3×10⁻⁶) / (0.5)²' },
      { label: 'Simplify:', value: 'F = 8.9875×10⁹ × 6×10⁻¹² / 0.25' },
      { label: 'Force:', value: 'F = 0.2157 N', full: true },
    ],
    note: 'The charges have opposite signs, so this 0.2157 N force is attractive — each charge is pulled toward the other.',
  },
  {
    title: 'Worked example 2 — repulsive force, solving for magnitude', tone: 'amber',
    given: 'Two charges of +5 μC each are separated by 0.2 m. Find the force between them.',
    rows: [
      { label: 'Formula:', value: 'F = k|q₁q₂|/r²' },
      { label: 'Substitute:', value: 'F = 8.9875×10⁹ × (5×10⁻⁶ × 5×10⁻⁶) / (0.2)²' },
      { label: 'Simplify:', value: 'F = 8.9875×10⁹ × 2.5×10⁻¹¹ / 0.04' },
      { label: 'Force:', value: 'F = 5.6172 N', full: true },
    ],
    note: 'Both charges are positive (like charges), so this force is repulsive — the charges push apart.',
  },
];

const comparison = {
  heading: "Coulomb's law vs Newton's law of gravitation",
  note: 'Both are inverse-square laws with an identical mathematical form, but the electric force is enormously stronger for everyday charges and masses.',
  headers: [{ label: 'Property' }, { label: "Coulomb's law" }, { label: "Newton's gravitation" }],
  rows: [
    ['Formula', 'F = k|q₁q₂|/r²', 'F = Gm₁m₂/r²'],
    ['Constant', 'k ≈ 8.9875×10⁹ N·m²/C²', 'G ≈ 6.674×10⁻¹¹ N·m²/kg²'],
    ['Distance dependence', '1/r² (inverse square)', '1/r² (inverse square)'],
    ['Can be attractive or repulsive', 'Yes — depends on charge signs', 'No — always attractive'],
    ['Relative strength (proton pair)', '~10³⁶ times stronger', 'baseline'],
  ],
  highlightIndex: 3,
  footnote: 'For two protons, the electric repulsion is about 10³⁶ times stronger than their mutual gravitational attraction — gravity only dominates at large scales because matter is usually charge-neutral overall.',
};

const realWorld = [
  { emoji: '🔌', title: 'Electronics and capacitors', body: 'The forces between charged plates in a capacitor, and the attraction that holds charge carriers in place in circuits, both follow Coulomb\'s law at the microscopic level — it underlies how charge storage and electric fields behave in every circuit.' },
  { emoji: '⚡', title: 'Van de Graaff generators', body: 'These build up large amounts of like charge on a metal sphere. Coulomb repulsion between the accumulated charges is strong enough to make hair stand on end or produce visible sparks when the potential gets high enough to ionise the surrounding air.' },
  { emoji: '🧬', title: 'Molecular and atomic bonding', body: 'Ionic bonds, and much of the fine structure of molecular interactions, arise from Coulomb attraction between oppositely charged ions or partial charges. The strength and distance-dependence of these forces shape crystal structures and reaction chemistry.' },
  { emoji: '🌩️', title: 'Lightning and static discharge', body: 'Charge separation between cloud and ground (or between your body and a doorknob) builds up an electric force described by Coulomb\'s law; when the resulting field is strong enough to ionise air, it discharges as a spark or lightning bolt.' },
];

const misconceptions = [
  { claim: '"Like charges attract."', truth: "It's the opposite: like charges (two positives or two negatives) repel, and only opposite charges attract. The magnitude formula F = k|q₁q₂|/r² doesn't show this by itself — the sign of the product q₁×q₂ determines the direction, not the formula's magnitude." },
  { claim: '"Coulomb\'s law only applies to point charges."', truth: "It's exact for point charges, but it also applies exactly to any spherically symmetric charge distribution (like a uniformly charged sphere) treated as a point charge at its centre — as long as the charge distributions don't overlap. This mirrors the shell theorem in gravity." },
  { claim: '"A bigger charge always means a bigger force, no matter what."', truth: 'Force depends on the product of both charges and the inverse square of distance together. A large q₁ paired with a tiny q₂, or placed very far away, can still produce a small force — all three quantities matter jointly.' },
  { claim: '"Coulomb force and gravity are basically the same strength."', truth: 'They share the same 1/r² form, but for charged particles like protons the electric force is roughly 10³⁶ times stronger than gravity between the same pair. Gravity only seems to dominate at large scales because bulk matter is nearly charge-neutral.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 2</em></strong> — §5.2 "Coulomb\'s Law" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-2/pages/5-2-coulombs-law" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 21, Coulomb\'s Law.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 23, Electric Fields.' },
];
const sourcesNote = "F = k|q₁q₂|/r² with k ≈ 8.9875×10⁹ N·m²/C², assuming point (or spherically symmetric) charges in a vacuum or air. Results are rounded for display.";

const howToUse = [
  { title: 'Choose the unknown', body: 'The calculator solves for force, charge 1, charge 2, or distance from the other three.' },
  { title: 'Enter charges in coulombs', body: 'Use scientific notation for lab-scale charges, e.g. 2e-6 for 2 μC.' },
  { title: 'Watch the charge pair', body: 'Use the sliders to see the force arrow grow, shrink, and flip direction in 3D.' },
];

const related = [
  { href: '/tools/gravitational-force-calculator', emoji: '🌍', title: 'Gravitational Force Calculator', desc: 'F = Gm₁m₂/r² — the same inverse-square form.' },
  { href: '/tools/force-calculator', emoji: '💥', title: 'Force Calculator (F=ma)', desc: 'Solve for force, mass, or acceleration.' },
  { href: '/tools/pressure-calculator', emoji: '🤿', title: 'Pressure Calculator', desc: 'P = F/A and P = ρgh.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="Coulomb's law says the electrostatic force between two point charges grows with the product of the charges and shrinks with the square of the distance between them — the same inverse-square shape as gravity, but able to attract or repel."
  howIntro="Rearranged, F = k|q₁q₂|/r² solves any variable: |q₁| = Fr²/(k|q₂|), |q₂| = Fr²/(k|q₁|), and r = √(k|q₁q₂|/F). Because F falls off as 1/r², doubling the distance between two charges cuts the force to a quarter — the same steep drop-off that makes gravity weak at planetary distances but electric forces dominate at the atomic scale."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where Coulomb's law actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Solve for:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-f" type="button" data-solve="f" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Force (F)</button>
      <button id="mode-q1" type="button" data-solve="q1" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Charge 1 (q1)</button>
      <button id="mode-q2" type="button" data-solve="q2" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Charge 2 (q2)</button>
      <button id="mode-r" type="button" data-solve="r" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Distance (r)</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-4">
      <label id="field-f" class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="f" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-q1" class="block"><span class="text-sm font-medium text-slate-700">Charge 1 (q1)</span>
        <input id="q1" type="number" step="any" placeholder="C, e.g. 2e-6" value="2e-6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-q2" class="block"><span class="text-sm font-medium text-slate-700">Charge 2 (q2)</span>
        <input id="q2" type="number" step="any" placeholder="C, e.g. -3e-6" value="-3e-6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label id="field-r" class="block"><span class="text-sm font-medium text-slate-700">Distance (r)</span>
        <input id="r" type="number" step="any" placeholder="m" value="0.5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-4">
      <div id="box-f" class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Force</div><div id="r-f" class="mt-1 text-2xl font-bold">—</div></div>
      <div id="box-q1" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Charge 1</div><div id="r-q1" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-q2" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Charge 2</div><div id="r-q2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div id="box-r" class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Distance</div><div id="r-r" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="cl-hint" class="mt-3 text-center text-sm text-slate-500"></p>
    <p id="cl-err" class="mt-1 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D charge pair + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D charge pair</h2>
      <p class="mt-1 text-sm text-slate-500">Two charged spheres sit a distance r apart — red for positive, blue for negative. The arrow shows the force direction and its length/colour scale with the force magnitude. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-3">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Charge 1 (q1) <span id="out-bq1" class="font-mono text-indigo-600">2.0 μC</span></span>
          <input id="b-q1" type="range" min="-10" max="10" step="0.1" value="2" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Charge 2 (q2) <span id="out-bq2" class="font-mono text-indigo-600">-3.0 μC</span></span>
          <input id="b-q2" type="range" min="-10" max="10" step="0.1" value="-3" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Distance r <span id="out-br" class="font-mono text-indigo-600">0.50 m</span></span>
          <input id="b-r" type="range" min="0.1" max="2" step="0.02" value="0.5" class="mt-2 w-full accent-indigo-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">Force F = <span id="out-bf" class="font-mono font-bold">0.216 N</span> <span id="out-bdir" class="font-semibold"></span></div>
      <div id="charges3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="charges3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Coulomb force graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">F vs distance r (at your current q1, q2) — an inverse-square curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-r"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">F vs charge product |q1×q2| (at your current r) — a straight line</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-q"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };
      const K = 8.9875e9;

      // ---- calculator ----
      let solveFor = 'f';
      const modeBtns = { f: 'mode-f', q1: 'mode-q1', q2: 'mode-q2', r: 'mode-r' };
      const fieldEls = { f: 'field-f', q1: 'field-q1', q2: 'field-q2', r: 'field-r' };
      const boxEls = { f: 'box-f', q1: 'box-q1', q2: 'box-q2', r: 'box-r' };

      function switchSolve(s) {
        solveFor = s;
        Object.keys(modeBtns).forEach((k) => {
          el(modeBtns[k]).className = k === s ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        });
        Object.keys(fieldEls).forEach((k) => {
          el(fieldEls[k]).style.opacity = k === s ? '0.45' : '1';
        });
        Object.keys(boxEls).forEach((k) => {
          el(boxEls[k]).className = k === s ? 'rounded-xl bg-indigo-600 p-5 text-center text-white' : 'rounded-xl bg-slate-50 p-5 text-center';
        });
        update();
      }

      function update() {
        el('cl-err').textContent = '';
        el('cl-hint').textContent = '';
        ['r-f', 'r-q1', 'r-q2', 'r-r'].forEach((id) => (el(id).textContent = '—'));
        const f = parseFloat(el('f').value);
        const q1 = parseFloat(el('q1').value);
        const q2 = parseFloat(el('q2').value);
        const r = parseFloat(el('r').value);

        function dirNote(a, b) {
          if (isNaN(a) || isNaN(b) || a === 0 || b === 0) return '';
          return (a * b > 0) ? 'Same-sign charges — this force is repulsive.' : 'Opposite-sign charges — this force is attractive.';
        }

        if (solveFor === 'f') {
          if (isNaN(q1) || isNaN(q2) || isNaN(r)) return;
          if (r === 0) { el('cl-err').textContent = 'Distance cannot be zero.'; return; }
          const ff = K * Math.abs(q1 * q2) / (r * r);
          el('r-f').textContent = fmt(ff) + ' N';
          el('r-q1').textContent = fmt(q1) + ' C';
          el('r-q2').textContent = fmt(q2) + ' C';
          el('r-r').textContent = fmt(r) + ' m';
          el('cl-hint').textContent = dirNote(q1, q2);
        } else if (solveFor === 'q1') {
          if (isNaN(f) || isNaN(q2) || isNaN(r)) return;
          if (q2 === 0) { el('cl-err').textContent = 'Charge 2 must be nonzero to solve for charge 1.'; return; }
          if (f < 0) { el('cl-err').textContent = 'Force must be non-negative.'; return; }
          const mag = (f * r * r) / (K * Math.abs(q2));
          const qq1 = q2 > 0 ? mag : -mag; // default assumes attraction-consistent sign relative to q2; magnitude is what matters
          el('r-f').textContent = fmt(f) + ' N';
          el('r-q1').textContent = fmt(mag) + ' C (magnitude)';
          el('r-q2').textContent = fmt(q2) + ' C';
          el('r-r').textContent = fmt(r) + ' m';
          el('cl-hint').textContent = 'Coulomb’s law gives only the magnitude of q1 from F — the sign depends on whether the force is attractive or repulsive.';
        } else if (solveFor === 'q2') {
          if (isNaN(f) || isNaN(q1) || isNaN(r)) return;
          if (q1 === 0) { el('cl-err').textContent = 'Charge 1 must be nonzero to solve for charge 2.'; return; }
          if (f < 0) { el('cl-err').textContent = 'Force must be non-negative.'; return; }
          const mag = (f * r * r) / (K * Math.abs(q1));
          el('r-f').textContent = fmt(f) + ' N';
          el('r-q1').textContent = fmt(q1) + ' C';
          el('r-q2').textContent = fmt(mag) + ' C (magnitude)';
          el('r-r').textContent = fmt(r) + ' m';
          el('cl-hint').textContent = 'Coulomb’s law gives only the magnitude of q2 from F — the sign depends on whether the force is attractive or repulsive.';
        } else if (solveFor === 'r') {
          if (isNaN(f) || isNaN(q1) || isNaN(q2)) return;
          if (f <= 0) { el('cl-err').textContent = 'Force must be positive to solve for distance.'; return; }
          const rr = Math.sqrt(K * Math.abs(q1 * q2) / f);
          el('r-f').textContent = fmt(f) + ' N';
          el('r-q1').textContent = fmt(q1) + ' C';
          el('r-q2').textContent = fmt(q2) + ' C';
          el('r-r').textContent = fmt(rr) + ' m';
          el('cl-hint').textContent = dirNote(q1, q2);
        }
      }
      el('mode-f').addEventListener('click', () => switchSolve('f'));
      el('mode-q1').addEventListener('click', () => switchSolve('q1'));
      el('mode-q2').addEventListener('click', () => switchSolve('q2'));
      el('mode-r').addEventListener('click', () => switchSolve('r'));
      ['f', 'q1', 'q2', 'r'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts shared state ----
      const charts = {};
      let scene3 = null;
      function bState() {
        const q1u = parseFloat(el('b-q1').value), q2u = parseFloat(el('b-q2').value), r = parseFloat(el('b-r').value);
        const q1 = q1u * 1e-6, q2 = q2u * 1e-6;
        const F = r > 0 ? K * Math.abs(q1 * q2) / (r * r) : 0;
        const repulsive = q1 * q2 > 0;
        return { q1u, q2u, q1, q2, r, F, repulsive };
      }
      function onB() {
        const s = bState();
        el('out-bq1').textContent = s.q1u.toFixed(1) + ' μC';
        el('out-bq2').textContent = s.q2u.toFixed(1) + ' μC';
        el('out-br').textContent = s.r.toFixed(2) + ' m';
        el('out-bf').textContent = fmt(s.F) + ' N';
        el('out-bdir').textContent = (s.q1u === 0 || s.q2u === 0) ? '' : (s.repulsive ? '(repulsive)' : '(attractive)');
        try { if (scene3) scene3.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-q1').addEventListener('input', onB);
      el('b-q2').addEventListener('input', onB);
      el('b-r').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.r = new Chart(el('chart-r'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'F', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Distance r (m)' } }, y: { title: { display: true, text: 'Force F (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.q = new Chart(el('chart-q'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'F', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: '|q1 × q2| (μC²)' } }, y: { title: { display: true, text: 'Force F (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const L1 = [], D1 = [];
        for (let rr = 0.1; rr <= 2.0001; rr += 0.05) { L1.push(rr.toFixed(2)); D1.push(+(K * Math.abs(s.q1 * s.q2) / (rr * rr)).toFixed(6)); }
        charts.r.data.labels = L1; charts.r.data.datasets[0].data = D1; charts.r.update();

        const L2 = [], D2 = [];
        const maxProd = 100; // uC^2
        for (let p = 0; p <= maxProd + 0.001; p += 5) {
          L2.push(p.toFixed(0));
          const qProdC2 = p * 1e-12; // convert uC^2 to C^2
          D2.push(+(K * qProdC2 / (s.r * s.r)).toFixed(6));
        }
        charts.q.data.labels = L2; charts.q.data.datasets[0].data = D2; charts.q.update();
      }

      // ---- 3D charge-pair scene ----
      function initScene() {
        const c = el('charges3d'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        s.scene.add(new THREE.GridHelper(12, 12, 0xcbd5e1, 0xe2e8f0));

        const posMat = new THREE.MeshStandardMaterial({ color: 0xef4444 });
        const negMat = new THREE.MeshStandardMaterial({ color: 0x3b82f6 });
        const sphere1 = new THREE.Mesh(new THREE.SphereGeometry(0.35, 24, 18), posMat);
        const sphere2 = new THREE.Mesh(new THREE.SphereGeometry(0.35, 24, 18), negMat);
        s.scene.add(sphere1, sphere2);
        let arrow1 = null, arrow2 = null;

        function update(state) {
          const half = Math.min(3.2, Math.max(0.4, state.r * 1.6));
          sphere1.position.set(-half, 0, 0);
          sphere2.position.set(half, 0, 0);
          sphere1.material = state.q1u >= 0 ? posMat : negMat;
          sphere2.material = state.q2u >= 0 ? posMat : negMat;
          const scale1 = 0.2 + Math.min(0.4, Math.abs(state.q1u) / 25);
          const scale2 = 0.2 + Math.min(0.4, Math.abs(state.q2u) / 25);
          sphere1.scale.setScalar(0.5 + scale1);
          sphere2.scale.setScalar(0.5 + scale2);

          if (arrow1) { s.scene.remove(arrow1); arrow1 = null; }
          if (arrow2) { s.scene.remove(arrow2); arrow2 = null; }
          if (state.q1u !== 0 && state.q2u !== 0) {
            const len = Math.min(1.6, 0.2 + state.F * 1.5);
            const color = state.repulsive ? 0xf59e0b : 0x22c55e;
            const dirOut = new THREE.Vector3(1, 0, 0);
            const dirIn = new THREE.Vector3(-1, 0, 0);
            if (state.repulsive) {
              arrow1 = new THREE.ArrowHelper(dirIn, sphere1.position, len, color, len * 0.3, 0.18);
              arrow2 = new THREE.ArrowHelper(dirOut, sphere2.position, len, color, len * 0.3, 0.18);
            } else {
              arrow1 = new THREE.ArrowHelper(dirOut, sphere1.position, len, color, len * 0.3, 0.18);
              arrow2 = new THREE.ArrowHelper(dirIn, sphere2.position, len, color, len * 0.3, 0.18);
            }
            s.scene.add(arrow1, arrow2);
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0012); s.renderer.render(s.scene, s.camera); }
        frame();
        scene3 = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { switchSolve('f'); update(); } catch (e) { console.error('[coulombs-law] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[coulombs-law] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[coulombs-law] charts failed', e); }
        if (window.THREE) {
          try { initScene(); } catch (e) { console.error('[coulombs-law] 3D failed', e); el('charges3d-fallback').classList.remove('hidden'); }
        } else { el('charges3d-fallback').classList.remove('hidden'); }
        mountResize([scene3]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
