---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Roof Truss Spacing Calculator';
const description = 'Count the roof trusses needed for a building from its length and the truss spacing, 16 or 24 inches on center.';
const intro = 'Count the roof trusses you need for a building from its length and your truss spacing, 16 or 24 inches on center.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How many roof trusses do I need?', a: 'Divide the building length in inches by the truss spacing, then add one for the starting truss at the gable end. A 40-foot building at 24 inches on center needs about 21 trusses.' },
  { q: 'What is standard truss spacing?', a: 'Roof trusses are commonly spaced 24 inches on center for residential roofs, since a truss is an engineered structural unit that can span farther than a stick-framed rafter. Some designs use 16 inches on center for heavier roofing materials or shorter trusses.' },
  { q: 'Does truss spacing affect sheathing?', a: 'Yes. Roof sheathing panels are sized to land their edges on truss centers, so spacing must match a dimension the sheathing divides into evenly — 24 inches on center works cleanly with standard 4x8 sheets.' },
  { q: 'Are gable-end trusses different?', a: 'Yes. The trusses at each gable end are usually a different, flat-topped design that supports the gable wall framing, while the trusses in between are the common structural roof trusses. Order gable-end trusses separately from your truss supplier.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Building length (ft)</span>
        <input id="length" type="number" step="any" placeholder="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Truss spacing</span>
        <select id="spacing" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="24" selected>24" on center</option>
          <option value="16">16" on center</option>
          <option value="12">12" on center</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Common trusses needed</div>
        <div id="r-trusses" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Bays</div><div id="r-bays" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
        <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Plus gable-end trusses</div><div id="r-gable" class="mt-1 text-lg font-bold text-slate-800">2</div></div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="260" viewBox="0 0 800 260" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="ts-title ts-desc">
      <title id="ts-title">Roof trusses at even spacing along a building</title>
      <desc id="ts-desc">A row of triangular roof trusses evenly spaced along the building length</desc>
      <g stroke="#6366f1" stroke-width="2" fill="none">
        <path d="M80 200 L130 140 L180 200 Z"/><path d="M180 200 L230 140 L280 200 Z"/><path d="M280 200 L330 140 L380 200 Z"/><path d="M380 200 L430 140 L480 200 Z"/><path d="M480 200 L530 140 L580 200 Z"/>
      </g>
      <text x="330" y="230" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">trusses at even spacing along the length</text>
      <rect x="620" y="90" width="140" height="90" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="640" y="118" font-size="12" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Count</text>
      <text x="640" y="140" font-size="11" fill="#475569" font-family="system-ui,sans-serif">trusses =</text>
      <text x="640" y="158" font-size="11" fill="#475569" font-family="system-ui,sans-serif">length&frasl;spacing + 1</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Trusses run at even spacing along the building; sheathing panel edges land on the same centers.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the truss spacing calculator works</h2>
    <p class="mt-2 text-slate-600">
      Roof trusses stand upright along the length of a building at even spacing, much like wall studs but spanning the full roof width as one engineered unit. The count works the same way as a stud layout: divide the building length by the spacing, then add one truss to close the far end of the run.
    </p>
    <p class="mt-3 text-slate-600">
      The calculator reports this as the count of common trusses — the repeating structural trusses along the roof — separate from the gable-end trusses, which sit at each end of the building and support the gable wall rather than carrying the full roof load. Gable-end trusses are typically ordered as two additional, differently designed units on top of the common truss count.
    </p>
    <p class="mt-3 text-slate-600">
      24 inches on center is the most common residential truss spacing, and it is chosen partly because standard 4-foot-wide roof sheathing panels land their edges cleanly on 24-inch centers. Heavier roofing materials, longer truss spans, or specific engineering may call for tighter 16-inch spacing — always follow the truss manufacturer's engineered spacing for your specific design.
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter the length</h3>
        <p class="mt-1 text-sm text-slate-600">The building's length along the direction the trusses run.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick the spacing</h3>
        <p class="mt-1 text-sm text-slate-600">Use the spacing from your engineered truss drawings.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Order common + gable</h3>
        <p class="mt-1 text-sm text-slate-600">Add the two gable-end trusses to the common truss count.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Common truss count</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= floor(length&frasl;spacing) + 1</span>. A 40 ft building at 24&Prime;: floor(480&frasl;24) + 1 = 20 + 1 = <strong>21 trusses</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Total with gable ends</p>
        <p class="mt-1 text-slate-600">
          21 common + 2 gable-end trusses = <strong>23 trusses total</strong> to order.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 60 ft pole barn at 16&Prime; on center.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Common trusses:</span> <span class="text-slate-600">floor(720&frasl;16) + 1 = 45 + 1 = <strong>46</strong></span></div>
        <div><span class="font-medium text-slate-700">With gable ends:</span> <span class="text-slate-600">46 + 2 = 48 total</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/rafter-length-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Rafter Length Calculator</a>
      <a href="/tools/framing-stud-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Framing Stud Calculator</a>
      <a href="/tools/roof-pitch-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Roof Pitch Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('length').value);
      const sp = parseFloat(el('spacing').value);
      if (!L || !sp || L <= 0 || sp <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const bays = Math.floor((L * 12) / sp);
      const trusses = bays + 1;

      el('r-trusses').textContent = trusses.toLocaleString();
      el('r-note').textContent = '+ 2 gable-end trusses = ' + (trusses + 2) + ' total';
      el('r-bays').textContent = bays.toLocaleString();
      el('results').classList.remove('hidden');
    }

    el('length').addEventListener('input', update);
    el('spacing').addEventListener('change', update);
  </script>
</ToolLayout>
