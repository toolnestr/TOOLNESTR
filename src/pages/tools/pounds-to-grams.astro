---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Pounds to Grams"
  emoji="⚖️"
  fromUnit="pounds" toUnit="grams"
  fromTitle="Pounds" toTitle="Grams"
  fromSym="lb" toSym="g"
  quantity="weight"
  kind="factor" factor={453.59237}
  reverseSlug="grams-to-pounds" reverseLabel="Grams to Pounds Converter"
  hasReverse={true}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Turn a weight in pounds into precise grams for recipes, lab work or shipping calculations."
/>
