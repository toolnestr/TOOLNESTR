      <a href="/tools/spf-checker/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:text-indigo-700">&rarr; SPF Record Checker</a>
      <a href="/tools/dmarc-checker/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:text-indigo-700">&rarr; DMARC Record Checker</a>
    </div>
  </section>

  <script is:inline>
    (function () {
      var el = function (id) { return document.getElementById(id); };

      var typeEl = el('type');
      var ttlEl = el('ttl');
      var generateBtn = el('generate-btn');
      var copyBtn = el('copy-btn');
      var codeBlock = el('code-block');
      var explanation = el('explanation');
      var errorEl = el('error');
      var resultArea = el('result-area');

      var fieldSets = {
        addr: el('fields-addr'),
        cname: el('fields-cname'),
        mx: el('fields-mx'),
        txt: el('fields-txt'),
        spf: el('fields-spf'),
        dkim: el('fields-dkim'),
      };

      function hideError() {
        errorEl.classList.add('hidden');
      }

      function showError(msg) {
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
      }

      function toggleFields() {
        var val = typeEl.value;
        var showAddr = val === 'A' || val === 'AAAA';
        var addrLabel = el('addr-value');
        var label = addrLabel.previousElementSibling;

        fieldSets.addr.classList.toggle('hidden', !showAddr);
        fieldSets.cname.classList.toggle('hidden', val !== 'CNAME');
        fieldSets.mx.classList.toggle('hidden', val !== 'MX');
        fieldSets.txt.classList.toggle('hidden', val !== 'TXT');
        fieldSets.spf.classList.toggle('hidden', val !== 'SPF');
        fieldSets.dkim.classList.toggle('hidden', val !== 'DKIM');

        if (showAddr) {
          label.textContent = val === 'A' ? 'IPv4 Address' : 'IPv6 Address';
          addrLabel.placeholder = val === 'A' ? '192.0.2.1' : '2001:db8::1';
        }

        hideError();
      }

      typeEl.addEventListener('change', toggleFields);
      toggleFields();

      function formatName(name) {
        name = name.trim();
        if (!name) return '';
        if (name === '@') return '@';
        if (name.indexOf('.') !== -1 && !name.endsWith('.')) return name + '.';
        return name;
      }

      function generate() {
        hideError();
        var type = typeEl.value;
        var ttl = ttlEl.value.trim() || '3600';

        var name,
          value,
          record = '';
        var expl = '';
        var ok = true;

        switch (type) {
          case 'A': {
            name = formatName(el('addr-name').value);
            value = el('addr-value').value.trim();
            if (!name || !value) { showError('Please enter both a name and an IPv4 address.'); ok = false; break; }
            record = name + ' ' + ttl + ' IN A ' + value;
            expl = 'Maps ' + name + ' to IPv4 address ' + value + '. Browsers and other clients use this record to find the server hosting the domain.';
            break;
          }
          case 'AAAA': {
            name = formatName(el('addr-name').value);
            value = el('addr-value').value.trim();
            if (!name || !value) { showError('Please enter both a name and an IPv6 address.'); ok = false; break; }
            record = name + ' ' + ttl + ' IN AAAA ' + value;
            expl = 'Maps ' + name + ' to IPv6 address ' + value + '. This is the IPv6 equivalent of an A record.';
            break;
          }
          case 'CNAME': {
            name = formatName(el('cname-name').value);
            value = formatName(el('cname-target').value);
            if (!name || !value) { showError('Please enter both a name and a target.'); ok = false; break; }
            record = name + ' ' + ttl + ' IN CNAME ' + value;
            expl = 'Aliases ' + name + ' to ' + value + '. Requests to the alias resolve to whatever IP the target resolves to.';
            break;
          }
          case 'MX': {
            name = formatName(el('mx-name').value);
            var priority = el('mx-priority').value.trim();
            value = formatName(el('mx-target').value);
            if (!name || !priority || !value) { showError('Please enter a name, priority, and target for the MX record.'); ok = false; break; }
            record = name + ' ' + ttl + ' IN MX ' + priority + ' ' + value;
            expl = 'Routes email for ' + name + ' to mail server ' + value + ' with priority ' + priority + '. Lower priorities are tried first.';
            break;
          }
          case 'TXT': {
            name = formatName(el('txt-name').value);
            value = el('txt-value').value.trim();
            if (!name || !value) { showError('Please enter both a name and a value.'); ok = false; break; }
            if (!value.startsWith('"')) value = '"' + value;
            if (!value.endsWith('"')) value = value + '"';
            record = name + ' ' + ttl + ' IN TXT ' + value;
            expl = 'Stores a text value at ' + name + '. Used for SPF, DKIM, DMARC, domain verification, and other text-based policies.';
            break;
          }
          case 'SPF': {
            var spfDomain = el('spf-domain').value.trim();
            var spfIps = el('spf-ips').value.trim();
            var spfDomains = el('spf-domains').value.trim();
            var spfPolicy = el('spf-policy').value;

            if (!spfDomain) { showError('Please enter a domain.'); ok = false; break; }

            var spfValue = 'v=spf1';
            if (spfIps) {
              var ips = spfIps.split(/\s+/);
              for (var i = 0; i < ips.length; i++) {
                if (ips[i]) spfValue += ' ip4:' + ips[i];
              }
            }
            if (spfDomains) {
              var domains = spfDomains.split(/\s+/);
              for (var j = 0; j < domains.length; j++) {
                if (domains[j]) spfValue += ' include:' + domains[j];
              }
            }
            spfValue += ' ' + spfPolicy;

            record = formatName(spfDomain) + ' ' + ttl + ' IN TXT "' + spfValue + '"';
            expl = 'SPF record for ' + spfDomain + ' authorising specified IPs and domains to send email. Policy: ' + spfPolicy + '.';
            break;
          }
          case 'DKIM': {
            var selector = el('dkim-selector').value.trim();
            var dkimDomain = el('dkim-domain').value.trim();
            var pubKey = el('dkim-key').value.trim();

            if (!selector || !dkimDomain || !pubKey) {
              showError('Please enter a selector, domain, and public key.');
              ok = false;
              break;
            }

            var dkimName = selector + '._domainkey.' + formatName(dkimDomain);
            var dkimValue = 'v=DKIM1; p=' + pubKey;
            record = dkimName + ' ' + ttl + ' IN TXT "' + dkimValue + '"';
            expl = 'DKIM public key record for ' + selector + '._domainkey.' + dkimDomain + '. Receiving servers use this key to verify email signatures from this domain.';
            break;
          }
        }

        if (!ok) return;

        codeBlock.textContent = record;
        explanation.textContent = expl;
        resultArea.classList.add('opacity-0', 'transition-opacity', 'duration-200');
        setTimeout(function () {
          resultArea.classList.remove('opacity-0');
          resultArea.classList.add('opacity-100');
        }, 10);
      }

      generateBtn.addEventListener('click', generate);

      copyBtn.addEventListener('click', async function () {
        var text = codeBlock.textContent;
        if (
          !text ||
          text === 'Select a record type, fill in the fields, and click Generate record.'
        ) {
          return;
        }
        try {
          await navigator.clipboard.writeText(text);
          var orig = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          setTimeout(function () {
            copyBtn.textContent = orig;
          }, 1200);
        } catch (e) {}
      });

      var inputs = document.querySelectorAll(
        '#fields-addr input, #fields-cname input, #fields-mx input, #fields-txt input, #fields-spf input, #fields-spf select, #fields-dkim input, #fields-dkim textarea'
      );
      for (var i = 0; i < inputs.length; i++) {
        inputs[i].addEventListener('keydown', function (e) {
          if (e.key === 'Enter') generate();
        });
      }
    })();
  </script>
</ToolLayout>
