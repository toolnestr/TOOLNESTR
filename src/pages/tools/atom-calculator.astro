---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Atom Calculator';
const description = "Atom calculator: find protons, neutrons and electrons from atomic number, mass number and charge, or identify an atom from its particle counts.";
const intro = 'Find the number of protons, neutrons, and electrons in any neutral atom or ion, or work backward from particle counts to identify the atomic number, mass number, and net charge. Two 3D diagrams compare a neutral atom to its ion and show the electron-shell structure, with charts comparing particle counts across common ions.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'How do you find the number of protons, neutrons, and electrons in an atom?', a: 'Protons always equal the atomic number (Z). Neutrons equal the mass number minus the atomic number (A − Z). Electrons equal the atomic number minus the net charge (Z − charge) — for a neutral atom, charge is 0, so electrons = Z.' },
  { q: 'What makes an atom become an ion?', a: 'An atom becomes an ion when it gains or loses electrons, creating a net electric charge. Losing electrons produces a positive ion (cation); gaining electrons produces a negative ion (anion). The proton and neutron counts never change in this process.' },
  { q: 'Does mass number change when an atom becomes an ion?', a: 'No — forming an ion only involves gaining or losing electrons, which have negligible mass compared to protons and neutrons. The mass number (protons + neutrons) stays exactly the same whether the atom is neutral or charged.' },
  { q: 'How is atomic mass different from mass number?', a: 'Mass number (A) is a whole-number count of protons plus neutrons for one specific isotope. Atomic mass on the periodic table is a weighted average across all naturally occurring isotopes of that element, which is why it usually isn\'t a whole number.' },
  { q: 'Can two atoms have the same electron count but be different elements?', a: 'Yes — this happens whenever ions are involved. For example, a neutral Neon atom (10 protons, 10 electrons) and a Sodium ion Na⁺ (11 protons, 10 electrons) both have 10 electrons, but they are different elements because their proton counts differ.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Atom Calculator',
  description: 'Find protons, neutrons, and electrons from atomic number, mass number, and charge, or work backward to identify an atom from its particle counts.',
  steps: [
    { name: 'Pick a mode', text: '"From Z, A, charge" finds particle counts. "From particle counts" identifies Z, A, and net charge.' },
    { name: 'Enter the values', text: 'Type the atomic number, mass number, and charge — or the proton, neutron, and electron counts.' },
    { name: 'Read the result', text: 'The particle counts, or the atom\'s identity, solve instantly.' },
  ],
};

const formulas = [
  { expr: 'protons = Z', note: 'the atomic number defines element identity' },
  { expr: 'neutrons = A − Z', note: 'mass number minus atomic number' },
  { expr: 'electrons = Z − charge', note: 'protons minus net charge (0 for a neutral atom)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a neutral sodium atom', tone: 'slate',
    given: 'Sodium-23 has atomic number Z = 11, mass number A = 23, and no net charge.',
    rows: [
      { label: 'Protons:', value: 'protons = Z = 11' },
      { label: 'Neutrons:', value: 'neutrons = A − Z = 23 − 11 = 12' },
      { label: 'Electrons:', value: 'electrons = Z − charge = 11 − 0 = 11', full: true },
    ],
    note: 'A neutral atom always has equal protons and electrons, which is exactly why its overall charge is zero.',
  },
  {
    title: 'Worked example 2 — the sodium ion Na⁺', tone: 'amber',
    given: 'The same Sodium-23, but now as the Na⁺ ion (net charge = +1) formed when it loses one electron.',
    rows: [
      { label: 'Protons:', value: 'protons = Z = 11 (unchanged)' },
      { label: 'Neutrons:', value: 'neutrons = A − Z = 23 − 11 = 12 (unchanged)' },
      { label: 'Electrons:', value: 'electrons = Z − charge = 11 − 1 = 10', full: true },
    ],
    note: 'Only the electron count changes when an ion forms — the proton and neutron counts stay exactly the same, since ionization never touches the nucleus.',
  },
];

const comparison = {
  heading: 'Common ions — protons stay fixed, electrons shift',
  note: 'Notice the proton count (which defines the element) never changes — only electrons are gained or lost to form the ion.',
  headers: [{ label: 'Species' }, { label: 'Protons' }, { label: 'Electrons' }, { label: 'Net charge' }],
  rows: [
    ['Na (neutral)', '11', '11', '0'],
    ['Na⁺ ★', '11', '10', '+1'],
    ['Cl (neutral)', '17', '17', '0'],
    ['Cl⁻', '17', '18', '−1'],
    ['Mg²⁺', '12', '10', '+2'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 2). Losing electrons gives a positive charge; gaining electrons gives a negative charge.',
};

const realWorld = [
  { emoji: '📊', title: 'Reading the periodic table', body: "Every element's position on the periodic table is fixed by its atomic number, the exact proton count — understanding proton/neutron/electron counts is the foundation for reading and using the entire table." },
  { emoji: '🔋', title: 'Ion formation in batteries and salts', body: 'Batteries and dissolved salts rely on atoms gaining or losing electrons to form ions — understanding how electron count shifts while protons stay fixed explains how these charged particles form and move.' },
  { emoji: '☢️', title: 'Nuclear chemistry', body: 'Nuclear reactions change proton and neutron counts directly (unlike ordinary chemical reactions, which only shuffle electrons) — tracking these counts explains how one element can transmute into another during radioactive decay.' },
  { emoji: '🔬', title: 'Mass spectrometry interpretation', body: "Mass spectrometers detect ions by their mass-to-charge ratio, so correctly accounting for how many electrons an ion has lost or gained is essential to correctly interpreting the resulting spectrum." },
];

const misconceptions = [
  { claim: '"Mass number and atomic mass are the same thing."', truth: "Mass number is a whole-number count of protons plus neutrons for one specific isotope. Atomic mass on the periodic table is a weighted average across all of an element's naturally occurring isotopes, so it is almost never a whole number." },
  { claim: '"Atoms with different electron counts must be different elements."', truth: "Element identity is defined only by proton count (Z). Ions of the exact same element can have very different electron counts than the neutral atom — Na and Na⁺ are both sodium, just with different net charges." },
  { claim: '"Forming an ion changes an atom\'s mass number."', truth: 'Ionization only involves gaining or losing electrons, which have negligible mass. The mass number (protons + neutrons) is completely unaffected by whether an atom is neutral or ionized.' },
  { claim: '"A positive ion has gained protons."', truth: 'A positive ion (cation) forms by losing electrons, not gaining protons — proton count is essentially fixed for a given element under normal chemical conditions; only electron count changes to create ions.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 2, "Atoms, Molecules, and Ions" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/2-3-atomic-structure-and-symbolism" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 2, Atoms, Molecules, and Ions.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Atomic structure and ion formation.' },
];
const sourcesNote = 'protons = Z; neutrons = A − Z; electrons = Z − charge. Results are rounded/whole-number by definition, since particle counts are always integers.';

const howToUse = [
  { title: 'Pick the mode', body: '"From Z, A, charge" for forward calculation; "From particle counts" to identify an unknown atom or ion.' },
  { title: 'Enter the values', body: 'Type whole numbers for atomic number, mass number, charge, or particle counts as required.' },
  { title: 'Read the result', body: 'Particle counts, or the atom\'s Z, A, and charge, solve instantly.' },
];

const related = [
  { href: '/tools/isotope-calculator', emoji: '☢️', title: 'Isotope Calculator', desc: 'Protons, neutrons, electrons — plus weighted average atomic mass.' },
  { href: '/tools/electron-configuration-calculator', emoji: '🔷', title: 'Electron Configuration Calculator', desc: 'Aufbau-order electron configuration and valence electrons.' },
  { href: '/tools/atomic-mass-calculator', emoji: '🔬', title: 'Molar Mass Calculator', desc: 'Molar mass from chemical formula.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="an atom's identity as an element is locked in by its proton count alone — everything else (neutrons, electrons, net charge) can vary independently without changing what element it is."
  howIntro="Protons never change during ordinary chemical processes, so protons = Z is fixed for a given element. Mass number A counts every nucleon (proton + neutron), so subtracting protons leaves neutrons = A − Z. Electrons balance charge: a neutral atom has electrons = Z exactly, while an ion has electrons = Z − charge, since losing an electron leaves a net positive charge and gaining one leaves a net negative charge."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where atomic structure actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-fwd" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From Z, A, charge</button>
      <button id="mode-rev" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">From particle counts</button>
    </div>

    <div id="fwd-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Atomic number Z</span>
        <input id="Z" type="number" step="1" value="11" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass number A</span>
        <input id="A" type="number" step="1" value="23" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Net charge</span>
        <input id="charge" type="number" step="1" value="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="rev-fields" class="hidden grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Protons</span>
        <input id="p_in" type="number" step="1" placeholder="e.g. 11" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Neutrons</span>
        <input id="n_in" type="number" step="1" placeholder="e.g. 12" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Electrons</span>
        <input id="e_in" type="number" step="1" placeholder="e.g. 10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="fwd-out" class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Protons</div><div id="r-p" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Neutrons</div><div id="r-n" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Electrons</div><div id="r-e" class="mt-1 text-xl font-bold">—</div></div>
    </div>
    <div id="rev-out" class="mt-6 hidden grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Atomic number Z</div><div id="r-Z" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Mass number A</div><div id="r-A" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Net charge</div><div id="r-charge" class="mt-1 text-xl font-bold">—</div></div>
    </div>
    <p id="atom-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Neutral atom vs ion</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-neutral" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. A neutral atom</h3>
          <p class="mt-1 text-sm text-slate-600">A central nucleus (protons in red, neutrons in grey) surrounded by an equal number of orbiting electrons (blue) — net charge zero.</p>
        </div>
        <div>
          <div id="diag-ion" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. The same atom as a positive ion</h3>
          <p class="mt-1 text-sm text-slate-600">Same nucleus, but one fewer orbiting electron — the missing electron leaves the ion with a net positive charge.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Atomic structure graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Protons vs electrons across common ions</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ions"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Electron count vs net charge (fixed Z=11, sodium)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-charge"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'fwd';
      function switchMode(m) {
        mode = m;
        el('mode-fwd').className = m === 'fwd' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-rev').className = m === 'rev' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('fwd-fields').className = m === 'fwd' ? 'grid gap-4 sm:grid-cols-3' : 'hidden grid gap-4 sm:grid-cols-3';
        el('rev-fields').className = m === 'rev' ? 'grid gap-4 sm:grid-cols-3' : 'hidden grid gap-4 sm:grid-cols-3';
        el('fwd-out').className = m === 'fwd' ? 'mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3' : 'mt-6 hidden grid grid-cols-1 gap-3 sm:grid-cols-3';
        el('rev-out').className = m === 'rev' ? 'mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3' : 'mt-6 hidden grid grid-cols-1 gap-3 sm:grid-cols-3';
        el('atom-err').textContent = '';
        update();
      }
      function update() {
        el('atom-err').textContent = '';
        if (mode === 'fwd') {
          ['r-p', 'r-n', 'r-e'].forEach((id) => (el(id).textContent = '—'));
          const Z = parseInt(el('Z').value, 10), A = parseInt(el('A').value, 10), charge = parseInt(el('charge').value, 10);
          if (isNaN(Z) || isNaN(A) || isNaN(charge)) return;
          if (Z <= 0 || A < Z) { el('atom-err').textContent = 'Mass number must be ≥ atomic number, both positive.'; return; }
          el('r-p').textContent = Z; el('r-n').textContent = A - Z; el('r-e').textContent = Z - charge;
        } else {
          ['r-Z', 'r-A', 'r-charge'].forEach((id) => (el(id).textContent = '—'));
          const p = parseInt(el('p_in').value, 10), n = parseInt(el('n_in').value, 10), e = parseInt(el('e_in').value, 10);
          if (isNaN(p) || isNaN(n) || isNaN(e)) return;
          if (p <= 0 || n < 0 || e < 0) { el('atom-err').textContent = 'Protons must be positive; neutrons and electrons cannot be negative.'; return; }
          el('r-Z').textContent = p; el('r-A').textContent = p + n;
          const c = p - e; el('r-charge').textContent = (c > 0 ? '+' : '') + c;
        }
      }
      el('mode-fwd').addEventListener('click', () => switchMode('fwd'));
      el('mode-rev').addEventListener('click', () => switchMode('rev'));
      ['Z', 'A', 'charge', 'p_in', 'n_in', 'e_in'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const ions = [{ n: 'Na⁺', p: 11, e: 10 }, { n: 'Cl⁻', p: 17, e: 18 }, { n: 'Mg²⁺', p: 12, e: 10 }, { n: 'O²⁻', p: 8, e: 10 }];
        charts.ions = new Chart(el('chart-ions'), {
          type: 'bar',
          data: { labels: ions.map((i) => i.n), datasets: [
            { label: 'Protons', data: ions.map((i) => i.p), backgroundColor: '#6366f1' },
            { label: 'Electrons', data: ions.map((i) => i.e), backgroundColor: '#f59e0b' },
          ] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Count' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        const labels = [], data = [];
        for (let c = -2; c <= 2; c++) { labels.push((c > 0 ? '+' : '') + c); data.push(11 - c); }
        charts.charge = new Chart(el('chart-charge'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'Electrons', data, borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 4 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Net charge' } }, y: { title: { display: true, text: 'Electron count' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function shellAtom(container, protons, neutrons, electrons) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const nucGroup = new THREE.Group();
        const nucCount = protons + neutrons;
        for (let i = 0; i < nucCount; i++) {
          const phi = Math.acos(1 - (2 * (i + 0.5)) / nucCount);
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const r = 0.55;
          const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
          const color = i < protons ? 0xef4444 : 0x94a3b8;
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.18, 10, 8), new THREE.MeshStandardMaterial({ color }));
          sph.position.set(x, y, z);
          nucGroup.add(sph);
        }
        s.scene.add(nucGroup);
        const ring = new THREE.Mesh(new THREE.TorusGeometry(2.2, 0.02, 8, 48), new THREE.MeshBasicMaterial({ color: 0xcbd5e1 }));
        ring.rotation.x = Math.PI / 2.3;
        s.scene.add(ring);
        for (let i = 0; i < electrons; i++) {
          const ang = (i / electrons) * Math.PI * 2;
          const e = new THREE.Mesh(new THREE.SphereGeometry(0.15, 10, 8), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          e.position.set(2.2 * Math.cos(ang), 0, 2.2 * Math.sin(ang) * Math.sin(Math.PI / 2.3));
          s.scene.add(e);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }

      let diagNeutral = null, diagIon = null;
      function initDiagNeutral() {
        const c = el('diag-neutral'); if (!c) throw new Error('no container');
        diagNeutral = shellAtom(c, 11, 12, 11);
      }
      function initDiagIon() {
        const c = el('diag-ion'); if (!c) throw new Error('no container');
        diagIon = shellAtom(c, 11, 12, 10);
      }

      function boot() {
        try { switchMode('fwd'); } catch (e) { console.error('[atom] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[atom] charts failed', e); }
        if (window.THREE) {
          try { initDiagNeutral(); } catch (e) { console.error('[atom] neutral diagram failed', e); }
          try { initDiagIon(); } catch (e) { console.error('[atom] ion diagram failed', e); }
        }
        mountResize([diagNeutral, diagIon]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
