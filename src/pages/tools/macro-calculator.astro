---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Macro Calculator';
const description =
  'Free macro calculator. Set your daily protein, carbohydrate and fat targets based on your calorie goal, activity level and diet preference.';
const intro =
  'Enter your body details, activity level and calorie goal to get a personalised daily macronutrient split — protein, carbs and fat in grams.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What are macronutrients?', a: 'Macronutrients (macros) are the three main calorie-providing nutrients: protein (4 cal/g), carbohydrates (4 cal/g) and fat (9 cal/g). Your body needs all three in different proportions depending on your goals.' },
  { q: 'Which macro split should I choose?', a: 'Balanced (30/40/30) works for most people. High-protein (40/30/30) is great for muscle building and fat loss. Low-carb (35/20/45) suits keto-adapted individuals. Keto (20/5/75) is for strict ketogenic diets.' },
  { q: 'How much protein do I need?', a: 'For general health, 0.8 g per kg of body weight is the minimum. For active individuals and muscle building, 1.6–2.2 g per kg is recommended. Higher protein intakes also help with satiety during weight loss.' },
  { q: 'Do macros matter more than total calories?', a: 'For weight change, total calories matter most. But macronutrient balance affects body composition, energy levels, hunger and adherence. Getting enough protein is especially important during weight loss.' },
  { q: 'Can I use this for keto?', a: 'Yes — select the Keto split and the calculator will set very low carbs (5%) with high fat (75%) and moderate protein (20%), keeping you in nutritional ketosis range.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
        <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Age</span>
        <input id="age" type="number" step="1" placeholder="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="metric" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="170" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-3" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="7" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Activity level</span>
      <select id="activity" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="1.2">Sedentary (little or no exercise)</option>
        <option value="1.375">Lightly active (1–3 days/week)</option>
        <option value="1.55" selected>Moderately active (3–5 days/week)</option>
        <option value="1.725">Very active (6–7 days/week)</option>
        <option value="1.9">Extra active (hard daily exercise/physical job)</option>
      </select></label>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Daily calorie target</span>
      <input id="cal-target" type="number" step="any" placeholder="2200" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Macro split style</span>
      <select id="split-style" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="balanced">Balanced (30% P / 40% C / 30% F)</option>
        <option value="high-protein">High Protein (40% P / 30% C / 30% F)</option>
        <option value="low-carb">Low Carb (35% P / 20% C / 45% F)</option>
        <option value="keto">Keto (20% P / 5% C / 75% F)</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Your daily macros</div>
        <div id="r-cal" class="mt-1 text-lg font-semibold opacity-80">—</div>
      </div>
      <div class="mt-3 grid grid-cols-3 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Protein</div><div id="r-protein" class="mt-1 text-xl font-bold text-indigo-600">—</div><div class="mt-1 text-xs text-slate-400"><span id="r-pcal">—</span> cal</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Carbs</div><div id="r-carbs" class="mt-1 text-xl font-bold text-emerald-600">—</div><div class="mt-1 text-xs text-slate-400"><span id="r-ccal">—</span> cal</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Fat</div><div id="r-fat" class="mt-1 text-xl font-bold text-amber-600">—</div><div class="mt-1 text-xs text-slate-400"><span id="r-fcal">—</span> cal</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your details and calorie target to see your macros.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About macro targets</h2>
    <p class="mt-2 text-slate-600">
      Macros make up all the calories you eat. Protein, carbohydrates and fat each play distinct roles in your body. Getting the right balance helps you feel energised, build or retain muscle, manage hunger and perform at your best. While total calorie intake drives weight change, your macro split determines <em>how</em> that weight loss or gain affects your body composition. This calculator starts from your TDEE (based on your body stats and activity) so you can set a custom calorie target, then splits it according to your chosen diet style. For more on your starting point, check the <a href="/tools/tdee-calculator" class="font-medium text-indigo-600 hover:underline">TDEE Calculator</a> or <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only — not medical advice.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="220" viewBox="0 0 800 220" role="img" aria-labelledby="macro-title macro-desc">
      <title id="macro-title">Macronutrient pie chart</title>
      <desc id="macro-desc">Three-slice pie chart showing the proportions of protein (30%), carbohydrates (40%), and fat (30%) in a balanced diet.</desc>
      <circle cx="400" cy="120" r="80" fill="#e2e8f0" />
      <path d="M400,120 L400,40 A80,80 0 0,1 468.28,74.43 Z" fill="#6366f1" />
      <path d="M400,120 L468.28,74.43 A80,80 0 0,1 469.28,163.44 Z" fill="#22c55e" />
      <path d="M400,120 L469.28,163.44 A80,80 0 0,1 400,200 Z" fill="#f59e0b" />
      <text x="438" y="72" font-size="13" fill="#6366f1" font-weight="bold">Protein 30%</text>
      <text x="480" y="130" font-size="13" fill="#16a34a" font-weight="bold">Carbs 40%</text>
      <text x="438" y="183" font-size="13" fill="#d97706" font-weight="bold">Fat 30%</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Balanced macro split: 30% protein, 40% carbohydrates, 30% fat of total daily calories</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      This calculator takes your daily calorie target and divides it across protein, carbohydrates and fat according to the percentage split you select. Each macro has a fixed calorie-per-gram value: protein and carbs each provide 4 calories per gram, while fat provides 9 calories per gram. For example, on a 2,000-calorie balanced split (30/40/30), you would get 150 g of protein, 200 g of carbs and 67 g of fat. The calculator also uses your body weight and activity level to suggest a sensible calorie target using the Mifflin-St Jeor BMR equation, so you can see what a maintenance or deficit level looks like before adjusting manually.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      Each macro is calculated using simple arithmetic from your total calorie goal:
    </p>
    <p class="mt-3 text-slate-600">
      <strong>Protein (g)</strong> = (total calories × protein%) ÷ 4<br>
      <strong>Carbs (g)</strong> = (total calories × carb%) ÷ 4<br>
      <strong>Fat (g)</strong> = (total calories × fat%) ÷ 9
    </p>
    <p class="mt-3 text-slate-600">
      The calculator also estimates your <strong>TDEE</strong> from your body stats so you can set an informed calorie target. If you want to lose weight, start 300–500 calories below TDEE. For muscle gain, add 300–500 calories on top.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 28-year-old man, 180 cm, 82 kg, moderately active, wants to eat at maintenance (~2,775 cal/day) with a balanced split.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Calorie target:</span> <span class="text-slate-600">2,775 cal/day (maintenance)</span></div>
        <div><span class="font-medium text-slate-700">Protein (30%):</span> <span class="text-slate-600">2,775 × 0.30 ÷ 4 = <strong>208 g</strong> (832 cal)</span></div>
        <div><span class="font-medium text-slate-700">Carbs (40%):</span> <span class="text-slate-600">2,775 × 0.40 ÷ 4 = <strong>278 g</strong> (1,110 cal)</span></div>
        <div><span class="font-medium text-slate-700">Fat (30%):</span> <span class="text-slate-600">2,775 × 0.30 ÷ 9 = <strong>93 g</strong> (833 cal)</span></div>
        <div><span class="font-medium text-slate-700">Total check:</span> <span class="text-slate-600">832 + 1,110 + 833 = <strong>2,775 cal</strong></span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏋️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Muscle-building lifter</h3>
      <p class="mt-1 text-sm text-slate-600">Use the High Protein split to ensure enough amino acids for muscle protein synthesis while keeping carbs moderate for workout fuel.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🥑</span>
      <h3 class="mt-2 font-semibold text-slate-900">Keto dieter</h3>
      <p class="mt-1 text-sm text-slate-600">Select the Keto split to get a very low carb, high fat breakdown that supports ketosis while keeping protein adequate to prevent muscle loss.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧑‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Meal prep enthusiast</h3>
      <p class="mt-1 text-sm text-slate-600">Plan weekly meals around precise gram targets so each container hits your macros. Batch cooking becomes far more effective with clear numbers.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍⚕️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Dietitian</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly generate sample macro targets for clients based on their calorie needs and preferred eating style, saving time in consultations.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set your calorie target</h3>
        <p class="mt-1 text-sm text-slate-600">Enter your daily calorie goal. Get a starting point from our TDEE or Calorie Calculator if you are unsure what target to use.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a split style</h3>
        <p class="mt-1 text-sm text-slate-600">Choose from Balanced, High Protein, Low Carb or Keto. Each preset reflects a well-known dietary approach with different macro priorities.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your grams</h3>
        <p class="mt-1 text-sm text-slate-600">See your daily targets for protein, carbs and fat in grams. Use a tracking app to log your food and hit these numbers consistently.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for hitting your macros</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Prioritise protein</h3>
        <p class="mt-1 text-sm text-slate-600">Even if you miss your other targets, hitting your protein goal is most important for body composition. Aim for 1.6–2.2 g per kg of body weight if you are active.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use a food scale</h3>
        <p class="mt-1 text-sm text-slate-600">Eyeballing portions is notoriously inaccurate. A simple digital kitchen scale will dramatically improve how well you hit your macro targets each day.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Adjust based on feedback</h3>
        <p class="mt-1 text-sm text-slate-600">Your macro split is a starting hypothesis. If you feel lethargic, try more carbs. If you are hungry between meals, try more protein or fat. Listen to your body and adjust.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/tdee-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">TDEE Calculator</a>
      <a href="/tools/protein-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Protein Calculator</a>
      <a href="/tools/keto-macro-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Keto Macro Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
    }

    function getSplits() {
      const s = el('split-style').value;
      if (s === 'balanced') return [0.30, 0.40, 0.30];
      if (s === 'high-protein') return [0.40, 0.30, 0.30];
      if (s === 'low-carb') return [0.35, 0.20, 0.45];
      return [0.20, 0.05, 0.75];
    }

    function update() {
      const cal = parseFloat(el('cal-target').value);
      if (!cal || cal <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const [pPct, cPct, fPct] = getSplits();
      const prot = cal * pPct / 4;
      const carbs = cal * cPct / 4;
      const fat = cal * fPct / 9;
      el('r-cal').textContent = cal.toLocaleString() + ' calories/day';
      el('r-protein').textContent = Math.round(prot) + ' g';
      el('r-pcal').textContent = Math.round(prot * 4).toLocaleString();
      el('r-carbs').textContent = Math.round(carbs) + ' g';
      el('r-ccal').textContent = Math.round(carbs * 4).toLocaleString();
      el('r-fat').textContent = Math.round(fat) + ' g';
      el('r-fcal').textContent = Math.round(fat * 9).toLocaleString();
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['cal-target', 'split-style'].forEach((id) => el(id).addEventListener('input', update));
    ['u-metric', 'u-imperial', 'sex', 'age', 'm-h', 'm-w', 'i-ft', 'i-in', 'i-w', 'activity'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
