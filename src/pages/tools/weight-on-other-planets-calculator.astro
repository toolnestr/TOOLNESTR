---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Weight on Other Planets Calculator';
const description = "Weight on other planets calculator. Enter a mass and see your weight (W = mg) on Mercury, Venus, Earth, the Moon, Mars, Jupiter, Saturn, Uranus.";
const intro = 'Enter your mass once and instantly compare your weight on every major body in the solar system — mass never changes, but weight (the force gravity pulls with) is different everywhere.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'Why does my weight change on other planets but my mass does not?', a: 'Mass is the amount of matter you contain — it stays the same everywhere. Weight is the force gravity exerts on that mass, W = mg. Because each planet has its own surface gravity g, the same mass produces a different weight (force) on each one, even though nothing about you has changed.' },
  { q: 'What determines a planet’s surface gravity?', a: 'Surface gravity comes from g = GM/r², so it depends on both the planet’s mass M and its radius r. A more massive planet pulls harder, but if that mass is spread over a larger radius, the surface gravity is weaker — it is the ratio of mass to the square of radius that matters, not mass alone.' },
  { q: 'Why is Jupiter’s surface gravity so much higher despite being a gas giant?', a: 'Jupiter’s mass is enormous — about 318 times Earth’s — and even though its radius is roughly 11 times Earth’s, mass in the g = GM/r² formula wins out. The huge M in the numerator outweighs the r² in the denominator, giving Jupiter a surface gravity of about 24.79 m/s², roughly 2.5 times Earth’s.' },
  { q: 'Would I weigh less on the Moon or on Mars?', a: 'The Moon. The Moon’s surface gravity is about 1.62 m/s², versus about 3.71 m/s² on Mars — so you would weigh roughly 16.5% of your Earth weight on the Moon but about 38% of it on Mars. Mars pulls noticeably harder than the Moon despite both being much weaker than Earth.' },
  { q: 'Does altitude change my weight on a planet?', a: 'Yes — the standard g values used here are surface values (at roughly mean radius). Because g falls off as 1/r², going higher (a mountaintop, an aircraft, orbit) reduces g slightly, and going up enough (like reaching orbital altitude) can reduce your effective weight dramatically, even though your mass is unchanged.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Weight on Other Planets Calculator',
  description: 'Calculate your weight (W = mg) on every major body in the solar system from a single mass input, or solve one body’s W, m or g given the other two.',
  steps: [
    { name: 'Enter your mass', text: 'Type a mass in kilograms (or switch to pounds).' },
    { name: 'Read the table', text: 'Your weight on Mercury through Pluto solves instantly, side by side.' },
    { name: 'Try the single-body solver', text: 'Optionally pick one body and solve for W, m or g given the other two values.' },
  ],
};

const formulas = [
  { expr: 'W = m × g', note: 'weight (force) from mass and local surface gravity' },
  { expr: 'g = GM / r²', note: 'surface gravity from a body’s mass M and radius r' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — Earth vs the Moon', tone: 'slate',
    given: 'A person with mass m = 70 kg. Earth’s surface gravity g = 9.81 m/s², the Moon’s g = 1.62 m/s².',
    rows: [
      { label: 'Weight on Earth:', value: 'W = 70 × 9.81 = <strong>686.7 N</strong>' },
      { label: 'Weight on the Moon:', value: 'W = 70 × 1.62 = <strong>113.4 N</strong>' },
      { label: 'Ratio:', value: '113.4 ÷ 686.7 ≈ 0.165 — about 16.5% of Earth weight', full: true },
    ],
    note: 'Mass (70 kg) is identical on both bodies — only the force gravity applies to it changes.',
  },
  {
    title: 'Worked example 2 — the same person on Jupiter', tone: 'amber',
    given: 'Same 70 kg person. Jupiter’s surface gravity g = 24.79 m/s².',
    rows: [
      { label: 'Weight on Jupiter:', value: 'W = 70 × 24.79 = <strong>1735.3 N</strong>' },
      { label: 'Compare to Earth:', value: '1735.3 ÷ 686.7 ≈ 2.53 — more than double the Earth weight', full: true },
    ],
    note: 'Jupiter’s immense mass overwhelms its larger radius, giving it the strongest surface gravity of any planet in the solar system.',
  },
];

const comparison = {
  heading: 'Surface gravity and a 70 kg person’s weight, by body',
  note: 'Same mass (70 kg) throughout — only g changes. Sorted by distance from the Sun.',
  headers: [{ label: 'Body' }, { label: 'g', sub: 'm/s²' }, { label: 'Weight of 70 kg', sub: 'N' }],
  rows: [
    ['Mercury', '3.70', '259.0'],
    ['Venus', '8.87', '620.9'],
    ['Earth ★', '9.81', '686.7'],
    ['Moon', '1.62', '113.4'],
    ['Mars', '3.71', '259.7'],
    ['Jupiter', '24.79', '1735.3'],
    ['Saturn', '10.44', '730.8'],
    ['Uranus', '8.69', '608.3'],
    ['Neptune', '11.15', '780.5'],
    ['Pluto', '0.62', '43.4'],
  ],
  highlightIndex: 2,
  footnote: '★ Earth reference. Values use standard surface-gravity references (m/s²); weight = 70 kg × g, rounded to one decimal.',
};

const realWorld = [
  { emoji: '🧑‍🚀', title: 'Astronaut training & mission planning', body: 'NASA trains astronauts using neutral-buoyancy pools and reduced-gravity aircraft to approximate the Moon’s ~1.62 m/s² or Mars’ ~3.71 m/s² gravity, because muscle load, balance and mobility all depend directly on local g, not on the astronaut’s unchanging mass.' },
  { emoji: '🛰️', title: 'Spacecraft & lander design', body: 'A lander’s legs, thrusters and parachutes must be engineered for the specific surface gravity of the landing site — the same lander mass produces very different touchdown forces and required deceleration on the Moon, Mars, or an asteroid.' },
  { emoji: '🤸', title: 'Why astronauts can jump so high on the Moon', body: 'With the same leg-muscle force but only about 1/6th of Earth’s gravity pulling back, Apollo astronauts could jump far higher and carry heavier loads relative to their weight — their mass, and the force their muscles produce, never changed.' },
];

const misconceptions = [
  { claim: '"You would weigh nothing in space because there is no gravity."', truth: 'Astronauts in low Earth orbit are in freefall (microgravity), not zero gravity — Earth’s gravity at typical orbital altitude is still roughly 90% of its surface value. They feel weightless because they and their spacecraft are falling together, not because gravity has vanished.' },
  { claim: '"A bigger planet always has stronger surface gravity."', truth: 'Surface gravity depends on both mass and radius, g = GM/r². Saturn is about 95 times Earth’s mass yet has a surface gravity of only about 10.44 m/s² (barely above Earth’s), because its huge, low-density bulk spreads that mass over a much larger radius.' },
  { claim: '"Weight and mass are the same thing, just different units."', truth: 'Mass (kg) measures how much matter something contains and never changes with location. Weight (newtons) is the force gravity exerts on that mass, W = mg, and changes with every different g — the same mass, ten different weights across the solar system.' },
  { claim: '"On Pluto you would basically float away."', truth: 'Pluto’s gravity (about 0.62 m/s²) is weak but not zero — a 70 kg person would still weigh about 43 N there, roughly the weight of a bag of sugar on Earth, enough to keep both feet on the ground, just very light.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §13.2, Gravitation Near Earth’s Surface (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/13-2-gravitation-near-earths-surface" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>NASA, Planetary Fact Sheets</strong> — surface gravity values for all planets and notable bodies. <a href="https://nssdc.gsfc.nasa.gov/planetary/factsheet/" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">nssdc.gsfc.nasa.gov</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 13, Gravitation.' },
];
const sourcesNote = 'Surface gravity g values are standard reference figures (m/s²), rounded to two or three decimals. Weight W = m × g; results are rounded for display.';

const howToUse = [
  { title: 'Enter your mass', body: 'Type a value in kilograms (or switch units to pounds).' },
  { title: 'Scan the table', body: 'Weight on all ten bodies updates together from the single mass input.' },
  { title: 'Try one body in detail', body: 'Pick a planet and solve W, m or g given the other two values.' },
];

const related = [
  { href: '/tools/escape-velocity-calculator', emoji: '🛰️', title: 'Escape Velocity Calculator', desc: 'v_esc = √(2GM/r) — leave a body’s gravity for good.' },
  { href: '/tools/gravitational-force-calculator', emoji: '🌍', title: 'Gravitational Force Calculator', desc: "Newton's law of gravitation between masses." },
  { href: '/tools/free-fall-calculator', emoji: '⬇️', title: 'Free Fall Calculator', desc: 'Time and velocity under gravity.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="mass is how much matter you have and never changes; weight is the force gravity exerts on that mass, W = mg, and it is different on every world because g is different everywhere."
  howIntro="Because g = GM/r² depends on a planet’s mass and radius together, no two bodies pull with quite the same strength. Swap g for any body into W = mg and the same mass produces a completely different weight — from a fraction of your Earth weight on the Moon or Pluto to more than double it on Jupiter."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where this actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-sm text-slate-500">Enter a mass — your weight on every body solves at once. Mass stays the same everywhere; only weight (the force) changes.</p>
    <div class="mb-4 flex flex-wrap items-end gap-4">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Mass</span>
        <input id="mass" type="number" step="any" placeholder="e.g. 70" value="70" class="mt-1 w-40 rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <div class="flex gap-2">
        <button id="unit-kg" type="button" class="rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white">kg</button>
        <button id="unit-lb" type="button" class="rounded-lg bg-slate-200 px-3 py-2 text-sm font-semibold text-slate-600">lb</button>
      </div>
    </div>
    <p id="wp-err" class="mb-2 text-sm text-red-600" role="alert"></p>

    <div class="overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full table-fixed text-center text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-2 py-2 text-left font-semibold sm:px-3">Body</th>
            <th class="px-2 py-2 font-semibold sm:px-3">g (m/s²)</th>
            <th class="px-2 py-2 font-semibold sm:px-3">Weight (N)</th>
            <th class="px-2 py-2 font-semibold sm:px-3">Weight (lbf)</th>
          </tr>
        </thead>
        <tbody id="wp-table" class="divide-y divide-slate-100 text-slate-700 tabular-nums"></tbody>
      </table>
    </div>

    <div class="mt-8 border-t border-slate-200 pt-6">
      <h3 class="text-sm font-semibold text-slate-900">Single-body solver</h3>
      <p class="mt-1 text-sm text-slate-500">Pick a body and solve W, m or g from the other two — leave one field blank.</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-4">
        <label class="block sm:col-span-1"><span class="text-sm font-medium text-slate-700">Body</span>
          <select id="sb-body" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"></select>
        </label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Mass (kg)</span>
          <input id="sb-m" type="number" step="any" placeholder="kg" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Gravity g (m/s²)</span>
          <input id="sb-g" type="number" step="any" placeholder="m/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Weight (N)</span>
          <input id="sb-w" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
      <p id="sb-err" class="mt-2 text-sm text-red-600" role="alert"></p>
      <div class="mt-3 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">Solved: <span id="sb-result" class="font-mono font-bold">—</span></div>
    </div>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Two ideas that trip students up</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-arrows" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Same mass, different pull</h3>
          <p class="mt-1 text-sm text-slate-600">Three identical spheres (same mass), each with a weight arrow scaled to a different world's gravity: the Moon (short, grey), Earth (medium, blue) and Jupiter (long, red). The sphere never changes — only the pull does.</p>
        </div>
        <div>
          <div id="diag-gravity-bars" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Surface gravity across worlds</h3>
          <p class="mt-1 text-sm text-slate-600">Bar heights compare surface gravity g for the Moon, Earth and Jupiter — the direct driver of how much any given mass weighs on each body.</p>
        </div>
      </div>
      <p id="scene3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D diagrams unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Weight and gravity graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Weight of a 70 kg person across every body (N)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-weight"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Surface gravity g by body (m/s²) — the direct driver</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-g"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;
      const BODIES = [
        { name: 'Mercury', g: 3.70, color: '#94a3b8' },
        { name: 'Venus', g: 8.87, color: '#f59e0b' },
        { name: 'Earth', g: 9.81, color: '#2563eb' },
        { name: 'Moon', g: 1.62, color: '#94a3b8' },
        { name: 'Mars', g: 3.71, color: '#ef4444' },
        { name: 'Jupiter', g: 24.79, color: '#f97316' },
        { name: 'Saturn', g: 10.44, color: '#eab308' },
        { name: 'Uranus', g: 8.69, color: '#22d3ee' },
        { name: 'Neptune', g: 11.15, color: '#3b82f6' },
        { name: 'Pluto', g: 0.62, color: '#a3a3a3' },
      ];
      const KG_PER_LB = 0.45359237;
      const N_PER_LBF = 4.4482216153;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      // ---- primary table ----
      let unit = 'kg';
      function massKg() {
        const raw = parseFloat(el('mass').value);
        if (isNaN(raw)) return NaN;
        return unit === 'kg' ? raw : raw * KG_PER_LB;
      }
      function renderTable() {
        el('wp-err').textContent = '';
        const m = massKg();
        const tbody = el('wp-table');
        tbody.innerHTML = '';
        if (isNaN(m) || m <= 0) { el('wp-err').textContent = 'Enter a positive mass.'; return; }
        BODIES.forEach((b) => {
          const w = m * b.g;
          const tr = document.createElement('tr');
          if (b.name === 'Earth') tr.className = 'bg-indigo-50 font-semibold text-indigo-700';
          tr.innerHTML = '<td class="px-2 py-2 text-left sm:px-3">' + b.name + '</td>' +
            '<td class="px-2 py-2 sm:px-3">' + b.g.toFixed(2) + '</td>' +
            '<td class="px-2 py-2 sm:px-3">' + fmt(w) + '</td>' +
            '<td class="px-2 py-2 sm:px-3">' + fmt(w / N_PER_LBF) + '</td>';
          tbody.appendChild(tr);
        });
      }
      function switchUnit(u) {
        unit = u;
        el('unit-kg').className = u === 'kg' ? 'rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-3 py-2 text-sm font-semibold text-slate-600';
        el('unit-lb').className = u === 'lb' ? 'rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-3 py-2 text-sm font-semibold text-slate-600';
        renderTable();
      }
      el('unit-kg').addEventListener('click', () => switchUnit('kg'));
      el('unit-lb').addEventListener('click', () => switchUnit('lb'));
      el('mass').addEventListener('input', renderTable);

      // ---- single-body solver ----
      BODIES.forEach((b) => {
        const opt = document.createElement('option');
        opt.value = b.name; opt.textContent = b.name + ' (g = ' + b.g.toFixed(2) + ' m/s²)';
        el('sb-body').appendChild(opt);
      });
      el('sb-body').value = 'Earth';
      function bodyG(name) { const b = BODIES.find((x) => x.name === name); return b ? b.g : NaN; }
      function syncSbG() { el('sb-g').value = bodyG(el('sb-body').value); solveSb(); }
      function solveSb() {
        el('sb-err').textContent = '';
        el('sb-result').textContent = '—';
        const m = parseFloat(el('sb-m').value), g = parseFloat(el('sb-g').value), w = parseFloat(el('sb-w').value);
        const filled = [!isNaN(m), !isNaN(g), !isNaN(w)];
        if (filled.filter(Boolean).length < 2) return;
        if (filled[0] && filled[1]) { el('sb-result').textContent = 'W = ' + fmt(m * g) + ' N'; }
        else if (filled[0] && filled[2]) { if (m === 0) { el('sb-err').textContent = 'Mass cannot be zero.'; return; } el('sb-result').textContent = 'g = ' + fmt(w / m) + ' m/s²'; }
        else if (filled[1] && filled[2]) { if (g === 0) { el('sb-err').textContent = 'Gravity cannot be zero.'; return; } el('sb-result').textContent = 'm = ' + fmt(w / g) + ' kg'; }
      }
      el('sb-body').addEventListener('change', syncSbG);
      ['sb-m', 'sb-g', 'sb-w'].forEach((id) => el(id).addEventListener('input', solveSb));

      // ---- charts ----
      const charts = {};
      const REF_MASS = 70;

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.weight = new Chart(el('chart-weight'), {
          type: 'bar',
          data: { labels: BODIES.map((b) => b.name), datasets: [{ label: 'Weight (N)', data: BODIES.map((b) => +(REF_MASS * b.g).toFixed(1)), backgroundColor: BODIES.map((b) => b.color) }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Weight of 70 kg (N)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.g = new Chart(el('chart-g'), {
          type: 'bar',
          data: { labels: BODIES.map((b) => b.name), datasets: [{ label: 'g (m/s²)', data: BODIES.map((b) => b.g), backgroundColor: BODIES.map((b) => b.color) }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Surface gravity (m/s²)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- standalone 3D diagrams (auto-rotating, static geometry) ----
      let diagArrows = null, diagGravityBars = null;

      function initDiagArrows() {
        const c = el('diag-arrows'); if (!c) throw new Error('no container');
        const s = makeScene(c, 12, new THREE.Vector3(3, 1, 0), OPTS);
        s.scene.add(new THREE.GridHelper(16, 16, 0xe2e8f0, 0xeef2f7));
        const sample = [
          { name: 'Moon', g: 1.62, color: 0x94a3b8 },
          { name: 'Earth', g: 9.81, color: 0x2563eb },
          { name: 'Jupiter', g: 24.79, color: 0xef4444 },
        ];
        const maxG = Math.max.apply(null, sample.map((b) => b.g));
        sample.forEach((b, i) => {
          const x = i * 4 - 4;
          const sphere = new THREE.Mesh(new THREE.SphereGeometry(0.5, 24, 24), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
          sphere.position.set(x, 2.5, 0); s.scene.add(sphere);
          const len = 0.6 + (b.g / maxG) * 2.8;
          s.scene.add(arrow(new THREE.Vector3(x, 2.5, 0), new THREE.Vector3(x, 2.5 - len, 0), b.color));
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagArrows = { resize: s.resize };
      }

      function initDiagGravityBars() {
        const c = el('diag-gravity-bars'); if (!c) throw new Error('no container');
        const s = makeScene(c, 15, new THREE.Vector3(5, 3, 0), OPTS);
        const grid = new THREE.GridHelper(16, 16, 0xe2e8f0, 0xeef2f7); grid.position.set(6, 0, 0); s.scene.add(grid);
        const sample = [
          { name: 'Moon', g: 1.62, color: 0x94a3b8 },
          { name: 'Earth', g: 9.81, color: 0x2563eb },
          { name: 'Jupiter', g: 24.79, color: 0xef4444 },
        ];
        const maxG = Math.max.apply(null, sample.map((b) => b.g));
        sample.forEach((b, i) => {
          const h = Math.max(0.5, (b.g / maxG) * 8);
          const bar = new THREE.Mesh(new THREE.BoxGeometry(1.2, h, 1.2), new THREE.MeshStandardMaterial({ color: b.color }));
          bar.position.set(i * 3, h / 2, 0);
          s.scene.add(bar);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagGravityBars = { resize: s.resize };
      }

      function boot() {
        try { renderTable(); } catch (e) { console.error('[weight-planets] table init failed', e); }
        try { syncSbG(); } catch (e) { console.error('[weight-planets] solver init failed', e); }
        try { initCharts(); } catch (e) { console.error('[weight-planets] charts failed', e); }
        if (window.THREE) {
          try { initDiagArrows(); } catch (e) { console.error('[weight-planets] diagArrows failed', e); }
          try { initDiagGravityBars(); } catch (e) { console.error('[weight-planets] diagGravityBars failed', e); }
        } else { el('scene3d-fallback').classList.remove('hidden'); }
        mountResize([diagArrows, diagGravityBars]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
