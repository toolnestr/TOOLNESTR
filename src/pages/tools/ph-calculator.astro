---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'pH Calculator';
const description = "pH calculator. Calculate pH from hydrogen ion concentration [H⁺] or find [H⁺] from pH, with worked examples for strong acids and bases.";
const intro = 'Enter either the hydrogen ion concentration to find the pH, or the pH to find the concentration, using pH = −log₁₀[H⁺]. Two 3D diagrams compare a strongly acidic and a strongly basic solution, and charts show the logarithmic relationship between pH and concentration.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is pH?', a: 'pH is a measure of the acidity or basicity of a solution, defined as the negative logarithm of the hydrogen ion concentration: pH = −log₁₀[H⁺]. A pH of 7 is neutral, below 7 is acidic, above 7 is basic.' },
  { q: 'What is the pH scale?', a: 'The pH scale typically runs from 0 to 14. A strong acid like HCl has pH near 0, pure water is pH 7, and a strong base like NaOH has pH near 14. Each whole-number step represents a tenfold change in [H⁺].' },
  { q: 'What does pOH mean?', a: 'pOH is the negative log of hydroxide concentration [OH⁻]. In water at 25°C, pH + pOH = 14, a relationship that comes from the ion product of water, Kw = [H⁺][OH⁻] = 1.0×10⁻¹⁴.' },
  { q: 'How do I find the pH of a weak acid?', a: 'Weak acids do not fully dissociate. Use the acid dissociation constant Ka and the initial concentration: [H⁺] ≈ √(Ka×C). This calculator assumes complete dissociation, so it is accurate for strong acids and strong bases.' },
  { q: 'Does temperature affect pH?', a: "Yes — the ion product of water Kw changes with temperature, shifting neutral pH away from exactly 7 (about 7.47 at 0°C, about 6.51 at 60°C). A specific solution's pH also shifts with temperature because dissociation constants themselves vary." },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the pH Calculator',
  description: 'Convert between pH and hydrogen ion concentration using pH = −log₁₀[H⁺].',
  steps: [
    { name: 'Pick a mode', text: '"pH from [H⁺]" converts concentration to pH; "[H⁺] from pH" converts pH to concentration.' },
    { name: 'Enter the value', text: 'Type the concentration in mol/L (scientific notation supported), or the pH value.' },
    { name: 'Read the result', text: 'The corresponding value and acid/base classification solve instantly.' },
  ],
};

const formulas = [
  { expr: 'pH = −log₁₀[H⁺]', note: 'pH from hydrogen ion concentration, [H⁺] in mol/L' },
  { expr: '[H⁺] = 10^(−pH)', note: 'the inverse conversion — concentration from pH' },
  { expr: 'pH + pOH = 14 (at 25°C)', note: 'from the ion product of water, Kw = [H⁺][OH⁻] = 1.0×10⁻¹⁴' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — pH from a known concentration', tone: 'slate',
    given: 'A solution has [H⁺] = 2.5 × 10⁻⁴ mol/L. Find the pH and classify the solution.',
    rows: [
      { label: 'Formula:', value: 'pH = −log₁₀[H⁺]' },
      { label: 'Substitute:', value: 'pH = −log₁₀(2.5 × 10⁻⁴)' },
      { label: 'Result:', value: 'pH = 3.60 — acidic (pH < 7)', full: true },
    ],
    note: 'The corresponding hydroxide concentration is [OH⁻] = 1.0×10⁻¹⁴ / 2.5×10⁻⁴ = 4.0×10⁻¹¹ M, confirming the solution is strongly acidic.',
  },
  {
    title: 'Worked example 2 — concentration from a known pH', tone: 'amber',
    given: 'A solution is measured at pH = 9.5. Find the hydrogen ion concentration and classify it.',
    rows: [
      { label: 'Formula:', value: '[H⁺] = 10^(−pH)' },
      { label: 'Substitute:', value: '[H⁺] = 10^(−9.5)' },
      { label: 'Result:', value: '[H⁺] ≈ 3.16 × 10⁻¹⁰ M — basic (pH > 7)', full: true },
    ],
    note: 'A pH of 9.5 is mildly basic — for comparison, baking soda solution sits around pH 8.3 and household ammonia around pH 11.',
  },
];

const comparison = {
  heading: 'The pH of common substances',
  note: 'Each whole-number pH step represents a tenfold change in hydrogen ion concentration — a small pH difference hides a large concentration difference.',
  headers: [{ label: 'Substance' }, { label: 'Approx. pH' }, { label: 'Classification' }],
  rows: [
    ['Battery acid', '0.5', 'Strongly acidic'],
    ['Vinegar', '2.5', 'Strongly acidic'],
    ['Pure water ★', '7.0', 'Neutral'],
    ['Baking soda solution', '8.3', 'Weakly basic'],
    ['Ammonia', '11.5', 'Strongly basic'],
  ],
  highlightIndex: 2,
  footnote: '★ Reference point. Pure water at 25°C has [H⁺] = 1.0×10⁻⁷ M, exactly matching [OH⁻], which is what defines neutral pH.',
};

const realWorld = [
  { emoji: '🌱', title: 'Environmental water quality monitoring', body: 'Scientists measure the pH of rivers, lakes, and groundwater to detect acid rain effects and track pollution impacts on aquatic ecosystems and drinking water safety.' },
  { emoji: '👩‍🔬', title: 'Buffer preparation in the lab', body: 'Lab technicians prepare buffer solutions at specific pH values for experiments and instrument calibration, often using the Henderson-Hasselbalch equation to calculate the needed acid-to-base ratio.' },
  { emoji: '🍎', title: 'Food science and preservation', body: 'Controlling pH is essential in food preservation, fermentation, and beverage production — canned foods must stay below pH 4.6 to prevent the growth of Clostridium botulinum.' },
  { emoji: '🩺', title: 'Blood pH regulation', body: "The human body tightly regulates blood pH within a very narrow range (about 7.35–7.45) — even small deviations outside this range indicate serious medical conditions requiring immediate attention." },
];

const misconceptions = [
  { claim: '"A pH of 3 is only slightly more acidic than a pH of 5."', truth: 'Because pH is logarithmic, a solution at pH 3 is actually 100 times more acidic (has 100× the hydrogen ion concentration) than one at pH 5 — the scale hides how dramatically concentration changes with each pH step.' },
  { claim: '"For any acid, [H⁺] equals the labeled concentration."', truth: 'This only holds for strong acids like HCl, which fully dissociate. Weak acids only partially dissociate, so their actual [H⁺] is much lower than the nominal concentration — the full dissociation assumption in this calculator applies only to strong acids and bases.' },
  { claim: '"pH 7 is always neutral, at any temperature."', truth: 'pH 7 is only neutral at 25°C — the ion product of water (Kw) changes with temperature, so neutral pH shifts to about 7.47 at 0°C and about 6.51 at 60°C, even though [H⁺] still equals [OH⁻] in each case.' },
  { claim: '"Negative pH values are impossible."', truth: 'Extremely concentrated strong acids can actually have pH values below 0 — the pH scale of 0–14 is a common convenient range, not a hard mathematical limit, since pH is simply −log₁₀[H⁺] for any positive concentration.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 14, "Acid-Base Equilibria" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/14-3-relative-strengths-of-acids-and-bases" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 16, Acid-Base Equilibria.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — pH and the pH scale.' },
];
const sourcesNote = 'pH = −log₁₀[H⁺]; [H⁺] = 10^(−pH); pH+pOH=14 at 25°C. Assumes complete dissociation (valid for strong acids/bases). Results are rounded for display.';

const howToUse = [
  { title: 'Choose the direction', body: '"pH from [H⁺]" calculates pH from concentration; "[H⁺] from pH" finds concentration from a known pH.' },
  { title: 'Enter your value', body: 'Type the concentration in mol/L (scientific notation supported) or the pH value.' },
  { title: 'See the classification', body: 'The solution is classified from strongly acidic to strongly basic, with a visual pH scale reference.' },
];

const related = [
  { href: '/tools/poh-calculator', emoji: '🔵', title: 'pOH Calculator', desc: 'pOH = -log[OH-]; pH + pOH = 14 — solve any variable.' },
  { href: '/tools/henderson-hasselbalch-calculator', emoji: '🧯', title: 'Henderson-Hasselbalch (Buffer) Calculator', desc: 'pH = pKa + log([A-]/[HA]) — solve pH or the buffer ratio.' },
  { href: '/tools/ka-kb-calculator', emoji: '⚛️', title: 'Ka/Kb Equilibrium Constant Calculator', desc: 'Estimate [H+]/pH from Ka, or convert Ka ⇄ Kb.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="pH compresses an enormous range of hydrogen ion concentrations into a small, manageable number line by taking a logarithm — so a seemingly small pH difference always hides a much larger difference in actual acidity."
  howIntro="Because pH is defined as −log₁₀[H⁺], every one-unit decrease in pH corresponds to a tenfold increase in hydrogen ion concentration. Taking 10 to the power of −pH reverses the operation, recovering [H⁺] directly. At 25°C, water's own self-ionization sets [H⁺]=[OH⁻]=1.0×10⁻⁷ M, which is exactly why pH 7 is the neutral midpoint of the scale, and why the ion product Kw=[H⁺][OH⁻]=1.0×10⁻¹⁴ links pH and pOH through pH+pOH=14."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where pH actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex gap-2">
      <button id="mode-ph" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">pH from [H⁺]</button>
      <button id="mode-h" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">[H⁺] from pH</button>
    </div>
    <div id="ph-fields" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">[H⁺] (mol/L)</span>
        <input id="conc" type="number" step="any" placeholder="e.g. 0.001" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="h-fields" class="hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">pH value</span>
        <input id="ph-val" type="number" step="any" placeholder="e.g. 3.0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">pH</div><div id="r-ph" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">[H⁺] (mol/L)</div><div id="r-conc" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-4 rounded-xl border border-slate-100 bg-slate-50 p-4">
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-600">Classification:</span>
        <span id="r-class" class="font-semibold text-slate-800">—</span>
      </div>
      <div class="mt-3 h-4 w-full rounded-full bg-gradient-to-r from-red-500 via-green-500 to-blue-500"></div>
      <div class="mt-1 flex justify-between text-xs text-slate-400">
        <span>0 (Strong acid)</span><span>7 (Neutral)</span><span>14 (Strong base)</span>
      </div>
    </div>
    <p id="ph-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Acidic vs basic solutions</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-acid" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Strongly acidic solution</h3>
          <p class="mt-1 text-sm text-slate-600">A dense cloud of H⁺ ions (red) — a low pH means a high concentration of hydrogen ions.</p>
        </div>
        <div>
          <div id="diag-base" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Strongly basic solution</h3>
          <p class="mt-1 text-sm text-slate-600">A sparse scattering of H⁺ ions (blue-tinted) — a high pH means very few free hydrogen ions remain.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">pH graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">[H⁺] (log scale) vs pH — the logarithmic relationship</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-log"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">pH of common substances</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-substances"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function classify(pH) {
        if (pH < 3) return 'Strongly acidic';
        if (pH < 6) return 'Weakly acidic';
        if (pH < 7.5) return 'Neutral';
        if (pH < 11) return 'Weakly basic';
        return 'Strongly basic';
      }
      let mode = 'ph';
      function switchMode(m) {
        mode = m;
        el('mode-ph').className = m === 'ph' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-h').className = m === 'h' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('ph-fields').className = m === 'ph' ? 'grid gap-4 sm:grid-cols-2' : 'hidden';
        el('h-fields').className = m === 'h' ? 'grid gap-4 sm:grid-cols-2' : 'hidden';
        el('r-ph').textContent = '—'; el('r-conc').textContent = '—'; el('r-class').textContent = '—';
        el('ph-err').textContent = '';
      }
      function update() {
        el('ph-err').textContent = '';
        if (mode === 'ph') {
          const c = parseFloat(el('conc').value);
          if (isNaN(c) || c <= 0) {
            el('r-ph').textContent = '—'; el('r-conc').textContent = '—'; el('r-class').textContent = '—';
            if (c <= 0 && !isNaN(c)) el('ph-err').textContent = 'Concentration must be positive.';
            return;
          }
          const pH = -Math.log10(c);
          el('r-ph').textContent = pH.toFixed(2);
          el('r-conc').textContent = c.toExponential(4) + ' M';
          el('r-class').textContent = classify(pH);
        } else {
          const pH = parseFloat(el('ph-val').value);
          if (isNaN(pH) || pH < 0 || pH > 14) {
            el('r-ph').textContent = '—'; el('r-conc').textContent = '—'; el('r-class').textContent = '—';
            if (!isNaN(pH) && (pH < 0 || pH > 14)) el('ph-err').textContent = 'pH must be between 0 and 14.';
            return;
          }
          const c = Math.pow(10, -pH);
          el('r-ph').textContent = pH.toFixed(2);
          el('r-conc').textContent = c.toExponential(4) + ' M';
          el('r-class').textContent = classify(pH);
        }
      }
      el('mode-ph').addEventListener('click', () => { switchMode('ph'); update(); });
      el('mode-h').addEventListener('click', () => { switchMode('h'); update(); });
      ['conc', 'ph-val'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsPh = [], dataConc = [];
        for (let ph = 0; ph <= 14; ph += 1) { labelsPh.push(ph); dataConc.push(Math.pow(10, -ph)); }
        charts.log = new Chart(el('chart-log'), {
          type: 'line',
          data: { labels: labelsPh, datasets: [{ label: '[H+] (M)', data: dataConc, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'pH' } }, y: { type: 'logarithmic', title: { display: true, text: '[H+] (mol/L, log scale)' } } }, plugins: { legend: { display: false } } }),
        });
        const subs = [{ n: 'Battery acid', ph: 0.5 }, { n: 'Vinegar', ph: 2.5 }, { n: 'Water', ph: 7.0 }, { n: 'Baking soda', ph: 8.3 }, { n: 'Ammonia', ph: 11.5 }];
        charts.substances = new Chart(el('chart-substances'), {
          type: 'bar',
          data: { labels: subs.map((s) => s.n), datasets: [{ label: 'pH', data: subs.map((s) => s.ph), backgroundColor: ['#ef4444', '#f59e0b', '#10b981', '#38bdf8', '#6366f1'] }] },
          options: Object.assign({}, base, { indexAxis: 'y', scales: { x: { min: 0, max: 14, title: { display: true, text: 'pH' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function ionScene(container, count, color) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < count; i++) {
          const x = (Math.random() - 0.5) * 5, y = (Math.random() - 0.5) * 3, z = (Math.random() - 0.5) * 3;
          const ion = new THREE.Mesh(new THREE.SphereGeometry(0.22, 12, 10), new THREE.MeshStandardMaterial({ color }));
          ion.position.set(x, y, z);
          s.scene.add(ion);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagAcid = null, diagBase = null;
      function initDiagAcid() { const c = el('diag-acid'); if (!c) throw new Error('no container'); diagAcid = ionScene(c, 40, 0xef4444); }
      function initDiagBase() { const c = el('diag-base'); if (!c) throw new Error('no container'); diagBase = ionScene(c, 5, 0x38bdf8); }

      function boot() {
        try { switchMode('ph'); update(); } catch (e) { console.error('[ph] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[ph] charts failed', e); }
        if (window.THREE) {
          try { initDiagAcid(); } catch (e) { console.error('[ph] acid diagram failed', e); }
          try { initDiagBase(); } catch (e) { console.error('[ph] base diagram failed', e); }
        }
        mountResize([diagAcid, diagBase]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
