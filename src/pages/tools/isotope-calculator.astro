---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Isotope Calculator';
const description = "Isotope calculator: find protons, neutrons and electrons from atomic and mass number, or compute weighted average atomic mass from isotope abundances.";
const intro = 'Find the number of protons, neutrons, and electrons in any isotope from its atomic number and mass number, or compute a weighted average atomic mass from two isotopes and their natural abundances. Two 3D diagrams compare isotopes with different neutron counts and show how abundance-weighting pulls the average mass toward the more common isotope, with charts illustrating both ideas.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is an isotope?', a: 'Isotopes are atoms of the same element (same number of protons, Z) that have different numbers of neutrons, and therefore different mass numbers (A). Carbon-12, Carbon-13, and Carbon-14 are all isotopes of carbon.' },
  { q: 'How do you find the number of neutrons in an isotope?', a: 'Subtract the atomic number from the mass number: neutrons = A − Z. The mass number A is the total count of protons plus neutrons in the nucleus.' },
  { q: 'What is the difference between mass number and atomic mass?', a: 'Mass number (A) is a whole number — the specific count of protons plus neutrons in one isotope\'s nucleus. Atomic mass (shown on the periodic table) is a weighted average across all naturally occurring isotopes of an element, which is why it usually isn\'t a whole number.' },
  { q: 'Are all isotopes radioactive?', a: 'No — most elements have one or more stable isotopes that never decay, alongside any unstable (radioactive) isotopes. Carbon-12 is stable and makes up about 98.9% of natural carbon, while Carbon-14 is radioactive and used for dating organic material.' },
  { q: 'How is average atomic mass calculated from isotopes?', a: 'Multiply each isotope\'s exact mass by its fractional natural abundance, then add the results together: average mass = Σ(isotope mass × fractional abundance). This weighted average is what appears on the periodic table.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Isotope Calculator',
  description: 'Find protons, neutrons, and electrons for a specific isotope, or compute a weighted average atomic mass from isotope abundances.',
  steps: [
    { name: 'Pick a mode', text: '"Isotope composition" finds protons/neutrons/electrons. "Average atomic mass" computes a weighted average from two isotopes.' },
    { name: 'Enter the values', text: 'Type the atomic number and mass number (plus optional charge), or two isotope masses and their percent abundances.' },
    { name: 'Read the result', text: 'Particle counts, or the weighted average atomic mass, solve instantly.' },
  ],
};

const formulas = [
  { expr: 'neutrons = A − Z', note: 'mass number minus atomic number' },
  { expr: 'electrons = Z − charge', note: 'for a neutral atom, charge = 0, so electrons = Z' },
  { expr: 'average mass = Σ(mass_i × fraction_i)', note: 'weighted average across all naturally occurring isotopes' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — Carbon-14 composition', tone: 'slate',
    given: 'Carbon-14 has atomic number Z = 6 and mass number A = 14, with no net charge.',
    rows: [
      { label: 'Protons:', value: 'protons = Z = 6' },
      { label: 'Neutrons:', value: 'neutrons = A − Z = 14 − 6 = 8' },
      { label: 'Electrons:', value: 'electrons = Z − charge = 6 − 0 = 6', full: true },
    ],
    note: 'Carbon-14 has 2 more neutrons than the common Carbon-12 isotope — this extra mass and its radioactive instability is exactly what makes carbon-14 useful for radiocarbon dating.',
  },
  {
    title: "Worked example 2 — chlorine's average atomic mass", tone: 'amber',
    given: 'Natural chlorine is a mix of Cl-35 (mass 34.969 amu, 75.77% abundance) and Cl-37 (mass 36.966 amu, 24.23% abundance).',
    rows: [
      { label: 'Cl-35 contribution:', value: '34.969 × 0.7577 ≈ 26.496' },
      { label: 'Cl-37 contribution:', value: '36.966 × 0.2423 ≈ 8.957' },
      { label: 'Average mass:', value: '26.496 + 8.957 ≈ 35.45 amu', full: true },
    ],
    note: "This weighted average of 35.45 amu matches chlorine's listed atomic mass on the periodic table — closer to Cl-35's mass because it's the more abundant isotope.",
  },
];

const comparison = {
  heading: 'Hydrogen isotopes — same protons, different neutrons',
  note: 'All three are chemically hydrogen (Z=1), but their differing neutron counts give them very different masses and, in tritium\'s case, radioactivity.',
  headers: [{ label: 'Isotope' }, { label: 'Protons' }, { label: 'Neutrons' }, { label: 'Notes' }],
  rows: [
    ['Protium (¹H) ★', '1', '0', 'Most common (~99.98%), stable'],
    ['Deuterium (²H)', '1', '1', 'Stable, used in heavy water'],
    ['Tritium (³H)', '1', '2', 'Radioactive, half-life ~12.3 years'],
  ],
  highlightIndex: 0,
  footnote: '★ All three have exactly one proton (Z=1), which is what makes them all hydrogen — only the neutron count changes between isotopes.',
};

const realWorld = [
  { emoji: '🕰️', title: 'Radiocarbon dating', body: 'Carbon-14 decays at a known, steady rate, letting archaeologists estimate the age of once-living organic material by measuring how much Carbon-14 remains relative to stable Carbon-12.' },
  { emoji: '🏥', title: 'Nuclear medicine tracers', body: 'Radioactive isotopes like Technetium-99m are injected into patients in tiny amounts and tracked with imaging equipment to diagnose conditions in bones, organs, and blood flow without invasive surgery.' },
  { emoji: '🔬', title: 'Mass spectrometry', body: "A mass spectrometer separates isotopes by their mass-to-charge ratio, letting chemists directly measure the abundance of each isotope in a sample — the exact data used to calculate an element's average atomic mass." },
  { emoji: '⚛️', title: 'Nuclear reactors', body: 'Nuclear power plants rely on specific isotopes like Uranium-235 (fissile) rather than the far more abundant Uranium-238, since only certain isotopes of an element can sustain a nuclear chain reaction.' },
];

const misconceptions = [
  { claim: '"Isotopes of the same element have different atomic numbers."', truth: 'Isotopes always share the exact same atomic number (Z) — that\'s precisely what makes them the same element. Only their neutron count, and therefore mass number, differs between isotopes.' },
  { claim: '"All isotopes are radioactive."', truth: 'Most elements have at least one stable isotope that never decays. Radioactive (unstable) isotopes exist alongside stable ones — for example, Carbon-12 and Carbon-13 are stable, while only Carbon-14 is radioactive.' },
  { claim: '"The atomic mass on the periodic table is the mass of the most common isotope."', truth: "It's a weighted average across every naturally occurring isotope, weighted by how abundant each one is — not simply the mass of whichever isotope happens to be most common." },
  { claim: '"Adding or removing neutrons changes what element an atom is."', truth: 'Element identity is defined entirely by the number of protons (Z), never by neutrons. Adding or removing neutrons only creates a different isotope of the same element, not a new element.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 2, "Atoms, Molecules, and Ions" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/2-3-atomic-structure-and-symbolism" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 2, Atoms, Molecules, and Ions.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Atomic structure and isotopes.' },
];
const sourcesNote = 'neutrons = A − Z; electrons = Z − charge; average mass = Σ(mass_i × fraction_i). Isotope masses and natural abundances are standard reference (IUPAC/NIST) values. Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"Isotope composition" for protons/neutrons/electrons; "Average atomic mass" for the weighted-average calculation.' },
  { title: 'Enter the values', body: 'Type atomic number, mass number, and charge — or two isotope masses with their percent abundances.' },
  { title: 'Read the result', body: 'Particle counts or the weighted average mass solve instantly.' },
];

const related = [
  { href: '/tools/atom-calculator', emoji: '🔘', title: 'Atom Calculator', desc: 'Protons, neutrons, and electrons from atomic number and charge.' },
  { href: '/tools/half-life-calculator', emoji: '☢️', title: 'Half-Life Calculator', desc: 'Remaining quantity after N half-lives.' },
  { href: '/tools/atomic-mass-calculator', emoji: '🔬', title: 'Molar Mass Calculator', desc: 'Molar mass from chemical formula.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="an element's identity is fixed entirely by its proton count, so isotopes of the same element can carry different numbers of neutrons — and therefore different masses — without ever becoming a different element."
  howIntro="Since mass number A is simply the total count of protons and neutrons in the nucleus, subtracting the atomic number (protons) leaves neutrons = A − Z directly. For a neutral atom, the electron count always matches the proton count to balance charge, so electrons = Z (or Z − charge for an ion). When an element occurs in nature as a mixture of isotopes, each contributes to the periodic table's listed atomic mass in direct proportion to how abundant it is — a more common isotope pulls the average closer to its own mass."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where isotopes actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-comp" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Isotope composition</button>
      <button id="mode-avg" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Average atomic mass</button>
    </div>

    <div id="comp-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Atomic number Z</span>
        <input id="Z" type="number" step="1" value="6" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass number A</span>
        <input id="A" type="number" step="1" value="14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Net charge</span>
        <input id="charge" type="number" step="1" value="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="avg-fields" class="hidden grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Isotope 1 mass (amu)</span>
        <input id="m1" type="number" step="any" placeholder="e.g. 34.969" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Isotope 1 abundance (%)</span>
        <input id="pct1" type="number" step="any" placeholder="e.g. 75.77" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Isotope 2 mass (amu)</span>
        <input id="m2" type="number" step="any" placeholder="e.g. 36.966" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Isotope 2 abundance (%)</span>
        <input id="pct2" type="number" step="any" placeholder="e.g. 24.23" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="comp-out" class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Protons</div><div id="r-p" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Neutrons</div><div id="r-n" class="mt-1 text-xl font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Electrons</div><div id="r-e" class="mt-1 text-xl font-bold">—</div></div>
    </div>
    <div id="avg-out" class="mt-6 hidden grid grid-cols-1 gap-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Weighted average atomic mass</div><div id="r-avg" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <p id="iso-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Same element, different neutrons</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-isotopes" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Two isotopes of the same element</h3>
          <p class="mt-1 text-sm text-slate-600">Same number of protons (red) in both nuclei, but the isotope on the right carries extra neutrons (grey) — same element, more mass.</p>
        </div>
        <div>
          <div id="diag-weighted" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Abundance-weighted average</h3>
          <p class="mt-1 text-sm text-slate-600">The larger sphere represents the more abundant isotope — the average mass sits closer to it than to the rarer, smaller isotope.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Isotope graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Chlorine isotopes — abundance comparison</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-abund"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Weighted average mass vs Cl-35 abundance</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-weighted"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      let mode = 'comp';
      function switchMode(m) {
        mode = m;
        el('mode-comp').className = m === 'comp' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-avg').className = m === 'avg' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('comp-fields').className = m === 'comp' ? 'grid gap-4 sm:grid-cols-3' : 'hidden grid gap-4 sm:grid-cols-3';
        el('avg-fields').className = m === 'avg' ? 'grid gap-4 sm:grid-cols-2' : 'hidden grid gap-4 sm:grid-cols-2';
        el('comp-out').className = m === 'comp' ? 'mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3' : 'mt-6 hidden grid grid-cols-1 gap-3 sm:grid-cols-3';
        el('avg-out').className = m === 'avg' ? 'mt-6 grid grid-cols-1 gap-3' : 'mt-6 hidden grid grid-cols-1 gap-3';
        el('iso-err').textContent = '';
        update();
      }
      function update() {
        el('iso-err').textContent = '';
        if (mode === 'comp') {
          ['r-p', 'r-n', 'r-e'].forEach((id) => (el(id).textContent = '—'));
          const Z = parseInt(el('Z').value, 10), A = parseInt(el('A').value, 10), charge = parseInt(el('charge').value, 10);
          if (isNaN(Z) || isNaN(A) || isNaN(charge)) return;
          if (Z <= 0 || A < Z) { el('iso-err').textContent = 'Mass number must be greater than or equal to the atomic number, and both positive.'; return; }
          el('r-p').textContent = Z;
          el('r-n').textContent = A - Z;
          el('r-e').textContent = Z - charge;
        } else {
          el('r-avg').textContent = '—';
          const m1 = parseFloat(el('m1').value), pct1 = parseFloat(el('pct1').value);
          const m2 = parseFloat(el('m2').value), pct2 = parseFloat(el('pct2').value);
          if (isNaN(m1) || isNaN(pct1) || isNaN(m2) || isNaN(pct2)) return;
          if (m1 <= 0 || m2 <= 0 || pct1 < 0 || pct2 < 0) { el('iso-err').textContent = 'Masses and abundances must be positive.'; return; }
          const avg = m1 * (pct1 / 100) + m2 * (pct2 / 100);
          el('r-avg').textContent = fmt(avg) + ' amu';
        }
      }
      el('mode-comp').addEventListener('click', () => switchMode('comp'));
      el('mode-avg').addEventListener('click', () => switchMode('avg'));
      ['Z', 'A', 'charge', 'm1', 'pct1', 'm2', 'pct2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.abund = new Chart(el('chart-abund'), {
          type: 'bar',
          data: { labels: ['Cl-35', 'Cl-37'], datasets: [{ label: 'Abundance (%)', data: [75.77, 24.23], backgroundColor: ['#6366f1', '#f59e0b'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Natural abundance (%)' } } }, plugins: { legend: { display: false } } }),
        });
        const labels = [], data = [];
        for (let p = 0; p <= 100; p += 10) { labels.push(p); data.push(+(34.969 * (p / 100) + 36.966 * ((100 - p) / 100)).toFixed(3)); }
        charts.weighted = new Chart(el('chart-weighted'), {
          type: 'line',
          data: { labels, datasets: [{ label: 'Avg mass (amu)', data, borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0.2, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Cl-35 abundance (%)' } }, y: { title: { display: true, text: 'Weighted average mass (amu)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      // ---- Diagram 1: two isotopes ----
      let diagIsotopes = null;
      function initDiagIsotopes() {
        const c = el('diag-isotopes'); if (!c) throw new Error('no container');
        const s = makeScene(c, 10, new THREE.Vector3(0, 0, 0), OPTS);
        function nucleus(cx, protons, neutrons) {
          const group = new THREE.Group();
          const n = protons + neutrons;
          for (let i = 0; i < n; i++) {
            const phi = Math.acos(1 - (2 * (i + 0.5)) / n);
            const theta = Math.PI * (1 + Math.sqrt(5)) * i;
            const r = 0.7;
            const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
            const color = i < protons ? 0xef4444 : 0x94a3b8;
            const sph = new THREE.Mesh(new THREE.SphereGeometry(0.25, 12, 10), new THREE.MeshStandardMaterial({ color, roughness: 0.5 }));
            sph.position.set(x, y, z);
            group.add(sph);
          }
          group.position.set(cx, 0, 0);
          s.scene.add(group);
        }
        nucleus(-2, 6, 6);
        nucleus(2, 6, 8);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagIsotopes = { resize: s.resize };
      }

      // ---- Diagram 2: abundance-weighted spheres ----
      let diagWeighted = null;
      function initDiagWeighted() {
        const c = el('diag-weighted'); if (!c) throw new Error('no container');
        const s = makeScene(c, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const big = new THREE.Mesh(new THREE.SphereGeometry(1.1, 24, 20), new THREE.MeshStandardMaterial({ color: 0x6366f1, roughness: 0.5 }));
        big.position.set(-1.6, 0, 0); s.scene.add(big);
        const small = new THREE.Mesh(new THREE.SphereGeometry(0.7, 24, 20), new THREE.MeshStandardMaterial({ color: 0xf59e0b, roughness: 0.5 }));
        small.position.set(1.6, 0, 0); s.scene.add(small);
        const avgMarker = new THREE.Mesh(new THREE.SphereGeometry(0.35, 16, 14), new THREE.MeshStandardMaterial({ color: 0x10b981, roughness: 0.5 }));
        avgMarker.position.set(-0.6, 1.6, 0); s.scene.add(avgMarker);
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        diagWeighted = { resize: s.resize };
      }

      function boot() {
        try { switchMode('comp'); } catch (e) { console.error('[isotope] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[isotope] charts failed', e); }
        if (window.THREE) {
          try { initDiagIsotopes(); } catch (e) { console.error('[isotope] isotopes diagram failed', e); }
          try { initDiagWeighted(); } catch (e) { console.error('[isotope] weighted diagram failed', e); }
        }
        mountResize([diagIsotopes, diagWeighted]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
