---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Pace Calculator';
const description =
  'Free running pace calculator. Enter your distance and time to get your pace per kilometre ' +
  'and per mile, plus your speed. Great for races and training.';
const intro =
  'Enter the distance you ran and the time it took to see your pace per km and per mile, plus your average speed.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is running pace?', a: 'Pace is how long it takes to cover one unit of distance \u2014 for example minutes per kilometre or minutes per mile. It\u2019s the standard way runners measure effort.' },
  { q: 'Can I use it for any distance?', a: 'Yes \u2014 5K, 10K, half marathon, marathon or any custom distance in kilometres or miles.' },
  { q: 'Does it show speed too?', a: 'Yes, it also shows your average speed in km/h and mph.' },
  { q: 'What is a good running pace for a beginner?', a: 'A comfortable conversational pace for a beginner is typically around 6:00\u20137:30 per km (9:40\u201312:00 per mile). The "right" pace is one you can sustain for your target distance.' },
  { q: 'How do I improve my pace?', a: 'Consistent training with a mix of easy runs, interval sessions and long runs is the most effective way. Many runners aim to improve by 5\u201310 seconds per km over a few months of structured training.' },
  { q: 'Can I use this for walking, cycling or swimming?', a: 'Yes \u2014 the calculator works for any activity where you cover distance over time. Enter your distance and time, and you\u2019ll get the pace and speed regardless of the activity.' },
  { q: 'How does elevation affect my pace?', a: 'Climbing 100 metres of elevation typically adds about 10\u201315 seconds per km. Descending can slightly improve pace but the net effect on hilly courses is usually slower overall.' },
  { q: 'What\u2019s a realistic pace goal for a first marathon?', a: 'Most first-time marathoners target 5:00\u20136:00 per km (8:00\u20139:40 per mile), finishing in 3:30\u20134:15. The key is to start conservatively and maintain a steady effort.' },
  { q: 'How do I pace an interval workout?', a: 'Run intervals at about your 5K race pace or slightly faster, with recovery jogs at a very easy effort. The rest between intervals should be long enough to catch your breath, typically equal to the work period.' },
  { q: 'How does weather affect running pace?', a: 'Heat, humidity and strong headwinds all slow you down. As a rough rule, pace slows by about 2\u20135 seconds per km for every 5\u00b0C above 15\u00b0C. Adjust your goals on hot days.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Distance</span>
        <div class="mt-1 flex gap-2">
          <input id="dist" type="number" step="any" placeholder="10" class="min-w-0 flex-1 rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <select id="unit" class="rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="km">km</option><option value="mi">miles</option></select>
        </div></label>
      <div><span class="text-sm font-medium text-slate-700">Time (h : m : s)</span>
        <div class="mt-1 grid grid-cols-3 gap-2">
          <input id="h" type="number" placeholder="h" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <input id="m" type="number" placeholder="m" value="50" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
          <input id="s" type="number" placeholder="s" class="rounded-xl border border-slate-300 p-3 text-center outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-sm opacity-80">Per km</div><div id="r-km" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-sm opacity-80">Per mile</div><div id="r-mi" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">km/h</div><div id="r-kmh" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">mph</div><div id="r-mph" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this pace calculator</h2>
    <p class="mt-2 text-slate-600">
      Whether you’re training for a 5K or a marathon, knowing your pace helps you plan and improve.
      Enter how far you ran and how long it took, and this calculator shows your pace per kilometre
      and per mile, along with your average speed — all instantly. Track your training alongside the <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> to see how much energy your runs burn.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="pace-title pace-desc">
      <title id="pace-title">Speed, distance and time relationship</title>
      <desc id="pace-desc">Triangle diagram illustrating the relationship between speed, distance and time with the formula.</desc>
      <polygon points="400,30 180,170 620,170" fill="none" stroke="#6366f1" stroke-width="3" />
      <text x="400" y="100" text-anchor="middle" font-size="15" fill="#6366f1" font-weight="bold">Speed</text>
      <text x="400" y="118" text-anchor="middle" font-size="12" fill="#818cf8">Distance / Time</text>
      <text x="240" y="170" text-anchor="middle" font-size="14" fill="#64748b" font-weight="bold">Distance</text>
      <text x="560" y="170" text-anchor="middle" font-size="14" fill="#64748b" font-weight="bold">Time</text>
      <text x="400" y="195" text-anchor="middle" font-size="12" fill="#94a3b8">Pace = Time / Distance (min/km) &nbsp; | &nbsp; Speed = Distance / Time (km/h)</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Relationship between distance, time and speed for running pace calculation</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Use the Pace Calculator before a race to decide what pace to target, or after a run to analyse your performance. It’s essential during training blocks — for example, checking whether your easy-run pace is in the right zone, or calculating the pace you need to hold for a sub-45-minute 10K. Coaches use it to prescribe goal paces for interval workouts and tempo runs.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Use a GPS watch or a measured route (like a track or marked course) for the most accurate distance input.</li>
      <li>For races, calculate your target pace in advance and write it on your wrist — it’s easy to go out too fast in the excitement.</li>
      <li>Remember that pace naturally slows on hilly terrain, so adjust your expectations when running a course with significant elevation gain.</li>
    </ul>
  </section>

  <!-- Pace ranges bar chart -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different pace ranges mean</h2>
    <p class="mt-2 text-slate-600">Running pace falls into distinct intensity zones. The bars below show approximate pace ranges for each zone and what they feel like.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Easy / recovery</span><span class="text-slate-400">Conversational effort</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Steady / endurance</span><span class="text-slate-400">Comfortably hard</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:25%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Tempo / threshold</span><span class="text-slate-400">Brisk, sustainable ~1 hour</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Race pace (10K / HM)</span><span class="text-slate-400">Hard but controlled</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Interval / sprint</span><span class="text-slate-400">All-out effort</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:15%"></div></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏃</span>
      <h3 class="mt-2 font-semibold text-slate-900">Marathon runner</h3>
      <p class="mt-1 text-sm text-slate-600">Calculate the exact pace you need to hold for 42.2 km to hit your goal time, and practise running at that effort during long runs.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚶</span>
      <h3 class="mt-2 font-semibold text-slate-900">Beginner jogger</h3>
      <p class="mt-1 text-sm text-slate-600">Find a comfortable, sustainable pace that lets you run without burning out after five minutes — the key to building a lasting habit.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👨‍🏫</span>
      <h3 class="mt-2 font-semibold text-slate-900">Running coach</h3>
      <p class="mt-1 text-sm text-slate-600">Prescribe precise paces for easy runs, tempo sessions and interval workouts so athletes train in the correct intensity zones.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚴</span>
      <h3 class="mt-2 font-semibold text-slate-900">Triathlete</h3>
      <p class="mt-1 text-sm text-slate-600">Use the same tool for running, cycling and swimming pace calculations to plan brick sessions and race-day transitions accurately.</p>
    </div>
  </section>

  <!-- Race pace reference table -->
  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Race distance</th><th class="p-3">Goal time (hr:min)</th><th class="p-3">Pace per km</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">5K</td><td class="p-3">22:30</td><td class="p-3">4:30 /km</td></tr>
        <tr><td class="p-3 font-medium">10K</td><td class="p-3">45:00</td><td class="p-3">4:30 /km</td></tr>
        <tr><td class="p-3 font-medium">Half marathon</td><td class="p-3">1:40:00</td><td class="p-3">4:44 /km</td></tr>
        <tr><td class="p-3 font-medium">Marathon</td><td class="p-3">3:30:00</td><td class="p-3">4:59 /km</td></tr>
        <tr><td class="p-3 font-medium">50K ultramarathon</td><td class="p-3">5:30:00</td><td class="p-3">6:36 /km</td></tr>
        <tr><td class="p-3 font-medium">100K ultramarathon</td><td class="p-3">12:00:00</td><td class="p-3">7:12 /km</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How pace is calculated</h2>
    <p class="mt-2 text-slate-600">
      Pace is simply <strong>time divided by distance</strong>. It tells you how long it takes to cover one unit of distance (usually one kilometre or one mile). The reciprocal of pace is <strong>speed</strong>, which tells you how far you cover per unit of time.
    </p>
    <p class="mt-3 text-slate-600">
      <strong>Pace (min per km)</strong> = total time (minutes) ÷ distance (km)<br>
      <strong>Speed (km/h)</strong> = distance (km) ÷ total time (hours) = 60 ÷ pace (min/km)<br>
      <strong>Pace (min per mile)</strong> = pace (min/km) × 1.609344<br>
      <strong>Speed (mph)</strong> = speed (km/h) ÷ 1.609344
    </p>
    <p class="mt-3 text-slate-600">
      For example, a pace of 5:00 /km means you run one kilometre in 5 minutes. Your speed is 60 ÷ 5 = 12 km/h. Runners use pace rather than speed because it maps naturally to interval distances and race splits.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A runner completes a 10 km race in 48 minutes and 30 seconds. What is their pace?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Distance:</span> <span class="text-slate-600">10 km</span></div>
        <div><span class="font-medium text-slate-700">Total time:</span> <span class="text-slate-600">48 min 30 sec = 48.5 minutes</span></div>
        <div><span class="font-medium text-slate-700">Pace per km:</span> <span class="text-slate-600">48.5 ÷ 10 = <strong>4:51 /km</strong></span></div>
        <div><span class="font-medium text-slate-700">Pace per mile:</span> <span class="text-slate-600">4:51 × 1.609 = <strong>7:48 /mi</strong></span></div>
        <div><span class="font-medium text-slate-700">Speed (km/h):</span> <span class="text-slate-600">60 ÷ 4.85 = <strong>12.4 km/h</strong></span></div>
        <div><span class="font-medium text-slate-700">Speed (mph):</span> <span class="text-slate-600">12.4 ÷ 1.609 = <strong>7.7 mph</strong></span></div>
      </div>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Pace Calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter distance</h3>
        <p class="mt-1 text-sm text-slate-600">Type the distance you covered or plan to cover, and choose kilometres or miles from the dropdown.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter time</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in hours, minutes and seconds. For a race, use your finish time. For training, use the duration of your run.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your pace</h3>
        <p class="mt-1 text-sm text-slate-600">See your pace per km and per mile, plus your average speed. Use the pace figure to guide your effort on future runs of similar distance.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for better pacing</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use a GPS watch or measured route</h3>
        <p class="mt-1 text-sm text-slate-600">The most accurate pace calculations start with accurate distance. GPS watches, track laps or pre-measured courses give the best data.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Practise race-day pacing</h3>
        <p class="mt-1 text-sm text-slate-600">Calculate your target pace in advance and write it on your wrist or set your watch. It's easy to go out too fast in the excitement — stick to the plan.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Adjust for terrain and weather</h3>
        <p class="mt-1 text-sm text-slate-600">Pace naturally slows on hills and in heat. A 5:00 /km effort on flat ground might feel like 5:30 /km on a hilly trail. Adjust your expectations and effort accordingly.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const mmss = (secs) => {
      if (!isFinite(secs) || secs <= 0) return '—';
      const m = Math.floor(secs / 60), s = Math.round(secs % 60);
      return `${m}:${s.toString().padStart(2, '0')}`;
    };

    function update() {
      const dist = parseFloat(el('dist').value);
      const totalSec = (parseInt(el('h').value, 10) || 0) * 3600 + (parseInt(el('m').value, 10) || 0) * 60 + (parseInt(el('s').value, 10) || 0);
      if (!dist || dist <= 0 || totalSec <= 0) { ['km', 'mi', 'kmh', 'mph'].forEach((k) => (el('r-' + k).textContent = '—')); return; }
      const km = el('unit').value === 'km' ? dist : dist * 1.609344;
      const mi = km / 1.609344;
      el('r-km').textContent = mmss(totalSec / km) + ' /km';
      el('r-mi').textContent = mmss(totalSec / mi) + ' /mi';
      el('r-kmh').textContent = (km / (totalSec / 3600)).toFixed(2);
      el('r-mph').textContent = (mi / (totalSec / 3600)).toFixed(2);
    }
    ['dist', 'unit', 'h', 'm', 's'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
