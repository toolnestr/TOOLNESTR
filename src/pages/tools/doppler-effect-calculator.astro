---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Doppler Effect Calculator';
const description = "Doppler effect calculator. Solve f_obs = f_source × v_sound / (v_sound ∓ v_source) for an approaching or receding sound source, with worked examples.";
const intro = 'Solve f_obs = f_source × v_sound / (v_sound ∓ v_source) for the frequency heard when a sound source moves toward or away from a stationary listener. Two 3D diagrams show compressed wavefronts ahead of the source and stretched wavefronts behind it, and charts compare observed frequency across a range of source speeds.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is the Doppler effect?', a: 'The Doppler effect is the change in observed frequency of a wave caused by relative motion between the source and the observer. A sound source moving toward you raises the pitch you hear (higher frequency); a source moving away lowers it (lower frequency), even though the source itself never changes its actual emitted frequency.' },
  { q: 'What is the formula for a moving source and stationary observer?', a: 'f_obs = f_source × v_sound / (v_sound − v_source) when the source approaches, and f_obs = f_source × v_sound / (v_sound + v_source) when it recedes, where v_sound ≈ 343 m/s in air at room temperature. The minus sign in the denominator raises the observed frequency; the plus sign lowers it.' },
  { q: 'Why does a passing ambulance siren change pitch?', a: "As the ambulance approaches, each successive sound wave is emitted from a position slightly closer to you than the last, compressing the wavefronts and raising the frequency you hear. Once it passes and recedes, each wave is emitted farther away, stretching the wavefronts and lowering the pitch — the classic 'eee-yoooown' effect." },
  { q: 'Does the Doppler effect only apply to sound?', a: "No — it applies to any wave phenomenon, including light. The same underlying principle causes the redshift and blueshift of light from stars and galaxies moving away from or toward Earth, which astronomers use to measure cosmic expansion and the motion of distant objects." },
  { q: 'What happens if the source moves faster than the speed of sound?', a: 'If v_source ≥ v_sound, the source is moving faster than the waves it emits can travel forward, and the standard formula breaks down (the denominator would be zero or negative for the approaching case). This is the regime of sonic booms, where wavefronts pile up into a shock cone instead of separate compressed waves.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Doppler Effect Calculator',
  description: 'Calculate the observed frequency for a sound source approaching or receding from a stationary listener.',
  steps: [
    { name: 'Enter the source frequency', text: 'This is the frequency the source actually emits, such as a siren at 700 Hz.' },
    { name: 'Enter the speed of sound and source speed', text: 'v_sound defaults to 343 m/s (air); enter the source\'s speed toward or away from the listener.' },
    { name: 'Choose approaching or receding', text: 'Toggle the direction to see the observed frequency rise or fall accordingly.' },
  ],
};

const formulas = [
  { expr: 'f<sub>obs</sub> = f<sub>source</sub> × v<sub>sound</sub> / (v<sub>sound</sub> − v<sub>source</sub>)', note: 'source approaching the observer (pitch rises)' },
  { expr: 'f<sub>obs</sub> = f<sub>source</sub> × v<sub>sound</sub> / (v<sub>sound</sub> + v<sub>source</sub>)', note: 'source receding from the observer (pitch falls)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — approaching siren', tone: 'slate',
    given: 'A siren emits f_source = 700 Hz. It approaches a stationary listener at v_source = 30 m/s, with v_sound = 343 m/s. Find the observed frequency.',
    rows: [
      { label: 'Formula:', value: 'f_obs = f_source × v_sound / (v_sound − v_source)' },
      { label: 'Substitute:', value: 'f_obs = 700 × 343 / (343 − 30) = 700 × 343 / 313' },
      { label: 'Result:', value: 'f_obs ≈ 767.09 Hz', full: true },
    ],
    note: 'The approaching source compresses the wavefronts, so the listener hears a higher pitch than the 700 Hz actually emitted.',
  },
  {
    title: 'Worked example 2 — receding siren', tone: 'amber',
    given: 'The same siren (f_source = 700 Hz, v_sound = 343 m/s) now recedes from the listener at v_source = 30 m/s. Find the observed frequency.',
    rows: [
      { label: 'Formula:', value: 'f_obs = f_source × v_sound / (v_sound + v_source)' },
      { label: 'Substitute:', value: 'f_obs = 700 × 343 / (343 + 30) = 240100 / 373' },
      { label: 'Result:', value: 'f_obs ≈ 643.70 Hz', full: true },
    ],
    note: 'Receding stretches the wavefronts, lowering the observed pitch below the true 700 Hz — this is the drop in pitch heard just after a siren passes by.',
  },
];

const comparison = {
  heading: 'Approaching vs receding — same speed, opposite effect',
  note: 'At the same source speed, approaching raises frequency more than receding lowers it, because the formulas are not symmetric around the source frequency.',
  headers: [{ label: 'Source speed' }, { label: 'Approaching f_obs' }, { label: 'Receding f_obs' }],
  rows: [
    ['0 m/s', '700.00 Hz', '700.00 Hz'],
    ['30 m/s', '767.09 Hz', '643.70 Hz'],
    ['60 m/s', '848.94 Hz', '598.76 Hz'],
    ['100 m/s', '1000.00 Hz', '564.63 Hz'],
  ],
  highlightIndex: 1,
  footnote: 'f_source = 700 Hz, v_sound = 343 m/s in all rows. The approaching case grows without bound as v_source approaches v_sound, while the receding case only asymptotically approaches zero.',
};

const realWorld = [
  { emoji: '🚑', title: 'Emergency vehicle sirens', body: 'The pitch shift of an approaching-then-receding ambulance or fire truck siren is a direct, everyday demonstration of the Doppler effect, and drivers instinctively use the changing pitch to judge whether a vehicle is approaching or moving away.' },
  { emoji: '🚔', title: 'Police radar and speed guns', body: 'Radar guns bounce a radio wave off a moving vehicle and measure the Doppler shift in the reflected frequency to calculate the vehicle\'s speed — the same v = fλ and Doppler relationships used for sound apply to these electromagnetic waves.' },
  { emoji: '🌌', title: 'Astronomical redshift', body: 'Light from galaxies moving away from Earth is Doppler-shifted to longer (redder) wavelengths, and this redshift is one of the primary pieces of evidence for the expansion of the universe.' },
  { emoji: '🌦️', title: 'Doppler weather radar', body: 'Weather radar stations measure the Doppler shift of radio waves reflecting off raindrops or debris to determine wind speed and direction inside storms, which is essential for detecting tornadoes and severe weather rotation.' },
];

const misconceptions = [
  { claim: '"The Doppler effect changes the actual frequency the source emits."', truth: 'The source\'s emitted frequency never changes — only the frequency an outside observer perceives changes, because of how the wavefronts get compressed or stretched by the source\'s motion relative to the observer.' },
  { claim: '"Approaching and receding shift the frequency by the same amount, just in opposite directions."', truth: "The two formulas aren't symmetric: f_obs = f_source·v/(v−v_source) for approaching grows without bound as v_source nears v, while f_obs = f_source·v/(v+v_source) for receding only approaches zero — the size of the shift differs between the two cases at the same speed." },
  { claim: '"The Doppler effect only happens when the source is moving, not the observer."', truth: 'The effect happens for either the source or the observer moving (or both) — a moving observer toward a stationary source also hears a higher frequency, though the exact formula differs slightly from the moving-source case used here.' },
  { claim: '"You need to be moving toward or away in a straight line for the Doppler effect to apply."', truth: 'The Doppler shift depends on the component of relative velocity along the line connecting source and observer — an object moving past you at an angle produces a smaller, continuously changing shift, not zero shift, except at the instant it is moving directly perpendicular to your line of sight.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §17.4 "The Doppler Effect" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/17-4-the-doppler-effect" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 17, Waves II (The Doppler Effect).' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 17, Sound Waves.' },
];
const sourcesNote = 'f_obs = f_source × v_sound / (v_sound ∓ v_source), for a moving source and stationary observer, with v_sound ≈ 343 m/s in air at room temperature. Results are rounded for display.';

const howToUse = [
  { title: 'Enter the source frequency', body: 'This is the true frequency emitted by the moving source, in hertz.' },
  { title: 'Set speed of sound and source speed', body: 'v_sound defaults to 343 m/s for air; adjust for other temperatures or media if needed.' },
  { title: 'Toggle direction', body: 'Switch between approaching (higher observed pitch) and receding (lower observed pitch).' },
];

const related = [
  { href: '/tools/wavelength-frequency-calculator', emoji: '🌊', title: 'Wavelength Calculator', desc: 'v = fλ — solve for wavelength, frequency, or wave velocity.' },
  { href: '/tools/snells-law-calculator', emoji: '🔦', title: "Snell's Law Calculator", desc: 'n1 sinθ1 = n2 sinθ2 — refraction of waves.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="A moving sound source compresses the wavefronts ahead of it and stretches them behind it, so a stationary listener hears a higher pitch as the source approaches and a lower pitch as it recedes — even though the source's true emitted frequency never changes."
  howIntro="For an approaching source, f_obs = f_source·v_sound/(v_sound − v_source) — the minus sign in the denominator makes f_obs larger than f_source. For a receding source, f_obs = f_source·v_sound/(v_sound + v_source) — the plus sign makes f_obs smaller. Both formulas reduce to f_obs = f_source when v_source = 0, and the approaching case grows without bound as the source speed approaches the speed of sound itself."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the Doppler effect actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-3 text-sm font-medium text-slate-700">Direction:</div>
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-approach" type="button" data-dir="approach" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Approaching</button>
      <button id="mode-recede" type="button" data-dir="recede" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Receding</button>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Source frequency (f_source)</span>
        <input id="fsrc" type="number" step="any" placeholder="Hz" value="700" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Speed of sound (v_sound)</span>
        <input id="vsound" type="number" step="any" placeholder="m/s" value="343" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Source speed (v_source)</span>
        <input id="vsrc" type="number" step="any" placeholder="m/s" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Observed frequency</div><div id="r-fobs" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Shift from source</div><div id="r-shift" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="dp-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two standalone 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Compressed vs stretched wavefronts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-ahead" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Ahead of the source — compressed</h3>
          <p class="mt-1 text-sm text-slate-600">Wavefronts <span class="font-semibold text-indigo-600">bunch closely together</span> on the approaching side, since each new wave is emitted from a position closer to this side than the last — a higher observed frequency.</p>
        </div>
        <div>
          <div id="diag-behind" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Behind the source — stretched</h3>
          <p class="mt-1 text-sm text-slate-600">Wavefronts <span class="font-semibold text-amber-500">spread farther apart</span> on the receding side, since each new wave is emitted from a position farther from this side — a lower observed frequency.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Doppler shift graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">f_obs vs source speed (approaching, f_source=700 Hz, v_sound=343 m/s)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-approach"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Approaching vs receding f_obs across source speeds</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-compare"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      // ---- calculator ----
      let direction = 'approach';
      function switchDir(d) {
        direction = d;
        el('mode-approach').className = d === 'approach' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-recede').className = d === 'recede' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        update();
      }
      el('mode-approach').addEventListener('click', () => switchDir('approach'));
      el('mode-recede').addEventListener('click', () => switchDir('recede'));

      function update() {
        el('dp-err').textContent = '';
        el('r-fobs').textContent = '—'; el('r-shift').textContent = '—';
        const fsrc = parseFloat(el('fsrc').value);
        const vsound = parseFloat(el('vsound').value);
        const vsrc = parseFloat(el('vsrc').value);
        if (isNaN(fsrc) || isNaN(vsound) || isNaN(vsrc)) return;
        if (vsound <= 0 || fsrc <= 0) { el('dp-err').textContent = 'Frequency and speed of sound must be positive.'; return; }
        if (vsrc < 0) { el('dp-err').textContent = 'Source speed cannot be negative.'; return; }
        let denom;
        if (direction === 'approach') {
          denom = vsound - vsrc;
          if (denom <= 0) { el('dp-err').textContent = 'Source speed must be less than the speed of sound for the approaching formula to apply.'; return; }
        } else {
          denom = vsound + vsrc;
        }
        const fobs = fsrc * vsound / denom;
        el('r-fobs').textContent = fmt(fobs) + ' Hz';
        const shift = fobs - fsrc;
        el('r-shift').textContent = (shift >= 0 ? '+' : '') + fmt(shift) + ' Hz';
      }
      ['fsrc', 'vsound', 'vsrc'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const fsrc = 700, vsound = 343;
        const L1 = [], D1 = [];
        for (let vs = 0; vs <= 100.001; vs += 5) { L1.push(vs.toFixed(0)); D1.push(+(fsrc * vsound / (vsound - vs)).toFixed(2)); }
        charts.approach = new Chart(el('chart-approach'), {
          type: 'line',
          data: { labels: L1, datasets: [{ label: 'f_obs', data: D1, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Source speed (m/s)' } }, y: { title: { display: true, text: 'Observed frequency (Hz)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        const L2 = [], appr = [], rec = [];
        for (let vs = 0; vs <= 100.001; vs += 10) {
          L2.push(vs.toFixed(0));
          appr.push(+(fsrc * vsound / (vsound - vs)).toFixed(2));
          rec.push(+(fsrc * vsound / (vsound + vs)).toFixed(2));
        }
        charts.compare = new Chart(el('chart-compare'), {
          type: 'line',
          data: { labels: L2, datasets: [
            { label: 'Approaching', data: appr, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.08)', fill: false, tension: 0.3, pointRadius: 2 },
            { label: 'Receding', data: rec, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.08)', fill: false, tension: 0.3, pointRadius: 2 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Source speed (m/s)' } }, y: { title: { display: true, text: 'Observed frequency (Hz)' }, beginAtZero: true } }, plugins: { legend: { display: true } } }),
        });
        charts.ready = true;
      }

      // ---- Diagrams: compressed (ahead) vs stretched (behind) wavefronts ----
      let diagAhead = null, diagBehind = null;
      function buildWavefronts(container, spacingStart, spacingStep, count, color) {
        const c = el(container); if (!c) throw new Error('no container');
        const s = makeScene(c, 11, new THREE.Vector3(0, 0, 0), OPTS);
        const sourceMat = new THREE.MeshStandardMaterial({ color: 0xef4444 });
        const source = new THREE.Mesh(new THREE.SphereGeometry(0.3, 20, 16), sourceMat);
        s.scene.add(source);

        const ringMat = new THREE.LineBasicMaterial({ color });
        let radius = spacingStart;
        for (let i = 0; i < count; i++) {
          const curve = new THREE.EllipseCurve(0, 0, radius, radius, 0, Math.PI * 2, false, 0);
          const pts = curve.getPoints(48).map((p) => new THREE.Vector3(p.x, 0, p.y));
          const geo = new THREE.BufferGeometry().setFromPoints(pts);
          const ring = new THREE.Line(geo, ringMat);
          s.scene.add(ring);
          radius += spacingStep;
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      function initDiagAhead() { diagAhead = buildWavefronts('diag-ahead', 0.6, 0.55, 6, 0x6366f1); }
      function initDiagBehind() { diagBehind = buildWavefronts('diag-behind', 0.8, 1.3, 5, 0xf59e0b); }

      function boot() {
        try { switchDir('approach'); update(); } catch (e) { console.error('[doppler-effect] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[doppler-effect] charts failed', e); }
        if (window.THREE) {
          try { initDiagAhead(); } catch (e) { console.error('[doppler-effect] ahead diagram failed', e); }
          try { initDiagBehind(); } catch (e) { console.error('[doppler-effect] behind diagram failed', e); }
        }
        mountResize([diagAhead, diagBehind]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
