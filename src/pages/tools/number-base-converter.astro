---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Number Base Converter';
const description =
  'Free number base converter. Convert between binary, octal, decimal and hexadecimal ' +
  'instantly. Enter a value in any base and see all the others. Private and free.';
const intro =
  'Type a number and choose its base — the binary, octal, decimal and hexadecimal versions all update instantly.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'Which bases are supported?', a: 'Binary (base 2), octal (base 8), decimal (base 10) and hexadecimal (base 16) — the four most common in computing.' },
  { q: 'What is hexadecimal used for?', a: 'Hex is widely used in programming for colors (#ff0000), memory addresses and byte values, because each hex digit maps neatly to 4 binary bits.' },
  { q: 'Why is my input invalid?', a: 'Each base only allows certain digits — binary uses 0\u20131, octal 0\u20137, decimal 0\u20139, and hex 0\u20139 plus A\u2013F. Check your input matches the chosen base.' },
  { q: 'Is it private?', a: 'Yes, everything runs in your browser.' },
  { q: 'What is binary used for?', a: 'Binary is the native language of computers. Programmers use it for bitwise operations, flags in permission systems, and understanding how data is stored at the hardware level.' },
  { q: 'Can I convert values with decimal points?', a: 'This converter handles whole numbers only. For fractional values you’ll need a specialised floating-point converter.' },
  { q: 'What does "0x" mean in hex?', a: 'In many programming languages, 0x is a prefix that indicates a hexadecimal number. For example, 0xFF is the same as 255 in decimal. The tool strips the prefix automatically.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="DeveloperApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-end">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Value</span>
        <input id="value" type="text" placeholder="e.g. 255" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Input base</span>
        <select id="base" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 sm:w-auto">
          <option value="2">Binary (2)</option>
          <option value="8">Octal (8)</option>
          <option value="10" selected>Decimal (10)</option>
          <option value="16">Hex (16)</option>
        </select>
      </label>
    </div>
    <p id="error" class="mt-2 hidden text-sm text-red-600"></p>

    <div class="mt-5 space-y-4">
      {[['Binary', 'bin'], ['Octal', 'oct'], ['Decimal', 'dec'], ['Hexadecimal', 'hex']].map(([label, id]) => (
        <div>
          <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">{label}</label>
          <div class="mt-1 flex gap-2">
            <input id={`out-${id}`} type="text" readonly class="min-w-0 flex-1 rounded-lg border border-slate-200 bg-slate-50 p-3 font-mono text-sm outline-none" />
            <button data-copy={`out-${id}`} class="copy shrink-0 rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Copy</button>
          </div>
        </div>
      ))}
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About number bases</h2>
    <p class="mt-2 text-slate-600">
      Computers work in binary, but programmers regularly switch between binary, octal, decimal and
      hexadecimal. This converter lets you type a value in any of those bases and instantly see it
      in all the others — handy for debugging, working with colors, bit masks or memory addresses.
      Pair it with the <a href="/tools/color-converter" class="font-medium text-indigo-600 hover:underline">Color Converter</a>
      to understand hex colour codes, or the <a href="/tools/timestamp-converter" class="font-medium text-indigo-600 hover:underline">Timestamp Converter</a>
      to work with epoch time values.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Select the base of the number you’re entering.</li>
      <li>Type the value.</li>
      <li>Read the equivalents and copy any one you need.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Converting between number bases is a fundamental skill in programming and computer science. Developers use it when debugging memory addresses in hex, interpreting permission bits in octal for Linux file systems, or working with colour values in CSS. Students learning computer architecture convert between binary and hex to understand how data flows through a CPU. Network engineers calculate subnet masks in binary. Embedded systems programmers read register values directly in hex from datasheets and need quick conversions to decimal.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Make sure your input only contains digits valid for the selected base — binary allows only 0 and 1, hex allows 0-9 and A-F.</li>
      <li>Hex values can be entered with or without the 0x prefix — both forms are accepted.</li>
      <li>Use the copy buttons next to each output field to grab the converted value in your desired base.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const value = el('value'), base = el('base'), error = el('error');
    const valid = { 2: /^[01]+$/, 8: /^[0-7]+$/, 10: /^[0-9]+$/, 16: /^[0-9a-fA-F]+$/ };

    function update() {
      const raw = value.value.trim().replace(/^0x/i, '');
      if (!raw) { ['bin', 'oct', 'dec', 'hex'].forEach((id) => (el('out-' + id).value = '')); error.classList.add('hidden'); return; }
      const b = parseInt(base.value, 10);
      if (!valid[b].test(raw)) {
        error.textContent = `Not a valid base-${b} number.`;
        error.classList.remove('hidden');
        return;
      }
      error.classList.add('hidden');
      const n = parseInt(raw, b);
      el('out-bin').value = n.toString(2);
      el('out-oct').value = n.toString(8);
      el('out-dec').value = n.toString(10);
      el('out-hex').value = n.toString(16).toUpperCase();
    }

    [value, base].forEach((e) => e.addEventListener('input', update));
    document.querySelectorAll('.copy').forEach((btn) => btn.addEventListener('click', async () => {
      const v = el(btn.dataset.copy).value;
      if (!v) return;
      try { await navigator.clipboard.writeText(v); const o = btn.textContent; btn.textContent = '✓'; setTimeout(() => (btn.textContent = o), 1000); } catch (e) {}
    }));
  </script>
</ToolLayout>
