---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Number Base Converter';
const description =
  'Free number base converter. Convert between binary, octal, decimal and hexadecimal ' +
  'instantly. Enter a value in any base and see all the others. Private and free.';
const intro =
  'Type a number and choose its base — the binary, octal, decimal and hexadecimal versions all update instantly.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'Which bases are supported?', a: 'Binary (base 2), octal (base 8), decimal (base 10) and hexadecimal (base 16) — the four most common in computing.' },
  { q: 'What is hexadecimal used for?', a: 'Hex is widely used in programming for colors (#ff0000), memory addresses and byte values, because each hex digit maps neatly to 4 binary bits.' },
  { q: 'Why is my input invalid?', a: 'Each base only allows certain digits — binary uses 0\u20131, octal 0\u20137, decimal 0\u20139, and hex 0\u20139 plus A\u2013F. Check your input matches the chosen base.' },
  { q: 'Is it private?', a: 'Yes, everything runs in your browser.' },
  { q: 'What is binary used for?', a: 'Binary is the native language of computers. Programmers use it for bitwise operations, flags in permission systems, and understanding how data is stored at the hardware level.' },
  { q: 'Can I convert values with decimal points?', a: 'This converter handles whole numbers only. For fractional values you\u2019ll need a specialised floating-point converter.' },
  { q: 'What does "0x" mean in hex?', a: 'In many programming languages, 0x is a prefix that indicates a hexadecimal number. For example, 0xFF is the same as 255 in decimal. The tool strips the prefix automatically.' },
  { q: 'What is the largest number I can convert?', a: 'JavaScript can safely represent integers up to 2^53 \u2013 1 (about 9 quadrillion). Numbers beyond this may lose precision in conversion.' },
  { q: 'Why does octal matter for file permissions?', a: 'Unix/Linux file permissions use octal notation (e.g., 755) because each digit maps directly to three permission bits (read, write, execute) for user, group, and others.' },
  { q: 'Can I convert negative numbers?', a: 'This converter handles positive integers only. Negative numbers typically use two\'s complement representation, which is not supported here.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="DeveloperApplication">
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-end">
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Value</span>
        <input id="value" type="text" placeholder="e.g. 255" class="mt-1 w-full rounded-xl border border-slate-300 p-3 text-base font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      </label>
      <label class="block">
        <span class="text-sm font-medium text-slate-700">Input base</span>
        <select id="base" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 sm:w-auto">
          <option value="2">Binary (2)</option>
          <option value="8">Octal (8)</option>
          <option value="10" selected>Decimal (10)</option>
          <option value="16">Hex (16)</option>
        </select>
      </label>
    </div>
    <p id="error" class="mt-2 hidden text-sm text-red-600"></p>

    <div class="mt-5 space-y-4">
      {[['Binary', 'bin'], ['Octal', 'oct'], ['Decimal', 'dec'], ['Hexadecimal', 'hex']].map(([label, id]) => (
        <div>
          <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">{label}</label>
          <div class="mt-1 flex gap-2">
            <input id={`out-${id}`} type="text" readonly class="min-w-0 flex-1 rounded-lg border border-slate-200 bg-slate-50 p-3 font-mono text-sm outline-none" />
            <button data-copy={`out-${id}`} class="copy shrink-0 rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Copy</button>
          </div>
        </div>
      ))}
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How number base conversion works</h2>
    <p class="mt-2 text-slate-600">Number base conversion relies on positional notation — each digit's value depends on its position and the base of the number system. The decimal number 2026 means 2×10³ + 0×10² + 2×10¹ + 6×10⁰.</p>
    <p class="mt-3 text-slate-600">To convert between bases, the tool first converts your input to a decimal integer using <span class="font-mono text-indigo-600">parseInt(value, base)</span>, then formats that integer into the target base using <span class="font-mono text-indigo-600">number.toString(base)</span>. Each output shows the same numeric value written in a different numeral system.</p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Converting the decimal number 2026 into binary, hex, and octal.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Decimal:</span> <span class="text-slate-600 font-mono">2026</span></div>
        <div><span class="font-medium text-slate-700">Binary:</span> <span class="text-slate-600 font-mono">11111101010</span></div>
        <div><span class="font-medium text-slate-700">Hexadecimal:</span> <span class="text-slate-600 font-mono">7EA</span></div>
        <div><span class="font-medium text-slate-700">Octal:</span> <span class="text-slate-600 font-mono">3752</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About number bases</h2>
    <p class="mt-2 text-slate-600">
      Computers work in binary, but programmers regularly switch between binary, octal, decimal and
      hexadecimal. This converter lets you type a value in any of those bases and instantly see it
      in all the others — handy for debugging, working with colors, bit masks or memory addresses.
      Pair it with the <a href="/tools/color-converter" class="font-medium text-indigo-600 hover:underline">Color Converter</a>
      to understand hex colour codes, or the <a href="/tools/timestamp-converter" class="font-medium text-indigo-600 hover:underline">Timestamp Converter</a>
      to work with epoch time values.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Select the base of the number you're entering.</li>
      <li>Type the value.</li>
      <li>Read the equivalents and copy any one you need.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Converting between number bases is a fundamental skill in programming and computer science. Developers use it when debugging memory addresses in hex, interpreting permission bits in octal for Linux file systems, or working with colour values in CSS. Students learning computer architecture convert between binary and hex to understand how data flows through a CPU. Network engineers calculate subnet masks in binary. Embedded systems programmers read register values directly in hex from datasheets and need quick conversions to decimal.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different number bases mean</h2>
    <p class="mt-2 text-slate-600">Each base has its own strengths and typical use cases. Here is how they compare in practical programming scenarios.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Decimal (base 10)</span><span class="text-slate-400">Human-readable, everyday counting, most intuitive</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:100%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Hexadecimal (base 16)</span><span class="text-slate-400">Compact byte representation, 1 hex digit = 4 bits</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:90%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Binary (base 2)</span><span class="text-slate-400">Native machine language, bitwise operations, flags</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-400" style="width:75%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Octal (base 8)</span><span class="text-slate-400">File permissions, legacy Unix, 1 octal digit = 3 bits</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-400" style="width:55%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4c8;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Software Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Converts hex memory addresses during debugging, interprets bit masks in embedded C, and works with colour values in front-end development.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f4f1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Network Engineer</h3>
      <p class="mt-1 text-sm text-slate-600">Calculates subnet masks and IP ranges using binary and decimal conversions for network configuration and troubleshooting.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1f393;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Computer Science Student</h3>
      <p class="mt-1 text-sm text-slate-600">Practises base conversions while studying computer architecture, digital logic, and low-level programming concepts.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x2699;&#xfe0f;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Embedded Systems Developer</h3>
      <p class="mt-1 text-sm text-slate-600">Reads hardware register values from datasheets in hex and converts them to decimal for configuration and interrupt handling.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Base</th><th class="p-3">Digits</th><th class="p-3">Common Use</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Binary (2)</td><td class="p-3 font-mono">0, 1</td><td class="p-3">Bitwise operations, flags, hardware registers</td></tr>
        <tr><td class="p-3 font-medium">Octal (8)</td><td class="p-3 font-mono">0–7</td><td class="p-3">Unix file permissions (755, 644), chmod</td></tr>
        <tr><td class="p-3 font-medium">Decimal (10)</td><td class="p-3 font-mono">0–9</td><td class="p-3">Everyday counting, user-facing numbers</td></tr>
        <tr><td class="p-3 font-medium">Hexadecimal (16)</td><td class="p-3 font-mono">0–9, A–F</td><td class="p-3">Colours (#FF5733), memory addresses, byte values</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the number base converter</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose input base</h3>
        <p class="mt-1 text-sm text-slate-600">Select the base your number is currently in — binary, octal, decimal, or hexadecimal.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Type your number</h3>
        <p class="mt-1 text-sm text-slate-600">Enter a valid value for the selected base. All four output fields update automatically as you type.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Copy the result</h3>
        <p class="mt-1 text-sm text-slate-600">Use the Copy button next to any output field to grab the converted value in your desired base.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for working with number bases</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Know your prefixes</h3>
        <p class="mt-1 text-sm text-slate-600">In code: <span class="font-mono">0b</span> for binary, <span class="font-mono">0o</span> for octal, <span class="font-mono">0x</span> for hex. The converter strips <span class="font-mono">0x</span> automatically, but most languages use these prefixes to distinguish number bases.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Think in groups for mental conversion</h3>
        <p class="mt-1 text-sm text-slate-600">Each hex digit represents 4 binary bits. Group binary digits into sets of 4 to mentally convert between binary and hex. For octal, group into 3-bit sets.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Validate your input first</h3>
        <p class="mt-1 text-sm text-slate-600">If you see a red error message, check that your input only contains digits valid for the selected base — binary allows only 0 and 1, hex allows 0–9 and A–F.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const value = el('value'), base = el('base'), error = el('error');
    const valid = { 2: /^[01]+$/, 8: /^[0-7]+$/, 10: /^[0-9]+$/, 16: /^[0-9a-fA-F]+$/ };

    function update() {
      const raw = value.value.trim().replace(/^0x/i, '');
      if (!raw) { ['bin', 'oct', 'dec', 'hex'].forEach((id) => (el('out-' + id).value = '')); error.classList.add('hidden'); return; }
      const b = parseInt(base.value, 10);
      if (!valid[b].test(raw)) {
        error.textContent = `Not a valid base-${b} number.`;
        error.classList.remove('hidden');
        return;
      }
      error.classList.add('hidden');
      const n = parseInt(raw, b);
      el('out-bin').value = n.toString(2);
      el('out-oct').value = n.toString(8);
      el('out-dec').value = n.toString(10);
      el('out-hex').value = n.toString(16).toUpperCase();
    }

    [value, base].forEach((e) => e.addEventListener('input', update));
    document.querySelectorAll('.copy').forEach((btn) => btn.addEventListener('click', async () => {
      const v = el(btn.dataset.copy).value;
      if (!v) return;
      try { await navigator.clipboard.writeText(v); const o = btn.textContent; btn.textContent = '✓'; setTimeout(() => (btn.textContent = o), 1000); } catch (e) {}
    }));
  </script>
</ToolLayout>
