---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Miles to Km"
  emoji="📏"
  fromUnit="miles" toUnit="kilometers"
  fromTitle="Miles" toTitle="Kilometers"
  fromSym="mi" toSym="km"
  quantity="length"
  kind="factor" factor={1.609344}
  reverseSlug="km-to-miles" reverseLabel="Km to Miles Converter"
  hasReverse={true}
  related={[{"slug":"length-converter","label":"Length Converter"}]}
  useCase="Convert a distance in miles into kilometers for maps, fitness apps and international travel."
/>
