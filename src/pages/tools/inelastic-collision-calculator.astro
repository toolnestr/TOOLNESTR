---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Inelastic Collision Calculator';
const description = 'Perfectly inelastic collision calculator with a live 3D two-body scene and charts. Solve the combined final velocity v\' = (m1u1 + m2u2)/(m1+m2) and see exactly how much kinetic energy is lost.';
const intro = 'Enter two masses and their initial velocities to find the shared final velocity after they collide and stick together (a perfectly inelastic collision). A live 3D scene shows the objects merge into one, and charts show the kinetic energy lost to heat, sound and deformation.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is a perfectly inelastic collision?', a: 'A perfectly inelastic collision is one where the two objects stick together after impact and move with a single common final velocity. Momentum is still conserved, but kinetic energy is not — some is converted to heat, sound and permanent deformation.' },
  { q: 'What is the formula for the final velocity?', a: "For masses m1 and m2 with initial velocities u1 and u2 colliding and sticking together, v' = (m1u1 + m2u2) / (m1+m2). This comes directly from conservation of momentum: m1u1 + m2u2 = (m1+m2)v'." },
  { q: 'How much kinetic energy is lost in an inelastic collision?', a: "KE lost = KE_before − KE_after = [½m1u1² + ½m2u2²] − ½(m1+m2)v'². For a perfectly inelastic collision this loss is the maximum possible while still conserving momentum — no other outcome loses more kinetic energy." },
  { q: 'Is momentum conserved in an inelastic collision?', a: 'Yes. Momentum conservation holds for any closed collision, elastic or not, because it follows from Newton\'s third law alone. Only kinetic energy conservation is special to the elastic case.' },
  { q: 'What are real examples of perfectly inelastic collisions?', a: 'A bullet embedding in a wooden block, two train cars coupling together, a football tackle where players end up moving as one, or a ball of wet clay hitting the floor and sticking — anywhere two objects end up moving with a single shared velocity.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Inelastic Collision Calculator',
  description: "Calculate the shared final velocity of two masses that collide and stick together, using v' = (m1u1 + m2u2)/(m1+m2), and the kinetic energy lost.",
  steps: [
    { name: 'Enter both masses', text: 'Type m1 and m2 in kilograms (or any consistent mass unit).' },
    { name: 'Enter both initial velocities', text: 'Type u1 and u2 in m/s. Use negative values for objects moving in the opposite direction.' },
    { name: 'Read the results', text: "The shared final velocity v' solves instantly, along with the kinetic energy lost and a live 3D collision." },
  ],
};

const formulas = [
  { expr: "v' = (m1·u1 + m2·u2) / (m1+m2)", note: 'shared final velocity (objects stick together)' },
  { expr: 'p_before = p_after', note: 'momentum is conserved' },
  { expr: "KE lost = KE_before − ½(m1+m2)v'²", note: 'kinetic energy is NOT conserved' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — bullet embeds in a block', tone: 'slate',
    given: 'A 0.010 kg bullet moving at 400 m/s embeds in a stationary 2.0 kg wooden block. Find the final velocity and the kinetic energy lost.',
    rows: [
      { label: "Final velocity:", value: "v' = (0.010×400 + 2.0×0) / (0.010+2.0) = 4 / 2.01 ≈ 1.99 m/s" },
      { label: 'KE before:', value: '½(0.010)(400²) = 800 J' },
      { label: 'KE after:', value: '½(2.01)(1.99²) ≈ 3.98 J' },
      { label: 'KE lost:', value: '800 − 3.98 ≈ 796 J (about 99.5% lost to heat, sound and deformation)', full: true },
    ],
  },
  {
    title: 'Worked example 2 — train cars coupling', tone: 'amber',
    given: 'A 20,000 kg train car moving at 3.0 m/s couples with a stationary 15,000 kg car. Find the combined final velocity.',
    rows: [
      { label: "Final velocity:", value: "v' = (20000×3 + 15000×0) / 35000 = 60000/35000 ≈ 1.71 m/s" },
      { label: 'KE before:', value: '½(20000)(3²) = 90,000 J' },
      { label: 'KE after:', value: '½(35000)(1.71²) ≈ 51,300 J' },
      { label: 'KE lost:', value: '90,000 − 51,300 ≈ 38,700 J, absorbed by the couplers as heat and deformation', full: true },
    ],
  },
];

const comparison = {
  heading: 'Elastic vs inelastic vs perfectly inelastic collisions',
  note: 'All three conserve momentum. What changes is kinetic energy and whether the objects stick together.',
  headers: [{ label: 'Collision type' }, { label: 'Momentum' }, { label: 'Kinetic energy' }, { label: 'After collision' }],
  rows: [
    ['Elastic', 'Conserved', 'Conserved', 'Objects separate, bounce apart'],
    ['Inelastic (general)', 'Conserved', 'Some KE lost to heat/sound/deformation', 'Objects separate, may deform'],
    ['Perfectly inelastic', 'Conserved', 'Maximum KE lost (but not necessarily all)', 'Objects stick together, move as one'],
  ],
  highlightIndex: 2,
  footnote: 'Momentum conservation holds for every closed collision — a perfectly inelastic collision loses the most kinetic energy possible while still conserving momentum.',
};

const realWorld = [
  { emoji: '🚗', title: 'Car crash analysis', body: 'When vehicles crumple together in a crash, accident investigators often model the impact as perfectly inelastic to estimate impact speeds from the wreckage — momentum conservation gives a lower bound on how fast the vehicles were moving.' },
  { emoji: '🚂', title: 'Train and freight coupling', body: 'Rail cars are designed to couple and move together after impact — an intentionally inelastic collision. The kinetic energy "lost" is absorbed by couplers and buffers so it does not damage the cargo or cars.' },
  { emoji: '🏈', title: 'Tackles and impacts in sport', body: 'A football tackle where two players end up moving together is a real-world perfectly inelastic collision. The kinetic energy lost is why such impacts feel much harder than a glancing, more elastic collision.' },
];

const misconceptions = [
  { claim: '"Inelastic collisions don\'t conserve anything."', truth: 'Momentum is still conserved — it is conserved in every closed collision regardless of type. Only kinetic energy fails to be conserved in an inelastic collision.' },
  { claim: '"Perfectly inelastic means all kinetic energy is lost."', truth: 'Not necessarily all — just the maximum amount possible while momentum is still conserved. If both objects end up at rest (e.g. equal and opposite momenta), then yes, all KE is lost; otherwise, some kinetic energy typically remains in the combined motion.' },
  { claim: '"Objects only stick together if they are sticky or soft."', truth: 'Stickiness is one way to get a perfectly inelastic collision, but any mechanism that leaves both objects with the same final velocity qualifies — a latching coupler, a tackle, or a bullet embedding in wood all count.' },
  { claim: '"The heavier object always ends up moving faster."', truth: 'The combined velocity is a mass-weighted average of the initial velocities — it depends on both masses and both velocities together, not on which object is heavier alone.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — §9.4 "Types of Collisions" (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/9-4-types-of-collisions" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter 9, Center of Mass and Linear Momentum, perfectly inelastic collisions.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Chapter 9, Linear Momentum and Collisions.' },
];
const sourcesNote = 'Formulas assume a 1D (head-on) collision with no external forces, and that the objects merge into one body. Results are rounded for display.';

const howToUse = [
  { title: 'Enter the masses', body: 'Type m1 and m2 — any consistent mass unit works since it cancels in the ratio.' },
  { title: 'Enter the velocities', body: 'Type u1 and u2 in m/s; use negative signs for objects approaching from opposite directions.' },
  { title: 'Check the energy loss', body: "Read the shared final velocity v', then see exactly how much kinetic energy was lost to heat, sound and deformation." },
];

const related = [
  { href: '/tools/elastic-collision-calculator', emoji: '🎱', title: 'Elastic Collision Calculator', desc: 'Momentum and kinetic energy both conserved.' },
  { href: '/tools/momentum-calculator', emoji: '🎯', title: 'Momentum & Impulse Calculator', desc: 'p = mv and the impulse–momentum theorem.' },
  { href: '/tools/force-calculator', emoji: '💥', title: 'Force Calculator', desc: 'F = ma — solve for any variable.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="in a perfectly inelastic collision the objects stick together, so momentum conservation alone determines the single shared final velocity — kinetic energy is not conserved."
  howIntro="Because the objects share one final velocity, momentum conservation m1u1 + m2u2 = (m1+m2)v' has only one unknown, making it the simplest collision to solve. The kinetic energy that vanishes — always the largest possible loss consistent with momentum conservation — goes into heat, sound and permanent deformation, which is exactly what car crumple zones and packaging are designed to absorb safely."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where inelastic collisions actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass 1 (m1)</span>
        <input id="m1" type="number" step="any" placeholder="kg" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Mass 2 (m2)</span>
        <input id="m2" type="number" step="any" placeholder="kg" value="1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial velocity 1 (u1)</span>
        <input id="u1" type="number" step="any" placeholder="m/s" value="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial velocity 2 (u2)</span>
        <input id="u2" type="number" step="any" placeholder="m/s" value="0" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-1">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Combined final velocity (v')</div><div id="r-v" class="mt-1 text-2xl font-bold">—</div></div>
    </div>
    <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">KE before</div><div id="r-keb" class="mt-1 text-lg font-semibold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">KE after</div><div id="r-kea" class="mt-1 text-lg font-semibold text-slate-800">—</div></div>
      <div class="rounded-xl bg-red-50 p-4 text-center"><div class="text-sm text-red-500">KE lost</div><div id="r-kel" class="mt-1 text-lg font-semibold text-red-700">—</div></div>
    </div>
    <p id="ic-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D collision + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D inelastic collision</h2>
      <p class="mt-1 text-sm text-slate-500">Sphere size reflects relative mass. Drag the sliders to change mass 1 and initial velocity 1; the spheres approach, collide and merge into one combined body moving at v'. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Mass 1 <span id="out-bm1" class="font-mono text-indigo-600">2.0 kg</span></span>
          <input id="b-m1" type="range" min="0.5" max="10" step="0.1" value="2" class="mt-2 w-full accent-indigo-600" />
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Initial velocity 1 <span id="out-bu1" class="font-mono text-indigo-600">5.0 m/s</span></span>
          <input id="b-u1" type="range" min="0.5" max="10" step="0.1" value="5" class="mt-2 w-full accent-indigo-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-indigo-50 p-3 text-center text-sm text-indigo-700">Combined v' = <span id="out-bvp" class="font-mono font-bold">—</span> &nbsp;|&nbsp; KE lost = <span id="out-bkel" class="font-mono font-bold">—</span></div>
      <div id="collision3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="collision3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Collision graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Velocity before vs combined after (mass 2 stationary at start)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-vel"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Kinetic energy lost vs mass ratio m2/m1 (fixed u1, u2=0)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-kel"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

      function solveInelastic(m1, m2, u1, u2) {
        const v = (m1 * u1 + m2 * u2) / (m1 + m2);
        const keBefore = 0.5 * m1 * u1 * u1 + 0.5 * m2 * u2 * u2;
        const keAfter = 0.5 * (m1 + m2) * v * v;
        return { v, keBefore, keAfter, keLost: keBefore - keAfter };
      }

      // ---- calculator ----
      function update() {
        el('ic-err').textContent = '';
        ['r-v', 'r-keb', 'r-kea', 'r-kel'].forEach((id) => (el(id).textContent = '—'));
        const m1 = parseFloat(el('m1').value), m2 = parseFloat(el('m2').value);
        const u1 = parseFloat(el('u1').value), u2 = parseFloat(el('u2').value);
        if ([m1, m2, u1, u2].some((x) => isNaN(x))) return;
        if (m1 <= 0 || m2 <= 0) { el('ic-err').textContent = 'Masses must be positive.'; return; }
        const { v, keBefore, keAfter, keLost } = solveInelastic(m1, m2, u1, u2);
        el('r-v').textContent = fmt(v) + ' m/s';
        el('r-keb').textContent = fmt(keBefore) + ' J';
        el('r-kea').textContent = fmt(keAfter) + ' J';
        el('r-kel').textContent = fmt(keLost) + ' J';
      }
      ['m1', 'm2', 'u1', 'u2'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let scene3d = null;
      function bState() {
        const m1 = parseFloat(el('b-m1').value), m2 = 2;
        const u1 = parseFloat(el('b-u1').value), u2 = 0;
        const r = solveInelastic(m1, m2, u1, u2);
        return { m1, m2, u1, u2, v: r.v, keBefore: r.keBefore, keAfter: r.keAfter, keLost: r.keLost };
      }
      function onB() {
        const s = bState();
        el('out-bm1').textContent = s.m1.toFixed(1) + ' kg';
        el('out-bu1').textContent = s.u1.toFixed(1) + ' m/s';
        el('out-bvp').textContent = fmt(s.v) + ' m/s';
        el('out-bkel').textContent = fmt(s.keLost) + ' J';
        try { if (scene3d) scene3d.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-m1').addEventListener('input', onB);
      el('b-u1').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.vel = new Chart(el('chart-vel'), {
          type: 'bar',
          data: { labels: ['Object 1 (before)', 'Object 2 (before)', 'Combined (after)'], datasets: [
            { label: 'Velocity (m/s)', data: [0, 0, 0], backgroundColor: ['#94a3b8', '#94a3b8', '#6366f1'] },
          ] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Velocity (m/s)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.kel = new Chart(el('chart-kel'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'KE lost (J)', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Mass ratio m2/m1' } }, y: { title: { display: true, text: 'KE lost (J)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        charts.vel.data.datasets[0].data = [+s.u1.toFixed(3), +s.u2.toFixed(3), +s.v.toFixed(3)];
        charts.vel.update();
        const L = [], D = [];
        for (let ratio = 0; ratio <= 5.001; ratio += 0.25) {
          const m2 = s.m1 * ratio;
          const r = solveInelastic(s.m1, m2 || 0.0001, s.u1, 0);
          L.push(ratio.toFixed(2)); D.push(+r.keLost.toFixed(3));
        }
        charts.kel.data.labels = L; charts.kel.data.datasets[0].data = D; charts.kel.update();
      }

      // ---- interactive 3D collision ----
      function initScene3d() {
        const c = el('collision3d'); if (!c) throw new Error('no container');
        const s = makeScene(c, 14, new THREE.Vector3(0, 0.5, 0), OPTS);
        s.scene.add(new THREE.GridHelper(20, 20, 0xcbd5e1, 0xe2e8f0));
        const mat1 = new THREE.MeshStandardMaterial({ color: 0x6366f1 });
        const mat2 = new THREE.MeshStandardMaterial({ color: 0xef4444 });
        const matCombined = new THREE.MeshStandardMaterial({ color: 0x10b981 });
        let sph1 = null, sph2 = null, merged = null;
        let t = 0, cur = bState();
        function radius(m) { return Math.max(0.4, Math.cbrt(m) * 0.6); }
        function build() {
          if (sph1) { s.scene.remove(sph1); sph1.geometry.dispose(); }
          if (sph2) { s.scene.remove(sph2); sph2.geometry.dispose(); }
          if (merged) { s.scene.remove(merged); merged.geometry.dispose(); merged = null; }
          sph1 = new THREE.Mesh(new THREE.SphereGeometry(radius(cur.m1), 24, 24), mat1);
          sph2 = new THREE.Mesh(new THREE.SphereGeometry(radius(cur.m2), 24, 24), mat2);
          s.scene.add(sph1); s.scene.add(sph2);
        }
        function update(state) { cur = state; build(); t = 0; }
        function frame() {
          requestAnimationFrame(frame);
          if (!reduceMotion) {
            t += 0.012;
            const ph = t % 3;
            const r1 = radius(cur.m1), r2 = radius(cur.m2);
            const contact = r1 + r2;
            const startX1 = -8, startX2 = 6;
            const collideX = startX2 - contact;
            if (ph < 1.4) {
              const frac = ph / 1.4;
              if (sph1 && sph2) {
                sph1.visible = true; sph2.visible = true; if (merged) merged.visible = false;
                sph1.position.set(startX1 + frac * (collideX - startX1), r1, 0);
                sph2.position.set(startX2, r2, 0);
              }
            } else {
              // merged phase: build combined sphere once, move together at v'
              if (sph1) sph1.visible = false;
              if (sph2) sph2.visible = false;
              const rMerged = Math.max(0.5, Math.cbrt(cur.m1 + cur.m2) * 0.6);
              if (!merged) {
                merged = new THREE.Mesh(new THREE.SphereGeometry(rMerged, 24, 24), matCombined);
                s.scene.add(merged);
              }
              merged.visible = true;
              const frac = (ph - 1.4) / 1.6;
              const dir = cur.v >= 0 ? 1 : -1;
              merged.position.set(collideX + dir * frac * Math.min(9, Math.abs(cur.v) * 0.9), rMerged, 0);
            }
            s.spin(0.0012);
          }
          s.renderer.render(s.scene, s.camera);
        }
        frame();
        scene3d = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { update(); } catch (e) { console.error('[inelastic-collision] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[inelastic-collision] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[inelastic-collision] charts failed', e); }
        if (window.THREE) {
          try { initScene3d(); } catch (e) { console.error('[inelastic-collision] 3D failed', e); el('collision3d-fallback').classList.remove('hidden'); }
        } else { el('collision3d-fallback').classList.remove('hidden'); }
        mountResize([scene3d]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
