---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Microbial Growth Curve Plotter';
const description = "Microbial growth curve plotter. Model the four classic bacterial growth phases — lag, log, stationary, and death — from your own parameters.";
const intro = 'Plot the classic four-phase bacterial growth curve — lag, log (exponential), stationary, and death — from a starting population, lag duration, growth rate, carrying capacity, and death rate. Two 3D diagrams compare the lag phase (adapting, not yet dividing) to the log phase (rapid division), and charts trace population size through all four phases over time.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What are the four phases of bacterial growth?', a: 'Lag phase (cells adapt to the new environment, little growth), log/exponential phase (rapid, constant-rate division), stationary phase (growth stalls as resources deplete and waste accumulates), and death phase (cells die faster than new ones form).' },
  { q: 'Why does the lag phase happen at all?', a: 'Cells transferred to a new environment need time to synthesize the enzymes and cellular machinery required for growth in that specific environment before they can begin dividing rapidly — this adaptation period is the lag phase.' },
  { q: 'What ends the log phase and starts the stationary phase?', a: 'As nutrients become depleted and metabolic waste products accumulate, cells can no longer sustain their maximum division rate — growth slows and eventually plateaus as the birth rate equals the death rate, defining the stationary phase.' },
  { q: 'Is the stationary phase population size the same as the environment\'s carrying capacity?', a: "Yes — the stationary phase population level is set by the environment's carrying capacity, the maximum population that available nutrients, space, and waste tolerance can support." },
  { q: 'Why does the death phase happen?', a: "Once nutrients are exhausted and toxic waste products build up further, the death rate exceeds any remaining reproduction rate, and the population size declines — often itself following an exponential decay pattern, just like the log phase's growth in reverse." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Microbial Growth Curve Plotter',
  description: 'Model all four phases of bacterial growth from your own starting population, growth rate, and carrying capacity.',
  steps: [
    { name: 'Enter starting parameters', text: 'Initial population, lag duration, log-phase growth rate, and carrying capacity.' },
    { name: 'Enter stationary and death phase parameters', text: 'How long the stationary phase lasts, and the death rate afterward.' },
    { name: 'Read the phase transition times', text: 'The exact time each phase begins and ends is calculated and plotted automatically.' },
  ],
};

const formulas = [
  { expr: 'Lag phase: N(t) = N0', note: 'population stays flat while cells adapt, for 0 ≤ t < t_lag' },
  { expr: 'Log phase: N(t) = N0·e^(k(t−t_lag))', note: 'exponential growth until reaching carrying capacity K' },
  { expr: 'Stationary phase: N(t) = K', note: 'population plateaus at the carrying capacity' },
  { expr: 'Death phase: N(t) = K·e^(−kd(t−t_death))', note: 'exponential decline once nutrients are exhausted' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — finding the log phase duration', tone: 'slate',
    given: 'N0 = 1,000 cells, growth rate k = 0.693 per hour (≈1 hour doubling time), carrying capacity K = 1,024,000 cells (exactly 1,000 × 2¹⁰).',
    rows: [
      { label: 'Formula:', value: 'Log phase duration = ln(K/N0) / k' },
      { label: 'Substitute:', value: 'ln(1,024,000/1,000) / 0.693 = ln(1024) / 0.693' },
      { label: 'Result:', value: 'Log phase duration = 10 hours (10 doublings of 1 hour each)', full: true },
    ],
    note: 'Choosing K as an exact power-of-2 multiple of N0 makes this example land on a clean 10-hour log phase — real cultures rarely divide such round numbers of times, but the math works identically either way.',
  },
  {
    title: 'Worked example 2 — the full four-phase timeline', tone: 'amber',
    given: 'Using the same culture: lag phase = 2 hours, log phase = 10 hours (from example 1), stationary phase = 3 hours, then death phase begins with kd = 0.35 per hour.',
    rows: [
      { label: 'Phase timeline:', value: 'Lag: 0-2h. Log: 2-12h. Stationary: 12-15h. Death: 15h onward.' },
      { label: 'Population at t=20h (5h into death phase):', value: 'N = 1,024,000 × e^(−0.35×5) ≈ 178,000 cells' },
      { label: 'Interpretation:', value: 'By hour 20, the population has fallen to about 17% of its peak stationary-phase size', full: true },
    ],
    note: 'Death phase decline follows the same exponential math as growth, just with population shrinking instead of expanding — a useful reminder that "exponential" describes the mathematical pattern, not automatically growth.',
  },
];

const comparison = {
  heading: 'The four phases at a glance',
  note: 'Each phase reflects a different balance between cell division and cell death.',
  headers: [{ label: 'Phase' }, { label: 'What\'s happening' }, { label: 'Population trend' }],
  rows: [
    ['Lag', 'Cells adapting, synthesizing enzymes', 'Flat'],
    ['Log (exponential) ★', 'Rapid, constant-rate division', 'Exponential increase'],
    ['Stationary', 'Birth rate ≈ death rate, resources limiting', 'Flat (plateau)'],
    ['Death', 'Death rate exceeds birth rate', 'Exponential decrease'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). The log phase is the only period where the growth rate constant k directly and predictably drives population change — the other three phases each reflect a different limiting factor taking over.',
};

const realWorld = [
  { emoji: '🏭', title: 'Fermentation batch timing', body: "Industrial fermentation processes are timed to harvest cells or products at the optimal phase — often late log or early stationary phase, depending on whether the target product accumulates during growth or afterward." },
  { emoji: '💊', title: 'Antibiotic testing timing', body: 'Antibiotic susceptibility testing is standardized to use log-phase cultures specifically, since actively dividing cells respond most predictably and consistently to antibiotic exposure.' },
  { emoji: '🧫', title: 'Food spoilage and preservation', body: 'Understanding the full growth curve — including how long lag phase delays spoilage — informs food preservation techniques and shelf-life predictions for perishable products.' },
  { emoji: '🔬', title: 'Microbiology education and research', body: "The four-phase growth curve is one of the most fundamental concepts in microbiology, taught as the foundation for understanding how any closed microbial population behaves over time." },
];

const misconceptions = [
  { claim: '"Bacteria don\'t grow at all during the lag phase."', truth: 'Cells are metabolically very active during lag phase, synthesizing new enzymes, RNA, and cellular machinery needed for growth in the new environment — they simply aren\'t yet dividing at a measurable rate.' },
  { claim: '"The stationary phase means all the bacteria have stopped dividing."', truth: "Cells are often still dividing during stationary phase — but at almost exactly the same rate that other cells are dying, so the net population size stays roughly constant even though individual cell turnover continues." },
  { claim: '"Every bacterial culture eventually enters a death phase."', truth: 'In a continuously fed environment (like a chemostat, or a natural ecosystem with ongoing nutrient input), a population can remain in a growth-death balance indefinitely without ever entering a true death phase — the classic four-phase curve specifically describes a closed batch culture with finite, non-renewed resources.' },
  { claim: '"The growth curve looks the same for every bacterial species and every environment."', truth: 'The duration and steepness of each phase varies enormously depending on species, temperature, nutrient availability, and starting population — the four-phase shape is a general pattern, not a fixed, universal timeline.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Microbiology</em></strong> — Chapter 9, "Microbial Growth" (free, peer-reviewed). <a href="https://openstax.org/books/microbiology/pages/9-1-how-microbes-grow" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Madigan et al., <em>Brock Biology of Microorganisms</em></strong> — The bacterial growth curve chapter.' },
  { html: '<strong>Monod (1949)</strong> — foundational bacterial growth curve research, <em>Annual Review of Microbiology</em>.' },
];
const sourcesNote = 'Log phase: N=N0·e^(k(t−t_lag)); death phase: N=K·e^(−kd(t−t_death)). A simplified model — real growth curves can deviate from perfectly exponential math in each phase.';

const howToUse = [
  { title: 'Enter starting parameters', body: 'Initial population, lag duration, log-phase growth rate, and carrying capacity.' },
  { title: 'Enter later-phase parameters', body: 'Stationary phase duration and the death-phase decline rate.' },
  { title: 'Read the full curve', body: 'All four phase transition times and the resulting growth curve plot automatically.' },
];

const related = [
  { href: '/tools/bacterial-growth-rate-calculator', emoji: '⏱️', title: 'Bacterial Growth Rate Calculator', desc: 'k = ln(Nt/N0)/t — exponential growth rate constant.' },
  { href: '/tools/generation-time-calculator', emoji: '🧮', title: 'Generation (Doubling) Time Calculator', desc: 'g = t/n — average generation time from population counts.' },
  { href: '/tools/logistic-growth-calculator', emoji: '📊', title: 'Logistic Growth / Carrying Capacity Calculator', desc: 'Population growth limited by a carrying capacity.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a bacterial population's entire life story in a closed environment is written in just four acts — adapt, multiply freely, plateau against limits, then decline — and each act follows its own simple, predictable mathematical rule."
  howIntro="A batch bacterial culture moves through four distinct phases as its environment changes under it. During lag phase, cells synthesize what they need to grow but don't yet divide measurably. Once ready, they enter log phase, dividing at a constant exponential rate until nutrients start running low. As growth slows to match the death rate, the population plateaus at the environment's carrying capacity during stationary phase. Finally, once nutrients are exhausted and waste has accumulated further, cells die faster than new ones form, and the population declines through an exponential death phase — the same exponential math as growth, just running in reverse."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where the microbial growth curve actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial population (N0)</span>
        <input id="n0" type="number" step="any" value="1000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Lag phase duration (hr)</span>
        <input id="tlag" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Log-phase growth rate, k (/hr)</span>
        <input id="k" type="number" step="any" value="0.693" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Carrying capacity (K)</span>
        <input id="k-cap" type="number" step="any" value="1024000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Stationary phase duration (hr)</span>
        <input id="tstat" type="number" step="any" value="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Death-phase rate, kd (/hr)</span>
        <input id="kd" type="number" step="any" value="0.35" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Log phase starts</div><div id="r-t1" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Stationary starts</div><div id="r-t2" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Death phase starts</div><div id="r-t3" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-3 text-center text-white"><div class="text-xs opacity-80">Log phase duration</div><div id="r-logdur" class="mt-1 text-lg font-bold">—</div></div>
    </div>
    <p id="mg-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Lag phase vs. log phase</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-lag" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Lag phase</h3>
          <p class="mt-1 text-sm text-slate-600">Cells present but not yet dividing — adapting to the environment.</p>
        </div>
        <div>
          <div id="diag-log" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Log phase</h3>
          <p class="mt-1 text-sm text-slate-600">Rapid, constant-rate division — the population is doubling repeatedly.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">The full growth curve</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Population vs. time (log scale) — all four phases</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:280px;"><canvas id="chart-curve"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Phase duration breakdown (hours)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:280px;"><canvas id="chart-phases"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      let charts = {};

      function population(t, p) {
        const { n0, tlag, k, kcap, tlogEnd, tstatEnd, kd } = p;
        if (t < tlag) return n0;
        if (t < tlogEnd) return n0 * Math.exp(k * (t - tlag));
        if (t < tstatEnd) return kcap;
        return kcap * Math.exp(-kd * (t - tstatEnd));
      }

      function update() {
        el('mg-err').textContent = '';
        ['r-t1', 'r-t2', 'r-t3', 'r-logdur'].forEach((id) => el(id).textContent = '—');
        const n0 = parseFloat(el('n0').value), tlag = parseFloat(el('tlag').value), k = parseFloat(el('k').value);
        const kcap = parseFloat(el('k-cap').value), tstat = parseFloat(el('tstat').value), kd = parseFloat(el('kd').value);
        if ([n0, tlag, k, kcap, tstat, kd].some(isNaN)) return;
        if (n0 <= 0 || kcap <= n0 || k <= 0 || tlag < 0 || tstat < 0 || kd < 0) { el('mg-err').textContent = 'Carrying capacity must exceed initial population; growth rate must be positive; durations cannot be negative.'; return; }
        const logDur = Math.log(kcap / n0) / k;
        const tlogEnd = tlag + logDur;
        const tstatEnd = tlogEnd + tstat;
        el('r-t1').textContent = fmt(tlag) + ' hr';
        el('r-t2').textContent = fmt(tlogEnd) + ' hr';
        el('r-t3').textContent = fmt(tstatEnd) + ' hr';
        el('r-logdur').textContent = fmt(logDur) + ' hr';
        updateCurve({ n0, tlag, k, kcap, tlogEnd, tstatEnd, kd });
      }
      ['n0', 'tlag', 'k', 'k-cap', 'tstat', 'kd'].forEach((id) => el(id).addEventListener('input', update));

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.curve = new Chart(el('chart-curve'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'Population', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.1)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time (hours)' } }, y: { type: 'logarithmic', title: { display: true, text: 'Population (log scale)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.phases = new Chart(el('chart-phases'), {
          type: 'bar',
          data: { labels: ['Lag', 'Log', 'Stationary', 'Death (shown)'], datasets: [{ label: 'Duration (hr)', data: [2, 10, 3, 5], backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { indexAxis: 'y', scales: { x: { title: { display: true, text: 'Duration (hours)' } } }, plugins: { legend: { display: false } } }),
        });
      }
      function updateCurve(p) {
        if (!charts.curve) return;
        const totalTime = p.tstatEnd + Math.max(8, p.tlag + 4);
        const labels = [], data = [];
        const steps = 40;
        for (let i = 0; i <= steps; i++) {
          const t = (totalTime * i) / steps;
          labels.push(t.toFixed(1));
          data.push(+population(t, p).toPrecision(4));
        }
        charts.curve.data.labels = labels;
        charts.curve.data.datasets[0].data = data;
        charts.curve.update('none');
        charts.phases.data.datasets[0].data = [p.tlag, p.tlogEnd - p.tlag, p.tstatEnd - p.tlogEnd, Math.max(4, totalTime - p.tstatEnd)];
        charts.phases.update('none');
      }

      function phaseScene(container, count, spread) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < count; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.2, 10, 8), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          m.position.set((Math.random() - 0.5) * spread, (Math.random() - 0.5) * spread * 0.7, (Math.random() - 0.5) * spread * 0.7);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagLag = null, diagLog = null;
      function initDiagLag() { const c = el('diag-lag'); if (!c) throw new Error('no container'); diagLag = phaseScene(c, 6, 3); }
      function initDiagLog() { const c = el('diag-log'); if (!c) throw new Error('no container'); diagLog = phaseScene(c, 45, 5); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[microbial-growth-curve] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagLag(); } catch (e) { console.error('[microbial-growth-curve] lag diagram failed', e); }
          try { initDiagLog(); } catch (e) { console.error('[microbial-growth-curve] log diagram failed', e); }
        }
        mountResize([diagLag, diagLog]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
