  <!-- Libraries: Three.js + Chart.js + shared subject kit (window.STK) -->
  <SubjectToolLibs />

  <script is:inline>
  (function () {
    'use strict';
    const { el, reduceMotion, fmt2: fmt, makeScene, arrow, mountResize, chartSetup } = window.STK;

    // ---- unit system ----
    const FT = 3.28084;
    let imperial = false;
    const units = () => imperial
      ? { vel: 'ft/s', len: 'ft', acc: 'ft/s²', g: 32.174 }
      : { vel: 'm/s', len: 'm', acc: 'm/s²', g: 9.81 };

    // ---- read inputs, keeping slider + number box in sync ----
    function readVal(sliderId, numId) {
      const s = el(sliderId), n = el(numId);
      let v = parseFloat(n.value);
      if (isNaN(v)) v = parseFloat(s.value);
      return v;
    }

    // ---- pure physics (units-agnostic; g just has to match) ----
    function solve(v0, angDeg, h0, g) {
      const rad = angDeg * Math.PI / 180;
      const vx = v0 * Math.cos(rad);
      const vy = v0 * Math.sin(rad);
      const disc = vy * vy + 2 * g * h0;
      if (v0 <= 0 || g <= 0) return { err: 'Speed and gravity must be greater than zero.' };
      if (disc < 0) return { err: "That combination isn't physically possible — try a smaller drop." };
      const t = (vy + Math.sqrt(disc)) / g;
      const range = vx * t;
      const hMax = h0 + (vy > 0 ? vy * vy / (2 * g) : 0);
      const vImp = Math.sqrt(vx * vx + Math.pow(vy - g * t, 2));
      return { vx, vy, t, range, hMax, vImp };
    }

    // ================= CALCULATOR (works with zero dependencies) =================
    let last = null;
    const charts = {};
    let scene3d = null, diagV = null, diagF = null;

    function updateAll() {
      const u = units();
      const v0 = readVal('speed', 'speed-n');
      const ang = Math.min(90, Math.max(0, readVal('angle', 'angle-n')));
      const h0 = Math.max(0, readVal('height', 'height-n'));
      const g = readVal('grav', 'grav');

      // live value labels
      el('out-speed').innerHTML = fmt(v0) + ' <span class="u-vel">' + u.vel + '</span>';
      el('out-angle').textContent = fmt(ang) + '°';
      el('out-height').innerHTML = fmt(h0) + ' <span class="u-len">' + u.len + '</span>';
      el('out-grav').innerHTML = fmt(g) + ' <span class="u-acc">' + u.acc + '</span>';

      const r = solve(v0, ang, h0, g);
      const errEl = el('proj-err');
      if (r.err) {
        errEl.textContent = r.err;
        ['r-range', 'r-hmax', 'r-time', 'r-imp'].forEach((id) => (el(id).textContent = '—'));
        return;
      }
      errEl.textContent = '';
      el('r-range').textContent = fmt(r.range) + ' ' + u.len;
      el('r-hmax').textContent = fmt(r.hMax) + ' ' + u.len;
      el('r-time').textContent = fmt(r.t) + ' s';
      el('r-imp').textContent = fmt(r.vImp) + ' ' + u.vel;
      last = { v0, ang, h0, g, r };

      try { if (charts.ready) updateCharts(); } catch (e) { /* charts optional */ }
      try { if (scene3d) scene3d.setTrajectory(); } catch (e) { /* 3d optional */ }
      syncUrl();
    }

    function syncUrl() {
      if (!last) return;
      const p = new URLSearchParams({ v: last.v0, a: last.ang, h: last.h0, g: last.g, u: imperial ? 'i' : 'm' });
      history.replaceState(null, '', '?' + p.toString());
    }

    // slider <-> number sync
    [['speed', 'speed-n'], ['angle', 'angle-n'], ['height', 'height-n']].forEach(([s, n]) => {
      el(s).addEventListener('input', () => { el(n).value = el(s).value; updateAll(); });
      el(n).addEventListener('input', () => { el(s).value = el(n).value; updateAll(); });
    });
    el('grav').addEventListener('input', updateAll);
    document.querySelectorAll('.planet').forEach((b) => b.addEventListener('click', () => {
      el('grav').value = b.getAttribute('data-g'); updateAll();
    }));

    // unit toggle (converts the values so the physics stays sensible)
    function setUnits(toImperial) {
      if (toImperial === imperial) return;
      const factor = toImperial ? FT : 1 / FT;
      ['speed', 'height'].forEach((base) => {
        const s = el(base), n = el(base + '-n');
        const nv = (parseFloat(n.value) || 0) * factor;
        n.value = Math.round(nv * 100) / 100; s.value = n.value;
      });
      imperial = toImperial;
      el('grav').value = units().g;
      // restyle toggle
      el('u-metric').className = 'px-3 py-1.5 ' + (imperial ? 'bg-white text-slate-600' : 'bg-indigo-600 text-white');
      el('u-imperial').className = 'px-3 py-1.5 ' + (imperial ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600');
      document.querySelectorAll('.u-vel').forEach((x) => (x.textContent = units().vel));
      document.querySelectorAll('.u-len').forEach((x) => (x.textContent = units().len));
      document.querySelectorAll('.u-acc').forEach((x) => (x.textContent = units().acc));
      updateAll();
    }
    el('u-metric').addEventListener('click', () => setUnits(false));
    el('u-imperial').addEventListener('click', () => setUnits(true));

    function resetExample() {
      imperial = false;
      el('u-metric').className = 'bg-indigo-600 px-3 py-1.5 text-white';
      el('u-imperial').className = 'bg-white px-3 py-1.5 text-slate-600';
      el('speed').value = el('speed-n').value = 20;
      el('angle').value = el('angle-n').value = 45;
      el('height').value = el('height-n').value = 0;
      el('grav').value = 9.81;
      document.querySelectorAll('.u-vel').forEach((x) => (x.textContent = 'm/s'));
      document.querySelectorAll('.u-len').forEach((x) => (x.textContent = 'm'));
      document.querySelectorAll('.u-acc').forEach((x) => (x.textContent = 'm/s²'));
      updateAll();
    }
    el('btn-reset').addEventListener('click', resetExample);

    // restore from URL if present
    (function restore() {
      const p = new URLSearchParams(location.search);
      if (!p.has('v')) return;
      if (p.get('u') === 'i') { imperial = true; el('u-metric').className = 'bg-white px-3 py-1.5 text-slate-600'; el('u-imperial').className = 'bg-indigo-600 px-3 py-1.5 text-white'; document.querySelectorAll('.u-vel').forEach((x) => (x.textContent = 'ft/s')); document.querySelectorAll('.u-len').forEach((x) => (x.textContent = 'ft')); document.querySelectorAll('.u-acc').forEach((x) => (x.textContent = 'ft/s²')); }
      const set = (base, key) => { if (p.has(key)) { el(base).value = el(base + '-n').value = p.get(key); } };
      set('speed', 'v'); set('angle', 'a'); set('height', 'h');
      if (p.has('g')) el('grav').value = p.get('g');
    })();

    // ================= CHARTS (Chart.js) =================
    function trajSamples(v0, ang, h0, g, n) {
      const rad = ang * Math.PI / 180, vx = v0 * Math.cos(rad), vy = v0 * Math.sin(rad);
      const disc = vy * vy + 2 * g * h0; if (disc < 0) return null;
      const tF = (vy + Math.sqrt(disc)) / g;
      const T = [], Y = [], VX = [], VY = [], X = [];
      for (let i = 0; i <= n; i++) {
        const t = tF * i / n;
        T.push(+(t).toFixed(2));
        Y.push(+(h0 + vy * t - 0.5 * g * t * t).toFixed(3));
        X.push(+(vx * t).toFixed(3));
        VX.push(+vx.toFixed(3));
        VY.push(+(vy - g * t).toFixed(3));
      }
      return { T, Y, VX, VY, X, tF };
    }

    function initCharts() {
      if (!window.Chart) return;
      const baseOpts = chartSetup();

      charts.height = new Chart(el('chart-height'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'Height (vs time)', data: [], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
        options: Object.assign({}, baseOpts, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Height' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });

      charts.vel = new Chart(el('chart-vel'), {
        type: 'line',
        data: { labels: [], datasets: [
          { label: 'Horizontal vₓ', data: [], borderColor: '#0ea5e9', pointRadius: 0, tension: 0 },
          { label: 'Vertical vᵧ', data: [], borderColor: '#10b981', pointRadius: 0, tension: 0 },
        ] },
        options: Object.assign({}, baseOpts, { scales: { x: { title: { display: true, text: 'Time (s)' } }, y: { title: { display: true, text: 'Velocity' } } }, plugins: { legend: { position: 'bottom' } } }),
      });

      charts.range = new Chart(el('chart-range'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'Range vs angle', data: [], borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.10)', fill: true, tension: 0.3, pointRadius: 0 }] },
        options: Object.assign({}, baseOpts, { scales: { x: { title: { display: true, text: 'Launch angle (°)' } }, y: { title: { display: true, text: 'Range' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });

      charts.ready = true;
      updateCharts();
    }

    function updateCharts() {
      if (!charts.ready || !last) return;
      const { v0, ang, h0, g } = last;
      const s = trajSamples(v0, ang, h0, g, 40);
      if (s) {
        charts.height.data.labels = s.T; charts.height.data.datasets[0].data = s.Y; charts.height.update();
        charts.vel.data.labels = s.T; charts.vel.data.datasets[0].data = s.VX; charts.vel.data.datasets[1].data = s.VY; charts.vel.update();
      }
      // Range vs angle (conceptual — uses current speed & height, sweeps the angle)
      const L = [], D = [];
      for (let a = 0; a <= 90; a += 3) {
        const rr = solve(v0, a, h0, g);
        L.push(a); D.push(rr.err ? 0 : +rr.range.toFixed(2));
      }
      charts.range.data.labels = L; charts.range.data.datasets[0].data = D; charts.range.update();
    }

    // ================= THREE.js SCENES (via window.STK) =================
    const PROJ_OPTS = { ambient: 0.85, dirLight: 0.55, azim: 0.9, pol: 1.15, polMin: 0.25, polMax: Math.PI / 2 + 0.15 };

    // ---- Scene 1: interactive live trajectory ----
    function initScene3d() {
      const c = el('scene3d'); if (!c) throw new Error('no container');
      const s = makeScene(c, 14, new THREE.Vector3(4, 2, 0), PROJ_OPTS);
      const grid = new THREE.GridHelper(20, 20, 0xcbd5e1, 0xe2e8f0); grid.position.set(6, 0, 0); s.scene.add(grid);
      const arcMat = new THREE.LineBasicMaterial({ color: 0x6366f1 });
      let arcLine = null, scale = 1, pts = [];
      const ball = new THREE.Mesh(new THREE.SphereGeometry(0.28, 24, 24), new THREE.MeshStandardMaterial({ color: 0xef4444 }));
      s.scene.add(ball);
      const pad = new THREE.Mesh(new THREE.CylinderGeometry(0.5, 0.5, 0.15, 24), new THREE.MeshStandardMaterial({ color: 0x94a3b8 }));
      s.scene.add(pad);

      function setTrajectory() {
        if (!last || last.r.err) return;
        const { v0, ang, h0, g } = last;
        const smp = trajSamples(v0, ang, h0, g, 60); if (!smp) return;
        const maxDim = Math.max(smp.tF > 0 ? Math.max.apply(null, smp.X) : 1, Math.max.apply(null, smp.Y), 1);
        scale = 12 / maxDim;
        pts = smp.X.map((x, i) => new THREE.Vector3(x * scale, Math.max(0, smp.Y[i]) * scale, 0));
        if (arcLine) { s.scene.remove(arcLine); arcLine.geometry.dispose(); }
        arcLine = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), arcMat); s.scene.add(arcLine);
        pad.position.set(pts[0].x, (h0 * scale) / 2, 0); pad.scale.y = Math.max(0.5, h0 * scale / 0.15);
        if (!animating) ball.position.copy(pts[0]);
        const mid = pts[Math.floor(pts.length / 2)];
        s.setTarget(new THREE.Vector3(mid.x, mid.y * 0.6, 0));
      }

      let animating = false, animI = 0;
      function launch() { if (pts.length) { animating = true; animI = 0; } }
      el('btn-launch').addEventListener('click', launch);

      function frame() {
        requestAnimationFrame(frame);
        if (!reduceMotion) s.spin(0.0016);
        if (animating && pts.length) {
          animI += Math.max(1, Math.round(pts.length / 90));
          if (animI >= pts.length) { animI = pts.length - 1; animating = false; }
          ball.position.copy(pts[animI]);
        }
        s.renderer.render(s.scene, s.camera);
      }
      frame();
      scene3d = { setTrajectory, resize: s.resize };
      setTrajectory();
      if (!reduceMotion) setTimeout(launch, 400);
    }

    // ---- Scene 2: velocity vector decomposition (auto-rotating) ----
    function initDiagVectors() {
      const c = el('diag-vectors'); if (!c) throw new Error('no container');
      const s = makeScene(c, 9, new THREE.Vector3(2, 1.4, 0), PROJ_OPTS);
      const g = new THREE.GridHelper(8, 8, 0xe2e8f0, 0xeef2f7); g.position.set(2, 0, 0); s.scene.add(g);
      const O = new THREE.Vector3(0, 0, 0);
      const tip = new THREE.Vector3(4, 3, 0);
      s.scene.add(arrow(O, tip, 0xef4444));                              // resultant v0
      s.scene.add(arrow(O, new THREE.Vector3(4, 0, 0), 0x0ea5e9));        // horizontal
      s.scene.add(arrow(new THREE.Vector3(4, 0, 0), tip, 0x10b981));      // vertical
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.004); s.renderer.render(s.scene, s.camera); }
      frame();
      diagV = { resize: s.resize };
    }

    // ---- Scene 3: family of trajectories (auto-rotating) ----
    function initDiagFamily() {
      const c = el('diag-family'); if (!c) throw new Error('no container');
      const s = makeScene(c, 15, new THREE.Vector3(5, 2, 0), PROJ_OPTS);
      const grid = new THREE.GridHelper(22, 22, 0xe2e8f0, 0xeef2f7); grid.position.set(6, 0, 0); s.scene.add(grid);
      const v0 = 12, g = 9.81, angles = [15, 30, 45, 60, 75];
      angles.forEach((a) => {
        const smp = trajSamples(v0, a, 0, g, 40);
        const scale = 10 / Math.max(Math.max.apply(null, smp.X), Math.max.apply(null, smp.Y));
        const pts = smp.X.map((x, i) => new THREE.Vector3(x * scale, Math.max(0, smp.Y[i]) * scale, 0));
        const col = a === 45 ? 0x4f46e5 : 0x94a3b8;
        const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: col, transparent: a !== 45, opacity: a === 45 ? 1 : 0.7 }));
        s.scene.add(line);
      });
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagF = { resize: s.resize };
    }

    // ================= BOOT (defensive: each widget isolated, spec Section 5) =================
    function boot() {
      try { updateAll(); } catch (e) { console.error('[projectile] calculator init failed', e); }
      try { initCharts(); } catch (e) { console.error('[projectile] charts init failed', e); }
      if (window.THREE) {
        try { initScene3d(); } catch (e) { console.error('[projectile] 3D scene failed', e); el('scene3d-fallback').classList.remove('hidden'); }
        try { initDiagVectors(); } catch (e) { console.error('[projectile] vector diagram failed', e); }
        try { initDiagFamily(); } catch (e) { console.error('[projectile] family diagram failed', e); }
      } else {
        el('scene3d-fallback').classList.remove('hidden');
      }
      updateAll();

      mountResize([scene3d, diagV, diagF]);
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
  </script>
</ToolLayout>
