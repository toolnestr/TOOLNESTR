---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Tailoring/Alteration Cost Estimator';
const description = 'Estimate the cost of common tailoring and alteration jobs like hemming, taking in, or replacing a zipper, from base job price and complexity.';
const intro = 'Estimate what a common alteration or tailoring job should cost based on job type and complexity.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'Why do alteration prices vary so much between shops?', a: 'Local labor cost, the tailor\'s skill/experience level, garment complexity (lining, structure, delicate fabric), and regional cost of living all shift alteration pricing significantly — a simple pants hem might cost very different amounts in different cities for that reason.' },
  { q: 'Why do lined garments or delicate fabrics cost more to alter?', a: 'A lined jacket or dress requires opening, altering, and re-closing both the outer fabric and the lining separately, roughly doubling the hand-sewing work compared to a single-layer garment — and delicate fabrics like silk or lace require slower, more careful handling that takes more skilled time.' },
  { q: 'Is a rush alteration always more expensive?', a: 'Often yes — a rush job disrupts the tailor\'s existing queue and may require them to work outside normal hours, so many shops apply a rush surcharge (commonly 25-50% extra) for short-notice or same-day turnaround.' },
  { q: 'Does this give an exact price?', a: 'No — this is a planning estimate based on typical complexity multipliers. Get an exact quote from your specific tailor, since garment-specific factors (fabric, construction, fit issues) always cause some variation from a general estimate.' },
];
const howTo = {
  name: 'How to estimate an alteration cost',
  steps: [
    { name: 'Enter the base job price', text: 'A simple version of the job on an unlined, easy fabric — from your tailor\'s price list or local research.' },
    { name: 'Select complexity factors', text: 'Toggle on lining, delicate fabric, or rush service, each adding its typical surcharge.' },
    { name: 'Read the estimated total', text: 'A planning estimate for what the full job is likely to cost.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Base job price ($)</span>
      <input id="base" type="number" step="any" placeholder="e.g. 20" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    <div class="mt-4 space-y-2">
      <label class="flex items-center gap-2 text-sm text-slate-700"><input id="lined" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-rose-600" /> Lined garment (+50%)</label>
      <label class="flex items-center gap-2 text-sm text-slate-700"><input id="delicate" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-rose-600" /> Delicate/structured fabric (+30%)</label>
      <label class="flex items-center gap-2 text-sm text-slate-700"><input id="rush" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-rose-600" /> Rush/same-day service (+40%)</label>
    </div>
    <div id="results" class="mt-6 hidden">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated total</div>
        <div id="r-total" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How alteration cost is estimated</h2>
    <p class="mt-2 text-slate-600">
      This estimator starts from a base price for a simple version of the job — say, hemming a pair of unlined trousers — and applies percentage surcharges for the complexity factors that most commonly raise a tailor's price: lining (roughly doubling the hand-sewing since both layers need altering), delicate or structured fabric (slower, more careful work), and rush turnaround (disrupting the shop's normal queue).
    </p>
    <p class="mt-3 text-slate-600">
      These surcharge percentages reflect typical tailoring-industry practice but vary by shop, so the result here is a planning estimate, not a quote. Actual pricing also depends heavily on the specific garment's construction — a simple hem and a full jacket resizing that moves seams, shoulders, and sleeves are entirely different jobs even within the same "alteration" category, and should be estimated with different base prices to begin with.
    </p>
    <p class="mt-3 text-xs text-slate-400">Complexity surcharges reflect common independent-tailoring and alteration-shop pricing practice.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A lined jacket taken in, needed by tomorrow: $20 base, lined + rush.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Base:</span> <span class="text-slate-600">$20</span></div>
        <div><span class="font-medium text-slate-700">+ 50% lined:</span> <span class="text-slate-600">20 × 1.5 = $30</span></div>
        <div><span class="font-medium text-slate-700">+ 40% rush:</span> <span class="text-slate-600">30 × 1.4 = <strong>$42</strong></span></div>
        <div><span class="font-medium text-slate-700">Estimated total:</span> <span class="text-slate-600"><strong>$42</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Wedding season is the classic case where every surcharge stacks: a bridal gown alteration is almost always lined, often structured with boning or a corset-style bodice, and frequently booked on a tight rush timeline close to the wedding date — which is exactly why bridal alterations routinely cost several times more than a simple garment hem.
    </p>
    <p class="mt-3 text-slate-600">
      Suit and jacket tailoring for a professional wardrobe similarly tends to run higher than casualwear alterations, since suiting fabric is often structured with interfacing and lining that both need to be opened and re-closed correctly to preserve the garment's shape — a skill that takes longer and commands a higher rate than altering a simple cotton dress.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"All hems cost the same regardless of the garment." <strong class="text-slate-900">Not true.</strong> A lined formal skirt hem takes meaningfully longer than a simple unlined casual dress hem, and pricing reflects that real difference in labor.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Rush fees are just upcharging for no reason." <strong class="text-slate-900">They reflect real disruption cost.</strong> A rush job often means the tailor reorders their existing queue or works outside normal hours to accommodate it, which has a real cost to their business.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/custom-garment-price-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Custom Garment Price Calculator</a>
      <a href="/tools/inseam-length-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Inseam Length Calculator</a>
      <a href="/tools/ease-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Ease Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const base = parseFloat(el('base').value);
      if (!(base > 0)) { el('results').classList.add('hidden'); return; }
      let total = base;
      if (el('lined').checked) total *= 1.5;
      if (el('delicate').checked) total *= 1.3;
      if (el('rush').checked) total *= 1.4;

      el('r-total').textContent = '$' + total.toFixed(2);
      el('results').classList.remove('hidden');
    }

    ['base', 'lined', 'delicate', 'rush'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
