---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Exponential Population Growth Calculator';
const description = "Exponential population growth calculator. Solve N(t) = N₀e^(rt) for unconstrained population growth, with worked examples and doubling-time calculations.";
const intro = 'Enter an initial population, growth rate, and time to project exponential population growth using N(t) = N₀e^(rt), the ecological model for growth without resource limits. Two 3D diagrams compare an early-stage and late-stage exponentially growing population, and charts trace the classic J-shaped growth curve.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is exponential population growth?', a: 'Exponential growth describes a population that grows at a rate proportional to its current size, with no resource limits slowing it down — producing the characteristic J-shaped growth curve where growth accelerates over time.' },
  { q: 'What does the growth rate (r) represent?', a: 'r is the per-capita growth rate — the intrinsic rate at which the population would grow per individual per unit time, combining birth rate minus death rate (assuming no migration).' },
  { q: 'How is doubling time related to growth rate?', a: 'Doubling time = ln(2)/r — a higher growth rate produces a shorter doubling time. This relationship comes directly from solving N(t)=2N₀ for t in the exponential growth equation.' },
  { q: 'When does exponential growth actually occur in nature?', a: 'True exponential growth is rare and typically short-lived — seen in situations like a small population colonizing a new, resource-rich habitat, bacteria in fresh nutrient broth, or an invasive species with no natural predators, before resource limits eventually kick in.' },
  { q: 'How is exponential growth different from logistic growth?', a: 'Exponential growth assumes no limits and keeps accelerating forever (unrealistic long-term). Logistic growth incorporates a carrying capacity, causing growth to slow and level off as the population approaches the environment\'s maximum sustainable size — a separate calculator models this case.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Exponential Population Growth Calculator',
  description: 'Project population growth using N(t) = N₀e^(rt), and find doubling time.',
  steps: [
    { name: 'Enter initial population and growth rate', text: 'Provide N₀ (starting population) and r (per-capita growth rate).' },
    { name: 'Enter a time value', text: 'Provide how far into the future to project the population.' },
    { name: 'Read the result', text: 'Projected population N(t) and doubling time solve instantly.' },
  ],
};

const formulas = [
  { expr: 'N(t) = N₀ × e^(rt)', note: 'N₀ = initial population, r = per-capita growth rate, t = time' },
  { expr: 'Doubling time = ln(2) / r', note: 'the time for the population to double, from the same growth rate' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a growing bacterial colony', tone: 'slate',
    given: 'A population starts at N₀ = 100 with a growth rate r = 0.1 per hour. Find the population after t = 10 hours.',
    rows: [
      { label: 'Formula:', value: 'N(t) = N₀ × e^(rt)' },
      { label: 'Substitute:', value: 'N(10) = 100 × e^(0.1×10) = 100 × e^1' },
      { label: 'Result:', value: 'N(10) = 100 × 2.71828 ≈ 271.8, so about 272 individuals', full: true },
    ],
    note: 'This nearly 2.7-fold increase in just 10 hours illustrates how quickly unconstrained exponential growth can compound.',
  },
  {
    title: 'Worked example 2 — finding doubling time', tone: 'amber',
    given: 'The same population has growth rate r = 0.1 per hour. Find its doubling time.',
    rows: [
      { label: 'Formula:', value: 'Doubling time = ln(2) / r' },
      { label: 'Substitute:', value: 'Doubling time = 0.6931 / 0.1' },
      { label: 'Result:', value: 'Doubling time ≈ 6.93 hours', full: true },
    ],
    note: 'Every 6.93 hours, this population doubles in size — a useful, intuitive way to communicate growth rate without needing to reference the underlying exponential formula directly.',
  },
];

const comparison = {
  heading: 'How growth rate affects doubling time',
  note: 'Even modest-looking differences in growth rate produce dramatically different doubling times.',
  headers: [{ label: 'Growth rate (r, per unit time)' }, { label: 'Doubling time' }],
  rows: [
    ['0.05', '13.86 time units'],
    ['0.10 ★', '6.93 time units'],
    ['0.20', '3.47 time units'],
    ['0.50', '1.39 time units'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 2). Doubling the growth rate roughly halves the doubling time — a direct consequence of the ln(2)/r relationship.',
};

const realWorld = [
  { emoji: '🦠', title: 'Microbial growth in fresh culture', body: 'Bacteria introduced into a nutrient-rich, unlimited growth medium initially grow exponentially, a foundational model in microbiology used to characterize growth rates of different species and strains.' },
  { emoji: '🐇', title: 'Invasive species colonization', body: 'Invasive species introduced into a new habitat with abundant resources and no natural predators often show a brief exponential growth phase before resource limits or new predators slow their expansion.' },
  { emoji: '🌍', title: 'Early-stage human population growth models', body: 'Historical human population growth in resource-rich, low-mortality periods has been approximated with exponential models, though real populations eventually experience resource and social constraints.' },
  { emoji: '📊', title: 'Epidemiology and early outbreak modeling', body: 'The early phase of an infectious disease outbreak, before public health interventions or population immunity slow transmission, often closely follows an exponential growth pattern.' },
];

const misconceptions = [
  { claim: '"Exponential growth can continue indefinitely in any real population."', truth: 'No real population can sustain exponential growth forever — limited resources, space, predators, or disease eventually slow growth, which is exactly why the logistic growth model (with a carrying capacity) is used for longer-term, more realistic population projections.' },
  { claim: '"A growth rate of 0.1 means the population grows by exactly 10% total over the whole time period."', truth: 'r is a continuous, instantaneous per-capita rate, not a simple percentage applied once — because growth compounds continuously, the actual total growth over a time period is calculated through the exponential function e^(rt), not a simple r×t percentage.' },
  { claim: '"Doubling time is a fixed number of individuals added each cycle."', truth: "Doubling time is a fixed TIME interval (not a fixed number of individuals) — because growth is exponential, the actual number of individuals added during each doubling period keeps increasing even though the doubling TIME itself stays constant." },
  { claim: '"A negative growth rate means the population math breaks down."', truth: 'A negative r simply models a shrinking (declining) population — the same N(t)=N₀e^(rt) formula works perfectly well, just producing a population that decreases exponentially toward zero over time instead of increasing.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 19, "Population and Community Ecology" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/19-1-population-demography" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Campbell &amp; Reece, <em>Biology</em></strong> — Chapter 53, Population Ecology.' },
  { html: '<strong>Molles, <em>Ecology: Concepts and Applications</em></strong> — Chapter 10, Population Growth and Regulation.' },
];
const sourcesNote = 'N(t)=N₀e^(rt); doubling time=ln(2)/r. Models unconstrained growth only — real populations eventually hit resource limits (see logistic growth). Results are rounded for display.';

const howToUse = [
  { title: 'Enter N₀ and r', body: 'Provide the starting population and per-capita growth rate.' },
  { title: 'Enter a time value', body: 'Choose how far into the future to project.' },
  { title: 'Read N(t) and doubling time', body: 'Both solve instantly from the same growth rate.' },
];

const related = [
  { href: '/tools/logistic-growth-calculator', emoji: '📉', title: 'Logistic Growth / Carrying Capacity Calculator', desc: 'N(t) with a carrying capacity — a more realistic model.' },
  { href: '/tools/population-density-calculator', emoji: '🌍', title: 'Population Density Calculator', desc: 'D = N/A — individuals per unit area.' },
  { href: '/tools/shannon-diversity-index-calculator', emoji: '📊', title: 'Shannon Diversity Index Calculator', desc: 'H\' = −Σ(pᵢ ln pᵢ) — measure community biodiversity.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="when a population's growth rate per individual stays constant and resources are effectively unlimited, the population compounds on itself exactly like continuously-compounding interest — producing accelerating growth that looks flat at first and then rises dramatically, the classic J-shaped curve."
  howIntro="The differential equation dN/dt = rN says the population's growth rate at any instant is directly proportional to how large the population already is — more individuals means more total births (and deaths) happening per unit time. Solving this differential equation produces the exponential solution N(t) = N₀e^(rt), where every additional unit of time multiplies the population by the same factor e^r, producing the compounding, accelerating growth pattern characteristic of unconstrained biological populations."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where exponential population growth actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Initial population (N₀)</span>
        <input id="n0" type="number" step="any" value="100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Growth rate (r, per unit time)</span>
        <input id="rate" type="number" step="any" value="0.1" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Time (t)</span>
        <input id="time" type="number" step="any" value="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Population N(t)</div><div id="r-nt" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Doubling time</div><div id="r-double" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="exp-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Early vs late population growth</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-early" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Early growth stage</h3>
          <p class="mt-1 text-sm text-slate-600">A small population — growth looks slow, but it's already compounding.</p>
        </div>
        <div>
          <div id="diag-late" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Later growth stage</h3>
          <p class="mt-1 text-sm text-slate-600">The same population many doublings later — the compounding effect is now dramatic and visually obvious.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Exponential growth graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">The classic J-shaped exponential growth curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-curve"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Doubling time vs growth rate</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-doubling"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      function update() {
        el('exp-err').textContent = '';
        el('r-nt').textContent = '—'; el('r-double').textContent = '—';
        const n0 = parseFloat(el('n0').value), r = parseFloat(el('rate').value), t = parseFloat(el('time').value);
        if (isNaN(n0) || isNaN(r) || isNaN(t)) return;
        if (n0 <= 0) { el('exp-err').textContent = 'Initial population must be greater than 0.'; return; }
        const nt = n0 * Math.exp(r * t);
        el('r-nt').textContent = fmt(nt);
        if (r > 0) el('r-double').textContent = fmt(Math.log(2) / r) + ' time units';
        else el('r-double').textContent = 'N/A (r ≤ 0)';
      }
      ['n0', 'rate', 'time'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsT = [], dataN = [];
        for (let t = 0; t <= 20; t += 1) { labelsT.push(t); dataN.push(+(100 * Math.exp(0.1 * t)).toFixed(1)); }
        charts.curve = new Chart(el('chart-curve'), {
          type: 'line',
          data: { labels: labelsT, datasets: [{ label: 'N(t)', data: dataN, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0.35, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Time' } }, y: { title: { display: true, text: 'Population N(t)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsR = [0.05, 0.1, 0.2, 0.3, 0.5], dataD = labelsR.map((r) => +(Math.log(2) / r).toFixed(2));
        charts.doubling = new Chart(el('chart-doubling'), {
          type: 'bar',
          data: { labels: labelsR.map((r) => 'r=' + r), datasets: [{ label: 'Doubling time', data: dataD, backgroundColor: '#f59e0b' }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Doubling time' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function popScene(container, count) {
        const s = makeScene(container, Math.max(7, Math.sqrt(count) * 1.4), new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < Math.min(count, 80); i++) {
          const phi = Math.acos(1 - (2 * (i + 0.5)) / Math.min(count, 80));
          const theta = Math.PI * (1 + Math.sqrt(5)) * i;
          const r = 2.2;
          const x = r * Math.sin(phi) * Math.cos(theta), y = r * Math.sin(phi) * Math.sin(theta), z = r * Math.cos(phi);
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.2, 10, 8), new THREE.MeshStandardMaterial({ color: 0x6366f1 }));
          sph.position.set(x, y, z);
          s.scene.add(sph);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagEarly = null, diagLate = null;
      function initDiagEarly() { const c = el('diag-early'); if (!c) throw new Error('no container'); diagEarly = popScene(c, 15); }
      function initDiagLate() { const c = el('diag-late'); if (!c) throw new Error('no container'); diagLate = popScene(c, 80); }

      function boot() {
        try { update(); } catch (e) { console.error('[exponential-population-growth] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[exponential-population-growth] charts failed', e); }
        if (window.THREE) {
          try { initDiagEarly(); } catch (e) { console.error('[exponential-population-growth] early diagram failed', e); }
          try { initDiagLate(); } catch (e) { console.error('[exponential-population-growth] late diagram failed', e); }
        }
        mountResize([diagEarly, diagLate]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
