---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Blood Alcohol Content (BAC) Calculator';
const description =
  'Free BAC calculator. Estimate your blood alcohol content using the Widmark formula. Understand how alcohol affects your body. Includes legal limit reference.';
const intro =
  'Enter your sex, weight, number of drinks and time spent drinking to estimate your blood alcohol content (BAC).';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'What is BAC?', a: 'Blood Alcohol Content (BAC) is the percentage of alcohol in your bloodstream. A BAC of 0.08% means 0.08 g of alcohol per 100 mL of blood, which is the legal driving limit in most US states.' },
  { q: 'How accurate is the Widmark formula?', a: 'The Widmark formula provides a reasonable estimate but individual factors — metabolism, liver function, food consumed, hydration and genetics — cause significant variation. Use it as an educational tool, not a precise measurement.' },
  { q: 'How quickly does the body metabolise alcohol?', a: 'The liver processes alcohol at an average rate of about 0.015–0.020% BAC per hour, or roughly one standard drink per hour. Nothing speeds this up — not coffee, cold showers or exercise.' },
  { q: 'What factors affect BAC?', a: 'Weight (more body water dilutes alcohol), sex (women generally have less body water and lower alcohol dehydrogenase activity), food (slows absorption), carbonation (speeds absorption), and genetics all influence BAC.' },
  { q: 'What is the legal BAC limit?', a: 'In most US states, the legal driving limit is 0.08% for drivers aged 21+. For commercial drivers it is 0.04%. Many countries have lower limits (0.05% in most of Europe, 0.02% in some).' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <label class="block"><span class="text-sm font-medium text-slate-700">Sex</span>
      <select id="sex" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option value="male">Male</option><option value="female">Female</option></select></label>

    <div id="metric" class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="70" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Drinks consumed</span>
        <input id="drinks" type="number" step="any" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-2" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="154" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Drinks consumed</span>
        <input id="i-drinks" type="number" step="any" placeholder="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Time spent drinking (hours)</span>
      <input id="hours" type="number" step="any" placeholder="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated BAC</div>
        <div id="r-bac" class="mt-1 text-3xl font-bold">—</div>
        <div id="r-status" class="mt-1 text-sm font-medium">—</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Hours to zero</div><div id="r-zero" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Standard drinks</div><div id="r-drinks" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your details to estimate your BAC.</p>
    <p class="mt-3 rounded-xl bg-red-50 p-3 text-sm text-red-700 font-medium">This is an educational estimate only. Never drink and drive. If you plan to drink, arrange a safe ride home.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About blood alcohol content</h2>
    <p class="mt-2 text-slate-600">
      Blood Alcohol Content (BAC) measures the concentration of alcohol in your blood. It is used legally to determine impairment for driving and other activities. This calculator uses the <a href="https://pubmed.ncbi.nlm.nih.gov/7023697/" rel="noopener">Widmark formula</a>, developed by Swedish physician Erik Widmark in the 1930s, which remains the standard method for estimating BAC. BAC is influenced by many factors beyond those in the formula — your food intake, hydration, liver health, genetics, medications and fatigue all affect your actual BAC. <strong>This is not a medical or legal instrument.</strong> If you plan to drink, arrange a safe ride home in advance. See also the <a href="/tools/calorie-calculator/" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a> for the calorie content of alcohol.
    </p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="bac-title bac-desc">
      <title id="bac-title">BAC curve over time and legal limit</title>
      <desc id="bac-desc">Line chart showing BAC rising and falling over time, with a horizontal red dashed line at the 0.08% legal limit.</desc>
      <line x1="60" y1="40" x2="60" y2="170" stroke="#cbd5e1" />
      <line x1="60" y1="170" x2="740" y2="170" stroke="#cbd5e1" />
      <!-- Legal limit line -->
      <line x1="60" y1="95" x2="740" y2="95" stroke="#ef4444" stroke-width="2" stroke-dasharray="6,3" />
      <text x="745" y="98" font-size="11" fill="#dc2626">0.08% limit</text>
      <!-- BAC curve -->
      <path d="M100,170 Q200,170 300,90 Q400,40 500,50 Q600,70 700,130" fill="none" stroke="#6366f1" stroke-width="3" />
      <circle cx="300" cy="90" r="4" fill="#6366f1" />
      <text x="300" y="85" text-anchor="middle" font-size="10" fill="#6366f1">Peak BAC</text>
      <text x="400" y="195" text-anchor="middle" font-size="11" fill="#94a3b8">Time (hours)</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">BAC rises after drinking, peaks at roughly 30–90 minutes, then declines at ~0.015%/hour. The red line shows the 0.08% legal limit.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The Widmark formula estimates peak BAC using the number of standard drinks, body weight, sex (which affects the distribution ratio) and time elapsed. One standard drink contains ~14 g of pure alcohol in the US (12 oz beer, 5 oz wine, 1.5 oz spirits). The formula calculates total alcohol consumed, divides by body water volume (adjusted for sex), then subtracts the alcohol metabolised during the drinking period. The metabolism rate is approximately 0.015% BAC per hour, though this varies.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Widmark formula:</strong> BAC = ((drinks × 14 g × 100) / (weight (g) × r)) − (metabolism × hours)
    </p>
    <p class="mt-3 text-slate-600">
      Where r (distribution ratio): Men = 0.68, Women = 0.55<br>
      Metabolism: ~0.015 g/100mL/hour
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 75 kg man drinks 4 standard beers over 3 hours. What is his estimated BAC?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Alcohol consumed:</span> <span class="text-slate-600">4 × 14 = <strong>56 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Body water (r = 0.68):</span> <span class="text-slate-600">75,000 × 0.68 = <strong>51,000 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Gross BAC:</span> <span class="text-slate-600">56 × 100 / 51,000 = <strong>0.110%</strong></span></div>
        <div><span class="font-medium text-slate-700">Metabolism (3 hrs):</span> <span class="text-slate-600">0.015 × 3 = <strong>0.045%</strong></span></div>
        <div><span class="font-medium text-slate-700">Estimated BAC:</span> <span class="text-slate-600">0.110 − 0.045 = <strong>0.065%</strong> (below 0.08% limit)</span></div>
        <div><span class="font-medium text-slate-700">Hours to zero:</span> <span class="text-slate-600">0.065 / 0.015 ≈ <strong>4.3 more hours</strong></span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🍻</span>
      <h3 class="mt-2 font-semibold text-slate-900">Social drinker</h3>
      <p class="mt-1 text-sm text-slate-600">Plan your evening by understanding how many drinks you can have before reaching impairing levels. Always arrange a safe ride home.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚗</span>
      <h3 class="mt-2 font-semibold text-slate-900">Designated driver</h3>
      <p class="mt-1 text-sm text-slate-600">Understand how long it takes for alcohol to leave your system after a night out. The only safe level for driving is 0.00%.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍⚕️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Health educator</h3>
      <p class="mt-1 text-sm text-slate-600">Use the calculator to teach students about alcohol metabolism, impairment levels and why coffee and cold showers do not speed up sobriety.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧑‍🎓</span>
      <h3 class="mt-2 font-semibold text-slate-900">College student</h3>
      <p class="mt-1 text-sm text-slate-600">Learn about BAC and make informed decisions about drinking. Know your limits and understand that impairment starts well below the legal limit.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your details</h3>
        <p class="mt-1 text-sm text-slate-600">Provide your sex and weight. The Widmark formula uses different distribution ratios for men and women.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Log your drinks and time</h3>
        <p class="mt-1 text-sm text-slate-600">Enter the number of standard drinks and the total hours you have been drinking. Time matters — spreading drinks out lowers peak BAC.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your estimate</h3>
        <p class="mt-1 text-sm text-slate-600">See your estimated BAC, whether it is above the legal limit, and how long until it reaches zero. Plan accordingly and never drink and drive.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Important safety information</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Only time lowers BAC</h3>
        <p class="mt-1 text-sm text-slate-600">Coffee, cold showers, vomiting, exercise or fresh air do not speed up alcohol metabolism. Only your liver processing alcohol over time reduces your BAC. The average rate is 0.015% per hour.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Impairment starts below the legal limit</h3>
        <p class="mt-1 text-sm text-slate-600">At 0.02–0.04% BAC, most people experience reduced judgement and coordination. At 0.05–0.07%, impairment is significant. Do not drive after any amount of alcohol.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Standard drink sizes vary</h3>
        <p class="mt-1 text-sm text-slate-600">A standard drink in the US is 14 g of alcohol (12 oz beer at 5%, 5 oz wine at 12%, 1.5 oz spirits at 40%). Many restaurant and home pours are larger — account for this when estimating your intake.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/calorie-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Calorie Calculator</a>
      <a href="/tools/body-surface-area-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">BSA Calculator</a>
      <a href="/tools/bmi-calculator/" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">BMI Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      let kg, drinks, hours;
      if (metric) {
        kg = parseFloat(el('m-w').value);
        drinks = parseFloat(el('drinks').value);
      } else {
        kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
        drinks = parseFloat(el('i-drinks').value);
      }
      hours = parseFloat(el('hours').value);
      if (!kg || !drinks || !hours || kg <= 0 || drinks <= 0 || hours < 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const male = el('sex').value === 'male';
      const r = male ? 0.68 : 0.55;
      const alcG = drinks * 14;
      const bac = Math.max(0, (alcG * 100) / (kg * 1000 * r) - 0.015 * hours);
      const hoursToZero = bac / 0.015;
      const pct = (bac * 100).toFixed(3);
      let status;
      if (bac >= 0.08) status = 'Above legal limit (0.08%) — Do NOT drive';
      else if (bac >= 0.05) status = 'Above 0.05% — Impaired, do not drive';
      else if (bac >= 0.02) status = 'Mild impairment — Do not drive';
      else status = 'Low BAC — Still, do not drive if you have consumed alcohol';
      el('r-bac').textContent = pct + '%';
      el('r-status').textContent = status;
      el('r-zero').textContent = hoursToZero.toFixed(1) + ' hours';
      el('r-drinks').textContent = Math.round(drinks);
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['sex', 'm-w', 'drinks', 'hours', 'i-w', 'i-drinks'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
