---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Hours Calculator';
const description =
  'Free hours calculator. Work out the hours and minutes between two times, with an optional ' +
  'break, and get the result as a decimal too. Perfect for timesheets and pay.';
const intro =
  'Enter a start and end time (and any break) to see the total hours and minutes worked — also shown as decimal hours.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'Does it handle overnight shifts?', a: 'Yes. If the end time is earlier than the start time, it assumes the shift runs past midnight and adds 24 hours.' },
  { q: 'What are decimal hours?', a: 'Decimal hours express minutes as a fraction of an hour (e.g. 8 hours 30 minutes = 8.5 hours), which is how many payroll systems calculate pay.' },
  { q: 'Can I subtract a break?', a: 'Yes — enter your break in minutes and it’s removed from the total.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Start time</span>
        <input id="start" type="time" value="09:00" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">End time</span>
        <input id="end" type="time" value="17:30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Break (minutes)</span>
        <input id="brk" type="number" step="1" value="30" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Total time</div><div id="r-hm" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Decimal hours</div><div id="r-dec" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this hours calculator</h2>
    <p class="mt-2 text-slate-600">
      Adding up worked hours by hand is fiddly, especially across a lunch break or an overnight
      shift. This calculator does it instantly: enter your start and end times and any break, and
      get the total in hours and minutes plus decimal hours for payroll.
    </p>
  </section>

  <Fragment slot="related">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <p class="mt-2 text-sm text-slate-600">
      Try the <a href="/tools/time-calculator" class="font-medium text-indigo-600 hover:underline">Time Calculator</a>
      or <a href="/tools/date-difference" class="font-medium text-indigo-600 hover:underline">Date Difference</a>.
    </p>
  </Fragment>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    function update() {
      const s = el('start').value, e = el('end').value;
      if (!s || !e) { el('r-hm').textContent = el('r-dec').textContent = '—'; return; }
      const [sh, sm] = s.split(':').map(Number), [eh, em] = e.split(':').map(Number);
      let mins = (eh * 60 + em) - (sh * 60 + sm);
      if (mins < 0) mins += 24 * 60;
      mins -= parseInt(el('brk').value, 10) || 0;
      if (mins < 0) mins = 0;
      const h = Math.floor(mins / 60), m = mins % 60;
      el('r-hm').textContent = `${h}h ${m}m`;
      el('r-dec').textContent = (mins / 60).toFixed(2) + ' h';
    }
    ['start', 'end', 'brk'].forEach((id) => el(id).addEventListener('input', update));
    update();
  </script>
</ToolLayout>
