---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Protein Calculator';
const description =
  'Free protein calculator. Estimate your daily protein needs based on body weight, activity level and fitness goals. Metric or imperial.';
const intro =
  'Enter your weight and activity level to estimate your daily protein needs in grams. Adjust the goal for maintenance, muscle gain or fat loss.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How much protein do I need per day?', a: 'For sedentary adults, the RDA is 0.8 g per kg of body weight. For active individuals, 1.2–1.6 g per kg is recommended. For muscle building and fat loss, 1.6–2.2 g per kg is optimal.' },
  { q: 'Can I eat too much protein?', a: 'For healthy individuals, protein intakes up to 2.5 g per kg are safe. Very high intakes (above 3 g/kg) are unnecessary and may cause digestive discomfort. People with kidney disease should consult a doctor before increasing protein.' },
  { q: 'Do I need more protein as I age?', a: 'Yes — older adults (65+) benefit from higher protein intake (1.2–1.6 g/kg) to counteract sarcopenia (age-related muscle loss) and maintain strength and mobility.' },
  { q: 'What are the best sources of protein?', a: 'Complete proteins (all essential amino acids) include meat, fish, eggs, dairy, soy and quinoa. Plant-based eaters should combine different sources throughout the day to ensure a full amino acid profile.' },
  { q: 'Should I eat protein before or after exercise?', a: 'Total daily protein intake matters more than timing. Spreading protein evenly across meals (3–4 servings of 20–40 g each) is more effective than loading up post-workout alone.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <div id="metric" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="65" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Goal</span>
        <select id="goal" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="0.8">Maintenance (0.8 g/kg — sedentary)</option>
          <option value="1.2">Light activity (1.2 g/kg — 1–3 days/week)</option>
          <option value="1.6" selected>Moderate activity (1.6 g/kg — 3–5 days/week)</option>
          <option value="2.0">Very active (2.0 g/kg — 6–7 days/week)</option>
          <option value="2.2">Bodybuilding / fat loss (2.2 g/kg)</option>
        </select></label>
    </div>
    <div id="imperial" class="grid gap-4 sm:grid-cols-2" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="145" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Goal</span>
        <select id="i-goal" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="0.8">Maintenance (0.8 g/kg)</option>
          <option value="1.2">Light activity (1.2 g/kg)</option>
          <option value="1.6" selected>Moderate activity (1.6 g/kg)</option>
          <option value="2.0">Very active (2.0 g/kg)</option>
          <option value="2.2">Bodybuilding / fat loss (2.2 g/kg)</option>
        </select></label>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Daily protein target</div>
        <div id="r-protein" class="mt-1 text-3xl font-bold">—</div>
        <div class="mt-1 text-sm opacity-80">grams of protein per day</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Per meal (3 meals)</div><div id="r-per-meal" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Calories from protein</div><div id="r-cal" class="mt-1 text-xl font-bold text-indigo-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your weight and goal to see your protein target.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About protein needs</h2>
    <p class="mt-2 text-slate-600">
      Protein is the building block of every cell in your body. It is essential for muscle repair, enzyme production, immune function and hormone synthesis. Your daily protein requirement depends primarily on your body weight and how active you are. The <a href="https://www.acsm.org/" rel="noopener">American College of Sports Medicine</a> recommends 1.2–1.7 g per kg of body weight for athletes, while the RDA for sedentary adults is just 0.8 g per kg. This calculator helps you find the right target based on your lifestyle. For a broader view of your nutrition, see the <a href="/tools/macro-calculator" class="font-medium text-indigo-600 hover:underline">Macro Calculator</a> and <a href="/tools/lean-body-mass-calculator" class="font-medium text-indigo-600 hover:underline">Lean Body Mass Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">⚕️ For general information only. Consult a professional before making major dietary changes.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="prot-title prot-desc">
      <title id="prot-title">Protein recommendations by activity level</title>
      <desc id="prot-desc">Horizontal bar chart comparing grams per kilogram recommendations for sedentary, active and bodybuilding goals.</desc>
      <rect x="100" y="40" width="160" height="30" rx="4" fill="#e2e8f0" />
      <rect x="100" y="40" width="160" height="30" rx="4" fill="#6366f1" />
      <text x="120" y="60" font-size="12" fill="#fff" font-weight="bold">0.8 g/kg</text>
      <text x="100" y="30" font-size="12" fill="#64748b">Sedentary</text>
      <rect x="100" y="90" width="240" height="30" rx="4" fill="#e2e8f0" />
      <rect x="100" y="90" width="240" height="30" rx="4" fill="#22c55e" />
      <text x="120" y="110" font-size="12" fill="#fff" font-weight="bold">1.2 g/kg</text>
      <text x="100" y="80" font-size="12" fill="#64748b">Light activity</text>
      <rect x="100" y="140" width="320" height="30" rx="4" fill="#e2e8f0" />
      <rect x="100" y="140" width="320" height="30" rx="4" fill="#f59e0b" />
      <text x="120" y="160" font-size="12" fill="#fff" font-weight="bold">1.6 g/kg</text>
      <text x="100" y="130" font-size="12" fill="#64748b">Moderate activity</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Protein recommendations range from 0.8 g/kg (sedentary) to 2.2 g/kg (bodybuilding)</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      Your daily protein target is calculated by multiplying your body weight (in kilograms) by a factor that corresponds to your activity level and goal. The factor ranges from 0.8 g/kg for sedentary individuals up to 2.2 g/kg for bodybuilders and those in a calorie deficit trying to preserve muscle. The calculator shows the result in grams, along with the per-meal breakdown for three meals and the total calories protein contributes (protein has 4 calories per gram).
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>Protein (g)</strong> = weight (kg) × protein factor
    </p>
    <p class="mt-3 text-slate-600">
      For example, a 75 kg person with a moderate activity goal (1.6 g/kg):<br>
      75 × 1.6 = <strong>120 g of protein per day</strong> = 480 calories
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 68 kg woman who exercises 4 days per week (moderate activity, 1.6 g/kg) wants to know her protein target.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Weight:</span> <span class="text-slate-600">68 kg</span></div>
        <div><span class="font-medium text-slate-700">Protein factor:</span> <span class="text-slate-600">1.6 g/kg (moderate activity)</span></div>
        <div><span class="font-medium text-slate-700">Daily target:</span> <span class="text-slate-600">68 × 1.6 = <strong>109 g</strong></span></div>
        <div><span class="font-medium text-slate-700">Per meal (3 meals):</span> <span class="text-slate-600">109 / 3 ≈ <strong>36 g per meal</strong></span></div>
        <div><span class="font-medium text-slate-700">Calories:</span> <span class="text-slate-600">109 × 4 = <strong>436 cal/day</strong> from protein</span></div>
        <div><span class="font-medium text-slate-700">Practical tip:</span> <span class="text-slate-600">A chicken breast (150 g) has ~40 g protein. 3 eggs = ~18 g. 1 scoop whey = ~25 g.</span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏋️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Bodybuilder on a cut</h3>
      <p class="mt-1 text-sm text-slate-600">High protein (2.0–2.2 g/kg) during a calorie deficit helps preserve muscle mass while losing fat. This is critical for body composition.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧑‍🌾</span>
      <h3 class="mt-2 font-semibold text-slate-900">Vegan athlete</h3>
      <p class="mt-1 text-sm text-slate-600">Plant-based eaters may benefit from slightly higher protein targets (2.0 g/kg) because plant proteins have lower digestibility and amino acid profiles.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🧓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Older adult</h3>
      <p class="mt-1 text-sm text-slate-600">Higher protein intake (1.2–1.6 g/kg) helps counteract sarcopenia and maintain bone density, strength and independence as you age.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍🍳</span>
      <h3 class="mt-2 font-semibold text-slate-900">Meal prepper</h3>
      <p class="mt-1 text-sm text-slate-600">Know the exact grams of protein needed per meal to plan your weekly grocery shop and batch-cook with confidence.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your weight</h3>
        <p class="mt-1 text-sm text-slate-600">Use your current body weight in either metric or imperial units. For best results, use your morning weight after the bathroom.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select your goal</h3>
        <p class="mt-1 text-sm text-slate-600">Choose from maintenance, light activity, moderate activity, very active or bodybuilding. Each corresponds to a g/kg factor.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your target</h3>
        <p class="mt-1 text-sm text-slate-600">See your daily protein target in grams, the per-meal amount and the calorie contribution. Use a tracking app to stay on target.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for hitting your protein target</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Spread it across meals</h3>
        <p class="mt-1 text-sm text-slate-600">Muscle protein synthesis responds best to 20–40 g of protein per meal, spread across 3–4 meals. A single huge dinner is less effective than balanced distribution.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Include protein at breakfast</h3>
        <p class="mt-1 text-sm text-slate-600">Many people eat very little protein at breakfast. Adding eggs, Greek yoghurt or a protein shake at breakfast helps spread your intake evenly across the day.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use protein supplements wisely</h3>
        <p class="mt-1 text-sm text-slate-600">Whole foods should be the foundation, but a whey or plant protein shake can help bridge the gap when you are short on time or appetite.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/macro-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Macro Calculator</a>
      <a href="/tools/lean-body-mass-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Lean Body Mass Calculator</a>
      <a href="/tools/fat-intake-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Fat Intake Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      let kg, factor;
      if (metric) {
        kg = parseFloat(el('m-w').value);
        factor = parseFloat(el('goal').value);
      } else {
        kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
        factor = parseFloat(el('i-goal').value);
      }
      if (!kg || kg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const protein = kg * factor;
      el('r-protein').textContent = Math.round(protein) + ' g';
      el('r-per-meal').textContent = Math.round(protein / 3) + ' g';
      el('r-cal').textContent = Math.round(protein * 4).toLocaleString() + ' cal';
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['m-w', 'goal', 'i-w', 'i-goal'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
