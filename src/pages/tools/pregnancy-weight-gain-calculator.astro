---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Pregnancy Weight Gain Calculator';
const description =
  'Free pregnancy weight gain calculator. Estimate the recommended weight gain range during pregnancy based on your pre-pregnancy BMI and trimester.';
const intro =
  'Enter your pre-pregnancy height and weight to see the recommended weight gain range for a healthy pregnancy by trimester.';
const category = { id: 'health', name: 'Health & Fitness' };
const faqs = [
  { q: 'How much weight should I gain during pregnancy?', a: 'The recommended total weight gain depends on your pre-pregnancy BMI: underweight (BMI &lt; 18.5): 12.5–18 kg. Normal weight (BMI 18.5–24.9): 11.5–16 kg. Overweight (BMI 25–29.9): 7–11.5 kg. Obese (BMI 30+): 5–9 kg.' },
  { q: 'How does weight gain distribute across trimesters?', a: 'First trimester: 0.5–2 kg total (minimal). Second trimester: ~0.45–0.6 kg per week. Third trimester: ~0.35–0.5 kg per week. The majority of gain happens in the second half of pregnancy.' },
  { q: 'Where does the extra weight go?', a: 'Average weight gain breaks down as: baby ~3.4 kg, placenta ~0.7 kg, amniotic fluid ~0.9 kg, uterine tissue ~1 kg, breast tissue ~0.5 kg, blood volume ~1.5 kg, and maternal fat stores ~2.5 kg.' },
  { q: 'Can I lose weight during pregnancy?', a: 'Weight loss during pregnancy is generally not recommended and may harm the baby. If you are overweight, your provider may recommend minimal weight gain, but not active weight loss.' },
  { q: 'What if I gain too much or too little?', a: 'Gaining too little increases the risk of low birth weight. Gaining too much increases the risk of gestational diabetes, preeclampsia, C-section and postpartum weight retention. Aim for the middle of your recommended range.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex rounded-xl bg-slate-100 p-1 text-sm font-medium">
      <button id="u-metric" class="flex-1 rounded-lg bg-white py-2 text-indigo-700 shadow-sm">Metric</button>
      <button id="u-imperial" class="flex-1 rounded-lg py-2 text-slate-500">Imperial</button>
    </div>

    <div id="metric" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (cm)</span>
        <input id="m-h" type="number" step="any" placeholder="165" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pre-pregnancy weight (kg)</span>
        <input id="m-w" type="number" step="any" placeholder="60" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <div id="imperial" class="mt-4 grid gap-4 sm:grid-cols-2" style="display:none">
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (ft)</span>
        <input id="i-ft" type="number" step="1" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Height (in)</span>
        <input id="i-in" type="number" step="any" placeholder="5" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Pre-pregnancy weight (lb)</span>
        <input id="i-w" type="number" step="any" placeholder="132" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Current week of pregnancy</span>
      <select id="week" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
        <option value="0">Not yet pregnant / trying</option>
        <option value="8">8 weeks (end of 1st trimester)</option>
        <option value="12">12 weeks</option>
        <option value="16">16 weeks</option>
        <option value="20" selected>20 weeks (mid-pregnancy)</option>
        <option value="24">24 weeks</option>
        <option value="28">28 weeks (3rd trimester start)</option>
        <option value="32">32 weeks</option>
        <option value="36">36 weeks</option>
        <option value="40">40 weeks (full term)</option>
      </select></label>

    <div id="result" class="mt-6 hidden">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Recommended total gain</div>
        <div id="r-range" class="mt-1 text-2xl font-bold">—</div>
        <div class="mt-1 text-sm opacity-80">by week 40</div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">BMI category</div><div id="r-bmi" class="mt-1 text-base font-bold text-indigo-600">—</div><div class="text-xs text-slate-400">pre-pregnancy</div></div>
        <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Gain by current week</div><div id="r-cur" class="mt-1 text-xl font-bold text-emerald-600">—</div></div>
      </div>
    </div>
    <p id="hint" class="mt-4 text-center text-sm text-slate-400">Enter your height and pre-pregnancy weight.</p>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About pregnancy weight gain</h2>
    <p class="mt-2 text-slate-600">
      Healthy weight gain during pregnancy supports your baby's growth and development while maintaining your own health. The <a href="https://www.acog.org/womens-health/faqs/weight-gain-during-pregnancy" rel="noopener">American College of Obstetricians and Gynecologists</a> recommends weight gain ranges based on your pre-pregnancy BMI. Gaining too little or too much can increase risks for both mother and baby. This calculator follows the Institute of Medicine (IOM) guidelines published in 2009, which remain the standard in obstetrics. For context on your pre-pregnancy health, check your <a href="/tools/bmi-calculator" class="font-medium text-indigo-600 hover:underline">BMI</a> and <a href="/tools/calorie-calculator" class="font-medium text-indigo-600 hover:underline">Calorie Calculator</a>.
    </p>
    <p class="mt-3 rounded-xl bg-amber-50 p-3 text-sm text-amber-800">For informational purposes only. Follow your healthcare provider's specific recommendations.</p>
  </section>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" role="img" aria-labelledby="pwg-title pwg-desc">
      <title id="pwg-title">Pregnancy weight gain by trimester</title>
      <desc id="pwg-desc">Bar chart showing the recommended weight gain bands across trimesters for different BMI categories.</desc>
      <rect x="60" y="120" width="200" height="40" rx="4" fill="#e2e8f0" /><rect x="60" y="120" width="120" height="40" rx="4" fill="#22c55e" />
      <text x="160" y="110" text-anchor="middle" font-size="11" fill="#64748b">Underweight</text>
      <text x="120" y="148" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">12.5–18</text>

      <rect x="300" y="120" width="200" height="40" rx="4" fill="#e2e8f0" /><rect x="300" y="130" width="180" height="30" rx="4" fill="#6366f1" />
      <text x="400" y="110" text-anchor="middle" font-size="11" fill="#64748b">Normal</text>
      <text x="390" y="148" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">11.5–16</text>

      <rect x="540" y="120" width="200" height="40" rx="4" fill="#e2e8f0" /><rect x="540" y="135" width="140" height="20" rx="4" fill="#f59e0b" />
      <text x="640" y="110" text-anchor="middle" font-size="11" fill="#64748b">Overweight</text>
      <text x="610" y="148" text-anchor="middle" font-size="11" fill="#fff" font-weight="bold">7–11.5</text>
    </svg>
    <figcaption class="text-center text-sm text-slate-500 mt-2">Recommended total weight gain (kg) ranges by pre-pregnancy BMI category</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it works</h2>
    <p class="mt-2 text-slate-600">
      The calculator determines your pre-pregnancy BMI from your height and weight, then applies the IOM guidelines to find your recommended total weight gain range. It also shows the expected gain by your current week of pregnancy. The IOM guidelines are based on large observational studies and are designed to optimise outcomes for both mother and baby. Gaining within the recommended range reduces the risk of gestational diabetes, preeclampsia, C-section delivery, preterm birth and postpartum weight retention.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The guidelines explained</h2>
    <p class="mt-2 text-slate-600">
      <strong>IOM weight gain recommendations by pre-pregnancy BMI:</strong><br>
      Underweight (BMI &lt; 18.5): 12.5–18 kg (28–40 lb)<br>
      Normal (BMI 18.5–24.9): 11.5–16 kg (25–35 lb)<br>
      Overweight (BMI 25–29.9): 7–11.5 kg (15–25 lb)<br>
      Obese (BMI 30+): 5–9 kg (11–20 lb)
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A woman is 165 cm tall and weighed 58 kg before pregnancy. She is currently 24 weeks pregnant. What should her target be?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Height:</span> <span class="text-slate-600">165 cm</span></div>
        <div><span class="font-medium text-slate-700">Pre-pregnancy weight:</span> <span class="text-slate-600">58 kg</span></div>
        <div><span class="font-medium text-slate-700">BMI:</span> <span class="text-slate-600">58 / (1.65)² = <strong>21.3</strong> (normal range)</span></div>
        <div><span class="font-medium text-slate-700">Recommended total gain:</span> <span class="text-slate-600"><strong>11.5–16 kg</strong></span></div>
        <div><span class="font-medium text-slate-700">Expected by week 24:</span> <span class="text-slate-600">~6.5–8 kg gained so far (1st tri: ~1.5 kg, weeks 13–24: ~5–6.5 kg)</span></div>
        <div><span class="font-medium text-slate-700">Target weight range:</span> <span class="text-slate-600">69.5–74 kg at full term</span></div>
      </div>
    </div>
  </section>

  <!-- Persona cards -->
  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🤰</span>
      <h3 class="mt-2 font-semibold text-slate-900">Expectant mother</h3>
      <p class="mt-1 text-sm text-slate-600">Track your weight gain against the recommended range for your BMI to ensure you and your baby are on track for a healthy pregnancy.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🩺</span>
      <h3 class="mt-2 font-semibold text-slate-900">Midwife</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly calculate the recommended weight gain range for patients to discuss during prenatal visits and track progress over time.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👩‍⚕️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Dietitian</h3>
      <p class="mt-1 text-sm text-slate-600">Use the BMI-based ranges to counsel pregnant clients on appropriate weight gain and provide tailored nutrition advice for each trimester.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📊</span>
      <h3 class="mt-2 font-semibold text-slate-900">Birth educator</h3>
      <p class="mt-1 text-sm text-slate-600">Teach expectant parents what healthy weight gain looks like and why the range varies based on starting BMI.</p>
    </div>
  </section>

  <!-- 3-step guide -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter pre-pregnancy stats</h3>
        <p class="mt-1 text-sm text-slate-600">Provide your height and weight from before pregnancy. These determine your starting BMI category.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select current week</h3>
        <p class="mt-1 text-sm text-slate-600">Choose how many weeks pregnant you are now. The calculator shows how much gain is expected by this point.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read your range</h3>
        <p class="mt-1 text-sm text-slate-600">See your recommended total gain range, your BMI category and the expected gain by your current week. Use this as a general guide.</p>
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for healthy pregnancy weight</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Eat nutrient-dense foods</h3>
        <p class="mt-1 text-sm text-slate-600">Focus on whole foods that provide protein, healthy fats, fibre, vitamins and minerals. Your calorie needs increase by roughly 300–450 per day in the second and third trimesters.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Stay active</h3>
        <p class="mt-1 text-sm text-slate-600">Moderate exercise during pregnancy is safe and beneficial for most women. Walking, swimming and prenatal yoga help manage weight gain and improve outcomes.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Hydrate well</h3>
        <p class="mt-1 text-sm text-slate-600">Proper hydration supports increased blood volume, amniotic fluid and nutrient transport. Aim for 8–10 glasses of water per day during pregnancy.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/pregnancy-due-date-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Due Date Calculator</a>
      <a href="/tools/bmi-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">BMI Calculator</a>
      <a href="/tools/calorie-calculator" class="rounded-xl bg-indigo-50 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">Calorie Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    let metric = true;

    function setUnit(isMetric) {
      metric = isMetric;
      el('metric').style.display = isMetric ? 'grid' : 'none';
      el('imperial').style.display = isMetric ? 'none' : 'grid';
      el('u-metric').className = 'flex-1 rounded-lg py-2 ' + (isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      el('u-imperial').className = 'flex-1 rounded-lg py-2 ' + (!isMetric ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500');
      update();
    }

    function update() {
      let cm, kg;
      if (metric) { cm = parseFloat(el('m-h').value); kg = parseFloat(el('m-w').value); }
      else {
        const ft = parseFloat(el('i-ft').value) || 0, inch = parseFloat(el('i-in').value) || 0;
        cm = (ft * 12 + inch) * 2.54; kg = (parseFloat(el('i-w').value) || 0) * 0.45359237;
      }
      if (!cm || !kg || cm <= 0 || kg <= 0) {
        el('result').classList.add('hidden'); el('hint').classList.remove('hidden'); return;
      }
      const bmi = kg / ((cm / 100) ** 2);
      let low, high, cat;
      if (bmi < 18.5) { cat = 'Underweight'; low = 12.5; high = 18; }
      else if (bmi < 25) { cat = 'Normal'; low = 11.5; high = 16; }
      else if (bmi < 30) { cat = 'Overweight'; low = 7; high = 11.5; }
      else { cat = 'Obese'; low = 5; high = 9; }
      const week = parseInt(el('week').value);
      const fraction = Math.min(week / 40, 1);
      const curLow = (low * fraction).toFixed(1);
      const curHigh = (high * fraction).toFixed(1);
      el('r-range').textContent = `${low}–${high} kg (${(low * 2.20462).toFixed(0)}–${(high * 2.20462).toFixed(0)} lb)`;
      el('r-bmi').textContent = `${cat} (BMI ${bmi.toFixed(1)})`;
      el('r-cur').textContent = `${curLow}–${curHigh} kg`;
      el('result').classList.remove('hidden'); el('hint').classList.add('hidden');
    }

    el('u-metric').addEventListener('click', () => setUnit(true));
    el('u-imperial').addEventListener('click', () => setUnit(false));
    ['m-h', 'm-w', 'i-ft', 'i-in', 'i-w', 'week'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
