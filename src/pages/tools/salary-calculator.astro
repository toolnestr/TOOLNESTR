---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Salary Calculator';
const description =
  'Free salary calculator. Convert pay between hourly, daily, weekly, bi-weekly, monthly and ' +
  'yearly. Adjust hours per week and weeks per year. Works in any currency.';
const intro =
  'Enter your pay for any period and see it converted to hourly, weekly, monthly and yearly. Adjust your hours and weeks for accuracy.';
const category = { id: 'finance', name: 'Finance' };
const faqs = [
  { q: 'How do you convert hourly to yearly?', a: 'We multiply your hourly rate by your hours per week and weeks per year. By default that\'s 40 hours × 52 weeks, but you can change both.' },
  { q: 'Does this account for tax?', a: 'No — these are gross (before-tax) figures, because income tax rules differ by country and change often. It shows your pay across different periods.' },
  { q: 'Can I use it for part-time hours?', a: 'Yes. Just set your actual hours per week and the calculator adjusts everything.' },
  { q: 'How do I calculate my effective hourly rate as a salaried employee?', a: 'Divide your annual salary by the product of your hours per week and weeks per year. For example, a $50,000 salary at 40 hours per week for 52 weeks is roughly $24.04 per hour.' },
  { q: 'What is the difference between gross and net pay?', a: 'Gross pay is your total earnings before any deductions (tax, insurance, retirement contributions). Net pay (take-home pay) is what you actually receive after deductions. This calculator shows gross figures only.' },
  { q: 'How should I set my freelance rate based on a salary target?', a: 'As a freelancer, you need to account for taxes, insurance, unpaid time off and business expenses. A common rule is to take your target salary and multiply by 1.5–2 to get your required annual freelance revenue.' },
  { q: 'How do I account for paid vs unpaid time off?', a: 'Change the "Weeks per year" field to reflect your actual paid weeks. If you get 2 weeks paid vacation, keep 52 weeks; if you are unpaid for 2 weeks, set it to 50. This ensures the annual figure matches your real income.' },
  { q: 'What if I work irregular hours each week?', a: 'Use your average weekly hours over a typical month or quarter. If your hours vary significantly, calculate your total annual income from pay stubs and enter it directly as a yearly amount for the most accurate breakdown.' },
  { q: 'Can I use this to set my freelance pricing?', a: 'Yes. Enter your desired annual income as a yearly amount, then look at the hourly rate. Keep in mind that freelancers need to charge higher hourly rates than employees because you cover your own taxes, benefits, insurance, and unpaid downtime.' },
  { q: 'How do benefits affect my total compensation?', a: 'Health insurance, retirement contributions, paid time off, and bonuses can add 20–30% to your total compensation beyond your salary. This calculator shows only base pay — add estimated benefits value separately for a full comparison.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Currency</span>
        <select id="cur" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"><option>$</option><option>€</option><option>£</option><option>₹</option><option>₨</option><option>¥</option><option>₦</option><option>A$</option></select></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Amount</span>
        <input id="amount" type="number" step="any" placeholder="50000" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">This amount is per</span>
        <select id="period" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="hour">Hour</option><option value="day">Day</option><option value="week">Week</option>
          <option value="biweek">Two weeks</option><option value="month">Month</option><option value="year" selected>Year</option>
        </select></label>
      <div class="grid grid-cols-2 gap-3">
        <label class="block"><span class="text-sm font-medium text-slate-700">Hours / week</span>
          <input id="hpw" type="number" step="any" value="40" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
        <label class="block"><span class="text-sm font-medium text-slate-700">Weeks / year</span>
          <input id="wpy" type="number" step="any" value="52" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      </div>
    </div>

    <div id="result" class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Hourly</div><div id="r-hour" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Daily</div><div id="r-day" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Weekly</div><div id="r-week" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Bi-weekly</div><div id="r-biweek" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-sm text-slate-500">Monthly</div><div id="r-month" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-sm opacity-80">Yearly</div><div id="r-year" class="mt-1 text-lg font-bold">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How salary conversion works</h2>
    <p class="mt-2 text-slate-600">
      Salary conversion works by first calculating your annual (yearly) pay, then dividing by the
      appropriate periods. The core formula is
      <span class="font-mono">Annual = Hourly rate &times; Hours per week &times; Weeks per year</span>.
      From the annual figure, all other periods are derived:
      <span class="font-mono">Monthly = Annual / 12</span>,
      <span class="font-mono">Weekly = Annual / Weeks per year</span>,
      <span class="font-mono">Daily = Weekly / 5</span>, and
      <span class="font-mono">Hourly = Annual / (Hours per week &times; Weeks per year)</span>.
    </p>
    <p class="mt-3 text-slate-600">
      The calculator handles six common pay periods — hourly, daily, weekly, bi-weekly, monthly, and
      yearly — and instantly converts between them. You can adjust hours per week and weeks per year to
      match part-time schedules, unpaid leave, or freelance availability for accurate results.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">You earn $25 per hour working 40 hours per week, 52 weeks per year.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Hourly rate:</span> <span class="text-slate-600">$25.00</span></div>
        <div><span class="font-medium text-slate-700">Hours per week:</span> <span class="text-slate-600">40</span></div>
        <div><span class="font-medium text-slate-700">Weeks per year:</span> <span class="text-slate-600">52</span></div>
        <div><span class="font-medium text-slate-700">Yearly salary:</span> <span class="text-slate-600">$52,000</span></div>
        <div><span class="font-medium text-slate-700">Monthly:</span> <span class="text-slate-600">$4,333.33</span></div>
        <div><span class="font-medium text-slate-700">Weekly:</span> <span class="text-slate-600">$1,000</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About this salary calculator</h2>
    <p class="mt-2 text-slate-600">
      Job offers and pay rates come in all shapes — hourly, monthly, yearly. This calculator
      converts any of them into every other period so you can <a href="https://www.bls.gov/oes/" rel="noopener">compare offers fairly</a> and understand
      exactly what you earn. Adjust hours per week and weeks per year to match your real schedule. For an estimate of what you'll take home after tax, try our <a href="/tools/tax-calculator" class="font-medium text-indigo-600 hover:underline">Tax Calculator</a>.
    </p>
      <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
      <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
        <li>Enter your pay amount and choose what period it applies to (hourly, monthly, yearly, etc.).</li>
        <li>Adjust your hours per week and weeks per year to match your actual work schedule.</li>
        <li>See your pay instantly converted across every common pay period.</li>
        <li>Compare job offers or set freelance rates with confidence.</li>
      </ol>

      <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
      <p class="mt-2 text-slate-600">
        Use this calculator when you're comparing job offers with different pay structures — for example, one listed as hourly and another as a yearly salary. It is also essential for freelancers who need to convert project fees into an equivalent hourly or annual rate, and for employees negotiating a raise who want to understand the annual impact of a proposed hourly increase.
      </p>

      <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
        <li>Set your actual hours per week — if you work 37.5 hours, don't leave the default at 40.</li>
        <li>Adjust weeks per year to account for unpaid vacation; 50 weeks is a common conservative estimate for freelancers.</li>
        <li>Remember that benefits (health insurance, retirement matching, paid time off) add 20–30% to total compensation beyond the salary figure.</li>
      </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What different salary ranges mean</h2>
    <p class="mt-2 text-slate-600">Salary ranges vary widely by industry, experience, and location. The bands below give a general sense of what different annual salaries mean in the US market.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Under $20k</span><span class="text-slate-400">Part-time / entry level</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:15%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">$20k–$40k</span><span class="text-slate-400">Support / administrative roles</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:30%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">$40k–$60k</span><span class="text-slate-400">Early career professional</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:45%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">$60k–$90k</span><span class="text-slate-400">Mid-career specialist</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-orange-500" style="width:65%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">$90k–$130k</span><span class="text-slate-400">Senior / management</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-red-500" style="width:85%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">$130k+</span><span class="text-slate-400">Executive / director level</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-purple-500" style="width:100%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💼</span>
      <h3 class="mt-2 font-semibold text-slate-900">Job Seeker</h3>
      <p class="mt-1 text-sm text-slate-600">Compare offers with different pay structures — hourly vs salary, or monthly vs annual — to see which role truly pays more.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🆓</span>
      <h3 class="mt-2 font-semibold text-slate-900">Freelancer</h3>
      <p class="mt-1 text-sm text-slate-600">Convert project fees into hourly or annual equivalents to ensure your freelance rates cover your costs and match your income goals.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">👔</span>
      <h3 class="mt-2 font-semibold text-slate-900">HR Manager</h3>
      <p class="mt-1 text-sm text-slate-600">Quickly convert posted salaries into different periods for job listings, internal equity comparisons, and offer letter preparation.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">💰</span>
      <h3 class="mt-2 font-semibold text-slate-900">Negotiator</h3>
      <p class="mt-1 text-sm text-slate-600">A small hourly increase can mean thousands more per year. Use this calculator to quantify the annual impact of a rate change before you negotiate.</p>
    </div>
  </section>

  <section class="mt-10 overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500"><tr><th class="p-3">Industry</th><th class="p-3">Median annual salary</th><th class="p-3">Typical hourly equivalent</th></tr></thead>
      <tbody class="divide-y divide-slate-100 text-slate-700">
        <tr><td class="p-3 font-medium">Technology</td><td class="p-3">$105,000</td><td class="p-3">$50.48</td></tr>
        <tr><td class="p-3 font-medium">Healthcare</td><td class="p-3">$72,000</td><td class="p-3">$34.62</td></tr>
        <tr><td class="p-3 font-medium">Finance & Insurance</td><td class="p-3">$76,000</td><td class="p-3">$36.54</td></tr>
        <tr><td class="p-3 font-medium">Education</td><td class="p-3">$55,000</td><td class="p-3">$26.44</td></tr>
        <tr><td class="p-3 font-medium">Retail & Hospitality</td><td class="p-3">$32,000</td><td class="p-3">$15.38</td></tr>
        <tr><td class="p-3 font-medium">Manufacturing</td><td class="p-3">$48,000</td><td class="p-3">$23.08</td></tr>
        <tr><td class="p-3 font-medium">Construction</td><td class="p-3">$52,000</td><td class="p-3">$25.00</td></tr>
        <tr><td class="p-3 font-medium">Legal</td><td class="p-3">$92,000</td><td class="p-3">$44.23</td></tr>
      </tbody>
    </table>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the salary calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter your amount</h3>
        <p class="mt-1 text-sm text-slate-600">Type any pay figure and select the period it applies to — hourly, daily, weekly, monthly, or yearly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Adjust your schedule</h3>
        <p class="mt-1 text-sm text-slate-600">Set your actual hours per week and weeks per year to get accurate conversions for your specific situation.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Compare and decide</h3>
        <p class="mt-1 text-sm text-slate-600">View all pay periods side by side and use the numbers to compare offers, set rates, or plan your finances.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for accurate salary comparison</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Include all compensation components</h3>
        <p class="mt-1 text-sm text-slate-600">Your total compensation includes more than base salary — factor in bonuses, commissions, overtime, and the value of benefits like health insurance and retirement matching for a complete picture.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Account for unpaid leave</h3>
        <p class="mt-1 text-sm text-slate-600">If you have unpaid time off, reduce your weeks per year accordingly. Freelancers should use 48–50 weeks to account for holidays, sick days, and gaps between projects.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Compare cost of living</h3>
        <p class="mt-1 text-sm text-slate-600">A $70,000 salary in a low-cost city may go further than $90,000 in an expensive metro area. Always factor local living costs when comparing offers across locations.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const cur = el('cur');
    const fmt = (n) => cur.value + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    function update() {
      const amount = parseFloat(el('amount').value);
      const hpw = parseFloat(el('hpw').value) || 0;
      const wpy = parseFloat(el('wpy').value) || 0;
      const dpw = 5;
      if (isNaN(amount) || hpw <= 0 || wpy <= 0) { ['hour', 'day', 'week', 'biweek', 'month', 'year'].forEach((p) => (el('r-' + p).textContent = '—')); return; }
      let annual;
      switch (el('period').value) {
        case 'hour': annual = amount * hpw * wpy; break;
        case 'day': annual = amount * dpw * wpy; break;
        case 'week': annual = amount * wpy; break;
        case 'biweek': annual = amount * (wpy / 2); break;
        case 'month': annual = amount * 12; break;
        default: annual = amount;
      }
      el('r-hour').textContent = fmt(annual / (hpw * wpy));
      el('r-day').textContent = fmt(annual / (dpw * wpy));
      el('r-week').textContent = fmt(annual / wpy);
      el('r-biweek').textContent = fmt(annual / (wpy / 2));
      el('r-month').textContent = fmt(annual / 12);
      el('r-year').textContent = fmt(annual);
    }
    ['cur', 'amount', 'period', 'hpw', 'wpy'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
