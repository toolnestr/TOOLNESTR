---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'DIY Shed Cost Calculator';
const description = 'Estimate the material cost to build a DIY storage shed from its floor size and a per-square-foot cost range for basic, mid-range or premium construction.';
const intro = 'Estimate the material cost to build a DIY shed, from its floor size and build quality.';
const category = { id: 'construction', name: 'Construction & Home Improvement', emoji: '🏠' };
const faqs = [
  { q: 'How much does it cost to build a DIY shed?', a: 'A rough materials-only estimate runs about $15-25 per square foot for a basic shed (simple framing, OSB siding, asphalt shingles), $25-40 for mid-range (better siding, a proper foundation, upgraded roofing), and $40-70+ for premium finishes. An 8×10 ft (80 sq ft) basic shed: 80 × $20 ≈ $1,600 in materials.' },
  { q: 'Does this include labor?', a: 'No — this is a materials-only estimate assuming DIY construction. Hiring a contractor to build the same shed typically adds 50-100% or more on top of material costs, depending on your area and the contractor.' },
  { q: 'What drives the cost per square foot up or down?', a: 'Foundation type (gravel pad vs. concrete slab), siding material (OSB/T1-11 vs. engineered wood or vinyl), roofing (asphalt shingles vs. metal), and any electrical or windows all push cost toward the higher end of a range. A bare-bones storage shed with no windows or power stays near the low end.' },
  { q: 'Do I need a permit to build a shed?', a: 'Many jurisdictions exempt small sheds (often under 100-200 square feet) from permitting, but this varies widely by city and county. Always check your local building department before building, especially for anything with electrical, plumbing, or a permanent foundation.' },
];
const howTo = {
  name: 'How to estimate DIY shed material cost',
  steps: [
    { name: 'Set the shed size', text: 'Enter the shed length and width in feet.' },
    { name: 'Pick a build tier', text: 'Choose basic, mid-range, or premium finishes.' },
    { name: 'Check for permits', text: 'Confirm your local building department rules before building.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Shed length (ft)</span>
        <input id="len" type="number" step="any" placeholder="10" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Shed width (ft)</span>
        <input id="width" type="number" step="any" placeholder="8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Build quality</span>
        <select id="tier" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="20" selected>Basic ($15-25/ft²)</option>
          <option value="32">Mid-range ($25-40/ft²)</option>
          <option value="55">Premium ($40-70+/ft²)</option>
        </select></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated material cost</div>
        <div id="r-cost" class="mt-1 text-2xl font-bold">—</div>
        <div id="r-note" class="text-sm opacity-80"></div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Floor area</div><div id="r-area" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="200" viewBox="0 0 800 200" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sc-title sc-desc">
      <title id="sc-title">Shed cost from floor area and build tier</title>
      <desc id="sc-desc">A simple storage shed with the cost-per-square-foot formula</desc>
      <rect x="80" y="100" width="160" height="80" fill="#fde68a" stroke="#a16207" stroke-width="1.5" />
      <polygon points="70,100 250,100 160,55" fill="#dc2626" stroke="#991b1b" stroke-width="1.5" />
      <rect x="145" y="140" width="30" height="40" fill="#78350f" />
      <text x="160" y="195" font-size="12" fill="#475569" text-anchor="middle" font-family="system-ui,sans-serif">floor area</text>
      <rect x="420" y="55" width="330" height="100" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
      <text x="440" y="84" font-size="13" font-weight="bold" fill="#1e293b" font-family="system-ui,sans-serif">Materials cost</text>
      <text x="440" y="110" font-size="12" fill="#475569" font-family="system-ui,sans-serif">cost = floor area &times; $/ft&sup2;</text>
      <text x="440" y="132" font-size="12" fill="#475569" font-family="system-ui,sans-serif">materials only, DIY labor assumed</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Build quality (foundation, siding, roofing) sets where in the range you land.</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the DIY shed cost calculator works</h2>
    <p class="mt-2 text-slate-600">
      Shed cost scales with floor area, since the framing, siding, and roofing needed all grow with the footprint. A simplified estimate multiplies the shed's square footage by a cost-per-square-foot figure, and that figure depends heavily on build quality: a basic shed with simple stick framing, OSB or T1-11 siding, and asphalt shingles runs roughly $15 to $25 per square foot in materials; a mid-range build with better siding, a proper foundation, and upgraded roofing runs $25 to $40; and a premium build with high-end finishes, windows, and possibly electrical can run $40 to $70 or more.
    </p>
    <p class="mt-3 text-slate-600">
      This is a materials-only estimate, assuming you supply the labor yourself. Hiring a contractor to build the same structure typically adds 50 to 100% or more on top of material costs, varying widely by region and contractor. The foundation type is one of the biggest cost swings within any tier — a simple gravel pad or skid foundation is far cheaper than a poured concrete slab — along with siding material, roofing choice, and whether the shed includes windows or electrical wiring.
    </p>
    <p class="mt-3 text-slate-600">
      Before building, check whether your shed needs a permit: many jurisdictions exempt small sheds, often under 100 to 200 square feet, from permitting requirements, but this threshold and the rules around it vary significantly by city and county. Always confirm with your local building department, especially if you're adding electrical, plumbing, or a permanent foundation.
    </p>
    <p class="mt-3 text-xs text-slate-400">Cost tiers reflect typical DIY materials pricing patterns reported in National Association of Home Builders (NAHB) cost-per-square-foot surveys for accessory structures.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Set the shed size</h3>
        <p class="mt-1 text-sm text-slate-600">Length and width in feet.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Pick a build tier</h3>
        <p class="mt-1 text-sm text-slate-600">Basic, mid-range, or premium finishes.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Check for permits</h3>
        <p class="mt-1 text-sm text-slate-600">Confirm your local rules before building.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Floor area</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= L &times; W</span>. A 10×8 ft shed: 10 × 8 = <strong>80 ft²</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Basic build cost</p>
        <p class="mt-1 text-slate-600">
          <span class="font-mono">= area &times; $20/ft&sup2;</span> = 80 × 20 = <strong>$1,600</strong>.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="font-semibold text-slate-900">Premium build cost</p>
        <p class="mt-1 text-slate-600">
          Same shed, premium tier: 80 × $55 = <strong>$4,400</strong>.
        </p>
      </div>
    </div>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">A 12×16 ft mid-range workshop shed.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Area:</span> <span class="text-slate-600">12 × 16 = 192 ft²</span></div>
        <div><span class="font-medium text-slate-700">Rate:</span> <span class="text-slate-600">$32/ft² (mid-range)</span></div>
        <div><span class="font-medium text-slate-700">Materials:</span> <span class="text-slate-600">192 × 32 = <strong>$6,144</strong></span></div>
        <div><span class="font-medium text-slate-700">Note:</span> <span class="text-slate-600">add 50-100% if hiring a contractor</span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Where this calculator gets used</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🧰</span>
        <h3 class="mt-2 font-semibold text-slate-900">Backyard storage shed</h3>
        <p class="mt-1 text-sm text-slate-600">The most common use case: a small basic-tier shed for lawn equipment and seasonal storage. These are usually under 100 square feet to stay under many jurisdictions' permit thresholds.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🪚</span>
        <h3 class="mt-2 font-semibold text-slate-900">Workshop or hobby shed</h3>
        <p class="mt-1 text-sm text-slate-600">Mid-range builds with a proper foundation, windows, and often electrical service for power tools. These run larger, typically 120-200 square feet, and justify the higher per-square-foot rate.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">🏡</span>
        <h3 class="mt-2 font-semibold text-slate-900">Backyard studio or office</h3>
        <p class="mt-1 text-sm text-slate-600">Premium-tier builds with insulation, finished interiors, and sometimes plumbing or HVAC. These blur the line with a small accessory dwelling unit (ADU) and often do require a permit.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <span class="text-2xl">💰</span>
        <h3 class="mt-2 font-semibold text-slate-900">Budgeting DIY vs. contractor</h3>
        <p class="mt-1 text-sm text-slate-600">Homeowners use this materials-only figure as a baseline, then add 50-100% to estimate what a contractor-built shed of the same size and tier would cost, to decide whether DIY is worth the time investment.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      An 8 ft by 10 ft basic storage shed — one of the most-built shed sizes because it stays under many towns' 120 square foot permit exemption threshold — has 80 square feet of floor area. At the basic-tier rate of $20 per square foot, that's $1,600 in materials: framing lumber, OSB siding, asphalt shingles, and basic hardware, with no electrical or plumbing included.
    </p>
    <p class="mt-3 text-slate-600">
      Step up to a 10 ft by 12 ft mid-range workshop shed and the numbers change on two fronts at once: floor area grows to 120 square feet, and the per-square-foot rate jumps to $32 for the better siding, real foundation, and upgraded roofing. That combination pushes materials cost to $3,840 — more than double the basic 8×10 shed, driven roughly half by size and half by build quality.
    </p>
    <p class="mt-3 text-slate-600">
      At the high end, a 14 ft by 20 ft premium studio shed — 280 square feet — at $55 per square foot in materials comes to $15,400. A structure this size, especially with premium finishes, windows, and likely electrical, is large enough that most jurisdictions will require a building permit and possibly a setback survey, so the material cost is only part of the planning involved.
    </p>
    <p class="mt-3 text-slate-600">
      A useful sanity check across all three sizes: doubling the floor area roughly doubles the material cost at a fixed tier, but moving up a tier on the same footprint typically adds 50-150% to the bill. That means, dollar for dollar, choosing a smaller shed at a higher build quality often gets you a more durable, better-finished structure than a larger shed built to the bare minimum.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"The cost-per-square-foot estimate is my total budget." <strong class="text-slate-900">It's materials only.</strong> This figure assumes you're supplying your own labor. A contractor-built shed of the same size and quality typically costs 50-100% more once labor, delivery, and overhead are added.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A shed under the permit-exempt size doesn't need to follow any rules." <strong class="text-slate-900">Not always true.</strong> Even permit-exempt sheds are often still subject to setback rules from property lines, height limits, and HOA restrictions. Exemption from a building permit does not mean exemption from zoning rules.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related calculators</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/framing-stud-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Framing Stud Calculator</a>
      <a href="/tools/roofing-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Roofing Calculator</a>
      <a href="/tools/concrete-slab-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">Concrete Slab Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const L = parseFloat(el('len').value);
      const W = parseFloat(el('width').value);
      const rate = parseFloat(el('tier').value);
      if (!(L > 0 && W > 0)) { el('results').classList.add('hidden'); return; }
      const area = L * W;
      const cost = area * rate;

      el('r-cost').textContent = '$' + Math.round(cost).toLocaleString();
      el('r-note').textContent = area.toFixed(0) + ' ft² at $' + rate + '/ft², materials only';
      el('r-area').textContent = area.toFixed(0) + ' ft²';
      el('results').classList.remove('hidden');
    }

    ['len', 'width'].forEach((id) => el(id).addEventListener('input', update));
    el('tier').addEventListener('change', update);
  </script>
</ToolLayout>
