---
import ToolLayout from '../../layouts/ToolLayout.astro';
import SubjectToolLibs from '../../components/SubjectToolLibs.astro';

const title = 'Parts Per Million (PPM) Calculator';
const description = 'PPM calculator with a live 3D beaker and charts. Find parts per million from solute and solution amounts, and convert between ppm, percent, ppb and mg/L.';
const intro = 'Work out ppm from a solute and solution amount, or convert between ppm, percent, ppb and mg/L. A live 3D beaker and charts put these tiny concentrations in perspective.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };
const faqs = [
  { q: 'What is parts per million (ppm)?', a: 'PPM measures a very small concentration: the number of parts of solute per one million parts of solution. 1 ppm is one milligram in one kilogram, or (for dilute water solutions) one milligram per litre.' },
  { q: 'How do I calculate ppm?', a: 'ppm = (mass of solute ÷ mass of solution) × 1,000,000. For a dilute aqueous solution where 1 L weighs ≈ 1 kg, this is the same as milligrams of solute per litre (mg/L).' },
  { q: 'How do ppm and percent relate?', a: 'Percent is parts per hundred, ppm is parts per million, so 1% = 10,000 ppm and 1 ppm = 0.0001%. Divide ppm by 10,000 to get percent.' },
  { q: 'What is ppb?', a: 'Parts per billion — a thousand times smaller than ppm. 1 ppm = 1000 ppb. It is used for ultra-trace contaminants like some heavy metals in drinking water.' },
  { q: 'Why is 1 ppm ≈ 1 mg/L for water?', a: 'One litre of dilute water solution has a mass of about 1 kg = 1,000,000 mg. One milligram in that litre is therefore one part per million by mass — so mg/L and ppm coincide for dilute aqueous solutions.' },
  { q: 'Where is ppm used?', a: 'Water quality (chlorine, nitrates, hardness), air quality (CO₂, pollutants), food safety limits, and calibration standards — anywhere concentrations are too small to express conveniently in percent.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to use the PPM Calculator',
    description: 'Calculate parts per million from solute and solution amounts, or convert between ppm, percent, ppb and mg/L.',
    step: [
      { '@type': 'HowToStep', name: 'Pick a mode', text: 'Choose "From amounts" to compute ppm, or "Convert units" to move between ppm, %, ppb and mg/L.' },
      { '@type': 'HowToStep', name: 'Enter the values', text: 'Type the solute and solution amounts (same unit), or a value in any concentration unit.' },
      { '@type': 'HowToStep', name: 'Read the result', text: 'The ppm and all equivalent units appear instantly.' },
    ],
  })} />

  <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">
    <span class="h-2 w-2 rounded-full bg-green-500"></span> Chemistry
  </span>

  <style is:global>
    @media print {
      .no-print { display: none !important; }
      a[href]::after { content: none !important; }
      section { break-inside: avoid; }
    }
  </style>

  <!-- ============ CALCULATOR ============ -->
  <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-amt" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">From amounts</button>
      <button id="mode-conv" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Convert units</button>
    </div>

    <div id="amt-fields" class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Solute amount</span>
        <input id="solute" type="number" step="any" placeholder="e.g. mg or g" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Solution amount <span class="text-slate-400">(same unit)</span></span>
        <input id="soln" type="number" step="any" placeholder="e.g. mg or g" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="conv-fields" class="hidden gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Value</span>
        <input id="conv-val" type="number" step="any" placeholder="enter a concentration" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Unit</span>
        <select id="conv-unit" class="mt-1 w-full rounded-xl border border-slate-300 bg-white p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="ppm">ppm</option>
          <option value="percent">percent (%)</option>
          <option value="ppb">ppb</option>
          <option value="mgl">mg/L (dilute water)</option>
        </select></label>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">ppm</div><div id="r-ppm" class="mt-1 text-lg font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">percent</div><div id="r-pct" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">ppb</div><div id="r-ppb" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-4 text-center"><div class="text-xs text-slate-500">mg/L (water)</div><div id="r-mgl" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <p id="ppm-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ INTERACTIVE 3D BEAKER ============ -->
  <section class="mt-8 no-print">
    <h2 class="text-lg font-bold text-slate-900">Live 3D — how tiny is a ppm?</h2>
    <p class="mt-1 text-sm text-slate-500">Slide the concentration and watch the dissolved particles: even at hundreds of ppm the solute is a scattering of specks in the water. Drag to orbit.</p>
    <label class="mt-3 block">
      <span class="flex items-center justify-between text-sm font-medium text-slate-700">Concentration <span id="out-bppm" class="font-mono text-green-600">250 ppm</span></span>
      <input id="b-ppm" type="range" min="0" max="1000" step="5" value="250" class="mt-2 w-full accent-green-600" />
    </label>
    <div class="mt-2 rounded-xl bg-green-50 p-3 text-center text-sm text-green-700">= <span id="out-bpct" class="font-mono font-bold">0.025%</span> &nbsp;= <span id="out-bmgl" class="font-mono font-bold">250 mg/L</span></div>
    <div id="beaker3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
    <p id="beaker3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
  </section>

  <!-- ============ LIVE CHARTS ============ -->
  <section class="mt-10 no-print">
    <h2 class="text-lg font-bold text-slate-900">Concentration scale</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">The unit ladder — %, ppm, ppb (log scale)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ladder"></canvas></div>
      </figure>
      <figure>
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Solute (mg) per litre of water vs ppm — a straight line</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-mgl"></canvas></div>
      </figure>
      <figure class="sm:col-span-2">
        <figcaption class="mb-1 text-sm font-semibold text-slate-700">Typical ppm levels around us (log scale)</figcaption>
        <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:260px;"><canvas id="chart-compare"></canvas></div>
      </figure>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How ppm is calculated</h2>
    <p class="mt-2 text-slate-600"><strong>The core idea in one line:</strong> ppm is just a percentage scaled for tiny amounts — parts per million instead of parts per hundred.</p>
    <p class="mt-3 text-slate-600">The definition and its unit conversions:</p>
    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      <li><span class="font-mono text-slate-800">ppm = (solute ÷ solution) × 1,000,000</span> — same unit top and bottom.</li>
      <li><span class="font-mono text-slate-800">1% = 10,000 ppm</span> &nbsp;and&nbsp; <span class="font-mono text-slate-800">1 ppm = 0.0001%</span></li>
      <li><span class="font-mono text-slate-800">1 ppm = 1000 ppb</span></li>
      <li><span class="font-mono text-slate-800">1 ppm ≈ 1 mg/L</span> &nbsp;for a dilute water solution (1 L ≈ 1 kg).</li>
    </ul>

    <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 1 — chlorine in a pool</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> 6 g of chlorine is dissolved in 3000 L of pool water (≈ 3000 kg). What is the concentration in ppm?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Convert:</span> <span class="text-slate-600">6 g = 6000 mg; 3000 L ≈ 3,000,000 g</span></div>
        <div><span class="font-medium text-slate-700">ppm:</span> <span class="text-slate-600">(6 ÷ 3,000,000) × 10⁶ = 2 ppm</span></div>
        <div class="sm:col-span-2 text-slate-600">Equivalently 6000 mg ÷ 3000 L = 2 mg/L = 2 ppm — a typical pool chlorine level.</div>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example 2 — percent to ppm</h3>
      <p class="mt-1 text-sm text-slate-600"><strong>Given:</strong> a label says 0.05%. What is that in ppm and ppb?</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">ppm:</span> <span class="text-slate-600">0.05 × 10,000 = 500 ppm</span></div>
        <div><span class="font-medium text-slate-700">ppb:</span> <span class="text-slate-600">500 × 1000 = 500,000 ppb</span></div>
      </div>
    </div>
  </section>

  <!-- ============ STANDALONE 3D DIAGRAMS ============ -->
  <section class="mt-12 no-print">
    <h2 class="text-xl font-bold text-slate-900">Two ideas that trip students up</h2>
    <div class="mt-4 grid gap-6 sm:grid-cols-2">
      <div>
        <div id="diag-scale" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">1. One red in a million</h3>
        <p class="mt-1 text-sm text-slate-600">A cube packed with particles, one of them red — that lone red among the crowd is roughly what "one part per million" looks like. ppm describes genuinely trace amounts.</p>
      </div>
      <div>
        <div id="diag-mgl" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
        <h3 class="mt-3 font-semibold text-slate-900">2. ppm = mg per litre (for water)</h3>
        <p class="mt-1 text-sm text-slate-600">Because a litre of dilute solution weighs about a kilogram (a million milligrams), one milligram dissolved in it is one part per million — so mg/L and ppm read the same.</p>
      </div>
    </div>
  </section>

  <!-- ============ COMPARISON TABLE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">The concentration unit ladder</h2>
    <p class="mt-1 text-sm text-slate-600">Each step down is 100× smaller than percent-to-ppm, then 1000× to ppb.</p>
    <div class="mt-3 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full table-fixed text-center text-xs sm:text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-2 py-2.5 text-left font-semibold sm:px-3">Concentration</th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">In percent</th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">In ppm</th>
            <th class="px-2 py-2.5 font-semibold sm:px-3">In ppb</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700 tabular-nums">
          <tr><td class="px-2 py-2.5 text-left sm:px-3">1%</td><td class="px-2 py-2.5 sm:px-3">1</td><td class="px-2 py-2.5 sm:px-3">10,000</td><td class="px-2 py-2.5 sm:px-3">10,000,000</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">0.1%</td><td class="px-2 py-2.5 sm:px-3">0.1</td><td class="px-2 py-2.5 sm:px-3">1,000</td><td class="px-2 py-2.5 sm:px-3">1,000,000</td></tr>
          <tr class="bg-indigo-50 font-semibold text-indigo-700"><td class="px-2 py-2.5 text-left sm:px-3">0.005% ★</td><td class="px-2 py-2.5 sm:px-3">0.005</td><td class="px-2 py-2.5 sm:px-3">50</td><td class="px-2 py-2.5 sm:px-3">50,000</td></tr>
          <tr><td class="px-2 py-2.5 text-left sm:px-3">0.0001%</td><td class="px-2 py-2.5 sm:px-3">0.0001</td><td class="px-2 py-2.5 sm:px-3">1</td><td class="px-2 py-2.5 sm:px-3">1,000</td></tr>
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-slate-400">★ 50 ppm is around the EPA limit for nitrate-related figures and many taste thresholds. ppm = % × 10,000; ppb = ppm × 1000.</p>
  </section>

  <!-- ============ REAL-WORLD CONTEXT ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Where ppm actually matters</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">💧 Water quality</h3>
        <p class="mt-1 text-sm text-slate-600">Chlorine, fluoride, nitrates, lead and hardness are all reported in ppm (mg/L). Regulatory limits — like ~10 ppm nitrate in drinking water — are set and tested in these units.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🌫️ Air quality</h3>
        <p class="mt-1 text-sm text-slate-600">CO₂ (~420 ppm in air today), carbon monoxide and ozone are quoted in ppm. Indoor CO₂ above ~1000 ppm is a common ventilation trigger.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="font-semibold text-slate-900">🧪 Labs &amp; food safety</h3>
        <p class="mt-1 text-sm text-slate-600">Calibration standards, trace additives and contaminant limits in food are prepared and checked in ppm and ppb, usually by serial dilution from a stock.</p>
      </div>
    </div>
  </section>

  <!-- ============ MISCONCEPTIONS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"1 ppm = 1%."</p>
        <p class="mt-1 text-sm text-slate-600">1 ppm = 0.0001%. Percent is per hundred, ppm is per million — a factor of 10,000 apart. 1% is 10,000 ppm.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"ppm always equals mg/L."</p>
        <p class="mt-1 text-sm text-slate-600">Only for dilute water solutions, where 1 L ≈ 1 kg. For dense liquids or gases the density differs, so the mg/L ↔ ppm shortcut no longer holds exactly.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"Solute and solution can be in different units."</p>
        <p class="mt-1 text-sm text-slate-600">The ratio must be dimensionless, so both amounts need the same unit before multiplying by a million. Convert grams to milligrams (or vice versa) first.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-red-600">"ppb is bigger than ppm."</p>
        <p class="mt-1 text-sm text-slate-600">The opposite — ppb is 1000× smaller. A concentration of 5 ppm equals 5000 ppb. Smaller "per" means a smaller slice.</p>
      </div>
    </div>
  </section>

  <!-- ============ FORMULA SOURCES ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Formula sources &amp; further reading</h2>
    <p class="mt-2 text-slate-600">ppm and trace concentration units are standard general chemistry, traceable to:</p>
    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      <li>• <strong>OpenStax, <em>Chemistry 2e</em></strong> — §3.4 "Other Units for Solution Concentrations" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/3-4-other-units-for-solution-concentrations" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a></li>
      <li>• <strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 13, Concentration units (ppm and ppb).</li>
      <li>• <strong>US EPA</strong> — National Primary Drinking Water Regulations (contaminant limits in mg/L = ppm).</li>
    </ul>
    <p class="mt-3 text-xs text-slate-400">1 ppm = 0.0001% = 1000 ppb ≈ 1 mg/L (dilute water). Results are rounded for display.</p>
  </section>

  <!-- ============ HOW TO USE ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">How to use this calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Choose a mode</h3>
        <p class="mt-1 text-sm text-slate-600">"From amounts" computes ppm from solute and solution; "Convert units" moves between ppm, %, ppb and mg/L.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter values</h3>
        <p class="mt-1 text-sm text-slate-600">Use the same unit for solute and solution, or type a value and pick its unit.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read every unit</h3>
        <p class="mt-1 text-sm text-slate-600">ppm, percent, ppb and mg/L all display together, with a 3D beaker for scale.</p>
      </div>
    </div>
  </section>

  <!-- ============ RELATED TOOLS ============ -->
  <section class="mt-12">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <a href="/tools/percent-concentration-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🧴</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Percent Concentration Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">w/v, w/w and v/v percent.</p>
      </a>
      <a href="/tools/dilution-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">💧</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Dilution Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">C₁V₁ = C₂V₂ — solve for any variable.</p>
      </a>
      <a href="/tools/molarity-calculator" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-sm">
        <span class="text-lg">🧪</span>
        <h3 class="mt-1 text-sm font-semibold text-slate-900">Molarity Calculator</h3>
        <p class="mt-0.5 text-xs text-slate-500">M = mol/L — solve for any variable.</p>
      </a>
    </div>
  </section>

  <!-- Libraries: Three.js + Chart.js + shared subject kit (window.STK) -->
  <SubjectToolLibs />

  <script is:inline>
  (function () {
    'use strict';
    const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
    const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

    // ================= CALCULATOR =================
    let mode = 'amt';
    function switchMode(m) {
      mode = m;
      el('mode-amt').className = m === 'amt' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
      el('mode-conv').className = m === 'conv' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
      el('amt-fields').className = m === 'amt' ? 'grid gap-4 sm:grid-cols-2' : 'hidden';
      el('conv-fields').className = m === 'conv' ? 'grid gap-4 sm:grid-cols-2' : 'hidden gap-4 sm:grid-cols-2';
      update();
    }
    function show(ppm) {
      if (!isFinite(ppm)) { ['r-ppm', 'r-pct', 'r-ppb', 'r-mgl'].forEach((id) => (el(id).textContent = '—')); return; }
      el('r-ppm').textContent = fmt(ppm);
      el('r-pct').textContent = fmt(ppm / 10000) + '%';
      el('r-ppb').textContent = fmt(ppm * 1000);
      el('r-mgl').textContent = fmt(ppm) + ' mg/L';
    }
    function update() {
      el('ppm-err').textContent = '';
      ['r-ppm', 'r-pct', 'r-ppb', 'r-mgl'].forEach((id) => (el(id).textContent = '—'));
      if (mode === 'amt') {
        const solute = parseFloat(el('solute').value), soln = parseFloat(el('soln').value);
        if (isNaN(solute) || isNaN(soln)) return;
        if (soln <= 0) { el('ppm-err').textContent = 'Solution amount must be greater than zero.'; return; }
        show(solute / soln * 1e6);
      } else {
        const val = parseFloat(el('conv-val').value); if (isNaN(val)) return;
        const unit = el('conv-unit').value;
        let ppm;
        if (unit === 'ppm') ppm = val;
        else if (unit === 'percent') ppm = val * 10000;
        else if (unit === 'ppb') ppm = val / 1000;
        else ppm = val; // mg/L ≈ ppm
        show(ppm);
      }
    }
    el('mode-amt').addEventListener('click', () => switchMode('amt'));
    el('mode-conv').addEventListener('click', () => switchMode('conv'));
    ['solute', 'soln', 'conv-val'].forEach((id) => el(id).addEventListener('input', update));
    el('conv-unit').addEventListener('change', update);

    // ================= 3D + charts =================
    const charts = {};
    let beaker = null;
    function onBChange() {
      const ppm = parseFloat(el('b-ppm').value);
      el('out-bppm').textContent = ppm.toFixed(0) + ' ppm';
      el('out-bpct').textContent = fmt(ppm / 10000) + '%';
      el('out-bmgl').textContent = ppm.toFixed(0) + ' mg/L';
      try { if (beaker) beaker.update(ppm); } catch (e) {}
    }
    el('b-ppm').addEventListener('input', onBChange);

    function initCharts() {
      if (!window.Chart) return;
      const base = chartSetup();
      charts.ladder = new Chart(el('chart-ladder'), {
        type: 'bar',
        data: { labels: ['1% ', '0.1%', '0.005%', '1 ppm', '1 ppb'], datasets: [{ label: 'ppm', data: [10000, 1000, 50, 1, 0.001], backgroundColor: '#6366f1' }] },
        options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'ppm (log)' } } }, plugins: { legend: { display: false } } }),
      });
      charts.mgl = new Chart(el('chart-mgl'), {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'mg/L', data: [], borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
        options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'ppm' } }, y: { title: { display: true, text: 'mg per litre (water)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
      });
      charts.compare = new Chart(el('chart-compare'), {
        type: 'bar',
        data: { labels: ['Pb limit (water)', 'Pool chlorine', 'Nitrate limit', 'Indoor CO₂', 'Atmos. CO₂', 'Seawater salt'], datasets: [{ label: 'ppm', data: [0.015, 2, 10, 1000, 420, 35000], backgroundColor: ['#94a3b8', '#94a3b8', '#94a3b8', '#94a3b8', '#94a3b8', '#94a3b8'] }] },
        options: Object.assign({}, base, { scales: { y: { type: 'logarithmic', title: { display: true, text: 'ppm (log)' } } }, plugins: { legend: { display: false } } }),
      });
      // mg/L line
      const L = [], D = [];
      for (let p = 0; p <= 1000.001; p += 100) { L.push(p + ''); D.push(p); }
      charts.mgl.data.labels = L; charts.mgl.data.datasets[0].data = D; charts.mgl.update();
      charts.ready = true;
    }

    // ================= 3D beaker (sparse specks) =================
    function glassBeaker(THREE) {
      const g = new THREE.Group();
      const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.25, roughness: 0.1, side: THREE.DoubleSide });
      g.add(new THREE.Mesh(new THREE.CylinderGeometry(2.2, 2.2, 5, 40, 1, true), glassMat));
      const bottom = new THREE.Mesh(new THREE.CircleGeometry(2.2, 40), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -2.5; g.add(bottom);
      return g;
    }
    function initBeaker() {
      const c = el('beaker3d'); if (!c) throw new Error('no beaker');
      const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
      s.scene.add(glassBeaker(THREE));
      const liquid = new THREE.Mesh(new THREE.CylinderGeometry(2.08, 2.08, 4.4, 40), new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.4, roughness: 0.3 }));
      liquid.position.y = -0.3; s.scene.add(liquid);
      const MAX_P = 80;
      const particleGeo = new THREE.SphereGeometry(0.1, 10, 10);
      const particleMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
      const particles = [];
      for (let i = 0; i < MAX_P; i++) { const p = new THREE.Mesh(particleGeo, particleMat); p.visible = false; s.scene.add(p); particles.push(p); }
      function update(ppm) {
        // map 0..1000 ppm to 0..MAX_P specks (purely illustrative of "trace")
        const nShow = Math.max(0, Math.min(MAX_P, Math.round(ppm / 1000 * MAX_P)));
        for (let i = 0; i < MAX_P; i++) {
          const p = particles[i];
          if (i < nShow) { const r = Math.sqrt(Math.random()) * 1.9, a = Math.random() * Math.PI * 2; p.position.set(Math.cos(a) * r, -2.4 + Math.random() * 4.4, Math.sin(a) * r); p.visible = true; }
          else p.visible = false;
        }
      }
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
      frame();
      beaker = { update, resize: s.resize };
      update(parseFloat(el('b-ppm').value));
    }

    // ---- diagram: one red in a cube ----
    function initDiagScale() {
      const c = el('diag-scale'); if (!c) throw new Error('no diag');
      const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
      s.scene.add(new THREE.LineSegments(new THREE.EdgesGeometry(new THREE.BoxGeometry(4, 4, 4)), new THREE.LineBasicMaterial({ color: 0x6366f1 })));
      const blueMat = new THREE.MeshStandardMaterial({ color: 0x93c5fd });
      const redMat = new THREE.MeshStandardMaterial({ color: 0xf43f5e });
      for (let i = 0; i < 120; i++) {
        const p = new THREE.Mesh(new THREE.SphereGeometry(0.08, 8, 8), i === 0 ? redMat : blueMat);
        p.position.set((Math.random() - 0.5) * 3.7, (Math.random() - 0.5) * 3.7, (Math.random() - 0.5) * 3.7);
        if (i === 0) p.scale.setScalar(1.6);
        s.scene.add(p);
      }
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.004); s.renderer.render(s.scene, s.camera); }
      frame();
      diagScale = { resize: s.resize };
    }

    // ---- diagram: 1 mg in a litre ----
    function initDiagMgl() {
      const c = el('diag-mgl'); if (!c) throw new Error('no diag');
      const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
      s.scene.add(glassBeaker(THREE));
      const liquid = new THREE.Mesh(new THREE.CylinderGeometry(2.08, 2.08, 4.4, 40), new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.4 }));
      liquid.position.y = -0.3; s.scene.add(liquid);
      const red = new THREE.Mesh(new THREE.SphereGeometry(0.16, 12, 12), new THREE.MeshStandardMaterial({ color: 0xf43f5e }));
      red.position.set(0.3, -1, 0.2); s.scene.add(red);
      function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
      frame();
      diagMgl = { resize: s.resize };
    }

    let diagScale = null, diagMgl = null;

    // ================= BOOT =================
    function boot() {
      try { switchMode('amt'); } catch (e) { console.error('[ppm] calc init failed', e); }
      try { onBChange(); } catch (e) { console.error('[ppm] slider init failed', e); }
      try { initCharts(); } catch (e) { console.error('[ppm] charts failed', e); }
      if (window.THREE) {
        try { initBeaker(); } catch (e) { console.error('[ppm] beaker failed', e); el('beaker3d-fallback').classList.remove('hidden'); }
        try { initDiagScale(); } catch (e) { console.error('[ppm] scale diagram failed', e); }
        try { initDiagMgl(); } catch (e) { console.error('[ppm] mgl diagram failed', e); }
      } else {
        el('beaker3d-fallback').classList.remove('hidden');
      }
      mountResize([beaker, diagScale, diagMgl]);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  })();
  </script>
</ToolLayout>
