---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Roman Numeral Converter';
const description =
  'Free Roman numeral converter. Convert numbers to Roman numerals and Roman numerals back ' +
  'to numbers (1–3999). Instant and private, right in your browser.';
const intro =
  'Convert a number into Roman numerals, or a Roman numeral back into a number. Both directions update instantly.';
const category = { id: 'everyday', name: 'Everyday & Students' };
const faqs = [
  { q: 'What range does it support?', a: 'Standard Roman numerals run from 1 to 3999 (I to MMMCMXCIX). There’s no zero or negative number in the Roman system.' },
  { q: 'How do Roman numerals work?', a: 'They combine the letters I (1), V (5), X (10), L (50), C (100), D (500) and M (1000). Smaller values before larger ones are subtracted, like IV (4) and IX (9).' },
  { q: 'Why is my Roman numeral marked invalid?', a: 'Check it only uses I, V, X, L, C, D, M and follows standard rules. For example IIII isn’t valid — 4 is written IV.' },
  { q: 'Is it private?', a: 'Yes, everything runs in your browser.' },
  { q: 'Why is there no zero in Roman numerals?', a: 'The Roman numeral system was developed for counting and trade, where zero wasn’t needed. It entered mathematics much later via Arabic numerals.' },
  { q: 'What is the largest Roman numeral?', a: 'Using standard rules, the largest is 3,999 (MMMCMXCIX). Larger numbers existed historically but used special notations like a vinculum (bar) over letters.' },
  { q: 'Why is 4 written as IV and not IIII?', a: 'Roman numerals use a subtractive principle — a smaller numeral before a larger one means subtract. So IV means 5 - 1 = 4. IIII is not standard, though it sometimes appears on old clocks.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs}>
  <div class="mt-6 grid gap-4 sm:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">Number → Roman</h2>
      <input id="num-in" type="number" min="1" max="3999" placeholder="2026" class="mt-3 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      <div class="mt-3 flex items-center gap-2">
        <span id="roman-out" class="break-all text-2xl font-bold text-indigo-600">—</span>
        <button id="copy-roman" class="ml-auto rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">Copy</button>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">Roman → Number</h2>
      <input id="roman-in" type="text" placeholder="MMXXVI" class="mt-3 w-full rounded-xl border border-slate-300 p-3 uppercase outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      <div class="mt-3 flex items-center gap-2">
        <span id="num-out" class="text-2xl font-bold text-indigo-600">—</span>
        <button id="copy-num" class="ml-auto rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">Copy</button>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About Roman numerals</h2>
    <p class="mt-2 text-slate-600">
      Roman numerals still appear on clocks, book chapters, movie credits, the Super Bowl and
      monument dates. This converter turns ordinary numbers into Roman numerals and back again,
      following the standard rules, so you can read or write them with confidence. For other number-related calculations, explore our <a href="/tools/percentage-calculator" class="font-medium text-indigo-600 hover:underline">Percentage Calculator</a> or <a href="/tools/unit-converter" class="font-medium text-indigo-600 hover:underline">Unit Converter</a>.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Type a number (1–3999) on the left to get its Roman numeral.</li>
      <li>Type a Roman numeral on the right to get the number.</li>
      <li>Copy whichever result you need.</li>
    </ol>

    <h2 class="mt-8 text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Roman numerals still appear on clock faces, book chapter headings, movie credits, the Super Bowl, and historical monument dates. Use this converter when you need to read a Roman numeral you’ve come across, or when you’re writing something that calls for Roman numerals — such as a document outline, an event poster, or a tattoo design.
    </p>

    <h2 class="mt-8 text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>The converter works in both directions — number to Roman and Roman to number — and updates instantly as you type.</li>
      <li>Only the letters I, V, X, L, C, D and M are valid. For example, 4 must be written as IV, not IIII.</li>
      <li>Use the Copy button next to each result to quickly grab the conversion for your document or project.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const map = [[1000,'M'],[900,'CM'],[500,'D'],[400,'CD'],[100,'C'],[90,'XC'],[50,'L'],[40,'XL'],[10,'X'],[9,'IX'],[5,'V'],[4,'IV'],[1,'I']];

    function toRoman(n) {
      if (!Number.isInteger(n) || n < 1 || n > 3999) return null;
      let out = '';
      for (const [v, s] of map) { while (n >= v) { out += s; n -= v; } }
      return out;
    }
    function fromRoman(str) {
      const s = str.toUpperCase().trim();
      if (!/^[MDCLXVI]+$/.test(s)) return null;
      const vals = { I:1,V:5,X:10,L:50,C:100,D:500,M:1000 };
      let total = 0;
      for (let i = 0; i < s.length; i++) {
        const cur = vals[s[i]], next = vals[s[i + 1]] || 0;
        total += cur < next ? -cur : cur;
      }
      return toRoman(total) === s ? total : null; // validates canonical form
    }

    el('num-in').addEventListener('input', () => {
      const r = toRoman(parseInt(el('num-in').value, 10));
      el('roman-out').textContent = el('num-in').value === '' ? '—' : (r || 'Enter 1–3999');
    });
    el('roman-in').addEventListener('input', () => {
      if (!el('roman-in').value) { el('num-out').textContent = '—'; return; }
      const n = fromRoman(el('roman-in').value);
      el('num-out').textContent = n || 'Invalid numeral';
    });

    async function copy(text, btn) {
      if (!text || ['—', 'Invalid numeral', 'Enter 1–3999'].includes(text)) return;
      try { await navigator.clipboard.writeText(text); const o = btn.textContent; btn.textContent = '✓'; setTimeout(() => (btn.textContent = o), 1000); } catch (e) {}
    }
    el('copy-roman').addEventListener('click', () => copy(el('roman-out').textContent, el('copy-roman')));
    el('copy-num').addEventListener('click', () => copy(el('num-out').textContent, el('copy-num')));
  </script>
</ToolLayout>
