---
import MultiUnitConverter from '../../components/MultiUnitConverter.astro';
const units = [{ name: "Watts", sym: "W", toBase: 1 }, { name: "Kilowatts", sym: "kW", toBase: 1000 }, { name: "Megawatts", sym: "MW", toBase: 1000000 }, { name: "Horsepower", sym: "hp", toBase: 745.6998716 }, { name: "Metric horsepower", sym: "PS", toBase: 735.49875 }, { name: "BTU per hour", sym: "BTU/h", toBase: 0.2930710702 }, { name: "Foot-pounds per second", sym: "ft·lb/s", toBase: 1.3558179 }];
---
<MultiUnitConverter
  title="Power Converter"
  emoji="🔌"
  quantity="power"
  baseName="watt"
  units={units}
  defaultFrom={1} defaultTo={3}
  intro="Convert between power units — watts, kilowatts, megawatts, horsepower, metric horsepower and more."
  blurb="Power is the rate of doing work or using energy, measured in watts and horsepower."
  related={[{"slug":"energy-converter","label":"Energy Converter Converter"}]}
/>
