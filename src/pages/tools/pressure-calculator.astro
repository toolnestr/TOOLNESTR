---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Pressure Calculator';
const description = 'Pressure calculator with a live 3D fluid column and charts. Solve P = F/A for force and area, or P = ρgh for hydrostatic pressure, with worked examples.';
const intro = 'Solve P = F/A for force spread over an area, or P = ρgh for fluid pressure at depth. A live 3D depth column shows pressure building with depth, and charts compare fluids and contact areas.';
const category = { id: 'physics', name: 'Physics', emoji: '⚛️' };

const faqs = [
  { q: 'What is pressure?', a: 'Pressure (P) is force distributed over an area: P = F/A. Its SI unit is the pascal (Pa = N/m²). The same force concentrated on a small area creates far more pressure than that force spread over a large area — this is why a knife cuts and a snowshoe does not sink.' },
  { q: 'What is hydrostatic (fluid) pressure?', a: 'Hydrostatic pressure is the pressure a fluid exerts due to its own weight: P = ρgh, where ρ is fluid density, g is gravitational acceleration (9.81 m/s² on Earth), and h is depth below the surface. It increases linearly with depth and does not depend on the shape or width of the container.' },
  { q: 'What is the difference between gauge and absolute pressure?', a: 'Gauge pressure is measured relative to atmospheric pressure (what a typical pressure gauge reads). Absolute pressure adds atmospheric pressure on top: P_abs = P_atm + ρgh, where P_atm ≈ 101,325 Pa at sea level. A depth gauge underwater reads gauge pressure; total pressure on your body is the absolute value.' },
  { q: 'Why does a wider container not change fluid pressure at a given depth?', a: 'Because P = ρgh has no term for width or volume — only the vertical column of fluid above a point matters. A narrow tube and a wide tank filled with the same fluid to the same depth exert identical pressure at the bottom, a result sometimes called the "hydrostatic paradox".' },
  { q: 'How does area affect pressure for a fixed force?', a: 'Pressure is inversely proportional to area: P = F/A. Halving the contact area doubles the pressure for the same force. This is why high heels, ice skate blades, and thumbtacks concentrate a modest force into enough pressure to pierce or dent a surface.' },
];

const badge = { label: 'Physics', color: 'blue' };
const howto = {
  name: 'How to use the Pressure Calculator',
  description: 'Calculate pressure from force and area (P = F/A), or hydrostatic pressure from depth (P = ρgh).',
  steps: [
    { name: 'Pick a mode', text: 'Choose "Force & area" (P = F/A) or "Fluid depth" (P = ρgh).' },
    { name: 'Enter the known values', text: 'Fill in any of the variables in that mode except the one you want to solve.' },
    { name: 'Read the result', text: 'The pressure solves instantly, and the 3D depth column and charts update.' },
  ],
};

const formulas = [
  { expr: 'P = F / A', note: 'pressure = force ÷ area over which it acts' },
  { expr: 'P = ρ · g · h', note: 'hydrostatic pressure = density × gravity × depth' },
  { expr: 'P<sub>abs</sub> = P<sub>atm</sub> + ρgh', note: 'absolute pressure adds atmospheric pressure (≈101,325 Pa)' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — scuba diver at depth', tone: 'slate',
    given: 'A scuba diver descends to 10 m in seawater (ρ = 1025 kg/m³). Find the gauge pressure and the absolute pressure.',
    rows: [
      { label: 'Formula:', value: 'P = ρgh' },
      { label: 'Gauge pressure:', value: 'P = 1025 × 9.81 × 10 = 100,552.5 Pa ≈ 100.6 kPa' },
      { label: 'Absolute pressure:', value: 'P_abs = 101,325 + 100,552.5 = 201,877.5 Pa ≈ 201.9 kPa', full: true },
    ],
    note: 'Absolute pressure roughly doubles every 10 m in seawater, which is why divers must ascend slowly to let dissolved gases equalise.',
  },
  {
    title: 'Worked example 2 — a stiletto heel', tone: 'amber',
    given: 'A 600 N person balances their full weight momentarily on a heel tip with contact area 1 cm² (0.0001 m²). Find the pressure.',
    rows: [
      { label: 'Formula:', value: 'P = F / A' },
      { label: 'Substitute:', value: 'P = 600 ÷ 0.0001' },
      { label: 'Pressure:', value: 'P = 6,000,000 Pa = 6 MPa', full: true },
    ],
    note: 'For comparison, a flat 200 cm² shoe sole under the same weight gives P = 600 ÷ 0.02 = 30,000 Pa — 200 times less, because the area is 200 times larger.',
  },
];

const comparison = {
  heading: 'Typical pressures compared',
  note: 'Approximate reference values; gauge pressure unless noted.',
  headers: [{ label: 'Situation' }, { label: 'Pressure', sub: 'kPa' }],
  rows: [
    ['Human blood pressure (systolic, ~120 mmHg)', '≈ 16 kPa'],
    ['Atmospheric pressure at sea level', '≈ 101.3 kPa'],
    ['Car tyre (typical)', '≈ 220 kPa'],
    ['Scuba diver at 10 m (seawater)', '≈ 100.6 kPa'],
    ['Ocean floor at 100 m depth (seawater)', '≈ 1,006 kPa'],
  ],
  highlightIndex: 1,
  footnote: 'Blood pressure of 120 mmHg converts to pressure via 1 mmHg ≈ 0.1333 kPa. Tyre and ocean figures are order-of-magnitude references, not exact constants.',
};

const realWorld = [
  { emoji: '🤿', title: 'Scuba diving depth limits', body: 'Absolute pressure rises by about 1 atmosphere every 10 m in seawater. Divers must ascend slowly and manage dissolved nitrogen to avoid decompression sickness, and depth limits are set largely by how pressure affects gas solubility in the blood.' },
  { emoji: '🛠️', title: 'Hydraulic systems', body: 'Hydraulic jacks and brakes use P = F/A in reverse: a small force on a small piston creates a pressure that, transmitted through an incompressible fluid, pushes a large piston with much greater force — the same pressure acting over a larger area.' },
  { emoji: '🚗', title: 'Tyre pressure', body: 'Tyres are inflated to a set gauge pressure so the contact patch area adjusts to support the vehicle weight: a heavier load needs either higher pressure or a larger contact area to keep P = F/A in the safe range for the tyre and the road grip.' },
  { emoji: '🌊', title: 'Dam and reservoir engineering', body: 'Dam walls must resist hydrostatic pressure that grows linearly with depth, so engineers make dams thicker at the base, where P = ρgh is largest, rather than uniformly thick from top to bottom.' },
];

const misconceptions = [
  { claim: '"Pressure only depends on force, not area."', truth: 'False — pressure is force divided by area, P = F/A. The same force spread over a larger area produces much less pressure; that is exactly why snowshoes and wide tyres reduce sinking or damage.' },
  { claim: '"A wider or bigger container means more pressure at the bottom."', truth: 'For a given depth and fluid, pressure depends only on ρ, g, and h — not on the container’s width or total volume. A thin tube and a wide tank filled to the same height exert identical pressure at the bottom.' },
  { claim: '"Deeper water is always more dangerous purely because of pressure."', truth: 'Pressure itself increases steadily and predictably with depth; the real diving hazards come from how the body and equipment respond to that pressure change (gas compression, nitrogen absorption, rate of ascent) rather than depth being intrinsically more "crushing" at any single instant.' },
  { claim: '"Gauge pressure and absolute pressure are the same thing."', truth: 'Gauge pressure is measured relative to atmospheric pressure and reads zero at the surface. Absolute pressure includes atmospheric pressure on top, so P_abs = P_atm + P_gauge — the two differ by about 101.3 kPa at sea level.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>University Physics Volume 1</em></strong> — Fluid Mechanics, pressure and Pascal’s principle (free, peer-reviewed). <a href="https://openstax.org/books/university-physics-volume-1/pages/14-1-fluids-density-and-pressure" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Halliday, Resnick &amp; Walker, <em>Fundamentals of Physics</em></strong> — Chapter on Fluids, pressure and Pascal’s law.' },
  { html: '<strong>Serway &amp; Jewett, <em>Physics for Scientists and Engineers</em></strong> — Fluid Mechanics, hydrostatic pressure derivation.' },
];
const sourcesNote = 'P = F/A and P = ρgh are standard definitions; g = 9.81 m/s² and P_atm = 101,325 Pa are used as defaults. Results are rounded for display.';

const howToUse = [
  { title: 'Pick the mode', body: '"Force & area" for P = F/A; "Fluid depth" for hydrostatic pressure P = ρgh.' },
  { title: 'Enter the known values', body: 'Fill in the fields except the one you want solved; g defaults to 9.81 m/s².' },
  { title: 'See it in the column', body: 'Drag the depth slider to watch pressure build with depth in the 3D fluid column.' },
];

const related = [
  { href: '/tools/density-calculator', emoji: '🧱', title: 'Density Calculator', desc: 'ρ = m/V — solve for any variable.' },
  { href: '/tools/force-calculator', emoji: '💥', title: 'Force Calculator (F=ma)', desc: 'Solve for force, mass, or acceleration.' },
  { href: '/tools/gravitational-force-calculator', emoji: '🪐', title: 'Gravitational Force Calculator', desc: 'F = Gm₁m₂/r² — Newton’s law of gravitation.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="pressure is force spread over area — squeeze the same force into a smaller area and pressure rises; stack up a taller fluid column and pressure rises too, in direct proportion to depth."
  howIntro="Rearranged, P = F/A solves force (F = P × A) or area (A = F / P) directly. For fluids, P = ρgh gives gauge pressure at depth h; add atmospheric pressure P_atm ≈ 101,325 Pa to get the absolute pressure a submerged object actually experiences: P_abs = P_atm + ρgh."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where pressure actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="mb-4 flex flex-wrap gap-2">
      <button id="mode-fa" type="button" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white">Force &amp; area (P = F/A)</button>
      <button id="mode-fluid" type="button" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600">Fluid depth (P = ρgh)</button>
    </div>

    <div id="fa-fields" class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Pressure (P)</span>
        <input id="fa-P" type="number" step="any" placeholder="Pa" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Force (F)</span>
        <input id="fa-F" type="number" step="any" placeholder="N" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Area (A)</span>
        <input id="fa-A" type="number" step="any" placeholder="m²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div id="fluid-fields" class="hidden grid gap-4 sm:grid-cols-4">
      <label class="block"><span class="text-sm font-medium text-slate-700">Pressure (P)</span>
        <input id="fl-P" type="number" step="any" placeholder="Pa" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Density (ρ)</span>
        <input id="fl-rho" type="number" step="any" placeholder="kg/m³" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Gravity (g)</span>
        <input id="fl-g" type="number" step="any" value="9.81" placeholder="m/s²" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Depth (h)</span>
        <input id="fl-h" type="number" step="any" placeholder="m" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div id="lab-1" class="text-sm opacity-80">Pressure</div><div id="r-1" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-2" class="text-sm text-slate-500">Force</div><div id="r-2" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div id="lab-3" class="text-sm text-slate-500">Area</div><div id="r-3" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <div id="abs-row" class="mt-3 hidden rounded-xl bg-sky-50 p-3 text-center text-sm text-sky-700">Absolute pressure (with atmosphere) ≈ <span id="r-abs" class="font-mono font-bold">—</span></div>
    <p id="p-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: one interactive 3D depth column + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-lg font-bold text-slate-900">Live 3D pressure column</h2>
      <p class="mt-1 text-sm text-slate-500">Set the fluid and the depth; the column colour deepens and the gauge reading climbs as P = ρgh grows. Drag to orbit (touch works too).</p>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Fluid <span id="out-bfluid" class="font-mono text-sky-600">Water</span></span>
          <select id="b-fluid" class="mt-2 w-full rounded-xl border border-slate-300 p-2 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-100">
            <option value="1000">Water (1000 kg/m³)</option>
            <option value="1025">Seawater (1025 kg/m³)</option>
            <option value="13600">Mercury (13600 kg/m³)</option>
          </select>
        </label>
        <label class="block">
          <span class="flex items-center justify-between text-sm font-medium text-slate-700">Depth <span id="out-bh" class="font-mono text-sky-600">5.0 m</span></span>
          <input id="b-h" type="range" min="0" max="20" step="0.1" value="5" class="mt-2 w-full accent-sky-600" />
        </label>
      </div>
      <div class="mt-2 rounded-xl bg-sky-50 p-3 text-center text-sm text-sky-700">Gauge pressure P = <span id="out-bp" class="font-mono font-bold">—</span></div>
      <div id="column3d" class="mt-3 w-full rounded-xl border border-slate-200 bg-gradient-to-b from-sky-50 to-white" style="height:340px;"></div>
      <p id="column3d-fallback" class="mt-2 hidden text-center text-xs text-slate-400">3D view unavailable in this browser — the calculator, charts and content below still work.</p>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Pressure graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pressure vs depth — water, seawater, mercury</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ph"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Pressure vs area at fixed force — an inverse curve</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-pa"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const MOL_OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const P_ATM = 101325;

      // ---- calculator ----
      let mode = 'fa';
      function switchMode(m) {
        mode = m;
        el('mode-fa').className = m === 'fa' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('mode-fluid').className = m === 'fluid' ? 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white' : 'rounded-lg bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-600';
        el('fa-fields').className = m === 'fa' ? 'grid gap-4 sm:grid-cols-3' : 'hidden';
        el('fluid-fields').className = m === 'fluid' ? 'grid gap-4 sm:grid-cols-4' : 'hidden grid gap-4 sm:grid-cols-4';
        el('abs-row').classList.toggle('hidden', m !== 'fluid');
        update();
      }
      function update() {
        el('p-err').textContent = '';
        ['r-1', 'r-2', 'r-3', 'r-abs'].forEach((id) => (el(id).textContent = '—'));
        if (mode === 'fa') {
          el('lab-1').textContent = 'Pressure'; el('lab-2').textContent = 'Force'; el('lab-3').textContent = 'Area';
          const P = parseFloat(el('fa-P').value), F = parseFloat(el('fa-F').value), A = parseFloat(el('fa-A').value);
          const filled = [!isNaN(P), !isNaN(F), !isNaN(A)];
          if (filled.filter(Boolean).length < 2) return;
          let rP = NaN, rF = NaN, rA = NaN;
          if (filled[1] && filled[2]) { if (A === 0) { el('p-err').textContent = 'Area cannot be zero.'; return; } rP = F / A; rF = F; rA = A; }
          else if (filled[0] && filled[2]) { rF = P * A; rP = P; rA = A; }
          else if (filled[0] && filled[1]) { if (P === 0) { el('p-err').textContent = 'Pressure cannot be zero when solving for area.'; return; } rA = F / P; rP = P; rF = F; }
          if (!isNaN(rP)) el('r-1').textContent = fmt(rP) + ' Pa';
          if (!isNaN(rF)) el('r-2').textContent = fmt(rF) + ' N';
          if (!isNaN(rA)) el('r-3').textContent = fmt(rA) + ' m²';
        } else {
          el('lab-1').textContent = 'Pressure'; el('lab-2').textContent = 'Density'; el('lab-3').textContent = 'Depth';
          const P = parseFloat(el('fl-P').value), rho = parseFloat(el('fl-rho').value), g = parseFloat(el('fl-g').value), h = parseFloat(el('fl-h').value);
          const filled = [!isNaN(P), !isNaN(rho), !isNaN(g), !isNaN(h)];
          if (filled.filter(Boolean).length < 3) return;
          let rP = NaN, rRho = NaN, rG = NaN, rH = NaN;
          if (filled[1] && filled[2] && filled[3]) { rP = rho * g * h; rRho = rho; rG = g; rH = h; }
          else if (filled[0] && filled[2] && filled[3]) { if (g === 0 || h === 0) { el('p-err').textContent = 'g and depth cannot be zero when solving for density.'; return; } rRho = P / (g * h); rP = P; rG = g; rH = h; }
          else if (filled[0] && filled[1] && filled[3]) { if (rho === 0 || h === 0) { el('p-err').textContent = 'Density and depth cannot be zero when solving for g.'; return; } rG = P / (rho * h); rP = P; rRho = rho; rH = h; }
          else if (filled[0] && filled[1] && filled[2]) { if (rho === 0 || g === 0) { el('p-err').textContent = 'Density and g cannot be zero when solving for depth.'; return; } rH = P / (rho * g); rP = P; rRho = rho; rG = g; }
          if (!isNaN(rP)) { el('r-1').textContent = fmt(rP) + ' Pa'; el('r-abs').textContent = fmt(rP + P_ATM) + ' Pa'; }
          if (!isNaN(rRho)) el('r-2').textContent = fmt(rRho) + ' kg/m³';
          if (!isNaN(rH)) el('r-3').textContent = fmt(rH) + ' m';
        }
      }
      el('mode-fa').addEventListener('click', () => switchMode('fa'));
      el('mode-fluid').addEventListener('click', () => switchMode('fluid'));
      ['fa-P', 'fa-F', 'fa-A', 'fl-P', 'fl-rho', 'fl-g', 'fl-h'].forEach((id) => el(id).addEventListener('input', update));

      // ---- 3D + charts ----
      const charts = {};
      let column = null;
      const FLUID_NAMES = { '1000': 'Water', '1025': 'Seawater', '13600': 'Mercury' };
      function bState() {
        const rho = parseFloat(el('b-fluid').value), h = parseFloat(el('b-h').value);
        return { rho, h, P: rho * 9.81 * h };
      }
      function onB() {
        const s = bState();
        el('out-bfluid').textContent = FLUID_NAMES[String(s.rho)] || 'Fluid';
        el('out-bh').textContent = s.h.toFixed(1) + ' m';
        el('out-bp').textContent = fmt(s.P) + ' Pa';
        try { if (column) column.update(s); } catch (e) {}
        try { if (charts.ready) updateCharts(s); } catch (e) {}
      }
      el('b-fluid').addEventListener('change', onB);
      el('b-h').addEventListener('input', onB);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const depths = []; for (let d = 0; d <= 20; d += 1) depths.push(d);
        charts.ph = new Chart(el('chart-ph'), {
          type: 'line',
          data: { labels: depths.map(String), datasets: [
            { label: 'Water (1000)', data: depths.map((d) => Math.round(1000 * 9.81 * d)), borderColor: '#38bdf8', pointRadius: 0, tension: 0 },
            { label: 'Seawater (1025)', data: depths.map((d) => Math.round(1025 * 9.81 * d)), borderColor: '#0ea5e9', pointRadius: 0, tension: 0 },
            { label: 'Mercury (13600)', data: depths.map((d) => Math.round(13600 * 9.81 * d)), borderColor: '#6366f1', pointRadius: 0, tension: 0 },
          ] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Depth (m)' } }, y: { title: { display: true, text: 'Pressure (Pa)' }, beginAtZero: true } }, plugins: { legend: { position: 'bottom' } } }),
        });
        charts.pa = new Chart(el('chart-pa'), {
          type: 'line',
          data: { labels: [], datasets: [{ label: 'P', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.12)', fill: true, tension: 0.3, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Area (m²)' } }, y: { title: { display: true, text: 'Pressure (Pa)' }, beginAtZero: true } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
        updateCharts(bState());
      }
      function updateCharts(s) {
        if (!charts.ready) return;
        const F = 600; // fixed reference force, N
        const L = [], D = [];
        for (let a = 0.01; a <= 2.001; a += 0.02) { L.push(a.toFixed(2)); D.push(+(F / a).toFixed(2)); }
        charts.pa.data.labels = L; charts.pa.data.datasets[0].data = D; charts.pa.update();
      }

      // ---- interactive depth column ----
      function initColumn() {
        const c = el('column3d'); if (!c) throw new Error('no column');
        const s = makeScene(c, 12, new THREE.Vector3(0, 0, 0), MOL_OPTS);
        const glassMat = new THREE.MeshStandardMaterial({ color: 0xdbeafe, transparent: true, opacity: 0.2, roughness: 0.1, side: THREE.DoubleSide });
        s.scene.add(new THREE.Mesh(new THREE.CylinderGeometry(2.2, 2.2, 8, 40, 1, true), glassMat));
        const bottom = new THREE.Mesh(new THREE.CircleGeometry(2.2, 40), glassMat); bottom.rotation.x = -Math.PI / 2; bottom.position.y = -4; s.scene.add(bottom);
        let liquid = null;
        let marker = null;
        const markerGeo = new THREE.TorusGeometry(2.25, 0.06, 8, 40);
        const markerMat = new THREE.MeshStandardMaterial({ color: 0xef4444 });
        marker = new THREE.Mesh(markerGeo, markerMat); marker.rotation.x = Math.PI / 2; s.scene.add(marker);
        function colourFor(t) {
          // interpolate light blue -> deep indigo as pressure fraction t (0..1) grows
          const c1 = new THREE.Color(0x7dd3fc), c2 = new THREE.Color(0x1e3a8a);
          return c1.clone().lerp(c2, t);
        }
        function update(state) {
          const hFrac = Math.max(0.02, Math.min(1, state.h / 20));
          const hLiq = hFrac * 7.6;
          const pFrac = Math.max(0, Math.min(1, state.P / (13600 * 9.81 * 20)));
          if (liquid) { s.scene.remove(liquid); liquid.geometry.dispose(); liquid.material.dispose(); }
          const liquidMat = new THREE.MeshStandardMaterial({ color: colourFor(pFrac), transparent: true, opacity: 0.55, roughness: 0.3 });
          liquid = new THREE.Mesh(new THREE.CylinderGeometry(2.08, 2.08, hLiq, 40), liquidMat);
          liquid.position.y = -4 + hLiq / 2; s.scene.add(liquid);
          marker.position.y = -4 + hLiq;
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.0016); s.renderer.render(s.scene, s.camera); }
        frame();
        column = { update, resize: s.resize };
        update(bState());
      }

      function boot() {
        try { switchMode('fa'); } catch (e) { console.error('[pressure] calc init failed', e); }
        try { onB(); } catch (e) { console.error('[pressure] slider init failed', e); }
        try { initCharts(); } catch (e) { console.error('[pressure] charts failed', e); }
        if (window.THREE) {
          try { initColumn(); } catch (e) { console.error('[pressure] column failed', e); el('column3d-fallback').classList.remove('hidden'); }
        } else { el('column3d-fallback').classList.remove('hidden'); }
        mountResize([column]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
