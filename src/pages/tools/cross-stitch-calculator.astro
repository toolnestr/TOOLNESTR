---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Cross-Stitch Calculator';
const description = 'Calculate the finished design size and fabric to cut from stitch count and Aida fabric count.';
const intro = 'Calculate the finished design size and fabric to cut from your stitch count and fabric count.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is "fabric count" in cross-stitch?', a: 'Fabric count is the number of stitches that fit into one inch of fabric — a 14-count Aida fabric fits 14 stitches per inch, so a higher count means smaller, more detailed stitches and a smaller finished design for the same stitch pattern.' },
  { q: 'Why does a higher fabric count give a smaller design?', a: 'Since fabric count is stitches per inch, a higher count packs more stitches into the same inch, meaning each stitch is physically smaller — the same stitch-count pattern worked on 18-count fabric will be noticeably smaller than the same pattern on 11-count fabric.' },
  { q: 'How much margin should I add around the design?', a: 'A common margin is 3-4 inches total (roughly 1.5-2 inches on each side), giving enough fabric to comfortably hoop, frame, or finish the edges without the stitching running too close to the fabric\'s cut edge.' },
  { q: 'Does this work for evenweave fabric too?', a: 'Yes — evenweave fabric is typically stitched over two threads at a time, so if you\'re using evenweave, treat its "count" as half its printed thread count when entering it here (a 28-count evenweave stitched over two threads behaves like 14-count Aida for this calculation).' },
];
const howTo = {
  name: 'How to calculate cross-stitch fabric size',
  steps: [
    { name: 'Enter design stitch count', text: 'Enter the design\'s width and height in stitches, from the pattern.' },
    { name: 'Enter fabric count and margin', text: 'Enter your fabric\'s count (stitches per inch) and desired margin.' },
    { name: 'Read fabric size needed', text: 'The finished design size and total fabric to cut appear instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Design width (stitches)</span>
        <input id="stitchW" type="number" step="1" placeholder="e.g. 140" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Design height (stitches)</span>
        <input id="stitchH" type="number" step="1" placeholder="e.g. 100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Fabric count (stitches/in)</span>
        <input id="count" type="number" step="any" value="14" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Margin, total per side (in)</span>
        <input id="margin" type="number" step="any" value="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden space-y-3">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Fabric to cut</div>
        <div id="r-fabric" class="mt-1 text-2xl font-bold">—</div>
      </div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-sm text-slate-500">Finished design size</div><div id="r-design" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="csc3-title csc3-desc">
      <title id="csc3-title">Cross-stitch design grid with margin around it</title>
      <desc id="csc3-desc">A small grid representing a stitched design centered inside a larger fabric rectangle, with margin space shown around the edges</desc>
      <rect x="200" y="30" width="400" height="120" fill="none" stroke="#94a3b8" stroke-width="2" stroke-dasharray="5 3" />
      <rect x="260" y="55" width="280" height="70" fill="#fecdd3" stroke="#e11d48" stroke-width="2" />
      <text x="400" y="95" text-anchor="middle" font-size="12" fill="#9f1239" font-family="system-ui,sans-serif">Design area</text>
      <text x="400" y="20" text-anchor="middle" font-size="12" fill="#475569" font-family="system-ui,sans-serif">Fabric to cut (with margin)</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Fabric to cut equals the finished design size plus margin on every side</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How cross-stitch fabric size is calculated</h2>
    <p class="mt-2 text-slate-600">
      The finished design size in inches is the stitch count divided by the fabric count, since fabric count directly tells you how many stitches fit per inch. A 140-stitch-wide design on 14-count fabric works out to 140 ÷ 14 = 10 inches wide, because each inch of that fabric holds exactly 14 stitches.
    </p>
    <p class="mt-3 text-slate-600">
      The fabric to actually cut adds your margin on top of that finished design size, giving enough blank fabric around the stitching to comfortably hoop, frame, or finish the piece without the design running to the very edge of the fabric.
    </p>
    <p class="mt-3 text-xs text-slate-400">This uses the standard stitch-count-divided-by-fabric-count formula referenced across cross-stitch and needlework pattern instructions.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A design is 140 stitches wide by 100 stitches tall, worked on 14-count Aida, with a 3-inch total margin.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Design width:</span> <span class="text-slate-600">140 ÷ 14 = 10 in</span></div>
        <div><span class="font-medium text-slate-700">Design height:</span> <span class="text-slate-600">100 ÷ 14 ≈ 7.14 in</span></div>
        <div><span class="font-medium text-slate-700">Fabric to cut:</span> <span class="text-slate-600"><strong>13 × 10.14 in</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Substituting a different fabric count than the pattern originally specified is a common reason to run this calculation — a stitcher who prefers larger, easier-to-see stitches might choose 11-count instead of the pattern's suggested 14-count, and needs to know both the new finished size (to check it still fits an intended frame) and the new fabric to buy.
    </p>
    <p class="mt-3 text-slate-600">
      Framing shops and gift-giving projects both benefit from calculating finished design size before stitching even begins, since choosing a frame or hoop size in advance avoids discovering after weeks of stitching that the finished piece doesn't fit the intended display size.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"A higher fabric count number means a bigger finished design." <strong class="text-slate-900">The opposite.</strong> A higher count means more, smaller stitches per inch, which makes the finished design smaller for the same stitch-count pattern, not bigger.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Evenweave fabric count works exactly like Aida count." <strong class="text-slate-900">Not directly.</strong> Evenweave is usually stitched over two threads, so its printed thread count needs to be halved to get the equivalent effective stitch-per-inch count for this calculation.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-unit-converter" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Unit Converter</a>
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Yardage Calculator</a>
      <a href="/tools/quilt-binding-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Quilt Binding Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const stitchW = parseFloat(el('stitchW').value);
      const stitchH = parseFloat(el('stitchH').value);
      const count = parseFloat(el('count').value);
      const margin = parseFloat(el('margin').value) || 0;
      if (!stitchW || !stitchH || !count || stitchW <= 0 || stitchH <= 0 || count <= 0) {
        el('results').classList.add('hidden');
        return;
      }
      const designW = stitchW / count;
      const designH = stitchH / count;
      const fabricW = designW + margin;
      const fabricH = designH + margin;

      el('r-design').textContent = designW.toFixed(2) + ' × ' + designH.toFixed(2) + ' in';
      el('r-fabric').textContent = fabricW.toFixed(2) + ' × ' + fabricH.toFixed(2) + ' in';
      el('results').classList.remove('hidden');
    }

    ['stitchW', 'stitchH', 'count', 'margin'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
