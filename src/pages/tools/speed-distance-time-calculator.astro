---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Speed, Distance & Time Calculator';
const description =
  'Calculate speed, distance, or time using the formula d = s × t. Supports km/h, mph, m/s, knots and more.';
const intro =
  'Calculate any one of speed, distance, or time from the other two using the formula d = s × t.';
const category = { id: 'automotive', name: 'Automotive' };
const faqs = [
  { q: 'Which value do I need to provide?', a: 'Provide any two values. The calculator automatically computes the missing third value.' },
  { q: 'What units are supported?', a: 'Speed: km/h, mph, m/s, knots. Distance: km, miles, metres. Time: hours, minutes, seconds.' },
  { q: 'Can I calculate time for a road trip?', a: 'Yes. Enter distance and average speed to get estimated driving time, excluding breaks.' },
  { q: 'How accurate is the result?', a: 'The calculation is mathematically exact. Accuracy depends on the precision of your inputs.' },
  { q: 'What is the formula?', a: 'Speed = Distance ÷ Time. The calculator uses d = s × t and rearranges it based on which value you want to find.' },
];
const sources = [
  { html: "<strong>SAE International</strong> standards (e.g. J1349 engine power, J1634 EV range). <a href=\"https://www.sae.org/standards/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">sae.org</a>" },
  { html: "<strong>U.S. DOE / EPA — fueleconomy.gov</strong>, official efficiency, MPGe and charging figures. <a href=\"https://www.fueleconomy.gov/\" rel=\"noopener nofollow\" target=\"_blank\" class=\"text-indigo-500 hover:text-indigo-600 hover:underline\">fueleconomy.gov</a>" },
  { html: "<strong>Vehicle manufacturer service specifications</strong> — always defer to the OEM figures for your specific vehicle." },
];
const sourcesNote = "General estimates. Follow your manufacturer’s published specifications and a qualified mechanic for safety-critical work.";

---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} sources={sources} sourcesNote={sourcesNote}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <p class="mb-4 text-xs text-slate-500">Enter any <strong>two</strong> values — the third is calculated automatically.</p>
    <div class="grid gap-4 sm:grid-cols-3">
      <div>
        <label class="block text-sm font-medium text-slate-700">Speed</label>
        <input id="speed" type="number" step="any" min="0" placeholder="e.g. 100"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <select id="speed-unit"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="kmh">km/h</option>
          <option value="mph">mph</option>
          <option value="ms">m/s</option>
          <option value="knots">knots</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Distance</label>
        <input id="dist" type="number" step="any" min="0" placeholder="e.g. 300"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <select id="dist-unit"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="km">km</option>
          <option value="mi">miles</option>
          <option value="m">metres</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Time</label>
        <input id="time" type="number" step="any" min="0" placeholder="e.g. 3"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        <select id="time-unit"
          class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">
          <option value="h">hours</option>
          <option value="min">minutes</option>
          <option value="s">seconds</option>
        </select>
      </div>
    </div>
    <div class="mt-6 rounded-xl bg-indigo-50 p-4 text-center">
      <div class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Calculated result</div>
      <div id="r-message" class="mt-2 text-xl font-bold text-indigo-700">Enter two values to calculate</div>
    </div>
  </div>

  <figure class="mt-10 overflow-hidden rounded-xl border border-slate-200 bg-white p-4">
    <svg width="800" height="220" viewBox="0 0 800 220" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="sdt-title sdt-desc">
      <title id="sdt-title">Car on road with speed, distance and time labels</title>
      <desc id="sdt-desc">A car moving along a road with labelled arrows for speed, distance, and time</desc>
      <rect x="40" y="120" width="720" height="30" rx="4" fill="#64748b" />
      <line x1="40" y1="120" x2="40" y2="150" stroke="#475569" stroke-width="2" />
      <line x1="280" y1="120" x2="280" y2="150" stroke="#f59e0b" stroke-width="2" />
      <line x1="720" y1="120" x2="720" y2="150" stroke="#475569" stroke-width="2" />
      <text x="160" y="112" text-anchor="middle" fill="#f59e0b" font-size="13" font-weight="bold">Distance</text>
      <text x="160" y="170" text-anchor="middle" fill="#f59e0b" font-size="11">(300 km)</text>
      <rect x="60" y="60" width="80" height="40" rx="10" fill="#ef4444" />
      <text x="100" y="85" text-anchor="middle" fill="#fff" font-size="13" font-weight="bold">Car</text>
      <circle cx="80" cy="120" r="10" fill="#1e293b" /><circle cx="120" cy="120" r="10" fill="#1e293b" />
      <text x="260" y="80" text-anchor="middle" fill="#6366f1" font-size="14" font-weight="bold">d = s &times; t</text>
      <text x="260" y="100" text-anchor="middle" fill="#818cf8" font-size="12">s = d / t &nbsp; t = d / s</text>
      <path d="M380 80 L520 80" stroke="#6366f1" stroke-width="2" stroke-dasharray="5 3" marker-end="url(#fa)" />
      <text x="450" y="72" text-anchor="middle" fill="#6366f1" font-size="12">Speed = 100 km/h</text>
      <rect x="540" y="50" width="200" height="60" rx="10" fill="#eef2ff" stroke="#c7d2fe" stroke-width="1.5" />
      <text x="640" y="72" text-anchor="middle" fill="#4f46e5" font-size="13" font-weight="bold">Time = 3 hours</text>
      <text x="640" y="92" text-anchor="middle" fill="#818cf8" font-size="11">300 ÷ 100 = 3</text>
      <defs><marker id="fa" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M0 0 L10 5 L0 10" fill="#6366f1" /></marker></defs>
    </svg>
    <figcaption class="mt-2 text-center text-xs text-slate-400">The three variables are related by the formula d = s × t</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How speed, distance, and time calculations work</h2>
    <p class="mt-2 text-slate-600">
      The relationship between speed, distance, and time is one of the most fundamental formulas in physics. The formula d = s × t (distance = speed × time) can be rearranged to solve for any variable when the other two are known. This calculator accepts any two of the three values, automatically determines which value is missing, and computes it using the appropriate rearrangement.
    </p>
    <p class="mt-3 text-slate-600">
      Internally, all values are converted to a consistent set of base units: kilometres for distance, hours for time, and km/h for speed. Input units are converted using standard factors: 1 mile = 1.60934 km, 1 metre = 0.001 km, 1 minute = 1/60 hour, 1 second = 1/3600 hour, 1 mph = 1.60934 km/h, 1 m/s = 3.6 km/h, 1 knot = 1.852 km/h.
    </p>
  </section>

  <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-xl font-bold text-slate-900">The formula explained</h2>
    <div class="mt-3 space-y-1 rounded-xl bg-white p-4 font-mono text-sm text-slate-700">
      <div><span class="font-semibold">Speed</span> = Distance ÷ Time</div>
      <div><span class="font-semibold">Distance</span> = Speed × Time</div>
      <div><span class="font-semibold">Time</span> = Distance ÷ Speed</div>
    </div>
    <h3 class="mt-4 font-semibold text-slate-900">Worked example</h3>
    <p class="mt-1 text-sm text-slate-600">Trip of <strong>300 km</strong> at an average speed of <strong>100 km/h</strong>.</p>
    <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
      <div><span class="font-medium text-slate-700">Formula:</span> <span class="text-slate-600">Time = Distance ÷ Speed</span></div>
      <div><span class="font-medium text-slate-700">Calculation:</span> <span class="text-slate-600">300 ÷ 100 = 3 hours</span></div>
      <div><span class="font-medium text-slate-700">In minutes:</span> <span class="text-slate-600">3 × 60 = 180 minutes</span></div>
      <div><span class="font-medium text-slate-700">At 60 mph:</span> <span class="text-slate-600">300 miles ÷ 60 mph = 5 hours</span></div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🚗</span>
      <h3 class="mt-2 font-semibold text-slate-900">Road Trip Planning</h3>
      <p class="mt-1 text-sm text-slate-600">Enter distance and target average speed to estimate driving time. Add rest stops for a realistic total journey time.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">🏃</span>
      <h3 class="mt-2 font-semibold text-slate-900">Running & Cycling</h3>
      <p class="mt-1 text-sm text-slate-600">Runners and cyclists use this formula constantly. Calculate your pace from distance and time, or predict race finish times.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">✈️</span>
      <h3 class="mt-2 font-semibold text-slate-900">Aviation & Marine</h3>
      <p class="mt-1 text-sm text-slate-600">Pilots and sailors use knots and nautical miles. The calculator supports these units for navigation planning.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">📦</span>
      <h3 class="mt-2 font-semibold text-slate-900">Logistics</h3>
      <p class="mt-1 text-sm text-slate-600">Delivery companies use speed-distance-time for route planning, ETAs, and fuel consumption modelling across their fleets.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the speed, distance and time calculator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Enter two values</h3>
        <p class="mt-1 text-sm text-slate-600">Fill in any two of the three fields. Leave the third blank — it will be calculated automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Select units</h3>
        <p class="mt-1 text-sm text-slate-600">Choose the units for each value. The calculator handles conversion automatically.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Read the result</h3>
        <p class="mt-1 text-sm text-slate-600">The missing value is displayed instantly with the correct unit label.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for speed-distance-time calculations</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Use average speed for trips</h3>
        <p class="mt-1 text-sm text-slate-600">Average speed accounts for traffic, stops, and varying conditions. For road trips, use 10–20% below the speed limit for a realistic average.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Convert units consistently</h3>
        <p class="mt-1 text-sm text-slate-600">If distance is in miles and speed in km/h, the calculator handles conversion. But it is best practice to keep units consistent for mental verification.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Add buffer time</h3>
        <p class="mt-1 text-sm text-slate-600">The calculated time is the minimum driving time. Always add buffer for rest breaks, refuelling, traffic, and unexpected delays, especially on longer trips.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 border-t border-slate-200 pt-8">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <a href="/tools/pace-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">🏃</span>
        <h3 class="mt-1 font-semibold text-slate-900">Pace Calculator</h3>
        <p class="text-sm text-slate-600">Calculate running pace per km or mile.</p>
      </a>
      <a href="/tools/race-finish-time-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">🏁</span>
        <h3 class="mt-1 font-semibold text-slate-900">Race Finish Time Calculator</h3>
        <p class="text-sm text-slate-600">Predict race finish times from pace.</p>
      </a>
      <a href="/tools/fuel-cost-calculator/" class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-indigo-300 hover:shadow-sm">
        <span class="text-lg">⛽</span>
        <h3 class="mt-1 font-semibold text-slate-900">Fuel Cost Calculator</h3>
        <p class="text-sm text-slate-600">Estimate fuel costs for any trip distance.</p>
      </a>
    </div>
  </section>

  <script is:inline>
    const conv = { kmh: 1, mph: 1.60934, ms: 3.6, knots: 1.852, km: 1, mi: 1.60934, m: 0.001, h: 1, min: 1/60, s: 1/3600 };
    function fmt(n) { if (Math.abs(n) >= 1000) return n.toLocaleString(undefined, { maximumFractionDigits: 1 }); return n.toLocaleString(undefined, { maximumFractionDigits: 2 }); }
    function update() {
      const s = parseFloat(document.getElementById('speed').value);
      const d = parseFloat(document.getElementById('dist').value);
      const t = parseFloat(document.getElementById('time').value);
      const su = document.getElementById('speed-unit').value;
      const du = document.getElementById('dist-unit').value;
      const tu = document.getElementById('time-unit').value;
      const msg = document.getElementById('r-message');
      const sBase = !isNaN(s) ? s * conv[su] : NaN;
      const dBase = !isNaN(d) ? d * conv[du] : NaN;
      const tBase = !isNaN(t) ? t * conv[tu] : NaN;
      const defined = [isFinite(sBase), isFinite(dBase), isFinite(tBase)].filter(Boolean).length;
      if (defined < 2) { msg.textContent = 'Enter at least two values to calculate'; return; }
      if (defined === 3) { msg.textContent = 'All three values provided — no calculation needed'; return; }
      if (isNaN(sBase) && isFinite(dBase) && isFinite(tBase)) {
        const speed = dBase / tBase;
        msg.innerHTML = `Speed = <strong>${fmt(speed)}</strong> km/h (${fmt(speed / conv[su])} in selected unit)`;
      } else if (isNaN(dBase) && isFinite(sBase) && isFinite(tBase)) {
        const dist = sBase * tBase;
        msg.innerHTML = `Distance = <strong>${fmt(dist)}</strong> km (${fmt(dist / conv[du])} in selected unit)`;
      } else if (isNaN(tBase) && isFinite(sBase) && isFinite(dBase)) {
        const time = dBase / sBase;
        msg.innerHTML = `Time = <strong>${fmt(time)}</strong> hours (${fmt(time * 60)} min, ${fmt(time * 3600)} s)`;
      }
    }
    ['speed','dist','time','speed-unit','dist-unit','time-unit'].forEach(id => {
      const el = document.getElementById(id);
      el.addEventListener('input', update);
      el.addEventListener('change', update);
    });
    update();
  </script>
</ToolLayout>
