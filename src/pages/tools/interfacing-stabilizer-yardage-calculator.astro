---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Interfacing/Stabilizer Yardage Calculator';
const description = 'Estimate how much interfacing or stabilizer you need for collars, cuffs, waistbands, or a structured bodice.';
const intro = 'Estimate interfacing or stabilizer yardage from the garment area being reinforced.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'What is interfacing used for?', a: 'Interfacing is a supportive fabric fused or sewn to the wrong side of garment pieces — collars, cuffs, waistbands, plackets, and facings — to add structure, crispness, and stability so those areas hold their shape instead of collapsing or stretching out.' },
  { q: 'What is the difference between interfacing and stabilizer?', a: 'Interfacing is typically used inside garment construction for structure (collars, waistbands), while stabilizer more often refers to a temporary or permanent backing used under machine embroidery or on stretchy knits to prevent distortion while sewing.' },
  { q: 'Do I need fusible or sew-in interfacing?', a: 'Fusible interfacing (applied with an iron) is faster and works well for most wovens; sew-in interfacing is preferred for fabrics that can\'t handle heat (some delicate silks, pile fabrics like velvet) or that shouldn\'t be permanently bonded.' },
  { q: 'How much extra should I buy?', a: 'This calculator already includes a general buffer for cutting waste in the ranges shown; if your project uses an unusually large collar, waistband, or multiple structured areas, buy toward the higher end of the range or run the numbers for each area separately.' },
];
const howTo = {
  name: 'How to estimate interfacing yardage',
  steps: [
    { name: 'Choose the garment area', text: 'Select which structured area you need to interface — collar/cuffs, waistband, facings, or a full bodice.' },
    { name: 'Read the yardage estimate', text: 'A typical interfacing yardage range for that area appears instantly.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <span class="text-sm font-medium text-slate-700">Garment area</span>
    <select id="area" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100">
      <option value="0">Collar and cuffs only</option>
      <option value="1">Waistband</option>
      <option value="2" selected>Facings (neckline, armhole)</option>
      <option value="3">Full structured bodice</option>
      <option value="4">Full jacket or coat front</option>
    </select>
    <div id="results" class="mt-6">
      <div class="rounded-xl bg-fuchsia-600 p-5 text-center text-white">
        <div class="text-sm opacity-80">Estimated interfacing needed</div>
        <div id="r-yards" class="mt-1 text-2xl font-bold">—</div>
      </div>
    </div>
  </div>

  <figure class="mt-10">
    <svg width="800" height="180" viewBox="0 0 800 180" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="isyc-title isyc-desc">
      <title id="isyc-title">Shirt collar with interfacing layer highlighted</title>
      <desc id="isyc-desc">A shirt collar shape with a shaded inner layer representing where fusible interfacing is applied</desc>
      <path d="M300 40 L400 20 L500 40 L480 70 L400 55 L320 70 Z" fill="#f5d0fe" stroke="#c026d3" stroke-width="2" />
      <path d="M320 45 L400 30 L480 45 L470 60 L400 48 L330 60 Z" fill="#f0abfc" opacity="0.6" />
      <text x="600" y="45" font-size="13" fill="#475569" font-family="system-ui,sans-serif">Interfacing adds</text>
      <text x="600" y="63" font-size="13" fill="#475569" font-family="system-ui,sans-serif">structure underneath</text>
    </svg>
    <figcaption class="mt-2 text-center text-sm text-slate-500">Interfacing is fused to the inside of collars, cuffs, and other structured pieces</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How interfacing yardage is estimated</h2>
    <p class="mt-2 text-slate-600">
      Interfacing needs are tied closely to which parts of a garment require structure, rather than the garment's overall size, since a collar and cuffs need only small pieces of interfacing regardless of whether the shirt itself is a small or an XXL. This calculator groups typical projects by structured area — collar and cuffs, a waistband, facings around a neckline or armhole, a fully interfaced bodice, or a full jacket or coat front — since each category uses a fairly consistent yardage range across garment sizes.
    </p>
    <p class="mt-3 text-slate-600">
      Interfacing is usually sold on bolts similar in width to garment fabric, so the ranges shown already assume a standard width; a narrower interfacing bolt may need slightly more yardage for the same pattern pieces, following the same piece-and-row logic as any fabric yardage calculation.
    </p>
    <p class="mt-3 text-xs text-slate-400">Yardage ranges reflect commonly published home-sewing guidance for typical interfacing applications; specific pattern instructions, when provided, take precedence.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A button-up shirt needs interfacing for its collar, cuffs, and front button placket facings.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Collar and cuffs:</span> <span class="text-slate-600">~0.25-0.5 yd</span></div>
        <div><span class="font-medium text-slate-700">Facings:</span> <span class="text-slate-600">~0.5-0.75 yd</span></div>
        <div><span class="font-medium text-slate-700">Combined estimate:</span> <span class="text-slate-600"><strong>~0.75-1.25 yd</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Shirt-making is the most common place interfacing is used repeatedly in one project — collar, collar stand, cuffs, and front placket all typically need it, so a maker sewing several shirts at once benefits from calculating the combined yardage upfront rather than guessing per project and running short partway through a batch.
    </p>
    <p class="mt-3 text-slate-600">
      Structured formalwear (a fitted bodice for a prom or wedding dress) often needs interfacing across a much larger area than everyday garments, since the entire bodice may be interfaced for boning or structure to hold its shape without a separate corset layer — this is where the "full structured bodice" range applies rather than the smaller collar/cuff estimate.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Interfacing yardage scales with garment size the same way shell fabric does." <strong class="text-slate-900">Not usually.</strong> Interfacing typically covers only specific structured pieces regardless of overall garment size, so a size 8 and size 18 shirt often need nearly the same amount of collar and cuff interfacing.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Any interfacing weight works for any fabric." <strong class="text-slate-900">Not for a good result.</strong> Interfacing weight should roughly match or be lighter than the shell fabric — heavy interfacing on delicate fabric creates a stiff, unnatural bubble effect, while too-light interfacing on heavy fabric fails to add real structure.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/lining-fabric-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Lining Fabric Calculator</a>
      <a href="/tools/seam-allowance-calculator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Seam Allowance Calculator</a>
      <a href="/tools/garment-fabric-estimator/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-fuchsia-300 hover:bg-fuchsia-50">Garment Fabric Estimator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);
    const ranges = [
      [0.25, 0.5], [0.375, 0.625], [0.5, 0.75], [1.5, 2.5], [2.5, 3.5],
    ];

    function update() {
      const idx = parseInt(el('area').value, 10);
      const [lo, hi] = ranges[idx];
      el('r-yards').textContent = lo.toFixed(2) + ' - ' + hi.toFixed(2) + ' yd';
    }

    el('area').addEventListener('change', update);
    update();
  </script>
</ToolLayout>
