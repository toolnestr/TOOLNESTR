---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Reverse Complement Sequence Tool';
const description = "Reverse complement calculator. Find the reverse complement of any DNA sequence, with worked examples and a step-by-step complement-then-reverse breakdown.";
const intro = 'Enter a DNA sequence to find its reverse complement — the sequence of the opposite, antiparallel strand read in the standard 5\'-to-3\' direction. Two 3D diagrams show the original and complementary strands running in opposite directions, and charts compare base composition before and after the transformation.';
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'What is a reverse complement?', a: "A reverse complement is the sequence of the opposite DNA strand, read in the standard 5' to 3' direction. It's found by first complementing every base (A↔T, G↔C), then reversing the order of the resulting sequence." },
  { q: 'Why do you need to reverse the sequence, not just complement it?', a: "DNA's two strands run antiparallel — one 5'→3' and the other 3'→5'. Simply complementing each base gives you the opposite strand read in the 3'→5' direction; reversing that result gives you the conventional 5'→3' reading of the opposite strand." },
  { q: 'When do molecular biologists need the reverse complement?', a: 'It\'s essential for designing PCR reverse primers (which must bind the template strand and read in the correct direction), for interpreting sequencing data from either strand, and for understanding genes located on the minus strand of a genome.' },
  { q: 'Is the reverse complement the same as just reading the sequence backwards?', a: "No — reading backwards alone doesn't complement the bases. The reverse complement of ATGC is GCAT, not CGTA (the simple reversal). You must swap A↔T and G↔C, THEN reverse the order." },
  { q: 'Can a sequence be its own reverse complement?', a: 'Yes — such sequences are called palindromic sequences, and they are biologically important because many restriction enzymes specifically recognize and cut at palindromic DNA sequences.' },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Reverse Complement Sequence Tool',
  description: "Find the reverse complement of a DNA sequence — the opposite strand read 5' to 3'.",
  steps: [
    { name: 'Enter a DNA sequence', text: "Type a sequence using A, T, C, G, read 5' to 3'." },
    { name: 'Read the reverse complement', text: "The opposite strand, correctly read 5' to 3', appears instantly." },
    { name: 'Check for palindromes', text: 'See if your sequence is a palindrome (its own reverse complement) — relevant for restriction sites.' },
  ],
};

const formulas = [
  { expr: 'Complement: A↔T, G↔C', note: 'swap each base for its Watson-Crick partner' },
  { expr: 'Reverse complement = reverse(complement(sequence))', note: "complement first, then reverse the order to read 5'→3'" },
];

const workedExamples = [
  {
    title: 'Worked example 1 — a short sequence', tone: 'slate',
    given: "DNA sequence (5'→3'): ATGCGT",
    rows: [
      { label: 'Step 1 — complement each base:', value: 'A→T, T→A, G→C, C→G, G→C, T→A = TACGCA' },
      { label: "Step 2 — reverse the complement:", value: 'TACGCA reversed = ACGCAT' },
      { label: 'Reverse complement:', value: "5'-ACGCAT-3'", full: true },
    ],
    note: 'Notice the reverse complement is NOT simply the original sequence backwards (TGCGTA) — the complementing step (swapping each base) is essential and easy to forget.',
  },
  {
    title: 'Worked example 2 — a palindromic restriction site', tone: 'amber',
    given: "DNA sequence (5'→3'): GAATTC (the EcoRI restriction enzyme recognition site)",
    rows: [
      { label: 'Step 1 — complement each base:', value: 'G→C, A→T, A→T, T→A, T→A, C→G = CTTAAG' },
      { label: 'Step 2 — reverse the complement:', value: 'CTTAAG reversed = GAATTC' },
      { label: 'Reverse complement:', value: "5'-GAATTC-3' — identical to the original! A palindrome.", full: true },
    ],
    note: 'This sequence is a true palindrome — its reverse complement is itself. This property is exactly why EcoRI (and most restriction enzymes) recognize palindromic sites, letting the enzyme bind symmetrically to both strands.',
  },
];

const comparison = {
  heading: 'Common restriction enzyme palindromic recognition sites',
  note: 'Most restriction enzymes recognize palindromic sequences — sequences equal to their own reverse complement.',
  headers: [{ label: 'Enzyme' }, { label: 'Recognition site' }, { label: 'Reverse complement' }],
  rows: [
    ['EcoRI ★', 'GAATTC', 'GAATTC (same)'],
    ['BamHI', 'GGATCC', 'GGATCC (same)'],
    ['HindIII', 'AAGCTT', 'AAGCTT (same)'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row (worked example 2). Every row shows the recognition site equals its own reverse complement — this palindromic property is characteristic of nearly all standard restriction enzymes.',
};

const realWorld = [
  { emoji: '🧬', title: 'PCR reverse primer design', body: "A PCR reverse primer must be designed as the reverse complement of the template's coding strand at the desired end point, so it binds correctly and extends in the right direction during amplification." },
  { emoji: '✂️', title: 'Restriction enzyme site recognition', body: 'Most restriction enzymes recognize palindromic sequences — a special case where a sequence equals its own reverse complement — enabling the enzyme to bind and cut symmetrically across both DNA strands.' },
  { emoji: '🔬', title: 'DNA sequencing interpretation', body: 'Sequencing data can come from either strand of a DNA molecule — converting between a sequence and its reverse complement is routine when assembling and interpreting sequencing reads.' },
  { emoji: '🧪', title: 'Cloning and vector design', body: 'Molecular cloning requires precisely matching sequence orientations between an insert and vector — reverse complement calculations ensure genes are inserted and expressed in the correct reading direction.' },
];

const misconceptions = [
  { claim: '"The reverse complement is just the original sequence spelled backwards."', truth: "Simply reversing the letters gives the wrong answer — each base must also be complemented (A↔T, G↔C) before reversing. Reversing ATGC gives CGTA, but the true reverse complement is GCAT." },
  { claim: '"Only special, unusual DNA sequences can be palindromes."', truth: 'Many common, biologically important sequences are palindromic — most restriction enzyme recognition sites are deliberately palindromic, since this symmetry lets the enzyme interact identically with both DNA strands.' },
  { claim: '"The reverse complement represents a completely different, unrelated piece of DNA."', truth: "The reverse complement represents the SAME double-stranded DNA molecule — just read from the opposite strand in the standard 5'→3' direction. It's the same physical molecule, described from the other side." },
  { claim: '"You need special lab equipment to determine a sequence\'s reverse complement."', truth: 'Reverse complementation is a purely computational operation based on simple, fixed base-pairing rules — it requires no wet-lab experiment at all, just the original sequence and the complement/reverse algorithm.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 14, "DNA Structure and Function" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/14-1-historical-basis-of-modern-understanding" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Chapter 4, DNA, Chromosomes, and Genomes.' },
  { html: '<strong>Sambrook &amp; Russell, <em>Molecular Cloning: A Laboratory Manual</em></strong> — restriction enzyme site reference tables.' },
];
const sourcesNote = "Reverse complement = reverse(complement(sequence)), using standard Watson-Crick base pairing (A↔T, G↔C). Input should use only A, T, C, G.";

const howToUse = [
  { title: 'Enter a DNA sequence', body: "Type any sequence using A, T, C, G, read 5' to 3'." },
  { title: 'Read the reverse complement', body: "The opposite strand, correctly oriented 5' to 3', appears instantly." },
  { title: 'Check for palindromes', body: 'The tool flags if your sequence is a palindrome (equals its own reverse complement).' },
];

const related = [
  { href: '/tools/dna-transcription-calculator', emoji: '🧬', title: 'DNA to mRNA Transcription Tool', desc: 'Convert a DNA template strand into mRNA.' },
  { href: '/tools/gc-content-calculator', emoji: '🔬', title: 'GC Content Calculator', desc: 'GC% = (G+C)/total bases × 100.' },
  { href: '/tools/pcr-annealing-temperature-calculator', emoji: '🧫', title: 'PCR Primer Annealing Temperature Calculator', desc: 'Estimate annealing temperature from primer Tm.' },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="DNA's two strands are antiparallel mirror images of each other, chemically bonded base-by-base but running in opposite directions — so reading the 'same' physical molecule from the other strand requires both swapping every base for its partner AND flipping the reading direction."
  howIntro="Because Watson-Crick base pairing is fixed (A always with T, G always with C), knowing one strand's sequence completely determines the other strand's sequence base-for-base. But since the two strands are antiparallel — one running 5'→3' left to right, the other running 3'→5' in that same left-to-right view — correctly reading the opposite strand in the conventional 5'→3' direction requires reversing the order after complementing every base, not just complementing alone."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where reverse complements actually matter"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">DNA sequence (5'→3'), A/T/C/G only</span>
      <input id="seq" type="text" value="GAATTC" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 rounded-xl bg-indigo-600 p-5 text-center text-white">
      <div class="text-sm opacity-80">Reverse complement (5'→3')</div>
      <div id="r-revcomp" class="mt-1 break-all font-mono text-xl font-bold">—</div>
    </div>
    <p id="rc-palindrome" class="mt-3 text-center text-sm font-semibold"></p>
    <p id="rc-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Antiparallel strand orientation</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-original" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Original strand (5'→3', left to right)</h3>
          <p class="mt-1 text-sm text-slate-600">The input sequence's bases, in their original reading order.</p>
        </div>
        <div>
          <div id="diag-complement" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Complementary strand (3'→5', same left-to-right view)</h3>
          <p class="mt-1 text-sm text-slate-600">Each base's Watson-Crick partner, running in the opposite chemical direction — reversing this row's order gives the reverse complement.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Reverse complement graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Base composition — original vs reverse complement</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-composition"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Common palindromic restriction sites</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-sites"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const COMPLEMENT = { A: 'T', T: 'A', C: 'G', G: 'C' };
      const COLORS = { A: 0x6366f1, T: 0xf59e0b, C: 0xef4444, G: 0x10b981 };

      function complement(seq) { return seq.split('').map((b) => COMPLEMENT[b] || '').join(''); }
      function reverseComplement(seq) { return complement(seq).split('').reverse().join(''); }

      const charts = {};
      function counts(seq) {
        const c = { A: 0, T: 0, C: 0, G: 0 };
        seq.split('').forEach((b) => { if (c[b] !== undefined) c[b]++; });
        return c;
      }
      function update() {
        el('rc-err').textContent = ''; el('rc-palindrome').textContent = '';
        const raw = (el('seq').value || '').toUpperCase().replace(/[^ATCG]/g, '');
        el('seq').value = el('seq').value.toUpperCase();
        if (!raw) { el('r-revcomp').textContent = '—'; return; }
        const rc = reverseComplement(raw);
        el('r-revcomp').textContent = rc;
        if (rc === raw) {
          el('rc-palindrome').textContent = 'This sequence is a palindrome (equals its own reverse complement)!';
          el('rc-palindrome').className = 'mt-3 text-center text-sm font-semibold text-green-600';
        }
        if (charts.composition) {
          const orig = counts(raw), rev = counts(rc);
          charts.composition.data.datasets[0].data = ['A', 'T', 'C', 'G'].map((b) => orig[b]);
          charts.composition.data.datasets[1].data = ['A', 'T', 'C', 'G'].map((b) => rev[b]);
          charts.composition.update();
        }
      }
      el('seq').addEventListener('input', update);

      // ---- charts ----
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.composition = new Chart(el('chart-composition'), {
          type: 'bar',
          data: { labels: ['A', 'T', 'C', 'G'], datasets: [
            { label: 'Original', data: [1, 2, 1, 2], backgroundColor: '#6366f1' },
            { label: 'Reverse complement', data: [2, 1, 2, 1], backgroundColor: '#f59e0b' },
          ] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Base count' } } }, plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        charts.sites = new Chart(el('chart-sites'), {
          type: 'bar',
          data: { labels: ['EcoRI\n(GAATTC)', 'BamHI\n(GGATCC)', 'HindIII\n(AAGCTT)'], datasets: [{ label: 'Recognition site length', data: [6, 6, 6], backgroundColor: ['#6366f1', '#f59e0b', '#10b981'] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Site length (bp)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function strandScene(container, seq) {
        const s = makeScene(container, 9, new THREE.Vector3(0, 0, 0), OPTS);
        const n = seq.length;
        seq.split('').forEach((b, i) => {
          const sph = new THREE.Mesh(new THREE.SphereGeometry(0.32, 14, 12), new THREE.MeshStandardMaterial({ color: COLORS[b] || 0x94a3b8 }));
          sph.position.set((i - n / 2) * 0.75, 0, 0);
          s.scene.add(sph);
        });
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagOriginal = null, diagComplement = null;
      function initDiagOriginal() { const c = el('diag-original'); if (!c) throw new Error('no container'); diagOriginal = strandScene(c, 'GAATTC'); }
      function initDiagComplement() { const c = el('diag-complement'); if (!c) throw new Error('no container'); diagComplement = strandScene(c, complement('GAATTC')); }

      function boot() {
        try { initCharts(); } catch (e) { console.error('[reverse-complement] charts failed', e); }
        try { update(); } catch (e) { console.error('[reverse-complement] calc init failed', e); }
        if (window.THREE) {
          try { initDiagOriginal(); } catch (e) { console.error('[reverse-complement] original diagram failed', e); }
          try { initDiagComplement(); } catch (e) { console.error('[reverse-complement] complement diagram failed', e); }
        }
        mountResize([diagOriginal, diagComplement]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
