---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Fabric Bolt-to-Garment Yield Calculator';
const description = 'Calculate how many garments a fabric bolt or roll will yield from total roll length and per-garment fabric consumption.';
const intro = 'Find out how many garments you can cut from a fabric bolt of a given length.';
const category = { id: 'clothing', name: 'Clothing & Garment Tools' };
const faqs = [
  { q: 'How do I calculate fabric yield from a bolt?', a: 'Divide the total usable length of the fabric bolt by the fabric consumption per garment. Round down, since a fractional garment can\'t be cut — any leftover length becomes offcut waste unless it happens to be reused for a smaller piece like a pocket or facing.' },
  { q: 'Should I subtract for flaws or end-of-roll loss before calculating?', a: 'Yes — real fabric rolls often have a few meters of unusable length at the very start/end and occasional flaw areas that get skipped during cutting. Subtract a realistic usable-length allowance from the labeled roll length before running the yield calculation for an accurate garment count.' },
  { q: 'Does this account for marker efficiency?', a: 'The per-garment consumption figure you enter should already reflect real marker-based consumption (including cutting waste), not just flat pattern area — see the Fabric Consumption-to-Cost Calculator for turning consumption into cost, and factor in wastage separately if your consumption number is a theoretical one.' },
  { q: 'Why would a factory buy slightly more fabric than the exact yield needs?', a: 'To buffer against fabric flaws discovered during cutting, dye-lot variation between bolts, and any cutting errors — ordering the exact calculated yield with zero margin risks running short mid-production if any of those issues appear.' },
];
const howTo = {
  name: 'How to calculate fabric bolt yield',
  steps: [
    { name: 'Enter usable bolt length', text: 'The fabric roll\'s total length, minus any known unusable start/end sections.' },
    { name: 'Enter fabric consumption per garment', text: 'Real, marker-based consumption per unit including cutting waste.' },
    { name: 'Read garments per bolt', text: 'The number of complete garments the bolt will yield, rounded down.' },
  ],
};
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} howTo={howTo}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block"><span class="text-sm font-medium text-slate-700">Usable bolt length (m)</span>
        <input id="bolt" type="number" step="any" placeholder="e.g. 100" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Consumption per garment (m)</span>
        <input id="consumption" type="number" step="any" placeholder="e.g. 1.8" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100" /></label>
    </div>
    <div id="results" class="mt-6 hidden grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-rose-600 p-5 text-center text-white"><div class="text-sm opacity-80">Garments per bolt</div><div id="r-count" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">Leftover fabric</div><div id="r-left" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How fabric bolt yield is calculated</h2>
    <p class="mt-2 text-slate-600">
      Yield is <span class="font-mono">floor(usable bolt length ÷ consumption per garment)</span> — the number of whole garments that fit into the roll's length, rounded down since a garment can't be cut from a fractional amount of leftover fabric. Any remainder becomes offcut, which may be usable for smaller pattern pieces (pockets, facings, bindings) on some garment styles, or scrapped as pure waste on others.
    </p>
    <p class="mt-3 text-slate-600">
      Accurate yield planning matters directly for purchasing: buying too little fabric mid-production halts a cutting line and can create a dye-lot mismatch problem when a new bolt is sourced later, while buying too much ties up cash in unused inventory and adds storage cost. Getting the yield calculation right — using real, marker-based consumption rather than a rough estimate — is central to efficient fabric procurement.
    </p>
    <p class="mt-3 text-xs text-slate-400">Bolt-length ÷ per-unit-consumption yield calculation follows standard cut-order-planning practice in apparel production.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Worked example</h2>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm text-slate-600">A 100-meter fabric bolt, each dress consuming 1.8 meters.</p>
      <div class="mt-2 grid gap-1 text-sm sm:grid-cols-2">
        <div><span class="font-medium text-slate-700">Bolt length:</span> <span class="text-slate-600">100 m</span></div>
        <div><span class="font-medium text-slate-700">Per garment:</span> <span class="text-slate-600">1.8 m</span></div>
        <div><span class="font-medium text-slate-700">Yield:</span> <span class="text-slate-600">floor(100 ÷ 1.8) = <strong>55 garments</strong></span></div>
        <div><span class="font-medium text-slate-700">Leftover:</span> <span class="text-slate-600">100 − (55 × 1.8) = <strong>1.0 m</strong></span></div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Real-world context</h2>
    <p class="mt-2 text-slate-600">
      Production planners use yield calculations to size fabric orders directly against a confirmed order quantity: a 5,000-unit order at 1.8 m consumption needs 9,000 meters plus a buffer for wastage and flaws, rather than a rough round number that risks either running short or leaving expensive fabric unused in a warehouse.
    </p>
    <p class="mt-3 text-slate-600">
      Fabric mills often produce and dye in specific standard roll lengths, so buyers sometimes deliberately design a cutting plan around a bolt length that yields a clean, whole number of garments with minimal leftover waste — a small planning optimization that adds up across a full production run.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Common misconceptions</h2>
    <div class="mt-3 space-y-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Leftover fabric is always wasted." <strong class="text-slate-900">Not always.</strong> Depending on the leftover length and the garment's smaller pattern pieces, offcuts can sometimes be used for pockets, facings, or accessory items rather than discarded entirely.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <p class="text-slate-600">"Rounding up a fractional yield is fine." <strong class="text-slate-900">It overstates real output.</strong> A partial garment's worth of leftover fabric can't be cut into a whole garment — always round down for a realistic yield count.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Related tools</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a href="/tools/fabric-consumption-cost-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Consumption-to-Cost Calculator</a>
      <a href="/tools/fabric-waste-overrun-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Waste & Overrun Calculator</a>
      <a href="/tools/fabric-yardage-calculator" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-rose-300 hover:bg-rose-50">Fabric Yardage Calculator</a>
    </div>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function update() {
      const bolt = parseFloat(el('bolt').value);
      const consumption = parseFloat(el('consumption').value);
      if (!(bolt > 0 && consumption > 0)) { el('results').classList.add('hidden'); return; }
      const count = Math.floor(bolt / consumption);
      const leftover = bolt - count * consumption;

      el('r-count').textContent = count.toLocaleString();
      el('r-left').textContent = leftover.toFixed(2) + ' m';
      el('results').classList.remove('hidden');
    }

    ['bolt', 'consumption'].forEach((id) => el(id).addEventListener('input', update));
  </script>
</ToolLayout>
