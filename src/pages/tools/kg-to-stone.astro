---
import FactorConverter from '../../components/FactorConverter.astro';
---
<FactorConverter
  title="Kg to Stone"
  emoji="⚖️"
  fromUnit="kilograms" toUnit="stone"
  fromTitle="Kilograms" toTitle="Stone"
  fromSym="kg" toSym="st"
  quantity="weight"
  kind="factor" factor={0.157473}
  reverseSlug="stone-to-kg" reverseLabel="Stone to Kg Converter"
  hasReverse={true}
  related={[{"slug":"weight-converter","label":"Weight Converter"}]}
  useCase="Stone is still widely used for body weight in the UK and Ireland, so this helps translate a metric figure into everyday terms."
/>
