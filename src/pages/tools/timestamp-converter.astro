---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Unix Timestamp Converter';
const description =
  'Free Unix timestamp converter. Convert a Unix epoch timestamp to a human-readable date, ' +
  'and a date back to a timestamp. Shows local and UTC time. Free and private.';
const intro =
  'Convert a Unix timestamp to a readable date, or a date to a Unix timestamp. The current timestamp is shown live below.';
const category = { id: 'developers', name: 'Developers' };
const faqs = [
  { q: 'What is a Unix timestamp?', a: 'It\u2019s the number of seconds that have passed since January 1, 1970 (UTC), known as the Unix epoch. It\u2019s a common way to store dates and times in software.' },
  { q: 'Does it support milliseconds?', a: 'Yes. If you paste a 13-digit value it\u2019s treated as milliseconds; a 10-digit value is treated as seconds.' },
  { q: 'What time zone does it show?', a: 'It shows both your local time and UTC, so you can use whichever you need.' },
  { q: 'Is it private?', a: 'Yes, conversions happen entirely in your browser.' },
  { q: 'What is the "current Unix timestamp" for?', a: 'The live counter at the top shows the current epoch time in seconds, updating every second. It’s useful for logging or API testing when you need the current timestamp.' },
  { q: 'Can I convert dates in the past or future?', a: 'Absolutely — the date picker and timestamp input both support any date from 1970 well into the future. There’s no practical limit.' },
  { q: 'Why does it show different results for the same timestamp?', a: 'If you enter a 10-digit number it’s treated as seconds, while a 13-digit number is treated as milliseconds. Make sure you’re using the right format for your use case.' },
];
---

<ToolLayout title={title} description={description} intro={intro} category={category} faqs={faqs} appCategory="DeveloperApplication">
  <div class="mt-6 space-y-4">
    <div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-4 text-center">
      <div class="text-sm text-indigo-700/70">Current Unix timestamp</div>
      <div id="now" class="mt-1 font-mono text-2xl font-bold text-indigo-700">—</div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">Timestamp → Date</h2>
      <input id="ts-in" type="text" placeholder="e.g. 1700000000" class="mt-3 w-full rounded-xl border border-slate-300 p-3 font-mono outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      <div class="mt-3 space-y-1 text-sm">
        <p>Local: <span id="ts-local" class="font-medium text-slate-800">—</span></p>
        <p>UTC: <span id="ts-utc" class="font-medium text-slate-800">—</span></p>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
      <h2 class="text-base font-semibold text-slate-900">Date → Timestamp</h2>
      <input id="date-in" type="datetime-local" class="mt-3 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
      <div class="mt-3 flex items-center gap-2 text-sm">
        <span>Timestamp (seconds):</span>
        <span id="date-out" class="font-mono font-bold text-indigo-600">—</span>
        <button id="copy-ts" class="ml-auto rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">Copy</button>
      </div>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">About Unix timestamps</h2>
    <p class="mt-2 text-slate-600">
      Unix timestamps are used throughout software and APIs to represent a moment in time as a
      single number — the seconds since 1 January 1970 UTC. This tool converts a timestamp into a
      readable local and UTC date, and converts a date you pick back into a timestamp.
      Need to encode data for APIs? Try the <a href="/tools/base64" class="font-medium text-indigo-600 hover:underline">Base64 Encoder / Decoder</a>
      or the <a href="/tools/json-formatter" class="font-medium text-indigo-600 hover:underline">JSON Formatter</a>
      to work with API payloads.
    </p>
    <h2 class="mt-8 text-xl font-bold text-slate-900">How to use it</h2>
    <ol class="mt-2 list-decimal space-y-1 pl-5 text-slate-600">
      <li>Paste a timestamp to see the date (in local time and UTC).</li>
      <li>Or pick a date and time to get its Unix timestamp.</li>
      <li>Copy whichever value you need.</li>
    </ol>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">When to use this tool</h2>
    <p class="mt-2 text-slate-600">
      Unix timestamps are everywhere in software development. Backend developers constantly convert between timestamps from database records and human-readable dates when debugging logs. API consumers receive timestamps in JSON responses and need to interpret them in their local timezone. DevOps engineers read server log timestamps during incident response. Mobile app developers store dates as timestamps for cross-timezone consistency. Even data analysts encounter Unix timestamps in exported datasets and need quick conversions without writing code.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Tips for best results</h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-600">
      <li>Enter a 10-digit number for seconds-based timestamps, or a 13-digit number for milliseconds — the tool detects the format automatically.</li>
      <li>Use the live "Current Unix timestamp" counter at the top to grab the current epoch time for testing or logging.</li>
      <li>The date picker lets you select any date and time; the corresponding Unix timestamp is calculated instantly.</li>
    </ul>
  </section>

  <script is:inline>
    const el = (id) => document.getElementById(id);

    function tick() { el('now').textContent = Math.floor(Date.now() / 1000); }
    tick(); setInterval(tick, 1000);

    el('ts-in').addEventListener('input', () => {
      const raw = el('ts-in').value.trim();
      if (!/^\d+$/.test(raw)) { el('ts-local').textContent = el('ts-utc').textContent = '—'; return; }
      let ms = parseInt(raw, 10);
      if (raw.length <= 11) ms *= 1000; // seconds → ms
      const d = new Date(ms);
      if (isNaN(d.getTime())) { el('ts-local').textContent = el('ts-utc').textContent = 'Invalid'; return; }
      el('ts-local').textContent = d.toLocaleString();
      el('ts-utc').textContent = d.toUTCString();
    });

    el('date-in').addEventListener('input', () => {
      const v = el('date-in').value;
      if (!v) { el('date-out').textContent = '—'; return; }
      el('date-out').textContent = Math.floor(new Date(v).getTime() / 1000);
    });

    el('copy-ts').addEventListener('click', async () => {
      const v = el('date-out').textContent;
      if (!v || v === '—') return;
      try { await navigator.clipboard.writeText(v); const b = el('copy-ts'); const o = b.textContent; b.textContent = '✓'; setTimeout(() => (b.textContent = o), 1000); } catch (e) {}
    });
  </script>
</ToolLayout>
