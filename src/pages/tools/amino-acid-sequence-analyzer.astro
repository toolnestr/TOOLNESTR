---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Amino Acid Sequence Analyzer';
const description = 'Amino acid sequence analyzer with a live 3D charge diagram and charts. Solve amino acid composition, hydrophobicity percentage, and estimated net charge at physiological pH, with worked examples.';
const intro = "Analyze a protein sequence's amino acid composition — the percentage that's hydrophobic, polar, acidic, or basic — and estimate its net charge at physiological pH. Two 3D diagrams compare a hydrophobic-rich sequence to a charged-rich one, and charts show the full amino acid category breakdown for your sequence.";
const category = { id: 'biology', name: 'Biology', emoji: '🧬' };

const faqs = [
  { q: 'How are amino acids categorized by chemical property?', a: 'Amino acids are commonly grouped into nonpolar/hydrophobic (like leucine, valine), polar uncharged (like serine, asparagine), acidic/negatively charged (aspartate, glutamate), and basic/positively charged (lysine, arginine, histidine).' },
  { q: 'How is net charge estimated from a sequence?', a: "As a simplified estimate at physiological pH (~7.4): count each lysine (K) and arginine (R) as +1, each aspartate (D) and glutamate (E) as −1, and sum them — histidine is typically left out of this simple estimate since its side chain is only weakly basic and mostly uncharged at pH 7.4." },
  { q: 'Why does hydrophobicity matter for protein structure?', a: 'Hydrophobic amino acids tend to cluster in a protein\'s interior (away from water) while polar and charged ones tend to sit on the surface — this hydrophobic effect is one of the most important forces driving how proteins fold into their functional 3D shape.' },
  { q: 'Why is histidine treated differently from lysine and arginine?', a: "Histidine's side chain has a pKa of about 6.0, very close to physiological pH — meaning only a modest fraction of histidine residues are actually protonated (charged) at pH 7.4, unlike lysine and arginine, whose side chains are essentially always fully protonated at that pH." },
  { q: 'Does amino acid composition affect protein solubility?', a: "Yes — proteins with a higher fraction of charged and polar residues on their surface tend to be more soluble in water, while proteins with a large hydrophobic surface fraction are more likely to aggregate or require detergents to stay in solution." },
];

const badge = { label: 'Biology', color: 'purple' };
const howto = {
  name: 'How to use the Amino Acid Sequence Analyzer',
  description: 'Analyze amino acid composition, hydrophobicity, and estimated net charge from a protein sequence.',
  steps: [
    { name: 'Enter a protein sequence', text: 'Type a sequence using standard one-letter amino acid codes.' },
    { name: 'Read the composition breakdown', text: 'Percentage hydrophobic, polar, acidic, and basic residues calculate instantly.' },
    { name: 'Check estimated net charge', text: 'A simplified net charge estimate at physiological pH is shown, based on basic and acidic residue counts.' },
  ],
};

const formulas = [
  { expr: 'Category % = (residues in category / total residues) × 100', note: 'nonpolar, polar uncharged, acidic, or basic' },
  { expr: 'Net charge ≈ (count of K+R) − (count of D+E)', note: 'simplified estimate at physiological pH; histidine excluded due to its near-neutral pKa' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — composition of a short sequence', tone: 'slate',
    given: 'The sequence MKVLDEEK (8 residues).',
    rows: [
      { label: 'Hydrophobic (M, V, L):', value: '3 of 8 = 37.5%' },
      { label: 'Basic (K, K):', value: '2 of 8 = 25%' },
      { label: 'Acidic (D, E, E):', value: '3 of 8 = 37.5%', full: true },
    ],
    note: 'This sequence is roughly split between hydrophobic and charged residues, with slightly more acidic than basic character.',
  },
  {
    title: 'Worked example 2 — estimating net charge', tone: 'amber',
    given: 'Same sequence, MKVLDEEK: 2 lysines (K), 0 arginines (R), 1 aspartate (D), 2 glutamates (E).',
    rows: [
      { label: 'Positive contribution:', value: '2 K + 0 R = +2' },
      { label: 'Negative contribution:', value: '1 D + 2 E = −3' },
      { label: 'Estimated net charge:', value: '+2 + (−3) = −1 (net negative)', full: true },
    ],
    note: 'A net negative charge at physiological pH means this peptide would migrate toward the positive electrode in an electrophoresis experiment — a real, testable prediction from this simple estimate.',
  },
];

const comparison = {
  heading: 'The four amino acid property categories',
  note: 'Every one of the 20 standard amino acids falls into one of these four groups.',
  headers: [{ label: 'Category' }, { label: 'Example residues' }, { label: 'Typical location in folded protein' }],
  rows: [
    ['Nonpolar/hydrophobic ★', 'Leu, Val, Ile, Phe, Ala', 'Buried in the protein\'s interior'],
    ['Polar uncharged', 'Ser, Thr, Asn, Gln, Cys, Tyr', 'Often on the surface, hydrogen bonding'],
    ['Acidic (negative)', 'Asp, Glu', 'Usually on the surface'],
    ['Basic (positive)', 'Lys, Arg, His', 'Usually on the surface'],
  ],
  highlightIndex: 0,
  footnote: '★ Reference row. Hydrophobic residues clustering in the core is one of the primary driving forces behind protein folding.',
};

const realWorld = [
  { emoji: '⚡', title: 'Protein electrophoresis (isoelectric focusing)', body: "Isoelectric focusing separates proteins based on their net charge, which shifts with pH — understanding a protein's charged residue composition predicts how it will migrate and helps interpret separation results." },
  { emoji: '💊', title: 'Drug and protein formulation', body: 'Pharmaceutical scientists analyze a therapeutic protein\'s surface charge and hydrophobicity to predict its solubility, stability, and aggregation risk during formulation and storage.' },
  { emoji: '🧬', title: 'Predicting protein structure and function', body: "A sequence's hydrophobicity pattern is one of the primary inputs used by computational tools to predict which regions of a protein are likely to be buried, exposed, or embedded in a cell membrane." },
  { emoji: '🔬', title: 'Antibody and enzyme engineering', body: "Engineers modify specific residues to adjust a protein's charge or hydrophobicity, fine-tuning its solubility, binding affinity, or stability for research and therapeutic applications." },
];

const misconceptions = [
  { claim: '"A protein\'s net charge estimate from its sequence is always exactly right."', truth: "This is a simplified estimate based on typical residue pKa values at pH 7.4 — the true charge can shift with the exact local environment inside a folded protein, and post-translational modifications (like phosphorylation) add additional charged groups not captured by the raw sequence alone." },
  { claim: '"Histidine should be counted as a full positive charge like lysine and arginine."', truth: "Histidine's side chain pKa (~6.0) sits close to physiological pH, so only a modest fraction of histidine residues are actually protonated at pH 7.4 — treating it as a full +1 charge like lysine or arginine (whose pKa values are much higher) would overestimate a protein's true net charge." },
  { claim: '"All hydrophobic amino acids are on a protein\'s surface, since that\'s where they\'d be most stable."', truth: "It's the opposite — hydrophobic residues are typically buried in a protein's interior, away from the surrounding water, while polar and charged residues face outward into the aqueous environment, which is the more energetically stable arrangement." },
  { claim: '"Amino acid composition alone tells you a protein\'s exact 3D shape."', truth: 'Composition strongly influences folding tendencies, but the precise order of residues (not just their overall proportions) and complex interactions between distant parts of the chain are what ultimately determine a protein\'s exact 3D structure.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Biology 2e</em></strong> — Chapter 3, "Biological Macromolecules" (free, peer-reviewed). <a href="https://openstax.org/books/biology-2e/pages/3-4-proteins" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Alberts et al., <em>Molecular Biology of the Cell</em></strong> — Amino acid properties and protein folding chapter.' },
  { html: '<strong>Lehninger, <em>Principles of Biochemistry</em></strong> — Amino acid classification and pKa reference chapter.' },
];
const sourcesNote = 'Net charge estimate uses standard side-chain pKa approximations at pH 7.4; histidine excluded from the simple count due to its near-neutral pKa (~6.0). Results are simplified estimates, not exact calculations.';

const howToUse = [
  { title: 'Enter a protein sequence', body: 'Type the sequence using standard one-letter amino acid codes.' },
  { title: 'Read composition percentages', body: 'Hydrophobic, polar, acidic, and basic residue percentages calculate instantly.' },
  { title: 'Check net charge estimate', body: 'A simplified estimate at physiological pH, from basic and acidic residue counts.' },
];

const related = [
  { href: '/tools/protein-molecular-weight-calculator', emoji: '⚖️', title: 'Protein Molecular Weight Calculator', desc: 'Sum residue masses from a protein sequence.' },
  { href: '/tools/ph-enzyme-activity-calculator', emoji: '🧫', title: 'pH-Enzyme Activity Simulator', desc: "Model enzyme activity across a range of pH." },
  { href: '/tools/mrna-translation-calculator', emoji: '🧩', title: 'mRNA to Protein Translation Tool', desc: 'Translate mRNA codons into an amino acid chain.' },
];

// [code, category: 'hydrophobic'|'polar'|'acidic'|'basic']
const aaCategory = [
  ['G','hydrophobic'],['A','hydrophobic'],['V','hydrophobic'],['L','hydrophobic'],['I','hydrophobic'],
  ['P','hydrophobic'],['F','hydrophobic'],['M','hydrophobic'],['W','hydrophobic'],
  ['S','polar'],['T','polar'],['C','polar'],['Y','polar'],['N','polar'],['Q','polar'],
  ['D','acidic'],['E','acidic'],
  ['K','basic'],['R','basic'],['H','basic'],
];
const aaCategoryJson = JSON.stringify(aaCategory);
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="a protein's amino acid composition alone — how much of it is oily-and-water-avoiding, water-loving, positively charged, or negatively charged — predicts a surprising amount about how it will fold, where it will sit in a cell, and how it will behave in the lab."
  howIntro="Each of the 20 standard amino acids carries a side chain with a characteristic chemical personality: some are oily and avoid water (hydrophobic), some are polar but electrically neutral, and some carry a genuine positive or negative charge at the cell's normal pH. Tallying what fraction of a sequence falls into each category reveals real, predictable biochemistry — a hydrophobic-heavy sequence likely folds with those residues buried in its core, while a highly charged sequence is more likely to be soluble and to migrate strongly in an electric field. Estimating net charge specifically requires care with histidine, whose side chain sits right at the edge of being charged at physiological pH, unlike lysine and arginine's side chains, which are reliably protonated."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where amino acid composition actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <label class="block"><span class="text-sm font-medium text-slate-700">Protein sequence (one-letter codes)</span>
      <textarea id="seq" rows="3" class="mt-1 w-full rounded-xl border border-slate-300 p-3 font-mono uppercase tracking-widest outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100">MKVLDEEK</textarea></label>
    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Hydrophobic</div><div id="r-hydro" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Polar</div><div id="r-polar" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Acidic</div><div id="r-acidic" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
      <div class="rounded-xl bg-slate-50 p-3 text-center"><div class="text-xs text-slate-500">Basic</div><div id="r-basic" class="mt-1 text-lg font-bold text-slate-800">—</div></div>
    </div>
    <div class="mt-3 rounded-xl bg-indigo-600 p-4 text-center text-white"><div class="text-xs opacity-80">Estimated net charge (pH 7.4)</div><div id="r-charge" class="mt-1 text-2xl font-bold">—</div></div>
    <p id="aa-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Hydrophobic-rich vs. charged-rich sequence</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-hydro" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Hydrophobic-rich</h3>
          <p class="mt-1 text-sm text-slate-600">Mostly nonpolar residues (grey) — likely buried in a folded protein's core.</p>
        </div>
        <div>
          <div id="diag-charged" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Charged-rich</h3>
          <p class="mt-1 text-sm text-slate-600">Mostly acidic (red) and basic (blue) residues — likely on the protein's surface.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Composition charts</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">Your sequence's category breakdown</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-composition"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">All 20 amino acids by category</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-all20"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline define:vars={{ aaCategoryJson }}>
    (function () {
      'use strict';
      const { el, reduceMotion, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };
      const aaCategory = JSON.parse(aaCategoryJson);
      const catMap = {};
      aaCategory.forEach(([code, cat]) => { catMap[code] = cat; });
      const catColors = { hydrophobic: '#94a3b8', polar: '#10b981', acidic: '#ef4444', basic: '#6366f1' };
      let charts = {};

      function update() {
        el('aa-err').textContent = '';
        ['r-hydro', 'r-polar', 'r-acidic', 'r-basic', 'r-charge'].forEach((id) => el(id).textContent = '—');
        const seq = (el('seq').value || '').toUpperCase().replace(/[^A-Z]/g, '');
        if (!seq) return;
        const counts = { hydrophobic: 0, polar: 0, acidic: 0, basic: 0 };
        let k = 0, r = 0, d = 0, e = 0;
        for (const c of seq) {
          const cat = catMap[c];
          if (!cat) { el('aa-err').textContent = 'Unrecognized amino acid code: ' + c; return; }
          counts[cat]++;
          if (c === 'K') k++; if (c === 'R') r++; if (c === 'D') d++; if (c === 'E') e++;
        }
        const total = seq.length;
        el('r-hydro').textContent = ((counts.hydrophobic / total) * 100).toFixed(1) + '%';
        el('r-polar').textContent = ((counts.polar / total) * 100).toFixed(1) + '%';
        el('r-acidic').textContent = ((counts.acidic / total) * 100).toFixed(1) + '%';
        el('r-basic').textContent = ((counts.basic / total) * 100).toFixed(1) + '%';
        const netCharge = (k + r) - (d + e);
        el('r-charge').textContent = (netCharge > 0 ? '+' : '') + netCharge;
        updateChart(counts);
      }
      el('seq').addEventListener('input', update);

      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        charts.comp = new Chart(el('chart-composition'), {
          type: 'pie',
          data: { labels: ['Hydrophobic', 'Polar', 'Acidic', 'Basic'], datasets: [{ data: [3, 0, 3, 2], backgroundColor: [catColors.hydrophobic, catColors.polar, catColors.acidic, catColors.basic] }] },
          options: Object.assign({}, base, { plugins: { legend: { display: true, position: 'bottom' } } }),
        });
        const counts20 = { hydrophobic: 0, polar: 0, acidic: 0, basic: 0 };
        aaCategory.forEach(([, cat]) => counts20[cat]++);
        new Chart(el('chart-all20'), {
          type: 'bar',
          data: { labels: ['Hydrophobic', 'Polar', 'Acidic', 'Basic'], datasets: [{ label: 'Number of amino acids', data: [counts20.hydrophobic, counts20.polar, counts20.acidic, counts20.basic], backgroundColor: [catColors.hydrophobic, catColors.polar, catColors.acidic, catColors.basic] }] },
          options: Object.assign({}, base, { scales: { y: { title: { display: true, text: 'Count (of 20 standard amino acids)' } } }, plugins: { legend: { display: false } } }),
        });
      }
      function updateChart(counts) {
        if (!charts.comp) return;
        charts.comp.data.datasets[0].data = [counts.hydrophobic, counts.polar, counts.acidic, counts.basic];
        charts.comp.update('none');
      }

      function residueScene(container, hydroCount, chargedCount) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        for (let i = 0; i < hydroCount; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.2, 10, 8), new THREE.MeshStandardMaterial({ color: 0x94a3b8 }));
          m.position.set((Math.random() - 0.5) * 4, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 2);
          s.scene.add(m);
        }
        for (let i = 0; i < chargedCount; i++) {
          const m = new THREE.Mesh(new THREE.SphereGeometry(0.2, 10, 8), new THREE.MeshStandardMaterial({ color: i % 2 === 0 ? 0xef4444 : 0x6366f1 }));
          m.position.set((Math.random() - 0.5) * 4, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 2);
          s.scene.add(m);
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagHydro = null, diagCharged = null;
      function initDiagHydro() { const c = el('diag-hydro'); if (!c) throw new Error('no container'); diagHydro = residueScene(c, 20, 2); }
      function initDiagCharged() { const c = el('diag-charged'); if (!c) throw new Error('no container'); diagCharged = residueScene(c, 3, 18); }

      function boot() {
        try { initCharts(); update(); } catch (e) { console.error('[amino-acid-analyzer] calc/chart init failed', e); }
        if (window.THREE) {
          try { initDiagHydro(); } catch (e) { console.error('[amino-acid-analyzer] hydrophobic diagram failed', e); }
          try { initDiagCharged(); } catch (e) { console.error('[amino-acid-analyzer] charged diagram failed', e); }
        }
        mountResize([diagHydro, diagCharged]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
