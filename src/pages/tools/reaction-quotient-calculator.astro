        try { initCharts(); } catch (e) { console.error('[reaction-quotient] charts failed', e); }
        if (window.THREE) {
          try { initDiagPiles(); } catch (e) { console.error('[reaction-quotient] pile diagram failed', e); }
          try { initDiagAxis(); } catch (e) { console.error('[reaction-quotient] axis diagram failed', e); }
        }
        mountResize([diagPiles, diagAxis]);
