---
import SubjectToolPage from '../../components/SubjectToolPage.astro';

const title = 'Freezing Point Depression Calculator';
const description = 'Freezing point depression calculator with a live 3D diagram and charts. Solve ΔTf = i·Kf·m for how much a solute lowers a solvent\'s freezing point, with worked examples for road salt and antifreeze.';
const intro = 'Solve ΔTf = i·Kf·m for the freezing point depression caused by dissolving a solute in a solvent — the colligative property behind road salt and antifreeze. Two 3D diagrams compare pure solvent freezing to a solution resisting freezing, and charts show how depression scales with molality and the van\'t Hoff factor.';
const category = { id: 'chemistry', name: 'Chemistry', emoji: '🧪' };

const faqs = [
  { q: 'What is freezing point depression?', a: 'Freezing point depression is the decrease in a solvent\'s freezing point caused by dissolving a solute in it. The formula is ΔTf = i·Kf·m, where i is the van\'t Hoff factor, Kf is the cryoscopic constant, and m is molality.' },
  { q: 'Why does road salt melt ice?', a: 'Salt dissolves into the thin layer of liquid water on ice, lowering its freezing point below the ambient temperature — this prevents the water from refreezing and helps melt the surrounding ice, which is exactly why salt is spread on icy roads.' },
  { q: 'What is the cryoscopic constant (Kf)?', a: 'Kf is a property of the solvent, describing how much its freezing point drops per unit of molality. For water, Kf = 1.86 °C·kg/mol — a larger value than water\'s ebullioscopic constant, meaning freezing point depression is a stronger effect than boiling point elevation at the same molality.' },
  { q: 'How does antifreeze protect a car engine?', a: 'Antifreeze (typically ethylene glycol) dissolves in the engine coolant, substantially lowering its freezing point so the coolant stays liquid in freezing weather, protecting the engine block from crack-inducing ice expansion.' },
  { q: 'Why is depression usually larger than elevation for the same solute?', a: 'Because Kf is typically larger than Kb for common solvents like water (1.86 vs 0.512 °C·kg/mol) — the same molal concentration of solute produces a bigger freezing point shift than boiling point shift.' },
];

const badge = { label: 'Chemistry', color: 'green' };
const howto = {
  name: 'How to use the Freezing Point Depression Calculator',
  description: 'Solve ΔTf = i·Kf·m for the freezing point depression from a solute\'s van\'t Hoff factor, the solvent\'s Kf, and molality.',
  steps: [
    { name: 'Enter the van\'t Hoff factor (i)', text: 'Use i=1 for nonelectrolytes (sugars, glycols), i=2 for 1:1 salts like NaCl.' },
    { name: 'Enter Kf and molality', text: 'Provide the solvent\'s cryoscopic constant (1.86 for water) and the solution\'s molality.' },
    { name: 'Read the result', text: 'The freezing point depression and new freezing point solve instantly.' },
  ],
};

const formulas = [
  { expr: 'ΔTf = i·Kf·m', note: 'freezing point depression — i = van\'t Hoff factor, Kf = cryoscopic constant, m = molality (mol/kg)' },
  { expr: 'FP_new = FP_pure − ΔTf', note: 'the solution\'s new (lower) freezing point' },
];

const workedExamples = [
  {
    title: 'Worked example 1 — road salt (NaCl) in water', tone: 'slate',
    given: '2 mol of NaCl dissolved in 1 kg of water (m = 2 mol/kg). NaCl dissociates into 2 ions (i=2). Water\'s Kf = 1.86 °C·kg/mol.',
    rows: [
      { label: 'Formula:', value: 'ΔTf = i·Kf·m' },
      { label: 'Substitute:', value: 'ΔTf = 2 × 1.86 × 2' },
      { label: 'Result:', value: 'ΔTf = 7.44°C, so FP_new = 0 − 7.44 = −7.44°C', full: true },
    ],
    note: 'This roughly 7.4°C freezing point drop is why concentrated salt brine stays liquid well below 0°C, keeping roads ice-free in moderately cold weather.',
  },
  {
    title: 'Worked example 2 — ethylene glycol antifreeze', tone: 'amber',
    given: '3 mol of ethylene glycol dissolved in 1 kg of water (m = 3 mol/kg). Ethylene glycol does not dissociate (i=1). Water\'s Kf = 1.86 °C·kg/mol.',
    rows: [
      { label: 'Formula:', value: 'ΔTf = i·Kf·m' },
      { label: 'Substitute:', value: 'ΔTf = 1 × 1.86 × 3' },
      { label: 'Result:', value: 'ΔTf = 5.58°C, so FP_new = 0 − 5.58 = −5.58°C', full: true },
    ],
    note: 'Real automotive antifreeze mixtures use much higher glycol concentrations than this to achieve freezing point drops of −30°C or more for winter protection.',
  },
];

const comparison = {
  heading: 'How the van\'t Hoff factor changes freezing point depression',
  note: 'Same molality (2 mol/kg) and solvent (water, Kf=1.86) — only the number of dissolved particles per formula unit changes.',
  headers: [{ label: 'Solute' }, { label: 'i' }, { label: 'ΔTf' }],
  rows: [
    ['Ethylene glycol (nonelectrolyte)', '1', '3.72°C'],
    ['NaCl ★', '2', '7.44°C'],
    ['CaCl₂', '3', '11.16°C'],
    ['AlCl₃', '4', '14.88°C'],
  ],
  highlightIndex: 1,
  footnote: '★ Reference row (worked example 1). CaCl₂-based deicers are often preferred over NaCl in very cold climates precisely because their higher i produces a larger freezing point depression per mole.',
};

const realWorld = [
  { emoji: '🧊', title: 'Road de-icing', body: 'Salt (NaCl) or calcium chloride spread on roads dissolves into surface ice, lowering its freezing point below the ambient temperature and helping melt dangerous ice layers.' },
  { emoji: '🚗', title: 'Automotive antifreeze/coolant', body: 'Ethylene glycol-based antifreeze lowers the coolant\'s freezing point far below 0°C, protecting engine blocks from the destructive expansion that occurs when water freezes.' },
  { emoji: '🍦', title: 'Ice cream making', body: 'Salt added to an ice bath around an ice cream mixture lowers the ice-water bath\'s temperature below 0°C, letting it draw enough heat from the cream mixture to freeze it, since the mixture itself has a lower freezing point too.' },
  { emoji: '🔬', title: 'Determining unknown molar masses', body: 'Freezing point depression is a classic experimental technique (cryoscopy) for determining an unknown solute\'s molar mass, since Kf and molality can be measured directly and then solved for.' },
];

const misconceptions = [
  { claim: '"Any de-icing salt works equally well no matter the temperature."', truth: "Different salts have practical minimum-effective temperatures based on their solubility and van't Hoff factor — calcium chloride remains effective at much lower temperatures than plain rock salt (NaCl), which is why it's preferred in extreme cold." },
  { claim: '"Freezing point depression and boiling point elevation always give the same size effect for the same solute."', truth: 'They use different solvent constants — for water, Kf (1.86) is more than three times larger than Kb (0.512), so the same solute at the same molality produces a much bigger freezing point shift than boiling point shift.' },
  { claim: '"Adding more salt always continues to lower the freezing point without limit."', truth: 'The formula assumes an ideal, dilute solution — at very high concentrations, real solutions deviate from ideal behavior, and there is a practical eutectic minimum temperature below which adding more salt no longer helps (about −21°C for saturated NaCl brine).' },
  { claim: '"Sugar and salt lower freezing point by the same amount at equal mass."', truth: 'What matters is molality (moles of particles per kg of solvent) times the van\'t Hoff factor — salt\'s much lower molar mass and its dissociation into 2 ions per formula unit mean it lowers freezing point far more per gram than sugar does.' },
];

const sources = [
  { html: '<strong>OpenStax, <em>Chemistry 2e</em></strong> — Chapter 11, "Solutions and Colloids" (free, peer-reviewed). <a href="https://openstax.org/books/chemistry-2e/pages/11-4-colligative-properties" rel="noopener nofollow" target="_blank" class="text-indigo-500 hover:text-indigo-600 hover:underline">openstax.org</a>' },
  { html: '<strong>Brown, LeMay &amp; Bursten, <em>Chemistry: The Central Science</em></strong> — Chapter 13, Properties of Solutions.' },
  { html: '<strong>Zumdahl &amp; Zumdahl, <em>Chemistry</em></strong> — Colligative properties of solutions.' },
];
const sourcesNote = 'ΔTf = i·Kf·m. Water Kf = 1.86 °C·kg/mol (standard reference value). Results are rounded for display; assumes ideal, dilute solution behavior.';

const howToUse = [
  { title: 'Enter the van\'t Hoff factor', body: 'Use i=1 for molecular solutes, i=2/3/4 for salts based on how many ions they dissociate into.' },
  { title: 'Enter Kf and molality', body: 'Default Kf=1.86 for water — change it for other solvents. Provide the molality in mol/kg.' },
  { title: 'Read the result', body: 'Freezing point depression and the new freezing point solve instantly.' },
];

const related = [
  { href: '/tools/boiling-point-elevation-calculator', emoji: '📈', title: 'Boiling Point Elevation Calculator', desc: 'ΔTb = i·Kb·m — how much a solute raises the boiling point.' },
  { href: '/tools/molality-calculator', emoji: '🧊', title: 'Molality Calculator', desc: 'm = mol solute / kg solvent — solve any variable.' },
  { href: '/tools/vapor-pressure-calculator', emoji: '💨', title: 'Vapor Pressure Calculator', desc: "Raoult's law — vapor pressure lowering from a dissolved solute." },
];
---

<SubjectToolPage
  title={title} description={description} intro={intro} category={category} faqs={faqs}
  badge={badge} howto={howto}
  coreIdea="dissolved solute particles disrupt the regular arrangement solvent molecules need to lock into a solid crystal lattice, so a solution must be cooled further below the pure solvent's freezing point before it will actually freeze."
  howIntro="Freezing requires solvent molecules to arrange into an ordered crystal lattice. Solute particles mixed among the solvent get in the way of this ordering, effectively lowering the temperature at which freezing can begin — ΔTf=i·Kf·m quantifies this directly, scaling with how many particles are dissolved (through i) and how concentrated the solution is (through molality m). Because this is a colligative property, it depends only on particle count, not on what the solute chemically is."
  formulas={formulas} workedExamples={workedExamples} comparison={comparison}
  realWorld={realWorld} realWorldHeading="Where freezing point depression actually matters"
  misconceptions={misconceptions} sources={sources} sourcesNote={sourcesNote}
  howToUse={howToUse} related={related}
>
  <!-- ============ CALCULATOR ============ -->
  <div slot="calculator" class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <div class="grid gap-4 sm:grid-cols-3">
      <label class="block"><span class="text-sm font-medium text-slate-700">Van't Hoff factor (i)</span>
        <input id="ivh" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Kf (°C·kg/mol)</span>
        <input id="kf" type="number" step="any" value="1.86" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
      <label class="block"><span class="text-sm font-medium text-slate-700">Molality (mol/kg)</span>
        <input id="molal" type="number" step="any" value="2" class="mt-1 w-full rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    </div>
    <label class="mt-4 block"><span class="text-sm font-medium text-slate-700">Pure solvent freezing point (°C)</span>
      <input id="fp0" type="number" step="any" value="0" class="mt-1 w-full max-w-xs rounded-xl border border-slate-300 p-3 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" /></label>
    <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-xl bg-indigo-600 p-5 text-center text-white"><div class="text-sm opacity-80">Freezing point depression (ΔTf)</div><div id="r-dtf" class="mt-1 text-2xl font-bold">—</div></div>
      <div class="rounded-xl bg-slate-50 p-5 text-center"><div class="text-sm text-slate-500">New freezing point</div><div id="r-fp" class="mt-1 text-2xl font-bold text-slate-800">—</div></div>
    </div>
    <p id="fpd-err" class="mt-3 text-center text-sm text-red-600" role="alert"></p>
  </div>

  <!-- ============ VIZ: two static 3D diagrams + charts + script ============ -->
  <div slot="viz">
    <section class="mt-8 no-print">
      <h2 class="text-xl font-bold text-slate-900">Pure solvent vs solution, freezing</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div>
          <div id="diag-crystal" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">1. Pure solvent forming an ordered crystal lattice</h3>
          <p class="mt-1 text-sm text-slate-600">Solvent molecules (blue) lock into a regular repeating lattice at the normal freezing point.</p>
        </div>
        <div>
          <div id="diag-disrupted" class="w-full rounded-xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white" style="height:240px;"></div>
          <h3 class="mt-3 font-semibold text-slate-900">2. Solute particles disrupting the lattice</h3>
          <p class="mt-1 text-sm text-slate-600">Solute particles (amber) scattered among the solvent block the regular lattice from forming, requiring a lower temperature to freeze.</p>
        </div>
      </div>
    </section>

    <section class="mt-10 no-print">
      <h2 class="text-lg font-bold text-slate-900">Freezing point depression graphs</h2>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ΔTf vs molality (water, i=2)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-molal"></canvas></div>
        </figure>
        <figure>
          <figcaption class="mb-1 text-sm font-semibold text-slate-700">ΔTf vs van't Hoff factor (fixed m=2 mol/kg)</figcaption>
          <div class="rounded-xl border border-slate-200 bg-white p-3" style="height:240px;"><canvas id="chart-ivh"></canvas></div>
        </figure>
      </div>
    </section>

    <script is:inline>
    (function () {
      'use strict';
      const { el, reduceMotion, fmtSig: fmt, makeScene, mountResize, chartSetup } = window.STK;
      const OPTS = { ambient: 0.9, dirLight: 0.5, azim: 0.7, pol: 1.2, polMin: 0.3, polMax: Math.PI / 2 + 0.2 };

      // ---- calculator ----
      function update() {
        el('fpd-err').textContent = '';
        el('r-dtf').textContent = '—'; el('r-fp').textContent = '—';
        const i = parseFloat(el('ivh').value), kf = parseFloat(el('kf').value), m = parseFloat(el('molal').value), fp0 = parseFloat(el('fp0').value);
        if (isNaN(i) || isNaN(kf) || isNaN(m) || isNaN(fp0)) return;
        if (i <= 0 || kf <= 0 || m < 0) { el('fpd-err').textContent = 'Van\'t Hoff factor and Kf must be positive; molality cannot be negative.'; return; }
        const dTf = i * kf * m;
        el('r-dtf').textContent = fmt(dTf) + ' °C';
        el('r-fp').textContent = fmt(fp0 - dTf) + ' °C';
      }
      ['ivh', 'kf', 'molal', 'fp0'].forEach((id) => el(id).addEventListener('input', update));

      // ---- charts ----
      const charts = {};
      function initCharts() {
        if (!window.Chart) return;
        const base = chartSetup();
        const labelsM = [], dataM = [];
        for (let m = 0; m <= 5; m += 0.5) { labelsM.push(m.toFixed(1)); dataM.push(+(2 * 1.86 * m).toFixed(3)); }
        charts.molal = new Chart(el('chart-molal'), {
          type: 'line',
          data: { labels: labelsM, datasets: [{ label: 'ΔTf (°C)', data: dataM, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.12)', fill: true, tension: 0, pointRadius: 0 }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: 'Molality (mol/kg)' } }, y: { title: { display: true, text: 'ΔTf (°C)' } } }, plugins: { legend: { display: false } } }),
        });
        const labelsI = [1, 2, 3, 4], dataI = labelsI.map((i) => +(i * 1.86 * 2).toFixed(3));
        charts.ivh = new Chart(el('chart-ivh'), {
          type: 'bar',
          data: { labels: labelsI, datasets: [{ label: 'ΔTf (°C)', data: dataI, backgroundColor: ['#94a3b8', '#6366f1', '#f59e0b', '#ef4444'] }] },
          options: Object.assign({}, base, { scales: { x: { title: { display: true, text: "Van't Hoff factor (i)" } }, y: { title: { display: true, text: 'ΔTf (°C)' } } }, plugins: { legend: { display: false } } }),
        });
        charts.ready = true;
      }

      function latticeScene(container, disrupted) {
        const s = makeScene(container, 8, new THREE.Vector3(0, 0, 0), OPTS);
        const spacing = 1.1;
        for (let x = -1; x <= 1; x++) {
          for (let y = -1; y <= 1; y++) {
            for (let z = -1; z <= 1; z++) {
              if (disrupted && Math.random() < 0.3) {
                const p = new THREE.Mesh(new THREE.SphereGeometry(0.24, 10, 8), new THREE.MeshStandardMaterial({ color: 0xf59e0b }));
                p.position.set(x * spacing + (Math.random() - 0.5) * 0.4, y * spacing + (Math.random() - 0.5) * 0.4, z * spacing + (Math.random() - 0.5) * 0.4);
                s.scene.add(p);
              } else {
                const m = new THREE.Mesh(new THREE.SphereGeometry(0.2, 10, 8), new THREE.MeshStandardMaterial({ color: 0x38bdf8 }));
                m.position.set(x * spacing, y * spacing, z * spacing);
                s.scene.add(m);
              }
            }
          }
        }
        function frame() { requestAnimationFrame(frame); if (!reduceMotion) s.spin(0.003); s.renderer.render(s.scene, s.camera); }
        frame();
        return { resize: s.resize };
      }
      let diagCrystal = null, diagDisrupted = null;
      function initDiagCrystal() { const c = el('diag-crystal'); if (!c) throw new Error('no container'); diagCrystal = latticeScene(c, false); }
      function initDiagDisrupted() { const c = el('diag-disrupted'); if (!c) throw new Error('no container'); diagDisrupted = latticeScene(c, true); }

      function boot() {
        try { update(); } catch (e) { console.error('[freezing-point-depression] calc init failed', e); }
        try { initCharts(); } catch (e) { console.error('[freezing-point-depression] charts failed', e); }
        if (window.THREE) {
          try { initDiagCrystal(); } catch (e) { console.error('[freezing-point-depression] crystal diagram failed', e); }
          try { initDiagDisrupted(); } catch (e) { console.error('[freezing-point-depression] disrupted diagram failed', e); }
        }
        mountResize([diagCrystal, diagDisrupted]);
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
      else boot();
    })();
    </script>
  </div>
</SubjectToolPage>
