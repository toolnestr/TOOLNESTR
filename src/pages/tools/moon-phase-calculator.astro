---
import ToolLayout from '../../layouts/ToolLayout.astro';
const title = 'Moon Phase Calculator';
const description = 'Find the moon phase for any date — new moon, first quarter, full moon, last quarter, and everything in between.';
const intro = 'Find the moon phase for any date — new, quarter, gibbous, full moon.';
const category = { id: 'time-date', name: 'Time & Date Tools' };
const faqs = [
  { q: 'How is the moon phase calculated?', a: 'Using the known lunar cycle (~29.53 days) from a reference new moon (Jan 6, 2000).' },
  { q: 'How accurate is it?', a: 'Accurate to within a day for most dates. For precise astronomical calculations, use specialized software.' },
  { q: 'What are the 8 phases?', a: 'New, Waxing Crescent, First Quarter, Waxing Gibbous, Full, Waning Gibbous, Last Quarter, Waning Crescent.' },
  { q: 'Can I see the moon for my birthday?', a: 'Yes — enter any past or future date to see the moon phase.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="date-input" class="block text-sm font-medium text-slate-700">Select a date</label>
          <input id="date-input" type="date" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100" />
        </div>
        <div class="flex items-end">
          <button id="calc-btn" class="w-full rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-indigo-700">Calculate Moon Phase</button>
        </div>
      </div>

      <div id="result" class="mt-6 hidden">
        <div class="flex flex-col items-center gap-4 sm:flex-row">
          <div class="shrink-0">
            <canvas id="moon-canvas" width="160" height="160" class="rounded-full shadow-md"></canvas>
          </div>
          <div class="min-w-0 flex-1">
            <p id="phase-name" class="text-xl font-bold text-slate-900"></p>
            <p id="phase-desc" class="mt-1 text-sm text-slate-600"></p>
            <div class="mt-3 grid grid-cols-2 gap-2 text-xs">
              <div class="rounded-lg bg-slate-50 px-3 py-2"><span class="font-medium text-slate-700">Illumination</span><br /><span id="illumination" class="text-slate-600"></span></div>
              <div class="rounded-lg bg-slate-50 px-3 py-2"><span class="font-medium text-slate-700">Days to next new moon</span><br /><span id="to-new-moon" class="text-slate-600"></span></div>
              <div class="rounded-lg bg-slate-50 px-3 py-2"><span class="font-medium text-slate-700">Days to next full moon</span><br /><span id="to-full-moon" class="text-slate-600"></span></div>
              <div class="rounded-lg bg-slate-50 px-3 py-2"><span class="font-medium text-slate-700">Cycle position</span><br /><span id="cycle-pos" class="text-slate-600"></span></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <figure class="mt-10">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 160" width="800" height="160" role="img" aria-labelledby="moon-svg-title moon-svg-desc" class="w-full max-w-2xl mx-auto">
        <title id="moon-svg-title">Eight moon phases arranged in a circle</title>
        <desc id="moon-svg-desc">A circular diagram showing the 8 moon phases: new, waxing crescent, first quarter, waxing gibbous, full, waning gibbous, last quarter, waning crescent</desc>
        <circle cx="80" cy="80" r="35" fill="#1e293b" stroke="#cbd5e1" stroke-width="1" />
        <circle cx="185" cy="80" r="35" fill="#1e293b" stroke="#cbd5e1" stroke-width="1" />
        <path d="M185 45 A35 35 0 0 0 185 115 A20 35 0 0 1 185 45" fill="#f8fafc" />
        <circle cx="290" cy="80" r="35" fill="#1e293b" stroke="#cbd5e1" stroke-width="1" />
        <rect x="290" y="45" width="17.5" height="70" fill="#f8fafc" />
        <circle cx="395" cy="80" r="35" fill="#1e293b" stroke="#cbd5e1" stroke-width="1" />
        <path d="M395 45 A35 35 0 0 0 395 115 A20 35 0 0 0 395 45" fill="#f8fafc" />
        <circle cx="500" cy="80" r="35" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1" />
        <circle cx="605" cy="80" r="35" fill="#1e293b" stroke="#cbd5e1" stroke-width="1" />
        <path d="M605 45 A35 35 0 0 1 605 115 A20 35 0 0 0 605 45" fill="#f8fafc" />
        <circle cx="710" cy="80" r="35" fill="#1e293b" stroke="#cbd5e1" stroke-width="1" />
        <rect x="727.5" y="45" width="17.5" height="70" fill="#f8fafc" />
        <text x="80" y="137" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="9">New</text>
        <text x="185" y="137" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="9"><tspan x="185">Waxing</tspan><tspan x="185" dy="11">Crescent</tspan></text>
        <text x="290" y="137" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="9"><tspan x="290">First</tspan><tspan x="290" dy="11">Quarter</tspan></text>
        <text x="395" y="137" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="9"><tspan x="395">Waxing</tspan><tspan x="395" dy="11">Gibbous</tspan></text>
        <text x="500" y="137" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="9">Full</text>
        <text x="605" y="137" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="9"><tspan x="605">Waning</tspan><tspan x="605" dy="11">Gibbous</tspan></text>
        <text x="710" y="137" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="9"><tspan x="710">Last</tspan><tspan x="710" dy="11">Quarter</tspan></text>
      </svg>
      <figcaption class="mt-2 text-center text-sm text-slate-500">The eight moon phases in order through the 29.53-day lunar cycle</figcaption>
    </figure>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">How moon phases work</h2>
      <p class="mt-2 text-slate-600">The moon orbits Earth approximately every 27.3 days (sidereal month), but because Earth is also moving around the sun, it takes about 29.53 days (synodic month) for the moon to return to the same phase relative to the sun. As the moon orbits, the angle between the sun, Earth, and moon changes, causing different fractions of the moon's Earth-facing side to be illuminated.</p>
      <p class="mt-3 text-slate-600">When the moon lies between Earth and the sun, the illuminated side faces away from us — that is a new moon. When Earth lies between the sun and the moon, the entire Earth-facing side is lit — a full moon. The quarters occur when the moon is at 90° from the sun in its orbit. The intermediate phases (waxing crescent, waxing gibbous, waning gibbous, waning crescent) fill the gaps between the four primary phases.</p>
      <p class="mt-3 text-slate-600">The terminator — the boundary between the lit and dark sides — moves across the moon's face throughout the cycle. Observing the terminator through binoculars or a telescope reveals detailed shadows that make lunar mountains and craters stand out in sharp relief, especially along the first-quarter and last-quarter terminators.</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">Use cases for moon phase calculations</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4"><span class="font-semibold text-slate-900">Astronomy education</span><p class="mt-1 text-sm text-slate-600">Students and enthusiasts track moon phases to understand orbital mechanics, tidal forces, and the sun-Earth-moon system.</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4"><span class="font-semibold text-slate-900">Photography planning</span><p class="mt-1 text-sm text-slate-600">Landscape and astro photographers plan shoots around specific moon phases — full moon for dramatic night landscapes, new moon for dark-sky astrophotography.</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4"><span class="font-semibold text-slate-900">Gardening by the moon</span><p class="mt-1 text-sm text-slate-600">Some gardeners plant according to moon phases: root crops during waning moons, above-ground crops during waxing moons, following biodynamic principles.</p></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4"><span class="font-semibold text-slate-900">Cultural & folk traditions</span><p class="mt-1 text-sm text-slate-600">Many festivals (Easter, Chinese New Year, Ramadan) are tied to lunar calendars. Moon folklore appears in cultures worldwide.</p></div>
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">Tips for using this calculator</h2>
      <ul class="mt-3 list-inside list-disc space-y-2 text-sm text-slate-600">
        <li>This tool shows the Northern Hemisphere perspective — the moon appears rotated 180° in the Southern Hemisphere.</li>
        <li>Approximation is within about one day. For precise astronomical calculations, use JPL HORIZONS or similar software.</li>
        <li>Blue moons (second full moon in a calendar month) occur roughly every 2.5 years.</li>
        <li>A supermoon occurs when a full moon coincides with perigee (closest approach to Earth), appearing about 14% larger.</li>
      </ul>
    </section>

    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="text-lg font-bold text-slate-900">Related tools</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        <a href="/tools/zodiac-sign-calculator" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Zodiac Sign Calculator</a>
        <a href="/tools/world-clock-comparator" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">World Clock Comparator</a>
        <a href="/tools/countdown-timer" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200">Countdown Timer</a>
      </div>
    </section>
  </div>
</ToolLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var dateInput = document.getElementById('date-input');
    var calcBtn = document.getElementById('calc-btn');
    var result = document.getElementById('result');
    var canvas = document.getElementById('moon-canvas');
    var ctx = canvas.getContext('2d');
    var phaseName = document.getElementById('phase-name');
    var phaseDesc = document.getElementById('phase-desc');
    var illumination = document.getElementById('illumination');
    var toNewMoon = document.getElementById('to-new-moon');
    var toFullMoon = document.getElementById('to-full-moon');
    var cyclePos = document.getElementById('cycle-pos');

    function getMoonPhase(date) {
      var ref = new Date(2000, 0, 6, 18, 14, 0);
      var lunarCycle = 29.53058867;
      var daysSince = (date.getTime() - ref.getTime()) / 86400000;
      var phaseDays = ((daysSince % lunarCycle) + lunarCycle) % lunarCycle;
      var angle = (phaseDays / lunarCycle) * 360;
      var illuminationPct = (1 - Math.cos(angle * Math.PI / 180)) / 2 * 100;
      return { days: phaseDays, angle: angle, illumination: illuminationPct };
    }

    function getPhaseName(angle) {
      var phases = [
        { name: 'New Moon', desc: 'The moon is between Earth and the sun. The side facing Earth is dark.', min: 0, max: 22.5 },
        { name: 'Waxing Crescent', desc: 'A thin sliver appears on the right side, growing larger each night.', min: 22.5, max: 67.5 },
        { name: 'First Quarter', desc: 'Half of the visible face is lit — the right half. The moon is at 90° elongation.', min: 67.5, max: 112.5 },
        { name: 'Waxing Gibbous', desc: 'More than half is lit, approaching full. The moon rises in the afternoon.', min: 112.5, max: 157.5 },
        { name: 'Full Moon', desc: 'The entire Earth-facing side is illuminated. The moon rises at sunset.', min: 157.5, max: 202.5 },
        { name: 'Waning Gibbous', desc: 'The lit portion shrinks from the right. The moon rises after sunset.', min: 202.5, max: 247.5 },
        { name: 'Last Quarter', desc: 'The left half is lit. The moon rises around midnight.', min: 247.5, max: 292.5 },
        { name: 'Waning Crescent', desc: 'A thin slimmer appears on the left, shrinking toward new moon.', min: 292.5, max: 337.5 },
        { name: 'New Moon', desc: 'Back to the start of the cycle. The moon is between Earth and the sun.', min: 337.5, max: 360 }
      ];
      for (var i = 0; i < phases.length; i++) {
        if (angle >= phases[i].min && angle < phases[i].max) return phases[i];
      }
      return phases[0];
    }

    function drawMoon(angle) {
      var cx = 80, cy = 80, r = 75;
      ctx.clearRect(0, 0, 160, 160);
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.fillStyle = '#1e293b';
      ctx.fill();
      ctx.strokeStyle = '#cbd5e1';
      ctx.lineWidth = 1;
      ctx.stroke();

      var rad = angle * Math.PI / 180;
      var cosAngle = Math.cos(rad);
      ctx.save();
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.clip();

      if (angle > 180) {
        ctx.beginPath();
        ctx.arc(cx - r * 0.5 * cosAngle, cy, r * 0.8, 0, Math.PI * 2);
        ctx.fillStyle = '#f8fafc';
        ctx.fill();
      }

      ctx.beginPath();
      ctx.ellipse(cx, cy, Math.abs(cosAngle) * r * 0.5, r, 0, 0, Math.PI * 2);
      ctx.fillStyle = '#f8fafc';
      ctx.fill();

      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.fillStyle = '#1e293b';
      ctx.globalCompositeOperation = 'destination-in';
      ctx.fill();
      ctx.restore();

      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,' + (0.03 * Math.sin(rad * 3 + 1)) + ')';
      ctx.fill();
    }

    function calculate() {
      var val = dateInput.value;
      if (!val) return;
      var date = new Date(val + 'T12:00:00');
      if (isNaN(date.getTime())) return;

      var phase = getMoonPhase(date);
      var info = getPhaseName(phase.angle);

      phaseName.textContent = info.name;
      phaseDesc.textContent = info.desc;
      illumination.textContent = phase.illumination.toFixed(1) + '%';
      toNewMoon.textContent = ((29.53058867 - phase.days) % 29.53058867).toFixed(1) + ' days';
      toFullMoon.textContent = ((14.765294335 - phase.days + 29.53058867) % 29.53058867).toFixed(1) + ' days';
      cyclePos.textContent = (phase.days / 29.53058867 * 100).toFixed(0) + '% through cycle';

      drawMoon(phase.angle);
      result.classList.remove('hidden');
    }

    var today = new Date();
    dateInput.value = today.getFullYear() + '-' + String(today.getMonth()+1).padStart(2,'0') + '-' + String(today.getDate()).padStart(2,'0');

    calcBtn.addEventListener('click', calculate);
    dateInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') calculate(); });
  });
</script>
