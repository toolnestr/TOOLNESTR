---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Keyword Cloud Generator';
const description =
  'Free online keyword cloud generator. Create a visual word cloud from any text — see your most frequent keywords at a glance. Runs in your browser.';
const intro =
  'Paste any text and generate a visual word cloud where the most frequent words appear largest.';
const category = { id: 'seo', name: 'SEO Tools' };
const faqs = [
  { q: 'What is a word cloud?', a: 'A word cloud is a visual representation of text where words are displayed in different sizes — the more frequently a word appears, the larger it appears in the cloud.' },
  { q: 'How is the word size determined?', a: 'Word size is based on frequency. The most common word gets the largest font, and all other words scale proportionally. Minimum and maximum font sizes keep the cloud readable.' },
  { q: 'Can I customize colors?', a: 'Yes. The tool uses a preset palette by default. You can choose from different color schemes to match your brand or presentation style.' },
  { q: 'Can I download the word cloud?', a: 'Yes. Click the Download button to save the word cloud as a PNG image. It captures the canvas content directly.' },
  { q: 'What kind of text works best?', a: 'Any text works — articles, survey responses, transcripts, social media comments. Remove very common stop words (the, a, is) for better results.' },
  { q: 'Does this tool remove stop words?', a: 'Common English stop words like "the", "and", "is" are filtered out automatically. You can toggle this feature on or off.' },
  { q: 'How many words appear in the cloud?', a: 'The top 50-100 words are shown depending on your text length. Very short texts may show fewer words.' },
  { q: 'What are word clouds used for?', a: 'Content analysis, keyword research, presentation visuals, educational exercises, social media analytics and quickly identifying themes in large text.' },
  { q: 'Is there a word limit?', a: 'No limit. Everything runs in your browser. Very large texts may render more slowly but the tool handles them.' },
  { q: 'Is my text private?', a: 'Yes. All processing happens in your browser. Your text is never sent to any server.' },
];
---

<ToolLayout {title} {description} {intro} {category} {faqs}>
  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <textarea
      id="text-input"
      rows="8"
      placeholder="Paste text here to generate a keyword cloud..."
      class="w-full resize-y rounded-xl border border-slate-300 p-4 text-base leading-relaxed outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
    ></textarea>

    <div class="mt-4 flex flex-wrap items-center gap-3">
      <button id="generate-btn" class="rounded-lg bg-indigo-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">Generate Cloud</button>
      <button id="download-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-40" disabled>Download PNG</button>
      <button id="clear-btn" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Clear</button>
      <label class="ml-auto flex items-center gap-2 text-sm text-slate-500">
        <input id="stop-words-toggle" type="checkbox" checked class="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
        Filter stop words
      </label>
    </div>

    <div id="cloud-container" class="mt-4 hidden">
      <canvas id="cloud-canvas" width="700" height="400" class="w-full rounded-xl border border-slate-200 bg-white"></canvas>
    </div>

    <div id="table-container" class="mt-4 hidden overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-left text-sm">
        <thead><tr class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500"><th class="px-4 py-3">Word</th><th class="px-4 py-3">Count</th><th class="px-4 py-3">Weight</th></tr></thead>
        <tbody id="words-body" class="divide-y divide-slate-100 text-slate-700"></tbody>
      </table>
    </div>
  </div>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How the word cloud algorithm works</h2>
    <p class="mt-2 text-slate-600">
      The word cloud generator processes text through a four-stage pipeline. First, the text is lowercased and stripped of punctuation and special characters. Second, words are split by whitespace and counted by frequency. Third, common English stop words are filtered out (optional). Finally, the top 80 words are rendered on a canvas where each word's font size scales proportionally to its frequency.
    </p>
    <p class="mt-3 text-slate-600">
      Font sizing follows a linear scale: <code>fontSize = (count ÷ maxCount) × 48 + 14</code>. The most frequent word gets the largest size (~62px), and the least frequent gets the minimum (~14px). Words are distributed around the canvas center using a spiral placement algorithm that prevents overlap. Color is assigned from a rotating palette, cycling through 10 preset colors to ensure visual contrast.
    </p>
    <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 p-5">
      <h3 class="font-semibold text-slate-900">Worked example</h3>
      <p class="mt-1 text-sm text-slate-600">Text: "SEO tools help improve SEO rankings. SEO requires consistent effort. Use SEO tools daily."</p>
      <div class="mt-2 text-sm text-slate-600">
        After stop word removal: SEO(3), tools(2), help(1), improve(1), rankings(1), requires(1), consistent(1), effort(1), use(1), daily(1)<br>
        Max count = 3. SEO gets font size <strong>62px</strong>, tools gets <strong>46px</strong>, singletons get <strong>30px</strong>
      </div>
    </div>
  </section>

  <figure>
    <svg xmlns="http://www.w3.org/2000/svg" width="800" height="200" viewBox="0 0 800 200">
      <title>Keyword Cloud Visualization</title>
      <desc>Visual tag cloud showing words of varying sizes representing frequency</desc>
      <rect width="800" height="200" fill="#f8fafc" rx="8"/>
      <text x="400" y="50" font-family="sans-serif" font-size="32" fill="#6366f1" font-weight="bold" text-anchor="middle">SEO</text>
      <text x="160" y="85" font-family="sans-serif" font-size="24" fill="#8b5cf6" font-weight="bold">content</text>
      <text x="560" y="80" font-family="sans-serif" font-size="26" fill="#ec4899" font-weight="bold">keywords</text>
      <text x="300" y="120" font-family="sans-serif" font-size="20" fill="#f97316" font-weight="bold">density</text>
      <text x="620" y="130" font-family="sans-serif" font-size="18" fill="#22c55e" font-weight="bold">analyzer</text>
      <text x="100" y="150" font-family="sans-serif" font-size="16" fill="#14b8a6" font-weight="bold">text</text>
      <text x="450" y="165" font-family="sans-serif" font-size="22" fill="#3b82f6" font-weight="bold">web</text>
      <text x="680" y="170" font-family="sans-serif" font-size="14" fill="#6366f1" font-weight="bold">search</text>
      <text x="230" y="175" font-family="sans-serif" font-size="15" fill="#f43f5e" font-weight="bold">tool</text>
      <text x="530" y="100" font-family="sans-serif" font-size="12" fill="#eab308" font-weight="bold">optimization</text>
      <text x="370" y="180" font-family="sans-serif" font-size="13" fill="#8b5cf6" font-weight="bold">frequency</text>
      <text x="700" y="60" font-family="sans-serif" font-size="12" fill="#06b6d4" font-weight="bold">ranking</text>
      <text x="40" y="65" font-family="sans-serif" font-size="14" fill="#f97316" font-weight="bold">analysis</text>
      <text x="60" y="180" font-family="sans-serif" font-size="11" fill="#6366f1" font-weight="bold">words</text>
    </svg>
    <figcaption>Tag cloud visualization where word size reflects frequency — larger words appear more often in the source text</figcaption>
  </figure>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Word cloud use cases</h2>
    <p class="mt-2 text-slate-600">How different professionals use word clouds to gain insights.</p>
    <div class="mt-5 space-y-3">
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Content analysis</span><span class="text-slate-400">35%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-indigo-500" style="width:35%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Presentations</span><span class="text-slate-400">25%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-emerald-500" style="width:25%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">SEO analysis</span><span class="text-slate-400">20%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-amber-500" style="width:20%"></div></div>
      </div>
      <div>
        <div class="flex items-baseline justify-between text-sm"><span class="font-medium text-slate-700">Education</span><span class="text-slate-400">20%</span></div>
        <div class="mt-1 h-3 w-full rounded-full bg-slate-100"><div class="h-3 rounded-full bg-rose-500" style="width:20%"></div></div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4CA;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Content Marketer</h3>
      <p class="mt-1 text-sm text-slate-600">Analyzes blog posts and competitor content to identify dominant themes and missing keywords. Adjusts content strategy based on visual keyword patterns.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F50D;</span>
      <h3 class="mt-2 font-semibold text-slate-900">SEO Analyst</h3>
      <p class="mt-1 text-sm text-slate-600">Creates word clouds from top-ranking pages to quickly understand keyword focus. Detects over-optimization and topic gaps at a glance.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F468;&#x200D;&#x1F3EB;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Teacher</h3>
      <p class="mt-1 text-sm text-slate-600">Uses word clouds to help students identify main ideas in texts, analyze writing style and visualize vocabulary frequency in essays.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <span class="text-2xl">&#x1F4F1;</span>
      <h3 class="mt-2 font-semibold text-slate-900">Presenter</h3>
      <p class="mt-1 text-sm text-slate-600">Creates engaging visual slides with word clouds to summarize key topics, audience feedback or survey results in a memorable format.</p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Color and font schemes</h2>
    <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
      <table class="w-full text-sm">
        <thead><tr class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500"><th class="px-4 py-3">Scheme</th><th class="px-4 py-3">Colors</th><th class="px-4 py-3">Best for</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <tr><td class="px-4 py-3 font-medium text-slate-900">Ocean</td><td class="px-4 py-3 text-slate-700">Blue, teal, cyan</td><td class="px-4 py-3 text-slate-500">Professional presentations</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Sunset</td><td class="px-4 py-3 text-slate-700">Orange, red, yellow</td><td class="px-4 py-3 text-slate-500">Creative and energetic topics</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Forest</td><td class="px-4 py-3 text-slate-700">Green, lime, emerald</td><td class="px-4 py-3 text-slate-500">Nature, health, sustainability</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Grayscale</td><td class="px-4 py-3 text-slate-700">Black, gray, slate</td><td class="px-4 py-3 text-slate-500">Print, formal documents</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Rainbow</td><td class="px-4 py-3 text-slate-700">Multi-color cycle</td><td class="px-4 py-3 text-slate-500">Education, infographics</td></tr>
          <tr><td class="px-4 py-3 font-medium text-slate-900">Pastel</td><td class="px-4 py-3 text-slate-700">Soft pink, lavender, mint</td><td class="px-4 py-3 text-slate-500">Social media, blogs</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How to use the Keyword Cloud Generator</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">1</span>
        <h3 class="mt-3 font-semibold text-slate-900">Paste your text</h3>
        <p class="mt-1 text-sm text-slate-600">Copy any content — article, survey data, or notes — and paste it into the text area.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">2</span>
        <h3 class="mt-3 font-semibold text-slate-900">Generate the cloud</h3>
        <p class="mt-1 text-sm text-slate-600">Click Generate Cloud. The canvas renders words sized by frequency. Toggle stop words as needed.</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-lg font-bold text-indigo-700">3</span>
        <h3 class="mt-3 font-semibold text-slate-900">Download or analyze</h3>
        <p class="mt-1 text-sm text-slate-600">Download the cloud as PNG for use in presentations, or review the word frequency table for deeper analysis.</p>
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6">
    <h2 class="text-xl font-bold text-slate-900">Tips for great word clouds</h2>
    <div class="mt-4 space-y-5">
      <div>
        <h3 class="font-semibold text-slate-900">Clean your text first</h3>
        <p class="mt-1 text-sm text-slate-600">Remove URLs, special characters and punctuation that might clutter the cloud. The tool strips most symbols automatically but cleaner input gives better results.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Use stop words wisely</h3>
        <p class="mt-1 text-sm text-slate-600">Toggle stop words on for general content analysis. Turn them off if you need to see every word including common ones — useful for grammar analysis or very short texts.</p>
      </div>
      <div>
        <h3 class="font-semibold text-slate-900">Keep it readable</h3>
        <p class="mt-1 text-sm text-slate-600">Limit your input to the most relevant text. Too many words can make the cloud crowded. The tool caps displayed words at 80 for clarity.</p>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">What is a word cloud?</h2>
    <p class="mt-2 text-slate-600">A word cloud (or tag cloud) is a visual representation of text data where each word's size reflects its frequency in the source material. It transforms raw text into an intuitive visual that highlights the most prominent terms at a glance.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">How it visualizes data</h2>
    <p class="mt-2 text-slate-600">Word clouds use font size, color and position to encode information. The most frequent word gets the largest font and each subsequent word scales proportionally. Colors group related concepts or add visual variety, making patterns immediately apparent.</p>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-900">Use cases</h2>
    <p class="mt-2 text-slate-600">Word clouds are used across fields: content marketers identify topic clusters, educators teach vocabulary, researchers analyze open-ended survey responses, and presenters create engaging visuals. They turn abstract word counts into an instantly understandable picture.</p>
  </section>

  <script is:inline>
    const input = document.getElementById('text-input');
    const generateBtn = document.getElementById('generate-btn');
    const downloadBtn = document.getElementById('download-btn');
    const clearBtn = document.getElementById('clear-btn');
    const cloudContainer = document.getElementById('cloud-container');
    const canvas = document.getElementById('cloud-canvas');
    const ctx = canvas.getContext('2d');
    const tableContainer = document.getElementById('table-container');
    const wordsBody = document.getElementById('words-body');
    const stopToggle = document.getElementById('stop-words-toggle');

    const STOP_WORDS = new Set([
      'the','a','an','and','or','but','in','on','at','to','for','of','by','with',
      'from','as','is','was','are','were','be','been','being','have','has','had',
      'do','does','did','will','would','could','should','may','might','shall',
      'can','need','dare','ought','used','not','no','nor','none','nothing',
      'neither','so','very','too','quite','rather','some','any','all','both',
      'each','every','few','many','much','such','that','this','these','those',
      'i','me','my','myself','we','us','our','ours','ourselves','you','your',
      'yours','yourself','yourselves','he','him','his','himself','she','her',
      'hers','herself','it','its','itself','they','them','their','theirs',
      'themselves','what','which','who','whom','whose','when','where','why',
      'how','if','then','than','because','since','until','while','about',
      'between','through','during','before','after','above','below','up','down',
      'out','off','over','under','again','further','once','here','there',
      'only','just','also','now','then','get','got','got','make','made',
    ]);

    function getFreq(text, filterStop) {
      const raw = text.toLowerCase().replace(/[^a-z0-9\s'-]/g, '').trim();
      const parts = raw.split(/\s+/).filter(w => w.length > 1);
      const freq = {};
      for (const w of parts) {
        if (filterStop && STOP_WORDS.has(w)) continue;
        freq[w] = (freq[w] || 0) + 1;
      }
      return Object.entries(freq).sort((a, b) => b[1] - a[1]).slice(0, 80);
    }

    function drawCloud(entries) {
      const w = canvas.width;
      const h = canvas.height;
      ctx.clearRect(0, 0, w, h);

      if (!entries.length) return;

      const maxCount = entries[0][1];
      const palette = ['#6366f1','#8b5cf6','#ec4899','#f43f5e','#f97316','#eab308','#22c55e','#14b8a6','#06b6d4','#3b82f6'];

      const placed = [];
      const cx = w / 2;
      const cy = h / 2;

      for (let i = 0; i < entries.length; i++) {
        const [word, count] = entries[i];
        const ratio = count / maxCount;
        const fontSize = Math.max(12, Math.round(ratio * 48) + 14);
        const color = palette[i % palette.length];

        ctx.font = 'bold ' + fontSize + 'px sans-serif';
        const metrics = ctx.measureText(word);
        const tw = metrics.width;
        const th = fontSize * 1.2;

        const angle = (i % 2 === 0) ? 0 : 0;
        const radius = Math.min(w, h) * 0.38;
        const aStep = (Math.PI * 2) / Math.max(entries.length, 8);
        const a = aStep * i + (Math.random() - 0.5) * 0.3;

        let x = cx + Math.cos(a) * radius * (0.3 + 0.7 * (i / entries.length));
        let y = cy + Math.sin(a) * radius * (0.3 + 0.7 * (i / entries.length));

        x = Math.max(tw / 2 + 5, Math.min(w - tw / 2 - 5, x));
        y = Math.max(th / 2 + 5, Math.min(h - th / 2 - 5, y));

        ctx.save();
        ctx.translate(x + tw / 2, y + th / 2);
        ctx.rotate(angle);
        ctx.fillStyle = color;
        ctx.globalAlpha = 0.9;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.font = 'bold ' + fontSize + 'px sans-serif';
        ctx.fillText(word, 0, 0);
        ctx.restore();

        placed.push({ word, x, y, tw, th, angle });
      }
    }

    function generate() {
      const text = input.value.trim();
      if (!text) {
        cloudContainer.classList.add('hidden');
        tableContainer.classList.add('hidden');
        downloadBtn.disabled = true;
        return;
      }

      const filterStop = stopToggle.checked;
      const entries = getFreq(text, filterStop);
      if (!entries.length) {
        cloudContainer.classList.add('hidden');
        tableContainer.classList.add('hidden');
        downloadBtn.disabled = true;
        return;
      }

      drawCloud(entries);
      cloudContainer.classList.remove('hidden');
      downloadBtn.disabled = false;
      downloadBtn.textContent = 'Download PNG';
      downloadBtn.className = 'rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50';

      const maxCount = entries[0][1];
      wordsBody.innerHTML = entries.slice(0, 20).map(([word, count]) => {
        const pct = Math.round((count / maxCount) * 100);
        return '<tr><td class="px-4 py-3 font-medium text-slate-900">' + word + '</td><td class="px-4 py-3 text-slate-700">' + count + '</td><td class="px-4 py-3 text-slate-700">' + pct + '%</td></tr>';
      }).join('');
      tableContainer.classList.remove('hidden');
    }

    downloadBtn.addEventListener('click', () => {
      const link = document.createElement('a');
      link.download = 'keyword-cloud.png';
      link.href = canvas.toDataURL('image/png');
      link.click();
    });

    generateBtn.addEventListener('click', generate);

    clearBtn.addEventListener('click', () => {
      input.value = '';
      cloudContainer.classList.add('hidden');
      tableContainer.classList.add('hidden');
      downloadBtn.disabled = true;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      input.focus();
    });
  </script>
</ToolLayout>
