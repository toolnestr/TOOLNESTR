---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { categories, toolsByCategory, liveTools, tools } from '../data/tools.js';
import { site } from '../data/site.js';

const faqs = [
  { q: 'Are these tools really free?', a: `Yes. Every tool on ${site.name} is completely free to use, with no sign-up, no account and no limits.` },
  { q: 'Do I need to install anything?', a: 'No. All tools run right in your web browser on any device — phone, tablet or computer. There is nothing to download.' },
  { q: 'Are my files and text private?', a: 'Yes. Most tools (like the PDF, image, password and text tools) process everything directly in your browser, so your data never gets uploaded to a server.' },
  { q: 'Do the tools work on mobile?', a: 'Absolutely. The whole site is mobile-first and designed to work smoothly on phones and tablets as well as desktops.' },
];

// Structured data: tells Google this is a website + a list of FAQs.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', name: site.name, url: site.url, description: site.description },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-slate-50">
    <div class="mx-auto max-w-3xl px-4 py-14 text-center sm:py-20">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        Free online tools that just work
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-slate-600">
        {tools.length}+ fast, private tools for everyday tasks, creators and developers.
        No sign-up. No uploads. Everything runs in your browser.
      </p>

      <div class="mx-auto mt-8 max-w-md">
        <input
          id="tool-search"
          type="search"
          placeholder="Search tools… (e.g. word counter)"
          aria-label="Search tools"
          class="w-full rounded-full border border-slate-300 bg-white px-5 py-3 text-base shadow-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
        />
      </div>
    </div>
  </section>

  <!-- Tool categories -->
  <div class="mx-auto max-w-6xl px-4 pb-20">
    {categories.map((cat) => (
      <section id={cat.id} class="category-section scroll-mt-20 pt-12">
        <h2 class="mb-5 flex items-center gap-2 text-xl font-bold text-slate-900">
          <span>{cat.emoji}</span> {cat.name}
        </h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {toolsByCategory(cat.id).map((tool) => <ToolCard tool={tool} />)}
        </div>
      </section>
    ))}

    <p id="no-results" class="hidden py-16 text-center text-slate-500">
      No tools match your search yet — more are on the way!
    </p>
  </div>

  <!-- Why ToolNestr (adds helpful content + SEO depth) -->
  <section class="border-t border-slate-200 bg-white">
    <div class="mx-auto max-w-5xl px-4 py-14">
      <h2 class="text-center text-2xl font-bold tracking-tight text-slate-900">Why use {site.name}?</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600">
        {site.name} brings together {tools.length}+ free online tools in one fast, clean place. Whether
        you’re a student, a creator or a developer, you’ll find calculators, converters, text helpers,
        PDF tools, image utilities and more — all built to do one job well.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-slate-200 p-5">
          <div class="text-2xl">⚡</div>
          <h3 class="mt-2 font-semibold text-slate-900">Instant &amp; free</h3>
          <p class="mt-1 text-sm text-slate-600">Every tool is free, with no sign-up and no limits. Results appear instantly as you type.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <div class="text-2xl">🔒</div>
          <h3 class="mt-2 font-semibold text-slate-900">Private by design</h3>
          <p class="mt-1 text-sm text-slate-600">Most tools run entirely in your browser, so your files and text never leave your device.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <div class="text-2xl">📱</div>
          <h3 class="mt-2 font-semibold text-slate-900">Works everywhere</h3>
          <p class="mt-1 text-sm text-slate-600">A mobile-first design that works smoothly on phones, tablets and computers alike.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-5">
          <div class="text-2xl">🧰</div>
          <h3 class="mt-2 font-semibold text-slate-900">All in one place</h3>
          <p class="mt-1 text-sm text-slate-600">No more bookmarking ten different sites — your everyday tools live together here.</p>
        </div>
      </div>

      <!-- FAQ -->
      <h2 class="mt-14 text-center text-2xl font-bold tracking-tight text-slate-900">Frequently asked questions</h2>
      <div class="mx-auto mt-6 max-w-3xl space-y-4">
        {faqs.map((f) => (
          <div class="rounded-xl border border-slate-200 p-4">
            <h3 class="font-semibold text-slate-900">{f.q}</h3>
            <p class="mt-1 text-sm text-slate-600">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tiny search filter (runs in the browser) -->
  <script is:inline>
    const input = document.getElementById('tool-search');
    const cards = Array.from(document.querySelectorAll('.tool-card'));
    const sections = Array.from(document.querySelectorAll('.category-section'));
    const noResults = document.getElementById('no-results');

    input?.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      cards.forEach((card) => {
        const match = card.dataset.name.includes(q);
        card.style.display = match ? '' : 'none';
      });
      let anyVisible = false;
      sections.forEach((section) => {
        const visible = section.querySelectorAll('.tool-card:not([style*="display: none"])').length;
        section.style.display = visible ? '' : 'none';
        if (visible) anyVisible = true;
      });
      noResults.classList.toggle('hidden', anyVisible);
    });
  </script>
</BaseLayout>
