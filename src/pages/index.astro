---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories, liveTools, totalInCategory, flagshipTools } from '../data/tools.js';
import { site } from '../data/site.js';

const faqs = [
  { q: 'Are these tools really free?', a: `Yes. Every tool on ${site.name} is completely free to use, with no sign-up, no account and no limits.` },
  { q: 'Do I need to install anything?', a: 'No. All tools run right in your web browser on any device — phone, tablet or computer. There is nothing to download.' },
  { q: 'Are my files and text private?', a: 'Yes. Most tools (like the PDF, image, password and text tools) process everything directly in your browser, so your data never gets uploaded to a server.' },
  { q: 'Do the tools work on mobile?', a: 'Absolutely. The whole site is mobile-first and designed to work smoothly on phones and tablets as well as desktops.' },
];

const catIcons = {
  networking: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>',
  everyday: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.412-.063.83-.128 1.25-.173A22.24 22.24 0 0112 5.5c.75 0 1.495.057 2.25.107 1.102.064 2.18.159 3.25.271M6 6.878a43.115 43.115 0 006.75 1.247M6 6.878a45.336 45.336 0 006.75.247M18 6.878a43.042 43.042 0 00-6.75.247m0 0A45.647 45.647 0 0118 7.185m-6.75.19A45.634 45.634 0 016 7.185m0 0A45.336 45.336 0 013 7.435v11.19a45.336 45.336 0 003 .25m0 0A45.647 45.647 0 016 19.065m0 0A45.336 45.336 0 013 19.315m12-6.19v.75a.75.75 0 01-.75.75h-4.5a.75.75 0 01-.75-.75v-.75m3-5.25v.75m0 0h-3M6 19.065a45.336 45.336 0 01-3-.25m12 .25a45.336 45.336 0 013 .25M3 7.435l3 11.63m12-11.63l-3 11.63" /></svg>',
  health: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>',
  finance: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  math: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" /></svg>',
  pdf: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>',
  creators: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>',
  developers: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>',
  engineering: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>',
  physics: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><circle cx="12" cy="12" r="1.75" fill="currentColor" stroke="none" /><ellipse cx="12" cy="12" rx="10" ry="4.25" /><ellipse cx="12" cy="12" rx="10" ry="4.25" transform="rotate(60 12 12)" /><ellipse cx="12" cy="12" rx="10" ry="4.25" transform="rotate(120 12 12)" /></svg>',
  chemistry: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>',
  biology: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3.75c0 3-3 4.5-3 8.25 0 3.75 3 5.25 3 8.25M15 3.75c0 3 3 4.5 3 8.25 0 3.75-3 5.25-3 8.25M6.75 7.5h10.5M6.75 16.5h10.5" /></svg>',
  construction: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" /></svg>',
  cooking: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.87v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.38a48.474 48.474 0 00-6-.37c-2.032 0-4.034.125-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.17c0 .62-.504 1.124-1.125 1.124H4.125A1.125 1.125 0 013 20.625V17.78c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 15.5" /></svg>',
  automotive: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.75 9.75a.75.75 0 010-1.06l4.258-4.258A1.5 1.5 0 019.621 4h4.758a1.5 1.5 0 011.061.44l4.259 4.258a.75.75 0 010 1.06L18 12m-6 6v-3" /></svg>',
  images: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>',
  security: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>',
  text: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>',
  seo: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>',
  converters: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>',
  'time-date': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  charts: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" /></svg>',
  clothing: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5L4.5 7.5 3 10.5l3 1.5v9h12v-9l3-1.5-1.5-3L15 4.5m-6 0a3 3 0 006 0m-6 0h6" /></svg>',
  islamic: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" /></svg>',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', name: site.name, url: site.url, description: site.description },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout jsonLd={jsonLd} geist={true}>
  <div class="geist">
    <!-- ─────────────── HERO ─────────────── -->
    <section class="g-hero">
      <div class="g-mesh" aria-hidden="true"></div>
      <div class="g-container g-hero-inner">
        <p class="g-eyebrow reveal">{site.name} · {liveTools.length}+ free tools</p>
        <h1 class="g-display reveal reveal-delay-2">
          Free online tools<br />that just work.
        </h1>
        <p class="g-lead reveal reveal-delay-3">
          Fast, private tools for everyday tasks, creators and developers.
          No sign-up. No uploads. Everything runs in your browser.
        </p>
        <div class="g-hero-cta reveal reveal-delay-4">
          <a href="#flagship" class="g-btn g-btn-primary">Explore flagship tools</a>
          <a href="#categories" class="g-btn g-btn-secondary">Browse all {liveTools.length}+ tools</a>
        </div>
      </div>
    </section>

    <!-- ─────────────── FLAGSHIP TOOLS ─────────────── -->
    <section id="flagship" class="g-band g-band-flag scroll-mt-16">
      <div class="g-container">
        <p class="g-eyebrow reveal">Flagship tools</p>
        <h2 class="g-heading reveal reveal-delay-2">The tools people come back for</h2>
        <p class="g-sub reveal reveal-delay-3">
          Our most powerful, interactive tools — each one a reason on its own to bookmark {site.name}.
        </p>
        <div class="g-grid g-grid-flag stagger-children">
          {flagshipTools.map((t) => (
            <a href={`/tools/${t.slug}/`} class="g-card g-card-flagship">
              <div class="g-card-top">
                <span class="g-emoji-tile">{t.emoji}</span>
                <span class="g-tag">Flagship</span>
              </div>
              <h3 class="g-card-title">{t.title}</h3>
              <p class="g-card-desc">{t.short}</p>
              <span class="g-card-link">
                Open tool
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ─────────────── CATEGORIES ─────────────── -->
    <section id="categories" class="g-band scroll-mt-16">
      <div class="g-container">
        <p class="g-eyebrow reveal">Browse by category</p>
        <h2 class="g-heading reveal reveal-delay-2">{categories.length} categories, {liveTools.length}+ tools</h2>
        <p class="g-sub reveal reveal-delay-3">Everything organised so you can find the right tool in seconds.</p>
        <div class="g-grid g-grid-cat3 stagger-children">
          {categories.map((cat) => {
            const total = totalInCategory(cat.id);
            return (
              <a href={`/tools/${cat.id}/`} class="g-card g-card-cat">
                <span class="g-cat-icon" set:html={catIcons[cat.id]} />
                <span class="g-cat-body">
                  <span class="g-card-title">{cat.name}</span>
                  <span class="g-cat-count">{total} tool{total !== 1 ? 's' : ''}</span>
                </span>
                <svg class="g-cat-arrow h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ─────────────── STATS ─────────────── -->
    <section class="g-band g-band-alt">
      <div class="g-container">
        <div class="g-stats">
          <div class="g-stat reveal">
            <div class="count-up g-stat-num" data-count={liveTools.length} data-suffix="+">{liveTools.length}+</div>
            <div class="g-stat-label">Free tools</div>
          </div>
          <div class="g-stat reveal reveal-delay-2">
            <div class="count-up g-stat-num" data-count={categories.length}>{categories.length}</div>
            <div class="g-stat-label">Categories</div>
          </div>
          <div class="g-stat reveal reveal-delay-3">
            <div class="count-up g-stat-num" data-count="100" data-suffix="%">100%</div>
            <div class="g-stat-label">Browser-based</div>
          </div>
          <div class="g-stat reveal reveal-delay-4">
            <div class="g-stat-num">Free</div>
            <div class="g-stat-label">No sign-up, ever</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────── WHY ─────────────── -->
    <section class="g-band">
      <div class="g-container">
        <p class="g-eyebrow reveal">Why {site.name}</p>
        <h2 class="g-heading reveal reveal-delay-2">Built to be fast, private and free</h2>
        <div class="g-grid g-grid-4 stagger-children">
          <div class="g-card g-card-feature">
            <span class="g-feat-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg></span>
            <h3 class="g-card-title">Instant &amp; free</h3>
            <p class="g-card-desc">Every tool is free, with no sign-up and no limits.</p>
          </div>
          <div class="g-card g-card-feature">
            <span class="g-feat-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg></span>
            <h3 class="g-card-title">Private by design</h3>
            <p class="g-card-desc">Most tools run entirely in your browser, so your data never leaves your device.</p>
          </div>
          <div class="g-card g-card-feature">
            <span class="g-feat-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg></span>
            <h3 class="g-card-title">Works everywhere</h3>
            <p class="g-card-desc">Mobile-first design that works smoothly on phones, tablets and computers.</p>
          </div>
          <div class="g-card g-card-feature">
            <span class="g-feat-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg></span>
            <h3 class="g-card-title">All in one place</h3>
            <p class="g-card-desc">No more bookmarking ten different sites for ten small jobs.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────── FAQ ─────────────── -->
    <section class="g-band g-band-alt">
      <div class="g-container g-narrow">
        <p class="g-eyebrow reveal">FAQ</p>
        <h2 class="g-heading reveal reveal-delay-2">Frequently asked questions</h2>
        <div class="g-faq-list">
          {faqs.map((f, i) => (
            <div class="g-faq faq-item reveal" style={`transition-delay: ${i * 80}ms`}>
              <button class="g-faq-btn faq-btn" aria-expanded="false">
                <span>{f.q}</span>
                <svg class="faq-chevron h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="accordion-content">
                <div><p class="g-faq-a">{f.a}</p></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─────────────── CTA ─────────────── -->
    <section class="g-band g-cta">
      <div class="g-container">
        <h2 class="g-display g-cta-title reveal">Pick a tool. Get it done.</h2>
        <div class="g-hero-cta reveal reveal-delay-2">
          <a href="#categories" class="g-btn g-btn-primary">Browse all tools</a>
          <a href="/tools/seo-analyzer/" class="g-btn g-btn-secondary">Try the SEO Analyzer</a>
        </div>
      </div>
    </section>
  </div>

  <style>
    /* ── Geist palette (Vercel), scoped to the landing page only ── */
    .geist {
      --ink: #171717;
      --body: #4d4d4d;
      --mute: #8f8f8f;
      --faint: #a1a1a1;
      --hairline: #ebebeb;
      --hairline-soft: #f2f2f2;
      --canvas: #fafafa;
      --elevated: #ffffff;
      --link: #0070f3;
      font-family: var(--font-geist);
      background: var(--canvas);
      color: var(--body);
    }
    :global(.dark) .geist {
      --ink: #ededed;
      --body: #a1a1a1;
      --mute: #8f8f8f;
      --faint: #6f6f6f;
      --hairline: #1f1f1f;
      --hairline-soft: #161616;
      --canvas: #0a0a0a;
      --elevated: #101010;
    }

    .g-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
    .g-narrow { max-width: 760px; }

    /* ── Hero ── */
    .g-hero {
      position: relative;
      overflow: hidden;
      background: var(--canvas);
      border-bottom: 1px solid var(--hairline);
    }
    .g-hero-inner { position: relative; z-index: 1; padding: 112px 24px 96px; text-align: center; }
    .g-mesh {
      position: absolute; inset: -20% -10% auto -10%; height: 620px; z-index: 0;
      background:
        radial-gradient(38% 55% at 18% 22%, rgba(0, 124, 240, 0.28), transparent 70%),
        radial-gradient(34% 50% at 82% 18%, rgba(0, 223, 216, 0.24), transparent 70%),
        radial-gradient(40% 55% at 74% 78%, rgba(121, 40, 202, 0.24), transparent 70%),
        radial-gradient(36% 50% at 24% 82%, rgba(255, 0, 128, 0.20), transparent 70%),
        radial-gradient(50% 50% at 50% 50%, rgba(249, 203, 40, 0.16), transparent 70%);
      filter: blur(56px);
      opacity: 0.9;
      pointer-events: none;
    }
    :global(.dark) .g-mesh { opacity: 0.55; }

    .g-eyebrow {
      font-family: var(--font-geist-mono);
      font-size: 12px; font-weight: 500; line-height: 16px;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--mute); margin: 0;
    }
    .g-display {
      font-family: var(--font-geist);
      font-weight: 600; color: var(--ink);
      font-size: clamp(38px, 6vw, 68px);
      line-height: 1.02; letter-spacing: -0.045em;
      margin: 18px 0 0;
    }
    .g-lead {
      max-width: 560px; margin: 22px auto 0;
      font-size: 18px; line-height: 28px; color: var(--body);
    }
    .g-hero-cta { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 34px; }

    /* ── Buttons: rounded pills ── */
    .g-btn {
      display: inline-flex; align-items: center; justify-content: center;
      height: 44px; padding: 0 20px; border-radius: 100px;
      font-family: var(--font-geist); font-size: 15px; font-weight: 500;
      transition: transform .15s ease, background-color .15s ease, border-color .15s ease, color .15s ease;
      white-space: nowrap;
    }
    .g-btn-primary { background: var(--ink); color: var(--canvas); border: 1px solid var(--ink); }
    .g-btn-primary:hover { transform: translateY(-1px); background: #000; }
    :global(.dark) .g-btn-primary { background: var(--ink); color: #0a0a0a; }
    :global(.dark) .g-btn-primary:hover { background: #fff; }
    .g-btn-secondary { background: var(--elevated); color: var(--ink); border: 1px solid var(--hairline); }
    .g-btn-secondary:hover { transform: translateY(-1px); border-color: var(--mute); }

    /* ── Bands ── */
    .g-band { padding: 88px 0; background: var(--canvas); border-bottom: 1px solid var(--hairline); }
    .g-band-alt { background: var(--hairline-soft); }
    /* Flagship band: a soft gradient wash (echoing the hero mesh) so the whole
       featured section reads as prominent instead of blending into the page. */
    .g-band-flag { background: var(--hairline-soft); }
    .g-heading {
      font-family: var(--font-geist); font-weight: 600; color: var(--ink);
      font-size: clamp(26px, 3.4vw, 34px); line-height: 1.15; letter-spacing: -0.035em;
      margin: 14px 0 0;
    }
    .g-sub { margin: 12px 0 0; font-size: 16px; line-height: 24px; color: var(--body); max-width: 620px; }

    /* ── Grids ── */
    .g-grid { display: grid; gap: 16px; margin-top: 40px; }
    .g-grid-flag { grid-template-columns: repeat(3, 1fr); }
    .g-grid-cat3 { grid-template-columns: repeat(3, 1fr); }
    .g-grid-4 { grid-template-columns: repeat(4, 1fr); }

    /* ── Cards ── */
    .g-card {
      background: var(--elevated); border: 1px solid var(--hairline);
      border-radius: 12px; padding: 20px;
      transition: border-color .18s ease, transform .18s ease, box-shadow .18s ease;
    }
    a.g-card { display: flex; flex-direction: column; }
    a.g-card:hover { border-color: var(--mute); transform: translateY(-2px); box-shadow: 0 1px 2px rgba(0,0,0,.04), 0 8px 24px -12px rgba(0,0,0,.12); }

    .g-card-top { display: flex; align-items: center; justify-content: space-between; }
    .g-emoji-tile {
      display: inline-flex; align-items: center; justify-content: center;
      height: 44px; width: 44px; border-radius: 11px; font-size: 24px; line-height: 1;
      background: var(--hairline-soft); border: 1px solid var(--hairline);
    }
    .g-tag {
      font-family: var(--font-geist-mono); font-size: 10px; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.08em; color: var(--mute);
      border: 1px solid var(--hairline); border-radius: 100px; padding: 3px 8px;
    }
    .g-card-title { font-family: var(--font-geist); font-weight: 600; color: var(--ink); font-size: 16px; letter-spacing: -0.02em; line-height: 1.3; }
    .g-card-flagship .g-card-title { margin-top: 14px; }
    .g-card-desc { margin-top: 6px; font-size: 14px; line-height: 20px; color: var(--body); flex: 1; }
    .g-card-link {
      display: inline-flex; align-items: center; gap: 6px; margin-top: 16px;
      font-size: 14px; font-weight: 500; color: var(--ink);
    }
    a.g-card:hover .g-card-link { gap: 9px; }
    .g-card-link svg { transition: transform .18s ease; }

    /* ── Flagship card: monochrome, distinguished by a thin ink top bar and
       a solid ink "Flagship" badge (Vercel-style, no colour) ── */
    .g-card-flagship { position: relative; overflow: hidden; padding-top: 22px; }
    .g-card-flagship::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: var(--ink);
    }
    a.g-card-flagship:hover {
      border-color: var(--mute); transform: translateY(-3px);
      box-shadow: 0 1px 2px rgba(0,0,0,.05), 0 14px 34px -16px rgba(0,0,0,.22);
    }
    /* Filled ink "Flagship" badge (inverted text) */
    .g-card-flagship .g-tag {
      background: var(--ink); color: var(--canvas); border-color: transparent;
    }

    /* Category card (horizontal) */
    .g-card-cat { flex-direction: row; align-items: center; gap: 14px; }
    .g-cat-icon {
      display: inline-flex; align-items: center; justify-content: center;
      height: 40px; width: 40px; flex-shrink: 0; border-radius: 10px;
      background: var(--hairline-soft); border: 1px solid var(--hairline); color: var(--ink);
    }
    .g-cat-body { display: flex; flex-direction: column; min-width: 0; }
    .g-cat-count { font-size: 13px; color: var(--mute); margin-top: 2px; }
    .g-cat-arrow { margin-left: auto; flex-shrink: 0; color: var(--faint); transition: transform .18s ease, color .18s ease; }
    a.g-card-cat:hover .g-cat-arrow { color: var(--ink); transform: translateX(2px); }

    /* Feature card */
    .g-card-feature .g-card-desc { margin-top: 8px; }
    .g-feat-icon {
      display: inline-flex; align-items: center; justify-content: center;
      height: 40px; width: 40px; border-radius: 10px; margin-bottom: 14px;
      background: var(--hairline-soft); border: 1px solid var(--hairline); color: var(--ink);
    }

    /* ── Stats ── */
    .g-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; text-align: center; }
    .g-stat { padding: 8px; }
    .g-stat-num { font-family: var(--font-geist); font-weight: 600; color: var(--ink); font-size: 34px; letter-spacing: -0.04em; font-variant-numeric: tabular-nums; }
    .g-stat-label { margin-top: 4px; font-size: 13px; color: var(--mute); }

    /* ── FAQ ── */
    .g-faq-list { margin-top: 32px; display: flex; flex-direction: column; gap: 10px; }
    .g-faq { background: var(--elevated); border: 1px solid var(--hairline); border-radius: 12px; overflow: hidden; }
    .g-faq-btn {
      width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px;
      padding: 16px 20px; text-align: left; font-family: var(--font-geist);
      font-weight: 500; font-size: 15px; color: var(--ink); background: none; border: 0; cursor: pointer;
    }
    .g-faq-btn .faq-chevron { color: var(--faint); flex-shrink: 0; transition: transform .3s ease; }
    .g-faq-a { padding: 0 20px 16px; font-size: 14px; line-height: 22px; color: var(--body); margin: 0; }

    /* ── CTA ── */
    .g-cta { text-align: center; border-bottom: 0; }
    .g-cta-title { font-size: clamp(30px, 4.5vw, 48px); }
    .g-cta .g-hero-cta { margin-top: 28px; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .g-grid-flag, .g-grid-cat3, .g-grid-4 { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      /* Keep tools two-per-row on phones (flagship + categories); only the
         text-heavy feature cards drop to a single column. */
      .g-grid-flag, .g-grid-cat3 { grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .g-grid-4 { grid-template-columns: 1fr; }
      .g-stats { grid-template-columns: repeat(2, 1fr); gap: 24px 16px; }
      .g-hero-inner { padding: 84px 24px 72px; }
      .g-band { padding: 64px 0; }
      .g-btn { width: 100%; }
      .g-hero-cta { flex-direction: column; }

      /* Compact flagship cards so two fit cleanly side by side */
      .g-card-flagship { padding: 18px 14px 14px; }
      .g-card-flagship .g-emoji-tile { height: 38px; width: 38px; font-size: 20px; border-radius: 10px; }
      .g-card-flagship .g-tag { font-size: 9px; padding: 2px 6px; }
      .g-card-flagship .g-card-title { font-size: 14px; margin-top: 10px; }
      .g-card-flagship .g-card-desc {
        font-size: 12px; line-height: 17px; margin-top: 5px;
        display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
      }
      .g-card-flagship .g-card-link { margin-top: 12px; font-size: 13px; }

      /* Category cards go vertical (icon over label) so two fit per row */
      .g-card-cat { flex-direction: column; align-items: flex-start; gap: 10px; padding: 14px; }
      .g-card-cat .g-cat-arrow { display: none; }
      .g-card-cat .g-card-title { font-size: 14px; }
    }
  </style>

  <script is:inline>
    (function () {
      if (!('IntersectionObserver' in window)) return;
      var els = document.querySelectorAll('.reveal, .stagger-children');
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.12 });
      els.forEach(function (el) { obs.observe(el); });
    })();

    // ── Animated count-up for the stats ──
    (function () {
      var counters = document.querySelectorAll('.count-up');
      if (!counters.length) return;
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      function run(el) {
        var target = parseInt(el.getAttribute('data-count'), 10) || 0;
        var suffix = el.getAttribute('data-suffix') || '';
        var start = null, dur = 1400;
        function step(ts) {
          if (!start) start = ts;
          var p = Math.min((ts - start) / dur, 1);
          var eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }
      if (reduce || !('IntersectionObserver' in window)) return;
      var cobs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { run(e.target); cobs.unobserve(e.target); }
        });
      }, { threshold: 0.5 });
      counters.forEach(function (c) {
        var suffix = c.getAttribute('data-suffix') || '';
        c.textContent = '0' + suffix;
        cobs.observe(c);
      });
    })();

    document.querySelectorAll('.faq-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var content = btn.nextElementSibling;
        var chevron = btn.querySelector('.faq-chevron');
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        content.classList.toggle('open', !expanded);
        chevron.style.transform = !expanded ? 'rotate(-180deg)' : 'rotate(0deg)';
      });
    });
  </script>
</BaseLayout>
