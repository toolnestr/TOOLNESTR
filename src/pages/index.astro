---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { categories, toolsByCategory, liveTools, tools } from '../data/tools.js';
import { site } from '../data/site.js';

// Structured data: tells Google this is a collection of tools.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.description,
};
---

<BaseLayout jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-slate-50">
    <div class="mx-auto max-w-3xl px-4 py-14 text-center sm:py-20">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        Free online tools that just work
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-slate-600">
        {tools.length}+ fast, private tools for everyday tasks, creators and developers.
        No sign-up. No uploads. Everything runs in your browser.
      </p>

      <div class="mx-auto mt-8 max-w-md">
        <input
          id="tool-search"
          type="search"
          placeholder="Search tools… (e.g. word counter)"
          aria-label="Search tools"
          class="w-full rounded-full border border-slate-300 bg-white px-5 py-3 text-base shadow-sm outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100"
        />
      </div>
    </div>
  </section>

  <!-- Tool categories -->
  <div class="mx-auto max-w-6xl px-4 pb-20">
    {categories.map((cat) => (
      <section id={cat.id} class="category-section scroll-mt-20 pt-12">
        <h2 class="mb-5 flex items-center gap-2 text-xl font-bold text-slate-900">
          <span>{cat.emoji}</span> {cat.name}
        </h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {toolsByCategory(cat.id).map((tool) => <ToolCard tool={tool} />)}
        </div>
      </section>
    ))}

    <p id="no-results" class="hidden py-16 text-center text-slate-500">
      No tools match your search yet — more are on the way!
    </p>
  </div>

  <!-- Tiny search filter (runs in the browser) -->
  <script is:inline>
    const input = document.getElementById('tool-search');
    const cards = Array.from(document.querySelectorAll('.tool-card'));
    const sections = Array.from(document.querySelectorAll('.category-section'));
    const noResults = document.getElementById('no-results');

    input?.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      cards.forEach((card) => {
        const match = card.dataset.name.includes(q);
        card.style.display = match ? '' : 'none';
      });
      let anyVisible = false;
      sections.forEach((section) => {
        const visible = section.querySelectorAll('.tool-card:not([style*="display: none"])').length;
        section.style.display = visible ? '' : 'none';
        if (visible) anyVisible = true;
      });
      noResults.classList.toggle('hidden', anyVisible);
    });
  </script>
</BaseLayout>
