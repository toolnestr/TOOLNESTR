---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories, liveTools, totalInCategory } from '../data/tools.js';
import { site } from '../data/site.js';

const faqs = [
  { q: 'Are these tools really free?', a: `Yes. Every tool on ${site.name} is completely free to use, with no sign-up, no account and no limits.` },
  { q: 'Do I need to install anything?', a: 'No. All tools run right in your web browser on any device — phone, tablet or computer. There is nothing to download.' },
  { q: 'Are my files and text private?', a: 'Yes. Most tools (like the PDF, image, password and text tools) process everything directly in your browser, so your data never gets uploaded to a server.' },
  { q: 'Do the tools work on mobile?', a: 'Absolutely. The whole site is mobile-first and designed to work smoothly on phones and tablets as well as desktops.' },
];

const catIcons = {
  networking: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>',
  everyday: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.412-.063.83-.128 1.25-.173A22.24 22.24 0 0112 5.5c.75 0 1.495.057 2.25.107 1.102.064 2.18.159 3.25.271M6 6.878a43.115 43.115 0 006.75 1.247M6 6.878a45.336 45.336 0 006.75.247M18 6.878a43.042 43.042 0 00-6.75.247m0 0A45.647 45.647 0 0118 7.185m-6.75.19A45.634 45.634 0 016 7.185m0 0A45.336 45.336 0 013 7.435v11.19a45.336 45.336 0 003 .25m0 0A45.647 45.647 0 016 19.065m0 0A45.336 45.336 0 013 19.315m12-6.19v.75a.75.75 0 01-.75.75h-4.5a.75.75 0 01-.75-.75v-.75m3-5.25v.75m0 0h-3M6 19.065a45.336 45.336 0 01-3-.25m12 .25a45.336 45.336 0 013 .25M3 7.435l3 11.63m12-11.63l-3 11.63" /></svg>',
  health: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>',
  finance: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  math: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" /></svg>',
  pdf: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>',
  creators: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>',
  developers: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>',
  engineering: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>',
  construction: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" /></svg>',
  cooking: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.87v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.38a48.474 48.474 0 00-6-.37c-2.032 0-4.034.125-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.17c0 .62-.504 1.124-1.125 1.124H4.125A1.125 1.125 0 013 20.625V17.78c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 15.5" /></svg>',
  automotive: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.75 9.75a.75.75 0 010-1.06l4.258-4.258A1.5 1.5 0 019.621 4h4.758a1.5 1.5 0 011.061.44l4.259 4.258a.75.75 0 010 1.06L18 12m-6 6v-3" /></svg>',
  images: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>',
  security: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>',
  text: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>',
  seo: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>',
  converters: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>',
  'time-date': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  charts: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" /></svg>',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', name: site.name, url: site.url, description: site.description },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900">
    <!-- Decorative backdrop: dotted grid + soft glows (purely cosmetic) -->
    <div class="bg-grid absolute inset-0 opacity-[0.15]" aria-hidden="true"></div>
    <div class="animate-blob-pulse pointer-events-none absolute -top-24 left-1/4 h-72 w-72 rounded-full bg-indigo-500/25 blur-3xl" aria-hidden="true"></div>
    <div class="animate-blob-pulse pointer-events-none absolute -bottom-32 right-1/4 h-80 w-80 rounded-full bg-violet-500/20 blur-3xl" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-3xl px-4 py-20 text-center sm:py-28">
      <span class="badge-rose inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.9 5.6L19.5 9l-4.5 3.3L16.7 18 12 14.7 7.3 18l1.7-5.7L4.5 9l5.6-1.4L12 2z"/></svg>
        {liveTools.length}+ free tools · no sign-up
      </span>
      <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Free online tools that <span class="bg-gradient-to-r from-rose-300 to-violet-300 bg-clip-text text-transparent">just work</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-slate-300">
        Fast, private tools for everyday tasks, creators and developers.
        No sign-up. No uploads. Everything runs in your browser.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="#categories" class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-semibold text-slate-900 shadow-lg shadow-indigo-950/30 transition hover:-translate-y-0.5 hover:bg-slate-100 sm:w-auto">
          Browse all tools
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </a>
        <a href="/tools/seo-analyzer" class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/10 sm:w-auto">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          Try the SEO Analyzer
        </a>
      </div>
    </div>
  </section>

  <div id="categories" class="mx-auto max-w-6xl px-4 pb-16">
    <div class="-mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => {
        const total = totalInCategory(cat.id);
        return (
          <a
            href={`/tools/${cat.id}/`}
            class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-indigo-300 hover:shadow-lg hover:shadow-indigo-100/60 dark:border-slate-700 dark:bg-slate-800/60 dark:hover:border-indigo-500/40"
          >
            <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-50 to-violet-50 text-indigo-600 dark:from-indigo-500/20 dark:to-violet-500/20 dark:text-indigo-400" set:html={catIcons[cat.id]} />
            <div class="min-w-0">
              <h3 class="font-semibold text-slate-900 dark:text-white">{cat.name}</h3>
              <p class="mt-0.5 text-sm text-slate-500 dark:text-slate-400">{total} tool{total !== 1 ? 's' : ''}</p>
            </div>
            <svg class="ml-auto h-5 w-5 shrink-0 text-slate-300 transition group-hover:translate-x-0.5 group-hover:text-indigo-500 dark:text-slate-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
          </a>
        );
      })}
    </div>
  </div>

  <section class="border-t border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-800/30">
    <div class="mx-auto max-w-5xl px-4 py-10">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        <div class="reveal">
          <div class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{liveTools.length}+</div>
          <div class="mt-1 text-xs text-slate-500">Free tools</div>
        </div>
        <div class="reveal reveal-delay-2">
          <div class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">{categories.length}</div>
          <div class="mt-1 text-xs text-slate-500">Categories</div>
        </div>
        <div class="reveal reveal-delay-3">
          <div class="text-2xl font-bold text-violet-600 dark:text-violet-400">100%</div>
          <div class="mt-1 text-xs text-slate-500">Browser-based</div>
        </div>
        <div class="reveal reveal-delay-4">
          <div class="text-2xl font-bold text-rose-600 dark:text-rose-400">No sign-up</div>
          <div class="mt-1 text-xs text-slate-500">Ever</div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-gradient-to-b from-white to-slate-50 dark:border-slate-700 dark:from-slate-900 dark:to-slate-800/30">
    <div class="mx-auto max-w-5xl px-4 py-16">
      <h2 class="text-center text-2xl font-bold tracking-tight text-slate-900 dark:text-white reveal">Why use {site.name}?</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600 dark:text-slate-400 reveal reveal-delay-2">
        {site.name} brings together {liveTools.length}+ free online tools in one fast, clean place.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4 stagger-children">
        <div class="gradient-border-card p-6">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-rose-500 text-white shadow-sm">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Instant &amp; free</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Every tool is free, with no sign-up and no limits.</p>
        </div>
        <div class="gradient-border-card p-6">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-400 to-violet-500 text-white shadow-sm">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Private by design</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Most tools run entirely in your browser, so your data never leaves your device.</p>
        </div>
        <div class="gradient-border-card p-6">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-emerald-400 to-teal-500 text-white shadow-sm">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Works everywhere</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Mobile-first design that works smoothly on phones, tablets and computers.</p>
        </div>
        <div class="gradient-border-card p-6">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-rose-400 to-pink-500 text-white shadow-sm">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" /></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">All in one place</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">No more bookmarking ten different sites.</p>
        </div>
      </div>

      <h2 class="mt-16 text-center text-2xl font-bold tracking-tight text-slate-900 dark:text-white reveal">Frequently asked questions</h2>
      <div class="mx-auto mt-6 max-w-3xl space-y-3">
        {faqs.map((f, i) => (
          <div class="faq-item rounded-xl border border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-800/50 reveal" style={`transition-delay: ${i * 100}ms`}>
            <button class="faq-btn flex w-full items-center justify-between px-5 py-4 text-left font-medium text-slate-900 dark:text-white" aria-expanded="false">
              <span>{f.q}</span>
              <svg class="faq-chevron h-4 w-4 flex-shrink-0 text-slate-400 transition duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="accordion-content">
              <div>
                <p class="px-5 pb-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{f.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      if (!('IntersectionObserver' in window)) return;
      var els = document.querySelectorAll('.reveal, .stagger-children');
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.15 });
      els.forEach(function (el) { obs.observe(el); });
    })();

    document.querySelectorAll('.faq-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var content = btn.nextElementSibling;
        var chevron = btn.querySelector('.faq-chevron');
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        content.classList.toggle('open', !expanded);
        chevron.style.transform = !expanded ? 'rotate(-180deg)' : 'rotate(0deg)';
      });
    });
  </script>
</BaseLayout>
