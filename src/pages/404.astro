---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you are looking for does not exist on ToolNestr.">
  <div class="mx-auto max-w-lg px-4 py-20 text-center">
    <h1 class="text-6xl font-bold text-indigo-600">404</h1>
    <p class="mt-4 text-lg text-slate-600">The page you are looking for does not exist.</p>
    <a href="/" class="mt-6 inline-block rounded-xl bg-indigo-600 px-6 py-3 font-medium text-white transition hover:bg-indigo-700">
      Back to Home
    </a>
  </div>
</BaseLayout>
