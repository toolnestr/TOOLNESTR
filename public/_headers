# Cloudflare Pages headers — improves security score + caching.
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com; connect-src 'self' https://toolnestr.toolnestr.workers.dev https://api.mail.tm https://1.1.1.1 https://cloudflare.com https://google.com https://earthquake.usgs.gov https://api.aladhan.com https://geocoding-api.open-meteo.com https://api.frankfurter.app; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'

# Long cache for fingerprinted build assets (safe — filenames change on update)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800
